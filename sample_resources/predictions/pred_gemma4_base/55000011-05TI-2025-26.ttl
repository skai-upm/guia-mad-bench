# Competencies
:comp_CE1 rdf:type guide:Competency ;
    guide:competencyCode "CE1" ;
    guide:competencyDescription "Capacidad para la resolución de los problemas matemáticos que puedan plantarse en la ingeniería. Aptitud para aplicar los conocimientos sobre: álgebra lineal; geometría; geometría diferencial; cálculo diferencial e integral; ecuaciones diferenciales ordinarias y en derivadas parciales; métodos numéricos; algorítmica numérica; optimización" .

:comp_CG1 rdf:type guide:Competency ;
    guide:competencyCode "CG1" ;
    guide:competencyDescription "Conocer y aplicar conocimientos de ciencias y tecnologías básicas a la práctica de la Ingeniería Industrial." .

:comp_CG10 rdf:type guide:Competency ;
    guide:competencyCode "CG10" ;
    guide:competencyDescription "Capacidad para generar nuevas ideas (Creatividad)." .

:comp_CG2 rdf:type guide:Competency ;
    guide:competencyCode "CG2" ;
    guide:competencyDescription "Poseer capacidad para diseñar, desarrollar, implementar, gestionar y mejorar productos, sistemas y procesos en los distintos ámbitos industriales..." .

:comp_CG3 rdf:type guide:Competency ;
    guide:competencyCode "CG3" ;
    guide:competencyDescription "Aplicar los conocimientos adquiridos para identificar, formular y resolver problemas dentro de contextos amplios y multidisciplinarios..." .

:comp_CG6 rdf:type guide:Competency ;
    guide:competencyCode "CG6" ;
    guide:competencyDescription "Poseer habilidades de aprendizaje que permitan continuar estudiando a la largo de la vida para su adecuado desarrollo profesional." .

# Learning Results
:lr_RA242 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA242" ;
    guide:learningResultDescription "Capacidad de abstracción y reconocimiento de conceptos generales en situaciones prácticas." .

:lr_RA243 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA243" ;
    guide:learningResultDescription "Capacidad para formular y analizar modelos de procesos naturales. Capacidad de interpretar los resultados obtenidos y evaluar los modelos utilizados." .

:lr_RA244 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA244" ;
    guide:learningResultDescription "Habilidad para aplicación de métodos analíticos a la resolución de problemas técnicos conocidos que han aparecido en otras materias." .

:lr_RA232 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA232" ;
    guide:learningResultDescription "Proporciona un abanico muy diverso de herramientas para abordar el tratamiento de modelos de procesos naturales." .

:lr_RA245 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA245" ;
    guide:learningResultDescription "Proporciona una panorámica muy amplia de modelos clásicos aplicados en muy diversos campos..." .

# Syllabus
:syllabus_55000011 rdf:type guide:Syllabus ;
    guide:hasItem :item_topic1, :item_topic2, :item_topic3, :item_topic4, :item_topic5 .

:item_topic1 rdf:type guide:SyllabusItem ;
    guide:itemIndex 1 ;
    guide:syllabusDescription "Ecuaciones diferenciales ordinarias de primer orden." .

:item_topic2 rdf:type guide:SyllabusItem ;
    guide:itemIndex 2 ;
    guide:syllabusDescription "Sistemas de ecuaciones diferencial lineales de primer orden." .

:item_topic3 rdf:type guide:SyllabusItem ;
    guide:itemIndex 3 ;
    guide:syllabusDescription "Ecuaciones diferenciales lineales de orden n." .

:item_topic4 rdf:type guide:SyllabusItem ;
    guide:itemIndex 4 ;
    guide:syllabusDescription "Ecuaciones en derivadas parciales de primer orden." .

:item_topic5 rdf:type guide:SyllabusItem ;
    guide:itemIndex 5 ;
    guide:syllabusDescription "Introducción a las ecuaciones en derivadas parciales de segundo orden." .

# Evaluation System
:evalSystem_55000011 rdf:type guide:EvaluationSystem ;
    guide:evaluationDescription "La evaluación progresiva consta de dos prácticas de computación científica (10%), una primera prueba escrita (40%) y una segunda prueba escrita global (50%)." ;
    guide:hasEvaluationTrial :trial_practice, :trial_exam_first, :trial_exam_global .

:trial_practice rdf:type guide:EvaluationTrial ;
    guide:trialType "Examen de Prácticas" ;
    guide:evaluationType "progresiva" ;
    guide:gradePercentage "10%" ;
    guide:trialMode "Presencial" ;
    guide:evaluationDuration "2:00" ;
    guide:involvesCompetency :comp_CG1, :comp_CG2, :comp_CG3, :comp_CE1 .

:trial_exam_first rdf:type guide:EvaluationTrial ;
    guide:trialType "Examen Escrito" ;
    guide:evaluationType "progresiva" ;
    guide:gradePercentage "40%" ;
    guide:trialMode "Presencial" ;
    guide:evaluationDuration "2:00" ;
    guide:involvesCompetency :comp_CG1, :comp_CG2, :comp_CG6, :comp_CG10, :comp_CE1 .

:trial_exam_global rdf:type guide:EvaluationTrial ;
    guide:trialType "Examen Escrito" ;
    guide:evaluationType "global" ;
    guide:gradePercentage "50%" ;
    guide:minimumScore "2.5 / 10" ;
    guide:trialMode "Presencial" ;
    guide:evaluationDuration "2:30" ;
    guide:involvesCompetency :comp_CG1, :comp_CG2, :comp_CG6, :comp_CG10, :comp_CE1 .

# Schedule
:schedule_55000011 rdf:type guide:Schedule ;
    sch:eventSchedule :event_week1, :event_week2, :event_week3, :event_week4, :event_week5, :event_week8, :event_week11, :event_week17 .

