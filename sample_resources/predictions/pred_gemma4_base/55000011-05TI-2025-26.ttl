    guide:activityDescription "Introducción a la asignatura y Desarrollo teórico del Tema 1" ;
    guide:activityDuration 5.0 ;
    guide:activityFormat "Lección Magistral" ;
    guide:attendanceType "Presencial" .

:event_week8 rdf:type guide:ScheduleEvent ;
    guide:eventWeek "Semana 8" ;
    guide:eventIndex 8 ;
    guide:hasActivity :act_exam_written .

:act_exam_written rdf:type guide:Activity ;
