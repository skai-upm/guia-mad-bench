    guide:activityDuration 2.0 ;
    guide:activityFormat "Examen Escrito" ;
    guide:attendanceType "Presencial" .

# Didactic Resources
:res_sanchez rdf:type guide:DidacticResource ;
    guide:bibliographyTitle "Sistemas Dinámicos. Una introducción a través de ejercicios." ;
    guide:bibliographyType "Libro" ;
    guide:bibliographyDescription "E. Sánchez, J. González y J. Gutiérrez. Sección de Publicaciones de la E.T.S.I. Industriales de la U.P.M." .

:res_braun rdf:type guide:DidacticResource ;
    guide:bibliographyTitle "Ecuaciones diferenciales y sus aplicaciones" ;
    guide:bibliographyType "Libro" ;
    guide:bibliographyDescription "M. Braun, 1990." .

:res_nagle rdf:type guide:DidacticResource ;
    guide:bibliographyTitle "Fundamentos de ecuaciones diferenciales 2ª ed." ;
    guide:bibliographyType "Libro" ;
    guide:bibliographyDescription "R. K. Nagle, E. B. Saff, 1992." .

:res_haberman rdf:type guide:DidacticResource ;
    guide:bibliographyTitle "Applied partial differential equations with fourier series and boundary value problems" ;
    guide:bibliographyType "Libro" ;
    guide:bibliographyDescription "R. Haberman, 2004." .

# Required Knowledge
:req_knowledge_math rdf:type guide:RequiredKnowledge ;
    guide:previousKnowledge "Técnicas del cálculo infinitesimal con funciones de varias variables reales; Técnicas elementales de Cálculo Infinitesimal; Técnicas elementales de Álgebra Lineal; Operaciones básicas con números complejos." ;
    guide:previousCourses "Algebra, Calculo I, Calculo II" .