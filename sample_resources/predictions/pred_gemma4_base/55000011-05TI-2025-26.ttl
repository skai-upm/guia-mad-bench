# Course Guide
:courseGuide_55000011 rdf:type guide:CourseGuide ;
    sch:name "Guía de Aprendizaje - Ecuaciones Diferenciales" ;
    sch:description "Los contenidos de esta asignatura se orientan especialmente al estudio de las ecuaciones diferenciales ordinarias así como a problemas de contorno y de valor inicial formulados en términos de ecuaciones en derivadas parciales." ;
    sch:inLanguage "Castellano" ;
    guide:teachingPeriod "2025-26" ;
    guide:periodStartingMonth "Septiembre" ;
    guide:periodEndingMonth "Enero" ;
    guide:numberOfCredits 6.0 ;
    guide:totalHours "150" ; # Estimated based on ECTS (6 * 25)
    guide:hasSyllabus :syllabus_55000011 ;
    guide:hasEvaluation :evalSystem_55000011 ;
    sch:courseSchedule :schedule_55000011 ;
    sch:director :lecturer_victor ;
    sch:instructor :lecturer_victor, :lecturer_pablo, :lecturer_ana, :lecturer_pedro ;
    guide:hasCompetency :comp_CE1, :comp_CG1, :comp_CG10, :comp_CG2, :comp_CG3, :comp_CG6 ;
    guide:hasLearningResult :lr_RA242, :lr_RA243, :lr_RA244, :lr_RA232, :lr_RA245 ;
    guide:hasDidacticResource :res_sanchez, :res_braun, :res_nagle, :res_haberman .

