# Competencies
:comp_CE_B2 rdf:type guide:Competency ;
    guide:competencyCode "CE B2" ;
    guide:competencyDescription "Conocimientos básicos sobre el uso y programación de los ordenadores, sistemas operativos, bases de datos y programas informáticos con aplicación en ingeniería."@en .

:comp_CE_SC01 rdf:type guide:Competency ;
    guide:competencyCode "CE SC01" ;
    guide:competencyDescription "Capacidad para construir, explotar y gestionar las redes, servicios, procesos y aplicaciones de telecomunicaciones..."@en .

# Learning Results
:lr_RA1239 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA1239" ;
    guide:learningResultDescription "Identificar, comprender y aplicar la sintaxis y semántica de lenguajes para el desarrollo de aplicaciones web actuales"@en .

:lr_RA1240 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA12<0xC2>40" ;
    guide:learningResultDescription "Utiliza entornos y herramientas de desarrollo para la programación de aplicaciones con interfaces en línea de comandos e interfaces gráficas"@en .

:lr_RA1238 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA1238" ;
    guide:learningResultDescription "Implementa, prueba y verifica soluciones atendiendo a criterios de eficacia, legibilidad y documentación"@en .

:lr_RA1241 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA1241" ;
    guide:learningResultDescription "Desarrolla soluciones con tecnologías Web"@en .

:lr_RA1242 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA1242" ;
    guide:learningResultDescription "Utilizar adecuadamente los entornos de desarrollo con herramientas de libre distribución"@en .

# Syllabus
:syllabus_595040063 rdf:type guide:Syllabus ;
    guide:hasItem :item_topic1, :item_topic2, :item_topic3, :item_topic4, :item_topic5 .

:item_topic1 rdf:type guide:SyllabusItem ;
    guide:itemIndex 1 ;
    guide:syllabusDescription "Introducción a la asignatura"@en .

:item_topic2 rdf:type guide:SyllabusItem ;
    guide:itemIndex 2 ;
    guide:syllabusDescription "Arquitectura de la WEB (Introducción, Modelo cliente-servidor, URL y HTTP)"@en .

:item_topic3 rdf:type guide:SyllabusItem ;
    guide:itemIndex 3 ;
    guide:syllabusDescription "Tecnologías WEB básicas (HTML, CSS, JavaScript)"@en .

:item_topic4 rdf:type guide:SyllabusItem ;
    guide:itemIndex 4 ;
    guide:syllabusDescription "Tecnologías WEB avanzadas (jQuery, SPA, Mapas interactivos)"@en .

:item_topic5 rdf:type guide:SyllabusItem ;
    guide:itemIndex 5 ;
    guide:syllabusDescription "Temas avanzados (Aplicaciones adaptativas, Terminales móviles, React)"@en .

