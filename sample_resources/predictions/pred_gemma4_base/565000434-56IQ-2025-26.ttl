# Evaluation System
:EvalSystem_565000434
    rdf:type guide:EvaluationSystem ;
    guide:evaluationDescription "Cada una de las actividades puntúa sobre 10 puntos. Para superar la asignatura en la convocatoria ordinaria es necesario obtener una calificación ponderada mínima de 5 puntos sobre 10 y una calificación superior a un 4 en el examen final." ;
    guide:hasEvaluationTrial :Trial_Control12, :Trial_Control34, :Trial_Control5, :Trial_Memorias, :Trial_Final .

:Trial_Control12
    rdf:type guide:EvaluationTrial ;
    guide:trialDescription "Control de los temas 1 y 2" ;
    guide:evaluationType "Examen Escrito" ;
    guide:gradePercentage "10%" ;
    guide:trialMode "Presencial" ;
    guide:evaluationDuration "01:00" ;
    guide:involvesCompetency :Competency_CE14, :Competency_CG1, :Competary_CG3, :Competency_CG4, :Competency_CG6, :Competency_CG10 ;
    guide:hasScheduleEvent :Event_W6 .

