# Evaluation System
:evalSystem_595044117 rdf:type guide:EvaluationSystem ;
    guide:evaluationDescription "La evaluación progresiva libera cada tema a partir de una nota de 3 sobre 10. Se aprueba la asignatura por evaluación progresiva si se tiene más de un 3 en los tres temas y la media ponderada es 5 o más."@en ;
    guide:hasEvaluationTrial :trial_theme1, :trial_theme2, :trial_theme3, :trial_project, :trial_final_exam .

:trial_theme1 rdf:type guide:EvaluationTrial ;
    guide:evaluationType "Examen Escrito" ;
    guide:trialWeek "4" ;
    guide:gradePercentage "25%" ;
    guide:minimumScore "3 / 10" ;
    guide:trialMode "Presencial" .

:trial_theme2 rdf:type guide:EvaluationTrial ;
    guide:evaluationType "Examen Escrito" ;
    guide:trialWeek "9" ;
    guide:gradePercentage "25%" ;
．guide:minimumScore "3 / 10" ;
    guide:trialMode "Presencial" .

:trial_theme3 rdf:type guide:EvaluationTrial ;
    guide:evaluationType "Presentación en Grupo" ;
    guide:trialWeek "13" ;
    guide:gradePercentage "25%" ;
    guide:minimumScore "3 / 10" ;
    guide:trialMode "Presencial" .

:trial_project rdf:type guide:EvaluationTrial ;
    guide:evaluationType "Trabajo en Grupo" ;
    guide:trialWeek "14" ;
    guide:gradePercentage "25%" ;
    guide:minimumScore "3 / 10" ;
    guide:trialMode "Presencial" .

:trial_final_exam rdf:type guide:EvaluationTrial ;
    guide:evaluationType "Examen Escrito" ;
    guide:trialWeek "17" ;
    guide:gradePercentage "100%" ;
    guide:minimumScore "5 / 10" ;
    guide:trialMode "Presencial" .

