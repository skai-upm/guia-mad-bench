    guide:hasSyllabus :syllabus_595044117 ;
    guide:hasCompetency :comp_CB02, :comp_CB03, :comp_CE21, :comp_CG02, :comp_CG03, :comp_CG05, :comp_CG06, :comp_CG07, :comp_CG08, :comp_CG09, :comp_CG10, :comp_CG11 ;
    guide:hasLearningResult :lr_RA027, :lr_RA028, :lr_RA031, :lr_RA047, :lr_RA061, :lr_RA112, :lr_RA098, :lr_RA111, :lr_RA057, :lr_RA032, :lr_RA113, :lr_RA115, :lr_RA123, :lr_RA125, :lr_RA126, :lr_RA127 ;
