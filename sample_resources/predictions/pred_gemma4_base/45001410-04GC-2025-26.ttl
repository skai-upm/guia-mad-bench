# Competencies
:comp_CM37_4 rdf:type guide:Competency ;
    guide:competencyCode "CM37.4" ;
    guide:competencyDescription "Comprensión del fundamento y de los sistemas de utilización de las energías renovables." .

:comp_CM38_1 rdf:type guide:Competency ;
    guide:competencyCode "CM38.1" ;
    guide:competencyDescription "Conocimiento y comprensión del funcionamiento de los ecosistemas y de los factores ambientales." .

:comp_CM38_2 rdf:type guide:Competency ;
    guide:competencyCode "CM38.2" ;
    guide:competencyDescription "Comprensión y capacidad de aplicación de metodologías de restauración ambiental." .

:comp_CM39_1 rdf:type guide:Competency ;
    guide:competencyCode "CM39.1" ;
    guide:competencyDescription "Conocimiento de los proyectos de servicios urbanos relacionados con la distribución de<0xC2>agua y el saneamiento" .

:comp_CM44 rdf:type guide:Competency ;
    guide:competencyCode "CM44" ;
    guide:competencyDescription "Valoración de los efectos histórico, social, económico, ambiental, cultural, político y globalizador de las realizaciones de la ingeniería civil." .

:comp_CM45 rdf:type guide:Competency ;
    guide:competencyCode "CM45" ;
    guide:competencyDescription "Comprensión y asunción de los principios de incertidumbre, riesgo y oportunidad en la aplicación de los métodos y modelos de la ingeniería civil." .

:comp_CT3 rdf:type guide:Competency ;
    guide:competencyCode "CT3" ;
    guide:competencyDescription "Capacidad de actuar con efectividad como miembro de equipos interdisciplinares." .

:comp_CT6 rdf:type guide:Competency ;
    guide:competencyCode "CT6" ;
    guide:competencyDescription "Compromiso y capacidad de aplicación de los estándares de deontología profesional." .

# Learning Results
:lr_RA95 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA95" ;
    guide:learningResultDescription "Explica el fundamento y los sistemas de utilización de las energías renovables." .

:lr_RA99 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA99" ;
    guide:learningResultDescription "Valora los efectos social, económico, ambiental, político y globalizador de las infraestructuras hidráulicas y energéticas." .

:lr_RA92 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA92" ;
    guide:learningResultDescription "Proyecta y dimensiona sistemas energéticos." .

# Syllabus
:syllabus_45001410 rdf:type guide:Syllabus ;
    guide:hasItem :item_suelos, :item_contaminacion, :item_residuos, :item_renovables .

:item_suelos rdf:type guide:SyllabusItem ;
    guide:itemIndex 1 ;
    guide:syllabusDescription "SUELOS CONTAMINADOS. Contaminación de suelos, Legislación, Remediación." .

:item_contaminacion rdf:type guide:SyllabusItem ;
    guide:itemIndex 2 ;
    guide:syllabusDescription "CONTAMINACIÓN ACÚSTICA Y ATMOSFÉRICA. Conceptos, legislación e impactos." .

:item_residuos rdf:type guide:SyllabusItem ;
    guide:itemIndex 3 ;
    guide:syllabusDescription "GESTIÓN DE RESIDUOS. RSU, Recogida, Tratamiento y Vertederos." .

:item_renovables rdf:type guide:SyllabusItem ;
    guide:itemIndex 4 ;
    guide:syllabusDescription "ENERGÍAS RENOVABLES. Solar térmica, fotovoltaica, biomasa y eólica." .

# Evaluation System
:evalSystem_45001410 rdf:type guide:EvaluationSystem ;
    guide:evaluationDescription "Sistema de evaluación continua con pruebas progresivas y examen global." ;
    guide:hasEvaluationTrial :trial_primero, :trial_segundo, :trial_global .

:trial_primero rdf:type guide:EvaluationTrial ;
    guide:trialType "Examen Escrito" ;
    guide:evaluationType "Progresiva" ;
    guide:gradePercentage "35%" ;
    guide:minimumScore "4/10" ;
    guide:evaluationDuration "01:00" ;
    guide:involvesCompetency :comp_CM39_1, :comp_CM44, :comp_CM45, :comp_CM38_1, :comp_CM38_2 .

:trial_segundo rdf:type guide:EvaluationTrial ;
    guide:trialType "Examen Escrito" ;
    guide:evaluationType "Progresiva" ;
    guide:gradePercentage "35%" ;
    guide:minimumScore "4/10" ;
    guide:evaluationDuration "01:00" ;
    guide:involvesCompetency :comp_CM39_1, :comp_CM45, :comp_CT3, :comp_CM37_4 .

:trial_global rdf:type guide:EvaluationTrial ;
    guide:trialType "Examen Escrito" ;
    guide:evaluationType "Global" ;
    guide:gradePercentage "100%" ;
    guide:minimumScore "5/10" ;
    guide:evaluationDuration "02:00" ;
    guide:involvesCompetency :comp_CM39_1, :comp_CM44, :comp_CM45, :comp_CT3, :comp_CM37_4, :comp_CT6, :comp_CM38_1, :comp_CM38_2 .

