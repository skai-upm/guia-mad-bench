# Course Guide
:courseGuide_45001410 rdf:type guide:CourseGuide ;
    sch:name "Guía de Aprendizaje - 45001410" ;
    sch:description "La asignatura estudia los servicios urbanos, centrándose en gestión de residuos y generación de energía, así como en aspectos relacionados como la contaminación acústica, atmosférica y de suelos." ;
    teachingPeriod "2025-26" ;
    guide:numberOfCredits 3.0 ;
    guide:periodStartingMonth "Septiembre" ;
    guide:periodEndingMonth "Enero" ;
    sch:inLanguage "Castellano" ;
    sch:instructor :prof_bianucci ;
    guide:hasSyllabus :syllabus_45001410 ;
    guide:hasEvaluation :evalSystem_45001410 ;
    guide:hasLearningResult :lr_RA95, :lr_RA99, :lr_RA92 ;
    guide:hasCompetency :comp_CM37_4, :comp_CM38_1, :comp_CM38_2, :comp_CM39_1, :comp_CM44, :comp_CM45, :comp_CT3, :comp_CT6 ;
    guide:hasDidacticResource :res_moodle, :res_biblio_basica, :res_biblio_comp ;
    sch:activitiesWorkload "26-27 horas por crédito ECTS" .

