    guide:syllabusDescription "Tema 2. Características de los modos de transporte." .

# --- Evaluation System ---

:eval_system_transportes rdf:type guide:EvaluationSystem ;
    guide:evaluationDescription "Evaluación continua mediante tests progresivos y exámenes parciales/finales." ;
    guide:hasEvaluationTrial :trial_test_tema1, :trial_examen_parcial, :trial_examen_final .

:trial_test_tema1 rdf:type guide:EvaluationTrial ;
    guide:evaluationType "Evaluación progresiva" ;
    guide:gradePercentage "2.3%" ;
    guide:minimumScore "5 / 10" ;
    guide:trialType "Test" ;
    guide:trialMode "Presencial" .

:trial_examen_parcial rdf:type guide:EvaluationTrial ;
    guide:evaluationType "Evaluación progresiva" ;
    guide:gradePercentage "35%" ;
    guide:minimumScore "5 / 10" ;
    guide:trialType "Examen Escrito" ;
    guide:trialMode "Presencial" .

:trial_examen_final rdf:type guide:EvaluationTrial ;
    guide:evaluationType "Evaluación Global" ;
    guide:gradePercentage "100%" ;
    guide:minimumScore "5 / 10" ;
    guide:trialType "Examen Escrito" ;
    guide:trialMode "Presencial" .

