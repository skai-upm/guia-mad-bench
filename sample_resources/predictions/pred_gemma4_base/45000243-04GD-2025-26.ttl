# --- Competencies ---

:comp_CM40_2 rdf:type guide:Competency ;
    guide:competencyCode "04GC. CM40.2" ;
    guide:competencyDescription "Comprensión del fenómeno urbano y sus factores determinantes (historia, economía, actividad humana, movilidad)." .

:comp_CM41_1 rdf:type guide:Competency ;
    guide:competencyCode "04GC. CM41.1" ;
    guide:competencyDescription "Conocimiento de la influencia de las infraestructuras en la ordenación del territorio..." .

:comp_CT1 rdf:type guide:Competency ;
    guide:competencyCode "04GC. CT1" ;
    guide:compet．description "Compromiso y capacidad para aplicar los principios de sostenibilidad en las actuaciones profesionales." .

# --- Learning Results ---

:lr_RA03 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA180 - RA03" ;
    guide:learningResultDescription "Trabajar de forma autónoma y con iniciativa personal" .

:lr_RA137 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA137" ;
    guide:learningResultDescription "Interioriza los principios de deontología profesional de ingeniería civil." .

:lr_RA100 rdf:type guide:Learning .

