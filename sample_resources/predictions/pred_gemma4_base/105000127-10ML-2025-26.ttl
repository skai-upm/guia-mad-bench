# --- Competencies and Learning Results ---
:comp_C1 a guide:Competency ;
    guide:competencyCode "C1" ;
    guide:competencyDescription "Capacidad de resolución de problemas aplicando conocimientos de matemáticas, ciencias e ingeniería." .

:comp_C2 a guide:Competency ;
    guide:competencyCode "C2" ;
    guide:competencyDescription "Capacidad para el aprendizaje autónomo y la actualización de conocimientos, y reconocimiento de su necesidad en las áreas de..." .

:comp_C7 a guide:Competency ;
    guide:competencyCode "C7" ;
    guide:competencyDescription "Capacidad para tomar iniciativas y espíritu emprendedor, el liderazgo, la dirección, la gestión de equipos y proyectos." .

:comp_K4 a guide:Competency ;
    guide:competencyCode "K4" ;
    guide:competencyDescription "Entender el soporte físico (hardware) de los ordenadores desde el punto de vista del soporte lógico (software)..." .

:comp_S19 a guide:Competency ;
    guide:competencyCode "S19" ;
    guide:competencyDescription "Capacidad de aplicar sus conocimientos e intuición para diseñar el hardware/software que cumple unos requisitos especificados." .

:comp_S21 a guide:Competency ;
    guide:competencyCode "S21" ;
    guide:competencyDescription "Concebir y diseñar la arquitectura de un sistema software." .

:lr_RA20 a guide:LearningResult ;
    guide:learningResultCode "RA20" ;
    guide:learningResultDescription "Los resultados del aprendizaje correspondientes a esta asignatura han quedado definimos en el apartado de competencias..." .

# --- Syllabus ---
:syllabus_so a guide:Syllabus ;
    guide:hasItem :item_intro, :item_ficheros, :item_procesos, :item_memoria, :item_sincronizacion .

:item_intro a guide:SyllabusItem ;
    guide:itemIndex 1 ;
    guide:syllabusDescription "Introducción al SSOO (Conceptos hardware, ejecución de instrucciones, interrupciones, Memoria virtual, Procesos, Protección, Ficheros)." .

:item_ficheros a guide:SyllabusItem ;
    guide:itemIndex 2 ;
    guide:syllabusDescription "Gestión de Ficheros (E/S, Organización, Directorios, Servicios)." .

:item_procesos a guide:SyllabusItem ;
    guide:itemIndex 3 ;
    guide:syllabusDescription "Gestión de Procesos (Planificación, Servicios, Señales)." .

:item_memoria a guide:SyllabusItem ;
    guide:itemIndex 4 ;
    guide:syllabusDescription "Gestión de Memoria (Mapa de memoria, Creación de ejecutables, Regiones)." .

:item_sincronizacion a guide:SyllabusItem ;
    guide:itemIndex 5 ;
    guide:syllabusDescription "Sincronización y Comunicación (Concurrencia, Problemas clásicos, Mecanismos, Interbloqueos)." .

# --- Evaluation System ---
:eval_system_so a guide:EvaluationSystem ;
    guide:evaluationDescription "Sistema de evaluación compuesto por Parte Teórica (50%) y Parte Práctica (50%)." ;
    guide:hasEvaluationTrial :trial_prueba_nivel, :trial_modulo_linux, :trial_parcial_sf, :trial_proyecto_1, :trial_examen_final .

