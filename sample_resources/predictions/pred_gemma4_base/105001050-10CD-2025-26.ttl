# Competencies
:comp_CB04 a guide:Competency ;
    guide:competencyCode "CB04" ;
    guide:competencyDescription "Que los estudiantes puedan transmitir información, ideas, problemas y soluciones a un público tanto especializado como no especializado" .

:comp_CE01 a guide:Competency ;
    guide:competencyCode "CE01" ;
    guide:competencyDescription "Capacidad para utilizar con destreza los conceptos y métodos matemáticos que subyacen a los problemas de la ciencia de datos y la inteligencia artificial para su modelización y resolución." .

:comp_CG02 a guide:Competency ;
    guide:competencyCode "CG02" ;
    guide:competencyDescription "Capacidad para organizar y planificar tareas y proyectos, identificando objetivos, prioridades, plazos, recursos y riesgos, y controlando los procesos establecidos." .

:comp_CG03 a guide:Competency ;
    guide:competencyCode "CG03" ;
    guide:competencyDescription "Capacidad de emprendimiento y de liderazgo para dirigir y gestionar equipos y proyectos, generando confianza y compromiso en el grupo de colaboradores." .

:comp_CG06 a guide:Competency ;
    guide:competencyCode "CG06" ;
    guide:competencyDescription "Identificar y utilizar las tecnologías de la información y las comunicaciones más adecuadas en el ámbito de la ingeniería." .

# Learning Results
:lr_RA133 a guide:LearningResult ;
    guide:learningResultCode "RA133" ;
    guide:learningResultDescription "Entender la importancia de las ecuaciones diferenciales y su utilidad para modelar fenómenos de la</em> vida real." .

:lr_RA136 a guide:LearningResult ;
    guide:learningResultCode "RA136" ;
    guide:learningResultDescription "Saber realizar un estudio cualitativo de sistemas diferenciales no lineales." .

:lr_RA134 a guide:LearningResult ;
    guide:learningResultCode "RA134" ;
    guide:learningResultDescription "Modelar matemáticamente problemas reales mediante ecuaciones diferenciales o sistemas diferenciales" .

:lr_RA135 a guide:LearningResult ;
    guide:learningResultCode "RA135" ;
    guide:learningResultDescription "Conocer técnicas para resolver algunos tipos de ecuaciones diferenciales y sistemas diferenciales lineales." .

:lr_RA138 a guide:LearningResult ;
    guide:learningResultCode "RA138" ;
    guide:learningResultDescription "Dominar diferentes métodos numéricos de diferencias finitas y su programación para estudiar problemas de la vida real descritos mediante ecuaciones o sistemas diferenciales." .

