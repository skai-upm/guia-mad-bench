# Competencies
guide:comp_CG1 rdf:type guide:Competency ;
    guide:competencyCode "CG-1/21" ;
    guide:competencyDescription "Capacidad de resolución de problemas aplicando conocimientos de matemáticas, ciencias e ingeniería." .

guide:comp_CG2 rdf:type guide:Competency ;
    guide:competencyCode "CG-2/CE45" ;
    guide:competencyDescription "Capacidad para el aprendizaje autónomo y la actualización de conocimientos, y reconocimiento de su necesidad en el área de la informática." .

guide:comp_CG3 rdf:type guide:Competency ;
    guide:compet competencyCode "CG-3/4" ;
    guide:competencyDescription "Saber trabajar en situaciones carentes de información y bajo presión, teniendo nuevas ideas, siendo creativo." .

guide:comp_Ce3 rdf:type guide:Competency ;
    guide:competencyCode "Ce 3/4" ;
    guide:competencyDescription "Capacidad de elegir y usar los．los métodos analíticos y de modelización relevantes, y de describir una solución de forma abstracta." .

guide:comp_Ce6 rdf:type guide:Competency ;
    guide:competencyCode "Ce 6" ;
    guide:competencyDescription "Comprender intelectualmente el papel central que tienen los algoritmos y las estructuras de datos, así como una apreciación del mismo." .

guide:comp_Ce8 rdf:type guide:Competency ;
    guide:competencyCode "Ce 8" ;
    guide:competencyDescription "Poseer destrezas fundamentales de la programación que permitan la implementación de los algoritmos y las estructuras de datos en el software." .

guide:comp_Ce9 rdf:type guide:Competency ;
    guide:competencyCode "Ce 9" ;
    guide:competencyDescription "Poseer las destrazas que se requieren para diseñar e implementar unidades estructurales mayores que utilizan los algoritmos y las estructuras de datos, así como las interfaces por las que se comunican estas unidades." .

# Learning Results
guide:lr_RA288 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA288" ;
    guide:learningResultDescription "Programar aplicaciones mediante librerías existentes de TADs, iteradores, etc,." .

guide:lr_RA287 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA287" ;
    guide:learningResultDescription "Traducir especificaciones de tipos abstractos de datos (TADs) a implementaciones." .

guide:lr_RA290 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA290" ;
    guide:learningResultDescription "Realizar pruebas para asegurar el correcto funcionamiento de un TAD así como" .

guide:lr_RA289 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA289" ;
    guide:learningResultDescription "Documentar clases y bibliotecas, tanto de manera pública (hacia el cliente)." .

# Syllabus
guide:syllabus_prog2 rdf:type guide:Syllabus ;
    guide:hasItem guide:item_1, guide:item_2, guide:item_3, guide:item_4, guide:item_5, guide:item_6, guide:item_7 .

guide:item_1 rdf:type guide:SyllabusItem ; guide:itemIndex 1 ; guide:syllabusDescription "Introducción a la programación orientada a objetos (POO)" .
guide:item_2 rdf:type guide:SyllabusItem ; guide:itemIndex 2 ; guide:syllabusDescription "Modelo de objetos: abstracciones de datos, clases y objetos" .
guide:item_3 rdf:type guide:SyllabusItem ; guide:itemIndex 3 ; guide:syllabusDescription "Listas" .
guide:item_4 rdf:type guide:SyllabusItem ; guide:itemIndex 4 ; guide:syllabusDescription "Listas enlazadas" .
guide:item_5 rdf:type guide:SyllabusItem ; guide:itemIndex 5 ; guide:syllabusDescription "Herencia y Polimorfismo" .
guide:item_6 rdf:type guide:SyllabusItem ; guide:itemIndex 6 ; guide:syllabusDescription "Pilas y Colas" .
guide:item_7 rdf:type guide:SyllabusItem ; guide:itemIndex 7 ; guide:syllabusDescription "Excepciones" .

# Evaluation System
guide:eval_system_prog2 rdf:type guide:EvaluationSystem ;
    guide:evaluationDescription "La evaluación se regirá por la Normativa de Evaluación de la Upreg, con dos sistemas: progresiva y global." ;
    guide:hasEvaluationTrial guide:trial_aep_5, guide:trial_aep_6, guide:trial_aep_7, guide:trial_aep_8, guide:trial_aep_9, guide:trial_aep_10, guide:trial_aep_11, guide:trial_aep_13, guide:trial_aep_14, guide:trial_aep_15, guide:trial_eep_12, guide:trial_eg_16, guide:trial_eg_extra .

guide:trial_aep_5 rdf:type guide:EvaluationTrial ;
    guide:evaluationType "Prueba Telemática" ;
    guide:gradePercentage "2.5%" ;
    guide:trialWeek "Semana 5" ;
    guide:trialMode "Presencial" .

guide:trial_eep_12 rdf:type guide:EvaluationTrial ;
    guide:evaluationType "Prueba Telemática" ;
    guide:gradePercentage "10%" ;
    guide:trialWeek "Semana 12" ;
    guide:trialMode "Presencial" .

guide:trial_eg_16 rdf:type guide:EvaluationTrial ;
    guide:evaluationType "Examen Escrito" ;
    guide:gradePercentage "60%" ;
    guide:trialWeek "Semana 16" ;
    guide:trialMode "Presencial" .

