#################################################################
#    Evaluation System
#################################################################

data:EvalSystem_Electronica_I rdf:type guide:EvaluationSystem ;
    guide:evaluationDescription "La evaluación se divide en teoría (70%) y práctica (30%). Es necesario aprobar ambas partes con un mínimo de 5/10." ;
    guide:hasEvaluationTrial data:Trial_Partial_1, data:Trial_Final .

data:Trial_Partial_1 rdf:type guide:EvaluationTrial ;
    guide:trialType "Examen" ;
    guide:evaluationType "progresiva" ;
    guide:gradePercentage "50%" ;
    guide:minimumScore "5/10" ;
    guide:trialWeek "Semana 8" ;
    guide:trialMode "Presencial" ;
    guide:involvesCompetency data:Comp_SC03, data:Comp_TEL01 .

data:Trial_Final rdf:type guide:EvaluationTrial ;
    guide:trialType "Examen" ;
    guide:evaluationType "global" ;
    guide:gradePercentage "100%" ;
    guide:minimumScore "5/10" ;
    guide:trialWeek "Semana 16" ;
    guide:trialMode "Presencial" .

