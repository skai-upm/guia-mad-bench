#################################################################
#    Competencies and Learning Results
#################################################################

data:Comp_SC03 rdf:type guide:Competency ;
    guide:competencyCode "CE SC04" ;
    guide:competencyDescription "Capacidad de análisis de componentes y sus especificaciones para sistemas de comunicaciones guiadas y no guiadas." .

data:Comp_TEL01 rdf:type guide:Competency ;
    guide:competencyCode "CE TEL01" ;
    guide:competencyDescription "Capacidad para aprender de manera autónoma nuevos conocimientos y técnicas adecuados para la concepción, el desarrollo o la explotación de sistemas y servicios de telecomunicación." .

data:LR_RA232 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA232" ;
    guide:learningResultDescription "Se concretarán para cada asignatura optativa o para la realización de prácticas en empresas." .

#################################################################
#    Syllabus
#################################################################

data:Syllabus_Electronica_I rdf:type guide:Syllabus ;
    guide:hasItem data:Topic_1, data:Topic_2, data:Topic_3, data:Topic_4, data:Topic_5 .

data:Topic_1 rdf:type guide:SyllabusItem ;
    guide:itemIndex 1 ;
    guide:syllabusDescription "Introducción al estudio de los osciladores. Definiciones, topologías, principios de funcionamiento, regímenes y metodologías de diseño." .

data:Topic_2 rdf:type guide:SyllabusItem ;
    guide:itemIndex 2 ;
    guide:syllabusDescription "Osciladores autocontrolados LC. Topologías, métodos de diseño, ejemplo de diseño y VCO." .

data:Topic_3 rdf:type guide:SyllabusItem ;
    guide:itemIndex 3 ;
    guide:syllabusDescription "Osciladores a cristal. Piezoelectricidad, circuito equivalente, modos de resonancia y ajuste." .

data:Topic_4 rdf:type guide:SyllabusItem ;
    guide:itemIndex 4 ;
    guide:syllabusDescription "Sintetizadores directos analógicos de frecuencia. Definiciones y topologías básicas." .

data:Topic_5 rdf:type guide:SyllabusItem ;
    guide:itemIndex 5 ;
    guide:syllabusDescription "Sintetizadores Indirectos analógicos de Frecuencia (PLL). Topología, ecuaciones, filtros paso bajo, comparadores y sintetizadores fraccionales." .

