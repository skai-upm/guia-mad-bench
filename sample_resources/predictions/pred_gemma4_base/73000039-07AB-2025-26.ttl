# --- Competencies ---

guide:CE_1_2 rdf:type guide:Competency ;
    guide:competencyCode "CE 1.2" ;
    guide:competencyDescription "Capacidad para emprender acciones relacionadas con la gestión forestal" .

guide:CE_2_1 rdf:type guide:Competency ;
    guide:competencyCode "CE 2.1" ;
    guide:competencyDescription "Capacidad para diseñar, redactar y gestionar planes y políticas de prevención y detección de incendios" .

guide:CG_5 rdf:type guide:Competency ;
    guide:competencyCode "CG 5" ;
    guide:competencyDescription "Búsqueda bibliográfica, análisis de documentación y tratamiento de la información procedente de diversas fuentes..." .

guide:CG_6 rdf:type guide:Competency ;
    guide:competencyCode "CG 6" ;
    guide:competencyDescription "Perfeccionar el conocimiento oral y escrito de la lengua inglesa" .

# --- Learning Results ---

guide:RA45 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA45" ;
    guide:learningResultDescription "Que los estudiantes tengan conocimientos para crear e interpretar cartografía temática y aplicarla a la gestión en su campo de<0xC2>工作" .

guide:RA43 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA43" ;
    guide:learningResultDescription "Capacidad para poner en práctica técnicas de selvicultura preventiva y de reducción del combustible en el monte" .

