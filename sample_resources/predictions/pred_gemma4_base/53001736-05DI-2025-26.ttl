# Evaluation System and Trials
:eval_system_53001736
    rdf:type guide:EvaluationSystem ;
    guide:evaluationDescription "La asignatura posee una parte en el área de la Automatización y una parte en el área del Control. Evaluación progresiva y global." ;
    guide:hasEvaluationTrial :trial_tarea1, :trial_tarea2, :trial_tri_3, :trial_examen_final .

:trial_tarea1
    rdf:type guide:EvaluationTrial ;
    guide:trialDescription "Tarea 1. Programación de autómatas" ;
    guide:evaluationType "Progresiva" ;
    guide:gradePercentage "30%" ;
    guide:minimumScore "4/10" ;
    guide:trialMode "No Presencial" ;
    guide:evaluationDuration "01:00" .

:trial_tarea2
    rdf:type guide:EvaluationTrial ;
    guide:trialDescription "Tarea 2. Control con realimentación del estado y diseño de observador" ;
    guide:evaluationType "Progresiva" ;
    guide:gradePercentage "10%" ;
    guide:minimumScore "/ 10" ;
    guide:trialMode "No Presencial" ;
    guide:evaluationDuration "01:00" .

:trial_tri_3
    rdf:type guide:EvaluationTrial ;
    guide:trialDescription "Tarea 3. Control de un sistema mediante un regulador lineal óptimo" ;
    guide:evaluationType "Progresiva" ;
    guide:gradePercentage "10%" ;
    guide:minimumScore "/ 10" ;
    guide:trialMode "No Presencial" ;
    guide:evaluationDuration "01:00" .

:trial_examen_final
    rdf:type guide:EvaluationTrial ;
    guide:trialDescription "Examen final con parte escrita y práctica" ;
    guide:evaluationType "Global" ;
    guide:gradePercentage "50%" ;
    guide:minimumScore "4/10" ;
    guide:trialMode "Presencial" ;
    guide:evaluationDuration "02:00" .

