### Syllabus Instances
:syllabus_95000062 rdf:type guide:Syllabus ;
    guide:hasItem :item_intro, :item_materiales, :item_diseno, :item_fabricacion, :item_pruebas .

:item_intro rdf:type guide:SyllabusItem ;
    guide:itemIndex 1 ;
    guide:syllabusDescription "Introducción a la fabricación (Ciclo de desarrollo, Escenario general, Normativas)"@en .

:item_materiales rdf:type guide:SyllabusItem ;
    guide:itemIndex 2 ;
    guide:syllabusDescription "Materiales (Componentes base, Propiedades, Encapsulados)"@en .

:item_diseno rdf:type guide:SyllabusItem ;
    guide:itemIndex 3 ;
    guide:syllabusDescription "Diseño orientado a fabricación (Características físicas, Herramientas, Proceso de diseño, Layout, etc.)"@en .

:item_fabricacion rdf:type guide:SyllabusItem ;
    guide:itemIndex 4 ;
    guide:syllabusDescription "Aspectos prácticos de fabricación (Drill, Inspección, Acabados, Ensamblado)"@en .

:item_pruebas rdf:type guide:SyllabusItem ;
    guide:itemIndex 5 ;
    guide:syllabusDescription "Pruebas y fiabilidad (Inspección, Diseño para pruebas, Análisis de fallos, Mantenimiento)"@<0xC2>pty .

### Evaluation System Instances
:eval_system_95000062 rdf:type guide:EvaluationSystem ;
    guide:evaluationDescription "La evaluación comprobará si los estudiantes han adquirido las competencias de la asignatura."@en ;
    guide:hasEvaluationTrial :trial_prog_4, :trial_prog_8, :trial_prog_9, :trial_prog_10, :trial_prog_12, :trial_prog_14, :trial_prog_17, :trial_global_9, :trial_global_10, :trial_global_17, :trial_extraordinary .

:trial_prog_4 rdf:type guide:EvaluationTrial ;
    guide:trialDescription "Análisis de componentes y normativa caso práctico" ;
    guide:evaluationType "Evaluación Progresiva" ;
    guide:gradePercentage "10%" ;
    guide:trialWeek "Semana 4" ;
