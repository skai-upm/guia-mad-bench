### Competency Instances
:comp_ce_se1 rdf:type guide:Competency ;
    guide:competencyCode "CE-SE1" ;
    guide:competencyDescription "Capacidad de construir, explotar y gestionar sistemas de captación, transporte, representación, procesado, almacenamiento, gestión y presentación de información multimedia..."@en .

:comp_ce_se3 rdf:type guide:Competency ;
    guide:competencyCode "CE-SE3" ;
    guide:competencyDescription "Capacidad de realizar la especificación, implementación, documentación y puesta a punto de equipos y sistemas electrónicos..."@en .

:comp_ce_se5 rdf:type guide:Competency ;
    guide:competencyCode "CE-SE5" ;
    guide:competencyDescription "Capacidad de diseñar circuitos de electrónica analógica y digital, de conversión analógico-digital y digital analógica..."@en .

:comp_ce_se9 rdf:type guide:Competency ;
    guide:competencyCode "CE-SE9" ;
    guide:competencyDescription "Capacidad de analizar y solucionar los problemas de interferencias y compatibilidad electromagnética"@en .

:comp_cg12 rdf:type guide:Competency ;
    guide:competencyCode "CG12" ;
    guide:competencyDescription "Organización y planificación"@en .

:comp_cg13 rdf:type guide:Competency ;
    guide:competencyCode "CG13" ;
    guide:competencyDescription "Respeto medioambiental"@en .

:comp_cg7 rdf:type guide:Competency ;
    guide:competencyCode "CG7" ;
    guide:competencyDescription "Trabajo en equipo"@en .

:comp_cg9 rdf:type guide:Competency ;
    guide:competencyCode "CG9" ;
    guide:competencyDescription "Uso de Tecnologías de la Información y de las Comunicaciones"@en .

