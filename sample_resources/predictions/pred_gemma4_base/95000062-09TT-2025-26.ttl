:trial_global_17 rdf:type guide:EvaluationTrial ;
    guide:trialDescription "Examen evaluación global" ;
    guide:evaluationType "Evaluación Global" ;
    guide:gradePercentage "50%" ;
    guide:minimumScore "4/10" ;
    guide:trialWeek "Semana 17" ;
    guide:involvesCompetency :comp_ce_se3, :comp_cg12, :comp_ce_se1, :comp_ce_se5, :comp_ce_se9 .

