### Course Guide Instance
:guide_95000062_2025_26 rdf:type guide:CourseGuide ;
    sch:name "Guía de Aprendizaje: Fabricación de Equipos Electrónicos" ;
    sch:description "El curso se centra en el diseño orientado a la fabricación de equipos electrónicos. Se estudian cuestiones relacionadas con el diseño físico de los sistemas electrónicos así como las diferentes tecnologías que se pueden utilizar para su fabricación."@en ;
    sch:inLanguage "Castellano" ;
    guide:teachingPeriod "2025-26" ;
    guide:teachingPeriodMonths "Septiembre-Enero" ;
    guide:numberOfCredits 4.5 ;
    guide:inpersonHours "No especificado" ;
    guide:remoteHours "No especificado" ;
    sch:instructor :lecturer_jorge_pedros ;
    sch:director :lecturer_alvaro_araujo ;
    guide:hasSyllabus :syllabus_95000062 ;
    guide:hasEvaluation :eval_system_95000062 ;
    guide:hasLearningResult :lr_ra732, :lr_ra733, :lr_ra76, :lr_ra734, :lr_ra71, :lr_ra70, :lr_ra74 ;
    guide:hasCompetency :comp_ce_se1, :comp_ce_se3, :comp_ce_se5, :comp_ce_se9, :comp_cg12, :comp_cg13, :comp_cg7, :comp_cg9 ;
    sch:courseSchedule :schedule_95000062 ;
    guide:hasDidacticResource :res_moodle, :res_coombs, :res_altium, :res_horno .

