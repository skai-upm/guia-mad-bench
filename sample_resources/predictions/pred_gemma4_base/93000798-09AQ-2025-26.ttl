# --- Degree and University Center ---

:Master_Telecomunicacion rdf:type guide:MasterDegree ;
    sch:name "Master Universitario en Ingenieria de Telecomunicacion" ;
    guide:degreeCode "09AQ" .

:ETSIT rdf:type guide:UniversityCenter ;
    sch:name "E.T.S. De Ingenieros De Telecomunicacion" ;
    guide:offers :Master_Telecomunicacion .

# --- Course ---

:Course_Aplicaciones_Servicios rdf:type guide:Course ;
    sch:name "Aplicaciones y Servicios" ;
    sch:courseCode 93000798 ;
    guide:courseType "Obligatoria" ;
    guide:courseYear 2025 ;
    guide:semester "Primer semestre" ;
    sch:hasCourseInstance :Guide_Aplicaciones_Servicios .

# --- Course Guide ---

:Guide_Aplicaciones_Servicios rdf:type guide:CourseGuide ;
    sch:name "Guía de Aprendizaje - Aplicaciones y Servicios" ;
    sch:description "La asignatura tiene como objetivo que el alumno conozca los tipos principales de tecnologías de software y servicios, y su contexto de uso en el ámbito empresarial."@en ;
    sch:hasCourseInstance :Course_Aplicaciones_Servicios ;
    sch:instructor :Lecturer_JuanCarlos_Duenas ;
    sch:director :Lecturer_JuanCarlos_Duenas ;
    sch:inLanguage "Inglés/Castellano" ;
    guide:numberOfCredits 6.0 ;
    guide:teachingPeriod "2025-26" ;
    guide:periodStartingMonth "Septiembre" ;
    guide:periodEndingMonth "Enero" ;
    guide:totalHours "150" ; # Estimated based on ECTS 6 * 25
    guide:hasSyllabus :Syllabus_Aplicaciones_Servicios ;
    guide:hasCompetency :Comp_CE6, :Comp_CE7, :Comp_CE8, :Comp_CT4, :Comp_CT5 ;
    guide:hasLearningResult :LR_RA4, :LR_RA3, :LR_RA5, :LR_RA1, :LR_RA2, :LR_RA7 ;
    guide:hasEvaluation :EvalSystem_Aplicaciones_Servicios ;
    guide:hasDidacticResource :Res_Moodle, :Res_Libro1, :Res_Libro2 ;
    sch:courseSchedule :Schedule_Aplicaciones_Servicios .

