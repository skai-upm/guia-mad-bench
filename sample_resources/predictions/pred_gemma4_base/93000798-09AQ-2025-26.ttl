    guide:bibliographyType "Bibliografía"@en ;
    guide:bibliographyDescription "C. Richardson, Manning 2019."@en .

# --- Required Knowledge ---

:ReqKnow_Java rdf:type guide:RequiredKnowledge ;
    guide:previousKnowledge "Conocimientos de programación en Java"@en .

:ReqKnow_SoftwareEng rdf:type guide:RequiredKnowledge ;
    guide:previousKnowledge "Conocimientos de Ingeniería del Software y desarrollo de aplicaciones"@en .