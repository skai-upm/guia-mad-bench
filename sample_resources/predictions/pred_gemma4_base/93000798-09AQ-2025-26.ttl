# --- Competencies ---

:Comp_CE6 rdf:type guide:Competency ;
    guide:competencyCode "CE6" ;
    guide:competencyDescription "Capacidad para modelar, diseñar, implantar, gestionar, operar, administrar y mantener redes, servicios y contenidos."@en .

:Comp_CE7 rdf:type guide:Competency ;
    guide:competencyCode "CE7" ;
    guide:competencyDescription "Capacidad para realizar la planificación, toma de decisiones y empaquetamiento de redes, servicios y aplicaciones..."@en .

:Comp_CT4 rdf:type guide:Competency ;
    guide:competencyCode "CT4" ;
    guide:competencyDescription "Capacidad para trabajar de forma efectiva como individuo, organizando y planificando su propio trabajo..."@en .

# --- Learning Results ---

:LR_RA4 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA4" ;
    guide:learningResultDescription "Conocer los métodos de ingeniería útiles en el desarrollo y operación de aplicaciones y servicios"@en .

:LR_RA1 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA1" ;
    guide:learningResultDescription "Conocer estándares y protocolos utilizados en el desarrollo de aplicaciones orientadas a servicios..."@en .

# --- Syllabus ---

:Syllabus_Aplicaciones_Servicios rdf:type guide:Syllabus ;
    guide:hasItem :SyllabusItem_Tema1, :SyllabusItem_Tema5, :SyllabusItem_Tema13, :SyllabusItem_Tema17 .

:SyllabusItem_Tema1 rdf:type guide:SyllabusItem ;
    guide:itemIndex 1 ;
    guide:syllabusDescription "Economía digital"@en .

:SyllabusItem_Tema5 rdf:type guide:SyllableItem ;
    guide:itemIndex 5 ;
    guide:syllabusDescription "Sistemas de información en la empresa"@en .

:SyllabusItem_Tema13 rdf:type guide:SyllabusItem ;
    guide:itemIndex 13 ;
    guide:syllabusDescription "SCRUM"@en .

# --- Evaluation System ---

:EvalSystem_Aplicaciones_Servicios rdf:type guide:EvaluationSystem ;
    guide:evaluationDescription "La calificación se obtiene mediante la media de las calificaciones correspondientes a los dos exámenes parciales, con igual peso."@en ;
    guide:hasEvaluationTrial :Trial_ExamenParcial1, :Trial_ExamenFinal .

:Trial_ExamenParcial1 rdf:type guide:EvaluationTrial ;
    sch:name "Examen parcial 1" ;
    guide:evaluationType "Examen Escrito" ;
    guide:gradePercentage "50%" ;
    guide:minimumScore "4 / 10" ;
    guide:trialMode "Presencial" ;
    guide:involvesCompetency :Comp_CE6, :Comp_CT4 .

:Trial_ExamenFinal rdf:type guide:EvaluationTrial ;
    sch:name "Examen final parcial 1" ;
    guide:evaluationType "Examen Escrito" ;
    guide:gradePercentage "100%" ;
    guide:minimumScore "5 / 10" ;
    guide:trialMode "Presencial" .

# --- Schedule and Activities ---

:Schedule_Aplicaciones_Servicios rdf:type guide:Schedule ;
    sch:eventSchedule :Event_Week1, :Event_Week8, :Event_Week17 .

:Event_Week1 rdf:type guide:ScheduleEvent ;
    guide:eventWeek "Semana 1"@en ;
    guide:eventIndex 1 ;
    guide:hasActivity :Act_Tema1 .

:Act_Tema1 rdf:type guide:Activity ;
    guide:activityDescription "Tema 1. Economía digital"@en ;
    guide:activityDuration 2.0 ;
    guide:activityFormat "Lección Magistral"@en ;
    guide:attendanceType "Presencial"@en .

:Event_Week8 rdf:type guide:ScheduleEvent ;
    guide:eventWeek "Semana 8"@en ;
    guide:eventIndex 8 ;
    guide:hasActivity :Act_ExamenParcial1 .

:Act_ExamenParcial1 rdf:type guide:Activity ;
    guide:activityDescription "Realización del examen parcial 1"@en ;
    guide:activityDuration 2.0 ;
    guide:activityFormat "Examen"@en .

