# --- Evaluation System ---

guide:EvaluationSystem_53001917 rdf:type guide:EvaluationSystem ;
    guide:evaluationDescription "Composición del examen teórico-práctico: Teoría 50%, Problemas 50%. Nota mínima 3/10 en cada parte. Aprobado con 5/10." ;
    guide:hasEvaluationTrial guide:EvaluationTrial_Exam_Progressive, guide:EvaluationTrial_Exam_Global, guide:EvaluationTrial_Exam_Extraordinary .

guide:EvaluationTrial_Exam_Progressive rdf:type guide:EvaluationTrial ;
    guide:trialDescription "Examen teórico-práctico" ;
    guide:trialType "Examen Escrito" ;
    guide:trialMode "Presencial" ;
    guide:evaluationDuration "02:00" ;
    guide:gradePercentage "100%" ;
    guide:minimumScore "5 / 10" ;
    guide:evaluationType "Progresiva" ;
    guide:involvesCompetency guide:Competency_MUII_CE21, guide:Competency_MUCTN_CT08 .

guide:EvaluationTrial_Exam_Global rdf:type guide:EvaluationTrial ;
    guide:trialDescription "Prueba evaluación global" ;
    guide:trialType "Examen Escrito" ;
    guide:trialMode "Pres．encial" ;
    guide:evaluationDuration "02:00" ;
    guide:gradePercentage "100%" ;
    guide:minimumScore "5 / 10" ;
    guide:evaluationType "Global" .

guide:EvaluationTrial_Exam_Extraordinary rdf:type guide:EvaluationTrial ;
    guide:trialDescription "Examen teórico-practico convocatoria extraordinaria" ;
    guide:trialType "Examen Escrito" ;
    guide:trialMode "Presencial" ;
    guide:evaluationDuration "02:00" ;
    guide:gradePercentage "100%" ;
    guide:minimumScore "5 / 10" ;
    guide:evaluationType "Extraordinaria" .

