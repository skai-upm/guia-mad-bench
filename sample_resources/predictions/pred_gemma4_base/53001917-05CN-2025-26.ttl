guide:LearningResult_RA80 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA80" ;
    guide:learningResultDescription "Conocer los conceptos relacionados con el transporte y sus modos" .

guide:LearningResult_RA76 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA76" ;
    guide:learningResultDescription "Valoración y validación del resultado obtenido" .

guide:LearningResult_RA81 rdf:type guide:LearningResult ;
