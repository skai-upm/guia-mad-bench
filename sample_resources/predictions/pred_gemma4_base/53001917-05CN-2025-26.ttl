# --- Course Guide ---

guide:CourseGuide_53001917_2S_2025_26 rdf:type guide:CourseGuide ;
    sch:name "Guía de Aprendizaje: Ingeniería del Transporte" ;
    sch:description "La asignatura de Ingeniería del Transporte pretende ofrecer una visión global sobre algunos de los aspectos más relevantes concernientes al transporte y la movilidad." ;
    sch:inLanguage "Castellano" ;
    guide:teachingPeriod "2025-26" ;
    guide:periodStartingMonth "Febrero" ;
    guide:periodEndingMonth "Junio" ;
    guide:numberOfCredits 3.0 ;
    guide:totalHours "78-81" ; # Based on 26-27 hours per ECTS
    sch:activitiesWorkload "Estimación de 26 a 27 horas por crédito ECTS" ;
    sch:director guide:Lecturer_Felipe_Jimenez_Alonso ;
    sch:instructor guide:Lecturer_Blanca_Arenas_Ramirez, 
                    guide:Lecturer_Luis_Martinez_Saez, 
                    guide:Lecturer_Felipe_Jimenez_Alonso, 
                    guide:Lecturer_Enrique_Alcala_Fazio, 
                    guide:Lecturer_Jose_Maria_Lopez_Martinez ;
    guide:hasSyllabus guide:Syllabus_53001917 ;
    guide:hasEvaluation guide:EvaluationSystem_53001917 ;
    guide:hasCompetency guide:Competency_MUCTN_CT08, guide:Competency_MUII_a, guide:Competency_MUII_e, guide:Competency_MUII_h, guide:Competency_MUII_j, guide:Competency_MUII_CB07, guide:Competency_MUII_CB08, guide:Competency_MUII_CB10, guide:Competency_MUII_CE21, guide:Competency_MUII_CG01, guide:Competency_MUII_CG08, guide:Competency_MUII_CG09, guide:Competency_MUII_CG11 ;
    guide:hasLearningResult guide:LearningResult_RA75, guide:LearningResult_RA78, guide:LearningResult_RA54, guide:LearningResult_RA71, guide:LearningResult_RA77, guide:LearningResult_RA80, guide:LearningResult_RA76, guide:LearningResult_RA81, guide:LearningResult_RA73, guide:LearningResult_RA70, guide:LearningResult_RA74, guide:LearningResult_RA79, guide:LearningResult_RA72 ;
    guide:hasDidacticResource guide:Resource_Libro_Ingenieria, guide:Resource_Moodle_Docs, guide:Resource_Moodle_Ejercicios ;
    sch:courseSchedule guide:Schedule_53001917 .

