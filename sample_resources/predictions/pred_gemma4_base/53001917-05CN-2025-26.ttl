# --- Competencies ---

guide:Competency_MUCTN_CT08 rdf:type guide:Competency ;
    guide:competencyCode "MUCTN.CT08" ;
    guide:competencyDescription "Entiende los impactos. Educación amplia necesaria para entender el impacto de las<0xC2>aciones ingenieriles en un contexto social global" .

guide:Competency_MUII_a rdf:type guide:Competency ;
    guide:competencyCode "MUII. (a)" ;
    guide:competencyDescription "APLICA. Habilidad para aplicar conocimientos científicos, matemáticos y tecnológicos en sistemas relacionados con la práctica de la ingeniería." .

guide:Competency_MUII_e rdf:type guide:Competency ;
    guide:competencyCode "MUII. (e)" ;
    guide:competencyDescription "RESUELVE. Habilidad para identificar, formular y resolver problemas de ingeniería." .

guide:Competency_MUII_h rdf:type guide:Competency ;
    guide:competencyCode "MUII. (h)" ;
    guide:competencyDescription "ENTIENDE LOS IMPACTOS. Educación amplia necesaria para entender el impacto de las soluciones ingenieriles en un contexto social global." .

guide:Competency_MUII_j rdf:type guide:Competency ;
    guide:competencyCode "MUII. (j)" ;
    guide:competencyDescription "CONOCE. Conocimiento de los temas contemporáneos." .

guide:Competency_MUII_CB07 rdf:type guide:Competency ;
    guide:competencyCode "MUII.CB07" ;
    guide:competencyDescription "Que los estudiantes sepan aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en entornos nuevos o poco conocidos dentro de contextos más amplios" .

guide:Competency_MUII_CB08 rdf:type guide:Competency ;
    guide:competencyCode "MUII.CB08" ;
    guide:competencyDescription "Que los estudiantes sean capaces de integrar conocimientos y enfrentarse a la...” .

guide:Competency_MUII_CB10 rdf:type guide:Competency ;
    guide:competencyCode "MUII.CB10" ;
    guide:competencyDescription "Que los estudiantes posean las habilidades de aprendizaje que les permitan continuar estudiando de un modo que habrá de ser en gran medida autodirigido o autónomo." .

guide:Competency_MUII_CE21 rdf:type guide:Competency ;
    guide:competencyCode "MUII.CE21" ;
    guide:competencyDescription "Conocimientos sobre métodos y técnicas del transporte y manutención industrial." .

guide:Competency_MUII_CG01 rdf:type guide:Competency ;
    guide:competencyCode "MUII.CG01" ;
    guide:competencyDescription "Tener conocimientos adecuados de los aspectos científicos y tecnológicos..." .

guide:Competency_MUII_CG08 rdf:type guide:Competency ;
    guide:competencyCode "MUII.CG08" ;
    guide:competencyDescription "Aplicar los conocimientos adquiridos y resolver problemas en entornos nuevos o poco conocidos dentro de contextos más amplios y multidisciplinares." .

guide:Competency_MUII_CG09 rdf:type guide:Competency ;
    guide:competencyCode "MUII.CG09" ;
    guide:competencyDescription "Ser capaz de integrar conocimientos y enfrentarse a la complejidad..." .

guide:Competency_MUII_CG11 rdf:type guide:Competency ;
    guide:competencyCode "MUII.CG11" ;
    guide:competencyDescription "Poseer las habilidades de aprendizaje que permitan continuar estudiando de un modo autodirigido o autónomo." .

