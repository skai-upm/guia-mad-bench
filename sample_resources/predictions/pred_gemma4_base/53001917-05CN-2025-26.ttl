guide:LearningResult_RA73 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA73" ;
    guide:learningResultDescription "Conocer las distintas tecnologías de seguridad de los vehículos automóviles" .

guide:LearningResult_RA70 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA70" ;
    guide:learningResultDescription "Conocer y saber aplicar los modelos de flujo de tráfico" .

guide:LearningResult_RA74 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA74" ;
    guide:learningResultDescription "Organiza la información" .

guide:LearningResult_RA79 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA79" ;
    guide:learningResultDescription "Conocer los equipos destinados a los procesos de manutención y transporte" .

guide:LearningResult_RA72 rdf:type guide:LearningResult ;
