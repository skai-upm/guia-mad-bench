    sch:name "Guía de Aprendizaje - Prototipado" ;
    sch:instructor :Roberto_Damato, :Manuel_Enrique_Islan_Marcos, :Fernando_Blaya_Haro, :Jaime_Solleiro_Rodriguez ;
    guide:numberOfCredits 4.5 ;
    guide:teachingPeriod "2025-26" ;
    guide:periodStartingMonth "Febrero" ;
    guide:periodEndingMonth "Junio" ;
    sch:inLanguage "Castellano" ;
    guide:hasSyllabus :Prototipado_Syllabus ;
    guide:hasLearningResult :RA45, :RA47, :RA44, :RA46, :RA48, :RA49 ;
    guide:hasCompetency :CE1, :CE4, :CE5, :CE8, :CG1, :CG2, :CG3, :CG4, :CG5, :CG7, :CT2, :CT3, :CT5, :CT7 ;
    guide:hasEvaluation :Prototipado_EvalSystem ;
    sch:courseSchedule :Prototipado_Schedule ;
    guide:hasDidacticResource :Printer3D_FDM, :Tools_Assembly, :Printer_Ultimaker_5S ;
    guide:otherInformation "La asignatura se relaciona con los ODS1, ODS3, ODS8, ODS9 Y ODS17. Las tutorías individuales se podrán realizar por vía telemática." .

