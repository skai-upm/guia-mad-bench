:Event_Week4 rdf:type guide:ScheduleEvent ; guide:eventWeek "4" ; guide:hasActivity :Act_LM_Topic3 .
:Act_LM_Topic3 rdf:type guide:Activity ; guide:activityDescription "Tema 3" ; guide:activityDuration 3.0 ; guide:activityFormat "Lección Magistral" ; guide:attendanceType "Presencial" .

:Event_Week5 rdf:type guide:ScheduleEvent ; guide:eventWeek "5" ; guide:hasActivity :Act_PL_Topic3_Opt .
