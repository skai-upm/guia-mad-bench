:Prototipado_Schedule rdf:type guide:Schedule ;
    sch:eventSchedule :Event_Week1, :Event_Week2, :Event_Week3, :Event_Week4, :Event_Week5, :Event_Week6, :Event_Week7, :Event_Week8, :Event_Week9, :Event_Week10, :Event_Week11, :Event_Week12, :Event_Week13 .

