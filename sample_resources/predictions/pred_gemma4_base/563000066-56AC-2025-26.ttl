# Evaluation System
:Prototipado_EvalSystem rdf:type guide:EvaluationSystem ;
    guide:evaluationDescription "Evaluación progresiva y prueba global." ;
    guide:hasEvaluationTrial :Trial_Assignment, :Trial_Global .

:Trial_Assignment rdf:type guide:EvaluationTrial ;
    guide:trialType "Trabajo" ;
    guide:trialMode "Presencial" ;
    guide:evaluationType "Progresiva" ;
    guide:gradePercentage "100%" ;
    guide:minimumScore "5 / 10" ;
    guide:trialWeek "12" ;
    guide:trialDescription "Presentación y Entrega de Trabajos Personal o de Grupo" ;
    guide:involvesCompetency :CG1, :CG3, :CG7, :CG2, :CG4, :CG5, :CT2, :CT3, :CT5, :CT7, :CE1, :CE4, :CE8, :CE5 .

:Trial_Global rdf:type guide:EvaluationTrial ;
    guide:trialType "Trabajo Individual" ;
    guide:trialMode "Presencial" ;
    guide:evaluationType "Global" ;
    guide:gradePercentage "100%" ;
    guide:minimumScore "5 / 10" ;
    guide:trialWeek "13" ;
    guide:trialDescription "Prueba global" ;
    guide:involvesCompetency :CG1, :CG3, :CG7, :CG2, :CG4, :CG5, :CT2, :CT3, :CT5, :CT7, :CE1, :CE4, :CE8, :CE5 .

