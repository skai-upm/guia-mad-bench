# Competencies
:CE30 rdf:type guide:Competency ;
    guide:competencyCode "CE30" ;
    guide:competencyDescription "Capacidad de planificación, gestión y explotación de infraestructuras relacionadas con la ingeniería civil." .

:CE33 rdf:type guide:Competency ;
    guide:competencyCode "CE33" ;
    guide:competencyDescription "Capacidad para aplicar los conocimientos técnicos en actividades de I+D+i dentro del ámbito de la ingeniería civil." .

:CE41 rdf:type guide:Competency ;
    guide:competencyCode "CE41" ;
    guide:competencyDescription "Capacidad para aplicar los conocimientos técnicos en la evaluación de infraestructuras y sistemas de transporte" .

:CGP03 rdf:type guide:Competency ;
    guide:competencyCode "CGP03" ;
    guide:competencyDescription "Conocimiento, comprensión y capacidad para aplicar la legislación necesaria en el ejercicio de la profesión de Ingeniero de Caminos, Canales y Puertos." .

:CGP07 rdf:type guide:Competency ;
    guide:competencyCode "CGP07" ;
    guide:competencyDescription "Capacidad para planificar, proyectar, inspeccionar y dirigir obras de infraestructuras de transportes terrestres o marítimos." .

:CT1 rdf:type guide:Competency ;
    guide:competencyCode "CT1" ;
    guide:competencyDescription "Capacidad de preparar y presentar comunicaciones orales, escritas y gráficas, estructurada y argumentadamente." .

# Learning Results
:RA1 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA1" ;
    guide:learningResultDescription "Formula y resuelve problemas matemáticos y numéricos avanzados de ingeniería civil..." .

:RA97 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA97" ;
    guide:learning．learningResultDescription "Es capaz de diseñar la gestión del tráfico de una red viaria urbana." .

:RA98 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA98" ;
    guide:learningResultDescription "Conoce los fundamentos de la gestión de la seguridad de la circulación viaria." .

# Syllabus
:Syllabus_Gestion_Circulacion rdf:type guide:Syllabus ;
    guide:hasItem :Tema1, :Tema2, :Tema3, :Tema4, :Tema5 .

:Tema1 rdf:type guide:SyllabusItem ;
    guide:itemIndex 1 ;
    guide:syllabusDescription "Caracterización de la circulación viaria" .

:Tema2 rdf:type guide:SyllabusItem ;
    guide:itemIndex 2 ;
    guide:syllabusDescription "El accidente de tráfico" .

# Evaluation System
:EvalSystem_Gestion_Circulacion rdf:type guide:EvaluationSystem ;
    guide:evaluationDescription "Evaluación continua y prueba evaluación global." ;
    guide:hasEvaluationTrial :Trial_Examen_Continuo, :Trial_Proyecto_Seguridad, :Trial_Examen_Global .

:Trial_Examen_Continuo rdf:type guide:EvaluationTrial ;
    guide:trialType "Examen Escrito" ;
    guide:evaluationType "progresiva" ;
    guide:gradePercentage "35%" ;
    guide:minimumScore "5 / 10" ;
    guide:trialMode "Presencial" .

:Trial_Proyecto_Seguridad rdf:type guide:EvaluationTrial ;
    guide:trialType "Examen Escrito (Proyecto)" ;
    guide:evaluationType "progresiva" ;
    guide:gradePercentage "20%" ;
    guide:minimumScore "0 / 10" ;
    guide:trialMode "Presencial" .

