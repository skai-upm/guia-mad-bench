# Degree and University Center
:Master_Software_Systems rdf:type guide:MasterDegree ;
    sch:name "10AK - Master Universitario en Software y Sistemas" ;
    guide:degreeCode "10AK" .

:ETS_Informaticos rdf:type guide:UniversityCenter ;
    sch:name "E.T.S. De Ingenieros Informáticos" ;
    guide:offers :Master_Software_Systems .

# Course
:Computer_Security_Course rdf:type guide:Course ;
    sch:name "103000590 - Computer Security" ;
    sch:courseCode 103000590 ;
    guide:courseType "Optional/elective" ;
    guide:courseYear 2025 ;
    guide:semester "Semester 1" ;
    sch:hasCourseInstance :Computer_Security_Guide .

# Course Guide
:Computer_Security_Guide rdf:type guide:CourseGuide ;
    sch:name "Learning Guide - Computer Security" ;
    sch:description "This course will focus on providing the students with a global view of the field of computer security."@en ;
    sch:inLanguage "English"@en ;
    guide:teachingPeriod "2025-26" ;
    guide:periodStartingMonth "September" ;
    guide:periodEndingMonth "January" ;
    guide:numberOfCredits 4.0 ;
    guide:totalHours "26/27 hours of student face-to-face contact and independent study time" ;
    guide:hasSyllabus :Computer_Security_Syllabus ;
    guide:hasEvaluation :Computer_Security_EvalSystem ;
    guide:hasCompetency :CG1, :CG13, :CG4, :CG8, :CG9, :CGI20, :CGI23 ;
    guide:hasLearningResult :RA12, :RA112 ;
    sch:instructor :Manuel_Carro_Linares ;
    sch:courseSchedule :Computer_Security_Schedule ;
    guide:hasDidacticResource :Various_Resources .

