# Competencies
:CG1 rdf:type guide:Competency ; guide:competencyCode "CG1" ; guide:competencyDescription "Que los estudiantes sepan aplicar los conocimientos adquiridos y su capacidad de...”@en .
:CG13 rdf:type guide:Competency ; guide:competencyCode "CG13" ; guide:competencyDescription "Apreciación de los límites del conocimiento actual..."@en .
:CG4 rdf:type guide:Competency ; guide:competencyCode "CG4" ; guide:competencyDescription "Que los estudiantes posean las habilidades de aprendizaje..."@en .
:CG8 rdf:type guide:Competency ; guide:competencyCode "CG8" ; guide:competencyDescription "Planteamiento y resolución de problemas también en áreas nuevas..."@en .
:CG9 rdf:type guide:Competency ; guide:competencyCode "CG9" ; guide:competencyDescription "Aplicación de los métodos de resolución de problemas más recientes..."@en .
:CGI20 rdf:type guide:Competency ; guide:competencyCode "CGI20" ; guide:competencyDescription "Adquirir conocimientos científicos avanzados del campo de la informática..."@en .
:CGI23 rdf:type guide:Competency ; guide:competencyCode "CGI23" ; guide:competencyDescription "Capacidad de leer y comprender publicaciones dentro de su ámbito..."@en .

# Learning Results
:RA12 rdf:type guide:LearningResult ; guide:learningResultCode "RA12" ; guide:learningResultDescription "Be familiar with examples of real applications and research trends and lines"@en .
:RA112 rdf:type guide:LearningResult ; guide:learningResultCode "RA112" ; guide:learningResultDescription "Identify computer security threats and decide the best proactive and reactive measures against them"@en .

# Syllabus
:Computer_Security_Syllabus rdf:type guide:Syllabus ;
    guide:hasItem :Syllabus_Intro, :Syllabus_Network, :Syllabus_Software .

:Syllabus_Intro rdf:type guide:SyllabusItem ; guide:itemIndex 1 ; guide:syllabusDescription "Introduction to Security" .
:Syllabus_Network rdf:type guide:SyllabusItem ; guide:itemIndex 2 ; guide:syllabusDescription "Network and web security" .
:Syllabus_Software rdf:type guide:SyllabusItem ; guide:itemIndex 3 ; guide:syllabusDescription "Software security" .

# Schedule & Activities
:Computer_Security_Schedule rdf:type guide:Schedule ;
    sch:eventSchedule :Event_Week1, :Event_Week9, :Event_Week17 .

:Event_Week1 rdf:type guide:ScheduleEvent ; guide:eventWeek "1" ; guide:hasActivity :Activity_Intro .
:Activity_Intro rdf:type guide:Activity ; guide:activityDescription "Course Introduction" ; guide:activityDuration 2.0 ; guide:activityFormat "Lecture" .

:Event_Week9 rdf:type guide:ScheduleEvent ; guide:eventWeek "9" ; guide:hasActivity :Activity_Midterm_Exam .
:Activity_Midterm_Exam rdf:type guide:Activity ; guide:activityDescription "Midterm exam" ; guide:activityDuration 2.0 ; guide:activityFormat "Written test" .

:Event_Week17 rdf:type guide:ScheduleEvent ; guide:eventWeek "17" ; guide:hasActivity :Activity_Global_Exam .
:Activity_Global_Exam rdf:type guide:Activity ; guide:activityDescription "Global exam" ; guide:activityDuration 2.0 ; guide:activityFormat "Written test" .

# Evaluation System
:Computer_Security_EvalSystem rdf:type guide:EvaluationSystem ;
    guide:evaluationDescription "The evaluation will be based on two exams: mid-term and final."@en ;
    guide:hasEvaluationTrial :Midterm_Trial, :Global_Trial .

:Midterm_Trial rdf:type guide:EvaluationTrial ;
    guide:trialType "Written test" ;
    guide:evaluationType "Progressive assessment" ;
    guide:gradePercentage "50%" ;
    guide:minimumScore "2 / 10" ;
    guide:trialWeek "9" ;
    guide:hasScheduleEvent :Event_Week9 ;
    guide:involvesCompetency :CG4, :CG8, :CG9, :CG1, :CG13, :CGI2:20, :CGI23 .

:Global_Trial rdf:type guide:EvaluationTrial ;
    guide:trialType "Written test" ;
    guide:evaluationType "Global examination" ;
    guide:gradePercentage "100%" ;
    guide:minimumScore "5 / 10" ;
    guide:trialWeek "17" ;
    guide:hasScheduleEvent :Event_Week17 ;
    guide:involvesCompetency :CG4, :CG8, :CG9, :CG1, :CG13, :CGI20, :CGI23 .

# Resources
:Various_Resources rdf:type guide:DidacticResource ;
    sch:name "Various" ;
    guide:bibliographyType "Others" ;
    guide:bibliographyDescription "Will be decided based on the selected topics."@en .

# Prior Knowledge
:Prior_Knowledge_Security rdf:type guide:RequiredKnowledge ;
    guide:previousKnowledge "An undergraduate level course on computer security is desired but not required. Some demonstrable knowledge on the basic principles of computer security is necessary."@en .