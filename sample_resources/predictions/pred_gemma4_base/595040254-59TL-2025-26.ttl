### Syllabus ###

:Syllabus_595040254 rdf:type guide:Syllabus ;
    guide:hasItem :Topic_1, :Topic_2, :Topic_3, :Topic_4, :Topic_5, :Topic_6, :Topic_7 .

:Topic_1 rdf:type guide:SyllabusItem ;
    guide:itemIndex 1 ;
    guide:syllabusDescription "Sociedad de la Información, sociedad del ruido y brechas digitales" .

:Topic_2 rdf:type guide:SyllabusItem ;
    guide:itemIndex 2 ;
    guide:syllabusDescription "TIC emergentes y retos sociales" .

:Topic_3 rdf:type guide:SyllabusItem ;
    guide:itemIndex 3 ;
    guide:syllabusDescription "Solucionismo, convivencialidad y tecnología apropiada" .

:Topic_4 rdf:type guide:SyllabusItem ;
    guide:itemIndex 4 ;
    guide:syllabusDescription "E-accesibilidad y diseño para todas las personas" .

:Topic_5 rdf:type guide:SyllabusItem ;
    guide:itemIndex 5 ;
    guide:syllabusDescription "Ética y legislación en robótica, IA, y Big Data" .

:Topic_6 rdf:type guide:SyllabusItem ;
    guide:itemIndex 6 ;
    guide:syllabusDescription "Transformación digital en integración, salud, y aprendizaje" .

:Topic_7 rdf:type guide:SyllabusItem ;
    guide:itemIndex 7 ;
    guide:syllabusDescription "Innovación y emprendimiento social" .

### Evaluation System ###

:EvalSystem_595040254 rdf:type guide:EvaluationSystem ;
    guide:evaluationDescription "La asignatura se imparte en modo seminario. La nota se compone de evaluación progresiva (60% presentaciones, 40% examen escrito) y una prueba global." ;
    guide:hasEvaluationTrial :Trial_Progressive_Presentation, :Trial_Progressive_Exam, :Trial_Global_Exam, :Trial_Extraordinary_Exam .

:Trial_Progressive_Presentation rdf:type guide:EvaluationTrial ;
    guide:trialType "Presentación Individual/Parejas" ;
    guide:evaluationType "progresiva" ;
．
    guide:gradePercentage "60%" ;
    guide:minimumScore "4 / 10" ;
    guide:evaluationDuration "00:40" ;
    guide:trialMode "Presencial" ;
    guide:involvesCompetency :Comp_CETEL03, :Comp_CETEL16, :Comp_CG02, :Comp_CG03, :Comp_CG04, :Comp_CG05, :Comp_CG06, :Comp_CG09, :Comp_CG10, :Comp_CG11 .

