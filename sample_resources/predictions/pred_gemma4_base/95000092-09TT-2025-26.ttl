:item_tema1 a guide:SyllabusItem ;
    guide:itemIndex 1 ;
    guide:syllabusDescription "Tema 1: El mundo en que vivimos" .

:item_tema2 a guide:SyllabusItem ;
    guide:itemIndex 2 ;
    guide:syllabusDescription "Tema 2: Estrategias de la cooperación para el desarrollo" .

:item_tema3 a guide:SyllabusItem ;
    guide:itemIndex 3 ;
    guide:syllabusDescription "Tema 3: Metodología de proyectos en cooperación" .

:item_tema4 a guide:SyllabusItem ;
    guide:itemIndex 4 ;
    guide:syllabusDescription "Tema 4: Aplicaciones TIC para el Desarrollo" .

:item_tema5 a guide:SyllabusItem ;
    guide:itemIndex 5 ;
    guide:syllabusDescription "Tema 5: Aplicaciones de electrificación rural" .

# Evaluation System
:evalSystem_95000092 a guide:EvaluationSystem ;
    guide:evaluationDescription "La evaluación progresiva se basa en la participación activa, análisis de libro, proyecto y examen final." ;
    guide:hasEvaluationTrial :trial_participacion, :trial_libro, :trial_proyecto, :trial_examen_final .

:trial_participacion a guide:EvaluationTrial ;
    guide:trialType "Participación activa" ;
    guide:evaluationType "Progresiva" ;
    guide:gradePercentage "20%" ;
    guide:trialMode "Presencial" .

:trial_libro a guide:EvaluationTrial ;
    guide:trialType "Análisis de un libro" ;
    guide:evaluationType "Progresiva" ;
    guide:gradePercentage "20%" ;
    guide:trialMode "Presencial" .

:trial_proyecto a guide:EvaluationTrial ;
    guide:trialType "Proyecto de cooperación" ;
    guide:evaluationType "Progresiva" ;
    guide:gradePercentage "35%" ;
    guide:trialMode "Presencial" .

:trial_examen_final a guide:EvaluationTrial ;
    guide:trialType "Examen final tipo test" ;
    guide:evaluationType "Global" ;
    guide:gradePercentage "45%" ;
    guide:trialMode "Presencial" ;
    guide:minimumScore "5.0" .

