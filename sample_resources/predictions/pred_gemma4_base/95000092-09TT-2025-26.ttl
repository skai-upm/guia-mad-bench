# Learning Results
:lr_RA357 a guide:LearningResult ;
    guide:learningResultCode "RA357" ;
    guide:learningResultDescription "Concreción de los conocimientos en aplicaciones prácticas en los ámbitos de las TIC, y la electrificación rural" .

:lr_RA354 a guide:LearningResult ;
    guide:learningResultCode "RA354" ;
    guide:learningResultDescription "Adquisión de una visión objetiva y amplia de los actuales desequilibrios sociales y medioambientales" .

:lr_RA45 a guide:LearningResult ;
    guide:learningResultCode "RA45" ;
    guide:learningResultDescription "Conocimientos y habilidades de las temáticas científico tecnológicas desarrolladas en las asignaturas ofertadas" .

:lr_RA355 a guide:LearningResult ;
    guide:learningResultCode "RA355" ;
    guide:learningResultDescription "Conocimiento de la estructura y los instrumentos de la cooperación internacional para el desarrollo" .

:lr_RA356 a guide:LearningResult ;
    guide:learningResultCode "RA356" ;
    guide:learningResultDescription "Conocimiento y aplicación de metodologías de planificación e intervención en proyectos de desarrollo" .

# Syllabus
:syllabus_95000092 a guide:Syllabus ;
