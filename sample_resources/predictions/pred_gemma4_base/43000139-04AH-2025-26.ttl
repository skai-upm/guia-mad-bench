# --- Competencies ---

:CB10 rdf:type guide:Competency ;
    guide:competencyCode "CB10" ;
    guide:competencyDescription "Que los estudiantes posean las habilidades de aprendizaje que les permitan continuar estudiando de un modo que habrá de ser en gran medida autodirigido o autónomo." .

:CE_A1 rdf:type guide:Competency ;
    guide:competencyCode "CE-A1" ;
    guide:competencyDescription "Capacitación científico-técnica y metodológica suficiente para el proyecto, análisis, planificación, explotación y mantenimiento de obras civiles..." .

:CE_A2 rdf:type guide:Competency ;
    guide:competencyCode "CE-A2" ;
    guide:competencyDescription "Conocimiento y capacidad para proyectar y dimensionar obras e instalaciones de ingeniería civil" .

# --- Learning Results ---

:RA10 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA10" ;
    guide:learningResultDescription "Argumenta la resolucion de los problemas de gestion mediante logica cientifica y aplicando una metodologia razonada." .

:RA103 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA103" ;
    guide:learningResultDescription "Aplica técnicas de optimización a la resolución de problemas de sistemas de ingeniería civil" .

# --- Syllabus ---

:Syllabus_Ingenieria_Ferroviaria rdf:type guide:Syllabus ;
    guide:hasItem :Tema_1, :Tema_2, :Tema_3 .

:Tema_1 rdf:type guide:SyllabusItem ;
    guide:itemIndex 1 ;
    guide:syllabusDescription "El proyecto ferroviario (Fundamentos, trazado, instalaciones, material móvil, métodos constructivos)" .

:Tema_2 rdf:type guide:SyllabusItem ;
    guide:itemIndex 2 ;
    guide:syllabusDescription "Comportamiento de la vía ferroviaria (Esfuerzos estáticos y dinámica de la vía)" .

:Tema_3 rdf:type guide:SyllabusItem ;
    guide:itemIndex 3 ;
    guide:syllabusDescription "Mantenimiento ferroviario (Confort, calidad, auscultación, RAMS, capacidad)" .

# --- Evaluation System ---

:EvalSystem_Ingenieria_Ferroviaria rdf:type guide:EvaluationSystem ;
    guide:evaluationDescription "Evaluación continua mediante controles y exámenes parciales, y prueba de evaluación global." ;
    guide:hasEvaluationTrial :Control_Sem4, :Examen_Parcial_Sem9, :Examen_Ordinario_Sem17 .

:Control_Sem4 rdf:type guide:EvaluationTrial ;
    guide:evaluationType "Evaluación Progresiva" ;
    guide:trialWeek "4" ;
    guide:gradePercentage "10%" ;
    guide:minimumScore "0 / 10" ;
    guide:trialType "Examen Escrito" ;
    guide:trialMode "Presencial" .

:Examen_Parcial_Sem9 rdf:type guide:EvaluationTrial ;
    guide:evaluationType "Evaluación Progresiva" ;
    guide:trialWeek "9" ;
    guide:gradePercentage "35%" ;
    guide:minimumScore "4 / 10" ;
    guide:trialType "Examen Escrito" ;
    guide:trialMode "Presencial" .

:Examen_Ordinario_Sem17 rdf:type guide:EvaluationTrial ;
    guide:evaluationType "Evaluación Global" ;
    guide:trialWeek "17" ;
    guide:gradePercentage "100%" ;
    guide:minimumScore "5 / 10" ;
    guide:trialType "Examen Escrito" ;
    guide:trialMode "Presencial" .

# --- Didactic Resources ---

:Moodle_Resource rdf:type guide:DidacticResource ;
    sch:name "Moodle" ;
    guide:bibliographyType "Recursos web" ;
    guide:bibliographyDescription "Toda la información del curso estará disponible en la plataforma Moodle" .

:Libro_Lopez_Pita rdf:type guide:DidacticResource ;
    sch:name "López Pita, A.: 'Infraestructuras ferroviarias'. 2ºed. Barcelona, 2010" ;
    guide:bibliographyType "Bibliografía" .

:Libro_Losada rdf:type guide:DidacticResource ;
    sch:name "Losada, M.: 'Curso de Ferrocarriles: Cuadernos I, II, III, IV y V.' Servicio de Publicaciones" ;
    guide:bibliographyType "Bibliografía" .

# --- Required Knowledge ---

:Conocimientos_Previos_Ingenieria_Ferroviaria rdf:type guide:RequiredKnowledge ;
    guide:previousKnowledge "Transportes, Geología" .