# --- Degree and University Center ---

:Master_Sistemas_Ingenieria_Civil rdf:type guide:MasterDegree ;
    sch:name "Master Universitario En Sistemas De Ingenieria Civil" ;
    guide:degreeCode "04AH" .

:ETS_Caminos_Canales_P rdf:type guide:UniversityCenter ;
    sch:name "E.T.S. de Ing. de Caminos Canales y P." ;
    guide:degreeCode "04" ;
    guide:offers :Master_Sistemas_Ingenieria_Civil .

# --- Course ---

:Curso_Ingenieria_Ferroviaria rdf:type guide:Course ;
    sch:name "43000139 - Ingenieria Ferroviaria" ;
    sch:courseCode 43000139 ;
    guide:courseType "Optativa" ;
    guide:semester "Primer semestre" .

:Master_Sistemas_Ingenieria_Civil guide:hasCourse :Curso_Ingenieria_Ferroviaria .

# --- Course Guide ---

:Guia_Aprendizaje_Ingenieria_Ferroviaria rdf:type guide:CourseGuide ;
    sch:name "Guía de Aprendizaje - Ingeniería Ferroviaria" ;
    sch:hasCourseInstance :Curso_Ingenieria_Ferroviaria ;
    guide:numberOfCredits 4.5 ;
    guide:teachingPeriod "2025-26" ;
    guide:periodStartingMonth "Septiembre" ;
    guide:periodEndingMonth "Enero" ;
    sch:inLanguage "Castellano" ;
    sch:description "La asignatura está dirigida a estudiantes que quieran especializarse en actividades del sector ferroviario. Contempla el ciclo completo de via de un proyecto ferroviario desde su concepción hasta su puesta en servicio." ;
    sch:director :Carlos_Romero_Morales ;
    sch:instructor :Luis_Esteras_Aldea, :Juan_Jose_Alvarez_Gonzalez, :Juan_Gomez_Sanchez, :Clara_Isabel_Zamorano_Martin ;
    guide:hasSyllabus :Syllabus_Ingenieria_Ferroviaria ;
    guide:hasCompetency :CB10, :CE_A1, :CE_A2, :CE_A5, :CE_A6, :CE_A7 ;
    guide:hasLearningResult :RA10, :RA103, :RA109, :RA97, :RA20, :RA98, :RA96, :RA95, :RA13, :RA65, :RA12, :RA113, :RA14, :RA63 ;
    guide:hasEvaluation :EvalSystem_Ingenieria_Ferroviaria ;
    guide:hasDidacticResource :Moodle_Resource, :Libro_Lopez_Pita, :Libro_Losada .

