# Competencies
:comp_MUII_C rdf:type guide:Competency ;
    guide:competencyCode "MUII. (c)" ;
    guide:competencyDescription "DISEÑA Habilidad para diseñar un sistema, componente o proceso que alcance los requisitos deseados teniendo en cuenta" .

:comp_MUII_E rdf:type guide:Competency ;
    guide:competencyCode "MUII. (e)" ;
    guide:competencyDescription "RESUELVE. Habilidad para identificar, formular y resolver problemas de ingeniería." .

:comp_MUII_G rdf:type guide:Competency ;
    guide:competencyCode "MUII. (g)" ;
    guide:competencyDescription "COMUNICA Habilidad para comunicar eficazmente." .

:comp_MUII_CB07 rdf:type guide:Competency ;
    guide:competencyCode "MUII.CB07" ;
    guide:competencyDescription "Que los estudiantes sepan aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en entornos nuevos o poco conocidos dentro de contextos más amplios" .

:comp_MUII_CB09 rdf:type guide:Competency ;
    guide:competencyCode "MUII.CB09" ;
    guide:competencyDescription "Que los estudiantes sepan comunicar sus conclusiones y los conocimientos y razones últimas que las sustentan a públicos especializados y no especializados de un modo claro y sin ambigüedades" .

:comp_MUII_CE02 rdf:type guide:Competency ;
    guide:competencyCode "MUII.CE02" ;
    guide:competencyDescription "Conocimiento y capacidad para proyectar, calcular y diseñar sistemas integrados de fabricación." .

:comp_MUII_CG02 rdf:type guide:Competency ;
    guide:competencyCode "MUII.CG02" ;
    guide:competencyDescription "Proyectar, calcular y diseñar productos, procesos, instalaciones y plantas." .

:comp_MUII_CG06 rdf:type guide:Competency ;
    guide:competencyCode "MUII.CG06" ;
    guide:competencyDescription "Gestionar técnica y económicamente proyectos, instalaciones, plantas, empresas y centros tecnológicos." .

:comp_MUII_CG08 rdf:type guide:Competency ;
    guide:competencyCode "MUII.CG08" ;
    guide:competencyDescription "Aplicar los conocimientos adquiridos y resolver problemas en entornos nuevos o poco conocidos dentro de contextos más amplios y multidisciplinares." .

:comp_MUII_CG10 rdf:type guide:Competency ;
    guide:competencyCode "MUII.CG10" ;
    guide:competencyDescription "Saber comunicar las conclusiones ¿y los conocimientos y razones últimas que las sustentan¿ a públicos especializados y no especializados de un modo claro y sin ambigüedades." .

# Learning Results
:lr_RA40 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA40" ;
    guide:learningResultDescription "Capacidad para analizar la influencia de determinadas variables en la eficiencia de un proceso" .

:lr_RA110 rdf:type guide:LearningResult ;
    guide:learning<0xC2>ResultCode "RA110" ;
    guide:learningResultDescription "Definir actuaciones de mejora y evolución sistemática" .

:lr_RA108 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA108" ;
    guide:learningResultDescription "Realización de trabajos prácticos sobre simulación de sistemas" .

:lr_RA38 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA38" ;
    guide:learningResultDescription "Capacidad para modelar un sistema de fabricación" .

:lr_RA39 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA39" ;
    guide:learningResultDescription "Capacidad para obtener los datos de producción que identifican el funcionamiento de un sistema de fabricación" .

# Syllabus
