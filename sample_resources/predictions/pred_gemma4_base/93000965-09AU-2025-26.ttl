# Course Guide
:guide_93000965_2025_26 a guide:CourseGuide ;
    sch:name "Guía de Aprendizaje - Modelado De Sistemas Biomédicos" ;
    sch:description "Introduction to the mathematical modelling of physiological systems. Model construction: modelling the system, modelling from data. Mathematical modelling techniques: Compartmental modelling, data-driven modelling, distributed models. Examples of physiological models: Metabolic compartmental models; Drug concentration models; Rythmic components models; Applications. Practical sessions in MATLAB and Simulink." ;
    guide:teachingPeriod "2025-26" ;
    guide:periodStartingMonth "Septiembre" ;
    guide:periodEndingMonth "Enero" ;
    guide:numberOfCredits 3.0 ;
    sch:inLanguage "Inglés/Castellano" ;
    sch:instructor :lecturer_gema_garcia, :lecturer_maria_elena_hernando ;
    guide:hasSyllabus :syllabus_93000965 ;
    guide:hasEvaluation :eval_system_93000965 ;
    sch:courseSchedule :schedule_93000965 ;
    guide:hasCompetency :comp_CB06, :comp_CB07, :comp_CB08, :comp_CB09, :comp_CB10, :comp_CE_MIB11, :comp_CG_MIB01, :comp_CG_MIB02, :comp_CG_MIB03, :comp_CG_MIB04, :comp_CG_MIB05, :comp_CG_MIB06, :comp_CG_MIB07 ;
    guide:hasLearningResult :lr_RA15, :lr_RA13, :lr_RA14 ;
    guide:hasDidacticResource :res_matlab, :res_book_cobelli, :res_book_ieee, :res_book_refinetti .

