# --- Syllabus ---
guide:Syllabus_565000215 rdf:type guide:Syllabus ;
    guide:hasItem guide:SyllabusItem_Topic1, guide:SyllabusItem_Topic2, guide:SyllabusItem_Topic3, guide:SyllabusItem_Topic10, guide:SyllabusItem_Topic15 .

guide:SyllabusItem_Topic1 rdf:type guide:SyllabusItem ;
    guide:itemIndex 1 ;
    guide:syllabusDescription "Fundamentos de DAO aplicado a la Expresión grafica"@en .

guide:SyllableItem_Topic2 rdf:type guide:SyllabusItem ;
    guide:itemIndex 2 ;
    guide:syllabusDescription "Introducción a la concepción espacial"@en .

guide:SyllabusItem_Topic3 rdf:type guide:SyllabusItem ;
    guide:itemIndex 3 ;
    guide:syllabusDescription "Paralelismo y perpendicularidad"@en .

guide:SyllabusItem_Topic10 rdf:type guide:SyllabusItem ;
    guide:itemIndex 10 ;
    guide:syllabusDescription "Introducción a la normalización industrial"@en .

guide:SyllabusItem_Topic15 rdf:type guide:SyllabusItem ;
    guide:itemIndex 15 ;
    guide:syllabusDescription "Simbología en las representaciónes"@en .

# --- Evaluation System ---
guide:EvalSystem_565000215 rdf:type guide:EvaluationSystem ;
    guide:evaluationDescription "Evaluación progresiva y examen global."@en ;
