    guide:bibliographyType "Bibliography" ;
    guide:bibliographyDescription "Connell, B.R.; et al. North Carolina State University." .

:Res_ISO_29138 rdf:type guide:DidacticResource ;
    guide:bibliographyTitle "Information technology -- User interface accessibility -- Part 1: User accessibility needs" ;
    guide:bibliographyType "Bibliography" ;
    guide:bibliographyDescription "ISO/IEC 29138-1:2018" .

