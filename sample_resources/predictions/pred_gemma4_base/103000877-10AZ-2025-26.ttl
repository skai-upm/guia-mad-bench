### Evaluation System ###

:EvalSystem_103000877 rdf:type guide:EvaluationSystem ;
    guide:evaluationDescription "The assessment of this module is divided into two parts: theory and practice. Both parts have to be passed in order to pass the module." ;
    guide:hasEvaluationTrial :Trial_Test1, :Trial_Exercise1, :Trial_Presentation3 .

:Trial_Test1 rdf:type guide:EvaluationTrial ;
    guide:trialType "Written test" ;
    guide:evaluationType "Progressive assessment" ;
    guide:gradePercentage "10%" ;
    guide:minimumScore "3/10" ;
    guide:trialMode "Not Presential" .

:Trial_Exercise1 rdf:type guide:EvaluationTrial ;
    guide:trialType "Group work" ;
    guide:evaluationType "Global examination" ;
    guide:gradePercentage "10%" ;
    guide:minimumScore "3/10" .

