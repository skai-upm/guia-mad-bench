# Degree and University Center
:Master_Software_Engineering rdf:type guide:MasterDegree ;
    sch:name "10AM - Master Universitario en Ingenieria del Software" .

:ETS_Informaticos rdf:type guide:UniversityCenter ;
    sch:name "E.T.S. De Ingenieros Informáticos" .

:ETS_Informaticos guide:offers :Master_Software_Engineering .

# Course
:EHealth_Course rdf:type guide:Course ;
    sch:name "103001025 - E-health: Promoting Active And Healthy Ageing" ;
    sch:courseCode 103001025 ;
    guide:courseType "Optional/elective" ;
    guide:courseYear 2025 .

:EHealth_Course sch:hasCourseInstance :EHealth_CourseGuide .

# Course Guide
:EHealth_CourseGuide rdf:type guide:CourseGuide ;
    sch:name "Learning Guide: E-health: Promoting Active And Healthy Ageing" ;
    sch:instructor :Elena_Villalba_Mora ;
    guide:hasSyllabus :EHealth_Syllabus ;
    guide:hasEvaluation :EHealth_EvalSystem ;
    guide:hasLearningResult :RA90, :RA91, :RA92, :RA93 ;
    guide:hasCompetency :CG1, :CG8, :CG18 ;
    guide:numberOfCredits 4.0 ;
    sch:courseSchedule :EHealth_Schedule ;
    guide:teachingPeriod "2025-26" ;
    guide:periodStartingMonth "September" ;
    guide:periodEndingMonth "January" ;
    guide:totalHours "26/27 hours of student face-to-face contact and independent study time" .

# Faculty
:Elena_Villalba_Mora rdf:type guide:Lecturer ;
    sch:name "Elena Villalba Mora" ;
    sch:email "elena.villalba@upm.es" ;
