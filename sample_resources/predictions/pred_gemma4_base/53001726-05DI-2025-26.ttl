# --- Degree and University Center ---

_:degree_industrial_eng rdf:type guide:BachelorDegree ;
    sch:name "05DI - D.m.u. en Ingeniería Industrial y en Automática y Robótica" ;
    guide:degreeCode "05DI" .

_:center_industrials rdf:type guide:UniversityCenter ;
    sch:name "E.T.S. De Ingenieros Industriales" ;
    guide:offers _:degree_industrial_eng .

# --- Course and Course Guide ---

_:course_dir_est rdf:type guide:Course ;
    sch:name "Dirección Estratégica y de la Innovación" ;
    sch:courseCode 53001726 ;
    guide:courseType "Obligatoria" ;
    guide:courseYear 2025 ;
    guide:semester "Cuarto semestre" .

_:course_guide_dir_est rdf:type guide:CourseGuide ;
    sch:hasCourseInstance _:course_dir_est ;
    sch:name "Guía de Aprendizaje - Dirección Estrের Estratégica y de la Innovación" ;
    sch:instructor _:lecturer_rafael ;
    sch:instructor _:lecturer_ebru ;
    guide:teachingPeriod "2025-26" ;
    guide:periodStartingMonth "Febrero" ;
    guide:periodEndingMonth "Junio" ;
    guide:numberOfCredits 3.0 ;
    guide:totalHours "78" ; # Calculated based on 26h per credit approx
    sch:inLanguage "Castellano" ;
    sch:description "La asignatura tiene como objetivos fundamentales que los alumnos sean capaces de abordar proyectos de innovación en un entorno real mediante trabajo colaborativo y aplicando metodologías como el Design Thinking." ;
    guide:hasSyllabus _:syllabus_dir_est ;
    guide:hasCompetency _:comp_bilingue, _:comp_originality, _:comp_problem_solving ;
    guide:hasLearningResult _:lr_ra87, _:lr_ra88, _:lr_ra89, _:lr_ra90, _:lr_ra9 ;
    guide:hasEvaluation _:eval_system_dir_est ;
    guide:hasDidacticResource _:res_moodle, _:res_chatgpt, _:res_book_chesbrough ;
    sch:courseSchedule _:schedule_dir_est .

