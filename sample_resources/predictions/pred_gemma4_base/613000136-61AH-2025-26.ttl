    guide:gradePercentage "50%" ;
    guide:minimumScore "5 / 10" ;
    guide:trialMode "Presencial" ;
    guide:evaluationDuration "02:00" ;
    guide:involvesCompetency guide:Comp_S01, guide:Comp_CB6, guide:Comp_CB8, guide:Comp_CB9, guide:Comp_CB10, guide:Comp_CG5, guide:Comp_CG1, guide:Comp_CG2, guide:Comp_CG3, guide:Comp_CG4, guide:Comp_CT1, guide:Comp_CT2, guide:Comp_CT3, guide:Comp_CT5 .

