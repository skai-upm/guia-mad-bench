# --- Syllabus ---
guide:Syllabus_613000136 rdf:type guide:Syllabus ;
    guide:hasItem guide:SyllabusItem_B1, guide:SyllabusItem_B2 .

guide:SyllabusItem_B1 rdf:type guide:SyllabusItem ;
    guide:itemIndex 1 ;
    guide:syllabusDescription "Bloque I (INVESTIGACIÓN): El conocimiento y la investigación, Impacto y diseminación, Redacción, Malas prácticas, Tesis Doctoral."@en .

guide:SyllabusItem_B2 rdf:type guide:SyllabusItem ;
    guide:itemIndex 2 ;
    guide:syllabusDescription "Bloque II (PROYECTOS): Concepción y diseño, Desarrollo de tema, Consorcio, Proyectos competitivos, Transferencia, Foros."@en .

# --- Evaluation System ---
guide:EvalSystem_613000136 rdf:type guide:EvaluationSystem ;
    guide:evaluationDescription "Evaluación progresiva y global con dos trabajos principales de 50% cada uno."@en ;
    guide:hasEvaluationTrial guide:Trial_Prog_1, guide:Trial_Prog_2, guide:Trial_Global, guide:Trial_Extraordinary .

