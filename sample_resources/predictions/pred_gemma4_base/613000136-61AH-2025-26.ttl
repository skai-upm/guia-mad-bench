    guide:hasCompetency guide:Comp_CB10, guide:Comp_CB6, guide:Comp_CB7, guide:Comp_CB8, guide:Comp_CB9, guide:Comp_CE01, guide:Comp_CG1, guide:Comp_CG2, guide:Comp_CG3, guide:Comp_CG4, guide:Comp_CG5, guide:Comp_CT1, guide:Comp_CT2, guide:Comp_CT3, guide:Comp_CT4, guide:Comp_CT5, guide:Comp_S01 ;
