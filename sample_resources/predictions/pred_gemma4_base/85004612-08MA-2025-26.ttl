# Competencies
:comp_CB2 rdf:type guide:Competency ;
    guide:competencyCode "CB2" ;
    guide:competencyDescription "Que los estudiantes sepan aplicar sus conocimientos a su trabajo o vocación de una forma profesional y posean las competencias que suelen demostrarse por medio de la elaboración y defensa de argumentos y la resolución de problemas dentro de su área de estudio" .

:comp_CB5 rdf:type guide:Competency ;
    guide:competencyCode "CB5" ;
    guide:competencyDescription "Que los estudiantes hayan desarrollado aquellas habilidades de aprendizaje necesarias para emprender estudios posteriores con un alto grado de autonomía" .

:comp_CE13 rdf:type guide:Competency ;
    guide:competencyCode "CE13" ;
    guide:competencyDescription "Conocimiento de la mecánica y de los componentes de maquinas" .

:comp_CE19 rdf:type guide:Competency ;
    guide:competencyCode "CE19" ;
    guide:competencyDescription "Conocimiento de los motores diesel marinos, turbinas de gas y plantas de vapor" .

:comp_CE23 rdf:type guide:Competency ;
    guide:competencyCode "CE23" ;
    guide:competencyDescription "Conocimiento de los métodos de proyecto de los sistemas de propulsión naval" .

:comp_CE7 rdf:type guide:Competency ;
    guide:competencyCode "CE7" ;
    guide:competencyDescription "Conocimiento de los conceptos fundamentales de la mecánica de fluidos y de su aplicación a las carenas de buques y artefactos, y a las máquinas, equipos y sistemas navales" .

:comp_CG3 rdf:type guide:Competency ;
    guide:competencyCode "CG3" ;
    guide:competencyDescription "Capacidad para el aprendizaje de nuevos métodos y teorías, y en la versatilidad para adaptarse a nuevas situaciones basándose en los conocimientos adquiridos en materias básicas y tecnológicas propias de la Ingeniería Marítima" .

# Learning Results
:lr_RA32 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA32" ;
    guide:learningResultDescription "Comprender los conceptos básicos de la Termodinámica y aplicarlos a problemas de<0xC2> interés en ingeniería." .

:lr_RA33 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA33" ;
    guide:learningResultDescription "Conocer y aplicar los Principios de la Termodinámica a procesos térmicos." .

# Syllabus
:syllabus_85004612 rdf:type guide:Syllabus ;
    guide:hasItem :item_1, :item_2, :item_3, :item_4, :item_5, :item_6, :item_7, :item_8, :item_9, :item_10, :item_11, :item_12, :item_13, :item_14, :item_15, :item_16, :item_17, :item_18, :item_19 .

:item_1 rdf:type guide:SyllabusItem ; guide:itemIndex 1 ; guide:syllabusDescription "Tema 1. Características Generales." .
:item_2 rdf:type guide:SyllabusItem ; guide:itemIndex 2 ; guide:syllabusDescription "Tema 2. Análisis de Ciclos Termodinámicos." .
:item_3 rdf:<0xC2>08MA rdf:type guide:SyllabusItem ; guide:itemIndex 3 ; guide:syllabusDescription "Tema 3. Toberas y Difusores." .
:item_4 rdf:type guide:SyllabusItem ; guide:itemIndex 4 ; guide:syllabusDescription "Tema 4. Paleteado, consideraciones geométricas y aerodinámicas. Perdidas energéticas." .
:item_5 rdf:type guide:SyllabusItem ; guide:itemIndex 5 ; guide:syllabusDescription "Tema 5. La Turbina de Acción. Transformación energética. Diagrama de velocidades." .
:item_6 rdf:type guide:SyllabusItem ; guide:itemIndex 6 ; guide:syllabusDescription "Tema 6. La Turbina de Reacción. Transformación energética. Diagrama de velocidades." .
:item_7 rdf:type guide:SyllabusItem ; guide:itemIndex 7 ; guide:syllabusDescription "Tema 7. Elementos estructurales. Paleteados. Rotores. Carcasas. Tubuladuras de escape. Válvulas. Cojinetes. Sistemas de lubricación. Cierres." .
:item_8 rdf:type guide:SyllabusItem ; guide:itemIndex 8 ; guide:syllabusDescription "Tema 8. Turbinas de vapor multietápicas. Funcionamiento. Proceso de expansión. Factor de recalentamiento. Curva de condición." .
:item_9 rdf:type guide:SyllabusItem ; guide:itemIndex 9 ; guide:syllabusDescription "Tema 9. Pérdidas en Turbinas. Conceptos generales. Perdidas internas. Perdidas externas." .
:item_10 rdf:type guide:SyllabusItem ; guide:itemIndex 10 ; guide:syllabusDescription "Tema 10. Vibraciones en la Turbina. Vibraciones en el rotor. Vibraciones en el paleteado. Problemas debidos a la admisión parcial." .
:item_11 rdf:type guide:SyllabusItem ; guide:itemIndex 11 ; guide:syllabusDescription "Tema 11. Regulación y Operación de las Turbinas. Variación de la carga. Etapa de regulación." .
:item_12 rdf:type guide: …” ; guide:itemIndex 12 ; guide:syllabusDescription "Tema 12. Ciclos de la Turbina de Gas. Ciclo simple ideal. Ciclo simple regenerativo. Ciclos compuestos. Pérdidas." .
:item_13 rdf:type guide:SyllabusItem ; guide:itemIndex 13 ; guide:syllabusDescription "Tema 13. Compresor centrífugo. Descripción y partes fundamentales. Esquema de funcionamiento. Trabajo. Pérdidas. Rendimiento." .
:item_14 rdf:type guide:SyllabusItem ; guide:itemIndex 14 ; guide:syllabusDescription "Tema 14. Compresor axial. Descripción y partes fundamentales. Etapas. Rendimientos, total y de etapa y Grado de reacción." .
:item_15 rdf:type guide:SyllabusItem ; guide:itemIndex 15 ; guide:syllabusDescription "Tema 15. Cámara de combustión. Descripción y esquema de funcionamiento. Inyección del combustible." .
:item_16 rdf:type guide:SyllabusItem ; guide:itemIndex 16 ; guide:syllabusDescription "Tema 16. Elementos principales. Gobierno y Operación. La planta de ciclo combinado." .
:item_17 rdf:type guide:SyllabusItem ; guide:itemIndex 17 ; guide:syllabusDescription "Tema 17. (No detailed description in text)" .
:item_18 rdf:type guide:SyllabusItem ; guide:itemIndex 18 ; guide:syllabusDescription "Tema 18. (No detailed description in text)" .
:item_19 rdf:type guide:SyllabusItem ; guide:itemIndex 19 ; guide:syllabusDescription "Tema 19. (No detailed description in text)" .

