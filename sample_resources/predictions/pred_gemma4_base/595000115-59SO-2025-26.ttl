# --- Prerequisites ---

:req_knowledge_java rdf:type guide:RequiredKnowledge ;
    guide:previousKnowledge "Conocimientos del lenguaje de programación Java como para desarrollar una aplicación de mediana complejidad." ;
    guide:previousCourses "Programación II" .

# --- Competencies ---

:comp_TEL01 rdf:type guide:Competency ;
    guide:competencyCode "CE TEL01" ;
    guide:competencyDescription "Capacidad para aprender de manera autónoma nuevos conocimientos y técnicas adecuados para la concepción, el desarrollo o la explotación de sistemas y servicios de telecomunicación." .

:comp_TEL06 rdf:type guide:Competency ;
    guide:competencyCode "CE TEL06" ;
    guide:competencyDescription "Capacidad de concebir, desplegar, organizar y gestionar redes, sistemas, servicios e infraestructuras de telecomunicación..." .

:comp_TEL13 rdf:type guide:Competency ;
    guide:competencyCode "CE TEL13" ;
    guide:competencyDescription "Conocimiento y utilización de los conceptos de arquitectura de red, protocolos e interfaces de comunicaciones." .

:comp_TEL14 rdf:type guide:Competency ;
    guide:competencyCode "CE TEL14" ;
    guide:competencyDescription "Capacidad de diferenciar los conceptos de redes de acceso y transporte, redes de conmutación de circuitos y de paquetes..." .

:comp_TEL15 rdf:type guide:Competency ;
    guide:competencyCode "CE TEL15" ;
    guide:competencyDescription "Conocimiento de los métodos de interconexión de redes y encaminamiento, así como los fundamentos de la planificación..." .

# --- Learning Results ---

:lr_RA1295 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA1295" ;
    guide:learningResultDescription "Enumerar los medios físicos para el despliegue de redes de área local." .

:lr_RA12_96 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA1296" ;
    guide:learningResultDescription "Describir las características y el modo de funcionamiento de Ethernet." .

:lr_RA242 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA242" ;
    guide:learningResultDescription "Capacidad de aprender de manera autónoma nuevos conocimientos y técnicas para la concepción de sistemas y servicios de telecomunicación..." .

