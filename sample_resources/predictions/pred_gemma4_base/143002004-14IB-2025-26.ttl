# Evaluation System
:eval_system_143002004
    rdf:type guide:EvaluationSystem ;
    guide:evaluationDescription "La asignatura consta de cuatro partes: planificación, diseño, seguridad operacional e ingeniería eléctrica. El peso de cada parte es del 25%." ;
    guide:hasEvaluationTrial :trial_exam_ordinario, :trial_trabajo_grupo .

:trial_exam_ordinario
    rdf:type guide:EvaluationTrial ;
    guide:evaluationType "Examen" ;
    guide:evaluationDuration "04:00" ;
    guide:gradePercentage "100%" ;
    guide:minimumScore "5/10" ;
    guide:trialMode "Presencial" ;
    guide:trialType "Examen Escrito" ;
    guide:involvesCompetency :comp_ce_ia_1, :comp_ce_ia_2, :comp_cg1 .

:trial_trabajo_grupo
    rdf:type guide:EvaluationTrial ;
    guide:evaluationType "Trabajo" ;
    guide:evaluationDuration "17:00" ;
    guide:gradePercentage "10%" ;
    guide:trialMode "No presencial" ;
    guide:trialType "Trabajo en Grupo" ;
    guide:involvesCompetency :comp_cg13 .

