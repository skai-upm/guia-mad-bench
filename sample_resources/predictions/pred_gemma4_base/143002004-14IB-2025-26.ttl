# Course Guide Instance
:course_guide_143002004_2S_2025_26
    rdf:type guide:CourseGuide ;
    sch:name "Guía de Aprendizaje: Desarrollo De Infraestructuras Aeronáuticas" ;
    sch:description "Conocimiento del ámbito de las infraestructuras aeroportuarias, desde el punto de vista de su relación con las operaciones de las aeronaves, la organización del sector, la terminología, reglamentación y normativas, y planificación, diseño, construcción y operación de las mismas." ;
    guide:teachingPeriod "2025-26" ;
    guide:periodStartingMonth "Febrero" ;
    guide:periodEndingMonth "Junio" ;
    sch:inLanguage "Castellano" ;
    guide:numberOfCredits 6.0 ;
    guide:totalHours "156-162" ; # Estimated based on ECTS (6 * 26/27)
    guide:hasSyllabus :syllabus_143002004 ;
    guide:hasEvaluation :eval_system_143002004 ;
    sch:courseSchedule :schedule_143002004 ;
    sch:instructor :lecturer_angel_paris ;
    sch:instructor :lecturer_diego_garcia ;
    sch:instructor :lecturer_alvaro_rodriguez ;
    sch:instructor :lecturer_santiago_pindado ;
    sch:instructor :lecturer_daniel_corcuera ;
    guide:hasDidacticResource :res_moodle, :res_book_garcia_cruzado, :res_reglamento_eu139 ;
    guide:hasLearningResult :lr_ra49, :lr_ra51, :lr_ra50, :lr_ra109, :lr_ra46, :lr_ra65, :lr_ra44, :lr_ra107, :lr_ra126, :lr_ra52, :lr_ra43, :lr_ra108, :lr_ra45, :lr_ra66, :lr_ra58, :lr_ra47, :lr_ra48 ;
    guide:hasCompetency :comp_ce_ia_1, :comp_ce_ia_2, :comp_ce_ia_4, :comp_ce_ia_5, :comp_ce_ia_6, :comp_cg1, :comp_cg10, :comp_cg11, :comp_cg12, :comp_cg13, :comp_cg14, :comp_cg15, :comp_cg16, :comp_ct1, :comp_ct2, :comp_ct3, :comp_ct4, :comp_ct5, :comp_ct6, :comp_ct7 .

