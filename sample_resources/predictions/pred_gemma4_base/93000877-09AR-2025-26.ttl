# --- Course Guide ---

guide:Guide_93000877 rdf:type guide:CourseGuide ;
    sch:name "Guía de Aprendizaje - Redes Neuronales Y Aprendizaje Estadístico" ;
    sch:hasCourseInstance guide:Course_93000877 ;
    sch:instructor guide:Prof_PedroZufiria ;
    guide:hasSyllabus guide:Syllabus_93000877 ;
    guide:hasEvaluation guide:EvalSystem_93000877 ;
    guide:hasLearningResult guide:LR_RA54, guide:LR_RA53, guide:LR_RA55, guide:LR_RA8, guide:LR_RA28 ;
    guide:hasCompetency guide:Comp_CE1, guide:Comp_CE2, guide:Comp_CE4, guide:Comp_CE5, guide:Comp_CE6, guide:Comp_CG1, guide:Comp_CG3, guide:Comp_CG5, guide:Comp_CG6 ;
    guide:hasDidacticResource guide:Res_Alpaydin, guide:Res_Bishop, guide:Res_Cucker, guide:Res_Deisenroth, guide:Res_Fernandez, guide:Res_Goodfellow, guide:Res_Haykin, guide:Res_Herbrich, guide:Res_James, guide:Res_Kohonen, guide:Res_Martin, guide:Res_Mitchell, guide:Res_Pearl, guide:Res_Vapnik, guide:Res_Vidyasagar1, guide:Res_Vidyasagar2, guide:Res_Python, guide:Res_R, guide:Res_Video ;
    guide:numberOfCredits 3.0 ;
