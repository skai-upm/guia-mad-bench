guide:Trial_Ex_Moodle2 rdf:type guide:EvaluationTrial ;
    guide:trialType "Prueba Telemática" ;
    guide:gradePercentage "10%" ;
    guide:trialMode "No Presencial" ;
    guide:evaluationDuration "00:00" .

guide:Trial_Examen_Escrito rdf:type guide:EvaluationTrial ;
    guide:trialType "Examen Escrito" ;
    guide:gradePercentage "30%" ;
    guide:trialMode "Presencial" ;
    guide:evaluationDuration "01:30" ;
    guide:involvesCompetency guide:Comp_CE5, guide:Comp_CE1 .

guide:Trial_Trabajo_Final rdf:type guide:EvaluationTrial ;
    guide:trialType "Trabajo Individual" ;
    guide:gradePercentage "30%" ;
    guide:trialMode "No Presencial" ;
    guide:evaluationDuration "00:00" ;
    guide:minimumScore "4 / 10" ;
    guide:involvesCompetency guide:Comp_CE4, guide:Comp_CG5, guide:Comp_CG3, guide:Comp_CG1, guide:Comp_CE2 .

guide:Trial_Global rdf:type guide:EvaluationTrial ;
    guide:trialType "Trabajo Individual" ;
    guide:gradePercentage "100%" ;
    guide:trialMode "Presencial" ;
    guide:evaluationDuration "03:00" ;
