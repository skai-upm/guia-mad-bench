    guide:periodEndingMonth "Junio" ;
    guide:totalHours "Estimación basada en créditos ECTS (aprox. 75-78 horas)" ;
    sch:inLanguage "Castellano" ;
    guide:otherInformation "La asignatura hace hincapié en los fundamentos y trata de vincular diferentes perspectivas y herramientas orientadas al procesamiento estadístico de datos. El uso de herramientas de IA está prohibido." .

# --- Lecturer ---

guide:Prof_PedroZufiria rdf:type guide:Lecturer ;
    sch:name "Pedro Jose Zufiria Zatarain" ;
    sch:email "pedro.zufiria@upm.es" ;
    guide:office "A-306" ;
    guide:tutorshipsSchedule "Sin horario. Flexible, previa petición de cita." .

# --- Required Knowledge ---

guide:ReqKnow_Pre1 rdf:type guide:RequiredKnowledge ;
    guide:previousCourses "Metodos De Regresion Y Prediccion, Tecnicas De Optimizacion, Metodos De Analisis Multivariante" .

guide:ReqKnow_Pre2 rdf:type guide:RequiredKnowledge ;
    guide:previousKnowledge "Fundamentos de programación con R o Python. Fundamentos de álgebra y análisis matemático. Fundamentos de cálculo de probabilidades e inferencia estadística." .

# --- Competencies ---

guide:Comp_CE1 rdf:type guide:Competency ;
    guide:competencyCode "CE1" ;
    guide:competencyDescription "Adquisición de una formación sólida y rigurosa en temas avanzados de Estadística, Matemática computacional, Modelos estocásticos y Metodología de la toma de Decisiones aplicadas al tratamiento de la Información." .

guide:Comp_CE2 rdf:type guide:Competency ;
    guide:competencyCode "CE2" ;
    guide:competencyDescription "Capacidad para planificar la resolución de un problema en función de las herramientas de que se disponga y, en su caso, de las restricciones de tiempo y recursos" .

guide:Comp_CE4 rdf:type guide:Competency ;
    guide:competencyCode "CE4" ;
    guide:competencyDescription "Desarrollar habilidades de aprendizaje en Estadística Computacional y Matemáticas..." .

guide:Comp_CE5 rdf:type guide:Competency ;
    guide:competencyCode "CE5" ;
    guide:competencyDescription "Resolver problemas y casos reales planteados en el tratamiento estadístico-computacional de la información..." .

guide:Comp_CE6 rdf:type guide:Competency ;
    guide:competencyCode "CE6" ;
    guide:competencyDescription "Desarrollar programas que resuelvan problemas matemáticos utilizando para cada caso el entorno computacional adecuado." .

guide:Comp_CG1 rdf:type guide:Competency ;
    guide:competencyCode "CG1" ;
    guide:competencyDescription "Aprender a aplicar los conocimientos adquiridos y a explotación su potencial..." .

guide:Comp_CG3 rdf:type guide:Competency ;
    guide:competencyCode "CG3" ;
    guide:competencyDescription "Integrar los conocimientos adecuados y enfrentarse a la complejidad de emitir juicios..." .

guide:Comp_CG5 rdf:type guide:Competency ;
    guide:competencyCode "CG5" ;
    guide:competencyDescription "Comprender y utilizar el lenguaje y las herramientas matemáticas para modelizar y resolver problemas complejos..." .

guide:Comp_CG6 rdf:type guide:Competency ;
    guide:competencyCode "CG6" ;
    guide:competencyDescription "Conocer los modelos, métodos y técnicas relevantes en distintas áreas de aplicación de la Estadística matemática..." .

# --- Learning Results ---

guide:LR_RA54 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA54" ;
    guide:learningResultDescription "Capacidad para diseñar modelos neuronales que resuelvan problemas de aprendizaje estadístico." .

guide:LR_RA53 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA53" ;
    guide:learningResultDescription "Capacidad para delimitar tipos de problemas de aprendizaje estadístico." .

guide:LR_RA55 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA55" ;
    guide:learningResultDescription "Capacidad para simular los modelos neuronales en plataformas de propósito general (R, Octave)." .

guide:LR_RA8 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA8" ;
    guide:learningResultDescription "Sabrán emplear los métodos y modelos de esta disciplina en su futura actividad investigadora" .

guide:LR_RA28 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA28" ;
    guide:learningResultDescription "Los alumnos conocerán los fundamentos matemáticos necesarios para contextualizar los modelos neuronales..." .

# --- Syllabus ---

guide:Syllabus_93000877 rdf:type guide:Syllabus ;
    guide:hasItem guide:Unit_1, guide:Unit_2, guide:Unit_3, guide:Unit_4, guide:Unit_5, guide:Unit_6, guide:Unit_7 .

guide:Unit_1 rdf:type guide:SyllabusItem ;
    guide:itemIndex 1 ;
    guide:syllabusDescription "Introducción: tipos de problemas; aprendizaje automático y aprendizaje estadístico; redes neuronales artificiales." .

guide:Unit_2 rdf:type guide:SylabusItem ;
    guide:itemIndex 2 ;
    guide:syllabusDescription "Fundamentos matemáticos: dinámica de sistemas; teoría de optimización; inferencia estadística y teoría de regresión (lineal y logística)." .

guide:Unit_3 rdf:type guide:SyllabusItem ;
    guide:itemIndex 3 ;
    guide:syllabusDescription "Aprendizaje supervisado: regresión y clasificación; modelos neuronales y otros modelos para su implementación." .

guide:Unit_4 rdf:type guide:SyllabusItem ;
    guide:itemIndex 4 ;
    guide:syllabusDescription "Aprendizaje no supervisado; modelos neuronales para su implementación." .

guide:Unit_5 rdf:type guide:SyllabusItem ;
    guide:itemIndex 5 ;
    guide:syllabusDescription "Modelos alternativos/avanzados para aprendizaje supervisado y no supervisado: modelos gráficos, máquinas de Boltzmann, arquitecturas profundas, etc." .

guide:Unit_6 rdf:type guide:SyllabusItem ;
    guide:itemIndex 6 ;
    guide:syllabusDescription "Otros tipos de problemas: aprendizaje en entornos dinámicos, aprendizaje por refuerzo, aprendizaje semisupervisado, inferencia causal, etc." .

guide:Unit_7 rdf:type guide:SyllabusItem ;
    guide:item．itemIndex 7 ;
    guide:syllabusDescription "Aplicaciones prácticas: tratamiento de señal, optimización de funciones tipo caja negra, predicción en series temporales, diagnóstico de fallos, control de sistemas y análisis de redes complejas." .

# --- Evaluation System ---

guide:EvalSystem_93000877 rdf:type guide:EvaluationSystem ;
    guide:evaluationDescription "La evaluación progresiva se traduce en una calificación ponderada entre los ejercicios realizados on-line, en clase y el trabajo final. La evaluación global abarcará los contenidos de toda la asignatura." ;
    guide:hasEvaluationTrial guide:Trial_Ex_Moodle1, guide:Trial_Simulacion, guide:Trial_Ex_Moodle2, guide:Trial_Examen_Escrito, guide:Trial_Trabajo_Final, guide:Trial_Global, guide:Trial_Extraordinaria .

guide:Trial_Ex_Moodle1 rdf:type guide:EvaluationTrial ;
    guide:trialType "Prueba Telemática" ;
    guide:gradePercentage "10%" ;
    guide:trialMode "No Presencial" ;
    guide:evaluationDuration "00:00" .

guide:Trial_Simulacion rdf:type guide:EvaluationTrial ;
    guide:trialType "Trabajo Individual" ;
    guide:gradePercentage "20%" ;
    guide:trialMode "No Presencial" ;
