    guide:minimumScore "5 / 10" ;
    guide:involvesCompetency guide:Comp_CE4, guide:Comp_CG3, guide:Comp_CG1, guide:Comp_CE1, guide:Comp_CE6, guide:Comp_CE2, guide:Comp_CE5, guide:Comp_CG6 .

