    guide:bibliographyTitle "E. Alpaydin, Introduction to Machine Learning, MIT Press, 2004" ;
    guide:bibliographyType "Bibliografía" ;
    guide:bibliographyDescription "Presenta los fundamentos del aprendizaje automático." .

