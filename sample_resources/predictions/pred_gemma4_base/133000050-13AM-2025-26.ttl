# Competencies
:CB7 rdf:type guide:Competency ;
    guide:competencyCode "CB7" ;
    guide:competencyDescription "Que los estudiantes sepan aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en entornos nuevos o poco conocidos." .

:CE1 rdf:type guide:Competency ;
    guide:competencyCode "CE1" ;
    guide:competencyDescription "Conocer los fundamentos de la Limnología" .

:CG3 rdf:type guide:Competency ;
    guide:competencyCode "CG3" ;
    guide:competencyDescription "Capacidad para participar en proyectos de investigación, desarrollo e innovación vinculados con el uso sostenible de los recursos hídricos" .

:CT6 rdf:type guide:Competency ;
    guide:competencyCode "CT6" ;
    guide:competencyDescription "Liderar equipos de trabajo de diversa índole, con actitud proactiva y motivadora." .

# Learning Result
:RA57 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA57" ;
    guide:learningResultDescription "Desarrollo de un trabajo original en el ámbito del uso y gestión del agua en el medio natural." .

# Syllabus
:Syllabus_Actividades_Deportivas rdf:type guide:Syllabus ;
    guide:hasItem :Tema_1, :Tema_2, :Tema_3, :Tema_4, :Tema_5, :Tema_6, :Tema_7 .

:Tema_1 rdf:type guide:SyllabusItem ; guide:itemIndex 1 ; guide:syllabusDescription "Conceptos y fundamentos del Ocio, Tiempo Libre y la Recreación Deportiva" .
:Tema_2 rdf:type guide:SyllabusItem ; guide:itemIndex 2 ; guide:syllabusDescription "Demanda de actividades físicas y deportivas en el tiempo libre y de ocio" .
:Tema_3 rdf:type guide:SyllabusItem ; guide:itemIndex 3 ; guide:syllabusDescription "Dimensiones y manifestaciones actuales del ocio" .
:Tema_4 rdf:type guide:SyllabusItem ; guide:itemIndex 4 ; guide:syllabusDescription "Actividades deportivas y recreativas fluviales. Clasificación." .
:Tema_5 rdf:type guide:SyllabusItem ; guide:itemIndex 5 ; guide:syllabusDescription "Diseño de programas de actividades acuáticas en la naturaleza" .
:Tema_6 rdf:type guide:SyllabusItem ; guide:itemIndex 6 ; guide:syllabusDescription "Experiencia práctica de piragüismo. Maniobras básicas de paleo para el descenso de aguas bravas" .
:Tema_7 rdf:type guide:SyllabusItem ; guide:itemIndex 7 ; guide:syllabusDescription "Gestión del riesgo en actividades fluviales y barrancos" .

