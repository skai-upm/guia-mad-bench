    guide:hasActivity :Act_Lecture_Unit4, :Act_Lab_Granulometria .

:Act_Lecture_Unit4 rdf:type guide:Activity ;
    guide:activityDescription "Tema 4: Compresbilidad e hinchamiento de suelos" ;
    guide:activityDuration 1.0 ;
    guide:activityFormat "Lección Magistral" ;
    guide:attendanceType "Presencial" .

:Act_Lab_Granulometria rdf:type guide:Activity ;
    guide:activityDescription "Granulometría" ;
    guide:activityDuration 1.0 ;
    guide:activityFormat "Prácticas de Laboratorio" ;
    guide:attendanceType "Presencial" .

