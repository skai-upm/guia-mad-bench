# --- Competencies and Learning Results ---

:CE59 rdf:type guide:Competency ;
    guide:competencyCode "CE59" ;
    guide:competencyDescription "Conocimiento adecuado y aplicado a la Ingeniería de: Los métodos de cálculo y de desarrollo de las diferentes soluciones de edificación y pavimentación de aeropuertos..." .

:CE60 rdf:type guide:Competency ;
    guide:competencyCode "CE60" ;
    guide:competencyDescription "Conocimiento aplicado de: edificación; electricidad; electrotecnia; electrónica; mecánica del。。。" .

:CG3 rdf:type guide:Competency ;
    guide:competencyCode "CG3" ;
    guide:competencyDescription "Capacidad para identificar y resolver problemas aplicando, con creatividad, los conocimientos adquiridos" .

:CG5 rdf:type guide:Competency ;
    guide:competencyCode "CG5" ;
    guide:competencyDescription "Liderazgo de equipos y organizaciones" .

:CG9 rdf:type guide:Competency ;
    guide:competencyCode "CG9" ;
    guide:competencyDescription "Razonamiento crítico y capacidad de asociación que posibiliten el aprendizaje continuo" .

:RA72 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA72" ;
    guide:learningResultDescription "Conocimiento, comprensión, aplicación y análisis de las diferentes tipologías de cimentación calculando las cargas de hundimiento en cimentaciones." .

:RA300 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA300" ;
    guide:learningResultDescription "Capacidad de análisis y síntesis para saber redactar e interpretar informes técnicos referentes a ensayos geotécnicos" .

:RA70 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA70" ;
    guide:learningResultDescription "Conocimiento, comprensión, análisis y valoración de los distintos tipos de suelo..." .

:RA71 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA71" ;
    guide:learningResultDescription "Conocimiento y aplicación de los ensayos tipo a realizar en los suelos para identificarlos y determinar su comportamiento." .

# --- Syllabus ---

:Syllabus_Geotecnia rdf:type guide:Syllabus ;
    guide:hasItem :Unit_1, :Unit_2, :Unit_3, :Unit_4, :Unit_5, :Unit_6, :Unit_7, :Unit_8 .

:Unit_1 rdf:type guide:SyllabusItem ;
    guide:itemIndex 1 ;
    guide:syllabusDescription "ORIGEN DE LOS SUELOS Y SUS PROPIEDADES FÍSICAS." .

:Unit_2 rdf:type guide:SyllabusItem ;
    guide:itemIndex 2 ;
    guide:syllabusDescription "IDENTIFICACIÓN Y CLASIFICACIÓN DE SUELOS." .

:Unit_3 rdf:type guide:SyllabusItem ;
    guide:itemIndex 3 ;
    guide:syllabusDescription "EL AGUA EN EL TERRENO." .

:Unit_4 rdf:type guide:SyllabusItem ;
    guide:item	index 4 ;
    guide:syllabusDescription "COMPRESIBILIDAD E HINCHAMIENTO DE SUELOS." .

:Unit_5 rdf:type guide:SyllabusItem ;
    guide:itemIndex 5 ;
    guide:syllabusDescription "RESISTENCIA Y ELASTICIDAD" .

:Unit_6 rdf:type guide:SyllabusItem ;
    guide:itemIndex 6 ;
    guide:syllabusDescription "RECONOCIMIENTOS GEOTÉCNICOS DE CAMPO." .

:Unit_7 rdf:type guide:SyllabusItem ;
    guide:itemIndex 7 ;
    guide:syllabusDescription "ESTABILIDAD DE TALUDES" .

:Unit_8 rdf:type guide:SyllabusItem ;
    guide:itemIndex 8 ;
    guide:syllabusDescription "CIMENTACIONES." .

# --- Evaluation System ---

:EvalSystem_Geotecnia rdf:type guide:EvaluationSystem ;
    guide:evaluationDescription "La evaluación continua se realizará mediante dos pruebas de evaluación intermedia. La última de las cuales coincidirá con la convocatoria oficial ordinaria..." ;
    guide:hasEvaluationTrial :Trial_Intermediate, :Trial_Final, :Trial_Extraordinary .

:Trial_Intermediate rdf:type guide:EvaluationTrial ;
    guide:trialType "Prueba de Evaluación Intermedia" ;
    guide:evaluationType "Progresiva" ;
    guide:gradePercentage "40%" ;
    guide:minimumScore "5 / 10" ;
    guide:trialWeek "8" ;
    guide:trialMode "Presencial" .

:Trial_Final rdf:type guide:EvaluationTrial ;
    guide:trialType "Examen ordinario" ;
    guide:evaluationType "Global" ;
    guide:gradePercentage "80%" ;
    guide:minimumScore "5 / 10" ;
    guide:trialWeek "17" ;
    guide:trialMode "Presencial" .

