@prefix : <http://guia-mad-bench.es/data/> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix om: <http://www.ontology-of-units-of-measure.org/resource/om-2/> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix sch: <https://schema.org/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix guide: <http://w3id.org/def/guia#> .

_:courseGuide a guide:CourseGuide ;
    sch:name "Organización de los Centros Docentes de Enseñanza Secundaria y de Formación Profesional" ;
    guide:teachingPeriod "2025-26" ;
    guide:numberOfCredits 3.0 ;
    guide:periodStartingMonth "Septiembre" ;
    guide:periodEndingMonth "Enero" ;
    sch:inLanguage "Castellano" ;
    guide:totalHours "78" ; # Calculated based on ECTS (approx 26h per credit)
    guide:hasSyllabus _:syllabus ;
    guide:hasCompetency _:compCE05, _:compCE06, _:compCG09, _:compCT04, _:compCT05;
    guide:hasLearningResult _:lrRA63, _:lrRA64, _:lrRA31, _:lrRA48;
    sch:instructor _:profRodrigo, _:profOlga ;
    sch:courseSchedule _:schedule ;
    guide:hasEvaluation _:evalSystem ;
    guide:hasDidacticResource _:resMoodle, _:resAula, _:resWeb, _:resBiblio1;
    sch:description "La asignatura tiene como objetivo dotar al alumnado de las competencias necesarias para comprender y analizar los distintos elementos que configuruan la organización y gestión de los centros educativos." .

_:course a guide:Course ;
    sch:name "303000073 - Organizacion De Los Centros Docentes De Enseñanza Secundaria Y De Formacion Profesional" ;
    guide:courseType "Obligatoria" ;
    guide:courseYear 2025 ;
    guide:semester "Primer semestre" ;
    sch:hasCourseInstance _:courseGuide ;
    sch:courseCode 303000073 .

_:degree a guide:MasterDegree ;
    sch:name "30AG - M U En Formacion Del Profesorado En Eso Bachillerato Y Fp (esp Educ Física)" ;
    guide:hasCourse _:course .

_:center a guide:UniversityCenter ;
    sch:name "Facultad CC. Actividad Fisica y Deporte" ;
    guide:offers _:degree .

_:profRodrigo a guide:Lecturer ;
    sch:name "Rodrigo Pardo Garcia" ;
    sch:email "rodrigo.pardo@upm.es" ;
    guide:office "503" ;
    guide:tutorshipsSchedule "Consultar la web del Departamento" .

_:profOlga a guide:Lecturer ;
    sch:name "Olga Segovia Pulido" ;
    sch:email "olga.segovia@upm.es" ;
    guide:tutorshipsSchedule "Consultar la web del Departamento" .

_:compCE05 a guide:Competency ;
    guide:competencyCode "CE05" ;
    guide:competencyDescription "Conocer los procesos de interacción en el aula y en el centro, abordar y resolver posibles problemas." .

_:compCE06 a guide:Competency ;
    guide:competencyCode "CE06" ;
    guide:competencyDescription "Conocer la evolución histórica del sistema educativo." .

_:compCG09 a guide:Competency ;
    guide:competencyCode "CG09" ;
    guide:competencyDescription "Conocer la normativa y organización institucional del sistema educativo y modelos de mejora de la calidad con aplicación a los centros de enseñanza." .

_:compCT04 a guide:Competency ;
    guide:competencyCode "CT04" ;
    guide:competencyDescription "Conocer y aplicar técnicas de organización y planificación." .

_:compCT05 a guide:Competency ;
    guide:competencyCode "CT05" ;
    guide:competencyDescription "Generar aptitudes relacionadas con la gestión de la información." .

_:lrRA63 a guide:LearningResult ;
    guide:learningResultCode "RA63" ;
    guide:learningResultDescription "Saber identificar, elaborar y evaluar los diferentes documentos de trabajo relativos a la organización docente en los centros educativos" .

_:lrRA64 a guide:LearningResult ;
    guide:learningResultCode "RA64" ;
    guide:learningResultDescription "Conocer la organización y funcionamiento de los Centros Escolares, tanto en relación a los Recursos Humanos como a los elementos normativos" .

_:lrRA31 a guide:LearningResult ;
    guide:learningResultCode "RA31" ;
    guide:learningResultDescription "Para la Formación Profesional, conocer el curriculum formativo y la organización académica de los Módulos Profesionales de la Familia Deporte." .

_:lrRA48 a guide:LearningResult ;
    guide:learningResultCode "RA48" ;
    guide:learningResultDescription "Conocer las exigencias reales de planificación, docencia y evaluación que requiere la estancia en un Centro de enseñanza como docente de su especialidad..." .

_:syllabus a guide:Syllabus ;
    guide:hasItem _:unit1, _:unit2, _:unit3, _:unit4, _:unit5 .

_:unit1 a guide:SyllabusItem ;
    guide:itemIndex 1 ;
    guide:syllabusDescription "MARCO LEGAL Y EVOLUCION DEL SISTEMA EDUCATIVO" .

_:unit2 a guide:SyllabusItem ;
    guide:itemIndex 2 ;
    guide:syllabusDescription "ORGANIZACION Y GESTION DE LOS CENTROS ESCOLARES" .

_:unit3 a guide:SyllabusItem ;
    guide:itemIndex 3 ;
    guide:syllabusDescription "DOCUMENTOS INSTITUCIONALES" .

_:unit4 a guide:SyllabusItem ;
    guide:itemIndex 4 ;
    guide:syllabusDescription "CONTEXTO ESPECIFICO DE EDUCACION FISICA" .

_:unit5 a guide:SyllabusItem ;
    guide:itemIndex 5 ;
    guide:syllabusDescription "LA FORMACION PROFESIONAL EN EL AMBITO DE LA ACTIVIDAD FISICA Y EL DEPORTE" .

_:evalSystem a guide:EvaluationSystem ;
    guide:evaluationDescription "La evaluación es continua formativa. Se tiene en cuenta el proceso de aprendizaje, la participación y las prácticas obligatorias." ;
    guide:hasEvaluationTrial _:trialProgressive, _:trialGlobal, _:trialExtraordinary .

_:trialProgressive a guide:EvaluationTrial ;
    guide:trialType "Evaluación Progresiva" ;
    guide:trialDescription "Evaluación continua basada en tareas, cuestionarios y autoevaluación." ;
    guide:hasScheduleEvent _:event1, _:event2, _:event3 .

_:trialGlobal a guide:EvaluationTrial ;
    guide:trialType "Prueba de evaluación global" ;
    guide:trialDescription "Examen final para alumnos que no superan la evaluación progresiva." ;
    guide:minimumScore "5/10" ;
    guide:hasScheduleEvent _:eventFinal .

_:trialExtraordinary a guide:EvaluationTrial ;
    guide:trialType "Convocatoria extraordinaria" ;
    guide:trialDescription "Examen teórico en fecha oficial de convocatoria extraordinaria." ;
    guide:minimumScore "5/10" ;
    guide:hasScheduleEvent _:eventExtra .

_:event1 a guide:ScheduleEvent ;
    guide:eventWeek "Semana 1" ;
    guide:eventIndex 1 ;
    guide:hasActivity _:actIntro .

_:actIntro a guide:Activity ;
    guide:activityDescription "Introducción asignatura" ;
    guide:activityFormat "Lección Magistral" ;
    guide:attendanceType "Presencial" .

_:eventFinal a guide:ScheduleEvent ;
    guide:eventWeek "Semana 16" ;
    guide:eventIndex 16 ;
    guide:hasActivity _:actExam .

_:actExam a guide:Activity ;
    guide:activityDescription "Prueba escrita de los contenidos de la asignatura" ;
    guide:activityFormat "Examen Escrito" ;
    guide:attendanceType "Presencial" ;
    guide:activityDuration 2.0 .

_:schedule a guide:Schedule ;
    sch:eventSchedule _:event1, _:eventFinal .

_:resMoodle a guide:DidacticResource ;
    sch:name "Plataforma Moodle" ;
    guide:bibliographyType "Recursos web" ;
    guide:bibliographyDescription "El seguimiento y presentación de trabajos a través de la plataforma Moodle será obligado." .

_:resAula a guide:DidacticResource ;
    sch:name "Aula" ;
    guide:bibliographyType "Equipamiento" ;
    guide:bibliographyDescription "Aula física adecuadamente dotada, con mesas que permitan agrupamientos flexibles y medios audiovisuales." .

_:resWeb a guide:DidacticResource ;
    sch:name "Páginas WEB" ;
    guide:bibliographyType "Recursos web" ;
    guide:bibliographyDescription "Páginas WEB del Ministerio de Educación y la Consejería de Educación de la Comunidad de Madrid." .

_:resBiblio1 a guide:DidacticResource ;
    sch:name "La organización escolar. Práctica y fundamentos" ;
    guide:bibliographyType "Bibliografía" ;
    guide:bibliographyDescription "Álvarez Rojo, V. y Lázaro Martínez, A (2002). Barcelona: Grao." .