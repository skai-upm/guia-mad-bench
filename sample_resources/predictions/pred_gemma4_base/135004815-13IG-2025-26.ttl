:course_guide_135004815 a guide:CourseGuide ;
    sch:name "Sostenibilidad 4.0: Integración de Taxonomía, Esg" ;
    sch:description "Esta asignatura proporciona al estudiante las competencias clave para comprender e implementar los principios de sostenibilidad exigidos por el entorno normativo y empresarial actual."@en ;
    guide:teachingPeriod "2025-26" ;
    guide:numberOfCredits 3.0 ;
    guide:periodStartingMonth "Febrero" ;
    guide:periodEndingMonth "Junio" ;
    sch:inLanguage "Castellano" ;
    guide:hasSyllabus :syllabus_135004815 ;
    guide:hasEvaluation :eval_system_135004815 ;
    guide:hasCompetency :comp_CB03, :comp_CB04, :comp_CB05, :comp_CG13, :comp_CT1 ;
    guide:hasLearningResult :lr_RA577, :lr_RA575, :lr_RA578, :lr_RA576, :lr_RA579 ;
    sch:instructor :prof_m_carmen_aviles ;
    sch:courseSchedule :schedule_135004815 ;
    guide:hasDidacticResource :res_ecovadis, :res_datamaran, :res_climact, :res_gri_tool, :res_sasb_finder, :res_eccles_krusz, :res_elkington ;
    sch:activitiesWorkload "26-25 horas de trabajo presencial y no presencial por cada crédito ECTS" ;
    guide:otherInformation "Cualquier elemento de esta guía podrá sufrir modificaciones."@en .

