:comp_CB03 a guide:Competency ;
    guide:competencyCode "CB03" ;
    guide:competencyDescription "Que los estudiantes tengan la capacidad de reunir e interpretar datos relevantes para emitir jueles..."@en .
:comp_CB04 a guide:Competency ;
    guide:competencyCode "CB04" ;
    guide:competencyDescription "Que los estudiantes puedan transmitir información, ideas, problemas y soluciones..."@en .
:comp_CB05 a guide:Competency ;
    guide:competencyCode "CB05" ;
    guide:competencyDescription "Que los estudiantes hayan desarrollado aquellas habilidades de aprendizaje necesarias..."@en .
:comp_CG13 a guide:Competency ;
    guide:competencyCode "CG13" ;
    guide:competencyDescription "Capacidad para diseñar, dirigir, elaborar, implementar e interpretar proyectos y planes..."@en .
:comp_CT1 a guide:Competency ;
    guide:competencyCode "CT1" ;
    guide:competencyDescription "Comunicación oral y escrita. Concluir aportaciones por escrito..."@en .

:lr_RA577 a guide:LearningResult ;
    guide:learningResultCode "RA577" ;
    guide:learningResultDescription "Diseñar un informe ESG adaptado al sector forestal o ambiental."@en .
:lr_RA575 a guide:LearningResult ;
    guide:learningResultCode "RA575" ;
    guide:learningResultDescription "Comprender el marco legal y normativo actual en sostenibilidad (Taxonomía, SFDR, GRI, ESRS)."@en .
:lr_RA578 a guide:LearningResult ;
    guide:learningResultCode "RA578" ;
    guide:learningResultDescription "Manejar plataformas y metodologías digitales orientadas a la sostenibilidad 4.0."@en .
:lr_RA576 a guide:LearningResult ;
    guide:learningResultCode "RA576" ;
    guide:learningResultDescription "Identificar y aplicar los indicadores clave de sostenibilidad en proyectos reales."@en .
:lr_RA579 a guide:LearningResult ;
    guide:learningResultCode "RA579" ;
    guide:learningResultDescription "Analizar y evaluar la doble materialidad en el contexto de cambio climático."@en .

