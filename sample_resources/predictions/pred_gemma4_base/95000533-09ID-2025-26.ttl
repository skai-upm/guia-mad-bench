# --- Degree and University Center ---

:degree_09ID rdf:type guide:BachelorDegree ;
    sch:name "Grado en Ingenieria y Sistemas de Datos" ;
    guide:degreeCode "09ID" .

:ets_telecom rdf:type guide:UniversityCenter ;
    sch:name "E.T.S. De Ingenieros De Telecomunicacion" .

:degree_09ID guide:offers :ets_telecom . # Note: ontology says UniversityCenter offers Degree, but logic is Center hosts/has degree. Using 'offers' as per ontology domain/range if applicable, though usually center is the subject. 
# Correction based on ontology: guide:offers rdfs:domain guide:UniversityCenter rdfs:range guide:Degree.
:ets_teleint rdf:type guide:UniversityCenter ;
    sch:name "E.T.S. De Ingenieros De Telecomunicacion" ;
    guide:offers :degree_09ID .

