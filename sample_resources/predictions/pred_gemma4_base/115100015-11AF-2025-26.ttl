# --- Degree and University Center ---

:degree_11AF rdf:type guide:BachelorDegree ;
    sch:name "Grado en Ciencias de la Actividad Física y del Deporte" ;
    guide:degreeCode "11AF" .

:center_facultad_afyd rdf:type guide:UniversityCenter ;
    sch:name "Facultad Cc. Actividad Fisica Y Deporte" ;
    guide:offers :degree_11AF .

# --- Course ---

:course_biomecanica rdf:type guide:Course ;
    sch:name "Biomecánica de la Afyd" ;
    sch:courseCode 115100015 ;
    guide:courseType "Básica" ;
    guide:courseYear 2025 ;
    guide:semester "Cuarto semestre" .

# --- Course Guide ---

:guide_biomecanica rdf:type guide:CourseGuide ;
    sch:hasCourseInstance :course_biomecanica ;
    sch:instructor :lecturer_enrique, :lecturer_archit, :lecturer_javier ;
    sch:director :lecturer_enrique ;
    guide:hasSyllabus :syllabus_biomecanica ;
    guide:hasEvaluation :eval_system_biomecanica ;
    guide:hasCompetency :comp_ce08, :comp_ce09 ;
    guide:hasLearningResult :lr_ra9, :lr_ra84, :lr_ra14, :lr_ra189 ;
    guide:hasDidacticResource :res_moodle, :res_lab_biomecanica, :res_book_barlett_1, :res_book_beer_1 ;
    sch:inLanguage "Castellano" ;
    guide:teachingPeriod "2025-26" ;
    guide:periodStartingMonth "Febrero" ;
    guide:periodEndingMonth "Junio" ;
    guide:numberOfCredits 6.0 ;
    guide:totalHours "150" ; # Estimated based on ECTS (6 * 25)
    sch:description "Aplica las leyes de la mecánica a los movimientos del cuerpo humano teniendo en cuenta sus características anatómicas y biológicas." .

# --- Lecturers ---

:lecturer_enrique rdf:type guide:Lecturer ;
    sch:name "Enrique Navarro Cabello" ;
    sch:email "enrique.navarro@upm.es" ;
    guide:office "204" ;
    guide:tutorshipsSchedule "L - 12:00 - 14:00, M - 12:00 - 14:00, X - 12:00 - 14:00" .

:lecturer_archit rdf:type guide:Lecturer ;
    sch:name "Archit Navandar" ;
    sch:email "archit.navandar@upm.es" ;
    guide:tutorshipsSchedule "L - 08:00 - 12:00, M - 08:00 - 10:00" .

:lecturer_javier rdf:type guide:Lecturer ;
    sch:name "Javier Rueda Ojeda" ;
    sch:email "javier.ruedao@upm.es" ;
    guide:tutorshipsSchedule "L - 08:00 - 12:00" .

# --- Competencies ---

:comp_ce08 rdf:type guide:Competency ;
    guide:competencyCode "CE08" ;
    guide:competencyDescription "Aplicar de manera fundament．fundamentada y argumentada los principios fisiológicos, biomecánicos, comportamentales y sociales, durante la dirección del entrenamiento deportivo. Nivel 3." .

:comp_ce09 rdf:type guide:Competency ;
    guide:competencyCode "CE09" ;
    guide:competencyDescription "Identificar y prevenir los riesgos que se derivan para la salud de los deportistas por la práctica de actividades físicas inadecuadas, en el contexto del entrenamiento deportivo. Nivel 2." .

# --- Learning Results ---

:lr_ra9 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA9" ;
    guide:learningResultDescription "Capacidad de trabajar en equipo" .

:lr_ra84 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA84" ;
    guide:learningResultDescription "Seleccionar y utilizar el material y el equipamiento deportivo adecuado en cada caso" .

:lr_ra14 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA14" ;
    guide:learningResultDescription "Saber aplicar los principios del entrenamiento y así como los fundamentos fisiológicos y biomecánicos a los programas de entrenamiento" .

:lr_ra189 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA189" ;
    guide:learningResultDescription "Saber realizar el análisis mecánico de cualquier ejercicio físico, entendiendo las características articulares y musculares de cualquier movimiento humano." .

# --- Syllabus ---

:syllabus_biomecanica rdf:type guide:Syllabus ;
    guide:hasItem :item_unit1, :item_unit2, :item_unit3, :item_unit4, :item_unit5, :item_unit6, :item_unit7, :item_unit8 .

:item_unit1 rdf:type guide:SyllabusItem ;
    guide:itemIndex 1 ;
    guide:syllabusDescription "Introducción al estudio de la biomecánica" .

:item_unit2 rdf:type guide:SyllabusItem ;
    guide:itemIndex 2 ;
    guide:syllabusDescription "Análisis cinemático Lineal" .

:item_unit3 rdf:type guide:SyllabusItem ;
    guide:itemIndex 3 ;
    guide:syllabusDescription "Análisis Cinematico Angular" .

:item_unit4 rdf:type guide:SyllabusItem ;
    guide:itemIndex 4 ;
    guide:syllabusDescription "Dinámica del Centro de Masas" .

:item_unit5 rdf:type guide:SyllabusItem ;
    guide:itemIndex 5 ;
    guide:syllabusDescription "Dinámica del cuerpo humano" .

:item_unit6 rdf:type guide:SyllabusItem ;
    guide:itemIndex 6 ;
    guide:syllabusDescription "Equilibrio mecánico del cuerpo humano" .

:item_unit7 rdf:type guide:SyllabusItem ;
    guide:itemIndex 7 ;
    guide:syllabusDescription "Energía Mecánica" .

:item_unit8 rdf:type guide:SyllabusItem ;
    guide:itemIndex 8 ;
    guide:syllabusDescription "Métodos de análisis biomecánico" .

# --- Evaluation System ---

:eval_system_biomecanica rdf:type guide:EvaluationSystem ;
    guide:evaluationDescription "Evaluación progresiva y evaluación global." ;
