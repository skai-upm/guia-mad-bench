    guide:gradePercentage "45%" ;
    guide:minimumScore "5 / 10" ;
    guide:trialWeek "Semana 15" ;
    guide:hasScheduleEvent :event_exam_p2 .

:trial_final rdf:type guide:EvaluationTrial ;
    guide:trialType "Prueba Telemática" ;
    guide:trialMode "Pres．encial" ;
    guide:evaluationType "Global" ;
    guide:gradePercentage "100%" ;
    guide:minimumScore "5 / 10" ;
    guide:trialWeek "Semana 17" ;
    guide:hasScheduleEvent :event_exam_final .

