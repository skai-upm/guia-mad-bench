# Course Guide Instance
:course_guide_615000300_2025_26 rdf:type guide:CourseGuide ;
    sch:name "Bases De Datos" ;
    sch:description "En esta asignatura el alumno aprenderá los conceptos fundamentales, tanto teóricos como práctico, necesarios para conocer el funcionamiento de las bases de datos."@en ;
    guide:teachingPeriod "2025-26" ;
    guide:numberOfCredits 9.0 ;
    guide:periodStartingMonth "Septiembre" ;
    guide:periodEndingMonth "Enero" ;
    sch:inLanguage "Castellano" ;
    guide:hasSyllabus :syllabus_databases ;
    guide:hasCompetency :comp_CB01, :comp_CC12, :comp_CC13, :comp_CC7, :comp_CT1, :comp_CT2 ;
    guide:hasLearningResult :lr_RA1, :lr_RA2, :lr_RA7, :lr_RA6, :lr_RA3, :lr_RA4, :lr_RA5 ;
    guide:hasEvaluation :eval_system_databases ;
    sch:instructor :lecturer_fernando_ortega, :lecturer_maria_angeles, :lecturer_santiago, :lecturer_edgar, :lecturer_gema, :lecturer_raul ;
    guide:hasDidacticResource :res_moodle, :res_ordenador, :res_book_elmasri, :res_book_silberschatz, :res_book_date .

