# Syllabus and Items
:syllabus_databases rdf:type guide:Syllabus ;
    guide:hasItem :item_topic_1, :item_topic_2, :item_topic_3, :item_topic_4, :item_topic_5, :item_topic_6, :item_topic_7 .

:item_topic_1 rdf:type guide:SyllabusItem ;
    guide:itemIndex 1 ;
    guide:syllabusDescription "Introducción (Introducción a las bases de datos, Tipos de bases de datos, Arquitectura cliente-servidor)"@en .

:item_topic_2 rdf:type guide:SyllabusItem ;
    guide:itemIndex 2 ;
    guide:syllabusDescription "Modelado de datos (Modelo entidad-relación)"@en .

:item_topic_3 rdf:type guide:SyllabusItem ;
    guide:itemIndex 3 ;
    guide:syllabusDescription "Modelo relacional (Introducción, Transformación, Normalización, Álgebra relacional)"@en .

:item_topic_4 rdf:type guide:SyllabusItem ;
    guide:itemIndex 4 ;
    guide:syllabusDescription "El lenguaje SQL (DML, DDL, DCL, TCL)"@en .

:item_topic_5 rdf:<0xC2>type guide:SyllabusItem ;
    guide:itemIndex 5 ;
    guide:syllabusDescription "Seguridad en bases de datos"@en .

:item_topic_6 rdf:type guide:SyllabusItem ;
    guide:itemIndex 6 ;
    guide:syllabusDescription "Programación contra bases de datos (Drivers, ORM)"@en .

:item_topic_7 rdf:type guide:SyllabusItem ;
    guide:itemIndex 7 ;
    guide:syllabusDescription "Almacenamiento de información basada en ficheros (CSV, JSON, XML)"@en .

# Competencies
:comp_CB01 rdf:type guide:Competency ;
    guide:competencyCode "CB01" ;
    guide:competencyDescription "Que los estudiantes hayan demostrado poseer y comprender conocimientos en un área de...”@en .

:comp_CC12 rdf:type guide:Competency ;
    guide:competencyCode "CC12" ;
    guide:competencyDescription "Conocimiento y aplicación de las características, funcionalidades y estructura de las bases de datos..."@en .

:comp_CC13 rdf:type guide:Competency ;
    guide:competencyCode "CC13" ;
    guide:competencyDescription "Conocimiento y aplicación de las herramientas necesarias para el almacenamiento, procesamiento y acceso a los Sistemas de información..."@en .

:comp_CC7 rdf:type guide:Competency ;
    guide:competencyCode "CC7" ;
    guide:competencyDescription "Conocimiento, diseño y utilización de forma eficiente los tipos y estructuras de datos más adecuados..."@en .

:comp_CT1 rdf:type guide:Competency ;
    guide:competencyCode "CT1" ;
    guide:competencyDescription "Análisis y síntesis: Descomponer la información en unidades más pequeñas..."@en .

:comp_CT2 rdf:type guide:Competency ;
    guide:competencyCode "CT2" ;
    guide:competencyDescription "Resolución de problemas: Identificar, analizar y definir los elementos significativos..."@en .

# Learning Results
:lr_RA1 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA1" ;
    guide:learningResultDescription "Conoce y utiliza correctamente las estructuras y tipos de ficheros de datos que conforman un sistema de información."@en .

:lr_RA2 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA2" ;
    guide:learningResultDescription "Conoce la estructura y utilización de ficheros índices para manejar ficheros de datos"@en .

:lr_RA7 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA7" ;
    guide:learningResultDescription "Lee un texto un artículo científico de cierta complejidad..."@en .

:lr_RA6 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA6" ;
    guide:learningResultDescription "Identifica las estructuras y problemas derivados de la integridad referencial en bases de datos"@en .

:lr_RA3 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA3" ;
    guide:learningResultDescription "Conoce las bases teóricas del modelado conceptual de datos..."@en .

:lr_RA4 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA4" ;
    guide:learningResultDescription "Conoce los fundamentos de los lenguajes de acceso a bases de datos relaciones..."@en .

:lr_RA5 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA5" ;
    guide:learningResultDescription "Conoce los fundamentos teóricos del proceso concurrente de transacciones..."@en .

# Evaluation System and Trials
:eval_system_databases rdf:type guide:EvaluationSystem ;
    guide:evaluationDescription "La evaluación de la asignatura se llevará a cabo mediante dos sistemas: evaluación progresiva y evaluación global."@en ;
    guide:hasEvaluationTrial :trial_oral_practice, :trial_final_exam, :trial_written_practice .

:trial_oral_practice rdf:type guide:EvaluationTrial ;
    guide:trialType "Examen de Prácticas" ;
    guide:trialMode "Presencial" ;
    guide:evaluationDuration "06:00" ;
    guide:gradePercentage "40%" ;
    guide:minimumScore "/ 10" ;
    guide:involvesCompetency :comp_CT1, :comp_CC12, :comp_CC13, :comp_CC7 .

:trial_final_exam rdf:type guide:EvaluationTrial ;
    guide:trialType "Examen Escrito" ;
    guide:trialMode "Presencial" ;
    guide:evaluationDuration "02:15" ;
    guide:gradePercentage "50%" ;
    guide:minimumScore "4 / 10" ;
    guide:involvesCompetency :comp_CT1, :comp_CC12, :comp_CC13, :comp_CC7, :comp_CT2, :comp_CB01 .

:trial_written_practice rdf:type guide:EvaluationTrial ;
    guide:trialType "Examen de Prácticas" ;
    guide:trialMode "Presencial" ;
    guide:evaluationDuration "00:15" ;
    guide:gradePercentage "10%" ;
    guide:minimumScore "3 / 10" ;
    guide:involvesCompetency :comp_CC7, :comp_CC13, :comp_CT1, :comp_CC12 .

