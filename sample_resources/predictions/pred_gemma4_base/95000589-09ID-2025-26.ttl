:item_2 rdf:type guide:SylabusItem ;
    guide:itemIndex 2 ;
    guide:syllabusDescription "Gestión de bases de datos relacionales" .

:item_3 rdf:type guide:SyllabusItem ;
    guide:itemIndex 3 ;
    guide:syllabusDescription "Introducción al entorno de desarrollo Web" .

:item_4 rdf:type guide:SyllabusItem ;
    guide:itemIndex 4 ;
    guide:syllabusDescription "Aplicación Web de gestión de usuarios" .

:item_5 rdf:type guide:SyllabusItem ;
    guide:itemIndex 5 ;
    guide:syllabusDescription "Aplicación Web para profesionales" .

:item_6 rdf:type guide:SyllabusItem ;
    guide:itemIndex 6 ;
    guide:syllabusDescription "Aplicación Web para pacientes" .

