### Competencies ###

:comp_CB05 rdf:type guide:Competency ;
    guide:competencyCode "CB05" ;
    guide:competencyDescription "Habilidades de aprendizaje necesarias para emprender estudios posteriores con un alto grado de autonomía." .

:comp_CE10 rdf:type guide:Competency ;
    guide:competencyCode "CE10" ;
    guide:competencyDescription "Capacidad de construir sistemas, aplicaciones y servicios telemáticos, interconectados y multiplataforma a partir de su comprensión de la arquitectura web." .

:comp_CE17 rdf:type guide:Competency ;
    guide:competencyCode "CE17" ;
    guide:competencyDescription "Capacidad de utilizar los fundamentos de la programación, sistemas operativos, bases de datos, tecnología web y las redes y servicios de telecomunicación en proyectos de ingeniería de datos y sistemas." .

:comp_CG03 rdf:type guide:Competency ;
    guide:competencyCode "CG03" ;
    guide:competencyDescription "Ser capaz de explicar de forma oral o escrita las soluciones planteadas para la resolución de un problema." .

:comp_CG04 rdf:type guide:Competency ;
    guide:competencyCode "CG04" ;
    guide:competencyDescription "Saber identificar y utilizar las herramientas de las Tecnologías de la Información y de las Comunicaciones más adecuadas para plantear y construir soluciones a problemas." .

### Learning Results ###

:lr_RA196 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA196-RA76" ;
    guide:learningResultDescription "Conocimientos teóricos y habilidades prácticas en tecnologías necesarias para el desarrollo e integración de servicios de telemedicina." .

:lr_RA063 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA063" ;
    guide:learningResultDescription "Saber diseñar páginas web estáticas y dinámicas usando HTML, CSS y JavaScript." .

:lr_RA062 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA062" ;
    guide:learningResultDescription "Comprender la web y el protocolo HTTP." .

:lr_RA061 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA061" ;
    guide:learningResultDescription "Diseñar e implementar una solución completa a un caso de uso." .

:lr_RA157 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA157" ;
    guide:learningResultDescription "Conocer y aprender el desarrollo de aplicaciones web para terminales móviles y de escritorio usando tecnologías web." .

### Syllabus ###

:syllabus_95000589 rdf:type guide:Syllabus ;
    guide:hasItem :item_1, :item_2, :item_3, :item_4, :item_5, :item_6 .

