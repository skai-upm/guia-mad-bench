# --- Course Guide ---

guide:Guide_203000157_2025_26 a guide:CourseGuide ;
    sch:name "Guía de Aprendizaje - Nuevas Tecnologías De Envasado De Alimentos" ;
    sch:description "En la asignatura se presentan y desarrollan las nuevas tecnologías de envasado de alimentos y los avances en ingeniería correspondentes, y su relación con la salud del consumidor."@en ;
    sch:inLanguage "Castellano" ;
    guide:teachingPeriod "2025-26" ;
    guide:periodStartingMonth "Septiembre" ;
    guide:periodEndingMonth "Enero" ;
    guide:numberOfCredits 4.0 ;
    guide:totalHours "104" ; # Calculated based on 26h per credit approx
    sch:instructor guide:Prof_Fernando_Calderon, guide:Prof_Eva_Navascues, guide:Prof_Felipe_Palomero ;
    sch:director guide:Prof_Fernando_Calderon ;
    guide:hasSyllabus guide:Syllabus_203000157 ;
    guide:hasCompetency guide:Comp_CB8, guide:Comp_CG1, guide:Comp_CG3, guide:Comp_CG8 ;
    guide:hasLearningResult guide:LR_RA7_RA16, guide:LR_RA50, guide:LR_RA51, guide:LR_RA53, guide:LR_RA52, guide:LR_RA49 ;
    guide:hasEvaluation guide:EvalSystem_203000157 ;
    guide:hasDidacticResource guide:Res_Baaghan_2022, guide:Res_Barros_2020, guide:Res_BRC_IoP, guide:Res_Coles_2009, guide:Res_Crosby_2024 ;
    sch:activitiesWorkload "Estimación de 26-27 horas por crédito ECTS" .

