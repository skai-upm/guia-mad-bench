# --- Competencies ---

guide:Comp_CB8 a guide:Competency ;
    guide:competencyCode "CB8" ;
    guide:competencyDescription "Que los estudiantes sean capaces de integrar conocimientos y enfrentarse a la complejidad de formular juicios..."@en .

guide:Comp_CG1 a guide:Competency ;
    guide:competencyCode "CG1" ;
    guide:competencyDescription "Capacidad de observación, generación de $\text{hipótesis}$ y planteamiento de problemas experimentales en el ámbito de la alimentación y la salud."@en .

guide:Comp_CG3 a guide:Competency ;
    guide:competencyCode "CG3" ;
    guide:competencyDescription "Capacidad para evaluar los sistemas de control de la cadena alimentaria y promover la seguridad en el consumo como estrategia competitiva."@en .

guide:Comp_CG8 a guide:Competency ;
    guide:competencyCode "CG8" ;
    guide:competencyDescription "Resolver con eficacia y eficiencia problemas relacionados con la alimentación salvaguardando y mejorando la salud de la sociedad..."@en .

# --- Learning Results ---

guide:LR_RA7_RA16 a guide:LearningResult ;
    guide:learningResultCode "RA7 - RA16" ;
    guide:learningResultDescription "Evaluar resultados analíticos y su repercusión en el contexto alimentación/salud"@en .

guide:LR_RA50 a guide:LearningResult ;
    guide:learningResultCode "RA50" ;
    guide:learningResultDescription "Conocer los avances en materiales tradicionales de envasado"@en .

guide:LR_RA51 a guide:LearningResult ;
    guide:learningResultCode "RA51" ;
    guide:learningResultDescription "Conocer los avances en nuevos materiales y técnicas de envasado"@en .

# --- Syllabus ---

guide:Syllabus_203000157 a guide:Syllabus ;
    guide:hasItem guide:SyllabusItem_Theme1, guide:SyllabusItem_Theme2, guide:SyllabusItem_Theme3, guide:SyllabusItem_Theme4, guide:SyllabusItem_Theme5, guide:Syll．abusItem_Theme6 .

guide:SyllabusItem_Theme1 a guide:SyllabusItem ;
    guide:itemIndex 1 ;
    guide:syllabusDescription "Introducción: Nuevas funciones del envase de alimentos; Legislación y normativa. Avances; Envasado de alimentos y salud."@en .

guide:SyllabusItem_Theme2 a guide:SyllabusItem ;
    guide:itemIndex 2 ;
    guide:syllabusDescription "Avances en materiales de envasado tradicionales (Metálicos, Vidrio, Cerámica, Papel/Cartón, Tejidos, Polímeros)."@en .

guide:SyllabusItem_Theme3 a guide:SyllabusItem ;
    guide:itemIndex 3 ;
    guide:syllabusDescription "Nuevos materiales de envasado (Polímeros última generación, Biopolímeros, Compuestos, Nanocompuestos, Multicapas)."@en .

