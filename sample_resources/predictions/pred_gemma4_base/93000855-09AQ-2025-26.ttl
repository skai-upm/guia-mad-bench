# Course Guide Instance
guide:course_guide_93000855 rdf:type guide:CourseGuide ;
    sch:name "Analisis Del Negocio Tic" ;
    sch:description "El curso Análisis de Negocios TIC y Digitales tiene como objetivo formar a los estudiantes en el análisis de casos empresariales..."@en ;
