# Competencies
guide:comp_ce7 rdf:type guide:Competency ;
    guide:competencyCode "CE7" ;
    guide:competencyDescription "Capacidad para realizar la planificación, toma de decisiones y empaquetamiento de redes..."@en .

guide:comp_cg1 rdf:type guide:Competency ;
    guide:competencyCode "CG1" ;
    guide:competencyDescription "Poseer y comprender conocimientos que aporten una base u oportunidad de ser originales..."@en .

guide:comp_cg3 rdf:type guide:Competency ;
    guide:competencyCode "CG3" ;
    guide:competencyDescription "Que los estudiantes sean capaces de integrar conocimientos y enfrentarse a la complejidad..."@en .

guide:comp_ct3 rdf:type guide:Competency ;
    guide:competencyCode "CT3" ;
    guide:competencyDescription "Capacidad para adoptar soluciones creativas que satisfagan adecuadamente las diferentes necesidades planteadas."@en .

guide:comp_ct6 rdf:type guide:Competency ;
    guide:competencyCode "CT6" ;
    guide:competencyDescription "Capacidad para emitir juicios sobre implicaciones económicas, administrativas, sociales, éticas y medioambientales..."@en .

# Learning Results (Sample)
guide:lr_ra172 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA172" ;
    guide:learningResultDescription "Analizar las finanzas de un operador de telecom, comparativamente con las de una OTT..."@en .

guide:lr_ra24 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA24" ;
    guide:learningResultDescription "Adquisición de conocimientos sobre aspectos complementarios para la gestión de un proyecto de ingeniería..."@en .

guide:lr_ra33 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA33" ;
    guide:learningResultDescription "Capacidad para abordar y desarrollar en grupo casos prácticos de análisis, diseño, dimensionamiento..."@en .

# Syllabus
guide:syllabus_93000855 rdf:type guide:Syllabus ;
    guide:hasItem guide:item_tema1, guide:item_tema2, guide:item_tema3 .

guide:item_tema1 rdf:type guide:SyllabusItem ;
    guide:itemIndex 1 ;
    guide:syllabusDescription "Tema 1. Valoración de proyectos de inversión" .

guide:item_tema2 rdf:type guide:SyllabusItem ;
    guide:itemIndex 2 ;
    guide:syllabusDescription "Tema 2. Valoración de empresas" .

guide:item_tema3 rdf:type guide:SyllabusItem ;
    guide:itemIndex 3 ;
    guide:syllabusDescription "Tema 3. El método del Venture Capital para valorar startups" .

# Evaluation System
guide:eval_system_93000855 rdf:type guide:EvaluationSystem ;
    guide:evaluationDescription "Evaluación progresiva y prueba global."@en ;
    guide:hasEvaluationTrial guide:trial_exam_final, guide:trial_case1, guide:trial_case2, guide:trial_case3a, guide:trial_case3b, guide:trial_case4 .

guide:trial_exam_final rdf:type guide:EvaluationTrial ;
    guide:trialType "Examen Escrito" ;
    guide:evaluationType "Global" ;
    guide:gradePercentage "50%" ;
    guide:minimumScore "5/10" ;
    guide:evaluationDuration "01:30" ;
    guide:trialMode "Presencial" .

guide:trial_case1 rdf:type guide:EvaluationTrial ;
    guide:trialType "Trabajo Individual" ;
    guide:evaluationType "Progresiva" ;
    guide:gradePercentage "9%" ;
    guide:minimumScore "5/10" ;
    guide:evaluationDuration "00:00" ;
    guide:trialMode "No Presencial" .

# Schedule
guide:schedule_93000855 rdf:type guide:Schedule ;
