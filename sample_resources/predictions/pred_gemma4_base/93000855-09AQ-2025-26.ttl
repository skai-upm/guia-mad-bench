    guide:activityFormat "Lección Magistral" ;
    guide:attendanceType "Presencial" .

guide:event_week2 rdf:type guide:ScheduleEvent ;
    guide:eventIndex 2 ;
    guide:eventWeek "Semana 2" ;
    guide:hasActivity guide:act_chapter1_cont, guide:act_participation .

guide:act_chapter1_cont rdf:type guide:Activity ;
    guide:activityDescription "CAPÍTULO 1. Estudio de caso 1 teoría y explicación" ;
    guide:activityDuration 1.75 ;
    guide:activityFormat "Lección Magistral" ;
    guide:attendanceType "Presencial" .

guide:act_participation rdf:type guide:Activity ;
