    guide:periodStartingMonth "Febrero" ;
    guide:periodEndingMonth "Junio" ;
    sch:inLanguage "Castellano" ;
    guide:totalHours "Estimado según créditos ECTS (26-27h por crédito)" ;
    guide:hasSyllabus guide:syllabus_93000855 ;
    guide:hasEvaluation guide:eval_system_93000855 ;
    guide:hasLearningResult guide:lr_ra172, guide:lr_ra24, guide:lr_ra33, guide:lr_ra145, guide:lr_ra29, guide:lr_ra25, guide:lr_ra139, guide:lr_ra138, guide:lr_ra23, guide:lr_ra76, guide:lr_ra244, guide:lr_ra245, guide:lr_ra70, guide:lr_ra243, guide:lr_ra246, guide:lr_ra146, guide:lr_ra10, guide:lr_ra148 ;
    guide:hasCompetency guide:comp_ce7, guide:comp_cg1, guide:comp_cg3, guide:comp_ct3, guide:comp_ct6 ;
    sch:instructor guide:lecturer_fernando_herrera, guide:lecturer_luis_castejon, guide:lecturer_zoraida_frias ;
    sch:courseSchedule guide:schedule_93000855 ;
    guide:hasDidacticResource guide:res_excel_valuation, guide:res_book_park, guide:res_book_newnan, guide:res_book_copeland ;
    sch:activitiesWorkload "Metodología híbrida (presencial y online)" .

