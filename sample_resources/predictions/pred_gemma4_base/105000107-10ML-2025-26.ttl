# Course Instance (Course Guide)
:course_guide_105000107_2S_2025_26
    rdf:type guide:CourseGuide ;
    sch:name "Matematica Discreta II" ;
    sch:description "La asignatura Matemática Discreta II complementa la asignatura Matemática Discreta I del primer semestre. En ella se estudia principalmente la Teoría de Grafos..."@en ;
    sch:courseCode 105000107 ;
    guide:numberOfCredits 6.0 ;
    guide:teachingPeriod "2025-26" ;
    guide:periodStartingMonth "Febrero" ;
    guide:periodEndingMonth "Junio" ;
    sch:inLanguage "Castellano" ;
    guide:hasSyllabus :syllabus_105000107 ;
    guide:hasEvaluation :eval_system_105000107 ;
    guide:hasCompetency :comp_C1, :comp_C10, :comp_C13, :comp_C2, :comp_C3, :comp_C4, :comp_C5 ;
    guide:hasLearningResult :lr_RA35, :lr_RA19, :lr_RA26, :lr_RA33, :lr_RA31, :lr_RA20 ;
    sch:instructor :lecturer_m_del_carmen_iglesias, :lecturer_luis_magdalena_layos ;
    sch:courseSchedule :schedule_105000107 ;
    guide:hasDidacticResource :res_biggs, :res_gross, :res_rosen, :res_caballero, :res_lipschutz, :res_vieites, :res_agnarsson, :res_balakrishnan, :res_chartrand, :res_kocay, :res_koh, :res_marcus, :res_matousek, :res_west ;
    guide:hasActivity :act_leccion_magistral, :act_clase_problemas, :act_practicas_laboratorio, :act_cuestionario_moodle, :act_trabajo ;
    sch:activitiesWorkload "26-2assumed hours per ECTS" .

