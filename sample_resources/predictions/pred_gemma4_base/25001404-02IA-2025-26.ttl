# Course Guide Instance
:course_guide_analisis_ecosistemas rdf:type guide:CourseGuide ;
    sch:name "Analisis De Ecosistemas" ;
    sch:courseCode 25001404 ;
    guide:numberOfCredits 4.0 ;
    guide:teachingPeriod "2025-26" ;
    guide:periodStartingMonth "Septiembre" ;
    guide:periodEndingMonth "Enero" ;
    sch:inLanguage "Castellano" ;
    guide:totalHours "26-27 hours per ECTS" ;
    sch:description "La asignatura se compone de cuatro partes: 1) Metodología de muestreo en campo; 2) Análisis de datos de muestreos en campo; 3) Fitosociología; 4) Bioindicadores." ;
    guide:hasSyllabus :syllabus_analisis_ecosistemas ;
    guide:hasCompetency :comp_ce14, :comp_ce15, :comp_ce17, :comp_ce24, :comp_ce36, :comp_ce39, :comp_cg14, :comp_cg6, :comp_cg7 ;
    guide:hasLearningResult :lr_ra519, :lr_ra228, :lr_ra227, :lr_ra229, :lr_ra230 ;
    guide:hasEvaluation :eval_system_analisis_ecosistemas ;
    sch:instructor :lecturer_santiago_moreno ;
    sch:courseSchedule :schedule_analisis_ecosistemas ;
    guide:hasDidacticResource :res_vegetacion_1, :res_qgis, :res_r_windows, :res_anthos, :res_idee, :res_natusfera ;
    sch:activitiesWorkload "26-27 hours per ECTS" .

# Course Instance
:course_analisis_ecosistemas rdf:type guide:Course ;
