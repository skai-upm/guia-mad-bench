    sch:numberOfCredits 4.0 ;
    sch:hasCourseInstance :course_guide_analisis_ecosistemas .

# Degree Instance
:degree_agroambiental rdf:type guide:BachelorDegree ;
    sch:name "Grado En Ingenieria Agroambiental" ;
    guide:degreeCode "02IA" .

# University Center Instance
:center_etsi_agronomica rdf:type guide:UniversityCenter ;
    sch:name "Etsi Agronómica, Aliment. y Biosistemas" ;
    guide:offers :degree_agroambiental .

# Lecturer Instances
:lecturer_santiago_moreno rdf:type guide:Lecturer ;
    sch:name "Santiago Moreno Vazquez" ;
    sch:email "santiago.moreno@upm.es" ;
    guide:office "Banco Semillas" ;
    guide:tutorshipsSchedule "X - 10:00 - 13:00, J - 10:00 - 13:00" .

