# Competency Instances
:comp_ce14 rdf:type guide:Competency ;
    guide:competencyCode "CE14" ;
    guide:competencyDescription "Conocimiento de los conceptos básicos de Ecología, sus objetivos, metodología y modo de estudiar el biotopo, la biocenosis y sus relaciones." .

:comp_ce15 rdf:type guide:Competency ;
    guide:competencyCode "CE15" ;
    guide:competencyDescription "Capacidad para aplicar los principios de la botánica en la identificación y caracterización de especies vegetales..." .

:comp_ce24 rdf:type guide:Competency ;
    guide:competencyCode "CE24" ;
    guide:competencyDescription "Capacidad para utilizar los modelos de datos espaciales y la incorporación de atributos relacionados con el medio ambiente..." .

:comp_cg7 rdf:type guide:Competency ;
    guide:competencyCode "CG7" ;
    guide:competencyDescription "Compromiso ético y profesional y respeto por el medio ambiente y la diversidad" .

# Learning Result Instances
:lr_ra519 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA51．9" ;
    guide:learningResultDescription "Utilizar organismos bioindicadores para conocer el estado de los ecosistemas" .

:lr_ra228 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA228" ;
    guide:learningResultDescription "Aplicar correctamente herramientas estadísticas para el análisis de datos cualitativos y cuantitativos obtenidos en la naturaleza." .

# Syllabus and Items
:syllabus_analisis_ecosistemas rdf:type guide:Syllabus ;
    guide:hasItem :item_seccion1, :item_seccion2, :item_seccion3, :item_seccion4 .

:item_seccion1 rdf:type guide:SyllabusItem ;
    guide:itemIndex 1 ;
    guide:syllabusDescription "Muestreo en campo sobre la abundancia de especies biológicas" .

:item_seccion2 rdf:type guide:SyllabusItem ;
    guide:itemIndex 2 ;
    guide:syllabusDescription "Fitosociología" .

# Evaluation System and Trials
:eval_system_analisis_ecosistemas rdf:type guide:EvaluationSystem ;
    guide:evaluationDescription "La evaluación continua aporta el 50% de la nota y el otro 50 % deriva de la evaluación global." ;
    guide:hasEvaluationTrial :trial_p02, :trial_p03, :trial_global .

:trial_p02 rdf:type guide:EvaluationTrial ;
    guide:trialType "Evaluación Progresiva" ;
    guide:gradePercentage "2.5%" ;
    guide:trialMode "Presencial" ;
    guide:involvesCompetency :comp_ce24 .

:trial_p03 rdf:type guide:EvaluationTrial ;
    guide:trialType "Evaluación Progresiva" ;
    guide:gradePercentage "5%" ;
    guide:trialMode "Presencial" ;
    guide:involvesCompetency :comp_cg7 .

:trial_global rdf:type guide:EvaluationTrial ;
    guide:trialType "Examen Escrito" ;
    guide:gradePercentage "50%" ;
    guide:minimumScore "3/10" ;
    guide:trialMode "Presencial" ;
    guide:involvesCompetency :comp_ce14 .

# Schedule and Events
:schedule_analisis_ecosistemas rdf:type guide:Schedule ;
    sch:eventSchedule :event_week1, :event_week2 .

:event_week1 rdf:type guide:ScheduleEvent ;
    guide:eventWeek "Semana 1" ;
    guide:eventIndex 1 ;
    guide:hasActivity :act_leccion_magistral_1 .

:act_leccion_magistral_1 rdf:type guide:Activity ;
    guide:activityDescription "Métodos florísticos (medidas de abundancia)" ;
    guide:activityDuration 0.5 ;
    guide:activityFormat "Lección Magistral" ;
    guide:attendanceType "Presencial" .

:event_week2 rdf:type guide:ScheduleEvent ;
    guide:eventWeek "Semana 2" ;
    guide:eventIndex 2 ;
    guide:hasActivity :act_practica_2 .

:act_practica_2 rdf:type guide:Activity ;
    guide:activityDescription "Práctica 2 (jardín ETSIAAB) manejo del navegador GPS y del teléfono móvil" ;
    guide:activityDuration 1.0 ;
    guide:activityFormat "Prácticas de Laboratorio" ;
    guide:attendanceType "Presencial" .

# Didactic Resources
:res_vegetacion_1 rdf:type guide:DidacticResource ;
    sch:name "Vegetación 1" ;
    guide:bibliographyTitle "Barbour MG (1999) Terrestrial plant ecology." ;
    guide:bibliographyType "Bibliografía" .

:res_qgis rdf:type guide:DidacticResource ;
    sch:name "Q-GIS" ;
    guide:bibliographyDescription "Software de SIG" ;
    guide:bibliographyType "Equipamiento" .

:res_anthos rdf:type guide:DidacticResource ;
    sch:name "Anthos" ;
    guide:bibliographyDescription "Sistema de información sobre las plantas de España" ;
    guide:bibliographyType "Recursos web" .

# Required Knowledge
:req_knowledge_ecosystems rdf:type guide:RequiredKnowledge ;
    guide:previousKnowledge "Sistemas De Informacion Geografica (sig), Biologia, Ecologia, Metodos Estadisticos En Ingenieria Agroambiental" .