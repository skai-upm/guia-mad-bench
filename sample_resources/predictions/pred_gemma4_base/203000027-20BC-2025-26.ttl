    sch:email "jesusisradel.pagan@upm.es" ;
    guide:office "231" ;
    guide:tutorshipsSchedule "Tu - 12:00 - 13:00" .

:lecturer_cristina rdf:type guide:Lecturer ;
    sch:name "Cristina Saez Sanchez" ;
    sch:email "cristina.saez@upm.es" ;
