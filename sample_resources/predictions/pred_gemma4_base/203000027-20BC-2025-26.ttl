# Degree and University Center
:degree_20BC rdf:type guide:MasterDegree ;
    sch:name "20BC - Master Universitario en Biologia Computacional" ;
    guide:degreeCode "20BC" .

:center_ETSI rdf:type guide:UniversityCenter ;
    sch:name "Etsi Agronómica, Aliment. y Biosistemas" ;
    guide:offers :degree_20BC .

# Course
:course_203000027 rdf:type guide:Course ;
    sch:name "203000027 - Computational Approaches In Evolutionary Biology" ;
    sch:courseCode 203000027 ;
    guide:courseType "Optional/elective" ;
    sch:hasCourseInstance :guide_203000027 .

:degree_20BC guide:hasCourse :course_203000027 .

# Course Guide
:guide_203000027 rdf:type guide:CourseGuide ;
    sch:name "Learning Guide - Computational Approaches In Evolutionary Biology" ;
    sch:inLanguage "English" ;
    teachingPeriod "2025-26" ;
    teachingPeriodMonths "September-January" ;
    periodStartingMonth "September" ;
    periodEndingMonth "January" ;
    guide:numberOfCredits 3.0 ;
    sch:instructor :lecturer_jesus, :lecturer_cristina ;
    sch:director :lecturer_jesus ;
    guide:hasSyllabus :syllabus_203000027 ;
    guide:hasEvaluation :eval_system_203000027 ;
    guide:hasCompetency :comp_CE02, :comp_CE03, :comp_CE05, :comp_CE10, :comp_CG03, :comp_CG05, :comp_CT02 ;
    guide:hasLearningResult :lr_RA18, :lr_RA19, :lr_RA16, :lr_RA17 ;
    guide:hasDidacticResource :res_nei, :res_hartl, :res_lemey ;
    sch:courseSchedule :schedule_203000027 ;
    sch:description "The course combines a solid formation in theoretical aspects on the mechanisms and forces determining the evolution of living organisms, with a strong practical component." .

# Faculty
:lecturer_jesus rdf:type guide:Lecturer ;
