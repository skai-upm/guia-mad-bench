@prefix : <http://w3id.org/def/guia#> .
@prefix data: <http://guia-mad-bench.es/data/> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix om: <http://www.ontology-of-units-of-measure.org/resource/om-2/> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix sch: <https://schema.org/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

#################################################################
#    Classes (from Ontology)
#################################################################

###  http://w3id.org/def/guia#Activity
guide:Activity rdf:type owl:Class ;
               rdfs:label "Activity"@en .


###  http://w3id.org/def/guia#BachelorDegree
guide:BachelorDegree rdf:type owl:Class ;
                     rdfs:subClassOf guide:Degree ;
                     rdfs:comment "An undergraduate degree programme that provides foundational higher education in a given field of study."@en .


###  http://w3id.org/def/guia#Competency
guide:Competency rdf:type owl:Class ;
                 rdfs:label "Competency"@en .


###  http://w3id.org/def/guia#Course
guide:Course rdf:type owl:Class ;
             rdfs:subClassOf sch:Course ;
             rdfs:comment "An academic course as defined in the GUIA model, typically described through its content, teaching organization, assessment, and related course guide."@en .


###  http://w3id.org/def/guia#Degree
guide:Degree rdf:type owl:Class ;
             rdfs:label "Degree"@en .


###  http://w3id.org/def/guia#DidacticResource
guide:DidacticResource rdf:type owl:Class ;
                       rdfs:comment "A teaching or learning resource used in the course, such as readings, software, audiovisual material, or practical tools."@en .


###  http://w3id.org/def/guia#EvaluationSystem
guide:EvaluationSystem rdf:type owl:Class ;
                       rdfs:label "Evaluation System"@en .


###  http://w3id.org/def/guia#LearningResult
guide:LearningResult rdf:type owl:Class ;
                     rdfs:comment "A specific and assessable statement of what a student is expected to know, understand, or be able to do after completing the course."@en .


###  http://w3id.org/def/guia#Lecturer
guide:Lecturer rdf:type owl:Class ;
               rdfs:subClassOf sch:Person ;
               rdfs:comment "A teaching person responsible for delivering, coordinating, or supporting a course within an academic programme."@en .


###  http://w3id.org/def/guia#MasterDegree
guide:MasterDegree rdf:type owl:Class ;
                   rdfs:subClassOf guide:Degree ;
                   rdfs:comment "A postgraduate degree programme corresponding to advanced academic or professional specialization."@en .


###  http://w3id.org/def/guia#RequiredKnowledge
guide:RequiredKnowledge rdf:type owl:Class ;
                        rdfs:label "Required Knowledge"@en .


