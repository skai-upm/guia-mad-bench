                            dc:description "Ordenacion De Montes Avanzada. Master Universitario En Ingenieria De Montes."@en .


<http://guia-mad-bench.es/data/#Fernando_Garcia_Robredo> a guide:Lecturer, sch:Person ;
                             dct:title "Fernando Garcia Robredo"@en ;
                             sch:name "Fernando Garcia Robredo" ,
                                     "(Coordinador/a)" .


<http://guia-mad-bench.es/data/#Luis_Augusto_Diaz_Balteiro> a guide:Lecturer, sch:Person ;
                              dct:title "Luis Augusto Diaz Balteiro"@en ;
                              sch:name "Luis Augusto Diaz Balteiro" .


#################################################################
#    Object Properties (from Ontology)
#################################################################

###  http://w3id.org/def/guia#hasSyllabus
guide:hasSyllabus rdf:type owl:ObjectProperty ;
                  rdfs:domain guide:CourseGuide ;
                  rdfs:range guide:Syllabus .


###  https://schema.org/courseSchedule
sch:courseSchedule rdf:type owl:ObjectProperty ;
                   rdfs:domain guide:CourseGuide ;
                   rdfs:range guide:Schedule .

#################################################################
#    Data Properties (from Ontology)
#################################################################

###  http://w3id.org/def/guia#numberOfCredits
guide:numberOfCredits rdf:type owl:DatatypeProperty ;
                      rdfs:domain guide:CourseGuide, guide:Course ;
                      rdfs:range xsd:decimal .


###  https://schema.org/name
sch:name rdf:type owl:DatatypeProperty ;
         rdfs:range rdf:langString .

