<guide:Degree_10ID> rdf:type guide:BachelorDegree, guide:Degree ;
                    sch:name "Doble Grado En Ingenieria Informatica Y En Ade"@en ;
                    guide:degreeCode "10ID"^^xsd:string ;
                    guide:hasCourse <guide:Course_Estructura_Computadores>.

<guide:UniversityCenter_UPM> rdf:type guide:UniversityCenter, sch:Organization ;
                             sch:name "E.T.S. de Ingenieros Informáticos"@en .

#################################################################
#    Competencies and Learning Results
#################################################################

<guide:Competency_10II-CE05> rdf:type guide:Competency ;
                              guide:competencyCode "10II-CE05"^^xsd:string ;
                              sch:description "Capacidad de diseñar y realizar experimentos apropiados, interpretar los datos y extraer conclusiones."@en .

<guide:Competency_10II-CE07> rdf:type guide:Competency ;
                             guide:competencyCode "10II-CE07"^^xsd:string ;
                             sch:description "Entender el soporte físico (hardware) de los ordenadores desde el punto del vista del soporte lógico."@es .

<guide:Competency_10II-CG22> rdf:type guide:Competency ;
                              guide:competencyCode "10II-CG22"^^xsd:string ;
                              sch:description "Capacidad de aplicar sus conocimientos e intuición para diseñar el hardware/software que cumple unos requisitos especificados."@es .

<guide:LearningResult_RA103> rdf:type guide:LearningResult ;
                             guide:learningResultCode "RA103"^^xsd:string ;
                             sch:description "Utilizar eficientemente los recursos básicos del computador mediante el lenguaje nativo del mismo."@en .

#################################################################
#    Course and Schedule Events
#################################################################

<guide:Course_Estructura_Computadores> rdf:type guide:Course, sch:CourseInstance ;
                                        sch:name "105000381 - Estructura De Computadores"@es ;
                                        guide:syllabus <guide:Syllabus_105000381>,
                                                  guide:EvaluationSystem_105000381 .

<guide:Schedule_Estructura_Computadores> rdf:type guide:Schedule, sch:CourseInstance ;
                                          sch:eventSchedule <guide:ScheduleEvent_Semana_1>.

#################################################################
#    Schedule Events (Sample)
#################################################################

<guide:ScheduleEvent_Semana_1> rdf:type guide:ScheduleEvent ;
                               sch:name "Explicación de contenidos teóricos del Tema 1"^^xsd:string ;
                               guide:eventWeek "Semestre 5, Semana 1"^^rdf:langString ;
                               om:activityDurationUnit <om:hour>,
                                         xsd:decimal(4.0) .

<guide:ScheduleEvent_Semana_2> rdf:type guide:ScheduleEvent ;
                               sch:name "Resolución de problemas del Tema 1 y Explicación teórica Tema 2"^^xsd:string ;
                               om:activityDurationUnit <om:hour>, xsd:decimal(5.0) .

<guide:EvaluationTrial_Primer_Parcial> rdf:type guide:EvaluationTrial, sch:EventSchedule ;
                                       sch:name "Realización de primer examen parcial"@es ;
                                       guide:trialType "Examen Escrito"^^xsd:string ;
                                       guide:evaluationDuration <om:hour>, xsd:decimal(2.0) .

<guide:EvaluationTrial_Examen_Final> rdf:type guide:EvaluationTrial, sch:EventSchedule ;
                                      sch:name "Examen final de teoría"@es ;
                                      guide:trialType "Examen Escrito"^^xsd:string ;
                                      guide:evaluationDuration <om:hour>, xsd:decimal(4.0) .

