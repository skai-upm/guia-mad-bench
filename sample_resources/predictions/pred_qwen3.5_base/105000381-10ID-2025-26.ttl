#################################################################

<guide:EvaluationSystem_105000381> rdf:type guide:EvaluationSystem, sch:EventSchedule ;
                                    sch:description "Evaluación progresiva y global."@es ;
                                    guide:hasEvaluationTrial <guide:EvaluationTrial_Primer_Parcial>,
                                                          <guide:EvaluationTrial_Examen_Final>.

