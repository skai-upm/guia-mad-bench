#################################################################
#    Instance Data Extraction (Course Guide 105000381)
#################################################################

<guide:CourseGuide_105000381> rdf:type guide:CourseGuide ;
                                sch:name "Estructura De Computadores"@en ;
                                dct:title "ANX-PR/CL/001-01 Guía de Aprendizaje"@es ;
                                guide:numberOfCredits 6.0^^xsd:decimal ;
                                guide:teachingPeriod "2025-26"^^xsd:string ;
                                guide:periodStartingMonth "Septiembre"^^rdf:langString ;
                                guide:periodEndingMonth "Enero"^^rdf:langString ;
                                sch:inLanguage "Castellano"@en ;
                                guide:syllabusDescription "Introducción a los computadores, Programación en Ensamblador, Procesador, Aritmética del computador y Periféricos."@es .

<guide:Syllabus_105000381> rdf:type guide:Syllabus ;
                             sch:courseSchedule <guide:CourseGuide_105000381> ;
                             guide:hasSyllabus <guide:CourseGuide_105000381> .

<guide:EvaluationSystem_105000381> rdf:type guide:EvaluationSystem ;
                                    sch:description "Evaluación progresiva y global. Dos partes: teoría (parciales) y proyecto."@es ;
                                    guide:hasEvaluation <guide:EvaluationTrial_Primer_Parcial>,
                                                        <guide:EvaluationTrial_Examen_Final>.

