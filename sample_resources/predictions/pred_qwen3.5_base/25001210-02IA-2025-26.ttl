<http://w3id.org/guia/ecologia_syllabus_25001210> rdf:type :Syllabus ;
    guide:sch:name "Ecología"@en ;
    sch:hasCourseInstance <http://w3id.org/guia/ecologia_25001210> .

<http://w3id.org/guia/syllabus_item_tema1> rdf:type :SyllabusItem ;
    guide:sch:itemIndex 1^^xsd:integer ;
    sch:name "Introducción a la Ecología"@en ;
    guide:syllabusDescription "Definición, datos históricos, conceptos básicos utilizados en ecología."@es .

<http://w3id.org/guia/syllabus_item_tema2> rdf:type :SyllabusItem ;
    guide:sch:itemIndex 2^^xsd:integer ;
    sch:name "Los organismos y el medio"@en ;
    guide:sylbusDescription "Recursos, condiciones del medio físico, clima, suelo."@es .

<http://w3id.org/guia/syllabus_item_tema3> rdf:type :SyllabusItem ;
    guide:sch:itemIndex 3^^xsd:integer ;
    sch:name "Población"@en ;
    guide:sylbusDescription "Propiedades, densidad, estructura por edades."@es .

<http://w3id.org/guia/syllabus_item_tema4> rdf:type :SyllabusItem ;
    guide:sch:itemIndex 4^^xsd:integer ;
    sch:name "Comunidad"@en ;
    guide:sylbusDescription "Competencia, mutualismo, depredación."@es .

<http://w3id.org/guia/syllabus_item_tema5> rdf:type :SyllabusItem ;
    guide:sch:itemIndex 5^^xsd:integer ;
    sch:name "Ecosistemas"@en ;
    guide:sylbusDescription "Biotopo, biocenosis, flujos de energía."@es .

