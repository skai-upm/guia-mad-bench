<http://w3id.org/def/guia#Competencia_CB1> rdf:type :Competency ;
    guide:competencyCode "CB1"^^xsd:string ;
    sch:description "Que los estudiantes hayan demostrado poseer y comprender conocimientos en un área de estudio que parte de la base de la educación secundaria general."@en .

<http://w3id.org/def/guia#Competencia_CB5> rdf:type :Competency ;
    guide:competencyCode "CB5"^^xsd:string ;
    sch:description "Que los estudiantes hayan desarrollado aquellas habilidades de aprendizaje necesarias para emprender estudios posteriores con un alto grado de autonomía."@en .

<http://w3id.org/def/guia#Competencia_CE14> rdf:type :Competency ;
    guide:competencyCode "CE 14"^^xsd:string ;
    sch:description "Conocimiento de la termodinámica aplicada y de la transmisión del calor."@en .

<http://w3id.org/def/guia#Competencia_CG3> rdf:type :Competency ;
    guide:competencyCode "CG3"^^xsd:string ;
    sch:description "Capacidad para el aprendizaje de nuevos métodos y teorías, y en la versatilidad para adaptarse a nuevas situaciones basándose en los conocimientos adquiridos."@en .

<http://w3id.org/def/guia#Resultado_RA192> rdf:type :LearningResult ;
    guide:learningResultCode "RA192"^^xsd:string ;
    sch:description "Conocer los ciclos termodinámicos"@es .

<http://w3id.org/def/guia#Resultado_RA189> rdf:type :LearningResult ;
    guide:learningResultCode "RA189"^^xsd:string ;
    sch:description "Conocer y comprender el comportamiento termodinámico de las sustancias puras"@es .

<http://w3id.org/def/guia#Resultado_RA190> rdf:type :LearningResult ;
    guide:learningResultCode "RA190"^^xsd:string ;
    sch:description "Conocer la formulación de los Principios Primero y Segundo de la Termodinámica en sistemas abiertos y cerrados"@es .

<http://w3id.org/def/guia#Resultado_RA188> rdf:type :LearningResult ;
    guide:learningResultCode "RA188"^^xsd:string ;
    sch:description "Conocer la composición del aire húmedo y el diagrama psicrométrico"@es .

<http://w3id.org/def/guia#Resultado_RA191> rdf:type :LearningResult ;
    guide:learningResultCode "RA191"^^xsd:string ;
    sch:description "Conocer los distintos mecanismos de transferencia de calor"@es .

<http://w3id.org/def/guia#Termodinamica_85003315> guide:hasCompetency <http://w3id.org/def/guia#Competencia_CB1>, <http://w3id.org/def/guia#Competencia_CB5>, <http://w3id.org/def/guia#Competencia_CE14>, <http://w3id.org/def/guia#Competencia_CG3> ;
    guide:hasLearningResult <http://w3id.org/def/guia#Resultado_RA192>, <http://w3id.org/def/guia#Resultado_RA189>, <http://w3id.org/def/guia#Resultado_RA190>, <http://w3id.org/def/guia#Resultado_RA188>, <http://w3id.org/def/guia#Resultado_RA191> .

