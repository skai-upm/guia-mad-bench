<http://guia-mad-bench.es/data/guia-65005004> a guide:CourseGuide, sch:CourseInstance ;
        dc:title "Laboreo De Minas"@es ;
        dct:creator "Juan Herrera Herbert" ,
                    "Carlos Lopez Jimeno" ,
                    "Jesus Caceres Jimeno" ;
        guide:numberOfCredits 4.5^^xsd:decimal ;
        sch:name "65005004 - Laboreo De Minas"@en ;
        guide:syllabusDescription "Introducción al conjunto de la industria minera actual, sus funciones, procesos, tecnologías..."@es ;
        guide:teachingPeriodMonths "Septiembre-Enero"^^xsd:string ;
        sch:description "La asignatura está planteada como una introducción a los conceptos fundamentales utilizados en la industria y las actividades desde una perspectiva integral."@en .

