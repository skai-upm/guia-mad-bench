<http://w3id.org/def/guia#ANX_PR_CL_001_01> rdf:type :CourseGuide ;
    dc:title "93001006 - Servicios De Seguridad En Red"@en ,
        "Servicios de Seguridad en Red"@es ;
    dct:creator <http://w3id.org/def/guia#DiegoRiveraPinto> ;
    sch:name "ANX-PR/CL/001-01"@en ;
    guide:numberOfCredits 3^^xsd:decimal ;
    guide:courseYear "2025"^xsd:string ;
    guide:syllabusDescription "La asignatura trata sobre los servicios de seguridad que permiten proteger la información en tránsito a través las redes de comunicaciones."@es ;
    sch:description "Guía de Aprendizaje para Servicios De Seguridad En Red"@en .

<http://w3id.org/def/guia#ANX_PR_CL_001_01> guide:hasCourse <http://w3id.org/def/guia#Master_Ciberseguridad> ;
    sch:courseCode 93001006^^xsd:integer .

<http://w3id.org/def/guia#ANX_PR_CL_001_01> guide:syllabus <http://w3id.org/def/guia#Syllabus_ServiciosSeguridadRed> ;
    sch:eventSchedule <http://w3id.org/def/guia#Semestre_Primer_2025_26> .

<http://w3id.org/def/guia#ANX_PR_CL_001_01> guide:hasEvaluationSystem <http://w3id.org/def/guia#Evaluacion_System_ServiciosSeguridadRed> ;
    sch:description "La asignatura se evaluará mediante un sistema de evaluación progresiva que consiste en la realización de cuatro trabajos prácticos."@es .

<http://w3id.org/def/guia#ANX_PR_CL_001_01> guide:hasLearningResult <http://w3id.org/def/guia#RA10_ServiciosSeguridadRed> ;
    sch:description "Analizar y seleccionar los mecanismos adecuados para proteger las comunicaciones"@es .

<http://w3id.org/def/guia#ANX_PR_CL_001_01> guide:hasCompetency <http://w3id.org/def/guia#CE04_ServiciosSeguridadRed> ;
    sch:description "Capacidad para establecer una categorización de servicios de ciberseguridad para proteger a las infraestructuras conectadas en red."@es .

<http://w3id.org/def/guia#ANX_PR_CL_001_01> guide:hasCompetency <http://w3id.org/def/guia#CE05_ServiciosSeguridadRed> ;
    sch:description "Capacidad de analizar y diseñar servicios de seguridad de control de acceso, protección de la información en tránsito y protección perimetral"@es .

<http://w3id.org/def/guia#ANX_PR_CL_001_01> guide:hasCompetency <http://w3id.org/def/guia#CG03_ServiciosSeguridadRed> ;
    sch:description "Dotar al alumno de la capacidad de diseñar e implantar procedimientos de protección de la información asociados con los sistemas de información, las redes y comunicaciones telemáticas"@es .

<http://w3id.org/def/guia#ANX_PR_CL_001_01> guide:hasDidacticResource <http://w3id.org/def/guia#Recursos_Moodle_ServiciosSeguridadRed> ;
    sch:bibliographyTitle "Presentaciones de los temas, enunciados y software"@es .

<http://w3id.org/def/guia#ANX_PR_CL_001_01> guide:hasScheduleEvent <http://w3id.org/def/guia#Semestre_Primer_2025_26> ;
    sch:eventIndex 4^^xsd:integer .

<http://w3id.org/def/guia#ANX_PR_CL_001_01> guide:syllabusDescription "Protección de redes telemáticas y sistemas. Infraestructuras de seguridad."@es ;
    rdf:type :SyllabusItem ;
    guide:itemIndex 1^^xsd:integer .

<http://w3id.org/def/guia#ANX_PR_CL_001_01> guide:syllabusDescription "Redes Privadas Virtuales (VPN)"@es ;
    rdf:type :SyllabusItem ;
    guide:itemIndex 2^^xsd:integer .

<http://w3id.org/def/guia#ANX_PR_CL_001_01> guide:syllabusDescription "Seguridad en nivel de enlace, redes móviles y WiFi"@es ;
    rdf:type :SyllabusItem ;
    guide:itemIndex 3^^xsd:integer .

<http://w3id.org/def/guia#ANX_PR_CL_001_01> guide:syllabusDescription "Seguridad en nivel de red: IPSEC"@es ;
    rdf:type :SyllabusItem ;
    guide:itemIndex 4^^xsd:integer .

<http://w3id.org/def/guia#ANX_PR_CL_001_01> guide:syllabusDescription "Seguridad en nivel de transporte: SSL/TLS"@es ;
    rdf:type :SyllabusItem ;
    guide:itemIndex 5^^xsd:integer .

<http://w3id.org/def/guia#ANX_PR_CL_001_01> guide:syllabusDescription "Seguridad en nivel de aplicación: SRTP, S/MIME, PGP"@es ;
    rdf:type :SyllabusItem ;
    guide:itemIndex 6^^xsd:integer .

<http://w3id.org/def/guia#ANX_PR_CL_001_01> sch:inLanguage "Castellano"@en ;
    guide:periodStartingMonth "Septiembre"@es ;
    guide:periodEndingMonth "Enero"@es .

