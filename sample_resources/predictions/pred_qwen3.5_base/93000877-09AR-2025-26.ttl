<http://guia-mad-bench.es/data/guia_ontology> rdf:type owl:Ontology ;
    dc:title "GUIA ontology"@en ;
    dct:creator "Andrea Cimmino Arriaga" ,
                "Covadonga Arias" ,
                "Joaquín Gayoso Cabada" ,
                "Juan Cano de Benito" ,
                "Paola Espinoza Arias" ;
    rdfs:comment "This ontology defines concepts to represent academic course guides in higher education. It models degrees, courses, teaching roles, learning design, resources, schedules, and evaluation systems."@en .

