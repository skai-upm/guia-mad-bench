<http://guia-mad-bench.es/data/courseguide_ANX_PR_CL_001> rdf:type :CourseGuide ;
    dc:title "Integración De Procesos Químicos"@en ;
    sch:name "53001432 - Integración De Procesos Químicos" ;
    guide:teachingPeriod "Septiembre-Enero" ;
    guide:numberOfCredits 4.5^^xsd:decimal ;
    guide:syllabusDescription <http://guia-mad-bench.es/data/syllabus_01> ;
    sch:description "El objetivo fundamental de la asignatura es aprender los fundamentos matemáticos y tecnológicos para mejorar la eficiencia energética másica de procesos químicos industriales."@en ;
    dct:creator "Manuel Rodriguez Hernandez" ,
                "Francisco Ismael Diaz Moreno"@en ;
    guide:syllabusDescription <http://guia-mad-bench.es/data/syllabus_01> .

