<http://guia-mad-bench.es/data/guia#CourseGuide_43000554> rdf:type :CourseGuide ;
    sch:name "Experimental Structural Analysis"@en ,
        "43000554 - Experimental Structural Analysis"@en ;
    dc:title "ANX-PR/CL/001 LEARNING GUIDE"@en ;
    dct:creator <http://guia-mad-bench.es/data/guia#CarlosMartinDeLaConcha> ,
        <http://guia-mad-bench.es/data/guia#AntonioJoseMadridRamos> ,
        <http://guia-mad-bench.es/data/guia#IvanMuñozDiaz> ;
    guide:numberOfCredits "4.5"^^xsd:decimal ;
    sch:description "This course deals with the fundamentals and applications of experimental techniques in structural engineering."@en .

<http://guia-mad-bench.es/data/guia#Syllabus_43000554> rdf:type :Syllabus ;
