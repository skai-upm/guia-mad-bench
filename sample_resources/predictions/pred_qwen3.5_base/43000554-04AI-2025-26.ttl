<http://guia-mad-bench.es/data/guia#Unit1> rdf:type :SyllabusItem ;
    guide:itemIndex "1"^^xsd:integer ;
    sch:description "Introduction to instrumentation"@en .

<http://guia-mad-bench.es/data/guia#Unit2> rdf:type :SylabusItem ;
    guide:itemIndex "2"^^xsd:integer ;
    sch:description "Signal conditioning, Basics of Electrotechnics."@en .

<http://guia-mad-bench.es/data/guia#Unit3> rdf:type :SyllabusItem ;
    guide:itemIndex "3"^^xsd:integer ;
    sch:description "Strain measurement, Working principle and configuration of strain gages"@en .

<http://guia-mad-bench.es/data/guia#Unit4> rdf:type :SylabusItem ;
    guide:itemIndex "4"^^xsd:integer ;
    sch:description "Load measurement, Load cells, Equipment for load application."@en .

<http://guia-mad-bench.es/data/guia#Unit5> rdf:type :SyllabusItem ;
    guide:itemIndex "5"^^xsd:integer ;
    sch:description "Displacement measurement, Potentiometers, Inductive transducers"@en .

