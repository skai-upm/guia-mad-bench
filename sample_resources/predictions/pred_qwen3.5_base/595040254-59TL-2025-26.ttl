<http://guia-mad-bench.es/data/guide-ANXPRCL001> rdf:type :CourseGuide ;
    dct:title "Guía de Aprendizaje"@en ;
    sch:name "595040254 - Tic Emergentes Para La Sostenibilidad" ;
    guide:courseYear 3 ;
    guide:numberOfCredits "4.5"^^xsd:decimal ;
    guide:teachingPeriodMonths "Febrero-Junio"@en ;
    sch:inLanguage "Castellano"@en ;
    dct:creator <http://guia-mad-bench.es/data/lecturer-aurelio-berges> ,
                <http://guia-mad-bench.es/data/lecturer-valero-duboy> ;
    guide:syllabusDescription "Sociedad de la Información, sociedad del ruido y brechas digitales; TIC emergentes y retos sociales..."@en .

