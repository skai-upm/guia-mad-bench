    guide:eventWeek "Semana 1"^^xsd:string ; # Using string as per data property `guide:eventIndex` range is integer, but table uses Sem. I will use the available properties like `om:Unit`. The snippet has `guide:activityDurationUnit` (range om:Unit).
    sch:name "Presentación de la asignatura" .

<http://guia-mad-bench.es/data/evt-sem2> rdf:type :ScheduleEvent ;
