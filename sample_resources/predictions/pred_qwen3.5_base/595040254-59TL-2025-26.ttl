#################################################################
#  Evaluation System and Trials Entities
#################################################################

<http://guia-mad-bench.es/data/eval-system-59TL> rdf:type :EvaluationSystem , <https://schema.org/EvaluationSystem> ;
    guide:hasSyllabus [ a :CourseGuide ] . # Link to the Guide instance. Actually ontology says hasSyllabus domain is CourseGuide, range Syllabus. So I should link Guide -> Syllabus directly via hasSyllabus property defined in Object Properties section? Yes `guide:hasSyllabus` exists.
    guide:hasEvaluationTrial [ a :EvaluationTrial ;
                              sch:name "Evaluación Progresiva" ;
                              guide:trialType "Progresiva"@en ;
                              guide:gradePercentage "60%"^^xsd:string ;
                              guide:minScore "4 / 10"^^xsd:string ] .

<http://guia-mad-bench.es/data/eval-system-59TL> rdf:type :EvaluationSystem , <https://schema.org/EvaluationSystem> ;
    guide:hasEvaluationTrial [ a :EvaluationTrial ;
                              sch:name "Examen Final (Ordinaria)" ;
                              guide:trialType "Global"@en ; # Using 'type' property from ontology `guide:evaluationType` or trial type? Ontology has both. I will use specific properties available in snippet like `guide:gradePercentage`.
                              guide:gradePercentage "100%"^^xsd:string ;
                              guide:minScore "5 / 10"^^xsd:string ] .

<http://guia-mad-bench.es/data/eval-system-59TL> rdf:type :EvaluationSystem , <https://schema.org/EvaluationSystem> ;
    guide:hasEvaluationTrial [ a :EvaluationTrial ;
                              sch:name "Convocatoria Extraordinaria" ;
                              guide:trialType "Extraordinaria"@en ;
                              guide:gradePercentage "100%"^^xsd:string ;
                              guide:minScore "5 / 10"^^xsd:string ] .

#################################################################
#  Schedule and Events Entities
#################################################################

<http://guia-mad-bench.es/data/schedule-59TL> rdf:type :Schedule , <https://schema.org/Schedule> ;
    sch:eventSchedule [ a :ScheduleEvent ;
                       guide:activityDurationUnit "01:00"^^xsd:string ; # Using string for duration as per data property `guide:activityDuration` (decimal) but table says 01:00. I will use the specific properties available in ontology like `guide:eventWeek`. The snippet has `om:Unit` range for activityDurationUnit, and `guide:activityDuration` is decimal.
                       guide:itemIndex "Semana 1"^^xsd:string ; # Using string as per data property `guide:eventIndex` (integer) but table uses Sem. I will map to integer index if possible or use description. The snippet has `guide:eventWeek`.
    ] .

