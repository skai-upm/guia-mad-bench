# Course Guide Instance
guide:MatematicaDiscretaII_Guide rdf:type guide:CourseGuide ;
    sch:name "Guía de Aprendizaje - Matemática Discreta II" ;
    guide:teachingPeriod "2025-26" ;
    guide:teachingPeriodMonths "Febrero-Junio" ;
    guide:numberOfCredits 6.0 ;
    guide:inpersonHours "Not specified" ;
    guide:remoteHours "Not specified" ;
    sch:inLanguage "Castellano" ;
    guide:hasSyllabus guide:MatematicaDiscretaII_Syllabus ;
    guide:hasEvaluation guide:MatematicaDiscretaII_EvalSystem ;
    guide:hasCompetency guide:C1, guide:C10, guide:C13, guide:C2, guide:C3, guide:C4, guide:C5 ;
    guide:hasLearningResult guide:RA35, guide:RA19, guide:RA26, guide:RA33, guide:RA31 ;
    sch:instructor guide:M_Del_Carmen_Escribano_Iglesias, guide:Luis_Magdalena_Layos ;
    sch:description "La asignatura Matemática Discreta II complementa la asignatura Matemática Discreta I del primer semestre. En ella se estudia principalmente la Teoría de Grafos..." .

