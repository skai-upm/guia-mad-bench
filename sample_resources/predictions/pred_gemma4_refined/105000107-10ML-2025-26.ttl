# Competencies
guide:C1 rdf:type guide:Competency ; sch:name "C1 - Capacidad de resolución de．．．" .
guide:C10 rdf:type guide:Competency ; sch:name "C10 - Capacidad para usar las tecnologías..." .
guide:C13 rdf:type guide:Competency ; sch:name "C13 - Capacidad de elegir y usar los métodos..." .
guide:C2 rdf:type guide:Competency ; sch:name "C2 - Capacidad para el aprendizaje autónomo..." .
guide:C3 rdf:type guide:Competency ; sch:name "C3 - Saber trabajar en situaciones carentes..." .
guide:C4 rdf:type guide:Competency ; sch:name "C4 - Capacidad de gestión de la información" .
guide:C5 rdf:type guide:Competency ; sch:name "C5 - Capacidad de abstracción, análisis y síntesis" .

# Learning Results
guide:RA35 rdf:type guide:LearningResult ; guide:learningResultCode "RA35" ; guide:learningResultDescription "Utilizar diversas técnicas para la resolución de problemas con ayuda de software matemático" .
guide:RA19 rdf:type guide:LearningResult ; guide:learning．learningResultCode "RA19" ; guide:learningResultDescription "Modelizar matemáticamente problemas reales y conocer las técnicas para resolverlos" .
guide:RA26 rdf:type guide:LearningResult ; guide:learningResultCode "RA26" ; guide:learningResultDescription "Adquirir destreza en la aplicación de los diferentes métodos de demostración" .
guide:RA33 rdf:type guide:LearningResult ; guide:learningResultCode "RA33" ; guide:learningResultDescription "Comprender las nociones de complejidad de un algoritmo y de complejidad de un problema" .
guide:RA31 rdf:type guide:LearningResult ; guide:learningResultCode "RA31" ; guide:learningResultDescription "Conocer, comprender y aplicar los conceptos, técnicas y algoritmos básicos de la teoría de grafos" .

# Syllabus
guide:MatematicaDiscretaII_Syllabus rdf:type guide:Syllabus ;
    guide:hasItem guide:Unit1, guide:Unit2, guide:Unit3, guide:Unit4, guide:Unit5, guide:Unit6, guide:Unit7 .

guide:Unit1 rdf:type guide:SyllabusItem ; guide:itemIndex 1 ; guide:syllabusDescription "Nociones básicas de grafos y digrafos" .
guide:Unit2 rdf:type guide:SyllabusItem ; guide:itemIndex 2 ; guide:syllabusDescription "Árboles: Búsquedas y optimización. Orientabilidad." .
guide:Unit3 rdf:type guide:SyllabusItem ; guide:itemIndex 3 ; guide:syllabusDescription "Distancias y caminos mínimos. Conectividad." .
guide:Unit4 rdf:type guide:SyllabusItem ; guide:itemIndex 4 ; guide:syllabusDescription "Flujos en redes. Emparejamientos. Recubrimientos." .
guide:Unit5 rdf:type guide:SyllabusItem ; guide:itemIndex 5 ; guide:syllabusDescription "Recorridos en grafos" .
guide:Unit6 rdf:type guide:SyllabusItem ; guide:itemIndex 6 ; guide:syllabusDescription "Planaridad. Coloración de grafos." .
guide:Unit7 rdf:type guide:SyllabusItem ; guide:itemIndex 7 ; guide:syllabusDescription "Complejidad de algoritmos" .

# Evaluation System
guide:MatematicaDiscretaII_EvalSystem rdf:type guide:EvaluationSystem ;
    guide:evaluationDescription "Sistema mediante pruebas de evaluación progresiva y prueba de evaluación global." ;
    guide:hasEvaluationTrial guide:Trial_CuestionarioMoodle, guide:Trial_ExamenParcial1, guide:Trial_Trabajo, guide:Trial_ExamenFinal .

guide:Trial_CuestionarioMoodle rdf:type guide:EvaluationTrial ;
    sch:name "Cuestionario Moodle" ;
    guide:evaluationType "Prueba Telemática" ;
    guide:gradePercentage "5%" ;
    guide:trialMode "Presencial" ;
    guide:trialWeek "6" .

guide:Trial_ExamenParcial1 rdf:type guide:EvaluationTrial ;
    sch:name "Primer examen parcial" ;
    guide:evaluationType "Examen Escrito" ;
    guide:gradePercentage "42.5%" ;
    guide:minimumScore "3 / 10" ;
    guide:trialMode "Presencial" ;
    guide:trialWeek "8" .

guide:Trial_Trabajo rdf:type guide:EvaluationTrial ;
    sch:name "Trabajo" ;
    guide:evaluationType "Otras técnicas evaluativas" ;
    guide:gradePercentage "5%" ;
    guide:trialMode "No presencial" ;
    guide:trialWeek "13" .

guide:Trial_ExamenFinal rdf:type guide:EvaluationTrial ;
    sch:name "Examen final" ;
    guide:evaluationType "Examen Escrito" ;
    guide:gradePercentage "85%" ;
    guide:minimumScore "5 / 10" ;
    guide:trialMode "Presencial" ;
    guide:trialWeek "16" .

# Schedule and Activities
guide:MatematicaDiscretaII_Schedule rdf:type guide:Schedule ;
    sch:eventSchedule guide:Event_Week1, guide:Event_Week8 .

guide:Event_Week1 rdf:type guide:ScheduleEvent ;
    guide:eventWeek "1" ;
    guide:hasActivity guide:Act_LeccionMagistral_W1 .

guide:Act_LeccionMagintral_W1 rdf:type guide:Activity ;
    guide:activityDescription "Explicación de contenidos teóricos" ;
    guide:activityDuration 2.0 ;
    guide:activityFormat "Lección Magistral" ;
    guide:attendanceType "Presencial" .

