# Didactic Resources
guide:res_ang_1975 a guide:DidacticResource ;
    guide:bibliographyTitle "ANG A.H.S y TANG W. (1975) Probability concepts in Engineering planning and design. Vol 1. John Wiley and Sons." ;
    guide:bibliographyType "Bibliografía" .

guide:res_atkinson_1978 a guide:DidacticResource ;
    guide:bibliographyTitle "Attkinson, J.H. & Bransby, P.L. (1978): The Mechanics of Soils. An Introduction to Critical State Soil Mechanics?. Mc Graw Hill. London, 375 p." ;
    guide:bibliographyType "Bibliografía" .

guide:res_baecher_2003 a guide:DidacticResource ;
    guide:bibliographyTitle "BAECHER G y CHRISTIAN J. (2003) Reliability and Statistics in Geotechnical Engineering. Wiley." ;
    guide:bibliographyType "Bibliografía" .

guide:res_cundall_1979 a guide:DidacticResource ;
    guide:bibliographyTitle "Cundall PA, Strack ODL. A discrete numerical model for granular assemblies. Geotechnique 1979;29(1):47-65." ;
    guide:bibliographyType "Bibliografía" .

guide:res_lade_2005 a guide:DidacticResource ;
    guide:bibliographyTitle "Lade, P. (2005): Overview of Constitutive Models for Soils. En Soil Constitutive Models. Evaluation, Selection and Calibration. Geotechnical Special Publication No 123. ASCE." ;
    guide:bibliographyType "Bibliografía" .

guide:res_schofield_1969 a guide:DidacticResource ;
    guide:bibliographyTitle "Schofield, A.N. & Wroth, C.P. (196<0xA0>6) Critical State Soil Mechanics. Mc Graw Hill. London." ;
    guide:bibliographyType "Bibliografía" .

guide:res_wong_1974 a guide:DidacticResource ;
    guide:bibliographyTitle "Wong, K. S. & Duncan, J.M. (1974). Hyperbolic stress-strain parameters for nonlinear finite element analyses of stress and movements in soil masses. Report no. TE 74-3. University of California." ;
    guide:bibliographyType "Bibliografía" .