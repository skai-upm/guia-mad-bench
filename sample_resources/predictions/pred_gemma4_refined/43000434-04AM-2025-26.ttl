# Competencies
guide:comp_CB10 a guide:Competency ;
    guide:competencyCode "CB10" ;
    guide:competencyDescription "Que los estudiantes posecan las habilidades de aprendizaje que les permitan continuar estudiando de un modo que habrá de ser en gran medida autodirigido o autónomo." .

guide:comp_CB9 a guide:Competency ;
    guide:competencyCode "CB9" ;
    guide:competencyDescription "Que los estudiantes sepan comunicar sus conclusiones y los conocimientos y razones últimas que las sustentan a públicos especializados y no especializados de un modo claro y sin ambigüedades" .

guide:comp_CE8 a guide:Competency ;
    guide:competencyCode "CE8" ;
    guide:competencyDescription "Capacidad para la participación en actividades de I+D+i mediante la utilización de recursos de modelización predictiva en Fiabilidad de modelos geotécnicos." .

guide:comp_CG1 a guide:Competency ;
    guide:competencyCode "CG1" ;
    guide:competencyDescription "Polivalencia para extender a ámbitos afines las competencias generales adquiridas en el ámbito temático del título." .

guide:comp_CG4 a guide:Competency ;
    guide:competencyCode "CG4" ;
    guide:competencyDescription "Capacidad de comunicación académica de contenido técnico y científico, oral y escrita en lengua inglesa." .

guide:comp_CT1 a guide:Competency ;
    guide:competencyCode "CT1" ;
    guide:competencyDescription "Capacidad de preparar y presentar comunicaciones orales, escritas y gráficas, estructurada y argumentadamente." .

# Learning Results
guide:lr_RA2 a guide:LearningResult ;
    guide:learningResultCode "RA2" ;
    guide:learningResultDescription "Presenta comunicaciones orales, escritas y gráficas, estructurada y argumentadamente, en lengua española e inglesa" .

guide:lr_RA1 a guide:LearningResult ;
    guide:learningResultCode "RA1" ;
    guide:learningResultDescription "Utiliza con eficacia, autonomía y polivalencia recursos de modelización predictiva en la temática de la materia" .

guide:lr_RA3 a guide:LearningResult ;
    guide:learningResultCode "RA3" ;
    guide:learningResultDescription "Interioriza los principios de deontología profesional para actividades de I+D+i" .

guide:lr_RA4 a guide:LearningResult ;
    guide:learningResultCode "RA4" ;
    guide:learningResultDescription "Utiliza con eficacia recursos de información y comunicación" .

