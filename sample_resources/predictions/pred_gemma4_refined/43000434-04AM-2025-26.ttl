guide:item_5 a guide:SyllabusItem ;
    guide:itemIndex 5 ;
    guide:syllabusDescription "Modelos de partículas" .

guide:item_6 a guide:SyllabusItem ;
    guide:itemIndex 6 ;
    guide:syllabusDescription "Análisis de fiabilidad" .

