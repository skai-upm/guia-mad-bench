# Syllabus and Items
:syllabus_93000877 rdf:type guide:Syllabus ;
    guide:hasItem :item_unit1, :item_unit2, :item_unit3, :item_unit4, :item_unit5, :item_unit6, :item_unit7 .

:item_unit1 rdf:type guide:SyllabusItem ;
    guide:itemIndex 1 ;
    guide:syllabusDescription "Introducción: tipos de problemas; aprendizaje automático y aprendizaje estadístico; redes neuronales artificiales." .

:item_unit2 rdf:type guide:SylabusItem ;
    guide:itemIndex 2 ;
    guide:syllabusDescription "Fundamentos matemáticos: dinámica de sistemas; teoría de optimización; inferencia estadística y teoría de regresión (lineal y logística)." .

:item_unit3 rdf:type guide:SyllabusItem ;
    guide:itemIndex 3 ;
    guide:syllabusDescription "Aprendizaje supervisado: regresión y clasificación; modelos neuronales y otros modelos para su implementación." .

:item_unit4 rdf:type guide:SyllabusItem ;
    guide:itemIndex 4 ;
    guide:syllabusDescription "Aprendizaje no supervisado; modelos neuronales para su implementación." .

:item_unit5 rdf:type guide:SyllabusItem ;
    guide:itemIndex 5 ;
    guide:syllabusDescription "Modelos alternativos/avanzados para aprendizaje supervisado y no supervisado: modelos gráficos, máquinas de Boltzmann, arquitecturas profundas, etc." .

:item_unit6 rdf:type guide:SyllabusItem ;
    guide:itemIndex 6 ;
    guide:syllabusDescription "Otros tipos de problemas: aprendizaje en entornos dinámicos, aprendizaje por refuerzo, aprendizaje semisupervisado, inferencia causal, etc." .

:item_unit7 rdf:type guide:SyllabusItem ;
    guide:itemIndex 7 ;
    guide:syllabusDescription "Aplicaciones prácticas: tratamiento de señal, optimización de funciones tipo caja negra, predicción en series temporales, diagnóstico de fallos, control de sistemas y análisis de redes complejas." .

# Competencies
:comp_CE1 rdf:type guide:Competency ; guide:competencyCode "CE1" ; guide:competencyDescription "Adquisición de una formación sólida y rigurosa en temas avanzados de Estadística, Matemática computacional..." .
:comp_CE2 rdf:type guide:Competency ; guide:competencyCode "CE2" ; guide:competencyDescription "Capacidad para planificar la resolución de un problema en función de las herramientas de que se disponga..." .
:comp_CE4 rdf:type guide:Competency ; guide:competencyCode "CE4" ; guide:competencyDescription "Desarrollar habilidades de aprendizaje en Estadística Computacional y Matemáticas..." .
:comp_CE5 rdf:type guide:Competency ; guide:competencyCode "CE5" ; guide:competencyDescription "Resolver problemas y casos reales planteados en el tratamiento estadístico-computacional..." .
:comp_CE6 rdf:type guide:Competency ; guide:competencyCode "CE6" ; guide:competencyDescription "Desarrollar programas que resuellam problemas matemáticos utilizando para cada caso el entorno computacional adecuado." .
:comp_CG1 rdf:type guide:Competency ; guide:competencyCode "CG1" ; guide:competencyDescription "Aprender a aplicar los conocimientos adquiridos y a explotar su potencial..." .
:comp_CG3 rdf:type guide:Competency ; guide:competencyCode "CG3" ; guide:competencyDescription "Integrar los conocimientos adecuados y enfrentarse a la complejidad de emitir juicios..." .
:comp_CG5 rdf:type guide:Competency ; guide:competencyCode "CG5" ; guide:competencyDescription "Comprender y utilizar el lenguaje y las herramientas matemáticas para modelizar y resolver problemas complejos..." .
:comp_CG6 rdf:type guide:Competency ; guide:competencyCode "CG6" ; guide:competencyDescription "Conocer los modelos, métodos y técnicas relevantes en distintas áreas de aplicación..." .

# Learning Results
:lr_RA54 rdf:type guide:LearningResult ; guide:learningResultCode "RA54" ; guide:learningResultDescription "Capacidad para diseñar modelos neuronales que resuelvan problemas de aprendizaje estadístico." .
:lr_RA53 rdf:type guide:LearningResult ; guide:learningResultCode "RA53" ; guide:learningResultDescription "Capacidad para delimitar tipos de problemas de aprendizaje estadístico." .
:lr_RA55 rdf:type guide:LearningResult ; guide:learningResultCode "RA55" ; guide:learningResultDescription "Capacidad para simular los modelos neuronales en plataformas de propósito general (R, Octave)." .
:lr_RA8 rdf:type guide:LearningResult ; guide:learningResultCode "RA8" ; guide:learningResultDescription "Sabrán emplear los métodos y modelos de esta disciplina en su futura actividad investigadora." .
:lr_RA28 rdf:type guide:LearningResult ; guide:learningResultCode "RA28" ; guide:learningResultDescription "Los alumnos conocerán los fundamentos matemáticos necesarios para contextualizar los modelos neuronales..." .

