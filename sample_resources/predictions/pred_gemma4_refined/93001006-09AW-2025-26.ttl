:Schedule_Servicios_Seguridad rdf:type guide:Schedule ;
    sch:eventSchedule :Event_Week1, :Event_Week2, :Event_Week3, :Event_Week4 .

:Event_Week1 rdf:type guide:ScheduleEvent ;
    guide:eventWeek "Semana 1" ;
    guide:eventIndex 1 ;
    guide:hasActivity :Activity_Tema1, :Activity_Tema2, :Activity_Prácticas_W1, :Activity_Tema3 .

:Activity_Tema1 rdf:type guide:Activity ;
    guide:activityDescription "Tema 1" ;
    guide:activityFormat "Lección Magistral" ;
    guide:activityDuration 2.0 ;
    guide:attendanceType "Presencial" .

:Activity_Tema2 rdf:type guide:Activity ;
    guide:activityDescription "Tema 2" ;
    guide:activityFormat "Lección Magistral" ;
    guide:activityDuration 3.0 ;
    guide:attendanceType "Presencial" .

:Activity_Prácticas_W1 rdf:type guide:Activity ;
    guide:activityDescription "Prácticas" ;
    guide:activityFormat "Prácticas de Laboratorio" ;
    guide:activityDuration 3.0 ;
    guide:attendanceType "Presencial" .

# Didactic Resources
:Res_Moodle rdf:type guide:DidacticResource ;
    sch:name "Recursos web Moodle" ;
    guide:bibliographyTitle "Presentaciones, enunciados de prácticas, software y material complementario" ;
