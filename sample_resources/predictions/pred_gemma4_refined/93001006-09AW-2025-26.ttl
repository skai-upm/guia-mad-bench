@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

# Degree and University Center
:Master_Ciberseguridad rdf:type guide:MasterDegree ;
    sch:name "09AW - Master Universitario en Ciberseguridad" .

:ETS_Telecomunicacion rdf:type guide:UniversityCenter ;
    sch:name "E.T.S. de Ingenieros de Telecomunicación" .

:Master_Ciberseguridad guide:hasCourse :Course_Servicios_Seguridad .

# Course and Course Guide
:Course_Servicios_Seguridad rdf:type guide:Course ;
    sch:name "93001006 - Servicios de Seguridad en Red" ;
    sch:courseCode 93001006 ;
    guide:courseYear 2025 ;
    guide:courseType "Obligatoria" ;
    guide:semester "Primer semestre" ;
    sch:hasCourseInstance :Guide_Servicios_Seguridad .

:Guide_Servicios_Seguridad rdf:type guide:CourseGuide ;
    sch:name "93:001006 - Servicios de Seguridad en Red" ;
    sch:description "La asignatura trata sobre los servicios de seguridad que permiten proteger la información en tránsito a través de las redes de comunicaciones." ;
    guide:teachingPeriod "2025-26" ;
    guide:teachingPeriodMonths "Septiembre-Enero" ;
    guide:numberOfCredits 3.0 ;
    sch:inLanguage "Castellano" ;
    guide:hasSyllabus :Syllabus_Servicios_Seguridad ;
    guide:hasCompetency :Comp_CE04, :Comp_CE05, :Comp_CG03 ;
    guide:hasLearningResult :LR_RA10 ;
    guide:hasEvaluation :EvalSystem_Servicios_Seguridad ;
    guide:hasDidacticResource :Res_Moodle ;
    sch:director :Lecturer_Diego_Rivera ;
    sch:instructor :Lectera_Diego_Rivera ;
    guide:totalHours "Estimado según créditos ECTS" ;
    guide:inpersonHours "Según plan de estudios" ;
    guide:remoteHours "Según plan de estudios" .

# Faculty
