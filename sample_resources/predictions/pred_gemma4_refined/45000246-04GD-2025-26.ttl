# Competencies
:comp_E15 rdf:type guide:Competency ;
    guide:competencyCode "30AD. E15" ;
    guide:competencyDescription "Entender el funcionamiento de los mercados financieros nacionales e internacionales." .

:comp_E16 rdf:type guide:Competency ;
    guide:competencyCode "30AD. E16" ;
    guide:competencyDescription "Conocer las principales teorías sobre el comportamiento de la economía tanto a nivel individual como agregado." .

:comp_E17 rdf:type guide:Competency ;
    guide:competencyCode "30AD. E17" ;
    guide:competencyDescription "Comprender las bases que configuran la actual estructura de la economía mundial y española." .

:comp_E18 rdf:type guide:Competency ;
    guide:competencyCode "30AD. E18" ;
    guide:competencyDescription "Conocer la determinación de los principales indicadores y agregados económicos, así como su impacto sobre las decisiones de la empresa." .

:comp_E19 rdf:type guide:Competency ;
    guide:competencyCode "30AD. E19" ;
    guide:competencyDescription "Comprender las variables e indicadores que caracterizan la política macroeconómica de un sector y un entorno geográfico." .

:comp_E20 rdf:type guide:Competency ;
    guide:competencyCode "30AD. E20" ;
    guide:competencyDescription "Comprender el contexto económico, regional, nacional e internacional que rodea a la empresa así como interpretar su impacto en la misma." .

:comp_G01 rdf:type guide:Competency ;
    guide:competencyCode "30AD. G01" ;
    guide:competencyDescription "Que los estudiantes sean capaces de comprender, interpretar, sintetizar y evaluar de forma crítica información proveniente de fuentes diversas..." .

:comp_G06 rdf:type guide:Competency ;
    guide:competencyCode "30AD. G06" ;
    guide:competencyDescription "Que los estudiantes sean capaces de trabajar en equipos multidisciplinares..." .

:comp_G07 rdf:type guide:Competency ;
    guide:competencyCode "30AD. G07" ;
    guide:competencyDescription "Que los estudiantes sean capaces de trabajar en entornos diversos..." .

:comp_G09 rdf:type guide:Competency ;
    guide:competencyCode "30AD. G09" ;
    guide:competencyDescription "Que los estudiantes sean capaces de trabajar en el ámbito de la administración y dirección de empresas aplicando criterios de calidad y sostenibilidad." .

# Learning Results
:lr_RA185 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA185 - RA2" ;
    guide:learningResultDescription "Entender los fundamentos de los intercambios comerciales y del marco monetario que los condiciona..." .

:lr_RA186 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA186 - RA4" ;
    guide:learningResultDescription "Saber utilizar correctamente los conceptos e instrumentos básicos del análisis para su aplicación a la de la realidad económica." .

:lr_RA189 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA189 - RA3" ;
    guide:learningResultDescription "Entender el funcionamiento de la economía española en general así como de sus diversos sectores..." .

:lr_RA184 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA184 - RA1" ;
    guide:learningResultDescription "Entender el funcionamiento de una economía de mercado tanto a nivel microeconómico como macroeconómico." .

:lr_RA188 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA188 - RA6" ;
    guide:learningResultDescription "Poder exponer y comunicar sus ideas y reflexiones tanto de forma oral como escrita." .

:lr_RA187 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA187 - RA5" ;
    guide:learningResultDescription "Conocer y gestionar las fuentes de información económica relevante y su contenido..." .

# Syllabus
:syllabus_45000246 rdf:type guide:Syllabus ;
    guide:hasItem :item_1, :item_2, :item_3, :item_4, :item_5, :item_6, :item_7, :item_8, :item_9, :item_10, :item_11, :item_12 .

