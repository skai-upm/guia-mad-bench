# Competencies
:competency_CB08 rdf:type guide:Competency ;
    guide:competencyCode "CB08" ;
    guide:competencyDescription "Que los estudiantes sean capaces de integrar conocimientos y enfrentarse a la complejidad de formular juicios..." .

:competency_CE_DIPO01 rdf:type guide:Competency ;
    guide:competencyCode "CE-DIPO01" ;
    guide:competencyDescription "Capacidad para conceptualizar, diseñar y desarrollar la interacción persona-ordenador..." .

:competency_CE_DIPO02 rdf:type guide:Competency ;
    guide:competencyCode "CE-DIPO02" ;
    guide:competencyDescription "Capaceidad para evaluar la interacción persona-ordenador de productos y servicios de alto valor innovador" .

:competency_CE_DIPO03 rdf:type guide:Competency ;
    guide:competencyCode "CE-DIPO03" ;
    guide:competencyDescription "Habilidad para hacer conexiones entre los deseos y necesidades del consumidor o cliente..." .

:competency_CE_DIPO04 rdf:type guide:Competency ;
    guide:competencyCode "CE-DIPO04" ;
    guide:competencyDescription "Capacidad para analizar las necesidades de información que se plantean en un entorno..." .

:competency_CG02 rdf:type guide:Competency ;
    guide:competencyCode "CG02" ;
    guide:competencyDescription "Que los estudiantes desarrollen la autonomía suficiente para participar en proyectos de investigación..." .

# Learning Outcomes
:learning_result_RA20 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA20" ;
    guide:learningResultDescription "Evaluate the usability and accessibility of prototypes" .

:learning_result_RA22 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA22" ;
    guide:learningResultDescription "Understand the concept and types of assistive products" .

:learning_result_RA7 rdf:type guide:LearningResult ;
    guide:learning_resultCode "RA7" ;
    guide:learningResultDescription "Understand how to design an interactive system using a user-centred approach" .

:learning_result_RA36 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA36" ;
    guide:learningResultDescription "Understand the diversity of user requirements and the characteristics of accessibility" .

