:trial_test1 rdf:type guide:EvaluationTrial ;
    guide:evaluationType "Written test" ;
    guide:gradePercentage "10%" ;
    guide:minimumScore "10" ;
    guide:trialMode "Not Presential" .

:trial_presentation_persona rdf:type guide:EvaluationTrial ;
    guide:evaluationType "Individual presentation" ;
    guide:gradePercentage "1%" ;
    guide:trialMode "Presential" ;
    guide:involvesCompetency :competency_CB08, :competency_CE_DIPO03 .

:trial_exercise1 rdf:type guide:EvaluationTrial ;
    guide:evaluationType "Group work" ;
    guide:gradePercentage "10%" ;
    guide:trialMode "Not Presential" ;
    guide:involvesCompetency :competency_CE_DIPO02 .

