# Competencies
:comp_CG1 a guide:Competency ;
    guide:competencyCode "CG 1" ;
    guide:competencyDescription "Conocer y aplicar conocimientos de ciencias y tecnologías básicas a la práctica de la Tecnología Minera." .

:comp_CG2 a guide:Competency ;
    guide:competencyCode "CG 2" ;
    guide:competencyDescription "Poseer capacidad para diseñar, analizar, calcular, proyectar, construir, mantener, conservar, explotar, desarrollar, implementar, gestionar y mejorar productos, sistemas y procesos..." .

:comp_CG3 a guide:Competency ;
    guide:competencyCode "CG 3" ;
    guide:competencyDescription "Aplicar los conocimientos adquiridos para identificar, formular y resolver problemas dentro de contextos amplios y multidisciplinarios..." .

:comp_CG4 a guide:Competency ;
    guide:competencyCode "CG 4" ;
    guide:competency .

:comp_CG5 a guide:Competency ;
    guide:competencyCode "CG 5" ;
    guide:competencyDescription "Saber comunicar los conocimientos y conclusiones, tanto de forma oral, escrita y gráfica..." .

:comp_CG6 a guide:Competency ;
    guide:competencyCode "CG 6" ;
    guide:competencyDescription "Poseer habilidades de aprendizaje que permitan continuar estudiando a lo largo de la vida..." .

:comp_CG7 a guide:Competency ;
    guide:competencyCode "CG 7" ;
    guide:competencyDescription "Incorporar nuevas tecnologías y herramientas de la ingeniería en tecnología minera..." .

:comp_CG9 a guide:Competency ;
    guide:competencyCode "CG 9" ;
    guide:competencyDescription "Organización y planificación en el ámbito de la empresa, y otras instituciones y organizaciones de proyectos y equipos humanos." .

# Learning Results
:lr_RA162 a guide:LearningResult ;
    guide:learningResultCode "RA162" ;
    guide:learningResultDescription "Conocer los distintos métodos de explotación de los recursos minerales" .

:lr_RA294 a guide:LearningResult ;
    guide:learningResultCode "RA294" ;
    guide:learningResultDescription "Conocer la naturaleza de la industria minera, su situación actual y el marco de desarrollo." .

:lr_RA297 a guide:LearningResult ;
    guide:learningResultCode "RA297" ;
    guide:learningResultDescription "Adquirir los conocimientos teóricos y práct．icos sobre los criterios, medios y métodos para la explotación de recursos minerales y energéticos." .

