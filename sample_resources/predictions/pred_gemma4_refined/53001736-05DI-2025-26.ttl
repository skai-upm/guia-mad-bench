# Competencies
:comp_muar_cb06 a guide:Competency ;
    guide:competencyCode "MUAR.CB06" ;
    guide:competencyDescription "Poseer y comprender conocimientos que aporten una base u oportunidad de ser originales en el desarrollo y/o aplicación de ideas, a menudo en un contexto de investigación" .

:comp_muar_cb07 a guide:Competency ;
    guide:competencyCode "MUAR.CB07" ;
    guide:competencyDescription "Que los estudiantes sepan aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en entornos nuevos o poco conocidos dentro de contextos más amplios (o multidisciplinares) relacionados con su área de estudio" .

:comp_muar_ce02 a guide:Competency ;
    guide:competencyCode "MUAR.CE02" ;
    guide:competencyDescription "Capacidad para aplicar estrategias avanzadas de control" .

:comp_muar_cg01 a guide:Competency ;
    guide:competencyCode "MUAR.CG01" ;
    guide:competencyDescription "Tener conocimientos adecuados de los aspectos científicos y tecnológicos de la automática y la robótica." .

:comp_muii_a a guide:Competency ;
    guide:competencyCode "MUII. (a)" ;
    guide:competencyDescription "APLICA. Habilidad para aplicar conocimientos científicos, matemáticos y tecnológicos en sistemas relacionados con la práctica de la ingeniería." .

:comp_muii_b a guide:Competency ;
    guide:competencyCode "MUII. (b)" ;
    guide:competencyDescription "EXPERIMENTA. Habilidad para diseñar y realizar experimentos así como analizar e interpretar datos." .

:comp_muii_e a guide:Competency ;
    guide:competencyCode "MUII. (e)" ;
    guide:competencyDescription "RESUELVE. Habilidad para identificar, formular y resolver problemas de ingeniería." .

:comp_muii_k a guide:Competency ;
    guide:competencyCode "MUII. (k)" ;
    guide:competencyDescription "USA HERRAMIENTAS. Habilidad para usar las técnicas, destrezas y herramientas ingenieriles modernas necesarias para la práctica de la ingeniería." .

:comp_muii_cb06 a guide:Competency ;
    guide:competencyCode "MUII.CB06" ;
    guide:competencyDescription "Poseer y comprender conocimientos que aporten una base u oportunidad de ser originales en el desarrollo y/o aplicación de ideas, a menudo en un contexto de investigación" .

:comp_muii_cb07 a guide:Competency ;
    guide:competencyCode "MUII.CB07" ;
    guide:competencyDescription "Que los estudiantes sepan aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en entornos nuevos o poco conocidos dentro de contextos más amplios" .

:comp_muii_ce08 a guide:Competency ;
    guide:competencyCode "MUII.CE08" ;
    guide:competencyDescription "Capacidad para diseñar y proyectar sistemas de producción automatizados y control avanzado de procesos." .

:comp_muii_cg01 a guide:Competency ;
    guide:competencyCode "MUII.CG01" ;
    guide:competencyDescription "Tener conocimientos adecuados de los aspectos científicos y tecnológicos de: métodos matemáticos, analíticos y numéricos en la ingeniería, ingeniería eléctrica, ingeniería energética, ingeniería química, ingeniería mecánica, mecánica de medios continuos, electrónica industrial, automática, fabricación, materiales, métodos cuantitativos de gestión, informática industrial, urbanismo, infraestructuras, etc." .

:comp_muii_cg08 a guide:Competency ;
    guide:competencyCode "MUII.CG08" ;
    guide:competencyDescription "Aplicar los conocimientos adquiridos y resolver problemas en entornos nuevos o poco conocidos dentro de contextos más amplios y multidisciplinares." .

# Learning Results
:lr_ra101 a guide:LearningResult ;
    guide:learningResultCode "RA101" ;
    guide:learningResultDescription "Realización de trabajos prácticos sobre simulación de sistemas" .

:lr_ra102 a guide:LearningResult ;
    guide:learningResultCode "RA102" ;
    guide:learningResultDescription "Modelado y simulación de sistemas de eventos discretos" .

# Evaluation System and Trials
:eval_system_53001736 a guide:EvaluationSystem ;
    guide:evaluationDescription "La asignatura posee una parte en el área de la Automatización y una parte en el área del Control. Evaluación progresiva y global." ;
    guide:hasEvaluationTrial :trial_tarea1, :trial_tarea2, :trial_tarea3, :trial_examen_final .

:trial_tarea1 a guide:EvaluationTrial ;
    sch:name "Tarea 1. Programación de autómatas" ;
    guide:evaluationType "Progresiva" ;
    guide:gradePercentage "30%" ;
    guide:minimumScore "4 / 10" ;
    guide:trialMode "No presencial" ;
    guide:trialWeek "5" .

:trial_tarea2 a guide:EvaluationTrial ;
    sch:name "Tarea 2. Control con realimentación del estado y diseño de observador" ;
    guide:evaluationType "Progresiva" ;
    guide:gradePercentage "10%" ;
    guide:minimumScore "/ 10" ;
    guide:trialMode "No presencial" ;
    guide:trialWeek "11" .

:trial_tarea3 a guide:EvaluationTrial ;
    sch:name "Tarea 3. Control de un sistema mediante un regulador lineal óptimo" ;
    guide:evaluationType "Progresiva" ;
    guide:gradePercentage "10%" ;
    guide:minimumScore "/ 10" ;
    guide:trialMode "No presencial" ;
    guide:trialWeek "14" .

:trial_examen_final a guide:EvaluationTrial ;
    sch:name "Examen final con parte escrita y práctica" ;
    guide:evaluationType "Global" ;
    guide:gradePercentage "50%" ;
    guide:minimumScore "4 / 10" ;
    guide:trialMode "Presencial" ;
    guide:trialWeek "17" .

