    guide:bibliographyType "Bibliografía" .

guide:Res_Reconfigurable_Sys
    rdf:type guide:DidacticResource ;
    sch:name "Reconfigurable System Design and Verification" ;
    guide:bibliographyType "Bibliografía" .

guide:Res_Dynamically_Reconfigurable
    rdf:type guide:DidacticResource ;
