# Competencies
guide:comp_MICCPCE38 a guide:Competency ;
    guide:competencyCode "MICCPCE38" ;
    guide:competencyDescription "Capacidad para integrar y aplicar los conocimientos técnicos en asesoría, análisis, diseño y modelización físico-matemática en ingeniería estructural." .

guide:comp_MICCPCGP11 a guide:Competency ;
    guide:competencyCode "MICCPCGP11" ;
    guide:competencyDescription "Capacidad para el proyecto, ejecución e inspección de estructuras (puentes, edificaciones, etc.), de obras de cimentación y de obras subterráneas de uso civil (túneles, aparcamientos), y el diagnóstico sobre su integridad." .

guide:comp_MICCPCT01 a guide:Competency ;
    guide:competencyCode "MICCPCT01" ;
    guide:competencyDescription "Capacidad de preparar y presentar comunicaciones orales, escritas y gráficas, estructurada y argumentadamente." .

guide:comp_MICCPCT03 a guide:Competency ;
    guide:competencyCode "MICCPCT03" ;
    guide:competencyDescription "Capacidad de comunicación técnica oral y escrita en lengua inglesa." .

guide:comp_MICCPCT08 a guide:Competency ;
    guide:competencyCode "MICPCCT08" ;
    guide:competencyDescription "Capacidad de diseñar, analizar e interpretar experimentos relevantes en ingeniería civil." .

# Learning Results
guide:lr_RA121 a guide:LearningResult ;
    guide:learningResultCode "RA121 - SO1" ;
    guide:learningResultDescription "The student knows the fundamentals and applications of the most relevant transducers for instrumentation of structures." .

guide:lr_RA122 a guide:LearningResult ;
    guide:learningResultCode "RA122" ;
    guide:learningResultDescription "The student acquires the fundamentals of static and dynamic experimental techniques in structural engineering, and understands the structural implications of taken measurements." .

# Syllabus
guide:syllabus_43000554 a guide:Syllabus ;
    guide:hasItem guide:item_intro, guide:item_signal, guide:item_strain, guide:item_load, guide:item_displacement, guide:item_acceleration, guide:item_bridges, guide:item_buildings, guide:item_frequency, guide:item_equipment, guide:item_monitoring, guide:item_modal .

guide:item_intro a guide:SyllabusItem ;
    guide:itemIndex 1 ;
    guide:syllabusDescription "Introduction to instrumentation" .

guide:item_signal a guide:SyllabusItem ;
    guide:itemIndex 2 ;
    guide:syllabusDescription "Signal conditioning" .

guide:item_strain a guide:SyllabusItem ;
    guide:itemIndex 3 ;
    guide:syllabusDescription "Strain measurement" .

guide:item_load a guide:SyllabusItem ;
    guide:itemIndex 4 ;
    guide:syllabusDescription "Load measurement" .

guide:item_displacement a guide:SyllabusItem ;
    guide:itemIndex 5 ;
    guide:syllabusDescription "Displacement measurement" .

guide:item_acceleration a guide:SyllabusItem ;
    guide:itemIndex 6 ;
    guide:syllabusDescription "Acceleration measurement" .

guide:item_bridges a guide:SyllabusItem ;
    guide:itemIndex 7 ;
    guide:syllabusDescription "Load tests in bridges" .

guide:item_buildings a guide:SyllableItem ;
    guide:itemIndex 8 ;
    guide:syllabusDescription "Load tests in buildings" .

# Schedule and Activities
guide:schedule_43000554 a guide:Schedule ;
    sch:eventSchedule guide:event_week1, guide:event_week2, guide:event_week4, guide:event_week17 .

guide:event_week1 a guide:ScheduleEvent ;
    guide:eventWeek "1" ;
    guide:hasActivity guide:act_unit1_lecture .

guide:act_unit1_lecture a guide:Activity ;
    guide:activityDescription "Unit 1 Lecture" ;
    guide:activityDuration 3.0 ;
    guide:activityFormat "Lecture" .

guide:event_week2 a guide:ScheduleEvent ;
    guide:eventWeek "2" ;
    guide:hasActivity guide:act_unit2_lecture, guide:act_unit2_problem .

guide:act_unit2_lecture a guide:Activity ;
    guide:activityDescription "Unit 2 Lecture" ;
    guide:activityDuration 2.0 ;
    guide:activityFormat "Lecture" .

guide:act_unit2_problem a guide:Activity ;
    guide:activityDescription "Unit 2 Problem-solving class" ;
    guide:activityDuration 1.0 ;
    guide:activityFormat "Problem-solving class" .

# Evaluation System
guide:eval_system_43000554 a guide:EvaluationSystem ;
    guide:evaluationDescription "Continuous assessment and final exam." ;
    guide:hasEvaluationTrial guide:trial_tasks, guide:trial_final_exam .

guide:trial_tasks a guide:EvaluationTrial ;
    guide:trialType "Assignment" ;
    guide:evaluationType "Progressive assessment" ;
    guide:gradePercentage "5.7%" ;
    guide:trialMode "Not Presential" ;
    guide:evaluationDescription "Resolution and submission of assigned tasks (exercises and case-studies)." .

guide:trial_final_exam a guide:EvaluationTrial ;
    guide:trialType "Written test" ;
    guide:evaluationType "Final exam" ;
    guide:gradePercentage "60.1%" ;
    guide:trialMode "Face-to-face" ;
    guide:evaluationDescription "Final examination consisting of applied theory and practical exercises." .

