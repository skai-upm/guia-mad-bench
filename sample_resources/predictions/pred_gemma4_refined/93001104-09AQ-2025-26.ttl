# Competencies
guide:comp_CE12 rdf:type guide:Competency ;
    guide:competencyCode "CE12" ;
    guide:competencyDescription "Capacidad para utilizar dispositivos lógicos programables, así como para diseñar sistemas electrónicos avanzados, tanto analógicos como digitales. Capacidad para diseñar componentes de comunicaciones como por ejemplo encaminadores, conmutadores, concentradores, emisores y receptores en diferentes bandas." .

guide:comp_CE15 rdf:type guide:Competency ;
    guide:competencyCode "CE15" ;
    guide:competencyDescription "Capacidad para la integración de tecnologías y sistemas propios de la Ingeniería de Telecomunicación, con carácter generalista, y en contextos más amplios y multidisciplinares como por ejemplo en bioingeniería, conversión fotovoltaica, nanotecnología, telemedicina." .

guide:comp_CG2 rdf:type guide:Competency ;
    guide:competencyCode "CG2" ;
    guide:competencyDescription "Que los estudiantes sepan aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en entornos nuevos o poco conocidos dentro de contextos más amplios (o multidisciplinares) relacionados con su área de estudio." .

# Learning Results
guide:lr_RA116 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA116" ;
    guide:learningResultDescription "Diseñar e implementar aplicaciones reales usando plataformas de diseño basadas en procesadores avanzados" .

guide:lr_RA218 rdf:type guide:LearningResult ;
    guide:learning_resultCode "RA218" ;
    guide:learningResultDescription "Analizar y diseñar el software de un sistema electrónico" .

guide:lr_RA217 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA217" ;
    guide:learningResultDescription "Analizar la fiabilidad de un sistema electrónico y diseñar sistemas en base a restricciones de fiabilidad" .

guide:lr_RA115 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA115" ;
    guide:learningResultDescription "Implementar aplicaciones sobre un Sistema Operativo de tiempo real en sistemas avanzados de procesadores" .

guide:lr_RA327 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA327" ;
    guide:learningResultDescription "Conocimientos cualitativos y cuantitativos del diseño de sistemas electrónicos" .

guide:lr_RA215 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA215" ;
    guide:learningResultDescription "Analizar y diseñar sistemas electrónicos teniendo en cuenta aspectos de compatibilidad electromagnética" .

# Syllabus
guide:syllabus_93001104 rdf:type guide:Syllabus ;
    guide:hasItem guide:item_1, guide:item_2, guide:item_3, guide:item_4, guide:item_5, guide:item_6 .

guide:item_1 rdf:type guide:SyllabusItem ;
    guide:itemIndex 1 ;
    guide:syllabusDescription "Introducción a los sistemas empotrados" .

guide:item_2 rdf:type guide:SyllabusItem ;
    guide:itemIndex 2 ;
    guide:syllabusDescription "Diseño hardware de sistemas empotrados" .

guide:item_3 rdf:type guide:SyllabusItem ;
    guide:itemIndex 3 ;
    guide:syllabusDescription "Diseño software de sistemas empotrados" .

guide:item_4 rdf:type guide:SyllabusItem ;
    guide:itemIndex 4 ;
    guide:syllabusDescription "Sistemas en tiempo real" .

guide:item_5 rdf:type guide:SyllabusItem ;
    guide:itemIndex 5 ;
    guide:syllabusDescription "Entorno de pruebas para sistemas empotrados" .

guide:item_6 rdf:type guide:SyllabusItem ;
    guide:itemIndex 6 ;
    guide:syllabusDescription "Seguridad en Sistemas Empotrados" .

