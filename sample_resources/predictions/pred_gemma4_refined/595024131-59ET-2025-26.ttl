# Course Guide Instance
_:courseGuide a guide:CourseGuide ;
    sch:name "Guía de Aprendizaje - Ingenieria De Audio II" ;
    guide:teachingPeriod "2025-26" ;
    guide:numberOfCredits 6.0 ;
    guide:inpersonHours "Not specified" ;
    guide:remoteHours "Not specified" ;
    guide:totalHours "Not specified" ;
    sch:inLanguage "Castellano" ;
    guide:hasCourse _:course ;
    guide:hasSyllabus _:syllabus ;
    guide:hasCompetency _:compEC01, _:compSO01, _:compSO02, _:compSO05, _:compCG02, _:compCG04 ;
    guide:hasLearningResult _:lrRA165 ;
    guide:hasEvaluation _:evalSystem ;
    guide:hasDidacticResource _:resVideo, _:resManuals ;
    sch:instructor _:lecturerLino, _:lecturerDaniel, _:lecturerMaria ;
    sch:director _:lecturerLino ;
    sch:description "Asignatura destinada al estudio de los equipos que permiten el tratamiento y manipulación de la señal de audio." .

