# Competency Instances
_:compEC01 a guide:Competency ;
    guide:competencyCode "CE EC01" ;
    guide:competencyDescription "Capacidad de construir, explotar y gestionar sistemas de captación, transporte, representación, procesado, almacenamiento, gestión y presentación de información multimedia..." .

_:compSO01 a guide:Competency ;
    guide:competencyCode "CE SO01" ;
    guide:competencyDescription "Capacidad de construir, explotar y gestionar servicios y aplicaciones de telecomunicaciones..." .

_:compSO02 a guide:Competency ;
    guide:competencyCode "CE SO02" ;
    guide:competencyDescription "Capacidad de analizar, especificar, realizar y mantener sistemas, equipos, cabeceras e instalaciones de televisión, audio y vídeo..." .

_:compSO05 a guide:Competency ;
    guide:competencyCode "CE SO05" ;
    guide:competencyDescription "Capacidad para crear, codificar, gestionar, difundir y distribuir contenidos multimedia..." .

_:compCG02 a guide:Competency ;
    guide:competencyCode "CG 02" ;
    guide:competencyDescription "Capacidad de búsqueda y selección de información, de razonamiento crítico y de elaboración y defensa de argumentos dentro del área." .

_:compCG04 a guide:Competency ;
    guide:competencyCode "CG 04" ;
    guide:competencyDescription "Capacidad de abstracción, de análisis y de síntesis y de resolución de problemas." .

# Learning Result Instance
_:lrRA165 a guide:LearningResult ;
    guide:learningResultCode "RA165" ;
    guide:learningResultDescription "Conocimiento de la arquitectura multicapa" .

# Syllabus and Items
_:syllabus a guide:Syllabus ;
    guide:hasItem _:item1, _:item2, _:item3 .

_:item1 a guide:SyllabusItem ;
    guide:itemIndex 1 ;
    guide:syllabusDescription "Estaciones de trabajo con audio digital (DAW)" .

_:item2 a guide:SyllabusItem ;
    guide:itemIndex 2 ;
    guide:syllabusDescription "Diseño de Estudios" .

_:item3 a guide:SyllabusItem ;
    guide:itemIndex 3 ;
    guide:syllabusDescription "Digitalización de la señal de audio" .

# Evaluation System and Trials
_:evalSystem a guide:EvaluationSystem ;
    guide:evaluationDescription "La evaluación de la asignatura es del tipo progresiva: suma de todos los controles de clase donde se incluye el control de laboratorio y el proyecto de diseño." ;
    guide:hasEvaluationTrial _:trialControl1, _:trialControl2, _:trialGlobal .

_:trialControl1 a guide:EvaluationTrial ;
    guide:evaluationType "Prueba Telemática" ;
    guide:gradePercentage "18%" ;
    guide:minimumScore "4 / 10" ;
    guide:trialWeek "4" ;
    guide:trialMode "Presencial" .

_:trialControl2 a guide:EvaluationTrial ;
    guide:evaluationType "Prueba Telemática" ;
    guide:gradePercentage "18%" ;
    guide:minimumScore "4 / 10" ;
    guide:trialWeek "8" ;
    guide:trialMode "Presencial" .

_:trialGlobal a guide:EvaluationTrial ;
    guide:evaluationType "Examen Escrito" ;
    guide:gradePercentage "90%" ;
    guide:minimumScore "5 / 10" ;
    guide:trialWeek "17" ;
    guide:trialMode "Presencial" .

