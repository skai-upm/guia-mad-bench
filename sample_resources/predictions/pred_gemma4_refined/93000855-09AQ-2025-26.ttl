# Competencies
:CE7 a guide:Competency ;
    guide:competencyCode "CE7" ;
    guide:competencyDescription "Capacidad para realizar la planificación, toma de decisiones y empaquet ​etamiento de redes, servicios y aplicaciones considerando la calidad de servicio, los costes directos y de operación..." .

:CG1 a guide:Competency ;
    guide:competencyCode "CG1" ;
    guide:competencyDescription "Poseer y comprender conocimientos que aporten una base u oportunidad de ser originales en el desarrollo y/o aplicación de ideas..." .

:CG3 a guide:Competency ;
    guide:competencyCode "CG3" ;
    guide:competencyDescription "Que los estudiantes sean capaces de integrar conocimientos y enfrentarse a la complejidad de formular juicios..." .

:CT3 a guide:Competency ;
    guide:competencyCode "CT3" ;
    guide:competencyDescription "Capacidad para adoptar soluciones creativas que satisfagan adecuadamente las diferentes necesidades planteadas." .

:CT6 a guide:Competency ;
    guide:competencyCode "CT6" ;
    guide:competencyDescription "Capacidad para emitir juicios sobre implicaciones económicas, administrativas, sociales, éticas y medioambientales..." .

# Learning Results
:RA172 a guide:LearningResult ;
    guide:learningResultCode "RA172" ;
    guide:learningResultDescription "Analizar las finanzas de un operador de telecom, comparativamente con las de una OTT, para conocer EBITDA, rotación activos, ROE, caja, Capex" .

:RA24 a guide:LearningResult ;
    guide:learningResultCode "RA24" ;
    guide:learningResultDescription "Adquisición de conocimientos sobre aspectos complementarios para la gestión de un proyecto de ingeniería: gestión de calidad y riesgos y toma de decisiones." .

:RA33 a guide:LearningResult ;
    guide:learningResultCode "RA33" ;
    guide:learningResultDescription "Capacidad para abordar y desarrollar en grupo casos prácticos de análisis, diseño, dimensionamiento, simulación, pruebas y su gestión técnico-económica..." .

# Syllabus
:AnalisisNgocioTic_Syllabus a guide:Syllabus ;
    guide:hasItem :Tema1, :Tema2, :Tema3 .

:Tema1 a guide:SyllabusItem ;
    guide:itemIndex 1 ;
    guide:syllabusDescription "Valoración de proyectos de inversión" .

:Tema2 a guide:SyllabusItem ;
    guide:itemIndex 2 ;
    guide:syllabusDescription "Valoración de empresas" .

:Tema3 a guide:SyllabusItem ;
    guide:itemIndex 3 ;
    guide:syllabusDescription "El método del Venture Capital para valorar startups" .

