# Competencies
:Comp_CE30 a guide:Competency ;
    guide:competencyCode "CE30" ;
    guide:competencyDescription "Capacidad de planificación, gestión y explotación de infraestructuras relacionadas con la ingeniería civil." .

:Comp_CE33 a guide:Competency ;
    guide:competencyCode "CE33" ;
    guide:competencyDescription "Capacidad para aplicar los conocimientos técnicos en actividades de I+D+i dentro del ámbito de la ingeniería civil." .

:Comp_CE41 a guide:Competency ;
    guide:competencyCode "CE41" ;
    guide:competencyDescription "Capacidad para aplicar los conocimientos técnicos en la evaluación de infraestructuras y sistemas de transporte" .

:Comp_CGP03 a guide:Competency ;
    guide:competencyCode "CGP03" ;
    guide:competencyDescription "Conocimiento, comprensión y capacidad para aplicar la legislación necesaria en el ejercicio de la profesión de Ingeniero de Caminos, Canales y Puertos." .

:Comp_CGP07 a guide:Competency ;
    guide:competencyCode "CGP07" ;
    guide:competencyDescription "Capacidad para planificar, proyectar, inspeccionar y dirigir obras de infraestructuras de transportes terrestres o marítimos." .

:Comp_CT1 a guide:Competency ;
    guide:competencyCode "CT1" ;
    guide:competencyDescription "Capacidad de preparar y presentar comunicaciones orales, escrit． escritas y gráficas, estructurada y argumentadamente." .

# Learning Results
:LR_RA1 a guide:LearningResult ;
    guide:learningResultCode "RA1" ;
    guide:learningResultDescription "Formula y resuelve problemas matemáticos y numéricos avanzados de ingeniería civil..." .

:LR_RA97 a guide:LearningResult ;
    guide:learningResultCode "RA97" ;
    guide:learningResultDescription "Es capaz de diseñar la gestión del tráfico de una red viaria urbana." .

:LR_RA98 a guide:LearningResult ;
    guide:learningResultCode "RA98" ;
    guide:learningResultDescription "Conoce los fundamentos de la gestión de la seguridad de la circulación viaria." .

:LR_RA90 a guide:LearningResult ;
    guide:learningResultCode "RA90" ;
    guide:learningResultDescription "Conoce la legislación aplicable a la circulación viaria, y puede evaluar las repercusiones de dicha legislación sobre la gestión de la misma" .

:LR_RA83 a guide:LearningResult ;
    guide:learningResultCode "RA83" ;
    guide:learningResultDescription "Sabe analizar y exponer (de forma oral, escrita y gráfica) los conocimientos adquiridos en esta asignatura estructurada y argumentadamente." .

:LR_RA89 a guide:LearningResult ;
    guide:learningResultCode "RA89" ;
    guide:learningResultDescription "Conoce, evalúa y aplica modelos avanzados para gestionar la circulación viaria y los problemas derivados de la seguridad vial" .

:LR_RA96 a guide:LearningResult ;
    guide:learningResultCode "RA96" ;
    guide:learningResultDescription "Es capaz de diseñar la gestión del tráfico de una red viaria interurbana." .

# Syllabus
:Syllabus_Gestion_Circulacion a guide:Syllabus ;
    guide:hasItem :SyllabusItem_1, :SyllabusItem_2, :SyllabusItem_3, :SyllabusItem_4, :SlabylusItem_5 .

:SyllabusItem_1 a guide:SyllabusItem ;
    guide:itemIndex 1 ;
    guide:syllabusDescription "Caracterización de la circulación viaria" .

:SyllabusItem_2 a guide:SyllabusItem ;
    guide:itemIndex 2 ;
    guide:syllabusDescription "El accidente de tráfico" .

:SyllabusItem_3 a guide:SyllabusItem ;
    guide:itemIndex 3 ;
    guide:syllabusDescription "Registro, tratamiento estadístico y análisis de accidentes de tráfico" .

:SyllabusItem_4 a guide:SyllabusItem ;
    guide:itemIndex 4 ;
    guide:syllabusDescription "Secuencia de un accidente y herramientas de intervención institucionales" .

:SlabylusItem_5 a guide:SyllabusItem ;
    guide:itemIndex 5 ;
    guide:syllabusDescription "Los retos de la gestión del tráfico en vías urbanas e interurbanas" .

# Evaluation System
:EvalSystem_Gestion_Circulacion a guide:EvaluationSystem ;
    guide:evaluationDescription "Evaluación continua y prueba evaluación global" ;
    guide:hasEvaluationTrial :Trial_Examen_Continuo, :Trial_Examen_Global, :Trial_Examen_Extraordinario .

:Trial_Examen_Continuo a guide:EvaluationTrial ;
    guide:evaluationType "Examen Escrito" ;
    guide:gradePercentage "35%" ;
    guide:trialMode "Presencial" ;
    guide:minimumScore "5 / 10" ;
    guide:trialDescription "Examen formado por varias preguntas de carácter teórico y práctico." .

:Trial_Examen_Global a guide:EvaluationTrial ;
    guide:evaluationType "Examen Escrito" ;
    guide:gradePercentage "100%" ;
    guide:trialMode "Presencial" ;
    guide:minimumScore "5 / 10" .

:Trial_Examen_Extraordinario a guide:EvaluationTrial ;
    guide:evaluationType "Examen Escrito" ;
    guide:gradePercentage "100%" ;
    guide:trialMode "No presencial" ;
    guide:minimumScore "5 / 10" .

