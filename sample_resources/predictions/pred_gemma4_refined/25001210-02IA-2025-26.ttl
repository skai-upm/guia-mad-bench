guide:competency_ce14 rdf:type guide:Competency ;
    guide:competencyCode "CE14"@en ;
    guide:competencyDescription "Conocimiento de los conceptos básicos de Ecología, sus objetivos, metodología y modo de estudiar el biotopo, la biocenosis y sus relaciones."@en .

guide:competency_ce47 rdf:type guide:Competency ;
    guide:competencyCode "CE47"@en ;
    guide:competencyDescription "Capacitar para el análisis y conservación de la biodiversidad y describir los métodos de caracterización de la gestión de recursos biológicos en los agroecosistemas."@en .

guide:competency_cg1 rdf:type guide:Competency ;
    guide:competencyCode "CG1"@en ;
    guide:competencyDescription "Que los estudiantes hayan demostrado pose de conocimientos en un área de estudio..."@en .

guide:learning_result_ra80 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA80"@en ;
    guide:learningResultDescription "Conocimientos sobre el medio físico y los componentes biológicos de los ecosistemas."@en .

guide:learning_result_ra83 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA83"@en ;
    guide:learningResultDescription "Utilizar modelos informáticos en estudio de ecosistemas."@en .

guide:syllabus_ecologia rdf:type guide:Syllabus ;
    guide:hasItem guide:syllabus_item_1, guide:syllabus_item_2, guide:syllabus_item_3, guide:syllabus_item_4, guide:syllabus_item_5, guide:syllabus_item_6, guide:syllabus_item_7, guide:syllabus_item_8, guide:syllabus_item_9, guide:syllabus_item_10, guide:syllabus_item_11, guide:syllabus_item_12, guide:syllabus_item_13, guide:syllabus_item_14, guide:syllabus_item_15, guide:syllabus_item_16 .

guide:syllabus_item_1 rdf:type guide:SyllabusItem ;
    guide:itemIndex 1 ;
    guide:syllabusDescription "Introducción a la Ecología. Definición. Datos históricos. Conceptos básicos utilizados en Ecología."@en .

guide:syllabus_item_2 rdf:type guide:SyllabusItem ;
    guide:itemIndex 2 ;
    guide:syllabusDescription "Los organismos y el medio. Recursos y condiciones del medio físico. Hábitat. Factores ambientales. Clima. Suelo. Homeostasis. Biomas."@en .

