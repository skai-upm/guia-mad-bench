guide:course_guide_ecologia rdf:type guide:CourseGuide ;
    sch:name "Guía de Aprendizaje - Ecología"@en ;
    sch:description "El objetivo de la asignatura de Ecología es que el alumno adquiera el conocimiento de conceptos básicos de Ecología, sus objetivos, metodología y modo de estudiar el biotopo, la biocenosis y sus interrelaciones."@en ;
    guide:teachingPeriod "2025-26"@en ;
    guide:numberOfCredits 6.0 ;
    guide:inpersonHours "No especificado"@en ;
    guide:remoteHours "No especificado"@en ;
    sch:inLanguage "Castellano"@en ;
    guide:hasSyllabus guide:syllabus_ecologia ;
    guide:hasCompetency guide:competency_ce14, guide:competency_ce47, guide:competency_cg1, guide:competency_cg12, guide:competency_cg6, guide:competency_cg7 ;
    guide:hasLearningResult guide:learning_result_ra80, guide:learning_result_ra83, guide:learning_result_ra84, guide:learning_result_ra85, guide:learning_result_ra86, guide:learning_result_ra81, guide:learning_result_ra82 ;
    guide:hasEvaluation guide:evaluation_system_ecologia ;
    guide:hasDidacticResource guide:resource_smith, guide:resource_odum, guide:resource_begon, guide:resource_gotelli, guide:resource_pinol, guide:resource_alstad, guide:resource_molles, guide:resource_lambers ;
    sch:instructor guide:lecturer_santiago, guide:lecturer_daniel .

guide:course_ecologia rdf:type guide:Course ;
    sch:name "25001210 - Ecologia"@en ;
    guide:courseYear 2025 ;
    guide:courseType "Obligatoria"@en ;
    guide:semester "Segundo semestre"@en ;
    sch:hasCourseInstance guide:course_guide_ecologia .

guide:degree_agroambiental rdf:type guide:Degree ;
    sch:name "02IA - Grado En Ingenieria Agroambiental"@en ;
    guide:hasCourse guide:course_ecologia .

guide:center_etsi rdf:type guide:UniversityCenter ;
    sch:name "Etsi Agronómica, Aliment. y Biosistemas"@en ;
    guide:offers guide:degree_agroambiental .

