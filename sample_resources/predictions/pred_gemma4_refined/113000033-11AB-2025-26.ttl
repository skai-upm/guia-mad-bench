# Course Guide
:guide_113000033 a guide:CourseGuide ;
    sch:name "Guía de Aprendizaje - Redaccion Técnica De Inglés Aplicada A La Actividad Fisica Y El Deporte" ;
    guide:teachingPeriod "2025-26" ;
    guide:semester "Primer semestre" ;
    guide:inLanguage "Castellano" ;
    guide:numberOfCredits 3.0 ;
    sch:instructor :lecturer_maria ;
    guide:hasSyllabus :syllabus_113000033 ;
    guide:hasEvaluation :eval_system_113000033 ;
    guide:hasLearningResult :res_RA94, :res_RA91, :res_RA96, :res_RA19, :res_RA95 ;
    guide:hasCompetency :comp_CB10, :comp_CG5, :comp_CG6, :comp_T2, :comp_T3, :comp_T6 ;
    sch:description "This module supports students whose first language is not English over a semester of academic study, and helps them to refine their writing through extensive language input, practice and feedback." .

