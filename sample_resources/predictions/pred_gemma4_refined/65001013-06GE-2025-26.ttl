# Degree and University Center
:Grado_Ingenieria_Geologica rdf:type guide:Degree ;
    sch:name "06GE - Grado En Ingenier ica Geologica" ;
    guide:degreeCode "06GE" ;
    guide:hasCourse :Electrotecnia .

:ETS_Minas_Energia rdf:type guide:UniversityCenter ;
    sch:name "E.T.S. de Ingenieros de Minas y Energía" ;
    guide:offers :Grado_Ingenieria_Geologica .

# Course and Course Guide
:Electrotecnia rdf:type guide:Course ;
    sch:name "65001013 - Electrotecnia" ;
    sch:courseCode 65001013 ;
    guide:courseType "Obligatoria" ;
    guide:semester "Cuarto semestre" ;
    sch:hasCourseInstance :Electrotecnia_Guide .

:Electrotecnia_Guide rdf:type guide:CourseGuide ;
    sch:name "Guía de Aprendizaje - Electrotecnia" ;
    sch:description "Esta asignatura tiene como finalidad proporcionar al alumno los conocimientos básicos sobre instalaciones eléctricas y las herramientas necesarias para su dimensionamiento y cálculo." ;
    guide:numberOfCredits 6.0 ;
    guide:teachingPeriod "2025-26" ;
    guide:periodStartingMonth "Febrero" ;
    guide:periodEndingMonth "Junio" ;
    sch:inLanguage "Castellano" ;
    guide:hasSyllabus :Electrotecnia_Syllabus ;
    guide:hasEvaluation :Electrotecnia_EvalSystem ;
    guide:hasLearningResult :RA74, :RA75, :RA74, :RA76, :RA77, :RA78, :RA79 ;
    guide:hasCompetency :CG1, :CG2, :CG3, :CG6, :CG7, :F17 ;
    guide:hasDidacticResource :Res_FraileMora_2023, :Res_Alexander_Sadiku ;
    sch:director :Eduardo_Conde_Lazaro .

