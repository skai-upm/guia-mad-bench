# Competencies
:CG1 rdf:type guide:Competency ;
    guide:competencyCode "CG1" ;
    guide:competencyDescription "Conocer y aplicar conocimientos de ciencias y tecnologías básicas a la práctica de la Ingeniería Geológica." .

:CG2 rdf:type guide:Competency ;
    guide:competencyCode "CG2" ;
    guide:competencyDescription "Poseer capacidad para diseñar, desarrollar, implementar, gestionar y mejorar productos, sistemas y procesos en los distintos ámbitos geológicos..." .

:CG3 rdf:type guide:Competency ;
    guide:competencyCode "CG3" ;
    guide:competencyDescription "Aplicar los conocimientos adquiridos para identificar, formular y resolver problemas dentro de contextos amplios y multidisciplinarios..." .

:CG6 rdf:type guide:Competency ;
    guide:competencyCode "CG6" ;
    guide:competencyDescription "Poseer habilidades de aprendizaje que permitan continuar estudiando a lo largo de la vida para su adecuado desarrollo profesional." .

:CG7 rdf:type guide:Competency ;
    guide:competencyCode "CG7" ;
    guide:competencyDescription "Incorporar nuevas tecnologías y herramientas de la Ingeniería Geológica en sus actividades profesionales." .

:F17 rdf:type guide:Competency ;
    guide:competencyCode "F17" ;
    guide:competencyDescription "Conocimientos fundamentales sobre el sistema eléctrico de potencia..." .

# Learning Results
:RA74 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA74" ;
    guide:learningResultDescription "Comprender los fundamentos del sistema eléctrico de potencia" .

:RA75 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA75" ;
    guide:learningResultDescription "Plantear las ecuaciones de los sistemas eléctricos y resolverlas en diversos regímenes de funcionamiento" .

:RA76 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA76" ;
    guide:learningResultDescription "Calcular flujos de potencia y energía de circuitos eléctricos en régimen armónico senoidal" .

:RA77 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA77" ;
    guide:learningResultDescription "Comprender el funcionamiento y la aplicación de las máquinas eléctricas: transformadores y motores" .

:RA78 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA78" ;
    guide:learningResultDescription "Seleccionar las características idóneas de máquinas eléctricas y elementos eléctricos (canalizaciones y protecciones) de un circuito" .

:RA79 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA79" ;
    guide:learningResultDescription "Interpretar y utilizar esquemas eléctricos" .

# Syllabus
:Electrotecnia_Syllabus rdf:type guide:Syllabus ;
    guide:hasItem :SyllabusItem_1, :SyllabusItem_2, :SyllabusItem_3, :SyllabusItem_4, :SyllabusItem_5 .

:SyllabusItem_1 rdf:type guide:SyllabusItem ;
    guide:itemIndex 1 ;
    guide:syllabusDescription "Componentes de los circuitos" .

:SyllableItem_2 rdf:type guide:SyllabusItem ;
    guide:itemIndex 2 ;
    guide:syllabusDescription "Circuitos en corriente alterna" .

:SyllabusItem_3 rdf:type guide:SyllabusItem ;
    guide:itemIndex 3 ;
    guide:syllabusDescription "Circuitos trifásicos" .

:SyllabusItem_4 rdf:type guide:SyllabusItem ;
    guide:itemIndex 4 ;
    guide:syllabusDescription "Transformadores" .

:SyllabusItem_5 rdf:type guide:SyllabusItem ;
    guide:itemIndex 5 ;
    guide:syllabusDescription "Generación, transporte y distribución y utilización de la energía eléctrica" .

# Evaluation System
:Electrotecnia_EvalSystem rdf:type guide:EvaluationSystem ;
    guide:evaluationDescription "Evaluación progresiva y global mediante cuestionarios, laboratorio y examen final." ;
    guide:hasEvaluationTrial :Trial_Cuestionario1, :Trial_Cuestionario2, :Trial_Cuestionario3, :Trial_Cuestionario4, :Trial_Laboratorio, :Trial_ExamenFinal .

:Trial_Cuestionario1 rdf:type guide:EvaluationTrial ;
    guide:evaluationType "Examen Escrito" ;
    guide:gradePercentage "7.5%" ;
    guide:trialWeek "Semana 5" ;
    guide:trialMode "No presencial" .

:Trial_Laboratorio rdf:type guide:EvaluationTrial ;
    guide:evaluationType "Examen de Prácticas" ;
    guide:gradePercentage "10%" ;
    guide:trialWeek "Semana 13" ;
    guide:trialMode "Presencial" .

:Trial_ExamenFinal rdf:type guide:EvaluationTrial ;
    guide:evaluationType "Examen Escrito" ;
    guide:gradePercentage "45%" ;
    guide:trialWeek "Semana 17" ;
    guide:trialMode "Presencial" .

