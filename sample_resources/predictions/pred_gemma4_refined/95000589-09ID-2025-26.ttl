# Competencies
guide:comp_CB05 rdf:type guide:Competency ;
    guide:competencyCode "CB05" ;
    guide:competencyDescription "Que los estudiantes hayan desarrollado aquellas habilidades de aprendizaje necesarias para emprender estudios posteriores con un alto grado de autonomía" .

guide:comp_CE10 rdf:type guide:Competency ;
    guide:competencyCode "CE10" ;
    guide:competencyDescription "Que los estudiantes tengan la capacidad de construir sistemas, aplicaciones y servicios telemáticos, interconectados y multiplataforma a partir de su comprensión de la arquitectura web" .

guide:comp_CE17 rdf:type guide:Competency ;
    guide:competencyCode "CE17" ;
    guide:competencyDescription "Que los estudiantes tengan la capacidad de utilizar los fundamentos de la programación, sistemas operativos, bases de datos, tecnología web y las redes y servicios de telecomunicación en proyectos de ingeniería de datos y sistemas" .

guide:comp_CG03 rdf:type guide:Competency ;
    guide:competencyCode "CG03" ;
    guide:competencyDescription "Ser capaz de explicar de forma oral o escrita las soluciones planteadas para la resolución de un problema" .

guide:comp_CG04 rdf:type guide:Competency ;
    guide:competencyCode "CG04" ;
    guide:competencyDescription "Saber identificar y utilizar las herramientas de las Tecnologías de la Información y de las Comunicaciones más adecuadas para plantear y construir soluciones a problemas" .

# Learning Results
guide:lr_RA196 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA196 - RA76" ;
    guide:learningResultDescription "Conocimientos teóricos y habilidades prácticas en tecnologías necesarias para el desarrollo e integración de servicios de telemedicina" .

guide:lr_RA063 rdf:type guide:LearningResult ;
    guide:learning<0xC2> مداDescription "Saber diseñar páginas web estáticas y dinámicas usando HTML, CSS y JavaScript" .

guide:lr_RA062 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA062" ;
    guide:learningResultDescription "Comprender la web y el protocolo HTTP" .

guide:lr_RA061 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA061" ;
    guide:learningResultDescription "Diseñar e implementar una solución completa a un caso de uso" .

guide:lr_RA157 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA157" ;
    guide:learningResultDescription "Conocer y aprender el desarrollo de aplicaciones web para terminales móviles y de escritorio usando tecnologías web" .

# Syllabus
guide:syllabus_95000589 rdf:type guide:Syllabus ;
    guide:hasItem guide:syllabus_item_1, guide:syllabus_item_2, guide:syllabus_item_3, guide:syllabus_item_4, guide:syllabus_item_5, guide:syllabus_item_6 .

