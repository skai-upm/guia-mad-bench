    guide:itemIndex 1 ;
    guide:syllabusDescription "Introducción al diseño de interfaces: Usabilidad" .

guide:syllabus_item_2 rdf:type guide:SyllabusItem ;
    guide:itemIndex 2 ;
    guide:syllabusDescription "Gestión de bases de datos relacionales" .

guide:syllabus_item_3 rdf:type guide:SyllabusItem ;
    guide:itemIndex 3 ;
    guide:syllabusDescription "Introducción al entorno de desarrollo Web" .

guide:syllabus_item_4 rdf:type guide:SyllabusItem ;
    guide:itemIndex 4 ;
    guide:syllabusDescription "Aplicación Web de gestión de usuarios" .

guide:syllabus_item_5 rdf:type guide:SyllabusItem ;
    guide:itemIndex 5 ;
    guide:syllabusDescription "Aplicación Web para profesionales" .

guide:syllabus_item_6 rdf:type guide:SyllabusItem ;
    guide:itemIndex 6 ;
    guide:syllabusDescription "Aplicación Web para pacientes" .

