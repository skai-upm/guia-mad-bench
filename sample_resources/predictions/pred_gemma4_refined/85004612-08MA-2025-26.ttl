guide:comp_CB2 a guide:Competency ;
    guide:competencyCode "CB2" ;
    guide:competencyDescription "Que los estudiantes sepan aplicar sus conocimientos a su trabajo o vocación de una forma profesional..." .

guide:comp_CB5 a guide:Competency ;
    guide:competencyCode "CB5" ;
    guide:competencyDescription "Que los estudiantes hayan desarrollado aquellas habilidades de aprendizaje necesarias para emprender estudios posteriores con un alto grado de autonomía" .

guide:comp_CE13 a guide:Competency ;
    guide:competencyCode "CE13" ;
    guide:competencyDescription "Conocimiento de la mecánica y de los componentes de maquinas" .

guide:comp_CE19 a guide:Competency ;
    guide:competencyCode "CE19" ;
    guide:competencyDescription "Conocimiento de los motores diesel marinos, turbinas de gas y plantas de vapor" .

guide:comp_CE23 a guide:Competency ;
    guide:competencyCode "CE23" ;
    guide:competencyDescription "Conocimiento de los métodos de proyecto de los sistemas de propulsión naval" .

guide:comp_CE7 a guide:Competency ;
    guide:competencyCode "CE7" ;
    guide:competencyDescription "Conocimiento de los conceptos fundamentales de la mecánica de fluidos y de su aplicación..." .

guide:comp_CG3 a guide:Competency ;
    guide:competencyCode "CG3" ;
    guide:competencyDescription "Capacidad para el aprendizaje de nuevos métodos y teorías, y en la versatilidad para adaptarse a nuevas situaciones..." .

guide:lr_RA32 a guide:LearningResult ;
    guide:learningResultCode "RA32" ;
    guide:learningResultDescription "Comprender los conceptos básicos de la Termodinámica y aplicarlos a problemas de interés en ingeniería." .

guide:lr_RA33 a guide:LearningResult ;
    guide:learningResultCode "RA33" ;
    guide:learningResultDescription "Conocer y aplicar los Principios de la Termodinámica a procesos térmicos." .

