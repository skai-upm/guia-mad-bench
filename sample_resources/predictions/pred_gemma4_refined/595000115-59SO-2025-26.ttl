# Competency Instances
guide:Competency_CE_TEL01
    rdf:type guide:Competency ;
    guide:competencyCode "CE TEL01" ;
    guide:competencyDescription "Capacidad para aprender de manera autónoma nuevos conocimientos y técnicas adecuados para la concepción, el desarrollo o la explotación de sistemas y servicios de telecomunicación." .

guide:Competency_CE_TEL06
    rdf:type guide:Competency ;
    guide:competencyCode "CE TEL06" ;
    guide:competencyDescription "Capacidad de concebir, desplegan, organizar y gestionar redes, sistemas, servicios e infraestructuras de telecomunicación..." .

guide:Competency_CE_TEL13
    rdf:type guide:Competency ;
    guide:competencyCode "CE TEL13" ;
    guide:competencyDescription "Conocimiento y utilización de los conceptos de arquitectura de red, protocolos e interfaces de comunicaciones." .

guide:Competency_CE_TEL14
    rdf:type guide:Competency ;
    guide:competencyCode "CE TEL14" ;
    guide:competencyDescription "Capacidad de diferenciar los conceptos de redes de acceso y transporte, redes de conmutación de circuitos y de paquetes..." .

guide:Competency_CE_TEL15
    rdf:type guide:Competency ;
    guide:competencyCode "CE TEL15" ;
    guide:competencyDescription "Conocimiento de los métodos de interconexión de redes y encaminamiento, así como los fundamentos de la planificación..." .

