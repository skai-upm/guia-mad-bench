# Competencies
:comp_10II_CE05 a guide:Competency ;
    guide:competencyCode "10II-CE05" ;
    guide:competencyDescription "Capacidad de diseñar y realizar experimentos apropiados, interpretar los datos y extraer conclusiones." .

:comp_10II_CE07 a guide:Competency ;
    guide:competencyCode "10II-CE07" ;
    guide:competencyDescription "Entender el soporte físico (hardware) de los ordenadores desde el punto de vista del soporte lógico (software)..." .

:comp_10II_CG01_21 a guide:Competency ;
    guide:competencyCode "10II-CG01/21" ;
    guide:competencyDescription "Capacidad de resolución de problemas aplicando conocimientos de matemáticas, ciencias e ingeniería." .

:comp_10II_CG05 a guide:Competency ;
    guide:competencyCode "10II-CG05" ;
    guide:competencyDescription "Capacidad de gestión de la información." .

:comp_10II_CG06 a guide:Competency ;
    guide:competencyCode "10II-CG06" ;
    guide:competencyDescription "Capacidad de abstracción, análisis y síntesis." .

:comp_10II_CE22 a guide:Competency ;
    guide:competencyCode "10II-CE22" ;
    guide:competencyDescription "Capacidad de aplicar sus conocimientos e intuición para diseñar el hardware/software que cumple unos requisitos especificados." .

# Learning Results
:lr_RA103 a guide:LearningResult ;
    guide:learningResultCode "RA103" ;
    guide:learningResultDescription "Utilizar eficientemente los recursos básicos del computador mediante el lenguaje nativo del mismo." .

:lr_RA104 a guide:LearningResult ;
    guide:learningResultCode "RA104" ;
    guide:learningResultDescription "Analizar y evaluar la estructura interna del computador: modos de direccionamiento, sistemas de...” .

