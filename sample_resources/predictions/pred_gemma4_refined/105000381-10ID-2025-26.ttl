:item_topic2 a guide:SyllabusItem ;
    guide:itemIndex 2 ;
    guide:syllabusDescription "Programación en Ensamblador" .

:item_topic3 a guide:SyllabusItem ;
    guide:itemIndex 3 ;
    guide:syllabusDescription "Procesador" .

:item_topic4 a guide:SyllabusItem ;
    guide:itemIndex 4 ;
    guide:syllabusDescription "Aritmética del computador" .

:item_topic5 a guide:SyllabusItem ;
    guide:itemIndex 5 ;
    guide:syllabusDescription "Periféricos" .

# Evaluation System
:evalSystem_105000381 a guide:EvaluationSystem ;
    guide:evaluationDescription "La asignatura consta de dos partes: teoría y proyecto, no liberatorias..." ;
    guide:hasEvaluationTrial :trial_first_partial, :trial_project_exam, :trial_final_theory .

:trial_first_partial a guide:EvaluationTrial ;
    guide:trialType "Examen Escrito" ;
    guide:evaluationType "Progresiva" ;
    guide:gradePercentage "44%" ;
    guide:minimumScore "2 / 10" ;
    guide:trialMode "Presencial" ;
    guide:eventWeek "11" .

:trial_project_exam a guide:EvaluationTrial ;
    guide:trialType "Examen Escrito" ;
    guide:evaluationType "Progresiva y Global" ;
    guide:gradePercentage "20%" ;
    guide:trialMode "Presencial" ;
    guide:eventWeek "17" .

:trial_final_theory a guide:EvaluationTrial ;
    guide:trialType "Examen Escrito" ;
    guide:evaluationType "Global" ;
    guide:gradePercentage "80%" ;
    guide:trialMode "Presencial" ;
    guide:eventWeek "17" .

