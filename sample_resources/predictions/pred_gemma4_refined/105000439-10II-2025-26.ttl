# Course Guide and Course
:course_guide_105000439 a guide:CourseGuide ;
    sch:name "El Arte De Programar" ;
    sch:description "En esta asignatura se estudiaran los algoritmos en más detalle que en las asignaturas obligatorias del grado. Prestaremos especial atención a cómo comparar diferentes algoritmos, midiendo su tiempo de ejecución o consumo de memoria." ;
    guide:numberOfCredits 6.0 ;
    guide:courseType "Optativa" ;
    guide:teachingPeriod "2025-26" ;
    guide:inLanguage "Castellano" ;
    guide:periodStartingMonth "Septiembre" ;
    guide:periodEndingMonth "Enero" ;
    sch:courseSchedule :schedule_105000439 ;
    guide:hasSyllabus :syllabus_105000439 ;
    guide:hasCompetency :comp_cg1_21, :comp_cg2_ce45, :comp_cg3_4, :comp_cg6, :comp_cg7_10_16_17, :comp_ce19_20 ;
    guide:hasLearningResult :lr_ra278 ;
    guide:hasEvaluation :eval_system_progressive, :eval_system_global, :eval_system_extraordinary ;
    guide:hasDidacticResource :res_skiena_manual_1, :res_skschema_manual_2, :res_knuth_vol3, :res_knuth_part1, :res_laaksonen_guide ;
    sch:instructor :lecturer_larsake_fredlund, :lecturer_julio_marino, :lecturer_clara_benac, :lecturer_santiago_tapia ;
    sch:director :lecturer_santiago_tapia .

:course_105000439 a guide:Course ;
    sch:name "105000439 - El Arte De Programar" ;
    sch:courseCode 105000439 ;
    guide:courseYear 2025 ;
    guide:semester "Primer semestre" ;
    guide:courseType "Optativa" ;
    sch:hasCourseInstance :course_guide_105000439 .

