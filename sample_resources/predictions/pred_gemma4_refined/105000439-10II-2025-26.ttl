# Competencies
:comp_cg1_21 a guide:Competency ;
    guide:competencyCode "CG-1/21" ;
    guide:competencyDescription "Capacidad de resolución de</em> problemas aplicando conocimientos de matemáticas, ciencias e ingeniería." .

:comp_cg2_ce45 a guide:Competency ;
    guide:competencyCode "CG-2/CE45" ;
    guide:competencyDescription "Capacidad para el aprendizaje autónomo y la actualización de conocimientos, y reconocimiento de su necesidad en el área de la informática." .

:comp_cg3_4 a guide:Competency ;
    guide:competencyCode "CG-3/4" ;
    guide:competencyDescription "Saber trabajar en situaciones carentes de información y bajo presión, teniendo nuevas ideas, siendo creativo." .

:comp_cg6 a guide:Competency ;
    guide:competencyCode "CG-6" ;
    guide:competencyDescription "Capacidad de abstracción, análisis y síntesis" .

:comp_cg7_10_16_17 a guide:Competency ;
    guide:competencyCode "CG-7:10/16/17" ;
    guide:competencyDescription "Capacidad para trabajar dentro de un equipo, organizando, planificando, tomando decisiones, negociando y resolviendo conflictos, relacionándose, y criticando y haciendo autocrítica" .

:comp_ce19_20 a guide:Competency ;
    guide:competencyCode "Ce 19/20" ;
    guide:competencyDescription "Conocimiento de los tipos apropiados de soluciones, y comprensión de la complejidad de los problemas informáticos y la viabilidad de su solución." .

# Learning Results
:lr_ra278 a guide:LearningResult ;
    guide:learningResultCode "RA278" ;
    guide:learningResultDescription "Desarrollar la solución matemática y algorítmica mas apropiada a un problema informático que requiera un tratamiento especialmente complejo, analizando y exponendo su viabilidad." .

# Syllabus
:syllabus_105000439 a guide:Syllabus ;
    guide:hasItem :item_intro, :item_eficiencia, :item_tecnicas_basicas, :item_tecnicas_diseno .

:item_intro a guide:SyllabusItem ;
    guide:itemIndex 1 ;
    guide:syllabusDescription "Introducción. Presentación de la asignatura. Programación competitiva. Familiarización con el entorno de trabajo. Jueces." .

:item_eficiencia a guide:SyllabusItem ;
    guide:itemIndex 2 ;
    guide:syllabusDescription "Eficiencia y complejidad de algoritmos. Análisis de tiempo de ejecución. Complejidad. Tratabilidad." .

:item_tecnicas_basicas a guide:SyllabusItem ;
    guide:itemIndex 3 ;
    guide:syllabusDescription "Técnicas básicas. Tratamiento de cadenas alfanuméricas (Strings). Estructuras de datos. Algoritmos sobre árboles y otros grafos." .

:item_tecnicas_diseno a guide:SyllabusItem ;
    guide:itemIndex 4 ;
    guide:syllabusDescription "Técnicas de diseño de algoritmos. Divide y vencerás. Algoritmos voraces. Búsqueda combinatoria. Backtracking. Búsica heurística. Programación dinámica." .

# Evaluation Systems and Trials
:eval_system_progressive a guide:EvaluationSystem ;
    guide:evaluationDescription "Evaluación progresiva. La nota se calcula como 0,3 * (Test de Teoría) + 0,7 * (Nota Concursos)." ;
    guide:hasEvaluationTrial :trial_concursos, :trial_ada_byron, :trial_test_teoria .

:eval_system_global a guide:EvaluationSystem ;
    guide:evaluationDescription "Evaluación global. La nota se calcula como 0,3 * (Test de Teoría) + 0,7 * (Nota de Concursos)." ;
    guide:hasEvaluationTrial :trial_recuperacion_concursos, :trial_test_teoria .

:eval_system_extraordinary a guide:EvaluationSystem ;
    guide:evaluationDescription "Evaluación convocatoria extraordinaria." ;
    guide:hasEvaluationTrial :trial_examen_practico_extra, :trial_test_teoria_extra .

:trial_concursos a guide:EvaluationTrial ;
    guide:evaluationType "Progresiva" ;
    guide:gradePercentage "7%" ;
    guide:trialMode "Presencial" ;
    guide:trialDescription "Concursos de Programación. Resolución de problemas prácticos en equipo." .

:trial_ada_byron a guide:EvaluationTrial ;
    guide:evaluationType "Progresiva" ;
    guide:gradePercentage "10%" ;
    guide:trialMode "Presencial" ;
    guide:trialDescription "Fase Local Ada Byron. Actividad docente de la propia asignatura." .

:trial_test_teoria a guide:EvaluationTrial ;
    guide:evaluationType "Progresiva" ;
    guide:gradePercentage "30%" ;
    guide:trialMode "Presencial" ;
    guide:trialDescription "Test teoría. Prueba escrita individual con preguntas tipo test o de respuesta corta." .

:trial_recuperacion_concursos a guide:EvaluationTrial ;
    guide:evaluationType "Global" ;
    guide:gradePercentage "70%" ;
    guide:trialMode "Presencial" ;
    guide:trialDescription "Recuperación concursos. Resolución de problemas similares a los propuestos en la evaluación progresiva." .

:trial_examen_practico_extra a guide:EvaluationTrial ;
    guide:evaluationType "Extraordinaria" ;
    guide:gradePercentage "70%" ;
    guide:trialMode "Presencial" ;
    guide:trialDescription "Examen Práctico. Serie de problemas a resolver equivalentes a los propuestos en la convocatoria ordinaria." .

:trial_test_teoria_extra a guide:EvaluationTrial ;
    guide:evaluationType "Extraordinaria" ;
    guide:gradePercentage "30%" ;
    guide:trialMode "Presencial" ;
    guide:trialDescription "Test Teoría. Análogo a los de la convocatoria ordinaria." .

