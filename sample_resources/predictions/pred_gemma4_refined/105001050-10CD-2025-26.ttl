# Competencies
:Competency_CB04 a guide:Competency ;
    guide:competencyCode "CB04" ;
    guide:competencyDescription "Que los estudiantes puedan transmitir información, ideas, problemas y soluciones a un público tanto especializado como no especializado" .

:Competency_CE01 a guide:Competency ;
    guide:competencyCode "CE01" ;
    guide:competencyDescription "Capacidad para utilizar con destreza los conceptos y métodos matemáticos que subyacen a los problemas de la ciencia de datos y la inteligencia artificial para su modelización y resolución." .

:Competency_CG02 a guide:Competency ;
    guide:competencyCode "CG02" ;
    guide:competencyDescription "Capacidad para organizar y planificar tareas y proyectos, identificando objetivos, prioridades, plazos, recursos y riesgos, and controlando los procesos establecidos." .

:Competency_CG03 a guide:Competency ;
    guide:competencyCode "CG03" ;
    guide:competencyDescription "Capacidad de emprendimiento y de liderazgo para dirigir y gestionar equipos y proyectos, generando confianza y compromiso en el grupo de colaboradores." .

:Competency_CG06 a guide:Competency ;
    guide:competencyCode "CG06" ;
    guide:competencyDescription "Identificar y utilizar las tecnologías de la información y las comunicaciones más adecuadas en el ámbito de la ingeniería." .

# Learning Results
:LearningResult_RA133 a guide:LearningResult ;
    guide:learningResultCode "RA133" ;
    guide:learningResultDescription "Entender la importancia de las ecuaciones diferenciales y su utilidad para modelar fenómenos de la vida real." .

:LearningResult_RA136 a guide:LearningResult ;
    guide:learningResultCode "RA13</sub>RA136" ;
    guide:learningResultDescription "Saber realizar un estudio cualitativo de sistemas diferenciales no lineales." .

:LearningResult_RA134 a guide:LearningResult ;
    guide:learningResultCode "RA134" ;
    guide:learningResultDescription "Modelar matemáticamente problemas reales mediante ecuaciones diferenciales o sistemas diferenciales" .

:LearningResult_RA135 a guide:LearningResult ;
    guide:learningResultCode "RA135" ;
    guide:learningResultDescription "Conocer técnicas para resolver algunos tipos de ecuaciones diferenciales y sistemas diferenciales lineales." .

:LearningResult_RA138 a guide:LearningResult ;
    guide:learningResultCode "RA138" ;
    guide:learningResultDescription "Dominar diferentes métodos numéricos de diferencias finitas y su programación para estudiar problemas de la vida real descritos mediante ecuaciones o sistemas diferenciales." .

# Syllabus
:Syllabus_105001050 a guide:Syllabus ;
    guide:hasItem :SyllabusItem_Topic1, :SyllabusItem_Topic2, :SyllabusItem_Topic3, :SyllabusItem_Topic4 .

:SyllabusItem_Topic1 a guide:SyllabusItem ;
    guide:itemIndex 1 ;
    guide:syllabusDescription "Ecuaciones diferenciales de primer orden." .

:SyllabusItem_Topic2 a guide:SyllabusItem ;
    guide:itemIndex 2 ;
    guide:syllabusDescription "Ecuaciones diferenciales de orden superior." .

:SyllabusItem_Topic3 a guide:SyllabusItem ;
    guide:itemIndex 3 ;
    guide:syllabusDescription "Sistemas diferenciales lineales de primer orden." .

:SyllabusItem_Topic4 a guide:SyllabusItem ;
    guide:itemIndex 4 ;
    guide:syllabusDescription "Sistemas diferenciales no lineales autónomos de primer orden." .

# Evaluation System
:EvaluationSystem_105001050 a guide:EvaluationSystem ;
    guide:evaluationDescription "La evaluación consistirá en la entrega de trabajos (progresiva y global) con una nota mínima de 3.5/10 por cada trabajo y una calificación final mayor o igual a 5/10." ;
    guide:hasEvaluationTrial :EvaluationTrial_Work1, :EvaluationTrial_Work2, :Evaluation．EvaluationTrial_Work3, :EvaluationTrial_Work4 .

:EvaluationTrial_Work1 a guide:EvaluationTrial ;
    guide:trialDescription "Trabajo sobre ecuaciones diferenciales de primer orden, modelización de fenómenos reales y su simulación numérica." ;
    guide:evaluationType "Progresiva" ;
    guide:gradePercentage "25%" ;
    guide:minimumScore "3.5 / 10" ;
    guide:trialMode "No Presencial" ;
    guide:involvesCompetency :Competency_CB04, :Competency_CE01 .

