:CourseGuide_105001050 a guide:CourseGuide ;
    sch:name "Ecuaciones Diferenciales y Modelización de Fenómen" ;
    sch:description "Estudio de fenómenos de la vida real mediante ecuaciones diferenciales ordinarias y sistemas de ecuaciones diferenciales." ;
    guide:numberOfCredits 6.0 ;
    guide:courseType "Optativa" ;
    guide:teachingPeriod "2025-26" ;
    guide:periodStartingMonth "Septiembre" ;
    guide:periodEndingMonth "Enero" ;
