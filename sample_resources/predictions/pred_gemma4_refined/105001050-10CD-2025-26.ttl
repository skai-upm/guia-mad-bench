    guide:hasCompetency :Competency_CB04, :Competency_CE01, :Competency_CG02, :Competency_CG03, :Competency_CG06 ;
    guide:hasLearningResult :LearningResult_RA133, :LearningResult_RA136, :LearningResult_RA134, :LearningResult_RA135, :LearningResult_RA138 ;
    guide:hasSyllabus :Syllabus_105001050 ;
