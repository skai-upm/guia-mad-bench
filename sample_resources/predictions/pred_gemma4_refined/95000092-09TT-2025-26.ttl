_:courseGuide a guide:CourseGuide ;
    sch:name "Ingeniería en Cooperación para el Desarrollo (Icd)" ;
    guide:numberOfCredits 4.5 ;
    guide:teachingPeriod "2025-26" ;
    guide:periodStartingMonth "Febrero" ;
    guide:periodEndingMonth "Junio" ;
    sch:inLanguage "Castellano" ;
    guide:hasSyllabus _:syllabus ;
    guide:hasCompetency _:compCG13, _:compCG2, _:compCG3, _:compCG7 ;
    guide:hasLearningResult _:lrRA357, _:lrRA354, _:lrRA45, _:lrRA355, _:lrRA356 ;
    guide:hasEvaluation _:evalSystem ;
    guide:hasDidacticResource _:res1, _:res2, _:res3, _:res4, _:res5, _:res6, _:res7, _:res8, _:res9 ;
    sch:instructor _:profManuel, _:profSantiago, _:profMaria, _:profLaura ;
    sch:director _:profCarlos ;
    sch:description "La asignatura pretende dar una visión al alumnado de los fundamentos de cooperación para el desarrollo y del papel de la ingeniería en entornos de bajo nivel de desarrollo." .

_:course a guide:Course ;
    sch:name "95000092 - Ingeniería en Cooperación para el Desarrollo (Icd)" ;
    guide:courseYear 3 ;
    guide:semester "Sexto semestre" ;
    guide:courseType "Optativa" ;
    sch:hasCourseInstance _:courseGuide .

