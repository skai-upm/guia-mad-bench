_:compCG13 a guide:Competency ;
    guide:competencyCode "CG13" ;
    guide:competencyDescription "Respeto medioambiental" .

_:compCG2 a guide:Competency ;
    guide:competencyCode "CG2" ;
    guide:competencyDescription "Que los estudiantes sepan aplicar sus conocimientos a su trabajo o vocación de una forma profesional..." .

_:compCG3 a guide:Competency ;
    guide:competencyCode "CG3" ;
    guide:competencyDescription "Que los estudiantes tengan la capacidad de reunir e interpretar datos relevantes..." .

_:compCG7 a guide:Competency ;
    guide:competencyCode "CG7" ;
    guide:competencyDescription "Trabajo en equipo" .

_:lrRA357 a guide:LearningResult ;
    guide:learningResultCode "RA3157" ;
    guide:learningResultDescription "Concreción de los conocimientos en aplicaciones prácticas en los ámbitos de las TIC, y la electrificación rural" .

_:lrRA354 a guide:LearningResult ;
    guide:learningResultCode "RA354" ;
    guide:learningResultDescription "Adquisición de una visión objetiva y amplia de los actuales desequilibrios sociales y medioambientales" .

_:lrRA45 a guide:LearningResult ;
    guide:learningResultCode "RA45" ;
    guide:learningResultDescription "Conocimientos y habilidades de las temáticas científico tecnológicas desarrolladas en las asignaturas ofertadas" .

_:lrRA355 a guide:LearningResult ;
    guide:learningResultCode "RA355" ;
    guide:learningResultDescription "Conocimiento de la estructura y los instrumentos de la cooperación internacional para el desarrollo" .

_:lrRA356 a guide:LearningResult ;
    guide:learningResultCode "RA356" ;
    guide:learningResultDescription "Conocimiento y aplicación de metodologías de planificación e intervención en proyectos de desarrollo con componente tecnológica" .

_:syllabus a guide:Syllabus ;
    guide:hasItem _:item1, _:item2, _:item3, _:item4, _:item5 .

_:item1 a guide:SyllabusItem ;
    guide:itemIndex 1 ;
    guide:syllabusDescription "Tema 1: El mundo en que vivimos" .

_:item2 a guide:SylabusItem ;
    guide:itemIndex 2 ;
    guide:syllabusDescription "Tema 2: Estrategias de la cooperación para el desarrollo" .

_:item3 a guide:SyllabusItem ;
    guide:itemIndex 3 ;
    guide:syllabusDescription "Tema 3: Metodología de proyectos en cooperación" .

_:item4 a guide:SyllabusItem ;
    guide:itemIndex 4 ;
    guide:syllabusDescription "Tema 4: Aplicaciones TIC para el Desarrollo" .

_:item5 a guide:SyllabusItem ;
    guide:itemIndex 5 ;
    guide:syllabusDescription "Tema 5: Aplicaciones de electrificación rural" .

_:evalSystem a guide:EvaluationSystem ;
    guide:evaluationDescription "La evaluación progresiva está basada en la participación activa, análisis de libro, proyecto y examen final." ;
    guide:hasEvaluationTrial _:trialExamFinal, _:trialBookAnalysis, _:trialProject .

_:trialExamFinal a guide:EvaluationTrial ;
    guide:evaluationType "Examen final" ;
    guide:trialType "Examen Escrito" ;
    guide:gradePercentage "25%" ;
    guide:trialMode "Presencial" ;
    guide:evaluationDuration "01:30" .

_:trialBookAnalysis a guide:EvaluationTrial ;
    guide:evaluationType "Análisis de un libro" ;
    guide:gradePercentage "20%" ;
    guide:trialMode "Presencial" .

_:trialProject a guide:EvaluationTrial ;
    guide:evaluationType "Proyecto de cooperación" ;
    guide:gradePercentage "35%" ;
    guide:trialMode "Presencial" .

