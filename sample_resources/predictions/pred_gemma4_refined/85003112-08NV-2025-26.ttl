# Competencies
:competency_CB1 a guide:Competency ;
    guide:competencyCode "CB1" ;
    guide:competencyDescription "Que los estudiantes hayan demostrado poseblen y comprender conocimientos en un área de estudio que parte de la base de la educación secundaria general..." .

:competency_CB5 a guide:Competency ;
    guide:competencyCode "CB5" ;
    guide:competencyDescription "Que los estudiantes hayan desarrollado aquellas habilidades de aprendizaje necesarias para emprender estudios posteriores con un alto grado de autonomía" .

:competency_CE1 a guide:Competency ;
    guide:competencyCode "CE 1" ;
    guide:competencyDescription "Capacidad para la resolución de los problemas matemáticos que puedan plantearse en la ingeniería." .

:competency_CG3 a guide:Competency ;
    guide:competencyCode "CG3" ;
    guide:competencyDescription "Capacidad para el aprendizaje de nuevos métodos y teorías, y en la versatilidad para adaptarse a nuevas situaciones..." .

# Learning Results
:learning_result_RA22 a guide:LearningResult ;
    guide:learningResultCode "RA22" ;
    guide:learningResultDescription "Estudiar la convergencia de sucesiones y series numéricas. Determinar el conjunto de convergencia de una serie de potencias..." .

:learning_result_RA20 a guide:LearningResult ;
    guide:learningResultCode "RA20" ;
    guide:learningResultDescription "Resolver límites de funciones. Analizar la continuidad y derivabilidad. Aproximación polinómica y acotación del error..." .

# Syllabus
:syllabus_calc1 a guide:Syllabus ;
    guide:hasItem :syllabus_item_complex_numbers, :syllabus_item_real_functions, :syllabus_item_integration, :syllabus_item_sequences_series .

:syllabus_item_complex_numbers a guide:SyllabusItem ;
    guide:itemIndex 1 ;
    guide:syllabusDescription "Números complejos: Aritmética, Fórmula de Euler, Representación, Potencias y raíces, Funciones de variable compleja, Logaritmo complejo." .

:syllabus_item_real_functions a guide:SyllabusItem ;
    guide:itemIndex 2 ;
    guide:syllabusDescription "Funciones de variable real. Límites y derivadas: Definición, Propiedades, Continuidad, Derivada, Reglas de derivación, Polinomios de Taylor, Curvatura." .

:syllabus_item_integration a guide:SyllabusItem ;
    guide:itemIndex 3 ;
    guide:syllabusDescription "Integración: Sumas de Riemann, Integral definida, Cálculo de primitivas, Teorema fundamental del cálculo, Técnicas de integración, Integrales impropias." .

:syllabus_item_sequences_series a guide:SyllabusItem ;
    guide:itemIndex 4 ;
    guide:syllabusDescription "Sucesiones y series. Series de potencias: Sucesión de números reales, Límite de una sucesión, Convergencia de series, Criterios de convergencia." .

