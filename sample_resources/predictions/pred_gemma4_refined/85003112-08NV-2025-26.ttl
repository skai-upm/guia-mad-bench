:evaluation_system_calc1 a guide:EvaluationSystem ;
    guide:evaluationDescription "La nota de la evaluación progresiva será la media ponderada de los dos controles... Se realizará un examen final..." ;
    guide:hasEvaluationTrial :trial_control_8, :trial_control_15, :trial_final_17 .

