# Course and Degree Information
:degree_06MM a guide:BachelorDegree ;
    sch:name "Grado En Ingeniería Mineralúrgica Y Metalúrgica De Las Materias Primas" ;
    guide:degreeCode "06MM" .

:university_center_ets a guide:UniversityCenter ;
    sch:name "E.T.S. de Ingenieros de Minas y Energía" ;
    guide:offers :degree_06MM .

:course_laboreo_de_minas a guide:Course ;
    sch:name "65005004 - Laboreo De Minas" ;
    sch:courseCode 65005004 ;
    guide:courseYear 2025 ;
    guide:courseType "Obligatoria" ;
    guide:semester "Quinto semestre" .

:course_guide_laboreo a guide:CourseGuide ;
    sch:hasCourseInstance :course_laboreo_de_minas ;
    sch:name "Guía de Aprendizaje - Laboreo De Minas" ;
    sch:inLanguage "Castellano" ;
    guide:numberOfCredits 4.5 ;
    guide:teachingPeriod "2025-26" ;
    guide:periodStartingMonth "Septiembre" ;
    guide:periodEndingMonth "Enero" ;
    sch:instructor :lecturer_juan_herrera, :lecturer_carlos_lopez, :lecturer_jesus_caceres ;
    guide:hasSyllabus :syllabus_laboreo ;
    guide:hasCompetency :comp_C1, :comp_C14, :comp_C15, :comp_C2, :comp_CON13, :comp_CON2, :comp_CON7, :comp_CON8, :comp_CON9, :comp_HAB10, :comp_HAB11, :comp_HAB5, :comp_HAB7, :comp_HAB8, :comp_HAB9 ;
    guide:hasLearningResult :lr_RA49, :lr_RA17_197, :lr_RA19_199 ;
    guide:hasEvaluation :eval_system_laboreo ;
    guide:hasDidacticResource :res_herrera_2006_1, :res_herrera_2006_2, :res_herrera_2007_1, :res_lab_equip .

