# Competencies
:comp_C1 a guide:Competency ;
    guide:competencyCode "C1" ;
    guide:competencyDescription "Comprender y utilizar los principios de la extracción de materias primas de origen mineral." .

:comp_C14 a guide:Competency ;
    guide:competencyCode "C14" ;
    guide:competencyDescription "Capacidad de trabajar en un entorno bilingüe (inglés-castellano)." .

:comp_CON13 a guide:Competency ;
    guide:competencyCode "CON13" ;
    guide:competencyDescription "Conocer y comprender la metodología, gestión y organización de proyectos." .

# Learning Results
:lr_RA49 a guide:LearningResult ;
    guide:learningResultCode "RA49" ;
    guide:learningResultDescription "Conocer, comprender y utilizar las técnicas de extracción, de transformación y elaboración de la piedra natural." .

:lr_RA17_197 a guide:LearningResult ;
    guide:learningResultCode "RA17-RA197" ;
    guide:learningResultDescription "Relacionar las propiedades de minerales y rocas con su empleo." .

# Syllabus
:syllabus_laboreo a guide:Syllabus ;
    guide:hasItem :item_B1T1, :item_B2T1, :item_B3T1, :item_B4T1, :item_B5T1, :item_B6T1 .

:item_B1T1 a guide:SyllabusItem ;
    guide:itemIndex 1 ;
    guide:syllabusDescription "B1T1. El abastecimiento de materias primas" .

:item_B2T1 a guide:SyllabusItem ;
    guide:itemIndex 2 ;
    guide:syllabusDescription "B2T1. Fundamentos de las técnicas de arranque de rocas" .

# Evaluation System
:eval_system_laboreo a guide:EvaluationSystem ;
    guide:evaluationDescription "La calificación final se expresará en una cifra numérica en una escala entre 0 y 10." ;
    guide:hasEvaluationTrial :trial_eval_blocks_1_2, :trial_eval_block_3, :trial_eval_final .

:trial_eval_blocks_1_2 a guide:EvaluationTrial ;
    guide:evaluationType "Evaluación Progresiva" ;
    guide:gradePercentage "25%" ;
    guide:minimumScore "5 / 10" ;
    guide:trialWeek "7" ;
    guide:hasScheduleEvent :event_eval_1_2 .

:trial_eval_final a guide:EvaluationTrial ;
    guide:evaluationType "Evaluación Global" ;
    guide:gradePercentage "100%" ;
    guide:minimumScore "5 / 10" ;
    guide:trialWeek "17" ;
    guide:hasScheduleEvent :event_eval_final .

# Schedule Events and Activities
:event_eval_1_2 a guide:ScheduleEvent ;
    guide:eventIndex 7 ;
    guide:eventWeek "Semana 7" ;
    guide:hasActivity :act_exam_test .

:event_eval_final a guide:ScheduleEvent ;
    guide:eventIndex 17 ;
    guide:eventWeek "Semana 17" ;
    guide:hasActivity :act_exam_final .

:act_exam_test a guide:Activity ;
    guide:activityDescription "Prueba Telemática" ;
    guide:activityFormat "ET" ;
    guide:attendanceType "Presencial" .

:act_exam_final a guide:Activity ;
    guide:activityDescription "Prueba Telemática" ;
    guide:activityFormat "ET" ;
    guide:attendanceType "Presencial" .

