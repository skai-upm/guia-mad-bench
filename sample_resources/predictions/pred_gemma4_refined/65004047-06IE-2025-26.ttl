# Evaluation System and Trials
ex:EvalSystem_65004047 rdf:type guide:EvaluationSystem ;
    guide:evaluationDescription "Existen dos opciones: evaluación progresiva, o evaluación global." ;
    guide:hasEvaluationTrial ex:Trial_PEP1, ex:Trial_PEP2, ex:Trial_Final .

ex:Trial_PEP1 rdf:type guide:EvaluationTrial ;
    guide:trialType "Prueba de evaluación progresiva 1" ;
    guide:evaluationType "Evaluación Progresiva" ;
    guide:gradePercentage "50%" ;
    guide:minimumScore "4 / 10" ;
    guide:trialWeek "7" ;
    guide:trialMode "Presencial" .

ex:Trial_PEP2 rdf:type guide:EvaluationTrial ;
    guide:trialType "Prueba de evaluación progresiva 2" ;
    guide:evaluationType "Evaluación Progresiva" ;
    guide:gradePercentage "50%" ;
    guide:minimumScore "4 / 10" ;
    guide:trialWeek "17" ;
    guide:trialMode "Presencial" .

ex:Trial_Final rdf:type guide:EvaluationTrial ;
    guide:trialType "Examen final" ;
    guide:evaluationType "Evaluación Global" ;
    guide:gradePercentage "100%" ;
    guide:minimumScore "5 / 10" ;
    guide:trialWeek "17" ;
    guide:trialMode "Presencial" .

