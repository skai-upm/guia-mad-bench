# Competencies
:comp_CB7 a guide:Competency ;
    guide:competencyCode "CB7" ;
    guide:competencyDescription "Que los estudiantes sepan aplicar los conocimientos adquirimos y su capacidad de resolución de problemas en entornos nuevos o poco conocidos dentro de contextos más amplios (o multidisciplinares) relacionados con su área de estudio" .

:comp_CE1 a guide:Competency ;
    guide:competencyCode "CE1" ;
    guide:competencyDescription "Conocer los fundamentos de la Limnología" .

:comp_CG3 a guide:Competency ;
    guide:competencyCode "CG3" ;
    guide:competencyDescription "Capacidad para participar en proyectos de investigación, desarrollo e innovación vinculados con el uso sostenible de los recursos hídricos" .

:comp_CT6 a guide:Competency ;
    guide:competencyCode "CT6" ;
    guide:competencyDescription "Liderar equipos de trabajo de diversa índole, con actitud proactiva y motivadora, comunicando con claridad los objetivos y las tareas de cada componente del equipo." .

# Learning Results
:lr_RA57 a guide:LearningResult ;
    guide:learningResultCode "RA57" ;
    guide:learningResultDescription "Desarrollo de un trabajo original en el ámbito del uso y gestión del agua en el medio natural." .

# Syllabus
:syllabus_133000050 a guide:Syllabus ;
    guide:hasItem :item_topic1, :item_topic2, :item_topic3, :item_topic4, :item_topic5, :item_topic6, :item_topic7 .

:item_topic1 a guide:SyllabusItem ;
    guide:itemIndex 1 ;
    guide:syllabusDescription "Conceptos y fundamentos del Ocio, Tiempo Libre y la Recreación Deportiva" .

:item_topic2 a guide:SyllabusItem ;
    guide:itemIndex 2 ;
    guide:syllabusDescription "Demanda de actividades físicas y deportivas en el tiempo libre y de ocio" .

:item_topic3 a guide:SyllabusItem ;
    guide:itemIndex 3 ;
    guide:syllabusDescription "Dimensiones y manifestaciones actuales del ocio" .

:item_topic4 a guide:SyllabusItem ;
    guide:itemIndex 4 ;
    guide:syllabusDescription "Actividades deportivas y recreativas fluviales. Clasificación." .

:item_topic5 a guide:SyllabusItem ;
    guide:itemIndex 5 ;
    guide:syllabusDescription "Diseño de programas de actividades acuáticas en la naturaleza" .

:item_topic6 a guide:SyllabusItem ;
    guide:itemIndex 6 ;
    guide:syllabusDescription "Experiencia práctica de piragüismo. Maniobras básicas de paleo para el descenso de aguas bravas" .

:item_topic7 a guide:SyllabusItem ;
    guide:itemIndex 7 ;
    guide:syllabusDescription "Gestión del riesgo en actividades fluviales y barrancos" .

