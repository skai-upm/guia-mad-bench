# Competencies
guide:comp_MUII_l rdf:type guide:Competency ;
    guide:competencyCode "MUII.(l)" ;
    guide:competencyDescription "Capacidad de trabajar en un entorno bilingüe (inglés/castellano)." .

guide:comp_MUAR_CB06 rdf:type guide:Competency ;
    guide:competencyCode "MUAR.CB06" ;
    guide:competencyDescription "Poseer y comprender conocimientos que aportament una base u oportunidad de ser originales en el desarrollo y/o aplicación de ideas." .

guide:comp_MUAR_CB07 rdf:type guide:Competency ;
    guide:competencyCode "MUAR.CB07" ;
    guide:competencyDescription "Que los estudiantes sepan aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en entornos nuevos o poco conocidos." .

# Learning Results
guide:lr_RA87 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA87" ;
    guide:learningResultDescription "Aplicar distintas herramientas y metodologías para el diseño y puesta en práctica de estrategias y políticas de innovación en contextos competitivos." .

guide:lr_RA88 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA88" ;
    guide:learningResultDescription "Distinguir y enumerar las fases características de la dinámica de los procesos innovadores." .

