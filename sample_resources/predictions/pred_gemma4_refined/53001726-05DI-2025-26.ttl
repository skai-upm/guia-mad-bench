# Evaluation System
guide:eval_system_53:001726 rdf:type guide:EvaluationSystem ;
    guide:evaluationDescription "La asignatura se evaluará de acuerdo a los siguientes criterios: Calificación de la presentación del resultado del Taller de Innovación: 60%; Calificación de las entregas intermedias del Taller de Innovación: 20%; Calificación de los cuestionarios de autocomprobación: 15%" ;
    guide:hasEvaluationTrial guide:trial_entrega_intermedia, guide:trial_cuestionarios, guide:trial_prueba_global .

guide:trial_entrega_intermedia rdf:type guide:EvaluationTrial ;
    guide:trialType "Entrega intermedia del Taller de Innovación" ;
    guide:gradePercentage "5%" ;
    guide:minimumScore "5 / 10" ;
    guide:evaluationDuration "00:30" ;
    guide:trialMode "No Presencial" .

guide:trial_cuestionarios rdf:type guide:EvaluationTrial ;
    guide:trialType "Cuestionarios de autocomprobación y participación en foros" ;
    guide:gradePercentage "2.5%" ;
    guide:minimumScore "5 / 10" ;
    guide:evaluationDuration "00:30" ;
    guide:trialMode "No Presencial" .

guide:trial_prueba_global rdf:type guide:EvaluationTrial ;
    guide:trialType "PRUEBA GLOBAL" ;
    guide:gradePercentage "100%" ;
    guide:minimumScore "5 / 10" ;
    guide:evaluationDuration "03:00" ;
    guide:trialMode "Presencial" .

