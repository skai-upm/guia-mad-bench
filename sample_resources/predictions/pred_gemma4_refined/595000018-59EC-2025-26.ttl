    guide:gradePercentage "25%" ;
    guide:minimumScore "3 / 10" ;
    guide:trialMode "Presencial" ;
    guide:evaluationDuration "00:20" ;
    guide:involvesCompetency :Competency_CG_02, :Competency_CG_14 .

:Trial_Tema3
    rdf:type guide:EvaluationTrial ;
    guide:trialType "Presentación en Grupo" ;
    guide:trialDescription "Evaluación contenidos Tema 3" ;
    guide:gradePercentage "25%" ;
    guide:minimumScore "3 / 10" ;
    guide:trialMode "Presencial" ;
    guide:evaluationDuration "01:40" ;
    guide:involvesCompetency :Competency_CG_02, :Competency_CG_03, :Competency_CG_05, :Competency_CG_06, :Competency_CG_09, :Competency_CG_11, :Competency_CG_14 .

:Trial_TrabajoFin
    rdf:type guide:EvaluationTrial ;
    guide:trialType "Trabajo en Grupo" ;
    guide:trialDescription "Presentación del trabajo fin de curso 'Cambiar tu entorno para cambiar el mundo'" ;
    guide:gradePercentage "25%" ;
