    guide:trialMode "Presencial" ;
    guide:evaluationDuration "02:00" ;
    guide:involvesCompetency :Competency_CG_02, :Competency_CG_03, :Competency_CG_05, :Competency_CE_TEL16, :Competency_CG_06, :Competency_CG_09, :Competency_CG_11, :Competency_CG_14 .

