# Competencies
:Competency_CE_TEL16
    rdf:type guide:Competency ;
    guide:competencyCode "CE TEL16" ;
    guide:competencyDescription "Conocimiento de la normativa y la regulación de las telecomunicaciones en los ámbitos nacional, europeo e internacional." .

:Competency_CG_02
    rdf:type guide:Competency ;
    guide:competencyCode "CG 02" ;
    guide:competencyDescription "Capacidad de búsqueda y selección de información, de razonamiento crítico y de elaboración y defensa de argumentos dentro del área." .

:Competency_CG_03
    rdf:type guide:Competency ;
    guide:competencyCode "CG 03" ;
    guide:competencyDescription "Capacidad para expresarse correctamente de forma oral y escrita y transmitir información mediante documentos y exposiciones en público." .

:Competency_CG_05
    rdf:type guide:Competency ;
    guide:competencyCode "CG 05" ;
    guide:competencyDescription "Capacidad de trabajo en equipo y en entornos multidisciplinares." .

:Competency_CG_06
    rdf:type guide:Competency ;
    guide:competencyCode "CG 06" ;
    guide:competencyDescription "Capacidad de adaptación, negociación, resolución de conflictos y de liderazgo." .

:Competency_CG_09
    rdf:type guide:Competency ;
    guide:competencyCode "CG 09" ;
    guide:competencyDescription "Capacidad de analizar y valorar el impacto social y medioambiental de las soluciones técnicas." .

:Competency_CG_11
    rdf:type guide:Competency ;
    guide:competencyCode "CG 11" ;
    guide:competencyDescription "Habilidades para la utilización de las Tecnologías de la Información y las Comunicaciones." .

:Competency_CG_14
    rdf:type guide:Competency ;
    guide:competencyCode "CG 14" ;
    guide:competencyDescription "Actitudes de ética y responsabilidad profesional, respeto a los Derechos Humanos y a la diversidad cultural." .

# Learning Results
:LearningResult_RA195
    rdf:type guide:LearningResult ;
    guide:learningResultCode "RA195" ;
    guide:learningResultDescription "Podrá contrastar las ideas aportadas por diferentes fuentes" .

:LearningResult_RA197
    rdf:type guide:LearningResult ;
    guide:learningResultCode "RA197" ;
    guide:learningResultDescription "Podrá relacionar los aspectos científico-tecnológicos con un entorno social de creciente complejidad: aspectos sociales, económicos, políticos, jurídicos, éticos y medioambientales." .

:LearningResult_RA194
    rdf:type guide:LearningResult ;
    guide:learningResultCode "RA194" ;
    guide:learningResultDescription "Podrá procesar la información de diferentes fuentes y sintetizarla adecuadamente" .

:LearningResult_RA196
    rdf:type guide:LearningResult ;
    guide:learningResultCode "RA196" ;
    guide:learningResultDescription "Podrá hacer una valoración sobre el rigor de la fuente de procedencia de la información" .

:LearningResult_RA192
    rdf:type guide:LearningResult ;
    guide:learningResultCode "RA192" ;
    guide:learningResultDescription "Podrá localizar con acierto la información requerida" .

:LearningResult_RA193
    rdf:type guide:LearningResult ;
    guide:learningResultCode "RA193" ;
    guide:learningResultDescription "Podrá analizar la información encontrada y descartar la irrelevante." .

