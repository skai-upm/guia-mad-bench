# Evaluation System and Trials
:EvaluationSystem_595000018
    rdf:type guide:EvaluationSystem ;
    guide:evaluationDescription "La evaluación progresiva libera cada tema a partir de una nota de 3 sobre 10. Se aprueba la asignatura por evaluación progresiva si se tiene más de un 3 en los tres temas y la media ponderada de todas las notas da un 5 o más." ;
    guide:hasEvaluationTrial :Trial_Tema1, :Trial_Tema2, :Trial_Tema3, :Trial_TrabajoFin, :Trial_ExamenFinal .

:Trial_Tema1
    rdf:type guide:EvaluationTrial ;
    guide:trialType "Examen Escrito" ;
    guide:trialDescription "Evaluación contenidos Tema 1" ;
    guide:gradePercentage "25%" ;
    guide:minimumScore "3 / 10" ;
    guide:trialMode "Presencial" ;
    guide:evaluationDuration "01:00" ;
    guide:involvesCompetency :Competency_CG_02, :Competency_CG_03, :Competency_CE_TEL16, :Competency_CG_09 .

:Trial_Tema2
    rdf:type guide:EvaluationTrial ;
