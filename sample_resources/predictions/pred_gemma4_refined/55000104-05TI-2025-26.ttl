    guide:degreeCode "05TI" .

:ETS_Ingenieros_Industriales rdf:type guide:UniversityCenter ;
    sch:name "E.T.S. De Ingenieros Industriales" ;
    guide:offers :Grado_Ingenieria_Tecnologias_Industriales .

# Course
:Electronica_Digital rdf:type guide:Course ;
    sch:name "55000104 - Electronica Digital" ;
    sch:courseCode 55000104 ;
    guide:courseType "Optativa" ;
    guide:semester "Séptimo semestre" .

# Course Guide
:Electronica_Digital_Guide rdf:type guide:CourseGuide ;
    sch:name "Guía de Aprendizaje - Electronica Digital" ;
    sch:hasCourseInstance :Electronica_Digital ;
    guide:numberOfCredits 3.0 ;
    guide:teachingPeriod "2025-26" ;
    guide:periodStartingMonth "Septiembre" ;
    guide:periodEndingMonth "Enero" ;
    sch:inLanguage "Castellano" ;
    guide:hasSyllabus :Syllabus_Electronica_Digital ;
    guide:hasCompetency :CE21A, :CE24A, :CG1, :CG10, :CG2, :CG3, :CG5, :CG6, :CG7, :CG9 ;
    guide:hasLearningResult :RA8, :RA9 ;
    guide:hasEvaluation :EvalSystem_Electronica_Digital ;
