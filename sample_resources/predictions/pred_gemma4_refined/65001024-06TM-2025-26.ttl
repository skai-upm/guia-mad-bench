# Competencies
_:compCG1 rdf:type guide:Competency ;
    guide:competencyCode "CG 1" ;
    guide:competencyDescription "Conocer y aplicar conocimientos de ciencias y tecnologías básicas a la práctica de la Tecnología Minera." .

_:compCG2 rdf:type guide:Competency ;
    guide:competencyCode "CG 2" ;
    guide:competencyDescription "Poseer capacidad para diseñar, analizar, calcular, proyectar, construir, mantener, conservar, explotar, desarrollar, implementar, gestionar y mejorar productos, sistemas y procesos..." .

_:compCG9 rdf:type guide:Competency ;
    guide:competencyCode "CG 9" ;
    guide:competencyDescription "Organización y planificación en el ámbito de la empresa, y otras instituciones y organizaciones de proyectos y equipos humanos." .

_:compF13 rdf:type guide:Competency ;
    guide:competencyCode "F13" ;
    guide:competencyDescription "Conocimiento de resistencia de materiales y teoría de estructuras" .

_:compF14 rdf:type guide:Competency ;
    guide:competencyCode "F14" ;
    guide:competencyDescription "Conocimiento de topografía, fotogrametría y cartografía" .

_:compF19 rdf:type guide:Competency ;
    guide:competencyCode "F19" ;
    guide:competencyDescription "Capacidad de planificación y gestión integral de obras, mediciones, replanteos, control y seguimiento." .

_:compF20 rdf:type guide:Competency ;
    guide:competencyCode "F20" ;
    guide:competencyDescription "Conocimiento de procedimientos de construcción" .

_:compF30 rdf:type guide:Competency ;
    guide:competencyCode "F30" ;
    guide:competencyDescription "Técnicas de perforación y sostenimiento aplicadas a obras subterráneas y superficiales." .

# Learning Results
_:lrRA122 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA122" ;
    guide:learningResultDescription "Conocer y utilizar los aspectos básicos de la normativa de edificación, tanto española como europea." .

_:lrRA123 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA123" ;
    guide:learningResultDescription "Calcular y comprobar diferentes elementos constructivos de las estructuras metálicas." .

_:lrRA121 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA121" ;
    guide:learningResultDescription "Aplicar los fundamentos del cálculo matricial de estructuras." .

_:lrRA111 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA111" ;
    guide:learningResultDescription "Conocimiento de resistencia de materiales y cálculo de estructuras" .

_:lrRA124 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA124" ;
    guide:learningResultDescription "Calcular y comprobar diferentes elementos constructivos de las estructuras de hormigón armado (H.A.)." .

_:lrRA125 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA125" ;
    guide:learningResultDescription "Conocimiento de los procedimientos de construcción." .

_:lrRA126 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA126" ;
    guide:learningResultDescription "Capacidad para replantear y medir sobre el terreno, con precisión y rigor..." .

_:lrRA120 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA120" ;
    guide:learningResultDescription "Aplicar las herramientas para el cálculo de estructuras." .

# Evaluation System and Trials
_:evalSystem rdf:type guide:EvaluationSystem ;
    guide:evaluationDescription "Sistema de evaluación continua y examen final." ;
    guide:hasEvaluationTrial _:trial1, _:trial2, _:trial $\text{trial3}$ .

_:trial1 rdf:type guide:EvaluationTrial ;
    guide:evaluationType "Progresiva" ;
    guide:gradePercentage "50%" ;
    guide:minimumScore "4 / 10" ;
    guide:trialType "Examen Escrito" ;
    guide:hasScheduleEvent _:event8 .

_:trial2 rdf:type guide:EvaluationTrial ;
    guide:evaluationType "Progresiva" ;
    guide:gradePercentage "50%" ;
    guide:minimumScore "4 / 10" ;
    guide:trialType "Examen Escrito" ;
    guide:hasScheduleEvent _:event15 .

_:trial3 rdf:type guide:EvaluationTrial ;
    guide:evaluationType "Global" ;
    guide:gradePercentage "100%" ;
    guide:minimumScore "5 / 10" ;
    guide:trialType "Examen Escrito" ;
    guide:hasScheduleEvent _:event17 .

