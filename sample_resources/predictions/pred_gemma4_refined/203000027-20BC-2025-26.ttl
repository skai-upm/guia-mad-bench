# Syllabus
:syllabus_203000027 a guide:Syllabus ;
    guide:hasItem :item_1, :item_2, :item_3, :item_4, :item_5, :item_6, :item_7 .

:item_1 a guide:SyllabusItem ;
    guide:itemIndex 1 ;
    guide:syllabusDescription "Mechanisms of evolution: mutation" .

:item_2 a guide:SyllabusItem ;
    guide:itemIndex 2 ;
    guide:syllabusDescription "Natural selection" .

:item_3 a guide:SyllabusItem ;
    guide:itemIndex 3 ;
    guide:syllabusDescription "Evolution in finite populations: genetic drift" .

:item_4 a guide:SyllabusItem ;
    guide:itemIndex 4 ;
    guide:syllabusDescription "Genetic variability in natural populations" .

:item_5 a guide:SyllabusItem ;
    guide:itemIndex 5 ;
    guide:syllabusDescription "Sex and recombination" .

:item_6 a guide:SyllabusItem ;
    guide:itemIndex 6 ;
    guide:syllabusDescription "Coevolution" .

:item_7 a guide:SyllabusItem ;
    guide:itemIndex 7 ;
    guide:syllabusDescription "Long-term evolution and macroevolution" .

# Evaluation System and Trials
:eval_system_203000027 a guide:EvaluationSystem ;
    guide:evaluationDescription "Progressive evaluation and Global evaluation based on individual works/manuscripts." ;
    guide:hasEvaluationTrial :trial_week4, :trial_week8, :trial_week12, :trial_week15, :trial_week17 .

:trial_week4 a guide:EvaluationTrial ;
    guide:trialType "Problem-solving test" ;
    guide:trialDescription "Problems: Estimation of selection coefficients through the use of fitness measures" ;
    guide:gradePercentage "25%" ;
    guide:minimumScore "5 / 10" ;
    guide:trialMode "Not Presential" ;
    guide:hasScheduleEvent :event_week4 .

:trial_week8 a guide:EvaluationTrial ;
    guide:trialType "Practical work" ;
    guide:trialDescription "Practical work: Nucleotide sequence alignment analysis" ;
    guide:gradePercentage "25%" ;
    guide:minimumScore "5 / 10" ;
    guide:trialMode "Not Presential" ;
    guide:hasScheduleEvent :event_week8 .

:trial_week17 a guide:EvaluationTrial ;
    guide:trialType "Global examination" ;
    guide:trialDescription "Examination with genetic and phenotypic data" ;
    guide:gradePercentage "100%" ;
    guide:minimumScore "5 / 10" ;
    guide:trialMode "Not Presential" ;
    guide:hasScheduleEvent :event_week17 .

