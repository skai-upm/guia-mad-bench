# Course Guide Instance
:course_guide_145005302 a guide:CourseGuide ;
    sch:name "Guía de Aprendizaje - Instalaciones Eléctricas" ;
    sch:description "En esta asignatura se estudia la configuración y el funcionamiento de los sistemas eléctricos de las anemonas y de los aeropuertos." ;
    guide:numberOfCredits 4.5 ;
    guide:courseType "Obligatoria" ;
    guide:teachingPeriod "2025-26" ;
    guide:periodStartingMonth "Septiembre" ;
    guide:periodEndingMonth "Enero" ;
    sch:inLanguage "Castellano" ;
    guide:hasCourse :course_145005302 ;
    guide:hasSyllabus :syllabus_145005302 ;
    guide:hasEvaluation :eval_system_145005302 ;
    guide:hasLearningResult :lr_ra144, :lr_ra143 ;
    guide:hasCompetency :comp_ce67, :comp_ce71, :comp_cg3, :comp_cg9 ;
    guide:hasDidacticResource :res_moodle, :res_book_sanjurjo ;
    sch:instructor :lecturer_victoria .

