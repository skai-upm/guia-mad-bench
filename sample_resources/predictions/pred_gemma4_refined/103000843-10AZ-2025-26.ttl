data:comp_CB07 a guide:Competency ;
    guide:competencyCode "CB07" ;
    guide:competencyDescription "Que los estudiantes sepan aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en entornos nuevos o poco conocidos dentro de contextos más amplios (o multidisciplinares) relacionados con su área de estudio" .

data:comp_CB08 a guide:Competency ;
    guide:competencyCode "CB08" ;
    guide:competencyDescription "Que los estudiantes sean capaces de integrar conocimientos y enfrentarse a la complejidad de formular juicios a partir de una información que, siendo incompleta o limitada, incluya reflexiones sobre las responsabilidades sociales y éticas vinculadas a la aplicación de sus conocimientos y juicios" .

data:comp_CB09 a guide:Competency ;
    guide:competencyCode "CB09" ;
    guide:competencyDescription "Que los estudiantes sepan comunicar sus conclusiones y los conocimientos y razones últimas que las sustentan a públicos especializados y no especializados de un modo claro y sin ambigüedades" .

data:comp_CEEIT03 a guide:Competency ;
    guide:competencyCode "CE-EIT03" ;
    guide:competencyDescription "Capacidad para identificar el nivel de$\\text{madurez}$ de una tecnología y desarrollar e interpretar un roadmap tecnológico seleccionando la mejor manera de proteger esa tecnología dependiendo de su tipo, nivel de madurez y las restricciones geográficas, y entendiendo las consecuencias de acceder a ella y comercializarla." .

data:comp_CG01 a guide:Competency ;
    guide:competencyCode "CG01" ;
    guide:competencyDescription "Que los estudiantes sean capaces de predecir y controlar la evolución de situaciones complejas mediante el desarrollo de nuevas e innovadoras metodologías de trabajo adaptadas al ámbito científico/investigador, tecnológico o profesional concreto, en general multidisciplinar, en el que se desarrolle su actividad." .

data:comp_CG03 a guide:Competency ;
    guide:competencyCode "CG03" ;
    guide:competencyDescription "La capacidad de usar la lengua inglesa de manera competente, es decir, con capacitación para tareas complejas de trabajo y estudio." .

data:comp_CG07 a guide:Competency ;
    guide:competencyCode "CG07" ;
    guide:competencyDescription "Capacidad de trabajar y comunicarse también en contextos internacionales." .

data:comp_CG08 a guide:Competency ;
    guide:competencyCode "CG08" ;
    guide:competencyDescription "La capacidad de traducir innovaciones en soluciones comerciales factibles." .

data:comp_CG09 a guide:Competency ;
    guide:competencyCode "CG09" ;
    guide:competencyDescription "La capacidad de transformar las experiencias prácticas en problemas y desafíos de investigación." .

data:lr_RA104 a guide:LearningResult ;
    guide:learningResultCode "RA104" ;
    guide:learningResultDescription "In depth understanding the basics of technology watch and transfer" .

