    sch:name "Introduction To Technology Watch And Competitive I" ;
    sch:description "To provide students with some conceptual and practical tools to understand the possible evolution of technologies for specific purposes." ;
    guide:numberOfCredits 1.0 ;
    guide:teachingPeriod "2: 2025-26" ;
    guide:periodStartingMonth "February" ;
    guide:periodEndingMonth "June" ;
    guide:inpersonHours "26/27 hours" ;
    guide:remoteHours "0" ;
