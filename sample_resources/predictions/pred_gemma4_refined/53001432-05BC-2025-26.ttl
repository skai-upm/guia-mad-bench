# Competency Instances
guide:CE1 rdf:type guide:Competency ;
    guide:competencyCode "CE1" ;
    guide:competencyDescription "Aplicar conocimientos de matemáticas, física, química, biología y otras ciencias naturales, obtenidos mediante estudio, experiencia, y práctica, con razonamiento crítico para establecer soluciones viables económicamente a problemas técnicos." .

guide:CE2 rdf:type guide:Competency ;
    guide:competencyCode "CE2" ;
    guide:competencyDescription "Diseñar productos, procesos, sistemas y servicios de la industria química, así como la optimización de otros ya desarrollados..." .

guide:CE3 rdf:type guide:Competency ;
    guide:competencyCode "CE3" ;
    guide:competencyDescription "Conceptualizar modelos de ingeniería, aplicar métodos innovadores en la resolución de problemas y aplicaciones informáticas adecuadas..." .

guide:CG2 rdf:type guide:Competency ;
    guide:competencyCode "CG2" ;
    guide:competencyDescription "Concebir, proyectar, calcular, y diseñar procesos, equipos, instalaciones industriales y servicios..." .

guide:CG5 rdf:type guide:Competency ;
    guide:competencyCode "CG5" ;
    guide:competencyDescription "Saber establecer modelos matemáticos y desarrollarlos mediante la informática apropiada..." .

# Learning Result Instances
guide:RA69 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA69" ;
    guide:learningResultDescription "Ser capaz de realizar la evaluación económica básica de un proceso químico" .

guide:RA67 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA67" ;
    guide:learningResultDescription "Ser capaz de realizar la integración energética de un proceso químico" .

# Syllabus Instance
guide:Syllabus_Integracion rdf:type guide:Syllabus ;
    guide:hasItem guide:SyllabusItem_1, guide:SyllabusItem_2, guide:SyllabusItem_3 .

guide:SyllabusItem_1 rdf:type guide:SyllabusItem ;
    guide:itemIndex 1 ;
    guide:syllabusDescription "Fundamentos (Integración de procesos, Integración energética)" .

guide:SyllabusItem_2 rdf:type guide:SyllabusItem ;
    guide:itemIndex 2 ;
    guide:syllabusDescription "Integración energética (Programación matemática, Análisis Pinch, Síntesis de redes)" .

guide:SyllabusItem_3 rdf:type guide:SyllabusItem ;
    guide:itemIndex 3 ;
    guide:syllabusDescription "Integración másica (Análisis de procesos, Síntesis de sistemas de separación y suministro)" .

# Evaluation System Instance
guide:EvalSystem_Integracion rdf:type guide:EvaluationSystem ;
    guide:evaluationDescription "Para aprobar la asignatura es necesario obtener una calificación global igual o superior a 5 como suma ponderada de los elementos de evaluación." ;
    guide:hasEvaluationTrial guide:Trial_Tareas_Energetica, guide:Trial_Prueba_Integracion, guide:Trial_Entregas_Masica .

# Evaluation Trial Instances
guide:Trial_Tareas_Energetica rdf:type guide:EvaluationTrial ;
    sch:name "Tareas integración energética" ;
    guide:evaluationType "Evaluación Progresiva y Global" ;
    guide:gradePercentage "15%" ;
    guide:minimumScore "5 / 10" ;
    guide:trialMode "Presencial" ;
    guide:involvesCompetency guide:CG5, guide:CE1, guide:CE3, guide:CG2 .

guide:Trial_Prueba_Integracion rdf:type guide:EvaluationTrial ;
    sch:name "Prueba integración energética" ;
    guide:evaluationType "Evaluación Progresiva y Global" ;
    guide:gradePercentage "30%" ;
    guide:minimumScore "5 / 10" ;
    guide:trialMode "Presencial" ;
    guide:involvesCompetency guide:CG2, guide:CG5, guide:CE1, guide:CE2, guide:CE3 .

guide:Trial_Entregas_Masica rdf:type guide:EvaluationTrial ;
    sch:name "Entregas integración másica" ;
    guide:evaluationType "Evaluación Progresiva y Global" ;
    guide:gradePercentage "40%" ;
    guide:minimumScore "5 / 10" ;
    guide:trialMode "No presencial" ;
    guide:involvesCompetency guide:CG2, guide:CG5, guide:CE1, guide:CE2, guide:CE3 .

