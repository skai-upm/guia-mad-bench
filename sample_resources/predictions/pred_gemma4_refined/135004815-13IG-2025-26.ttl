:Act_Eval_Intermediate rdf:type guide:Activity ;
    guide:activityDescription "Evaluación intermedia (presentación de avances del informe) ESG" ;
    guide:activityDuration 2.0 ;
    guide:activityFormat "Presentación en Grupo" .

:Event_Week16 rdf:type guide:ScheduleEvent ;
    guide:eventWeek "Semana 16" ;
    guide:hasActivity :Act_Eval_Final .

:Act_Eval_Final rdf:type guide:Activity ;
    guide:activityDescription "Entrega y defensa de informe ESG corregido" ;
    guide:activityDuration 2.0 ;
    guide:activityFormat "Presentación en Grupo" .

