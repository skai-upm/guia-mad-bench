# Competencies
:Comp_CB03 rdf:type guide:Competency ;
    guide:competencyCode "CB03" ;
    guide:competencyDescription "Que los estudiantes tengan la capacidad de reunir e interpretar datos relevantes para emitir juicios que incluyan una reflexión sobre temas relevantes de índole social, científica - ética" .

:Comp_CB04 rdf:type guide:Competency ;
    guide:competencyCode "CB04" ;
    guide:competencyDescription "Que los estudiantes puedan transmitir información, ideas, problemas y soluciones a un público tanto especializado como no especializado" .

:Comp_CB05 rdf:type guide:Competency ;
    guide:competencyCode "CB05" ;
    guide:competencyDescription "Que los estudiantes hayan desarrollado aquellas habilidades de aprendizaje necesarias para emprender estudios posteriores con un alto grado de autonomía" .

:Comp_CG13 rdf:type guide:Competency ;
    guide:competencyCode "CG13" ;
    guide:competencyDescription "Capacidad para diseñar, dirigir, elaborar, implementar e interpretar proyectos y planes, así como para redactar informes técnicos, memorias de reconocimiento, valoraciones, peritajes y tasaciones." .

:Comp_CT1 rdf:type guide:Competency ;
    guide:competencyCode "CT1" ;
    guide:competencyDescription "Comunicación oral y escrita. Concluir aportaciones por escrito, desarrollando la capacidad de síntesis y presentación de las ideas propias en un grupo de trabajo y en exposición pública." .

# Learning Results
:LR_RA577 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA577" ;
    guide:learningResultDescription "Diseñar un informe ESG adaptado al sector forestal o ambiental." .

:LR_RA575 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA575" ;
    guide:learningResultDescription "Comprender el marco legal y normativo actual en sostenibilidad (Taxonomía, SFDR, GRI, ESRS)." .

:LR_RA578 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA578" ;
    guide:learningResultDescription "Manejar plataformas y metodologías digitales orientadas a la sostenibilidad 4.0." .

:LR_RA576 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA576" ;
    guide:learningResultDescription "Identificar y aplicar los indicadores clave de sostenibilidad en proyectos reales." .

:LR_RA579 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA579" ;
    guide:learningResultDescription "Analizar y evaluar la doble materialidad en el contexto de cambio climático." .

# Syllabus
:Syllabus_Sostenibilidad_40 rdf:type guide:Syllabus ;
    guide:hasItem :SyllabusItem_1, :SyllabusItem_2, :SyllabusItem_3, :SyllabusItem_4, :SyllabusItem_5, :SyllabusItem_6, :SyllabusItem_7 .

:SyllabusItem_1 rdf:type guide:SyllabusItem ;
    guide:itemIndex 1 ;
    guide:syllabusDescription "Introducción a la Sostenibilidad 4.0" .

:SyllabusItem_2 rdf:type guide:SyllabusItem ;
    guide:itemIndex 2 ;
    guide:syllabusDescription "Taxonomía de la UE: objetivos y aplicación" .

:SyllabusItem_3 rdf:type guide:SyllabusItem ;
    guide:itemIndex 3 ;
    guide:syllabusDescription "ESG: indicadores, riesgos y oportunidades" .

:SyllabusItem_4 rdf:type guide:SyllabusItem ;
    guide:itemIndex 4 ;
    guide:syllabusDescription "Marcos de reporte no financiero (GRI, ESRS, SFDR)" .

:SyllabusItem_5 rdf:type guide:SyllabusItem ;
    guide:itemIndex 5 ;
    guide:syllabusDescription "Evaluación de la sostenibilidad y gestión de riesgos climáticos" .

:SyllabusItem_6 rdf:<0xC2>type guide:SyllabusItem ;
    guide:itemIndex 6 ;
    guide:syllabusDescription "Herramientas digitales para sostenibilidad y reporting" .

:SyllabusItem_7 rdf:type guide:SyllabusItem ;
    guide:itemIndex 7 ;
    guide:syllabusDescription "Análisis de informes y estudios de caso sectoriales" .

# Evaluation System and Trials
:EvalSystem_Sostenibilidad_40 rdf:type guide:EvaluationSystem ;
    guide:evaluationDescription "Sistema de evaluación progresiva y global." ;
    guide:hasEvaluationTrial :Trial_Intermediate, :Trial_Final .

:Trial_Intermediate rdf:type guide:EvaluationTrial ;
    guide:evaluationType "Evaluación Progresiva" ;
    guide:gradePercentage "25%" ;
    guide:minimumScore "5 / 10" ;
    guide:trialWeek "Semana 8" ;
    guide:trialMode "Presencial" ;
    guide:trialDescription "Evaluación intermedia (presentación de avances del informe) ESG" .

:Trial_Final rdf:type guide:EvaluationTrial ;
    guide:evaluationType "Evaluación Global" ;
    guide:gradePercentage "75%" ;
    guide:minimumScore "5 / 10" ;
    guide:trialWeek "Semana 16" ;
    guide:trialMode "Presencial" ;
    guide:trialDescription "Entrega y defensa de informe ESG corregido" .

