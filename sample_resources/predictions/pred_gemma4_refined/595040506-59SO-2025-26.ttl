    guide:syllabusDescription "Tema 0. Introducción y contextualización a las Bases de Datos Relacionales" .

:item_tema1 a guide:SyllabusItem ;
    guide:itemIndex 1 ;
    guide:syllabusDescription "Tema 1. Modelado Conceptual y Modelos de Datos Semánticos" .

