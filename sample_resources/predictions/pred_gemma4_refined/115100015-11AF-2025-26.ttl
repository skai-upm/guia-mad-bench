# Course Guide
:course_guide_115100015 a guide:CourseGuide ;
    sch:name "Biomecánica de la Afyd" ;
    sch:courseCode "115100015" ;
    guide:numberOfCredits 6.0 ;
    guide:courseType "Básica" ;
    guide:teachingPeriod "2025-26" ;
    guide:periodStartingMonth "Febrero" ;
    guide:periodEndingMonth "Junio" ;
    sch:inLanguage "Castellano" ;
    guide:hasCompetency :competency_CE08, :competency_CE09 ;
    guide:hasLearningResult :learningResult_RA9, :learningResult_RA84, :learningResult_RA14, :learningResult_RA189 ;
    guide:hasEvaluation :evaluation_system_biomecanica ;
    sch:instructor :lecturer_enrique, :lecturer_archit, :lecturer_javier ;
    sch:director :lecturer_enrique ;
    guide:hasSyllabus :syllabus_biomecanica ;
    guide:hasDidacticResource :resource_moodle, :resource_lab_biomecanica ;
    sch:description "Aplica las leyes de la $\text{mecánica}$ a los movimientos del cuerpo humano teniendo en cuenta sus características anatómicas y biológicas." .

