# Competencies
:Competency_CB10 rdf:type guide:Competency ;
    guide:competencyCode "CB10" ;
    guide:competencyDescription "Que los estudiantes posean las habilidades de aprendizaje que les permitan continuar estudiando de un modo que habrá de ser en gran medida autodirigido o autónomo." .

:Competency_CB6 rdf:type guide:Competency ;
    guide:competencyCode "CB6" ;
    guide:competencyDescription "Poseer y comprender conocimientos que aporten una base u oportunidad de ser originales en el desarrollo y/o aplicación de ideas, a menudo en un contexto de investigación" .

:Competency_CE01 rdf:type guide:Competency ;
    guide:competencyCode "CE01" ;
    guide:competencyDescription "Emplear resultados de aprendizaje automático, adaptados al tratamiento de datos masivos, como fundamento para métodos avanzados de predicción y clasificación." .

:Competency_CG1 rdf:type guide:Competency ;
    guide:competencyCode "CG1" ;
    guide:competencyDescription "Capacidad para aplicar el método científico y saber organizar y planificar experimentos con rigor metodológico en el ámbito del aprendizaje automático y los datos masivos" .

:Competency_CT1 rdf:type guide:Competency ;
    guide:competencyCode "CT1" ;
    guide:competencyDescription "Creatividad" .

:Competency_S01 rdf:type guide:Competency ;
    guide:competencyCode "S01" ;
    guide:competencyDescription "El alumno elabora artículos e informes científicos que demuestran una o varias hipótesis mediante los resultados obtenidos a partir de experimentos" .

# Learning Results
:LR_RA50 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA50" ;
    guide:learningResultDescription "Buscar bibliografía científica, herramientas software y recursos para validación de resultados" .

:LR_RA51 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA51" ;
    guide:learningResultDescription "Abordar y plantear un tema de investigación de interés" .

:LR_RA52 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA52" ;
    guide:learningResultDescription "Conocer y aplicar la metodología científica en ciencia e ingeniería" .

# Syllabus
:Syllabus_613000136 rdf:type guide:Syllabus ;
    guide:hasItem :SyllabusItem_BlockI, :SyllabusItem_BlockII .

:SyllabusItem_BlockI rdf:type guide:SyllabusItem ;
    guide:itemIndex 1 ;
    guide:syllabusDescription "Bloque I (INVESTIGACIÓN): El conocimiento y la investigación; Impacto y diseminación de la ciencia; Redacción y presentación de trabajos científicos; Malas prácticas en investigación; La Tesis Doctoral y la Carrera investigadora" .

:SyllabusItem_BlockII rdf:type guide:SyllabusItem ;
    guide:itemIndex 2 ;
    guide:syllabusDescription "Bloque II (PROYECTOS): Concepción y diseño de un proyecto de investigación; Desarrollo de un tema de investigación; Formación de un consorcio, el equipo de investigadores; Proyectos competitivos vs no competitivos; Transferencia del conocimiento; Principales foros" .

# Evaluation System
:EvalSystem_613000136 rdf:type guide:EvaluationSystem ;
    guide:evaluationDescription "Evaluación progresiva y prueba evaluación global." ;
    guide:hasEvaluationTrial :Trial_Week3, :Trial_Week5, :Trial_Week17, :Trial_Extraordinary .

:Trial_Week3 rdf:type guide:EvaluationTrial ;
    guide:trialWeek "3" ;
    guide:trialType "Presentación en Grupo" ;
    guide:evaluationType "Progresiva" ;
    guide:gradePercentage "50%" ;
    guide:minimumScore "5 / 10" ;
    guide:trialDescription "Presentación de un trabajo de investigación" .

:Trial_Week5 rdf:type guide:EvaluationTrial ;
    guide:trialWeek "5" ;
    guide:trialType "Presentación en Grupo" ;
    guide:evaluationType "Progresiva" ;
    guide:gradePercentage "50%" ;
    guide:minimumScore "5 / 10" ;
    guide:trialDescription "Exposición de un proyecto de investigación" .

:Trial_Week17 rdf:type guide:EvaluationTrial ;
    guide:trialWeek "17" ;
    guide:trialType "Presentación Individual" ;
    guide:evaluationType "Global" ;
    guide:gradePercentage "100%" ;
    guide:minimumScore "5 / 10" ;
    guide:trialDescription "Presentación de un trabajo de investigación y de un proyecto de I+D+i" .

