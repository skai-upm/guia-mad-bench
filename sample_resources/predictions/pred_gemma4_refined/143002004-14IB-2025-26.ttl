# Course Guide Instance
:course_guide_143002004 rdf:type guide:CourseGuide ;
    sch:name "Guía de Aprendizaje - Desarrollo De Infraestructuras Aeronáuticas" ;
    sch:description "Conocimiento del ámbito de las infraestructías aeroportuarias, desde el punto de vista de su relación con las operaciones de las aeronaves, la organización del sector, la terminología, reglamentación y normativas, y planificación, diseño, construcción y operación de las mismas." ;
    guide:numberOfCredits 6.0 ;
    guide:teachingPeriod "2025-26" ;
    guide:periodStartingMonth "Febrero" ;
    guide:periodEndingMonth "Junio" ;
    sch:inLanguage "Castellano" ;
    guide:hasSyllabus :syllabus_143002004 ;
    guide:hasCompetency :comp_CE_IA_1, :comp_CG1, :comp_CT1 ;
    guide:hasLearningResult :lr_RA49, :lr_RA51, :lr_RA50 ;
    guide:hasEvaluation :eval_system_143002004 ;
    guide:hasDidacticResource :res_bibliografia_1, :res_web_moodle ;
    sch:instructor :lecturer_diego, :lecturer_alvaro, :lecturer_santiago, :lecturer_daniel, :lecturer_angel ;
    sch:director :lecturer_angel .

