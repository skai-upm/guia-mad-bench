# Competencies (Sample)
:comp_CE_IA_1 rdf:type guide:Competency ;
    guide:competencyCode "CE-IA-1" ;
    guide:competencyDescription "Aptitud para realizar los Planes Directores de aeropuertos y los proyectos y la dirección de construcción de las infraestructuras, edificaciones e instalaciones aeroportuarias." .

:comp_CG1 rdf:type guide:Competency ;
    guide:competencyCode "CG1" ;
    guide:competencyDescription "Capacidad para proyectar, construir, inspeccionar, certificar y mantener todo tipo de aeronaves y vehículos espaciales, con sus correspondientes subsistemas." .

:comp_CT1 rdf:type guide:Competency ;
    guide:competencyCode "CT1" ;
    guide:competencyDescription "Capacidad para comprender los contenidos de clases magistrales, conferencias y seminarios, así como cualquier información y documentación en lengua inglesa." .

# Learning Results (Sample)
:lr_RA49 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA49" ;
    guide:learningResultDescription "Identifica las unidades estratégicas de análisis del negocio de explotación aeroportuaria" .

:lr_RA51 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA51" ;
    guide:learningResultDescription "Analiza internamente el aeropuerto e identifica las ventajas competitivas y las debilidades significativas" .

:lr_RA50 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA50" ;
    guide:learningResultDescription "Analiza el entorno e identifica las amenazas y oportunidades que afectan al negocio de explotación aeroportuaria" .

# Syllabus
:syllabus_143002004 rdf:type guide:Syllabus ;
    guide:hasItem :syllabus_item_tema1, :syllabus_item_tema2, :syllabus_item_tema3 .

:syllabus_item_tema1 rdf:type guide:SyllabusItem ;
    guide:itemIndex 1 ;
    guide:syllabusDescription "Tema 1. CARACTERÍSTICAS FÍSICAS." .

:syllabus_item_tema2 rdf:type guide:SyllabusItem ;
    guide:itemIndex 2 ;
    guide:syllabusDescription "Tema 2. ORDENACIÓN Y REGULACIÓN DEL SISTEMA AEROPORTUARIO." .

:syllabus_item_tema3 rdf:type guide:SyllabusItem ;
    guide:itemIndex 3 ;
    guide:syllabusDescription "Tema 3. PLANES DIRECTORES." .

# Evaluation System
:eval_system_143002004 rdf:type guide:EvaluationSystem ;
    guide:evaluationDescription "La asignatura consta de cuatro partes: planificación, diseño, seguridad operacional e ingeniería eléctrica. El peso de cada parte en la nota es del 2	5%." ;
    guide:hasEvaluationTrial :trial_examen_escrito, :trial_trabajo .

:trial_examen_escrito rdf:type guide:EvaluationTrial ;
    sch:name "Examen escrito" ;
    guide:evaluationType "Examen" ;
    guide:gradePercentage "100%" ;
    guide:minimumScore "5 / 10" ;
    guide:trialMode "Presencial" ;
    guide:trialWeek "17" .

:trial_trabajo rdf:type guide:EvaluationTrial ;
    sch:name "Trabajo" ;
    guide:evaluationType "Trabajo" ;
    guide:gradePercentage "10%" ;
    guide:minimumScore "5 / 10" ;
    guide:trialMode "No presencial" ;
    guide:evaluationDuration "17:00" .

# Didactic Resources
:res_bibliografia_1 rdf:type guide:DidacticResource ;
    guide:bibliographyTitle "M. GARCÍA CRUZADO. 'Ingeniería Aeroportuaria'. Ed. UPM, ETSI Aeronáuticos" ;
    guide:bibliographyType "Bibliografía" .

:res_web_moodle rdf:type guide:DidacticResource ;
    guide:bibliographyTitle "Espacio MOODLE de la asignatura http://moodle.upma.es/" ;
    guide:bibliographyType "Recursos web" .

