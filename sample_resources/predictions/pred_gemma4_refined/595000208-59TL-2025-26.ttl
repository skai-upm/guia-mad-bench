# Competencies
:CE_B4 rdf:type guide:Competency ;
    guide:competencyCode "CE B4" ;
    guide:competencyDescription "Comprensión y dominio de los conceptos básicos de sistemas lineales y las funciones y transformadas relacionadas, teoría de circuitos eléctricos, circuitos electrónicos, principio físico de los semiconductores y familias lógicas, dispositivos electrónicos y fotónicos, tecnología de materiales y su aplicación para la resolución de problemas propios de la ingeniería." .

:CE_TEL12 rdf:type guide:Competency ;
    guide:competencyCode "CE TEL12" ;
    guide:competencyDescription "Capacidad de utilizar distintas fuentes de energía y en especial la solar fotovoltaica y térmica, así como los fundamentos de la electrotecnia y de la electrónica de potencia." .

:CG_02 rdf:type guide:Competency ;
    guide:competencyCode "CG 02" ;
    guide:competencyDescription "Capacidad de búsqueda y selección de información, de razonamiento crítico y de elaboración y defensa de argumentos dentro del área." .

:CG_04 rdf:type guide:Competency ;
    guide:competencyCode "CG 04" ;
    guide:competencyDescription "Capacidad de abstracción, de análisis y de síntesis y de resolución de problemas." .

:CG_05 rdf:type guide:Competency ;
    guide:competencyCode "CG 05" ;
    guide:competencyDescription "Capacidad de trabajo en equipo y en entornos multidisciplinares." .

# Learning Results
:RA68 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA68" ;
    guide:learningResultDescription "Entender el diagrama de bloques de sistemas electrónicos sencillos aplicados en el sector de las telecomunicaciones" .

:RA69 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA6<0xC2>9" ;
    guide:learningResultDescription "Conocer la función y características básicas de los componentes electrónicos pasivos (Resistencia, condensador y bobina). Conocer sus propiedades básicas." .

:RA67 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA67" ;
    guide:learningResultDescription "Entender las características principales de los bloques funcionales que componen un sistema electrónico básico (amplificador, atenuador, alimentación, ADC, DAC)." .

:RA70 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA70" ;
    guide:learningResultDescription "Entender el modelo y las propiedades básicas de los amplificadores y su implementación con amplificadores operacionales ideales." .

:RA71 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA71" ;
    guide:learningResultDescription "Conocer la función y características básicas de los componentes electrónicos activos (diodo, transistor bipolar y unipolar)." .

:RA66 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA66" ;
    guide:learningResultDescription "Entender la nomenclatura y propiedades básicas de las señales elementales que se utilizan en los circuitos electrónicos" .

# Syllabus
:ElectronicaI_Syllabus rdf:type guide:Syllabus ;
    guide:hasItem :SyllabusItem_1, :SyllabusItem_2, :SyllabusItem_3, :SyllabusItem_4 .

:SyllabusItem_1 rdf:type guide:SyllabusItem ;
    guide:itemIndex 1 ;
    guide:syllabusDescription "Introducción a los sistemas electrónicos" .

:SyllableItem_2 rdf:type guide:SyllabusItem ;
    guide:itemIndex 2 ;
    guide:syllabusDescription "Componentes y dispositivos electrónicos" .

:SyllabusItem_3 rdf:type guide:SyllabusItem ;
    guide:itemIndex 3 ;
    guide:syllabusDescription "Subsistemas electrónicos integrados" .

:SyllabusItem_4 rdf:type guide:SyllabusItem ;
    guide:itemIndex 4 ;
    guide:syllabusDescription "Prácticas" .

