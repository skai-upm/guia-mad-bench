# Syllabus Instance
:syllabus_63000126 a guide:Syllabus ;
    guide:hasItem :item_topic_1, :item_topic_2, :item_topic_3, :item_topic_4, :item_topic_5, :item_topic_6, :item_topic_7, :item_topic_8, :item_topic_9, :item_topic_10 .

:item_topic_1 a guide:SyllabusItem ; guide:itemIndex 1 ; guide:syllabusDescription "EL PROYECTO MINERO (MINING PROJECT)" .
:item_topic_2 a guide:SyllabusItem ; guide:itemIndex 2 ; guide:syllabusDescription "PLANIFICACIÓN MINERA (MINE PLANNING)" .
:item_topic_3 a guide:SyllabusItem ; guide:itemIndex 3 ; guide:syllabusDescription "COSTES E INGRESOS MINEROS (MINE REVENUES AND COSTS)" .
:item_topic_4 a guide:SyllabusItem ; guide:itemIndex 4 ; guide:syllabusDescription "ANÁLISIS Y EVALUACIÓN ECONÓMICA DE PROYECTOS MINEROS" .
:item_topic_5 a guide:SyllabusItem ; guide:itemIndex 5 ; guide:syllabusDescription "EVALUACIÓN DE ASPECTOS SOCIALES Y AMBIENTALES DE UN PROYECTO MINERO" .
:item_topic_6 a guide:SyllabusItem ; guide:itemIndex 6 ; guide:syllabusDescription "FINANCIACIÓN DE PROYECTOS MINEROS (MINE PROJECT FINANCING)" .
:item_topic_7 a guide:SyllabusItem ; guide:itemIndex 7 ; guide:syllabusDescription "OREBODY DEFINITION AND ASSESSMENT" .
:item_topic_8 a guide:SyllabusItem ; guide:itemIndex 8 ; guide:syllabusDescription "DISEÑO DE MINA A CIELO ABIERTO (OPEN PIT MINE DESIGN)" .
:item_topic_9 a guide:SyllabusItem ; guide:itemIndex 9 ; guide:syllabusDescription "SELECCIÓN DE MAQUINARIA (MACHINERY SELECTION)" .
:item_topic_10 a guide:SyllabusItem ; guide:itemIndex 10 ; guide:syllabusDescription "PLANIFICACIÓN, DISEÑO Y CONSTRUCCIÓN DE MINAS DE INTERIOR (UNDERGROUND MINE PLANNING AND DESIGN)" .

