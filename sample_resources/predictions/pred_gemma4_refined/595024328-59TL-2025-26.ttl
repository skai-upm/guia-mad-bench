# Course
:course_595024328 rdf:type guide:Course ;
    sch:name "Electronica De Comunicaciones I" ;
    sch:courseCode 595024328 ;
    guide:courseType "Optativa" ;
    sch:hasCourseInstance :guide_595024328 .

# Course Guide
:guide_595024328 rdf:type guide:CourseGuide ;
    sch:name "Guía de Aprendizaje - Electronica De Comunicaciones I" ;
    sch:description "Introducción al alumno en el mundo de la generación de señales de alta frecuencia y elevada estabilidad." ;
    guide:teachingPeriod "2025-26" ;
    guide:periodStartingMonth "Septiembre" ;
    guide:periodEndingMonth "Enero" ;
    guide:numberOfCredits 6.0 ;
    sch:inLanguage "Castellano" ;
    sch:instructor :lecturer_ortega ;
    sch:instructor :lecturer_pardo ;
    sch:instructor :lecturer_jimenez ;
    guide:hasCompetency :comp_SC03, :comp_SC04, :comp_TEL01, :comp_TEL02, :comp_TEL03, :comp_CG02, :comp_SG04, :comp_CG05, :comp_CG09, :comp_CG10, :comp_CG11 ;
    guide:hasEvaluation :eval_system_main ;
    guide:hasDidacticResource :res_sierra, :res_gonzalez, :res_rhea, :res_smith, :res_gardner, :res_best, :res_rohde, :res_manassewitsch, :res_chenakin, :res_moodle ;
    guide:hasSyllabus :syllabus_electronica .

