# Competencies
:comp_SC03 rdf:type guide:Competency ;
    guide:competencyCode "CE SC03" ;
    guide:competencyDescription "Capacidad de análisis de componentes y sus especificaciones para sistemas de comunicaciones guiadas y no guiadas." .

:comp_SC04 rdf:type guide:Competency ;
    guide:competencyCode "CE SC04" ;
    guide:competencyDescription "Capacidad para la selección de circuitos, subsistemas y sistemas de radiofrecuencia, microondas, radiodifusión, radioenlaces y radiodeterminación." .

:comp_TEL01 rdf:type guide:Competency ;
    guide:competencyCode "CE TEL01" ;
    guide:competencyDescription "Capacidad para aprender de manera autónoma nuevos conocimientos y técnicas adecuados para la concepción, el desarrollo o la explotación de sistemas y servicios de telecomunicación." .

# Evaluation System and Trials
:eval_system_main rdf:type guide:EvaluationSystem ;
    guide:evaluationDescription "La evaluación de la asignatura se divide en dos partes: teoría (70%) y práctica (30%)." ;
    guide:hasEvaluationTrial :trial_exam1, :trial_exam2, :trial_final .

:trial_exam1 rdf:type guide:EvaluationTrial ;
    sch:name "1er Examen parcial" ;
    guide:evaluationType "Examen Escrito" ;
    guide:trialMode "Presencial" ;
    guide:gradePercentage "50%" ;
    guide:minimumScore "5 / 10" ;
    guide:trialWeek "8" .

:trial_exam2 rdf:type guide:EvaluationTrial ;
    sch:name "2º Examen Parcial de Teoría" ;
    guide:evaluationType "Examen Escrito" ;
    guide:trialMode "Presencial" ;
    guide:gradePercentage "50%" ;
    guide:minimumScore "5 / 10" ;
    guide:trialWeek "14" .

:trial_final rdf:type guide:EvaluationTrial ;
    sch:name "Examen Final de Teoría" ;
    guide:evaluationType "Examen Escrito" ;
    guide:trialMode "Presencial" ;
    guide:gradePercentage "100%" ;
    guide:minimumScore "5 / 10" ;
    guide:trialWeek "16" .

# Syllabus
:syllabus_electronica rdf:type guide:Syllabus ;
    guide:hasItem :item_topic1, :item_topic2, :item_topic3, :item_topic4, :item_topic5 .

:item_topic1 rdf:type guide:SyllabusItem ;
    guide:itemIndex 1 ;
    guide:syllabusDescription "Introducción al estudio de los osciladores." .

:item_topic2 rdf:type guide:SyllabusItem ;
    guide:itemIndex 2 ;
    guide:syllabusDescription "Osciladores autocontrolados LC." .

:item_topic3 rdf:<0xC2>type guide:SyllabusItem ;
    guide:itemIndex 3 ;
    guide:syllabusDescription "Osciladores a cristal." .

# Didactic Resources
:res_sierra rdf:type guide:DidacticResource ;
    guide:bibliographyTitle "M. Sierra Pérez y otros, Electrónica de Comunicaciones, Pearson Education, 2003" ;
    guide:bibliographyType "Bibliografía" ;
    guide:bibliographyDescription "Texto en castellano de carácter general sobre diferentes circuitos y sub-sistemas de electrónica de comunicaciones." .

:res_gonzalez rdf:type guide:DidacticResource ;
    guide:bibliographyTitle "G. González, Foundations of Oscillators Circuit Design, Artech House, 2006" ;
    guide:bibliographyType "Bibliografía" .

:res_moodle rdf:type guide:DidacticResource ;
    guide:bibliographyTitle "Plataforma Moodle UPM" ;
    guide:bibliographyType "Recursos web" ;
    guide:bibliographyDescription "Herramienta de interacción asíncrona." .

# Required Knowledge
:req_knowledge_electro rdf:type guide:RequiredKnowledge ;
    guide:previousKnowledge "Conocimiento de las técnicas básicas de polarización de transistores bipolares y FET. Resolución de ecuaciones diferenciales ordinarias. Transformación en el dominio de Laplace." .

