# Competencies
:comp_ce_se3 a guide:Competency ;
    guide:competencyCode "CE-SE3" ;
    guide:competencyDescription "Capacidad de realizar la especificación, implementación, documentación y puesta a punto de equipos y sistemas, electrónicos, de instrumentación y de control..." .

:comp_ce_se5 a guide:Competency ;
    guide:competencyCode "CE-SE5" ;
    guide:competencyDescription "Capacidad de diseñar circuitos de electrónica analógica y digital, de conversión analógico-digital y digital analógica..." .

:comp_ce_se8 a guide:Competency ;
    guide:competencyCode "CE-SE8" ;
    guide:competencyDescription "Capacidad para especificar y utilizar instrumentación electrónica y sistemas de medida" .

:comp_cg10 a guide:Competency ;
    guide:competencyCode "CG10" ;
    guide:competencyDescription "Creatividad" .

:comp_cg12 a guide:Competency ;
    guide:competencyCode "CG12" ;
    guide:competencyDescription "Organización y planificación" .

:comp_cg8 a guide:Competency ;
    guide:competencyCode "CG8" ;
    guide:competencyDescription "Comunicación oral y escrita" .

# Learning Results
:lr_ra70 a guide:LearningResult ;
    guide:learningResultCode "RA70" ;
    guide:learningResultDescription "Conocimientos de dispositivos, circuitos, equipos y sistemas electrónicos." .

:lr_ra210 a guide:LearningResult ;
    guide:learningResultCode "RA210" ;
    guide:learningResultDescription "Realizar una documentación técnica completa sobre el diseño realizado..." .

:lr_ra555 a guide:LearningResult ;
    guide:learningResultCode "RA555" ;
    guide:learningResultDescription "Diseñar individualmente los módulos digitales y ser capaz de describirlos adecuadamente en un lenguaje de descripción hardware" .

