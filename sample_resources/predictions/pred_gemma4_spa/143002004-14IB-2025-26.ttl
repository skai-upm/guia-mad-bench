# Evaluation System
:EvalSystem_143002004 a guide:EvaluationSystem ;
    guide:evaluationDescription "La asignatura consta de cuatro partes: planificación, diseño, seguridad operacional e ingeniería eléctrica. El peso de cada parte en la nota es del 25%." ;
    guide:hasEvaluationTrial :EvalTrial_Examen_Ordinario, :EvalTrial_Trabajo_Voluntario .

:EvalTrial_Examen_Ordinario a guide:EvaluationTrial ;
    guide:trialType "Examen Escrito" ;
    guide:trialMode "Presencial" ;
    guide:evaluationType "progresiva" ;
    guide:gradePercentage "100%" ;
    guide:minimumScore "5 / 10" ;
    guide:evaluationDuration "04:00" .

:EvalTrial_Trabajo_Voluntario a guide:EvaluationTrial ;
    guide:trialType "Trabajo en Grupo" ;
    guide:trialMode "No presencial" ;
    guide:gradePercentage "10%" ;
    guide:evaluationDuration "17:00" .

