# Course Instance / Guide
:CourseGuide_143002004 a guide:CourseGuide ;
    sch:name "Guía de Aprendizaje - Desarrollo De Infraestructuras Aeronáuticas" ;
    sch:description "Conocimiento del ámbito de las infraestructuras aeroportuarias, desde el punto de vista de su relación con las operaciones de las aeronaves, la organización del sector, la terminología, reglamentación y normativas, y planificación, diseño, construcción y operación de las mismas." ;
    guide:teachingPeriod "2025-26" ;
    guide:teachingPeriodMonths "Febrero-Junio" ;
    guide:numberOfCredits 6.0 ;
    sch:inLanguage "Castellano" ;
    sch:instructor :Lecturer_Nicolas, :Lecturer_Alvaro, :Lecturer_Santiago, :Lecturer_Daniel, :Lecturer_Angel ;
    sch:director :Lecturer_Angel ;
    guide:hasSyllabus :Syllabus_143002004 ;
    guide:hasCompetency :Comp_CE_IA_1, :Comp_CG1, :Comp_CT1 ;
    guide:hasLearningResult :LR_RA49, :LR_RA51, :LR_RA50 ;
    guide:hasEvaluation :EvalSystem_143002004 ;
    guide:hasDidacticResource :Res_GarciaCruzado, :Res_ReglamentoEU, :Res_Anexo14OACI ;
    sch:activitiesWorkload "26-27 horas por crédito ECTS" .

