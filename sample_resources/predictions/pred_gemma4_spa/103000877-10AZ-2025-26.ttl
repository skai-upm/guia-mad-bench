# --- Competencies ---
:comp_CB08 rdf:type guide:Competency ;
    guide:competencyCode "CB08" ;
    guide:competencyDescription "Que los estudiantes sean capaces de integrar conocimientos y enfrentarse a la complejidad..." .

:comp_CE_DIPO01 rdf:type guide:Competency ;
    guide:competencyCode "CE-DIPO01" ;
    guide:competencyDescription "Capacidad para conceptualizar, diseñar y desarrollar la interacción persona-ordenador..." .

:comp_CE_DIPO02 rdf:type guide:Competency ;
    guide:competencyCode "CE-DIPO02" ;
    guide:competencyDescription "Capacidad para evaluar la interacción persona-ordenador de productos y servicios..." .

:comp_CE_DIPO03 rdf:type guide:Competency ;
    guide:competencyCode "CE-DIPO03" ;
    guide:competencyDescription "Habilidad para hacer conexiones entre los deseos y necesidades del consumidor..." .

:comp_CE_DIPO04 rdf:type guide:Competency ;
    guide:competencyCode "CE-DIPO04" ;
    guide:competencyDescription "Capacidad para analizar las necesidades de información que se plantean en un entorno..." .

:comp_CG02 rdf:type guide:Competency ;
    guide:competencyCode "CG02" ;
    guide:competencyDescription "Que los estudiantes desarrollen la autonomía suficiente para participar en proyectos..." .

# --- Learning Results ---
:lr_RA20 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA20" ;
    guide:learningResultDescription "Evaluate the usability and accessibility of prototypes" .

:lr_RA22 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA22" ;
    guide:learningResultDescription "Understand the concept and types of assistive products" .

:lr_RA7 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA7" ;
    guide:learningResultDescription "Understand how to design an interactive system using a user-centred approach" .

:lr_RA36 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA36" ;
    guide:learningResultDescription "Understand the diversity of user requirements and the characteristics of accessibility" .

# --- Syllabus ---
:syllabus_103000877 rdf:type guide:Syllabus ;
    guide:hasItem :item_1, :item_2, :item_3, :item_4 .

:item_1 rdf:type guide:SyllabusItem ;
    guide:itemIndex 1 ;
    guide:syllabusDescription "Functional diversity, accessibility and design for all" .

:item_2 rdf:type guide:SyllabusItem ;
    guide:itemIndex 2 ;
    guide:syllabusDescription "ICT accessibility standards" .

:item_3 rdf:type guide:SyllabusItem ;
    guide:itemIndex 3 ;
    guide:syllabusDescription "State of the art in ICT accessibility" .

:item_4 rdf:type guide:SyllabusItem ;
    guide:itemIndex 4 ;
    guide:syllabusDescription "Cognitive Accessibility" .

# --- Evaluation System ---
:eval_system_103000877 rdf:type guide:EvaluationSystem ;
    guide:evaluationDescription "The assessment of this module is divided into two parts: theory and practice." ;
