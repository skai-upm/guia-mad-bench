    guide:gradePercentage "10%" ;
    guide:trialMode "No Presential" .

:trial_exercise2 rdf:type guide:EvaluationTrial ;
    guide:evaluationType "Group work" ;
    guide:gradePercentage "20%" ;
    guide:trialMode "No Presential" .

