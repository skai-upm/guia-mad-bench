# --- Degree and University Center ---
data:Degree_13AD rdf:type guide:MasterDegree ;
    sch:name "Master Universitario En Ingenieria De Montes" ;
    guide:degreeCode "13AD" ;
    guide:hasCourse data:Course_133000241 .

data:UniversityCenter_ETSI rdf:type guide:UniversityCenter ;
    sch:name "E.T.S.I. Montes, Forestal Y Medio Natur." ;
    guide:offers data:Degree_13AD .

# --- Course and Course Guide ---
data:Course_133000241 rdf:type guide:Course ;
    sch:name "133000241 - Ordenacion De Montes Avanzada" ;
    sch:courseCode 133000241 ;
    sch:numberOfCredits 5.0 ;
    guide:courseType "Obligatoria" ;
    guide:semester "Tercer semestre" ;
    sch:hasCourseInstance data:CourseGuide_133000241 .

data:CourseGuide_133000241 rdf:type guide:CourseGuide ;
    sch:description "Esta asignatura se impartió por primera vez en el curso 2020/2021 y su objetivo es profundizar y completar los conocimientos de Ordenación de Montes adquiridos en el grado." ;
    guide:teachingPeriod "2025-26" ;
    guide:teachingPeriodMonths "Septiembre-Enero" ;
    sch:inLanguage "Castellano" ;
    guide:hasSyllabus data:Syllabus_133000241 ;
    guide:hasCompetency data:Competency_CB09, data:Competency_CE28, data:Competency_CE61, data:Competency_CT02, data:Competency_CT06 ;
    guide:hasLearningResult data:LearningResult_RA162, data:LearningResult_RA163, data:LearningResult_RA132, data:LearningResult_RA164, data:LearningResult_RA165, data:LearningResult_RA134 ;
    guide:hasEvaluation data:EvaluationSystem_133000241 ;
    guide:hasDidacticResource data:Resource_Dubourdieu, data:Resource_Madrigal, data:Resource_Gonzalez, data:Resource_Ministerio, data:Resource_Davis, data:Resource_Bettinger, data:Resource_Buongiorno, data:Resource_Moodle ;
    sch:instructor data:Lecturer_FernandoGarcia, data:Lecturer_LuisDiaz ;
    sch:courseSchedule data:Schedule_133000241 .

# --- Lecturers ---
