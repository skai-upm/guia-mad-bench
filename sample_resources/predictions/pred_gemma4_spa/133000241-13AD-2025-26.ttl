    guide:bibliographyType "Bibliografía" .

data:Resource_Moodle rdf:type guide:DidacticResource ;
    guide:bibliographyTitle "Espacio de la asignatura en Moodle" ;
    guide:bibliographyType "Recursos web" .

# --- Required Knowledge ---
data:RequiredKnowledge_133000241 rdf:type guide:RequiredKnowledge ;
    guide:previousKnowledge "Ordenación de Montes y Valoración Agraria, Economía Forestal, estadística, álgebra matricial, ecología y selvicultura." .