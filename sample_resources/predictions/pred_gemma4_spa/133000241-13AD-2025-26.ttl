data:Trial_Control34 rdf:type guide:EvaluationTrial ;
    guide:trialType "Examen Escrito" ;
    guide:trialMode "Presencial" ;
    guide:gradePercentage "50%" ;
    guide:minimumScore "5/10" ;
    guide:involvesCompetency data:Competency_CE28, data:Competency_CB09, data:Competency_CT06, data:Competency_CT02, data:Competency_CE61 .

data:Trial_Final rdf:type guide:EvaluationTrial ;
