    guide:bibliographyType "Bibliografía" .

data:Resource_Madrigal rdf:type guide:DidacticResource ;
    guide:bibliographyTitle "MADRIGAL, A., et al. 1994. Ordenación de montes arbolados." ;
    guide:bibliographyType "Bibliografía" .

data:Resource_Gonzalez rdf:type guide:DidacticResource ;
    guide:bibliographyTitle "GONZÁLEZ MOLINA J.M., PIQUÉ M., VERICAT P., 2006. Manual de Ordenación por Rodales." ;
    guide:bibliographyType "Bibliografía" .

data:Resource_Ministerio rdf:type guide:DidacticResource ;
    guide:bibliographyTitle "MINISTERIO DE AGRICULTURA, 1971. Instrucciones Generales para la Ordenación de Montes Arbolados." ;
    guide:bibliographyType "Bibliografía" .

data:Resource_Davis rdf:type guide:DidacticResource ;
    guide:bibliographyTitle "DAVIS, L.S., et al. 2001. Forest Management to Sustain Ecological, Economic and Social Values." ;
    guide:bibliographyType "Bibliografía" .

data:Resource_Bettinger rdf:type guide:DidacticResource ;
    guide:bibliographyTitle "BETTINGER, P., et al. 2017. Forest Management and Planning." ;
    guide:bibliographyType "Bibliografía" .

data:Resource_Buongiorno rdf:type guide:DidacticResource ;
