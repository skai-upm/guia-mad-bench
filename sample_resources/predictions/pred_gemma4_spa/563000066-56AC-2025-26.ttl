# --- Competencies ---

:comp_CE1 rdf:type guide:Competency ;
    guide:competencyCode "CE1" ;
    guide:competencyDescription "Capacidad de diseñar, innovar y gestionar nuevos productos teniendo en cuenta criterios de calidad y medioambientales" .

:comp_CE4 rdf:type guide:Competency ;
    guide:competencyCode "CE4" ;
    guide:competencyDescription "Capacidad de manejar e integrar las herramientas de representación, similiación y cálculo CAD-CAM-CAE para una correcta definición del producto diseñado" .

:comp_CE5 rdf:type guide:Competency ;
    guide:competencyCode "CE5" ;
    guide:competencyDescription "Capacidad para seleccionar los materiales adecuados para un correcto diseño de producto" .

:comp_CE8 rdf:type guide:Competency ;
    guide:competencyCode "CE8" ;
    guide:competencyDescription "Capacidad para aplicar herramientas de visualización y generación virtual de productos" .

:comp_CG1 rdf:type guide:Competency ;
    guide:competencyCode "CG1" ;
    guide:competencyDescription "Capacidad para fomentar, en contextos académicos y profesionales, el avance tecnológico, social o cultural dentro de una sociedad basada en el conocimiento" .

# --- Learning Results ---

:lr_RA45 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA45" ;
    guide:learningResultDescription "Gestionar y procesar la información generada desde diferentes herramientas para realizar proyectos de prototipado rápido." .

:lr_RA47 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA47" ;
    guide:learningResultDescription "Realizar series cortas mediante técnicas de fabricación rápida." .

# --- Syllabus ---

:syllabus_prototipado rdf:type guide:Syllabus ;
    guide:hasItem :item_tema1, :item_tema2, :item_tema3, :item_tema4, :item_tema5 .

