    guide:itemIndex 1 ;
    guide:syllabusDescription "Introducción" .

:item_tema2 rdf:type guide:SyllabusItem ;
    guide:itemIndex 2 ;
    guide:syllabusDescription "Técnicas de Prototipado Rápido (Fundamentos, Corte y Laminado, Estereolitografía, Fotopolimerización, etc.)" .

