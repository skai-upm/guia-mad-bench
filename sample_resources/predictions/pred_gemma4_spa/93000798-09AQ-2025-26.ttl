# Competencies
guide:Comp_CE6 a guide:Competency ;
    guide:competencyCode "CE6" ;
    guide:competencyDescription "Capacidad para modelar, diseñar, implant

implantar, gestionar, operar, administrar y mantener redes, servicios y contenidos." .

guide:Comp_CE7 a guide:Competency ;
    guide:competencyCode "CE7" ;
    guide:competencyDescription "Capacidad para realizar la planificación, toma de decisiones y empaquetamiento de redes, servicios y aplicaciones..." .

guide:Comp_CT4 a guide:Competency ;
    guide:competencyCode "CT4" ;
    guide:competencyDescription "Capacidad para trabajar de forma efectiva como individuo, organizando y planificando su propio trabajo..." .

# Learning Results
guide:LR_RA4 a guide:LearningResult ;
    guide:learningResultCode "RA4" ;
    guide:learningResultDescription "Conocer los métodos de ingeniería útiles en el desarrollo y operación de aplicaciones y servicios" .

guide:LR_RA1 a guide:LearningResult ;
    guide:learningResultCode "RA1" ;
    guide:learningResultDescription "Conocer estándares y protocolos utilizados en el desarrollo de aplicaciones orientadas a servicios." .

# Evaluation System and Trials
guide:EvalSystem_93000798 a guide:EvaluationSystem ;
    guide:evaluationDescription "La calificación se obtiene mediante la media de las calificaciones correspondientes a los dos exámenes parciales, con igual peso." ;
    guide:hasEvaluationTrial guide:Trial_ExamenParcial1, guide:Trial_ExamenFinal .

guide:Trial_ExamenParcial1 a guide:EvaluationTrial ;
    sch:name "Examen parcial 1" ;
    guide:evaluationType "Examen Escrito" ;
    guide:gradePercentage "50%" ;
    guide:minimumScore "4/10" ;
    guide:trialMode "Presencial" ;
    guide:involvesCompetency guide:Comp_CE6, guide:Comp_CT4 .

guide:Trial_ExamenFinal a guide:EvaluationTrial ;
    sch:name "Examen final parcial 1" ;
    guide:evaluationType "Examen Escrito" ;
    guide:gradePercentage "100%" ;
    guide:minimumScore "5/10" ;
    guide:trialMode "Presencial" .

