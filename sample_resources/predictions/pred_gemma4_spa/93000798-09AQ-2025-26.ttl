guide:CourseGuide_93000798 a guide:CourseGuide ;
    sch:hasCourseInstance guide:Course_93000798 ;
    sch:description "La asignatura tiene como objetivo que el alumno conozca los tipos principales de tecnologías de software y servicios, y su contexto de uso en el ámbito empresarial." ;
