    guide:teachingPeriod "2025-26" ;
    guide:periodStartingMonth "Septiembre" ;
    guide:periodEndingMonth "Enero" ;
    guide:numberOfCredits 6.0 ;
    guide:totalHours "154" ; # Calculated based on 26h per credit approx
    sch:instructor guide:Lecturer_JuanCarlosDueñas, guide:Lecturer_FelixCuadrado, guide:Lecturer_DavidRodriguez, guide:Lecturer_JavierAndion, guide:Lecturer_JuanCarlosYelmo, guide:Lecturer_JoseMariaAlamo, guide:Lecturer_YodSamuel ;
