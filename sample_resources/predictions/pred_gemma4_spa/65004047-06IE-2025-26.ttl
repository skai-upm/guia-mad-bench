@prefix : <http://guia-mad-bench.es/data/> .
@prefix guide: <http://w3id.org/def/guia#> .
@prefix sch: <https://schema.org/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

# University Center
:ets_minas_energia rdf:type guide:UniversityCenter ;
    sch:name "E.T.S. de Ingenieros de Minas y Energía" ;
    guide:offers :degree_ingenieria_energia .

# Degree
:degree_ingenier	_engineering rdf:type guide:Degree ;
    sch:name "06IE - Grado En Ingenieria De La Energia" ;
    guide:degreeCode "06IE" ;
    guide:hasCourse :course_fluidos .

# Course
:course_fluidos rdf:type guide:Course ;
    sch:name "65004047 - Ingenieria De Fluidos" ;
    sch:courseCode 65004047 ;
    guide:numberOfCredits 4.5 ;
    guide:courseType "Optativa" ;
    guide:semester "Quinto semestre" ;
    sch:hasCourseInstance :guide_fluidos .

# Course Guide
:guide_fluidos rdf:type guide:CourseGuide ;
    sch:name "Guía de Aprendizaje - Ingeniería de Fluidos" ;
    guide:teachingPeriod "2025-26" ;
    guide:teachingPeriodMonths "Septiembre-Enero" ;
    guide:inpersonHours "Not specified" ;
    guide:remoteHours "Not specified" ;
    guide:totalHours "Not specified" ;
    sch:inLanguage "Castellano" ;
    sch:instructor :lecturer_jorge_duenas ;
    sch:director :lecturer_jorge_duenas ;
    guide:hasSyllabus :syllabus_fluidos ;
    guide:hasEvaluation :eval_system_fluidos ;
    guide:hasCompetency :comp_ce11, :comp_ce19, :comp_ce23, :comp_cg1, :comp_cg5, :comp_cg6, :comp_cg7 ;
    guide:hasLearningResult :lr_ra324, :lr_ra325, :lr_ra323, :lr_ra326, :lr_ra327, :lr_ra328, :lr_ra150 ;
    guide:hasDidacticResource :res_libro_crespo, :res_ejercicios_web .

# Lecturer
:lecturer_jorge_duenas rdf:type guide:Lecturer ;
    sch:name "Jorge Dueñas Pamplona" ;
    sch:email "jorge.duenas.pamplona@upm.es" ;
    guide:office "10" ;
    guide:tutorshipsSchedule "Sin horario. Contactar previamente con el profesor vía correo electrónico." .

# Syllabus and Items
:syllabus_fluidos rdf:type guide:Syllabus ;
    guide:hasItem :item_leyes_conservacion, :item_masa, :item_momento, :item_energia, :item_flujo_compresible, :item_aerodinamica .

:item_leyes_conservacion rdf:type guide:SyllabusItem ;
    guide:itemIndex 1 ;
    guide:syllabusDescription "Leyes de conservación" .

:item_masa rdf:type guide:SylIabusItem ;
    guide:itemIndex 2 ;
    guide:syllabusDescription "Conservación de la masa" .

# Evaluation System and Trials
:eval_system_fluidos rdf:type guide:EvaluationSystem ;
    guide:evaluationDescription "Existen dos opciones: evaluación progresiva, o evaluación global." ;
    guide:hasEvaluationTrial :trial_pep1, :trial_pep2, :trial_final .

:trial_pep1 rdf:type guide:EvaluationTrial ;
    sch:name "Prueba de evaluación progresiva 1" ;
    guide:evaluationType "Examen Escrito" ;
    guide:evaluationDuration "02:00" ;
    guide:gradePercentage "50%" ;
    guide:minimumScore "4 / 10" ;
    guide:trialWeek "7" ;
    guide:trialMode "Presencial" ;
    guide:involvesCompetency :comp_cg5, :comp_ce11, :comp_ce19 .

:trial_final rdf:type guide:EvaluationTrial ;
    sch:name "Examen final" ;
    guide:evaluationType "Examen Escrito" ;
    guide:evaluationDuration "02:30" ;
    guide:gradePercentage "100%" ;
    guide:minimumScore "5 / 10" ;
    guide:trialWeek "17" ;
    guide:trialMode "Presencial" .

# Competencies
:comp_ce11 rdf:type guide:Competency ;
    guide:competencyCode "CE11" ;
    guide:competencyDescription "Comprender las leyes generales de la mecánica y aplicarlas a la resolución de problemas propios de la ingeniería." .

:comp_cg5 rdf:type guide:Competency ;
    guide:competencyCode "CG5" ;
    guide:competencyDescription "Saber comunicar los conocimientos y conclusiones, tanto de forma oral, escrita y gráfica, a públicos especializados y no especializados de un modo claro y sin ambigüedades." .

# Learning Results
:lr_ra324 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA324" ;
    guide:learningResultDescription "Poseer capacidad para diseñar, desarrollar, implementar, gestionar y mejorar productos, sistemas y procesos en los distintos ámbitos industriales." .

# Didactic Resources
:res_libro_crespo rdf:type guide:DidacticResource ;
    guide:bibliographyTitle "Mecánica de Fluidos" ;
    guide:bibliographyDescription "A. Crespo Martinez" ;
    guide:bibliographyType "Libro" .

:res_ejercicios_web rdf:type guide:DidacticResource ;
    sch:name "Colección de ejercicios y exámenes resueltos" ;
    guide:bibliographyType "Recursos web" .

# Activities (from Schedule)
:act_teoria_sem1 rdf:type guide:Activity ;
    guide:activityDescription "Clase de teoría" ;
    guide:activityDuration 1.16 ;
    guide:activityFormat "Lección Magistral" ;
    guide:attendanceType "Presencial" .

:act_problemas_sem1 rdf:type guide:Activity ;
    guide:activityDescription "Clase de problemas" ;
    guide:activityDuration 1.16 ;
    guide:activityFormat "Clase de Problemas" ;
    guide:attendanceType "Presencial" .

# Previous Knowledge
:knowledge_previo rdf:type guide:RequiredKnowledge ;
    guide:previousKnowledge "Ecuaciones Diferenciales, Mecanica De Fluidos E Hidraulica, Mecanica, Algebra, Termodinamica" ;
    guide:previousCourses "Conocimientos básicos de programación (Matlab u otros)" .