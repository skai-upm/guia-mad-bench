    sch:email "jesusmaria.rodriguez@upm.es" ;
    guide:office "L.Aerop. ETSIA" .

# Competencies
guide:Competency_CE59 rdf:type guide:Competency ;
    guide:competencyCode "CE59" ;
    guide:competencyDescription "Conocimiento adecuado y aplicado a la Ingeniería de: Los métodos de cálculo y de desarrollo de las diferentes soluciones de edificación y pavimentación de aeropuertos..." .

guide:Competency_CE60 rdf:type guide:Competency ;
    guide:competencyCode "CE60" ;
    guide:competencyDescription "Conocimiento aplicado de: edificación; electricidad; electrotecnia; electrónica; mecánica del vuelo; hidráulica; instalaciones aeroportuarias..." .

guide:Competency_CG3 rdf:type guide:Competency ;
    guide:competencyCode "CG3" ;
    guide:competencyDescription "Capacidad para identificar y resolver problemas aplicando, con creatividad, los conocimientos adquiridos" .

guide:Competency_CG5 rdf:type guide:Competency ;
    guide:competencyCode "CG5" ;
    guide:competencyDescription "Liderazgo de equipos y organizaciones" .

guide:Competency_CG9 rdf:type guide:Competency ;
    guide:competencyCode "CG9" ;
    guide:competencyDescription "Razonamiento crítico y capacidad de asociación que posibiliten el aprendizaje continuo" .

# Learning Results
guide:LearningResult_RA72 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA72" ;
    guide:learningResultDescription "Conocimiento, comprensión, aplicación y análisis de las diferentes tipologías de cimentación calculando las cargas de hundimiento en cimentaciones." .

guide:LearningResult_RA300 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA300" ;
    guide:learningResultDescription "Capacidad de análisis y síntesis para saber redactar e interpretar informes técnicos referentes a ensayos geotécnicos" .

guide:LearningResult_RA70 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA70" ;
    guide:learningResultDescription "Conocimiento, comprensión, análisis y valoración de los distintos tipos de suelo identificando su composición..." .

guide:LearningResult_RA71 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA71" ;
    guide:learningResultDescription "Conocimiento y aplicación de los ensayos tipo a realizar en los suelos para identificarlos y determinar su comportamiento." .

# Syllabus
guide:Syllabus_Geotecnia rdf:type guide:Syllabus ;
    guide:hasItem guide:SyllabusItem_1, guide:SyllabusItem_2, guide:SyllabusItem_3, guide:SyllabusItem_4, guide:SyllabusItem_5, guide:SyllabusItem_6, guide:SyllabusItem_7, guide:SyllabusItem_8 .

guide:SyllabusItem_1 rdf:type guide:SyllabusItem ;
    guide:itemIndex 1 ;
    guide:syllabusDescription "ORIGEN DE LOS SUELOS Y SUS PROPIEDADES FÍSICAS." .

guide:SyllabusItem_2 rdf:type guide:SyllabusItem ;
    guide:itemIndex 2 ;
    guide:syllabusDescription "IDENTIFICACIÓN Y CLASIFICACIÓN DE SUELOS." .

guide:SyllabusItem_3 rdf:type guide:SyllabusItem ;
    guide:itemIndex 3 ;
    guide:syllabusDescription "EL AGUA EN EL TERRENO." .

guide:SyllabusItem_4 rdf:type guide:SyllabusItem ;
    guide:itemIndex 4 ;
    guide:syllabusDescription "COMPRESIBILIDAD E HINCHAMIENTO DE SUELOS" .

guide:SyllabusItem_5 rdf:type guide:SyllabusItem ;
    guide:itemIndex 5 ;
    guide:syllabusDescription "RESISTENCIA Y ELASTICIDAD" .

guide:SyllabusItem_6 rdf:type guide:SyllabusItem ;
    guide:itemIndex 6 ;
    guide:syllabusDescription "RECONOCIMIENTOS GEOTÉCNICOS DE CAMPO." .

guide:SyllabusItem_7 rdf:type guide:SyllabusItem ;
    guide:itemIndex 7 ;
    guide:syllabusDescription "ESTABILIDAD DE TALUDES" .

guide:SyllabusItem_8 rdf:type guide:SyllabusItem ;
    guide:itemIndex 8 ;
    guide:syllabusDescription "CIMENTACIONES." .

# Evaluation System
guide:EvalSystem_Geotecnia rdf:type guide:EvaluationSystem ;
    guide:evaluationDescription "La evaluación continua se realizará mediante dos pruebas de evaluación intermedia..." ;
    guide:hasEvaluationTrial guide:Trial_Intermedia, guide:Trial_Global, guide:Trial_Extraordinario .

guide:Trial_Intermedia rdf:type guide:EvaluationTrial ;
    guide:trialType "Prueba de Evaluación Intermedia" ;
    guide:evaluationType "Evaluación Progresiva" ;
    guide:gradePercentage "40%" ;
    guide:minimumScore "5 / 10" ;
    guide:trialMode "Presencial" .

guide:Trial_Global rdf:type guide:EvaluationTrial ;
    guide:trialType "Examen ordinario" ;
    guide:evaluationType "Evaluación Global" ;
    guide:gradePercentage "80%" ;
    guide:minimumScore "5 / 10" ;
    guide:trialMode "Presencial" .

