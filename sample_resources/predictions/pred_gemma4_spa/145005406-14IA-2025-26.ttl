# Degree and University Center
guide:Degree_Aeroespacial rdf:type guide:BachelorDegree ;
    sch:name "14IA - Grado En Ingeniería Aeroespacial" ;
    guide:degreeCode "14IA" ;
    guide:hasCourse guide:Course_Geotecnia .

guide:ETSIA_Center rdf:type guide:UniversityCenter ;
    sch:name "E.T.S.I. Aeronáutica Y Del Espacio" ;
    guide:offers guide:Degree_Aeroespacial .

# Course
guide:Course_Geotecnia rdf:type guide:Course ;
    sch:name "145005406 - Geotecnia" ;
    sch:courseCode 145005406 ;
    guide:courseType "Obligatoria" ;
    guide:semester "Quinto semestre" ;
    sch:hasCourseInstance guide:CourseGuide_Geotecnia_2025_26 .

# Course Guide Instance
guide:CourseGuide_Geotecnia_2025_26 rdf:type guide:CourseGuide ;
    sch:name "Guía de Aprendizaje - Geotecnia" ;
    sch:description "Introducción a los conceptos básicos de la Geontenia como disciplina de la Geología Aplicada..." ;
    guide:teachingPeriod "2025-26" ;
    guide:periodStartingMonth "Septiembre" ;
    guide:periodEndingMonth "Enero" ;
    guide:numberOfCredits 3.0 ;
    sch:inLanguage "Castellano" ;
    guide:hasSyllabus guide:Syllabus_Geotecnia ;
    guide:hasCompetency guide:Competency_CE59, guide:Competency_CE60, guide:Competency_CG3, guide:Competency_CG5, guide:Competency_CG9 ;
    guide:hasLearningResult guide:LearningResult_RA72, guide:LearningResult_RA300, guide:LearningResult_RA70, guide:LearningResult_RA71 ;
    guide:hasEvaluation guide:EvalSystem_Geotecnia ;
    guide:hasDidacticResource guide:Resource_Moodle, guide:Resource_CEDEX, guide:Resource_ITGE ;
    sch:instructor guide:Lecturer_Antonia_Pacios, guide:Lecturing_Angel_Paris, guide:Lecturing_Manuel_Tarifa, guide:Lecturing_Jesus_Rodriguez .

