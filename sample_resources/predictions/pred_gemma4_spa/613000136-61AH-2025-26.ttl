# Syllabus
:syllabus_613000136 rdf:type guide:Syllabus ;
    guide:hasItem :item_bloque_I, :item_bloque_II .

:item_bloque_I rdf:type guide:SyllabusItem ;
    guide:itemIndex 1 ;
    guide:syllabusDescription "Bloque I (Investigación): El conocimiento y la investigación, Impacto y diseminación, Redacción, Malas prácticas, Tesis Doctoral." .

:item_bloque_II rdf:type guide:SyllabusItem ;
    guide:itemIndex 2 ;
    guide:syllabusDescription "Bloque II (Proyectos): Concepción y diseño, Desarrollo de tema, Formación de equipo, Proyectos competitivos, Transferencia, Foros." .

