# Competencies
:Comp_CE12 rdf:type guide:Competency ;
    guide:competencyCode "CE 1.2" ;
    guide:competencyDescription "Capacidad para empre．emprender acciones relacionadas con la gestión forestal" .

:Comp_CE21 rdf:type guide:Competency ;
    guide:competencyCode "CE 2.1" ;
    guide:competencyDescription "Capacidad para diseñar, redactar y gestionar planes y políticas de prevención y detección de incendios" .

:Comp_CG5 rdf:type guide:Competency ;
    guide:competencyCode "CG 5" ;
    guide:competencyDescription "Búsqueda bibliográfica, análisis de documentación y tratamiento de la información..." .

:Comp_CG6 rdf:type guide:Competency ;
    guide:competencyCode "CG 6" ;
    guide:competencyDescription "Perfeccionar el conocimiento oral y escrito de la lengua inglesa" .

# Learning Results
:LR_RA45 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA45" ;
    guide:learning .learningResultDescription "Que los estudiantes tengan conocimientos para crear e interpretar cartografía temática..." .

:LR_RA43 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA43" ;
    guide:learningResultDescription "Capacidad para poner en práctica técnicas de selvicultura preventiva y de reducción del combustible en el monte" .

