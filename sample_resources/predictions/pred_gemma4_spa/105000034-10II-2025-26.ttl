    guide:degreeCode "10II" ;
    guide:hasCourse :course_105000034 .

:university_center_ets a guide:UniversityCenter ;
    sch:name "E.T.S. de Ingenieros Informáticos" ;
    guide:offers :degree_10II .

# Course and Course Guide
:course_105000034 a guide:Course ;
    sch:name "Proyecto De Instalacion Informatica" ;
    sch:courseCode 105000034X ; # Adjusted to integer-compatible if possible, or string
    guide:courseType "Obligatoria" ;
    sch:hasCourseInstance :course_guide_105000034 .

:course_guide_105000034 a guide:CourseGuide ;
    sch:name "Guía de Aprendizaje - Proyecto De Instalacion Informatica" ;
    guide:numberOfCredits 3.0 ;
    guide:teachingPeriod "2025-26" ;
    guide:periodStartingMonth "Febrero" ;
    guide:periodEndingMonth "Junio" ;
    sch:inLanguage "Castellano" ;
    guide:hasCompetency :comp_cg1_21, :comp_cg2_ce45, :comp_ce32, :comp_ce36 ;
    guide:hasLearningResult :lr_ra564, :lr_ra562, :lr_ra563 ;
    guide:hasEvaluation :eval_system_progressive ;
    sch:instructor :lecturer_juan_carlos ;
    sch:director :lecturer_juan_carlos ;
    guide:hasSyllabus :syllabus_105000034 ;
    guide:hasDidacticResource :res_moodle, :res_book_inst ;
    sch:courseSchedule :schedule_105000034 .

