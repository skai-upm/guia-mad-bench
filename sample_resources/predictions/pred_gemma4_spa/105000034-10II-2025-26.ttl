# Competencies
:comp_cg1_21 a guide:Competency ;
    guide:competencyCode "CG-1/21" ;
    guide:competencyDescription "Capacidad de resolución de problemas aplicando conocimientos de matemáticas, ciencias e ingeniería." .

:comp_cg2_ce45 a guide:Competency ;
    guide:competencyCode "CG-2/CE45" ;
    guide:competencyDescription "Capacidad para el aprendizaje autónomo y la actualización de conocimientos, y reconocimiento de su necesidad en el área de la informática." .

:comp_ce32 a guide:Competency ;
    guide:competencyCode "Ce 32" ;
    guide:competencyDescription "Comprender el concepto de ciclo de vida, que abarca el significado de sus fases (planificación, desarrollo, instalación y evolución)..." .

:comp_ce36 a guide:Competency ;
    guide:competencyCode "Ce 36" ;
    guide:competencyDescription "Capacidad para diseñar, planificar, documentar y presupuestar la instalación de un sistema hardware y de puestos de trabajo en un espacio físico." .

# Learning Results
:lr_ra564 a guide:LearningResult ;
    guide:learningResultCode "RA564" ;
    guide:learningResultDescription "Comprender y aplicar los principios de diseño y gestión integrada de la infraestructura de una instalación informática" .

:lr_ra562 a guide:LearningResult ;
    guide:learningResultCode "RA562" ;
    guide:learningResultDescription "Seleccionar y definir las especificaciones de funcionamiento de equipos informáticos." .

:lr_ra563 a guide:LearningResult ;
    guide:learningResultCode "RA56 $\text{63}$" ;
    guide:learningResultDescription "Comprender y aplicar los principios tecnológicos involucrados en una instalación informática (eléctricos, electro-magnéticos, térmicos y mecánicos)." .

# Syllabus
:syllabus_105000034 a guide:Syllabus ;
    guide:hasItem :item_intro, :item_refrigeracion, :item_instalacion, :item_seguridad, :item_alimentacion, :item_cableado, :item_emc, :item_multicomputador .

:item_intro a guide:SyllabusItem ;
    guide:syllabusDescription "Introducción: Tipos de instalaciones, Especificaciones, Ciclo de vida, Criterios generales." .

:item_refrigeracion a guide:SyllabusItem ;
    guide:syllabusDescription "Refrigeración: El agua, Sicrometría, Transferencia del calor, Sistemas de refrigeración." .

# Evaluation System
:eval_system_progressive a guide:EvaluationSystem ;
    guide:evaluationDescription "Evaluación progresiva mediante entregables y examen global." ;
    guide:hasEvaluationTrial :trial_propuesta, :trial_tabla, :trial_infra, :trial_electrotecnia, :trial_termotecnia, :trial_cableado, :trial_memoria_final, :trial_examen_global .

:trial_propuesta a guide:EvaluationTrial ;
    guide:trialType "TG" ;
    guide:gradePercentage "5%" ;
    guide:minimumScore "5/10" ;
    guide:involvesCompetency :comp_cg1_21, :comp_ce32 .

:trial_examen_global a guide:EvaluationTrial ;
    guide:trialType "OT" ;
    guide:gradePercentage "100%" ;
    guide:minimumScore "5/1 $\text{10}$" ;
    guide:eventSchedule :event_week16 .

# Schedule and Events
