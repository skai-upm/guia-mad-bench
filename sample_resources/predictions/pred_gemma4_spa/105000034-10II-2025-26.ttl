    guide:activityDuration 2.0 ;
    guide:activityFormat "Lección Magistral" ;
    guide:attendanceType "Presencial" .

:event_week16 a guide:ScheduleEvent ;
    guide:eventWeek "Semana 16" ;
    guide:hasActivity :act_examen_global .

:act_examen_global a guide:Activity ;
    guide:activityDescription "Examen Global: Desarrollo de un proyecto" ;
    guide:activityDuration 3.0 ;
    guide:activityFormat "OT" ;
    guide:attendanceType "Presante" .

