# Competencies
:comp_MUEI_CB06 a guide:Competency ;
    guide:competencyCode "MUEI.CB06" ;
    guide:competencyDescription "Poseer y comprender conocimientos que aporten una base u oportunidad de ser originales en el desarrollo y/o aplicación de ideas, a menudo en un contexto de investigación" .

:comp_MUEI_CB07 a guide:Competency ;
    guide:competencyCode "MUEI.CB07" ;
    guide:competencyDescription "Que los estudiantes sepan aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en entornos nuevos o poco conocidos dentro de contextos más amplios (o multidisciplinares) relacionados con su área de estudio" .

:comp_MUEI_CE01 a guide:Competency ;
    guide:competencyCode "MUEI.CE01" ;
    guide:competencyDescription "Comprender, diseñar y analizar sistemas y componentes electrónicos en el ámbito de la electrónica industrial. Modelización y caracterización de sistemas electrónicos complejos." .

:comp_MUEI_CT01 a guide:Competency ;
    guide:competencyCode "MUEI.CT01" ;
    guide:competencyDescription "Uso de la lengua inglesa" .

# Learning Results
:lr_RA43 a guide:LearningResult ;
    guide:learningResultCode "RA43" ;
    guide:learningResultDescription "Identificar, analizar, e interpretar los datos de problemas relacionados con el tráfico y el transporte" .

:lr_RA41 a guide:LearningResult ;
    guide:learningResultCode "RA41" ;
    guide:learningResultDescription "Conocer los conceptos relacionados con el transporte y sus modos" .

:lr_RA42 a guide:LearningResult ;
    guide:learningResultCode "RA42" ;
    guide:learningResultDescription "Conocer las distintas tecnologías relativas a la seguridad de los vehículos automóviles" .

:lr_RA40 a guide:LearningResult ;
    guide:learningResultCode "RA40" ;
    guide:learningResultDescription "Capacidad para analizar la influencia de determinadas variables en la eficiencia de un proceso" .

:lr_RA44 a guide:LearningResult ;
    guide:learningResultCode "RA44" ;
    guide:learningResultDescription "Identificar los retos medioambientales del transporte por carretera" .

# Syllabus
:syllabus_smartgrids a guide:Syllabus ;
    guide:hasItem :item_1, :item_2, :item_3, :item_4, :item_5, :item_6, :item_7, :item_8, :item_9, :item_10, :item_11 .

:item_1 a guide:SyllabusItem ;
    guide:itemIndex 1 ;
    guide:syllabusDescription "Introduction to Smart Grids and Microgrids" .

:item_2 a guide:SyllabusItem ;
    guide:itemIndex 2 ;
    guide:syllabusDescription "Architectures of AC and DC Microgrids. Different topologies" .

:item_3 a guide:SyllabusItem ;
    guide:itemIndex 3 ;
    guide:syllabusDescription "The role of Power Electronics in Smart Grids and Microgrids" .

:item_4 a guide:SyllabusItem ;
    guide:itemIndex 4 ;
    guide:syllabusDescription "AC Microgrids. Power Converters in AC Microgrids. Grid-connected mode. Islanded mode. Hierarchical Control" .

:item_5 a guide:SyllabusItem ;
    guide:itemIndex 5 ;
    guide:syllabusDescription "Synchronization Techniques. PLLs, DSOGI, etc." .

:item_6 a guide:SyllabusItem ;
    guide:imdex 6 ;
    guide:syllabusDescription "PWM Techniques. Space Vector Modulation" .

:item_7 a guide:SyllabusItem ;
    guide:itemIndex 7 ;
    guide:syllabusDescription "Park Transformation review. dq controllers in power converters" .

:item_8 a guide:SyllabusItem ;
    guide:itemIndex 8 ;
    guide:syllabusDescription "An exercise of a 3-phase power inverter in grid-connected mode using Matlab/Simulink" .

:item_9 a guide:SyllabusItem ;
    guide:itemIndex 9 ;
    guide:syllabusDescription "DC Microgrids. Advantages and disadvantages in DC Power Distribution" .

:item_10 a guide:SyllabusItem ;
    guide:itemIndex 10 ;
    guide:syllabusDescription "Power Converters in DC Distribution. Droop Control in DC Microgrids" .

:item_11 a guide:SyllabusItem ;
    guide:itemIndex 11 ;
    guide:syllabusDescription "DC Bus Signalling as a control strategy in DC distribution. Models and Simulation" .

