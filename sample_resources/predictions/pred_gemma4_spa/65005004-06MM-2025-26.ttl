# Syllabus
:Syllabus_Laboreo rdf:type guide:Syllabus ;
    guide:hasItem :SyllabusItem_B1, :SyllabusItem_B2, :SyllabusItem_B3, :SyllabusItem_B4, :SyllabusItem_B5, :SyllabusItem_B6 .

