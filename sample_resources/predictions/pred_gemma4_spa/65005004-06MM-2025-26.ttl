# Competencies
:Comp_C1 rdf:type guide:Competency ;
    sch:name "C1" ;
    guide:competencyDescription "Comprender y utilizar los principios de la extracción de materias primas de origen mineral." .

:Comp_C14 rdf:type guide:Competency ;
    sch:name "C14" ;
    guide:competencyDescription "Capacidad de trabajar en un entorno bilingüe (inglés-castellano)." .

:Comp_C15 rdf:type guide:Competency ;
    sch:name "C15" ;
    guide:competencyDescription "Capacidad para organizar y planificar en el ámbito de la empresa, y otras instituciones y organizaciones de proyectos y equipos humanos." .

:Comp_C2 rdf:type guide:Competency ;
    sch:name "C2" ;
    guide:competencyDescription "Comprender y aplicar el diseño, operación y mantenimiento de plantas de preparación y tratamiento de minerales, rocanes industriales, rocas ornamentales y residuos." .

# Learning Results
:LR_RA17_RA197 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA17 - RA197" ;
    guide:learningResultDescription "Relacionar las propiedades de minerales y rocas con su empleo." .

:LR_RA49 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA49" ;
    guide:learningResultDescription "Conocer, comprender y utilizar las técnicas de extracción, de transformación y elaboración de la piedra natural." .

:LR_RA19_RA199 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA19 - RA199" ;
    guide:learningResultDescription "Aplicar los datos teóricos de composición y estructura, en casos concreticos, a la posibilidad de explotación de estos materiales." .

