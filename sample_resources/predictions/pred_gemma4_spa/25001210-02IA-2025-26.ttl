# Competencies
guide:CE14 rdf:type guide:Competency ;
    guide:competencyCode "CE14" ;
    guide:competencyDescription "Conocimiento de los conceptos básicos de Ecología, sus objetivos, metodología y modo de estudiar el biotopo, la biocenosis y sus relaciones." .

guide:CE47 rdf:type guide:Competency ;
    guide:competencyCode "CE47" ;
    guide:competencyDescription "Capacitar para el análisis y conservación de la biodiversidad y describir los métodos de caracterización de la gestión de recursos biológicos en los agroecosistemas." .

guide:CG6 rdf:type guide:Competency ;
    guide:competencyCode "CG6" ;
    guide:competencyDescription "Transmitir con claridad y rigor información, ideas, $\text{problemas}$ y soluciones de forma oral y escrita" .

# Learning Results
guide:RA80 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA80" ;
    guide:learningResultDescription "Conocimientos sobre el medio físico y los componentes biológicos de los ecosistemas." .

guide:RA83 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA83" ;
    guide:learningResultDescription "Utilizar modelos informáticos en estudio de ecosistemas." .

# Syllabus and Items
guide:Ecologia_Syllabus rdf:type guide:Syllabus ;
    guide:hasItem guide:Topic_1, guide:Topic_2, guide:Topic_3 .

guide:Topic_1 rdf:type guide:SyllabusItem ;
    guide:itemIndex 1 ;
    guide:syllabusDescription "Introducción a la Ecología. Definición. Datos históricos. Conceptos básicos utilizados en Ecología." .

guide:Topic_2 rdf:type guide:SyllabusItem ;
    guide:itemIndex 2 ;
    guide:syllabusDescription "Los organismos y el medio. Recursos y condiciones del medio físico. Hábitat. Factores ambientales." .

# Evaluation System and Trials
guide:Ecologia_EvalSystem rdf:type guide:EvaluationSystem ;
    guide:evaluationDescription "La calificación será la media ponderada de informes, trabajos cooperativos, exámenes de prácticas y exámenes teóricos." ;
    guide:hasEvaluationTrial guide:P01_Informe, guide:Prueba_Prog_Exam, guide:Examen_Practicas .

guide:P01_Informe rdf:type guide:EvaluationTrial ;
    guide:trialType "Trabajo Individual" ;
    guide:gradePercentage "4%" ;
    guide:trialMode "No Presencial" .

guide:Prueba_Prog_Exam rdf:type guide:EvaluationTrial ;
    guide:trialType "Examen Escrito" ;
    guide:gradePercentage "32.5%" ;
    guide:trialMode "Presencial" .

