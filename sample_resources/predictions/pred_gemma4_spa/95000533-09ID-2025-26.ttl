# Competencies
:comp_CB01 rdf:type guide:Competency ;
    guide:competencyCode "CB01" ;
    guide:competencyDescription "Que los estudiantes hayan demostrado poseer y comprender conocimientos en un área de estudio..." .

:comp_CE04 rdf:type guide:Competency ;
    guide:competencyCode "CE04" ;
    guide:competencyDescription "Que los estudiantes sean capaces de aplicar los conceptos y tecnologías del ámbito de la ingeniería de las telecomunicación..." .

:comp_CG01 rdf:type guide:Competency ;
    guide:competencyCode "CG01" ;
    guide:competencyDescription "Tener capacidad de trabajar en entornos internacionales y multidisciplinares, haciendo uso de la lengua inglesa..." .

# Learning Results
:lr_RA112 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA112" ;
    guide:learningResultDescription "Analizar las tecnologías necesarias para implementar un caso de estudio." .

:lr_RA110 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA110" ;
    guide:learningResultDescription "Saber identificar y definir los requisitos de un proyecto en ingeniería de datos y sistemas." .

