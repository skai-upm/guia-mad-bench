# Course Guide Instance
:course_95000533 rdf:type guide:CourseGuide ;
    sch:name "Proyectos En Ingeniería De Datos Y Sistemas" ;
    sch:courseCode 95000533 ;
    guide:numberOfCredits 9.0 ;
    guide:courseType "Obligatoria" ;
    guide:teachingPeriod "2025-26" ;
    guide:periodStartingMonth "Septiembre" ;
    guide:periodEndingMonth "Enero" ;
    sch:inLanguage "Castellano" ;
    sch:description "El objetivo principal de la asignatura es introducir a los estudiantes en la ejecución de proyectos en ingeniería de datos y sistemas, a partir de casos de estudio." ;
    guide:hasCompetency :comp_CB01, :comp_CB02, :comp_CB05, :comp_CE04, :comp_CE05, :comp_CE18, :comp_CE19, :comp_CE21, :comp_CG01, :comp_CG02, :comp_CG03, :comp_CG04, :comp_CG05, :comp_CG06, :comp_CG07, :comp_CG10, :comp_CG11 ;
    guide:hasLearningResult :lr_RA112, :lr_RA110, :lr_RA111, :lr_RA113 ;
    guide:hasEvaluation :eval_system_prog ;
    guide:hasSyllabus :syllabus_main ;
    sch:instructor :lecturer_fraile, :lecturer_gutierrez, :lecturer_fernandez, :lecturer_vinagre, :lecturer_sanchez, :lecturer_cabrera ;
    sch:director :lecturer_cabrera .

