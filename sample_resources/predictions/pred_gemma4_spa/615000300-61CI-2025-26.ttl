:schedule_databases a guide:Schedule ;
    sch:eventSchedule :event_week_1, :event_week_2, :event_week_3, :event_week_4, :event_week_5, :event_week_6, :event_week_7, :event_week_8, :event_week_9, :event_week_10, :event_week_12, :event_week_13, :event_week_14, :event_week_15, :event_week_17 .

