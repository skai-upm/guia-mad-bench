    sch:name "Ordenador" ;
    guide:bibliographyType "Equipamiento" ;
    guide:bibliographyDescription "Ordenador para la realización de las prácticas de la asignatura"@en .

:res_book_elmasri a guide:DidacticResource ;
    guide:bibliographyTitle "Fundamentos de sistemas de bases de datos" ;
    guide:bibliographyDescription "Elmasri, R. A., & Navathe, S. B. (2007). Addison Wesley."@en .

:res_book_silberschatz a guide:DidacticResource ;
    guide:bibliographyTitle "Fundamentos de bases de datos" ;
    guide:bibliographyDescription "Silberschatz, A., Korth, H. F., et al. (2002)."@en .

:res_book_date a guide:DidacticResource ;
    guide:bibliographyTitle "Introducción a los sistemas de bases de datos" ;
    guide:bibliographyDescription "Date, C. J. (2001). Pearson Educación."@en .

