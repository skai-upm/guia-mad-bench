# Course Guide Instance
:course_guide_databases a guide:CourseGuide ;
    sch:name "Bases De Datos" ;
    guide:courseYear 2025 ;
    guide:numberOfCredits 9.0 ;
    guide:teachingPeriod "2025-26" ;
    guide:semester "Tercer semestre" ;
    guide:courseType "Obligatoria" ;
    guide:inpersonHours "No especificado" ;
    guide:remoteHours "No especificado" ;
    guide:totalHours "No especificado" ;
    guide:hasLearningResult :lr_ra1, :lr_ra2, :lr_ra7, :lr_ra6, :lr_ra3, :lr_ra4, :lr_ra5 ;
    guide:hasCompetency :comp_cb01, :comp_cc12, :comp_cc13, :comp_cc7, :comp_ct1, :comp_ct2 ;
    guide:hasEvaluation :eval_system_progressive, :eval_system_global ;
    guide:hasDidacticResource :res_moodle, :res_ordenador, :res_book_elmasri, :res_book_silberschatz, :res_book_date ;
    sch:instructor :lecturer_fernando_ortega ;
    sch:courseSchedule :schedule_databases .

# Course Instance
:course_databases a guide:Course ;
