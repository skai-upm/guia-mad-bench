    guide:bibliographyType "Bibliografía" .

:res_cengel rdf:type guide:DidacticResource ;
    guide:bibliographyTitle "Termodinámica, Çengel, Y.A., Boles, M.A. y Kanoglu, M." ;
    guide:bibliographyType "Bibliografía" .

:res_perez_notario rdf:type guide:DidacticResource ;
    guide:bibliographyTitle "'Termodinámica: estructura y aplicaciones. Parte I', P. Pérez del Notario" ;
