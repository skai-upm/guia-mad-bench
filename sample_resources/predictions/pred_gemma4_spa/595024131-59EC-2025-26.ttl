# Competencies
:comp_EC01 rdf:type guide:Competency ;
    guide:competencyCode "CE EC01" ;
    guide:competencyDescription "Capacidad de construir, explotante y gestionar sistemas de captación, transporte, representación, procesado, almacenamiento, gestión y presentación de información multimedia..." .

:comp_SC01 rdf:type guide:Competency ;
    guide:competencyCode "CE SC01" ;
    guide:competencyDescription "Capacidad para construir, explotar y gestionar las redes, servicios, procesos y aplicaciones de telecomunicaciones..." .

:comp_CG02 rdf:type guide:Competency ;
    guide:competencyCode "CG 02" ;
    guide:competencyDescription "Capacidad de búsqueda y selección de información, de razonamiento crítico y de elaboración y defensa de argumentos dentro del área." .

# Learning Results
:lr_RA170 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA170" ;
    guide:learningResultDescription "Comprensión y manejo de las señales de audio y video (digitalización, formatos y sistemas de codificación)" .

:lr_RA408 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA408" ;
    guide:learningResultDescription "Conocer los aspectos específicos en la digitalización de la señal de audio." .

# Evaluation System
:eval_system_prog rdf:type guide:EvaluationSystem ;
    guide:evaluationDescription "La evaluación de la asignatura es del tipo progresiva: suma de todos los controles de clase donde se incluye el control de laboratorio y el proyecto de diseño." ;
    guide:hasEvaluationTrial :trial_control1, :trial_control2, :trial_control3, :trial_control4, :trial_control5 .

:trial_control1 rdf:type guide:EvaluationTrial ;
    guide:trialType "Prueba Telemática" ;
    guide:gradePercentage "18%" ;
    guide:minimumScore "4 / 10" ;
    guide:evaluationDuration "00:10" ;
    guide:eventWeek "4" .

