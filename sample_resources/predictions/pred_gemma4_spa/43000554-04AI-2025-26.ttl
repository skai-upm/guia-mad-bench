# Competencies
guide:MICCPCE38
    rdf:type guide:Competency ;
    guide:competencyCode "MICCPCE3．38" ;
    guide:competencyDescription "Capacidad para integrar y aplicar los conocimientos técnicos en asesoría, análisis, diseño y modelización físico-matemática en ingeniería estructural." .

guide:MICCPCGP11
    rdf:type guide:Competency ;
    guide:competencyCode "MICCPCGP11" ;
    guide:competencyDescription "Capacidad para el proyecto, ejecución e inspección de estructuras (puentes, edificaciones, etc.), de obras de cimentación y de obras subterráneas de uso civil (túneles, aparcamientos), y el diagnóstico sobre su integridad." .

guide:MICCPCT01
    rdf:type guide:Competency ;
    guide:competencyCode "MICCPCT01" ;
    guide:competencyDescription "Capacidad de preparar y presentar comunicaciones orales, escritas y gráficas, estructurada y argumentadamente." .

guide:MICCPCT03
    rdf:type guide:Competency ;
    guide:competencyCode "MICCPCT03" ;
    guide:competencyDescription "Capacidad de comunicación técnica oral y escrita en lengua inglesa." .

guide:MICCPCT08
    rdf:<0xC2>type guide:Competency ;
    guide:competencyCode "MICCPCT08" ;
    guide:competencyDescription "Capacidad de diseñar, analizar e interpretar experimentos relevantes en ingeniería civil." .

# Learning Results
guide:RA121
    rdf:type guide:LearningResult ;
    guide:learningResultCode "RA121" ;
    guide:learningResultDescription "The student knows the fundamentals and applications of the most relevant transducers for instrumentation of structures." .

guide:RA122
    rdf:type guide:LearningResult ;
    guide:learningResultCode "RA122" ;
    guide:learningResultDescription "The student acquires the fundamentals of static and dynamic experimental techniques in structural engineering, and understands the structural implications of taken measurements." .

