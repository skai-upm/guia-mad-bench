# Course Guide Instance
guide:GA_04AI_43000554_2025_26
    rdf:type guide:CourseGuide ;
    sch:name "Experimental Structural Analysis" ;
    sch:description "This course deals with the fundamentals and applications of experimental techniques in structural engineering. This course is divided into three parts: the first part is aimed at the study of instrumentation techniques and equipment; the second part deals with the design of load tests in bridges and buildings; the goal of the last part is the study of dynamic testing techniques." ;
    guide:numberOfCredits 4.5 ;
    guide:courseType "Optional/elective" ;
    guide:teachingPeriod "2025-26" ;
    guide:periodStartingMonth "September" ;
    guide:periodEndingMonth "January" ;
    sch:inLanguage "English" ;
    sch:instructor guide:Carlos_Martin_De_La_Concha_Renedo ;
    sch:director guide:Carlos_Zanuy_Sanches ;
    guide:hasSyllabus guide:Syllabus_ExpStructAnal ;
    guide:hasCompetency guide:MICCPCE38, guide:MICCPCGP11, guide:MICCPCT01, guide:MICCPCT03, guide:MICCPCT08 ;
    guide:hasLearningResult guide:RA121, guide:RA122 ;
    guide:hasEvaluation guide:EvalSystem_ExpStructAnal ;
    sch:courseSchedule guide:Schedule_ExpStructAnal ;
    guide:hasDidacticResource guide:Moodle_Platform, guide:Book_Instrumentacion_Aplicada, guide:Book_Modal_Testing, guide:Book_Analisis_Experimental, guide:Equipment_Lab_Structures ;
    guide:otherInformation "Semester 3" .

