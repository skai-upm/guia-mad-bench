# --- Evaluation System and Trials ---

data:EvaluationSystem_53002093 rdf:type guide:EvaluationSystem ;
    guide:evaluationDescription "La Evaluación Progresiva (EP) consta de un trabajo práctico y un trabajo al final de la asignatura. Existe también una Prueba de Evaluación Global (PEG)." ;
    guide:hasEvaluationTrial data:Trial_Práctica_Ordenador, data:Trial_Trabajo_Aplicacion, data:Trial_PEG .

data:Trial_Práctica_Ordenador rdf:type guide:EvaluationTrial ;
    guide:trialDescription "Práctica de ordenador" ;
    guide:evaluationType "Evaluación Progresiva" ;
    guide:gradePercentage "20%" ;
    guide:minimumScore "0 / 10" ;
    guide:trialMode "Presencial" ;
    guide:involvesCompetency data:Competency_CG01, data:Competency_CG11 .

data:Trial_Trabajo_Aplicacion rdf:type guide:EvaluationTrial ;
    guide:trialDescription "Trabajo sobre aplicación de transformadas en Ingeniería" ;
    guide:evaluationType "Evaluación Progresiva" ;
    guide:gradePercentage "40%" ;
    guide:minimumScore "3 / 10" ;
    guide:trialMode "Presencial" .

data:Trial_PEG rdf:type guide:EvaluationTrial ;
    guide:trialDescription "Prueba de evaluación global (PEG)" ;
    guide:evaluationType "Evaluación Global" ;
    guide:gradePercentage "100%" ;
    guide:minimumScore "5 / 10" ;
    guide:trialMode "Presencial" .

