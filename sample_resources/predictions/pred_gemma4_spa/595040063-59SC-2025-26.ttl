# Competencies
:comp_CE_B2 a guide:Competency ;
    guide:competencyCode "CE B2" ;
    guide:competencyDescription "Conocimientos básicos sobre el uso y programación de los ordenadores, sistemas operativos, bases de datos y programas informáticos con aplicación en ingeniería." .

:comp_CE_SC01 a guide:Competency ;
    guide:competencyCode "CE SC01" ;
    guide:competencyDescription "Capacidad para construir, explotar y gestionar las redes, servicios, procesos y aplicaciones de telecomunicaciones..." .

# Learning Results
:lr_RA1239 a guide:LearningResult ;
    guide:learningResultCode "RA1239" ;
    guide:learningResultDescription "Identificar, comprender y aplicar la sintaxis y semántica de lenguajes para el desarrollo de aplicaciones web actuales" .

:lr_RA1240 a guide:LearningResult ;
    guide:learningResultCode "RA1240" ;
    guide:learningResultDescription "Utiliza entornos y herramientas de desarrollo para la programación de aplicaciones con interfaces en línea de comandos e interfaces gráficas" .

:lr_RA1238 a guide:LearningResult ;
    guide:learningResultCode "RA1238" ;
    guide:learningResultDescription "Implementa, prueba y verifica soluciones atendiendo a criterios de eficacia, legibilidad y documentación" .

:lr_RA1241 a guide:LearningResult ;
    guide:learningResultCode "RA1241" ;
    guide:learningResultDescription "Desarrolla soluciones con tecnologías Web" .

:lr_RA1242 a guide:LearningResult ;
    guide:learningResultCode "RA1242" ;
    guide:learningResultDescription "Utilizar adecuadamente los entornos de desarrollo con herramientas de libre distribución." .

# Syllabus and Items
:syllabus_595040063 a guide:Syllabus ;
    guide:hasItem :item_topic1, :item_topic2, :item_topic3, :item_topic4, :item_topic5 .

:item_topic1 a guide:SyllabusItem ;
    guide:itemIndex 1 ;
    guide:syllabusDescription "Introducción a la asignatura" .

:item_topic2 a guide:SyllabusItem ;
    guide:itemIndex 2 ;
    guide:syllabusDescription "Arquitectura de la WEB (Introducción, Modelo cliente-servidor, URL y HTTP)" .

:item_topic3 a guide:SyllabusItem ;
    guide:itemIndex 3 ;
    guide:syllabusDescription "Tecnologías WEB básicas (Diseño de páginas WEB: HTML, CSS; JavaScript)" .

:item_topic4 a guide:SyllabusItem ;
    guide:itemIndex 4 ;
    guide:syllabusDescription "Tecnologías WEB avanzadas (jQuery, Single Page Applications, Mapas interactivos)" .

:item_topic5 a guide:SyllabusItem ;
    guide:itemIndex 5 ;
    guide:syllabusDescription "Temas avanzados (Terminales móviles: aplicaciones híbridas y nativas; React)" .

