# Competencies
:comp_CB03 a guide:Competency ;
    guide:competencyCode "CB03" ;
    guide:competencyDescription "Que los estudiantes tengan la capacidad de reunir e interpretar datos relevantes para emitir juicios que incluyan una reflexión sobre temas relevantes de índole social, científica - ética" .

:comp_CB04 a guide:Competency ;
    guide:competencyCode "CB04" ;
    guide:competencyDescription "Que los estudiantes puedan transmitir información, ideas, problemas y soluciones a un público tanto especializado como no especializado" .

:comp_CB05 a guide:Competency ;
    guide:competencyCode "CB05" ;
    guide:competencyDescription "Que los estudiantes hayan desarrollado aquellas habilidades de aprendizaje necesarias para emprender estudios posteriores con un alto grado de autonomía" .

:comp_CG13 a guide:Competency ;
    guide:competencyCode "CG13" ;
    guide:competencyDescription "Capacidad para diseñar, dirigir, elaborar, implementar e interpretar proyectos y planes, así como para redactar informes técnicos, memorias de reconocimiento, valoraciones, peritajes y tasaciones." .

:comp_CT1 a guide:Competency ;
    guide:competencyCode "CT1" ;
    guide:competencyDescription "Comunicación oral y escrita. Concluir aportaciones por escrito, desarrollando la capacidad de síntesis y presentación de las ideas propias en un grupo de trabajo y en exposición pública." .

# Learning Results
:lr_RA577 a guide:LearningResult ;
    guide:learningResultCode "RA577" ;
    guide:learningResultDescription "Diseñar un informe ESG adaptado al sector forestal o ambiental." .

:lr_RA575 a guide:LearningResult ;
    guide:learningResultCode "RA575" ;
    guide:learningResultDescription "Comprender el marco legal y normativo actual en sostenibilidad (Taxonomía, SFDR, GRI, ESRS)." .

:lr_RA578 a guide:LearningResult ;
    guide:learningResultCode "RA578" ;
    guide:learningResultDescription "Manejar plataformas y metodologías digitales orientadas a la sostenibilidad 4.0." .

:lr_RA576 a guide:LearningResult ;
    guide:learningResultCode "RA576" ;
    guide:learningResultDescription "Identificar y aplicar los indicadores clave de sostenibilidad en proyectos reales." .

:lr_RA579 a guide:LearningResult ;
    guide:learningResultCode "RA579" ;
    guide:learningResultDescription "Analizar y evaluar la doble materialidad en el contexto de cambio climático." .

# Syllabus
:syllabus_135004815 a guide:Syllabus ;
