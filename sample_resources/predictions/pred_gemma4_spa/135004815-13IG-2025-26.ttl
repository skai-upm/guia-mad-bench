    guide:syllabusDescription "Taxonomía de la UE: objetivos y aplicación" .

:item_topic3 a guide:SyllabusItem ;
    guide:itemIndex 3 ;
    guide:syllabusDescription "ESG: indicadores, riesgos y oportunidades" .

:item_topic4 a guide:SyllabusItem ;
    guide:itemIndex 4 ;
    guide:syllabusDescription "Marcos de reporte no financiero (GRI, ESRS, SFDR)" .

:item_topic5 a guide:SyllabusItem ;
    guide:itemIndex 5 ;
    guide:syllabusDescription "Evaluación de la sostenibilidad y gestión de riesgos climáticos" .

:item_topic6 a guide:SyllabusItem ;
    guide:itemIndex 6 ;
    guide:syllabusDescription "Herramientas digitales para sostenibilidad y reporting" .

:item_topic7 a guide:SyllabusItem ;
    guide:itemIndex 7 ;
    guide:syllabusDescription "Análisis de informes y estudios de caso sectoriales" .

