# Course Guide Instance
:CourseGuide_55001039
    rdf:type guide:CourseGuide ;
    sch:name "Ingenieria Procesos Y Productos" ;
    sch:description "El objetivo de la asignatura es familiarizarse con las distintas etapas necesarias para llevar a cabo el diseño de procesos y productos, de forma que el estudiante sea capaz de realizar un diseño de un proceso y/o producto partiendo de una información acotada." ;
    guide:numberOfCredits 4.5 ;
    guide:courseType "Optativa" ;
    guide:semester "Séptimo semestre" ;
    guide:teachingPeriodMonths "Septiembre-Eral" ;
    guide:teachingPeriod "2025-26" ;
    sch:instructor :MariaGonzalezMiquel ;
    sch:director :MariaGonzalezMiquel ;
    guide:hasCompetency :CE15, :CE19, :CE20, :CE23_ETSII, :CG1, :CG2, :CG3, :CG4, :CG6 ;
    guide:hasLearningResult :RA190, :RA193, :RA194, :RA191, :RA192, :RA302, :RA301, :RA303, :RA300, :RA189 ;
    guide:hasSyllabus :Syllabus_55001039 ;
    guide:hasEvaluation :EvalSystem_55001039 ;
    guide:hasDidacticResource :Res_Notes, :Res_Dimian, :Res_Cussler, :Res_Seider, :Res_Towler, :Res_Smith ;
    sch:courseSchedule :Schedule_55_55001039 .

