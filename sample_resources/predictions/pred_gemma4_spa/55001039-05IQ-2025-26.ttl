# Evaluation System
:EvalSystem_55001039
    rdf:type guide:EvaluationSystem ;
    guide:evaluationDescription "La nota final de la asignatura tiene distintas contribuciones: la nota del Proyecto de Diseño de Procesos dividida en subentregas, la nota del Proyecto de Diseño de Productos, la nota de la Presentación de los Proyectos de Diseño y la nota del Examen Teórico-Práctico." ;
    guide:hasEvaluationTrial :Trial_Week5, :Trial_Week9, :Trial_Week13, :Trial_Week14, :Trial_Week15, :Trial_Week16, :Trial_Week17 .

:Trial_Week5
    rdf:type guide:EvaluationTrial ;
    guide:trialType "Entrega Proyecto Diseño de Procesos (Síntesis del proceso)" ;
    guide:evaluationType "Evaluación Progresiva" ;
    guide:gradePercentage "15%" ;
    guide:minimumScore "5 / 10" ;
    guide:trialMode "No presencial" ;
    guide:hasScheduleEvent :Event_Week5 .

:Trial_Week15
    rdf:type guide:EvaluationTrial ;
    guide:trialType "Examen Teórico-Práctico" ;
    guide:evaluationType "Evaluación Progresiva" ;
    guide:gradePercentage "30%" ;
    guide:minimumScore "5 / 10" ;
    guide:trialMode "Presencial" ;
    guide:hasScheduleEvent :Event_Week15 .

