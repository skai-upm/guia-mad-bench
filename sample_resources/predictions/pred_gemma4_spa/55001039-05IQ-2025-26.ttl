# Competencies
:CE15 rdf:type guide:Competency ;
    guide:competencyCode "CE 15" ;
    guide:competencyDescription "Conocimientos básicos de los sistemas de producción y fabricación industrial" .

:CE19 rdf:type guide:Competency ;
    guide:competencyCode "CE 19" ;
    guide:competencyDescription "Conocimientos sobre balances de materia y energía, biotecnología, transferencia de materia, operaciones de separación, ingeniería de la reacción química, diseño de reactores, y valoración y transformación de materias primas y recursos energéticos" .

:CE20 rdf:type guide:Competency ;
    guide:competencyCode "CE 20" ;
    guide:competencyDescription "Capacidad para el análisis, diseño, simulación y optimización de procesos y productos" .

:CE23_ETSII rdf:type guide:Competency ;
    guide:competencyCode "CE 23 (ETSII)" ;
    guide:competencyDescription "Conocimiento de los procesos disponibles para la obtención de productos" .

:CG1 rdf:type guide:Competency ;
    guide:competencyCode "CG 1" ;
    guide:competencyDescription "Conocer y aplicar los conocimientos de ciencias y tecnologías básicas a la práctica de la Ingeniería Industria" .

:CG2 rdf:type guide:Competency ;
    guide:competencyCode "CG 2" ;
    guide:competencyDescription "Poseer la capacidad para diseñar, desarrollar, implementar, gestionar y mejorar productos, sistemas y procesos en los distintos ámbitos industriales, usando técnicas analíticas, computacionales o experimentales apropiadas" .

:CG3 rdf:type guide:Competency ;
    guide:competencyCode "CG 3" ;
    guide:competencyDescription "Aplicar los conocimientos adquiridos para identificar, formular y resolver problemas en contextos amplios, siendo capaces de integrar los trabajando en equipos multidisciplinares" .

:CG4 rdf:type guide:Competency ;
    guide:competencyCode "CG 4" ;
    guide:competency .

:CG6 rdf:type guide:Competency ;
    guide:competencyCode "CG 6" ;
    guide:competencyDescription "Poseer las habilidades de aprendizaje que permitan continuar estudiando a lo largo de toda la vida para un desarrollo profesional adecuado" .

# Learning Results
:RA190 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA190" ;
    guide:learningResultDescription "El alumno será capaz de escoger los algoritmos apropiados e implementarlos para la simulación de los modelos." .

:RA193 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA193" ;
    guide:learningResultDescription "El alumno será capaz de formular un problema genérico de optimización y realizar la resolución y análisis de casos particulares como optimización lineal." .

:RA194 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA194" ;
    guide:learningResultDescription "El alumno será capaz de realizar un diseño preliminar de un proceso químico" .

:RA189 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA189" ;
    guide:learningResultDescription "El alumno será capaz de desarrollar modelos de unidades de proceso y procesos de ingeniería química basados en ecuaciones y principios físicos." .

