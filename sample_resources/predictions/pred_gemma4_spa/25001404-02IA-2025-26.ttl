guide:Res_QGIS rdf:type guide:DidacticResource ; guide:bibliographyTitle "Q-GIS" ; guide:bibliographyDescription "http://www.qgis.org" .
guide:Res_R_Project rdf:type guide:DidacticResource ; guide:bibliographyTitle "R para windows" ; guide:bibliographyDescription "http://cran.es.r-project.org/" .

