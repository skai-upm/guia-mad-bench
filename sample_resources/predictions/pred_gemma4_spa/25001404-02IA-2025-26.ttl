# Competencies
guide:Comp_CE14 rdf:type guide:Competency ; guide:competencyCode "CE14" ; guide:competencyDescription "Conocimiento de los conceptos básicos de Ecología, sus objetivos, metodología y modo de estudiar el biotopo, la biocenosis y sus relaciones." .
guide:Comp_CE15 rdf:type guide:Competency ; guide:competencyCode "CE15" ; guide:competencyDescription "Capacidad para aplicar los principios de la botánica en la identificación y caracterización de especies vegetales..." .
guide:Comp_CE17 rdf:type guide:Competency ; guide:competencyCode "CE17" ; guide:competencyDescription "Capacidad para utilizar los principios de Estadística Aplicada en el análisis y resolución de problemas en Agricultura e Ingeniería Agroambiental" .
guide:Comp_CE24 rdf:type guide:Competency ; guide:competencyCode "CE24" ; guide:competencyDescription "Capacidad para utilizar los modelos de datos espaciales y la incorporación de atributos relacionados con el medio ambiente..." .
guide:Comp_CE36 rdf:type guide:Competency ; guide:competencyCode "CE36" ; guide:competencyDescription "Capacitar para la medición de flora y fauna en agroecosistemas y aplicar los métodos de análisis del medio natural..." .
guide:Comp_CE39 rdf:<0xC2>type guide:Competency ; guide:competencyCode "CE39" ; guide:competencyDescription "Capacidad para utilizar los sistemas globales de navegación por satélite y de teledetección..." .
guide:Comp_CG14 rdf:type guide:Competency ; guide:competencyCode "CG14" ; guide:competencyDescription "Análisis y síntesis, razonamiento crítico y resolución de problemas científicos y técnicos" .
guide:Comp_CG6 rdf:type guide:Competency ; guide:competencyCode "CG6" ; guide:competencyDescription "Transmitir con claridad y rigor información, ideas, problemas y soluciones de forma oral y escrita" .
guide:Comp_CG7 rdf:type guide:Competency ; guide:competencyCode "CG7" ; guide:competencyDescription "Compromiso ético y profesional y respeto por el medio ambiente y la diversidad" .

# Learning Results
guide:LR_RA519 rdf:type guide:LearningResult ; guide:learningResultCode "RA519" ; guide:learningResultDescription "Utilizar organismos bioindicadores para conocer el estado de los ecosistemas" .
guide:LR_RA228 rdf:type guide:LearningResult ; guide:learning                resultCode "RA228" ; guide:learningResultDescription "Aplicar correctamente herramientas estadísticas para el análisis de datos cualitativos y cuantitativos obtenidos en la naturaleza." .
guide:LR_RA227 rdf:type guide:LearningResult ; guide:learningResultCode "RA227" ; guide:learningResultDescription "Aprender a muestrear plantas y animales en ecosistemas naturales y agroecosistemas." .
guide:LR_RA229 rdf:type guide:LearningResult ; guide:learningResultCode "RA229" ; guide:learningResultDescription "Conocer las metodologías que permiten establecer relaciones entre factores ambientales y bióticos." .
guide:LR_RA230 rdf:type guide:LearningResult ; guide:learningResultCode "RA230" ; guide:learningResultDescription "Conocer la potencialidad de los S.I.G. en combinación con la teledetección para el análisis de ecosistemas naturales." .

# Syllabus
guide:Syllabus_AnalisisEcosistemas 
    rdf:type guide:Syllabus ;
    guide:hasItem guide:SyllabusItem_Sec1, guide:SyllabusItem_Sec2, guide:SyllabusItem_Sec3, guide:SyllabusItem_Sec4 .

guide:SyllabusItem_Sec1 rdf:type guide:SyllableItem ; guide:syllabusDescription "Muestreo en campo sobre la abundancia de especies biológicas" ; guide:itemIndex 1 .
guide:SyllabusItem_Sec2 rdf:type guide:SyllableItem ; guide:syllabusDescription "Fitosociología" ; guide:itemIndex 2 .
guide:SyllabusItem_Sec3 rdf:type guide:SyllableItem ; guide:syllabusDescription "Análisis de datos sobre la abundancia de especies" ; guide:itemIndex 3 .
guide:SyllabusItem_Sec4 rdf:type guide:SyllableItem ; guide:syllabusDescription "Bioindicadores" ; guide:itemIndex 4 .

# Evaluation System
guide:EvalSystem_AnalisisEcosistemas 
    rdf:type guide:EvaluationSystem ;
    guide:evaluationDescription "La evaluación continua aporta el 50% de la nota y el otro 50 % deriva de la evaluación global." ;
    guide:hasEvaluationTrial guide:Trial_P02, guide:Trial_P03, guide:Trial_P04a, guide:Trial_Global .

guide:Trial_P02 
    rdf:type guide:EvaluationTrial ;
    guide:trialType "Evaluación de asistencia y participación" ;
    guide:gradePercentage "2.5%" ;
    guide:involvesCompetency guide:Comp_CE24 .

guide:Trial_P03 
    rdf:type guide:EvaluationTrial ;
    guide:trialType "Evaluación de asistencia y participación en viaje" ;
    guide:gradePercentage "5%" ;
    guide:involvesCompetency guide:Comp_CG7, guide:Comp_CE7, guide:Comp_CE14, guide:Comp_CE15, guide:Comp_CE24, guide:Comp_CE36, guide:Comp_CE39 .

guide:Trial_P04a 
    rdf:type guide:EvaluationTrial ;
    guide:trialType "Evaluación de matrices y fotografías" ;
    guide:gradePercentage "2.5%" ;
    guide:involvesCompetency guide:Comp_CG6, guide:Comp_CE7, guide:Comp_CE14, guide:Comp_CE17, guide:Comp_CE24, guide:Comp_CE36, guide:Comp_CE39 .

guide:Trial_Global 
    rdf:type guide:EvaluationTrial ;
    guide:trialType "Prueba de evaluación global" ;
    guide:gradePercentage "50%" ;
    guide:minimumScore "3/10" ;
    guide:involvesCompetency guide:Comp_CG6, guide:Comp_CG14, guide:Comp_CE14, guide:Comp_CE17, guide:Comp_CE24 .

