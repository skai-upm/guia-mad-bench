# Syllabus and Items
:syllabus_93000855 rdf:type guide:Syllabus ;
    guide:hasItem :item_tema1, :item_tema2, :item_tema3 .

:item_tema1 rdf:type guide:SyllabusItem ;
    guide:itemIndex 1 ;
    guide:syllabusDescription "Valoración de proyectos de inversión (Engineering economics, NPV, IRR, WACC)." .

:item_tema2 rdf:type guide:SyllabusItem ;
    guide:itemIndex 2 ;
    guide:syllabusDescription "Valoración de empresas (Plan de negocio, proyecciones de cash flows)." .

:item_tema3 rdf:type guide:SyllabusItem ;
    guide:itemIndex 3 ;
    guide:syllabusDescription "El método del Venture Capital para valorar startups." .

