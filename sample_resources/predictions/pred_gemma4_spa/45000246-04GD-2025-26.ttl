    guide:learningResultDescription "Entender los fundamentos de los intercambios comerciales y del marco monetario que los condiciona..." .

:LR_RA184
    rdf:type guide:LearningResult ;
    guide:learningResultCode "RA184 - RA1" ;
    guide:learningResultDescription "Entender el funcionamiento de una economía de mercado tanto a nivel microeconómico como macroeconómico." .

