# Competencies
:comp_10II_CE05 a guide:Competency ;
    guide:competencyCode "10II-CE05" ;
    guide:competencyDescription "Capacidad de diseñar y realizar experimentos apropiados, interpretar los datos y extraer conclusiones." .

:comp_10II_CE07 a guide:Competency ;
    guide:competencyCode "10II-CE07" ;
    guide:competencyDescription "Entender el soporte físico (hardware) de los ordenadores desde el punto de vista del soporte lógico (software)." .

:comp_10II_CG01_21 a guide:Competency ;
    guide:competencyCode "10II-CG01/21" ;
    guide:competencyDescription "Capacidad de resolución de problemas aplicando conocimientos de matemáticas, ciencias e ingeniería." .

# Learning Results
:lr_RA103 a guide:LearningResult ;
    guide:learningResultCode "RA103" ;
    guide:learningResultDescription "Utilizar eficientemente los los recursos básicos del computador mediante el lenguaje nativo del mismo." .

:lr_RA104 a guide:LearningResult ;
    guide:learningResultCode "RA104" ;
    guide:learningResultDescription "Analizar y evaluar la estructura interna del computador: modos de direccionamiento, sistemas de representación, rutas de datos, sistema de entrada/salida, periféricos y lenguaje ensamblador." .

# Syllabus
:syllabus_105000381 a guide:Syllabus ;
    guide:hasItem :item_tema1, :item_tema2, :item_tema3, :item_tema4, :item_tema5 .

:item_tema1 a guide:SyllabusItem ;
    guide:syllabusDescription "Introducción a los computadores" ;
    guide:itemIndex 1 .

:item_tema2 a guide:SylabusItem ;
    guide:syllabusDescription "Programación en Ensamblador" ;
    guide:itemIndex 2 .

# Evaluation Systems and Trials
:eval_system_progresiva a guide:EvaluationSystem ;
    guide:evaluationDescription "Evaluación progresiva basada en exámenes parciales y proyecto." ;
    guide:hasEvaluationTrial :trial_parcial_1, :trial_proyecto_ensamblador .

:trial_parcial_1 a guide:EvaluationTrial ;
    guide:evaluationType "Examen Escrito" ;
    guide:gradePercentage "44%" ;
    guide:minimumScore "2 / 10" ;
    guide:trialMode "Presencial" ;
    guide:eventWeek "Semana 11" .

:trial_proyecto_ensamblador a guide:EvaluationTrial ;
    guide:evaluationType "Examen Escrito" ;
    guide:gradePercentage "20%" ;
    guide:trialMode "Presencial" ;
    guide:eventWeek "Semana 17" .

:eval_system_global a guide:EvaluationSystem ;
    guide:evaluationDescription "Prueba de evaluación global." ;
    guide:hasEvaluationTrial :trial_final_teoria .

:trial_final_teoria a guide:EvaluationTrial ;
    guide:evaluationType "Examen Escrito" ;
    guide:gradePercentage "80%" ;
    guide:trialMode "Presencial" ;
    guide:eventWeek "Semana 17" .

