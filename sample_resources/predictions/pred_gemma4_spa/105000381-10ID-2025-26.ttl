# Course and Degree Structure
:degree_10ID a guide:Degree ;
    sch:name "10ID - Doble Grado En Ingenieria Informatica Y En Ade" ;
    guide:degreeCode "10ID" ;
    guide:hasCourse :course_105000381 .

:course_105000381 a guide:Course ;
    sch:name "Estructura De Computadores" ;
    sch:courseCode 105000381 ;
    guide:courseType "Obligatoria" ;
    sch:hasCourseInstance :course_guide_105000381 .

:course_guide_105000381 a guide:CourseGuide ;
    sch:name "Guía de Aprendizaje - Estructura De Computadores" ;
    guide:numberOfCredits 6.0 ;
    guide:teachingPeriod "2025-26" ;
    guide:periodStartingMonth "Septiembre" ;
    guide:periodEndingMonth "Enero" ;
    sch:inLanguage "Castellano" ;
    guide:hasSyllabus :syllabus_105000381 ;
    guide:hasCompetency :comp_10II_CE05, :comp_10II_CE07, :comp_10II_CE22, :comp_10II_CG01_21, :comp_10II_CG05, :comp_10II_CG06 ;
    guide:hasLearningResult :lr_RA103, :lr_RA104 ;
    guide:hasEvaluation :eval_system_progresiva, :eval_system_global, :eval_system_extraordinaria ;
    guide:hasDidacticResource :res_libro_miguel, :res_libro_stallings, :res_web_asignatura .

# University Center
:university_center_ets a guide:UniversityCenter ;
