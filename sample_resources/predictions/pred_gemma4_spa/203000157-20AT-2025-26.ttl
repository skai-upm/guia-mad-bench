# Competencies
guide:Comp_CB8 a guide:Competency ;
    guide:competencyCode "CB8" ;
    guide:competencyDescription "Que los estudiantes sean capaces de integrar conocimientos y enfrentarse a la complejidad de formular juicios..." .

guide:Comp_CG1 a guide:Competency ;
    guide:competencyCode "CG1" ;
    guide:competencyDescription "Capacidad de observación, generación de hipótesis y planteamiento de problemas experimentales en el ámbito de la alimentación y la salud." .

guide:Comp_CG3 a guide:Competency ;
    guide:competencyCode "CG3" ;
    guide:competencyDescription "Capacidad para evaluar los sistemas de control de la cadena alimentaria y promover la seguridad en el consumo como estrategia competitiva." .

guide:Comp_CG8 a guide:Competency ;
    guide:competencyCode "CG8" ;
    guide:competencyDescription "Resolver con eficacia y eficiencia problemas relacionados con la alimentación salvaguardando y mejorando la salud de la sociedad..." .

# Learning Results
guide:LR_RA50 a guide:LearningResult ;
    guide:learningResultCode "RA50" ;
    guide:learningResultDescription "Conocer los avances en materiales tradicionales de envasado" .

guide:LR_RA51 a guide:LearningResult ;
    guide:learningResultCode "RA51" ;
    guide:learningResultDescription "Conocer los avances en nuevos materiales y técnicas de envasado" .

guide:LR_RA53 a guide:LearningResult ;
    guide:learningResultCode "RA53" ;
    guide:learningResultDescription "Conocer los nuevos sistemas de gestión ambiental de envases" .

guide:LR_RA52 a guide:CR_RA52 ; # Note: Using class for consistency if code is just string
    guide:learningResultCode "RA52" ;
    guide:learningResultDescription "Conocer y aplicar la legislación sobre envasado de alimentos y salud" .

guide:LR_RA49 a guide:LearningResult ;
    guide:learningResultCode "RA49" ;
    guide:learningResultDescription "Aquirir conocimientos sobre la relación ingeniería del envasado y salud" .

