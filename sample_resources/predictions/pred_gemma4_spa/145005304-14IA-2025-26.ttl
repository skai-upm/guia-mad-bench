# Competencies
gmb:Comp_CE71 a guide:Competency ;
    guide:competencyCode "CE71" ;
    guide:competencyDescription "Conocimiento aplicado de: Transmisores y receptores; Línguas de transmisión y sistemas radiantes de señales para la navegación aérea; Sistemas de navegación; Instalaciones eléctricas en el sector tierra y sector aire; Mecánica del Vuelo; Cartografía; Cosmografía; Meteorología; Distribución, gestión y economía del transporte aéreo." .

gmb:Comp_CG3 a guide:Competency ;
    guide:competencyCode "CG3" ;
    guide:competencyDescription "Capacidad para identificar y resolver problemas aplicando, con creatividad, los conocimientos adquiridos" .

gmb:Comp_CG9 a guide:Competency ;
    guide:competencyCode "CG9" ;
    guide:competencyDescription "Razonamiento crítico y capacidad de asociación que posibiliten el aprendizaje continuo" .

# Learning Results
gmb:LR_RA119 a guide:LearningResult ;
    guide:learningResultCode "RA119" ;
    guide:learningResultDescription "Comprensión, aplicación, análisis y síntesis de las Líneas de Transmisión, Guías de Ondas, Fibra Óptica, Antenas y Redes de antenas, aplicadas a los dispositivos que forman parte de los equipos que conforman el Sistema de Navegación Aérea." .

# Syllabus
gmb:Syllabus_RF a guide:Syllabus ;
    guide:hasItem gmb:Topic_1, gmb:Topic_2, gmb:Topic_3, gmb:Topic_4, gmb:Topic_5, gmb:Topic_6 .

gmb:Topic_1 a guide:SyllabusItem ; guide:itemIndex 1 ; guide:syllabusDescription "PRINCIPIOS FUNDAMENTAL DE LOS SISTEMAS DE RADIOFRECUENCIA" .
gmb:Topic_2 a guide:SyllabusItem ; guide:itemIndex 2 ; guide:syllabusDescription "ONDAS ELECTROMAGNÉTICAS: NATURALEZA Y PROPAGACIÓN" .
gmb:Topic_3 a guide:SyllabusItem ; guide:itemIndex 3 ; guide:syllabusDescription "LINEAS DE TRANSMISION" .
gmb:Topic_4 a guide:SyllabusItem ; guide:itemIndex 4 ; guide:syllabusDescription "GUIAS DE ONDA" .
gmb:Topic_5 a guide:SyllabusItem ; guide:itemIndex 5 ; guide:syllabusDescription "ANTENAS" .
gmb:Topic_6 a guide:SyllabusItem ; guide:itemIndex 6 ; guide:syllabusDescription "TIPOS Y REDES DE ANTENAS" .

