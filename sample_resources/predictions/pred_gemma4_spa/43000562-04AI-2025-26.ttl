    guide:hasItem data:Topic_1, data:Topic_2, data:Topic_3, data:Topic_4, data:Topic_5, data:Topic_6, data:Topic_7, data:Topic_8, data:Topic_9, data:Topic_10 .

data:Topic_1 rdf:type guide:SyllabusItem ;
    guide:itemIndex 1 ;
    guide:syllabusDescription "Introduction" .

data:MarineEnergiesSchedule rdf:type guide:Schedule ;
    sch:eventSchedule data:Event_Week1, data:Event_Week2, data:Event_Week3, data:Event_Week4, data:Event_Week6, data:Event_Week7, data:Event_Week8, data:Event_Week9, data:Event_Week11, data:Event_Week12, data:Event_Week13, data:Event_Week14, data:Event_Week15, data:Event_Week16, data:Event_Week17 .

