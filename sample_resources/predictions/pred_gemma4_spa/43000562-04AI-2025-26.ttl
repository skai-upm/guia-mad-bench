@prefix data: <http://guia-mad-bench.es/data/> .
@prefix guide: <http://w3id.org/def/guia#> .
@prefix sch: <https://schema.org/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

# Course and Degree Structure
data:MarineEnergiesCourse rdf:type guide:Course ;
    sch:courseCode 43000562 ;
    guide:courseType "Optativa" ;
    sch:hasCourseInstance data:MarineEnergiesCourseGuide .

data:MarineEnergiesCourseGuide rdf:type guide:CourseGuide ;
    sch:name "Marine Energies" ;
    sch:description "This subject is optional within the specialty of Hydraulics, Energy and Environment. The course offers an overview of the use of renewable energies in the marine environment such as waves, currents, tides or wind." ;
    guide:numberOfCredits 4.5 ;
    guide:semester "Cuarto semestre" ;
    guide:teachingPeriod "2025-26" ;
    guide:periodStartingMonth "Febrero" ;
    guide:periodEndingMonth "Junio" ;
    sch:inLanguage "Castellano" ;
    guide:hasCompetency data:Comp_MICCPCE27, data:Comp_MICCPCE30, data:Comp_MICCPCE33 ;
    guide:hasLearningResult data:LR_RA124, data:LR_RA114, data:LR_RA99 ;
    guide:hasEvaluation data:EvalSystem_MarineEnergies ;
    guide:hasDidacticResource data:Res_Esteban2009, data:Res_CoastalEngManual ;
    sch:instructor data:Lecturer_VicenteNegro, data:Lecturer_JoseSantos, data:Lecturer_PedroFernandez, data:Lecturer_MariaDolores .

data:DobleMasterIccp rdf:type guide:MasterDegree ;
    sch:name "04AI - Dobint Master Universitario En Iccp Y En Sistemas De Ingenieria Civil" ;
    guide:hasCourse data:MarineEnergiesCourse .

data:ETS_Caminos rdf:type guide:UniversityCenter ;
    sch:name "E.T.S. de Ing. de Caminos Canales y P." ;
    guide:offers data:DobleMasterIccp .

