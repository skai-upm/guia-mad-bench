# Competencies
data:Comp_MICCPCE27 rdf:type guide:Competency ;
    guide:competencyCode "MICCPCE27" ;
    guide:competencyDescription "Conocimientos y capacidades que permiten comprender los fenómenos dinám<0xC2>icos del medio océano-atmósfera-costa..." .

data:Comp_MICCPCE30 rdf:type guide:Competency ;
    guide:competencyCode "MICCPCE30" ;
    guide:competencyDescription "Capacidad de planificación, gestión y explotación de infraestructuras relacionadas con la ingeniería civil." .

data:Comp_MICCPCE33 rdf:type guide:Competency ;
    guide:competencyCode "MICCPCE33" ;
    guide:competencyDescription "Capacidad para aplicar los conocimientos técnicos en actividades de I+D+i dentro del ámbito de la ingeniería civil." .

# Learning Results
data:LR_RA124 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA124" ;
    guide:learningResultDescription "Explica, conoce y tiene capacidad para conocer los aspectos técnicos, legales y de la propiedad..." .

data:LR_RA114 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA114" ;
    guide:learningResultDescription "Capacidad para analizar y sintetizar los diversos contenidos de información de fuentes diversas." .

data:LR_RA99 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA9_99" ;
    guide:learningResultDescription "Analizar con carácter crítico la parte metodológica de un proyecto de investigación..." .

# Evaluation System
data:EvalSystem_MarineEnergies rdf:type guide:EvaluationSystem ;
    guide:evaluationDescription "Evaluation through progressive assessment and global assessment." ;
    guide:hasEvaluationTrial data:Trial_Submission, data:Trial_Presentation, data:Trial_FinalExam .

data:Trial_Submission rdf:type guide:EvaluationTrial ;
    guide:trialType "Trabajo en Grupo" ;
    guide:gradePercentage "50%" ;
    guide:minimumScore "5 / 10" ;
    guide:trialMode "Presencial" .

data:Trial_Presentation rdf:type guide:EvaluationTrial ;
    guide:trialType "Presentación en Grupo de Laboratorio" ;
    guide:gradePercentage "50%" ;
    guide:minimumScore "5 / 10" ;
    guide:trialMode "Presencial" .

data:Trial_FinalExam rdf:type guide:EvaluationTrial ;
    guide:trialType "Examen Escrito" ;
    guide:gradePercentage "100%" ;
    guide:minimumScore "5 / 10" ;
    guide:trialMode "Presencial" .

