    guide:itemIndex 4 .

# Evaluation System and Trials
:eval_system_105001050 rdf:type guide:EvaluationSystem ;
    guide:evaluationDescription "La evaluación consiste en la entrega de trabajos y pruebas según convocatoria ordinaria o extraordinaria." ;
    guide:hasEvaluationTrial :trial_work_1, :trial_work_2, :trial_work_3, :trial_work_4 .

:trial_work_1 rdf:type guide:EvaluationTrial ;
    guide:trialDescription "Trabajo sobre ecuaciones diferenciales de primer orden, modelización de fenómenos reales y su simlamulación numérica." ;
    guide:evaluationType "Progresiva" ;
    guide:gradePercentage "25%" ;
    guide:minimumScore "3.5 / 10" ;
    guide:trialMode "No Presencial" .

:trial_work_2 rdf:type guide:EvaluationTrial ;
    guide:trialDescription "Trabajo sobre ecuaciones diferenciales de orden superior, modelización de fenómenos reales y su simulación numérica." ;
    guide:evaluationType "Progresiva" ;
    guide:gradePercentage "25%" ;
    guide:minimumScore "3.5 / 10" ;
    guide:trialMode "No Presencial" .

