    guide:hasItem :SyllabusItem_1, :SyllabusItem_2, :SyllabusItem_3, :SyllabusItem_4, :SyllabusItem_5, :SyllabusItem_6, :SyllabusItem_7, :SyllabusItem_8, :SyllabusItem_9, :SyllabusItem_10, :SyllabusItem_11, :SyllabusItem_12 .

:SyllabusItem_1 rdf:type guide:SyllabusItem ; guide:itemIndex 1 ; syllabusDescription "LA ENERGÍA ELÉCTRICA EN LAS AERONAVES" .
:SyllabusItem_2 rdf:type guide:SyllabusItem ; guide:itemIndex 2 ; syllabusDescription "CONFIGURACIÓN DEL SISTEMA ELÉCTRICO" .
:SyllabusItem_3 rdf:type guide:SyllabusItem ; guide:itemIndex 3 ; syllabusDescription "LOS CONSUMIDORES ELÉCTRICOS" .
:SylllabusItem_4 rdf:type guide:SyllabusItem ; guide:itemIndex 4 ; syllabusDescription "LOS GENERADORES DE CC" .
:SyllabusItem_5 rdf:type guide:SyllabusItem ; guide:itemIndex 5 ; syllabusDescription "LOS GENERADORES DE CA" .
:SyllabusItem_6 rdf:type guide:SyllabusItem ; guide:itemIndex 6 ; syllabusDescription "LAS BATERÍAS" .
:SyllabusItem_7 rdf:type guide:SyllabusItem ; guide:itemIndex 7 ; syllabusDescription "LOS CONVERTIDORES" .
:SyllabusItem_8 rdf:type guide:SyllabusItem ; guide:itemIndex 8 ; syllabusDescription "EL MANDO Y CONTROL" .
:SyllabusItem_9 rdf:type guide:SyllabusItem ; guide:itemIndex 9 ; syllabusDescription "LAS PROTECCIONES" .
:SyllabusItem_10 rdf:type guide:SyllabusItem ; guide:itemIndex 10 ; syllabusDescription "LA DISTRIBUCIÓN" .
:SyllabusItem_11 rdf:type guide:SyllabusItem ; guide:itemIndex 11 ; syllabusDescription "LA MEDIDA, LA SEÑALIZACIÓN, LA PRESENTACIÓN Y EL REGISTRO DE LA INFORMACIÓN" .
:SyllabusItem_12 rdf:type guide:SyllabusItem ; guide:itemIndex 12 ; syllabusDescription "EL SISTEMA ELÉCTRICO DE LOS AEROPUERTOS" .

# Evaluation System
:EvalSystem_Instalaciones_Electricas rdf:type guide:EvaluationSystem ;
    guide:evaluationDescription "Evaluación progresiva y global." ;
    guide:hasEvaluationTrial :Prueba_Intermedia, :Examen_Final_Ordinario, :Examen_Final_Extraordinario .

:Prueba_Intermedia rdf:type guide:EvaluationTrial ;
    guide:trialType "Examen Escrito" ;
    guide:trialMode "Presencial" ;
    guide:evaluationDuration "01:30" ;
    guide:gradePercentage "50%" ;
    guide:minimumScore "3 / 10" ;
    guide:trialWeek "10" ;
    guide:involvesCompetency :CG3, :CG9, :CE67, :CE71 .

:Examen_Final_Ordinario rdf:type guide:EvaluationTrial ;
    guide:trialType "Examen Escrito" ;
    guide:trialMode "Presencial" ;
    guide:evaluationDuration "03:00" ;
    guide:gradePercentage "50%" ;
    guide:minimumScore "5 / 10" ;
    guide:trialWeek "17" ;
    guide:involvesCompetency :CG3, :CG9, :CE67, :CE71 .

:Examen_Final_Extraordinario rdf:type guide:EvaluationTrial ;
    guide:trialType "Examen Escrito" ;
    guide:trialMode "Presencial" ;
    guide:evaluationDuration "02:00" ;
    guide:gradePercentage "100%" ;
    guide:minimumScore "5 / 10" ;
    guide:trialWeek "17" ;
    guide:involvesCompetency :CG3, :CG9, :CE67, :CE71 .

