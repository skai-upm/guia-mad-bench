# Lecturer Instance
:M_Victoria_Alonso_Maldonado rdf:type guide:Lecturer ;
    sch:name "M Victoria Alonso Maldonado" ;
    sch:email "mariavictoria.alonso@upm.es" ;
    guide:office "A-208" ;
    guide:tutorshipSchedule "Sin horario. Al comienzo del curso se publicará un horario de tutorías orientativo en el tablón del Departamento." .

# Competencies
:CE67 rdf:type guide:Competency ;
    guide:competencyCode "CE67" ;
    guide:competencyDescription "Conocimiento adecuado y aplicado a la Ingeniería de: Las instalaciones eléctricas y electrónicas." .

:CE71 rdf:type guide:Competency ;
    guide:competencyCode "CE71" ;
    guide:competencyDescription "Conocimiento aplicado de: Transmisores y receptores; Líneas de transmisión y sistemas radiantes de señales para la navegación aérea; Sistemas de navegación; Instalaciones eléctricas en el sector tierra y sector aire; Mecánica del Vuelo; Cartografía; Cosmografía; Meteorología; Distribución, gestión y economía del transporte aéreo." .

:CG3 rdf:type guide:Competency ;
    guide:competencyCode "CG3" ;
    guide:competencyDescription "Capacidad para identificar y resolver problemas aplicando, con creatividad, los conocimientos adquiridos" .

:CG9 rdf:type guide:Competency ;
    guide:competencyCode "CG9" ;
    guide:competencyDescription "Razonamiento crítico y capacidad de asociación que posibiliten el aprendizaje continuo" .

# Learning Results
:RA144 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA144" ;
    guide:learningResultDescription "Conocimiento, comprensión, aplicación, análisis y síntesis de los fundamentos, concepción, mantenimiento y operatividad de los sistemas e instalaciones eléctricos de potencia en los sectores aeronáuticos tierra y aire." .

:RA143 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA143" ;
    guide:learningResultDescription "Aplicación de las técnicas utilizadas en el laboratorio y conocimiento de las medidas de seguridad dispuestas." .

