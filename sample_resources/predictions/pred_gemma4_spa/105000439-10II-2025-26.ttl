# Evaluation Systems and Trials
data:EvalSystem_Progresiva a guide:EvaluationSystem ;
    guide:evaluationDescription "La nota de evaluación progresiva se calcula como 0,3 * (Test de Teoría) + 0,7 * (Nota Concursos)." ;
    guide:hasEvaluationTrial data:Trial_Concursos, data:Trial_AdaByron, data:Trial_TestTeoria .

data:EvalSystem_Global a guide:EvaluationSystem ;
    guide:evaluationDescription "La nota de evaluación global se calcula como 0,3 * (Test de Teoría) + 0,7 * (Nota de Concursos)." ;
    guide:hasEvaluationTrial data:Trial_Recuperacion .

data:Trial_Concursos a guide:EvaluationTrial ;
    guide:evaluationType "Progresiva" ;
    guide:gradePercentage "7%" ;
    guide:trialMode "Presencial" ;
    guide:trialType "Trabajo en Grupo" .

data:Trial_AdaByron a guide:EvaluationTrial ;
    guide:evaluationType "Progresiva" ;
    guide:gradePercentage "10%" ;
    guide:trialMode "Presencial" ;
    guide:trialType "Otras técnicas evaluativas" .

data:Trial_TestTeoria a guide:EvaluationTrial ;
    guide:evaluationType "Progresiva" ;
    guide:gradePercentage "30%" ;
    guide:trialMode "Presencial" ;
    guide:trialType "Examen Escrito" .

data:Trial_Recuperacion a guide:EvaluationTrial ;
    guide:evaluationType "Global" ;
    guide:gradePercentage "70%" ;
    guide:trialMode "Presencial" ;
    guide:trialType "Examen de Prácticas" .

