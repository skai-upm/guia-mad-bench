@prefix : <http://guia-mad-bench.es/data/> .
@prefix guide: <http://w3id.org/def/guia#> .
@prefix sch: <https://schema.org/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# Degree and Course Structure
:degree_06GE a guide:Degree ;
    sch:name "Grado en Ingenieria Geologica" ;
    guide:degreeCode "06GE" ;
    guide:hasCourse :course_electrotecnia .

:course_electrotecnia a guide:Course ;
    sch:name "Electrotecnia" ;
    guide:courseCode "65001013" ;
    guide:courseType "Obligatoria" ;
    guide:semester "Cuarto semestre" ;
    sch:hasCourseInstance :course_guide_electrotecnia .

:course_guide_electrotecnia a guide:CourseGuide ;
    sch:name "Guía de Aprendizaje - Electrotecnia" ;
    guide:numberOfCredits 6.0 ;
    guide:teachingPeriod "2025-26" ;
    guide:periodStartingMonth "Feagero" ;
    guide:periodEndingMonth "Junio" ;
    sch:inLanguage "Castellano" ;
    sch:director :lecturer_eduardo ;
    sch:instructor :lecturer_luis, :lecturer_daniel ;
    guide:hasSyllabus :syllabus_electrotecnia ;
    guide:hasEvaluation :eval_system_electrotecnia ;
    guide:hasLearningResult :lr_ra74, :lr_ra75, :lr_ra76, :lr_ra77, :lr_ra78, :lr_ra79 ;
    guide:hasCompetency :comp_cg1, :comp_ag2, :comp_cg3, :comp_cg6, :comp_cg7, :comp_f17 ;
    guide:hasDidacticResource :res_fraile_mora, :res_moodle ;
    guide:otherInformation "La calculadora científica es una herramienta que debe usar el alumno de forma habitual en el aula." .

# University Center
:center_minas_energia a guide:UniversityCenter ;
    sch:name "E.T.S. de Ingenieros de Minas y Energía" ;
    guide:offers :degree_06GE .

