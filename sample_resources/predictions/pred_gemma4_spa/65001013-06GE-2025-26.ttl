# Competencies
:comp_cg1 a guide:Competency ;
    guide:competencyCode "CG1" ;
    guide:competencyDescription "Conocer y aplicar conocimientos de ciencias y tecnologías básicas a la práctica de la Ingeniería Geológica." .

:comp_cg2 a guide:Competency ;
    guide:competencyCode "CG2" ;
    guide:competencyDescription "Poseer capacidad para diseñar, desarrollar, implementar, gestionar y mejorar productos, sistemas y procesos en los distintos ámbitos geológicos..." .

:comp_f17 a guide:Competency ;
    guide:competencyCode "F17" ;
    guide:competencyDescription "Conocimientos fundamentales sobre el sistema eléctrico de potencia: generación de energía, red de transporte, reparto y distribución..." .

# Learning Results
:lr_ra74 a guide:LearningResult ;
    guide:learningResultCode "RA74" ;
    guide:learningResultDescription "Comprender los fundamentos del sistema eléctrico de potencia" .

:lr_ra75 a guide:LearningResult ;
    guide:learningResultCode "RA75" ;
    guide:learningResultDescription "Plantear las ecuaciones de los sistemas eléctricos y resolverlas en diversos regímenes de funcionamiento" .

# Syllabus
:syllabus_electrotecnia a guide:Syllabus ;
    guide:hasItem :item_1_1, :item_2_1, :item_3_1, :item_4_1, :item_5_1 .

:item_1_1 a guide:SyllabusItem ;
    guide:itemIndex 1 ;
    guide:syllabusDescription "Componentes de los circuitos: Variables eléctricas fundamentales. Simbología." .

:item_2_1 a guide:SyllabusItem ;
    guide:itemIndex 2 ;
    guide:syllabusDescription "Circuitos en corriente alterna: Ecuaciones en régimen estacionario senoidal. Cálculo simbólico." .

# Evaluation System and Trials
:eval_system_electrotecnia a guide:EvaluationSystem ;
    guide:evaluationDescription "La nota por global se calcula como N=0,45*T+0,45*P+0,1*L..." ;
    guide:hasEvaluationTrial :trial_cuestionario_1, :trial_lab_exam .

:trial_cuestionario_1 a guide:EvaluationTrial ;
    sch:name "Cuestionario tema 1 (circuitos continua)" ;
    guide:evaluationType "Examen Escrito" ;
    guide:gradePercentage "7.5%" ;
    guide:evaluationDuration "00:30" ;
    guide:trialMode "No presencial" ;
    guide:involvesCompetency :comp_cg1, :comp_cg2 .

:trial_lab_exam a guide:EvaluationTrial ;
    sch:name "Examen Laboratorio" ;
    guide:evaluationType "Examen de Prácticas" ;
    guide:gradePercentage "10%" ;
    guide:evaluationDuration "00:30" ;
    guide:trialMode "Presencial" ;
    guide:involvesCompetency :comp_cg1, :comp_cg6 .

# Didactic Resources
:res_fraile_mora a guide:DidacticResource ;
    sch:name "FRAILE MORA, Electrotecnia para ingenieros, IBERGARCETA PUBLICACIONES, 2023." ;
    guide:bibliographyType "Bibliografía" .

:res_moodle a guide:DidacticResource ;
    sch:name "Plataforma educativa Moodle (UPM)" ;
    guide:bibliographyType "Recursos web" .

# Required Knowledge
:req_knowledge_electrotecnia a guide:RequiredKnowledge ;
    guide:previousKnowledge "Calculo II, Electromagnetismo, Calculo I" .