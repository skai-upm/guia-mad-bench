# Competencies
:comp_cb10 rdf:type guide:Competency ;
    guide:competencyCode "CB10" ;
    guide:competencyDescription "Que los estudiantes posean las habilidades de aprendizaje que les permitan continuar estudiando de un modo que habrá de ser en gran medida autodirigido o autónomo." .

:comp_ce_a1 rdf:type guide:Competency ;
    guide:competencyCode "CE-A1" ;
    guide:competencyDescription "Capacitación científico-técnica y metodológica suficiente para el proyecto, análisis, planificación, explotación y mantenimiento de obras civiles..." .

:comp_ce_a2 rdf:type guide:Competency ;
    guide:competencyCode "CE-A2" ;
    guide:competencyDescription "Conocimiento y capacidad para proyectar y dimensionar obras e instalaciones de ingeniería civil" .

:comp_ce_a5 rdf:type guide:Competency ;
    guide:competencyCode "CE-A5" ;
    guide:competencyDescription "Conocimiento de la influencia de las infraestructuras en la ordenación del territorio." .

:comp_ce_a6 rdf:type guide:Competency ;
    guide:competencyCode "CE-A6" ;
    guide:competencyDescription "Conocimiento del marco de regulación de los sistemas de ingeniería civil" .

:comp_ce_a7 rdf:type guide:Competency ;
    guide:competencyCode "CE-A7" ;
    guide:competencyDescription "Conocimiento y capacidad para idear soluciones innovadoras en sistemas de ingeniería civil" .

# Learning Results
:lr_ra10 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA10" ;
    guide:learningResultDescription "Argumenta la resolucion de los problemas de gestion mediante logica cientifica y aplicando una metodologia razonada." .

:lr_ra103 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA103" ;
    guide:learningResultDescription "Aplica técnicas de optimización a la resolución de problemas de sistemas de ingeniería civil" .

:lr_ra97 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA97" ;
    guide:learningResultDescription "Capacidad de plantear una metodología de investigación basada en el estado del arte." .

# Syllabus
:syllabus_ferroviaria rdf:type guide:Syllabus ;
    guide:hasItem :item_tema1, :item_tema2, :item_tema3 .

:item_tema1 rdf:type guide:SyllabusItem ;
    guide:itemIndex 1 ;
    guide:syllabusDescription "El proyecto ferroviario: Fundamentos y normativa, Proyectos de trazado, Proyectos de instalaciones, Material móvil, Métodos constructivos" .

:item_tema2 rdf:type guide:SylabusItem ;
    guide:itemIndex 2 ;
    guide:syllabusDescription "Comportamiento de la vía ferroviaria: Esfuerzos estáticos, Dinámica de la vía" .

# Evaluation System and Trials
:eval_system_ferroviaria rdf:type guide:EvaluationSystem ;
    guide:evaluationDescription "Evaluación continua y prueba final." ;
    guide:hasEvaluationTrial :trial_control4, :trial_examen_9, :trial_examen_17 .

:trial_control4 rdf:type guide:EvaluationTrial ;
    guide:evaluationType "Examen Escrito" ;
    guide:gradePercentage "10%" ;
    guide:evaluationDuration "00:15" ;
    guide:trialMode "Presencial" ;
    guide:minimumScore "0 / 10" ;
    guide:involvesCompetency :comp_cb10, :comp_ce_a1 .

:trial_examen_9 rdf:type guide:EvaluationTrial ;
    guide:evaluationType "Examen Escrito" ;
    guide:gradePercentage "35%" ;
    guide:evaluationDuration "01:45" ;
    guide:trialMode "Presencial" ;
    guide:minimumScore "4 / 10" ;
    guide:involvesCompetency :comp_ce_a2, :comp_ce_a1 .

:trial_examen_17 rdf:type guide:EvaluationTrial ;
    guide:evaluationType "Examen Escrito" ;
    guide:gradePercentage "100%" ;
    guide:evaluationDuration "03:00" ;
    guide:trialMode "Presencial" ;
    guide:minimumScore "5 / 10" ;
    guide:involvesCompetency :comp_ce_a2, :comp_ce_a5 .

