# Competencies
:comp_ec02 a guide:Competency ;
    guide:competencyCode "CE EC02" ;
    guide:competencyDescription "Capacidad para seleccionar circuitos y dispositivos electrónicos especializados para la transmisión, el encaminamiento o enrutamiento y los terminales, tanto en entornos fijos como móviles." .

:comp_ec05 a guide:Competency ;
    guide:competencyCode "CE EC05" ;
    guide:competencyDescription "Capacidad de diseñar circuitos de electrónica analógica y digital, de conversión analógico-digital y digital-analógica, de radiofrecuencia, de alimentación y conversión de energía eléctrica para aplicaciones de telecomunicación y computación." .

:comp_cg04 a guide:Competency ;
    guide:competencyCode "CG 04" ;
    guide:competencyDescription "Capacidad de abstracción, de análisis y de síntesis y de resolución de problemas." .

:comp_cg11 a guide:Competency ;
    guide:competencyCode "CG 11" ;
    guide:competencyDescription "Habilidades para la utilización de las Tecnologías de la Información y las Comunicaciones." .

# Learning Results
:lr_ra546 a guide:LearningResult ;
    guide:learningResultCode "RA546" ;
    guide:learningResultDescription "Comprender e interpretar las especificaciones y parámetros de un amplificador operacional a partir de las hojas de características del fabricante" .

:lr_ra550 a guide:LearningResult ;
    guide:learningResultCode "RA550" ;
    guide:learningResultDescription "Calcular, de forma aproximada y rápida, el ancho de banda de un amplificador construido con amplificador operacional compensado en frecuencia." .

# Syllabus and Items
:syllabus_ea2 a guide:Syllabus ;
    guide:hasItem :item_unit1, :item_unit2, :item_unit3 .

:item_unit1 a guide:SyllabusItem ;
    guide:itemIndex 1 ;
    guide:syllabusDescription "Circuitos realimentados con Amplificador Operacional" .

:item_unit2 a guide:SyllabusItem ;
    guide:itemIndex 2 ;
    guide:syllabusDescription "Respuesta en frecuencia de circuitos basados en el Amplificador Operacional" .

:item_unit3 a guide:SyllabusItem ;
    guide:itemIndex 3 ;
    guide:syllabusDescription "Parámetros de los Amplificadores Operacionales comerciales" .

