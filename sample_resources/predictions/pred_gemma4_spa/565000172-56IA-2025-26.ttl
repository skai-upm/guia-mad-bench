# Competencies
:CE24 rdf:type guide:Competency ;
    guide:competencyCode "CE 24" ;
    guide:competencyDescription "Capacidad para diseñar sistemas electrónicos analógicos, digitales y de potencia." .

:CE25 rdf:type guide:Competency ;
    guide:competencyCode "CE 25" ;
    guide:competencyDescription "Conocimiento y capacidad para el modelado y simulación de sistemas." .

:CG1 rdf:type guide:Competency ;
    guide:competencyCode "CG 1" ;
    guide:competencyDescription "Conocer y aplicar los conocimientos de ciencias y tecnologías básicas a la práctica de la Ingeniería Industrial" .

:CG10 rdf:type guide:Competency ;
    guide:competencyCode "CG 10" ;
    guide:competencyDescription "Creatividad." .

# Learning Results
:RA58 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA58" ;
    guide:learningResultDescription "Conocimiento y capacidad para el modelado y simulación de sistemas electrónicos digitales." .

:RA238 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA238" ;
    guide:learningResultDescription "Realizar descripciones de circuitos mediante VHDL." .

# Evaluation System
:EvalSystem_SistemasDigitales rdf:type guide:EvaluationSystem ;
    guide:evaluationDescription "La evaluación consta de un examen parcial y un examen global en aula. La nota final se calcula según la ponderación de los componentes." ;
    guide:hasEvaluationTrial :ExamenParcial_Trial, :ExlamenGlobal_Trial, :TrabajoAsignatura_Trial .

:ExamenParcial_Trial rdf:type guide:EvaluationTrial ;
    guide:evaluationType "progresiva" ;
    guide:gradePercentage "25%" ;
    guide:minimumScore "0 / 10" ;
    guide:trialType "Examen Escrito" .

:ExlamenGlobal_Trial rdf:type guide:EvaluationTrial ;
    guide:evaluationType "global" ;
    guide:gradePercentage "40%" ;
    guide:minimumScore "4 / 10" ;
    guide:trialType "Examen Escrito" .

:TrabajoAsignatura_Trial rdf:type guide:EvaluationTrial ;
    guide:evaluationType "global" ;
    guide:gradePercentage "35%" ;
    guide:minimumScore "5 / 10" ;
    guide:trialType "Presentación en Grupo de Laboratorio" .

# Syllabus and Topics
:Syllabus_SistemasDigitales rdf:type guide:Syllabus ;
    guide:hasItem :Tema1_Item, :Tema2_Item, :Tema3_Item, :Tema4_Item .

:Tema1_Item rdf:type guide:SyllabusItem ;
    guide:syllabusDescription "Introducción a la microelectrónica, breve historia y tendencias actuales. Dispositivos Lógicos Programables (PL．PLD) y CPLD. FPGA." ;
    guide:itemIndex 1 .

:Tema2_Item rdf:type guide:SyllabusItem ;
    guide:syllabusDescription "Diseño mediante Lenguajes de Descripción Hardware (VHDL). Sintaxis dataflow, behavioural, estructural y simulación." ;
    guide:itemIndex 2 .

