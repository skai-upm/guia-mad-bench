# Competencies
guide:CM37_4 rdf:type guide:Competency ;
    guide:competencyCode "CM37.4" ;
    guide:competencyDescription "Comprensión del fundamento y de losES sistemas de utilización de las energías renovables." .

guide:CM38_1 rdf:type guide:Competency ;
    guide:competencyCode "CM38.1" ;
    guide:competencyDescription "Conocimiento y comprensión del funcionamiento de los ecosistemas y de los factores ambientales." .

guide:CM38_2 rdf:type guide:Competency ;
    guide:competencyCode "CM38.2" ;
    guide:competencyDescription "Comprensión y capacidad de aplicación de metodologías de restauración ambiental." .

guide:CM39_1 rdf:type guide:Competency ;
    guide:competencyCode "CM39.1" ;
    guide:competencyDescription "Conocimiento de los proyectos de servicios urbanos relacionados con la distribución de agua y el saneamiento" .

guide:CM44 rdf:type guide:Competency ;
    guide:competencyCode "CM44" ;
    guide:competencyDescription "Valoración de los efectos histórico, social, económico, ambiental, cultural, político y globalizador de las realizaciones de la ingeniería civil." .

guide:CM45 rdf:type guide:Competency ;
    guide:competencyCode "CM45" ;
    guide:competencyDescription "Comprensión y asunción de los principios de incertidumbre, riesgo y oportunidad en la aplicación de los métodos y modelos de la ingeniería civil." .

guide:CT3 rdf:type guide:Competency ;
    guide:competencyCode "CT3" ;
    guide:competencyDescription "Capacidad de actuar con efectividad como miembro de equipos interdisciplinares." .

guide:CT6 rdf:type guide:Competency ;
    guide:competencyCode "CT6" ;
    guide:competencyDescription "Compromiso y capacidad de aplicación de los estándares de deontología profesional." .

# Learning Results
guide:RA95 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA95" ;
    guide:learningResultDescription "Explica el fundamento y los sistemas de utilización de las energías renovables." .

guide:RA99 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA99" ;
    guide:learningResultDescription "Valora los efectos social, económico, ambiental, político y globalizador de las infraestructuras hidráulicas y energéticas." .

guide:RA92 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA92" ;
    guide:learningResultDescription "Proyecta y dimensiona sistemas energéticos." .

# Syllabus
guide:Syllabus_Servicios_Proteccion rdf:type guide:Syllabus ;
    guide:hasItem guide:SyllabusItem_1, guide:SyllabusItem_2, guide:SyllabusItem_3, guide:SyllabusItem_4 .

guide:SyllabusItem_1 rdf:type guide:SyllabusItem ;
    guide:itemIndex 1 ;
    guide:syllabusDescription "SUELOS CONTAMINADOS." .

guide:SyllabusItem_2 rdf:type guide:SyllabusItem ;
    guide:itemIndex 2 ;
    guide:syllabusDescription "CONTAMINACIÓN ACÚSTICA Y ATMOSFÉRICA." .

guide:SyllabusItem_3 rdf:type guide:SyllabusItem ;
    guide:itemIndex 3 ;
    guide:syllabusDescription "GESTIÓN DE RESIDUOS." .

guide:SyllabusItem_4 rdf:type guide:Syllabus*.
    guide:itemIndex 4 ;
    guide:syllabusDescription "ENERGÍAS RENOVABLES." .

# Evaluation System
guide:EvalSystem_Servicios_Proteccion rdf:type guide:EvaluationSystem ;
    guide:evaluationDescription "El sistema de evaluación continua se valorara de acuerdo a las siguientes pruebas, ponderadas por el porcentaje especificado." ;
    guide:hasEvaluationTrial guide:Trial_PrimerParcial, guide:Trial_SegundoParcial, guide:Trial_Global .

# Evaluation Trials
guide:Trial_PrimerParcial rdf:type guide:EvaluationTrial ;
    guide:evaluationType "Examen Escrito" ;
    guide:gradePercentage "35%" ;
    guide:minimumScore "4 / 10" ;
    guide:eventWeek "8" ;
    guide:involvesCompetency guide:CM39_1, guide:CM44, guide:CM45, guide:CM38_1, guide:CM38_2 .

guide:Trial_SegundoParcial rdf:type guide:EvaluationTrial ;
    guide:evaluationType "Examen Escrito" ;
    guide:gradePercentage "35%" ;
    guide:minimumScore "4 / 10" ;
    guide:eventWeek "16" ;
    guide:involvesCompetency guide:CM39_1, guide:CM45, guide:CT3, guide:CM37_4 .

guide:Trial_Global rdf:type guide:EvaluationTrial ;
    guide:evaluationType "Examen Escrito" ;
    guide:gradePercentage "100%" ;
    guide:minimumScore "5 / 10" ;
    guide:eventWeek "17" ;
    guide:involvesCompetency guide:CM39_1, guide:CM44, guide:CM45, guide:CT3, guide:CM37_4, guide:CT6, guide:CM38_1, guide:CM38_2 .

