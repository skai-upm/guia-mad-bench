# University Center
guide:ETSICCP rdf:type guide:UniversityCenter ;
    sch:name "E.T.S. De Ing. De Caminos Canales Y P." .

# Degree
guide:Grado_Ingenieria_Civil_y_Territorial rdf:type guide:BachelorDegree ;
    sch:name "04GC - Grado en Ingenieria Civil y Territorial" ;
    guide:degreeCode "04GC" .

# Relationship between Center and Degree
guide:ETSICCP guide:offers guide:Grado_Ingenieria_Civil_y_Territorial .

# Course
guide:Curso_Servicios_Proteccion rdf:type guide:Course ;
    sch:name "45001410 - Servicios, Proteccion Del Medio Urbano Y Gestion D" ;
    guide:courseYear 4 ;
    guide:courseType "Optativa" ;
    guide:semester "Séptimo semestre" ;
    sch:hasCourseInstance guide:Guia_Servicios_Proteccion .

# Relationship between Degree and Course
guide:Grado_Ingenieria_Civil_y_Territorial guide:hasCourse guide:Curso_Servicios_Proteccion .

# Course Guide
guide:Guia_Servicios_Proteccion rdf:type guide:CourseGuide ;
    sch:name "45001410 - Servicios, Proteccion Del Medio Urbano Y Gestion D" ;
    guide:numberOfCredits 3.0 ;
    guide:teachingPeriod "2025-26" ;
    guide:periodStartingMonth "Septiembre" ;
    guide:periodEndingMonth "Enero" ;
    sch:inLanguage "Castellano" ;
    guide:otherInformation "La asignatura se relaciona con el ODS3, ODS7, ODS9, ODS11, ODS12 y ODS13." ;
    guide:hasSyllabus guide:Syllabus_Servicios_Proteccion ;
    guide:hasCompetency guide:CM37_4, guide:CM38_1, guide:CM38_2, guide:CM39_1, guide:CM44, guide:CM45, guide:CT3, guide:CT6 ;
    guide:hasLearningResult guide:RA95, guide:RA99, guide:RA92 ;
    guide:hasEvaluation guide:EvalSystem_Servicios_Proteccion ;
    guide:hasDidacticResource guide:Recurso_Moodle ;
    sch:director guide:Sandra_Paola_Bianucci .

