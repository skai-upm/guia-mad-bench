    guide:competencyCode "12TG-CIST1" ;
    guide:competencyDescription "Conocimiento y utilización de los conceptos de arquitectura de red, protocolos e interfaces de comunicaciones" .

:comp_CT1 rdf:type guide:Competency ;
    guide:competencyCode "CT1" ;
