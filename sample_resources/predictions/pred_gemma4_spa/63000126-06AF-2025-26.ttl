# Competencies
:comp_ce01 rdf:type guide:Competency ;
    guide:competencyCode "CE01" ;
    guide:competencyDescription "Capacidad para abordar y resolver problemas matemáticos avanzados de ingeniería..." .

:comp_ce02 rdf:type guide:Competency ;
    guide:competencyCode "CE02" ;
    guide:competencyDescription "Conocimiento adecuado de aspectos científicos y tecnológicos de mecánica de fluidos, mecánica de medios continuos, cálculo de estructuras, geotecnia, carboquímica y petroquímica" .

:comp_cg01 rdf:type guide:Competency ;
    guide:competencyCode "CG01" ;
    guide:competencyDescription "Capacitación científico-técnica y metodológica para el reciclaje continuo de conocimientos..." .

# Learning Results
:lr_ra144 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA144" ;
    guide:learningResultDescription "Capacidad para comprender la complejidad de las inversiones en proyectos mineros y los mecanismos para su financiación." .

:lr_ra145 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA145" ;
    guide:learningResultDescription "Capacidad para idear, diseñar, proyectar y evaluar explotaciones que maximicen el aprovechamiento de los recursos minerales..." .

# Evaluation System and Trials
:eval_system_63000126 rdf:type guide:EvaluationSystem ;
    guide:evaluationDescription "La calificación final se expresará en una cifra numérica en una escala entre 0 y 10. Se compone de pruebas telemáticas y exámenes finales." .

:trial_eval_block1_2 rdf:type guide:EvaluationTrial ;
    guide:evaluationType "Prueba Telemática" ;
    guide:gradePercentage "25%" ;
    guide:minimumScore "5 / 10" ;
    guide:trialMode "Presencial" ;
    guide:trialWeek "5" ;
    guide:trialDescription "Evaluación de Bloques 1 y 2" .

:trial_exam_final rdf:type guide:EvaluationTrial ;
    guide:evaluationType "Prueba Telemática" ;
    guide:gradePercentage "100%" ;
    guide:minimumScore "5 / 10" ;
    guide:trialMode "Presencial" ;
    guide:trialWeek "17" ;
    guide:trialDescription "Examen final para aquellos alumnos que no superan la evaluación progresiva" .

