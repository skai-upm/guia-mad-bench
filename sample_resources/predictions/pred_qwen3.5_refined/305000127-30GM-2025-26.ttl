    guide:itemIndex "2"^^xsd:string ;
    guide:syllabusDescription "Modelización de superficies mínimas. Problema de Plateau."^^rdf:langString .

# Item 3: Métodos geométricos en robótica
data:#Item_Robotica a guide:SyllabusItem, data:#Syllabus_305000127 ;
    guide:itemIndex "3"^^xsd:string ;
    guide:syllabusDescription "Métodos geométricos en robótica. Grupos y álgebras de Lie."^^rdf:langString .

