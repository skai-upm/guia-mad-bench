#    Competencies and Learning Results
#################################################################

###  http://w3id.org/def/guia#Competency instances
<http://guia-mad-bench.es/data/competency-CB09> rdf:type :Competency ;
    guide:competencyCode "CB09"^^xsd:string ;
    guide:competencyDescription "Que los estudiantes sepan comunicar sus conclusiones y los conocimientos y razones últimas que las sustentan a públicos especializados y no especializados de un modo claro y sin ambigüedades"@en .

<http://guia-mad-bench.es/data/competency-CE_2.8> rdf:type :Competency ;
    guide:competencyCode "CE 2.8"^^xsd:string ;
    guide:competencyDescription "Capacidad para la redacción, dirección y ejecución de Proyectos de Ordenación de Montes"@en .

<http://guia-mad-bench.es/data/competency-CT06> rdf:type :Competency ;
    guide:competencyCode "CT06"^^xsd:string ;
    guide:competencyDescription "Búsqueda bibliográfica, análisis de documentación y tratamiento de la información procedente de diversas fuentes y de su análisis y síntesis aplicándola a la resolución de problemas complejos"@en .

###  http://w3id.org/def/guia#LearningResult instances
<http://guia-mad-bench.es/data/result-RA162> rdf:type :LearningResult ;
    guide:learningResultCode "RA162"^^xsd:string ;
    guide:learningResultDescription "Conocer cómo utilizar la información disponible en la toma de decisiones en gestión forestal"@en .

<http://guia-mad-bench.es/data/result-RA134> rdf:type :LearningResult ;
    guide:learningResultCode "RA134"^^xsd:string ;
    guide:learningResultDescription "Capacidad para realizar búsquedas bibliográficas, consultar y utilizar con criterio bases de datos y otras fuentes de información"@en .

