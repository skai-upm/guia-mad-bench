<http://guia-mad-bench.es/data/competency/CB07> rdf:type :Competency ;
    guide:learningResultCode "CB07"^^xsd:string ;
    sch:description "Que los estudiantes sepan aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en entornos nuevos o poco conocidos"@en .

<http://guia-mad-bench.es/data/competency/CB08> rdf:type :Competency ;
    guide:learningResultCode "CB08"^^xsd:string ;
    sch:description "Que los estudiantes sean capaces de integrar conocimientos y enfrentarse a la complejidad"@en .

<http://guia-mad-bench.es/data/competency/CB09> rdf:type :Competency ;
    guide:learningResultCode "CB09"^^xsd:string ;
    sch:description "Que los estudiantes sepan comunicar sus conclusiones y los conocimientos y razones últimas"@en .

<http://guia-mad-bench.es/data/competency/CB_EIT_03> rdf:type :Competency ;
    guide:learningResultCode "CE-EIT03"^^xsd:string ;
    sch:description "Capacidad para identificar el nivel de madurez de una tecnología y desarrollar e interpretar un roadmap tecnológico"@en .

<http://guia-mad-bench.es/data/competency/CB_CG_01> rdf:type :Competency ;
    guide:learningResultCode "CG01"^^xsd:string ;
    sch:description "Que los estudiantes sean capaces de predecir y controlar la evolución de situaciones complejas"@en .

<http://guia-mad-bench.es/data/competency/CB_CG_03> rdf:type :Competency ;
    guide:learningResultCode "CG03"^^xsd:string ;
    sch:description "La capacidad de usar la lengua inglesa de manera competente"@en .

