@prefix guide: <http://w3id.org/def/guia#> .
@prefix data: <http://guia-mad-bench.es/data/> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix om: <http://www.ontology-of-units-of-measure.org/resource/om-2/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix sch: <https://schema.org/> .

<http://guia-mad-bench.es/data/course_guide_45000246> a guide:CourseGuide ;
    dc:title "Economía Mundial, Española Y Regional"@en ;
    dct:creator "Jose Balibrea Iniesta" ,
               "Antonio Sanchez Soliño" ;
    sch:name "Economía Mundial, Española Y Regional"@en ;
    guide:numberOfCredits 3^^xsd:decimal ;
    guide:teachingPeriod "2025-26"@en ;
    guide:periodStartingMonth "Septiembre"@en ;
    guide:periodEndingMonth "Enero"@en ;
    sch:inLanguage "Castellano" .

<http://guia-mad-bench.es/data/degree_04GD> a guide:Degree ;
    rdfs:subClassOf guide:BachelorDegree ,
                   guide:MasterDegree ; # Note: Doble Grado is complex, mapping to Degree base class as per text "Titulación" structure. However ontology has Bachelor/Master subclasses. I will use generic `guide:Degree` for the instance URI but note it's a Double degree in comment if needed (but instruction says map terms). Text doesn't specify Bachelor or Master explicitly other than Doble Grado, so using base class is safer to avoid type mismatch unless specific subclass exists.
    guide:degreeCode "04GD"^^xsd:string ;
    sch:name "Doble Grado En Ingenieria Civil Y Territorial Y En Ade"@en .

<http://guia-mad-bench.es/data/course_45000246> a guide:Course ;
    rdfs:subClassOf sch:Course ;
    guide:numberOfCredits 3^^xsd:decimal ;
    guide:courseYear "Cuarto curso" .

<http://guia-mad-bench.es/data/course_guide_45000246> guide:hasSyllabus <http://guia-mad-bench.es/data/syllabus_PRCL001> ;
    sch:eventSchedule <http://guia-mad-bench.es/data/schedule_PRCL001> .

<http://guia-mad-bench.es/data/lecturer_jose_balibrea_iniesta> a guide:Lecturer ,
                       sch:Person ;
    rdfs:subClassOf guide:Lecturer ; # Ontology says subClassOf sch:Person. I will use the ontology class as primary type if possible, but text implies Person role. Let's stick to `guide:Lecturer` for consistency with ontology classes provided in reference block (which extends or uses schema.org).
    rdfs:type guide:Lecturer ; # Using Ontology Class directly
    sch:director <http://guia-mad-bench.es/data/course_guide_45000246> ;
    sch:name "Jose Balibrea Iniesta"@en ;
    sch:email "jose.balibrea@upm.es"^^xsd:string ;
    guide:office "6ª planta"@en .

<http://guia-mad-bench.es/data/lecturer_antonio_sanchez_solino> a guide:Lecturer ,
                       sch:Person ;
    rdfs:type guide:Lecturer ;
    sch:name "Antonio Sanchez Soliño"@en ;
    sch:email "antonio.sanchezso@upm.es"^^xsd:string .

<http://guia-mad-bench.es/data/syllabus_PRCL001> a guide:Syllabus ,
                       rdfs:subClassOf sch:Syllabus ;
    guide:hasSyllabus <http://guia-mad-bench.es/data/course_guide_45000246> .

<http://guia-mad-bench.es/data/schedule_PRCL001> a guide:Schedule ,
                       rdfs:subClassOf sch:Schedule ;
    guide:syllabus <http://guia-mad-bench.es/data/syllabus_PRCL001> .

# Syllabus Items (Topics) mapped to Schedule Events or directly as items if ontology allows. Ontology has `guide:SyllabusItem`. I will link them via the syllabus instance using `hasItem` property? No, `guide:CourseGuide hasSyllabus`, and `guide:Syllabus hasItem SyllabusItem`.
# Text lists "Temario" (Topics 1-12). I'll create instances for key topics.

<http://guia-mad-bench.es/data/syllabus_item_01> a guide:SyllabusItem ;
    rdfs:subClassOf sch:Event . # Mapping topic to event-like structure or just item? Ontology has `guide:SyllabusItem`. I will use it directly.
    guide:itemIndex 1^^xsd:integer ;
    guide:syllabusDescription "Operaciones y agregados económicos"@en .

<http://guia-mad-bench.es/data/schedule_event_09> a guide:ScheduleEvent ,
                       rdfs:subClassOf sch:Event ;
    guide:eventIndex 1^^xsd:integer ; # Assuming index based on text order or just generic. Text has "Sem" column. I'll use Sem as identifier if possible, but ontology expects integer for eventIndex? `guide:eventWeek` is langString. Let's stick to properties available in Ontology Data Props.
    guide:activityDurationUnit om:Unit ; # Not specific value in text (01:15). Text says "Duración". I'll use data prop if possible, but ontology has `om:Unit`.
    sch:eventSchedule <http://guia-mad-bench.es/data/schedule_PRCL001> .

# Competencies mapped from text section 4.1
