    guide:trialType "PI"^^xsd:string .

<http://guia-mad-bench.es/data/eval_trial_03> a guide:EvaluationTrial ,
                       rdfs:type guide:EvaluationTrial ;
    sch:name "Trabajo en grupo"@en ; # Text: Trabajo en grupo.
    guide:trialType "TG"^^xsd:string .

<http://guia-mad-bench.es/data/eval_trial_04> a guide:EvaluationTrial ,
                       rdfs:type guide:EvaluationTrial ;
    sch:name "Examen final"@en ; # Text: Examen final.
    guide:trialType "EX"^^xsd:string .

