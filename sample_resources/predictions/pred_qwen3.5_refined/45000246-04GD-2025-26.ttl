    guide:competencyDescription "Entender el funcionamiento de los mercados financieros nacionales e internacionales."@en .

<http://guia-mad-bench.es/data/competency_30AD_E20> a guide:Competency ;
    rdfs:type guide:Competency ;
    guide:competencyCode "30AD.E20"^^xsd:string ;
    guide:competencyDescription "Comprender el contexto económico, regional, nacional e internacional que rodea a la empresa..."@en .

