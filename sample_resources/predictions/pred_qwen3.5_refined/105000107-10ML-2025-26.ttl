data:data-course-guide-105000107 rdf:type guide:CourseGuide ;
    sch:name "Matematica Discreta II"@en ;
    guide:numberOfCredits 6.0^^xsd:decimal ;
    guide:title "Matematica Discreta Ii"@es ;
    guide:syllabusDescription "Teoría de Grafos, algoritmos y modelización@"es ;
    sch:description "La asignatura Matemática Discreta II complementa la asignatura Matemática Discreta I del primer semestre. En ella se estudia principalmente la Teoría de Grafos..."@en ;
    guide:inLanguage "Castellano"@es ;
    guide:teachingPeriodMonths "Febrero-Junio"^^xsd:string ;
    sch:courseSchedule data:data-schedule-105000107 .

data:data-degree-10ML rdf:type guide:BachelorDegree ;
    sch:name "Grado En Matematicas e Informática"@es ;
    dct:title "10ML - Grado En Matematicas E Informática"^^xsd:string .

data:data-course-105000107 rdf:type guide:Course, sch:Course ;
    sch:name "Matematica Discreta Ii"@en ;
    guide:numberOfCredits 6.0^^xsd:decimal ;
    guide:courseYear 2025^^xsd:integer ;
    guide:semester "Segundo semestre"^^xsd:string .

data:data-syllabus-105000107 rdf:type guide:Syllabus, sch:Syllabus ;
    guide:hasSyllabus data:data-course-guide-105000107 ;
    dct:title "Temario de la asignatura"@es .

data:sy-item-1 rdf:type guide:SyllabusItem ;
    rdfs:label "Nociones básicas de grafos y digrafos"^^xsd:string ;
    sch:description "Representación de grafos, sucesión de grados, isomorfismo..."@en ;
    guide:itemIndex 1 .

data:sy-item-2 rdf:type guide:SyllabusItem ;
    rdfs:label "Árboles: Búsquedas y optimización"^^xsd:string ;
    sch:description "Algoritmos de Boruvka, Kruskal y Prim..."@en ;
    guide:itemIndex 2 .

data:sy-item-3 rdf:type guide:SyllabusItem ;
    rdfs:label "Distancias y caminos mínimos. Conectividad"^^xsd:string ;
    sch:description "Algoritmos de Dijkstra, Bellman-Ford..."@en ;
    guide:itemIndex 3 .

data:data-schedule-105000107 rdf:type guide:Schedule, sch:Schedule ;
    sch:eventSchedule data:sch-event-exam-final , data:sch-event-moodle-test .

data:sch-event-exam-final rdf:type guide:ScheduleEvent, sch:Event ;
    rdfs:label "Examen final"^^xsd:string ;
    guide:eventIndex 16 ;
    om:activityDurationUnit "03:00"^^xsd:gDayTime ;
    sch:description "Segundo examen parcial y recuperación del primer parcial"@en .

data:sch-event-moodle-test rdf:type guide:ScheduleEvent, sch:Event ;
    rdfs:label "Cuestionario Moodle"^^xsd:string ;
    guide:eventIndex 6 ;
    om:activityDurationUnit "01:00"^^xsd:gDayTime ;
    sch:description "Prueba telemática"@en .

data:data-evaluation-system-1 rdf:type guide:EvaluationSystem, owl:Thing ;
    rdfs:label "Evaluación Progresiva y Global"@es ;
    guide:evaluationDescription "Sistema mediante pruebas de evaluación progresiva... Se considera superada la asignatura con una nota mayor o igual a 5 sobre 10."@en .

data:data-eval-trial-1 rdf:type guide:EvaluationTrial, owl:Thing ;
    rdfs:label "Examen final"^^xsd:string ;
    sch:name "Segundo examen parcial y recuperación del primer parcial"@es ;
    guide:hasEvaluationTrial data:data-evaluation-system-1 ;
    om:activityDurationUnit "03:00"^^xsd:gDayTime ;
    guide:gradePercentage 85.0^^xsd:decimal ;
    sch:description "Examen Escrito, Presencial"@en .

