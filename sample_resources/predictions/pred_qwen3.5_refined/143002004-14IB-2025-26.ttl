<http://guia-mad-bench.es/data/competency/CE-IA-1> rdf:type :Competency ;
    guide:competencyCode "CE-IA-1"@en ;
    sch:description "Aptitud para realizar los Planes Directores de aeropuertos y los proyectos y la dirección de construcción de las infraestructuras, edificaciones e instalaciones aeroportuarias."^^xsd:string .

<http://guia-mad-bench.es/data/competency/CE-IA-2> rdf:type :Competency ;
    guide:competencyCode "CE-IA-2"@en ;
    sch:description "Capacidad para la Planificación, Diseño, Construcción y Gestión de Aeropuertos, y capacidad para el proyecto de sus Instalaciones Eléctricas."^^xsd:string .

<http://guia-mad-bench.es/data/competency/CE-IA-4> rdf:type :Competency ;
    guide:competencyCode "CE-IA-4"@en ;
    sch:description "Comprensión y dominio de la Organización Aeronáutica nacional e internacional y del funcionamiento de los distintos modos del sistema mundial de transportes, con especial énfasis en el transporte aéreo."^^xsd:string .

<http://guia-mad-bench.es/data/competency/CE-IA-5> rdf:type :Competency ;
    guide:competencyCode "CE-IA-5"@en ;
    sch:description "Conocimiento adecuado de las disciplinas Cartografía, Geodesia, Topografía y Geotecnia, aplicadas al diseño del aeropuerto y sus infraestructuras."^^xsd:string .

<http://guia-mad-bench.es/data/competency/CE-IA-6> rdf:type :Competency ;
    guide:competencyCode "CE-IA-6"@en ;
    sch:description "Capacidad para llevar a cabo la Certificación de Aeropuertos."^^xsd:string .

<http://guia-mad-bench.es/data/competency/CG1> rdf:type :Competency ;
    guide:competencyCode "CG1"@en ;
    sch:description "Capacidad para proyectar, construir, inspeccionar, certificar y mantener todo tipo de aeronaves y vehículos espaciales, con sus correspondientes subsistemas."^^xsd:string .

<http://guia-mad-bench.es/data/competency/CG2> rdf:type :Competency ;
    guide:competencyCode "CG2"@en ;
    sch:description "Capacidad para planificar, proyectar y controlar los procesos de construcción de infraestructuras, edificios e instalaciones aeroportuarias, así como su mantenimiento, conservación y explotación."^^xsd:string .

<http://guia-mad-bench.es/data/competency/CG3> rdf:type :Competency ;
    guide:competencyCode "CG3"@en ;
    sch:description "Capacidad para la dirección general y la dirección técnica de proyectos de investigación, desarrollo e innovación, en empresas y centros tecnológicos aeronáuticos y espaciales."^^xsd:string .

<http://guia-mad-bench.es/data/competency/CG4> rdf:type :Competency ;
    guide:competencyCode "CG4"@en ;
    sch:description "Capacidad de integrar sistemas aeroespaciales complejos y equipos de trabajo multidisciplinares."^^xsd:string .

<http://guia-mad-bench.es/data/competency/CG5> rdf:type :Competency ;
    guide:competencyCode "CG5"@en ;
    sch:description "Capacidad para analizar y corregir el impacto ambiental y social de las soluciones técnicas de cualquier sistema aeroespacial."^^xsd:string .

<http://guia-mad-bench.es/data/competency/CG6> rdf:type :Competency ;
    guide:competencyCode "CG6"@en ;
    sch:description "Capacidad para el análisis y la resolución de problemas aeroespaciales en entornos nuevos o desconocidos, dentro de contextos amplios y complejos."^^xsd:string .

<http://guia-mad-bench.es/data/competency/CG7> rdf:type :Competency ;
    guide:competencyCode "CG7"@en ;
    sch:description "Competencia para planificar, proyectar, gestionar y certificar los procedimientos, infraestructuras y sistemas que soportan la actividad aeroespacial, incluyendo los sistemas de navegación aérea."^^xsd:string .

<http://guia-mad-bench.es/data/competency/CG8> rdf:type :Competency ;
    guide:competencyCode "CG8"@en ;
    sch:description "Competencia para el proyecto de construcciones e instalaciones aeronáuticas y espaciales, que requieran un proyecto integrado de conjunto, por la diversidad de sus tecnologías, su complejidad o por los amplios conocimientos técnicos necesarios."^^xsd:string .

<http://guia-mad-bench.es/data/competency/CG9> rdf:type :Competency ;
    guide:competencyCode "CG9"@en ;
    sch:description "Competencia en todas aquellas áreas relacionadas con las tecnologías aeroportuarias, aeronáuticas o espaciales que, por su naturaleza, no sean exclusivas de otras ramas de la ingeniería."^^xsd:string .

<http://guia-mad-bench.es/data/competency/CG10> rdf:type :Competency ;
    guide:competencyCode "CG10"@en ;
    sch:description "Conocimiento, comprensión y capacidad para aplicar la legislación necesaria en el ejercicio de la profesión de Ingeniero Aeronáutico."^^xsd:string .

<http://guia-mad-bench.es/data/competency/CG11> rdf:type :Competency ;
    guide:competencyCode "CG11"@en ;
    sch:description "Poseer y comprender conocimientos que aportan una base u oportunidad de ser originales en el desarrollo y/o aplicación de ideas, a menudo en un contexto de investigación."^^xsd:string .

<http://guia-mad-bench.es/data/competency/CG12> rdf:type :Competency ;
    guide:competencyCode "CG12"@en ;
    sch:description "Aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en entornos nuevos o poco conocidos dentro de contextos más amplios (o multidisciplinares) relacionados con su área de estudio."^^xsd:string .

<http://guia-mad-bench.es/data/competency/CG13> rdf:type :Competency ;
    guide:competencyCode "CG13"@en ;
    sch:description "Ser capaz de integrar conocimientos y enfrentarse a la complejidad de formular juicios a partir de una información que, siendo incompleta o limitada, incluya reflexiones sobre las responsabilidades sociales y éticas vinculadas a la aplicación de sus conocimientos y juicios."^^xsd:string .

<http://guia-mad-bench.es/data/competency/CG14> rdf:type :Competency ;
    guide:competencyCode "CG14"@en ;
    sch:description "Comunicar sus conclusiones ?y los conocimientos y razones últimas que las sustentan? a públicos especializados y no especializados de un modo claro y sin ambigüedades."^^xsd:string .

<http://guia-mad-bench.es/data/competency/CG15> rdf:type :Competency ;
    guide:competencyCode "CG15"@en ;
    sch:description "Poseer las habilidades de aprendizaje que les permitan continuar estudiando de un modo que habrá de ser en gran medida autodirigido o autónomo."^^xsd:string .

<http://guia-mad-bench.es/data/competency/CG16> rdf:type :Competency ;
    guide:competencyCode "CG16"@en ;
    sch:description "Capacidad de integrar el respeto al medio ambiente como actitud general en la gestión y el desempeño de sus actividades."^^xsd:string .

<http://guia-mad-bench.es/data/competency/CT1> rdf:type :Competency ;
    guide:competencyCode "CT1"@en ;
    sch:description "Capacidad para comprender los contenidos de clases magistrales, conferencias y seminarios, así como cualquier información y documentación en lengua inglesa."^^xsd:string .

<http://guia-mad-bench.es/data/competency/CT2> rdf:type :Competency ;
    guide:competencyCode "CT2"@en ;
    sch:description "Capacidad para dinamizar y liderar equipos de trabajo multidisciplinares."^^xsd:string .

<http://guia-mad-bench.es/data/competency/CT3> rdf:type :Competency ;
    guide:competencyCode "CT3"@en ;
    sch:description "Capacidad para adoptar soluciones creativas que satisfagan adecuadamente las diferentes necesidades planteadas."^^xsd:string .

<http://guia-mad-bench.es/data/competency/CT4> rdf:type :Competency ;
    guide:competencyCode "CT4"@en ;
    sch:description "Capacidad para trabajar de forma efectiva como individuo, organizando y planificando su propio trabajo, de forma independiente o como miembro de un equipo."^^xsd:string .

<http://guia-mad-bench.es/data/competency/CT5> rdf:type :Competency ;
    guide:competencyCode "CT5"@en ;
    sch:description "Capacidad para gestionar la información, identificando las fuentes necesarias, los principales tipos de documentos técnicos y científicos, de una manera adecuada y eficiente."^^xsd:string .

<http://guia-mad-bench.es/data/competency/CT6> rdf:type :Competency ;
    guide:competencyCode "CT6"@en ;
    sch:description "Capacidad para emitir juicios sobre implicaciones económicas, administrativas, sociales, éticas y medioambientales ligadas a la aplicación de sus conocimientos."^^xsd:string .

<http://guia-mad-bench.es/data/competency/CT7> rdf:type :Competency ;
    guide:competencyCode "CT7"@en ;
    sch:description "Capacidad para trabajar en contextos internacionales."^^xsd:string .

