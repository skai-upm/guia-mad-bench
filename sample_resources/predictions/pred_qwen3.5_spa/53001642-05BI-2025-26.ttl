    guide:syllabusDescription "In this course, the fundamentals of smart grids are covered..."@en .

<http://guia-mad-bench.es/data/syllabus/anx-pr-cl-001-syllabus> a guide:Syllabus ;
    sch:name "Temario Smart Grids"@es ;
    rdfs:comment "Outline for the course ANX-PR/CL/001-01" .

<http://guia-mad-bench.es/data/syllabus-item/1> a guide:SyllabusItem ;
    guide:itemIndex 1^^xsd:integer ;
    sch:name "Introduction to Smart Grids and Microgrids"@en ;
    guide:syllabusDescription "Introducción a las redes inteligentes y microredes."@es .

<http://guia-mad-bench.es/data/syllabus-item/2> a guide:SyllabusItem ;
    guide:itemIndex 2^^xsd:integer ;
    sch:name "Architectures of AC and DC Microgrids. Different topologies"@en ;
    guide:syllabusDescription "Arquitecturas de microredes CA y CC."@es .

<http://guia-mad-bench.es/data/syllabus-item/3> a guide:SyllabusItem ;
    guide:itemIndex 3^^xsd:integer ;
    sch:name "The role of Power Electronics in Smart Grids and Microgrids"@en ;
    guide:syllabusDescription "El papel de la electrónica de potencia."@es .

<http://guia-mad-bench.es/data/syllabus-item/4> a guide:SyllabusItem ;
    guide:itemIndex 4^^xsd:integer ;
    sch:name "AC Microgrids. Power Converters in AC Microgrids"@en ;
    guide:syllabusDescription "Microredes CA y convertidores de potencia."@es .

<http://guia-mad-bench.es/data/syllabus-item/5> a guide:SyllabusItem ;
    guide:itemIndex 5^^xsd:integer ;
    sch:name "Synchronization Techniques. PLLs, DSOGI, etc"@en ;
    guide:syllabusDescription "Técnicas de sincronización."@es .

<http://guia-mad-bench.es/data/syllabus-item/6> a guide:SyllabusItem ;
    guide:itemIndex 6^^xsd:integer ;
    sch:name "PWM Techniques. Space Vector Modulation"@en ;
    guide:syllabusDescription "Técnicas PWM y modulación de vector espacial."@es .

<http://guia-mad-bench.es/data/syllabus-item/7> a guide:SyllabusItem ;
    guide:itemIndex 7^^xsd:integer ;
    sch:name "Park Transformation review. dq controllers in power converters"@en ;
    guide:syllabusDescription "Transformación de Park y controladores dq."@es .

<http://guia-mad-bench.es/data/syllabus-item/8> a guide:SyllabusItem ;
    guide:itemIndex 8^^xsd:integer ;
    sch:name "An exercise of a 3-phase power inverter in grid-connected mode using Matlab/Simulink"@en ;
    guide:syllabusDescription "Ejercicio de inversor trifásico en modo conectado."@es .

<http://guia-mad-bench.es/data/syllabus-item/9> a guide:SyllabusItem ;
    guide:itemIndex 9^^xsd:integer ;
    sch:name "DC Microgrids. Advantages and disadvantages in DC Power Distribution"@en ;
    guide:syllabusDescription "Microredes CC y distribución."@es .

<http://guia-mad-bench.es/data/syllabus-item/10> a guide:SyllabusItem ;
    guide:itemIndex 10^^xsd:integer ;
    sch:name "Power Converters in DC Distribution. Droop Control in DC Microgrids"@en ;
    guide:syllabusDescription "Convertidores en distribución CC y control de caída."@es .

<http://guia-mad-bench.es/data/syllabus-item/11> a guide:SyllabusItem ;
    guide:itemIndex 11^^xsd:integer ;
    sch:name "DC Bus Signalling as a control strategy in DC distribution. Models and Simulation"@en ;
    guide:syllabusDescription "Señalización de bus CC y simulación."@es .

