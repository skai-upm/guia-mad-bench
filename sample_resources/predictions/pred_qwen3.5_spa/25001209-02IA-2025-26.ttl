    guide:competencyCode "CE15"^^xsd:string ;
    sch:description "Capacidad para aplicar los principios de la botánica en la identificación y caracterización de especies vegetales, así como conocer las principales especies agrícolas..."@en .

<http://guia-mad-bench.es/data/comp_CG16> rdf:type :Competency ;
    guide:competencyCode "CG16"^^xsd:string ;
    sch:description "Aplicar conocimientos adquiridos a la práctica de la ingeniería agraria"@en .

<http://guia-mad-bench.es/data/comp_CE3> rdf:type :Competency ;
    guide:competencyCode "CE3"^^xsd:string ;
    sch:description "Que los estudiantes tengan la capacidad de reunir e interpretar datos relevantes..."@en .

<http://guia-mad-bench.es/data/comp_CG5> rdf:type :Competency ;
    guide:competencyCode "CG5"^^xsd:string ;
    sch:description "Que los estudiantes hayan desarrollado aquellas habilidades de aprendizaje necesarias para emprender estudios posteriores con un alto grado de autonomía"@en .

<http://guia-mad-bench.es/data/comp_CG7> rdf:type :Competency ;
    guide:competencyCode "CG7"^^xsd:string ;
    sch:description "Compromiso ético y profesional y respeto por el medio ambiente y la diversidad"@en .

<http://w3id.org/def/guia#LearningResult> rdf:type owl:Class ;
