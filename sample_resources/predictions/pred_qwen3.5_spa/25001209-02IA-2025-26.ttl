<http://guia-mad-bench.es/data/res_RA47> rdf:type :LearningResult ;
    guide:learningResultCode "RA47"^^xsd:string ;
    sch:description "Reconocer y caracterizar las principales especies vegetales de interés en los campos de la agronomía y la flora española"@en .

<http://guia-mad-bench.es/data/res_RA48> rdf:type :LearningResult ;
    guide:learningResultCode "RA48"^^xsd:string ;
    sch:description "Relacionar caracteres botánicos con las aplicaciones de las especies vegetales y sus requerimientos de hábitat"@en .

<http://guia-mad-bench.es/data/res_RA50> rdf:type :LearningResult ;
    guide:learningResultCode "RA50"^^xsd:string ;
    sch:description "Identificar especies vegetales mediante el uso e interpretación de herramientas apropiadas al caso"@en .

