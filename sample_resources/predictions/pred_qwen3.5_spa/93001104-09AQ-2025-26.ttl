    <http://guia-mad-bench.es/data/res_RA217>,
    <http://guia-mad-bench.es/data/res_RA115> .

<http://guia-mad-bench.es/data/comp_CE12> rdf:type guide:Competency ;
    guide:competencyCode "CE12"^^xsd:string ;
    guide:competencyDescription "Capacidad para utilizar dispositivos lógicos programables, así como para diseñar sistemas electrónicos avanzados"@en .

<http://guia-mad-bench.es/data/comp_CE15> rdf:type guide:Competency ;
    guide:competencyCode "CE15"^^xsd:string ;
    guide:competencyDescription "Capacidad para la integración de tecnologías y sistemas propios de la Ingeniería de Telecomunicación"@en .

<http://guia-mad-bench.es/data/comp_CG2> rdf:type guide:Competency ;
    guide:competencyCode "CG2"^^xsd:string ;
    guide:competencyDescription "Que los estudiantes sepan aplicar los conocimientos adquiridos y su capacidad de resolución de problemas"@en .

<http://guia-mad-bench.es/data/res_RA116> rdf:type guide:LearningResult ;
    guide:learningResultCode "RA116"^^xsd:string ;
    guide:learningResultDescription "Diseñar e implementar aplicaciones reales usando plataformas de diseño basadas en procesadores avanzados"@en .

<http://guia-mad-bench.es/data/res_RA218> rdf:type guide:LearningResult ;
    guide:learningResultCode "RA218"^^xsd:string ;
    guide:learningResultDescription "Analizar y diseñar el software de un sistema electrónico"@en .

<http://guia-mad-bench.es/data/item_intro> rdf:type guide:SyllabusItem ;
    guide:itemIndex 1^^xsd:integer ;
    guide:syllabusDescription "Introducción a los sistemas empotrados, Aplicaciones, Ejemplo motivante, Proceso de diseño"@en .

<http://guia-mad-bench.es/data/item_hardware> rdf:type guide:SyllabusItem ;
    guide:itemIndex 2^^xsd:integer ;
    guide:syllabusDescription "Diseño hardware de sistemas empotrados, Microcontroladores, Arquitectura de memoria, Entrada/Salida"@en .

<http://guia-mad-bench.es/data/item_software> rdf:type guide:SyllabusItem ;
    guide:itemIndex 3^^xsd:integer ;
    guide:syllabusDescription "Diseño software de sistemas empotrados, Sistemas Operativos, Tareas, Planificación en tiempo real"@en .

