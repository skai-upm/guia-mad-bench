<http://guia-mad-bench.es/data/courseGuide_93001104> rdf:type guide:CourseGuide ;
    dc:title "Sistemas Electronicos Para Iot"@en ;
    dct:creator "Alvaro Araujo Pinto" ,
               "Pedro Jose Malagon Marzo" ;
    sch:name "Sistemas Electronicos Para Iot" ;
    guide:numberOfCredits 4^^xsd:decimal ;
    guide:teachingPeriodMonths "Septiembre - Enero"@en ;
    sch:inLanguage "Castellano"@en ;
    guide:syllabusDescription <http://guia-mad-bench.es/data/syllabus_93001104> .

