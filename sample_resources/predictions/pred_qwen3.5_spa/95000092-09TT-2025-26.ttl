    sch:name "Manuel Sierra Castañer"@es ;
    guide:office "C-410"@en ;
    sch:email <mailto:manuel.sierra@upm.es> .

<http://guia-mad-bench.es/data/guide:Lecturer#Carlos_Del_Cañizo_Nadal> rdf:type :Lecturer , :CourseGuideDirector ; # Note: Ontology doesn't have CourseGuideDirector class, but sch:name is used. I will use the ontology classes provided for Lecturers and link via properties defined in ontology like guide:syllabusDescription? No, that's SyllabusItem.
    sch:description "Coordinador/a"@es .

