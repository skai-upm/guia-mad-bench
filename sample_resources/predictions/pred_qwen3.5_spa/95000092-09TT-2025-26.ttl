<http://guia-mad-bench.es/data/guide:CourseGuide#95000092> rdf:type :CourseGuide ;
    dct:title "Ingeniería en Cooperación para el Desarrollo (Icd)"@en ;
    guide:numberOfCredits 4.5^^xsd:decimal ;
    sch:name "ANX-PR/CL/001 - GUÍA DE APRENDIZAJE"@es ;
    guide:courseYear 2026^^xsd:integer ; # Assuming year based on context, though text says 2025/26. Text explicitly mentions 2025/26. I will use the academic year string or integer if mapped to courseYear property which expects xsd:integer in ontology but document has "Curso académico". Let's stick to data available.
    guide:syllabusDescription "El mundo en que vivimos, Estrategias de la cooperación para el desarrollo..."@es ; # Simplified based on text content summary or use specific item descriptions if linked directly. The property is for SyllabusItem in ontology but I will map the course description to CourseGuide using available properties like sch:description which exists in ontology (https://schema.org/description).
    guide:teachingPeriod "Febrero-Junio"@es ;
    dct:creator <http://guia-mad-bench.es/data/guide:Lecturer#Carlos_Del_Cañizo_Nadal> ,
               <http://guia-mad-bench.es/data/guide:Lecturer#Manuel_Sierra_Castañer> ;
    sch:description "La asignatura pretende dar una visión al alumnado de los fundamentos de cooperación para el desarrollo y del papel de la ingeniería en entornos de bajo nivel de desarrollo."@es .

