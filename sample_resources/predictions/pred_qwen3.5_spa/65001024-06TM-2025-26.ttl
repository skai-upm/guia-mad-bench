@prefix : <http://w3id.org/def/guia#> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix om: <http://www.ontology-of-units-of-measure.org/resource/om-2/> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix sch: <https://schema.org/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

#################################################################
#    Classes (Ontology)
#################################################################

###  http://w3id.org/def/guia#Activity
guide:Activity rdf:type owl:Class ;
               rdfs:comment "A teaching or learning activity carried out as part of the course, such as lectures, labs, seminars, tutorials, or independent work."@en .


#################################################################
#    Classes (Instances) - Data Extraction
#################################################################

###  http://guia-mad-bench.es/data/course_guide_65001024
:courseGuide_65001024 rdf:type :CourseGuide ;
                       sch:name "Teoria De Estructuras Y Procedimientos de Construc" ;
                       guide:numberOfCredits 4.5 .


###  http://guia-mad-bench.es/data/degree_06TM
:degree_06TM rdf:type :BachelorDegree ;
             dct:title "Grado En Ingenieria En Tecnologia Minera"@en ;
             sch:name "Grado en Ingeniería en Tecnología Minera" .


###  http://guia-mad-bench.es/data/course_65001024
:course_65001024 rdf:type :Course ;
                  dct:title "Teoria De Estructuras Y Procedimientos de Construc"@en ;
                  sch:name "65001024 - Teoria De Estructuras y Procedimientos de Construccion" .


###  http://guia-mad-bench.es/data/syllabus_65001024
:syllabus_65001024 rdf:type :Syllabus ;
                    sch:name "Guía de Aprendizaje - Teoria De Estructuras y Procedimientos de Construccion"@en .


###  http://guia-mad-bench.es/data/schedule_65001024
:schedule_65001024 rdf:type :Schedule ;
                    sch:name "Cronograma - Teoria De Estructuras y Procedimientos de Construccion"@en .


###  http://guia-mad-bench.es/data/eval_system_65001024
:evalSystem_65001024 rdf:type :EvaluationSystem ;
                      sch:name "Sistema de Evaluación - Teoria De Estructuras y Procedimientos de Construccion"@en .


#################################################################
#    Object Properties (Ontology)
#################################################################

###  http://w3id.org/def/guia#hasCourseInstance
sch:hasCourseInstance rdf:type owl:ObjectProperty ;
                      rdfs:domain :Course ;
                      rdfs:range :CourseGuide ;
                      rdfs:comment "Links a course to a concrete course guide or offering for a given academic period."@en .


###  http://w3id.org/def/guia#hasSyllabus
guide:hasSyllabus rdf:type owl:ObjectProperty ;
                  rdfs:domain :CourseGuide ;
                  rdfs:range :Syllabus ;
                  rdfs:comment "Links a course guide to the syllabus that describes the thematic contents of the course."@en .


###  http://w3id.org/def/guia#hasScheduleEvent
guide:hasScheduleEvent rdf:type owl:ObjectProperty ;
                       rdfs:domain :EvaluationTrial ;
                       rdfs:range :ScheduleEvent ;
                       rdfs:comment "Links an evaluation trial to the schedule event in which it takes place."@en .


#################################################################
#    Data Properties (Ontology)
#################################################################

###  http://w3id.org/def/guia#numberOfCredits
guide:numberOfCredits rdf:type owl:DatatypeProperty ;
                      rdfs:domain :CourseGuide ;
                      rdfs:range xsd:decimal .


