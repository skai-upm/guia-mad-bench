# Competencies (CB1, CB5, CE 1, CG3)
<http://guia-mad-bench.es/data/competency/CB1> rdf:type :Competency ;
    guide:competencyCode "CB1"@en ;
    guide:competencyDescription "Que los estudiantes hayan demostrado poseer y comprender conocimientos en un área de estudio que parte de la base de la educación secundaria general, y se suele encontrar a un nivel que, si bien se apoya en libros de texto avanzados, incluye también algunos aspectos que implican conocimientos procedentes de la vanguardia de su campo de estudio"@es .

<http://guia-mad-bench.es/data/competency/CB5> rdf:type :Competency ;
    guide:competencyCode "CB5"@en ;
    guide:competencyDescription "Que los estudiantes hayan desarrollado aquellas habilidades de aprendizaje necesarias para emprender estudios posteriores con un alto grado de autonomía"@es .

<http://guia-mad-bench.es/data/competency/CE_1> rdf:type :Competency ;
    guide:competencyCode "CE 1"@en ;
    guide:competencyDescription "Capacidad para la resolución de los problemas matemáticos que puedan plantearse en la ingeniería. Aptitud para aplicar los conocimientos sobre álgebra lineal; geometría; cálculo diferencial e integral..."@es .

<http://guia-mad-bench.es/data/competency/CG3> rdf:type :Competency ;
    guide:competencyCode "CG3"@en ;
    guide:competencyDescription "Capacidad para el aprendizaje de nuevos métodos y teorías, y en la versatilidad para adaptarse a nuevas situaciones basándose en los conocimientos adquiridos..."@es .

# Link Competencies to CourseGuide
<http://guia-mad-bench.es/data/course/GA_08NV_85003112> :hasCompetency <http://guia-mad-bench.es/data/competency/CB1> ;
    :hasCompetency <http://guia-mad-bench.es/data/competency/CB5> ;
    :hasCompetency <http://guia-mad-bench.es/data/competency/CE_1> ;
    :hasCompetency <http://guia-mad-bench.es/data/competency/CG3> .

# Learning Results (RA20-RA24)
<http://guia-mad-bench.es/data/result/Ra20> rdf:type :LearningResult ;
    guide:learningResultCode "RA20"@en ;
    guide:learningResultDescription "Resolver límites de funciones. Analizar la continuidad y derivabilidad. Aproximación polinómica..."@es .

<http://guia-mad-bench.es/data/result/Ra21> rdf:type :LearningResult ;
    guide:learningResultCode "RA21"@en ;
    guide:learningResultDescription "Aplicar correctamente los métodos de integración elementales. Estudiar la convergencia de las integrales impropias..."@es .

<http://guia-mad-bench.es/data/result/Ra22> rdf:type :LearningResult ;
    guide:learningResultCode "RA22"@en ;
    guide:learningResultDescription "Estudiar la convergencia de sucesiones y series numéricas. Determinar el conjunto de convergencia..."@es .

<http://guia-mad-bench.es/data/result/Ra23> rdf:type :LearningResult ;
    guide:learningResultCode "RA23"@en ;
    guide:learningResultDescription "Manejar la aritmética compleja con soltura. Representar en forma binómica, trigonométrica o exponencial..."@es .

<http://guia-mad-bench.es/data/result/Ra24> rdf:type :LearningResult ;
    guide:learningResultCode "RA24"@en ;
    guide:learningResultDescription "Métodos numéricos: método de la bisección, interpolación de Lagrange e integración numérica."@es .

# Link Learning Results to CourseGuide
<http://guia-mad-bench.es/data/course/GA_08NV_85003112> :hasLearningResult <http://guia-mad-bench.es/data/result/Ra20> ;
    :hasLearningResult <http://guia-mad-bench.es/data/result/Ra21> ;
    :hasLearningResult <http://guia-mad-bench.es/data/result/Ra22> ;
    :hasLearningResult <http://guia-mad-bench.es/data/result/Ra23> ;
    :hasLearningResult <http://guia-mad-bench.es/data/result/Ra24> .

