<http://guia-mad-bench.es/data/schedule_event_203000027> rdf:type :ScheduleEvent ;
    guide:eventIndex "4"^^xsd:integer ;
    sch:description "Problems: Estimation of selection coefficients through the use of fitness measures"@en .

<http://guia-mad-bench.es/data/schedule_event_8_203000027> rdf:type :ScheduleEvent ;
    guide:eventIndex "8"^^xsd:integer ;
    sch:description "Practical work: The students will be provided with a nucleotide sequence alignment derived from individuals from a given population of the same organism. They will have to estimate mutation rates and the genetic structure of the population."@en .

<http://guia-mad-bench.es/data/schedule_event_15_203000027> rdf:type :ScheduleEvent ;
    guide:eventIndex "15"^^xsd:integer ;
    sch:description "Practical work: The students are provided with an alignment with nucleotide sequence from the genome of various related species, and they have to analyze whether these species followed a simpatric or an allopatric mode of speciation."@en .

<http://guia-mad-bench.es/data/schedule_event_17_203000027> rdf:type :ScheduleEvent ;
    guide:eventIndex "17"^^xsd:integer ;
    sch:description "The students will be provided with genetic and phenotypic data for certain organisms and they have to aswer five questions about the evolutionary dynamics of the population."@en .

<http://guia-mad-bench.es/data/schedule_event_4_eval> rdf:type :ScheduleEvent ;
    guide:trialType "Progressive assessment"@en ;
    sch:description "Problem-solving test"@en .

