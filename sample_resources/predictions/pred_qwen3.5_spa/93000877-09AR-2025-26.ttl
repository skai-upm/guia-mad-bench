<http://guia-mad-bench.es/data/syllabitem/GA_09AR_93000877_SyllabusItem_1> rdf:type :SyllabusItem ;
    guide:itemIndex 1^^xsd:integer ;
    guide:syllabusDescription "Introducción: tipos de problemas; aprendizaje automático y aprendizaje estadístico; redes neuronales artificiales."@en .

<http://guia-mad-bench.es/data/schedule/GA_09AR_93000877_Schedule> rdf:type :Schedule, sch:Schedule ;
    guide:eventIndex 1^^xsd:integer .

<http://guia-mad-bench.es/data/competency/CE1> rdf:type :Competency ;
    guide:competencyCode "CE1" ;
    guide:hasLearningResult <http://guia-mad-bench.es/data/learningresult/RA54> .

<http://guia-mad-bench.es/data/courseguide/GA_09AR_93000877> guide:hasCompetency <http://guia-mad-bench.es/data/competency/CE1> ;
    sch:description "Adquisición de una formación sólida y rigurosa en temas avanzados..."@en .

<http://guia-mad-bench.es/data/courseguide/GA_09AR_93000877> guide:hasLearningResult <http://guia-mad-bench.es/data/learningresult/RA54> ;
    sch:description "Capacidad para diseñar modelos neuronales que resuelvan problemas de aprendizaje estadístico."@en .

<http://guia-mad-bench.es/data/syllabitem/GA_09AR_93000877_SyllabusItem_2> rdf:type :SyllabusItem ;
    guide:itemIndex 2^^xsd:integer ;
    guide:syllabusDescription "Fundamentos matemáticos: dinámica de sistemas; teoría de optimización; inferencia estadística y teoría de regresión (lineal y logística)."@en .

<http://guia-mad-bench.es/data/schedule/GA_09AR_93000877_Schedule> guide:eventIndex 2^^xsd:integer ;
    sch:description "El método de la ingeniería y pensamiento estadístico. -Modelos: relevancia y construcción."@en .

<http://guia-mad-bench.es/data/syllabitem/GA_09AR_93000877_SyllabusItem_5> rdf:type :SyllabusItem ;
    guide:itemIndex 5^^xsd:integer ;
    guide:syllabusDescription "Modelos alternativos/avanzados para aprendizaje supervisado y no supervisado: modelos gráficos, máquinas de Boltzmann, arquitecturas profundas, etc."@en .

<http://guia-mad-bench.es/data/schedule/GA_09AR_93000877_Schedule> guide:eventIndex 5^^xsd:integer ;
    sch:description "Otros modelos: RBFs, wavenets SVM. -Modelos hebbianos."@en .

<http://guia-mad-bench.es/data/syllabitem/GA_09AR_93000877_SyllabusItem_6> rdf:type :SyllabusItem ;
    guide:itemIndex 6^^xsd:integer ;
    guide:syllabusDescription "Otros tipos de problemas: aprendizaje semisupervisado, aprendizaje por refuerzo, en entornos dinámicos; optimización de funciones tipo caja negra."@en .

<http://guia-mad-bench.es/data/schedule/GA_09AR_93000877_Schedule> guide:eventIndex 6^^xsd:integer ;
    sch:description "Otros tipos de problemas: aprendizaje semisupervisado, aprendizaje por refuerzo..."@en .

