        "Turbomáquinas Térmicas para Aplicaciones Navales"@es ;
    schema:numberOfCredits 4.5 .

<https://guia-kg.skai.etsisi.upm.es/resource/85004612/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/85004612/2025-26/CB2>,
