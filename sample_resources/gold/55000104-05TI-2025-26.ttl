    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/55000104/2025-26/eventSchedule> ;
    schema:description "La asignatura cubre los aspectos principales del diseño de sistemas digitales empleando para ello un Lenguaje de Descripción Hardware (VHDL). Se estudiarán tanto el diseño de circuitos combinacionales como el de circuitos secuenciales síncronos. Se verán también tecnologías de implementación de circuitos digitales, y los primeros conceptos de arquitecturas de sistemas digitales, que servirán de enlace a asignaturas posteriores."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/joseandres.otero%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/jorge.portilla%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/joseandres.otero%40upm.es> ;
    schema:name "Electronica Digital"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000104/2025-26/CE21A> a ns1:Competency ;
    ns1:competencyCode "CE21A" ;
    ns1:competencyDescription "Conocimiento de los fundamentos y aplicaciones de la electrónica digital y microprocesadores."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000104/2025-26/CE24A> a ns1:Competency ;
    ns1:competencyCode "CE24A" ;
    ns1:competencyDescription "Capacidad para diseñar sistemas electrónicos analógicos, digitales y de potencia."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000104/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Conocer y aplicar conocimientos de ciencias y tecnologías básicas a la práctica de la Ingeniería Industrial."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000104/2025-26/CG10> a ns1:Competency ;
    ns1:competencyCode "CG10" ;
    ns1:competencyDescription "Capacidad para generar nuevas ideas (Creatividad)."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000104/2025-26/CG2> a ns1:Competency ;
    ns1:competencyCode "CG2" ;
    ns1:competencyDescription "Poseer capacidad para diseñar, desarrollar, implementar, gestionar y mejorar productos, sistemas y procesos en los distintos ámbitos industriales, usando técnicas analíticas, computacionales o experimentales apropiadas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000104/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Aplicar los conocimientos adquiridos para identificar, formular y resolver problemas dentro de contextos amplios y multidisciplinarios, siendo capaces de integrar conocimientos, trabajando en equipos multidisciplinares."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000104/2025-26/CG5> a ns1:Competency ;
    ns1:competencyCode "CG5" ;
    ns1:competencyDescription "Saber comunicar los conocimientos y conclusiones, de forma oral, escrita y gráfica, a públicos especializados y no especializados de un modo claro y sin ambigüedades."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000104/2025-26/CG6> a ns1:Competency ;
    ns1:competencyCode "CG6" ;
    ns1:competencyDescription "Poseer habilidades de aprendizaje que permitan continuar estudiando a lo largo de la vida para su adecuado desarrollo profesional."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000104/2025-26/CG7> a ns1:Competency ;
    ns1:competencyCode "CG7" ;
    ns1:competencyDescription "Incorporar nuevas tecnologías y herramientas de la Ingeniería Industrial en sus actividades profesionales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000104/2025-26/CG9> a ns1:Competency ;
    ns1:competencyCode "CG9" ;
    ns1:competencyDescription "Organización y planificación en el ámbito de la empresa, y otras instituciones y organizaciones de proyectos y equipos humanos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000104/2025-26/RA8> a ns1:LearningResult ;
    ns1:learningResultCode "RA8" ;
    ns1:learningResultDescription "Capacidad y habilidades para diseñar circuitos digitales de complejidad intermedia, a partir de bloques funcionales conocidos, combinados con máquinas de estados."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000104/2025-26/RA9> a ns1:LearningResult ;
    ns1:learningResultCode "RA9" ;
    ns1:learningResultDescription "Adquirir criterios para seleccionar las diferentes posibilidades tecnológicas de implementación de circuitos"@es .

