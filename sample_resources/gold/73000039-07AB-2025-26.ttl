    ns1:numberOfCredits 5.0 ;
    ns1:otherInformation "La asignatura está vinculada al ODS13 ACCIÓN POR EL CLIMA y ODS15 VIDA DE ECOSISTEMAS TERRESTRES"@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
