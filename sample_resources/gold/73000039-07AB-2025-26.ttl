    ns1:competencyCode "CE 1.2" ;
    ns1:competencyDescription "Capacidad para emprender acciones relacionadas con la gestión forestal"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/73000039/2025-26/CE%202.1> a ns1:Competency ;
    ns1:competencyCode "CE 2.1" ;
    ns1:competencyDescription "Capacidad para diseñar, redactar y gestionar planes y políticas de prevención y detección de incendios"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/73000039/2025-26/CG%205> a ns1:Competency ;
    ns1:competencyCode "CG 5" ;
    ns1:competencyDescription "Búsqueda bibliográfica, análisis de documentación y tratamiento de la información procedente de diversas fuentes y de su análisis y síntesis aplicándola a la resolución de problemas complejos, en el campo de la gestión de incendios forestales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/73000039/2025-26/CG%206> a ns1:Competency ;
    ns1:competencyCode "CG 6" ;
    ns1:competencyDescription "Perfeccionar el conocimiento oral y escrito de la lengua inglesa"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/73000039/2025-26/RA41> a ns1:LearningResult ;
    ns1:learningResultCode "RA41" ;
    ns1:learningResultDescription "Capacidad para diseñar, dirigir, elaborar, implementar e interpretar proyectos y planes de prevención y gestión territorial de incendios"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/73000039/2025-26/RA42> a ns1:LearningResult ;
    ns1:learningResultCode "RA42" ;
    ns1:learningResultDescription "Conocimientos adecuados para la gestión de trabajos de limpieza del sotobosque y el establecimiento de cortafuegos y cortacombustibles y de infraestructuras de apoyo al combate del fuego."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/73000039/2025-26/RA43> a ns1:LearningResult ;
    ns1:learningResultCode "RA43" ;
    ns1:learningResultDescription "Capacidad para poner en práctica técnicas de selvicultura preventiva y de reducción del combustible en el monte"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/73000039/2025-26/RA44> a ns1:LearningResult ;
    ns1:learningResultCode "RA44" ;
    ns1:learningResultDescription "Que los estudiantes tengan conocimientos y capacidades para tomar, gestionar y analizar datos de detección, prevención o lucha contra incendios."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/73000039/2025-26/RA45> a ns1:LearningResult ;
    ns1:learningResultCode "RA45" ;
    ns1:learningResultDescription "Que los estudiantes tengan conocimientos para crear e interpretar cartografía temática y aplicarla a la gestión en su campo de trabajo"@es .

