    ns1:bibliographyDescription "básico"@es ;
    ns1:bibliographyTitle "Tortora, G.H. & Evans, R.L. (2009). \"Principles of human phisiology\". Harper and Row. New York. 12ed"@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000317/2025-26/didactic_resource/2> a ns1:DidacticResource ;
    ns1:bibliographyDescription "básico"@es ;
    ns1:bibliographyTitle "Guyton, A. C., & Hall, J. E. (2011). Tratado de fisiología médica (12ª ed.). Madrid: Elsevier España"@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000317/2025-26/didactic_resource/3> a ns1:DidacticResource ;
