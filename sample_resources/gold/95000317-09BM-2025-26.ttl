    ns1:bibliographyTitle "Silverthorn, D. U. (2008). Fisiología humana : un enfoque integrado (4ª ed.). Madrid: Editorial Médica Panamericana."@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000317/2025-26/didactic_resource/4> a ns1:DidacticResource ;
