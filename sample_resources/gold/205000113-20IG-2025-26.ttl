<https://guia-kg.skai.etsisi.upm.es/resource/205000113/2025-26/RA271> a ns1:LearningResult ;
    ns1:learningResultCode "RA271" ;
    ns1:learningResultDescription "Aplicar los principios de la genética a los procedimientos relacionados con la conservación, selección y mejora de especies de interés ganadero."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000113/2025-26/RA272> a ns1:LearningResult ;
    ns1:learningResultCode "RA272" ;
    ns1:learningResultDescription "Diseñar y evaluar programas de mejora genética y llevarlos a la práctica."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000113/2025-26/RA273> a ns1:LearningResult ;
