<https://guia-kg.skai.etsisi.upm.es/resource/53001240/2025-26/didactic_resource/1> a ns1:DidacticResource ;
    ns1:bibliographyTitle "CMOS VLSI Design - A Circuits and Systems Perspective (4th Edition). Neil Weste and David Harris."@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001240/2025-26/didactic_resource/2> a ns1:DidacticResource ;
    ns1:bibliographyTitle "Digital Integrated Circuits - A Design Perspective (2nd Edition). Rabaey, Chandrakasan and Nikolic."@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001240/2025-26/didactic_resource/3> a ns1:DidacticResource ;
    ns1:bibliographyTitle "Reconfigurable System Design and Verification. Hsiung, Santambrogio and Huang."@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001240/2025-26/didactic_resource/4> a ns1:DidacticResource ;
    ns1:bibliographyTitle "Dynamically Reconfigurable Systems - Architectures, Design Methods and Applications. Platzner, Teich and Wehn"@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001240/2025-26/didactic_resource/5> a ns1:DidacticResource ;
    ns1:bibliographyTitle "Reconfigurable Computing - Accelerating Computation with Field-Programmable Gate Arrays. Gokhale and Graham."@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001240/2025-26/evaluation> a ns1:EvaluationSystem ;
    ns1:evaluationDescription "The evaluation of the subject will consist of 20% from a homework project on CMOS technology, 20% from a homework project on Advanced digital modules, and 60% from the final written exam."@es .

