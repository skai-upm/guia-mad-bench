    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/53001240/2025-26/eventSchedule> ;
    schema:description "This subject addresses two main topics: on the one hand, microelectronics, including CMOS technology (CMOS logic, fabrication, physical design and layout), advanced digital subsystems and components, key VLSI design concepts and methods (static timing analysis, low-power design, clock distribution and metastability) and IC testing; on the other hand, reconfigurable computing, including FPGA architectures, reconfiguration techniques, and both design- and run-time reconfiguration support."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/alfonso.rodriguezm%40upm.es> ;
    schema:inLanguage "Inglés/Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/alfonso.rodriguezm%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/daniel.vazquez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/joseandres.otero%40upm.es> ;
    schema:name "Microelectronica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001240/2025-26/%28a%29> a ns1:Competency ;
    ns1:competencyCode "(a)" ;
    ns1:competencyDescription "APLICA. Habilidad para aplicar conocimientos científicos, matemáticos y tecnológicos en sistemas relacionados con la práctica de la ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001240/2025-26/%28b%29> a ns1:Competency ;
    ns1:competencyCode "(b)" ;
    ns1:competencyDescription "EXPERIMENTA. Habilidad para diseñar y realizar experimentos así como analizar e interpretar datos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001240/2025-26/%28c%29> a ns1:Competency ;
    ns1:competencyCode "(c)" ;
    ns1:competencyDescription "DISEÑA. Habilidad para diseñar un sistema, componente o proceso que alcance los requisitos deseados teniendo en cuenta restricciones realistas tales como las económicas, medioambientales, sociales, políticas, éticas, de salud y seguridad, de fabricación y de sostenibilidad."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001240/2025-26/%28d%29> a ns1:Competency ;
    ns1:competencyCode "(d)" ;
    ns1:competencyDescription "TRABAJA EN EQUIPO. Habilidad para trabajar en equipos multidisciplinares."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001240/2025-26/%28e%29> a ns1:Competency ;
    ns1:competencyCode "(e)" ;
    ns1:competencyDescription "RESUELVE. Habilidad para identificar, formular y resolver problemas de ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001240/2025-26/%28g%29> a ns1:Competency ;
    ns1:competencyCode "(g)" ;
    ns1:competencyDescription "COMUNICA. Habilidad para comunicar eficazmente."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001240/2025-26/%28k%29> a ns1:Competency ;
    ns1:competencyCode "(k)" ;
    ns1:competencyDescription "USA HERRAMIENTAS. Habilidad para usar las técnicas, destrezas y herramientas ingenieriles modernas necesarias para la práctica de la ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001240/2025-26/%28n%29> a ns1:Competency ;
    ns1:competencyCode "(n)" ;
    ns1:competencyDescription "IDEA. Creatividad"@es .

