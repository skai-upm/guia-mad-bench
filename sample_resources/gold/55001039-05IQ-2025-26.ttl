<https://guia-kg.skai.etsisi.upm.es/resource/55001039/2025-26/CE%2020> a ns1:Competency ;
    ns1:competencyCode "CE 20" ;
    ns1:competencyDescription "Capacidad para el análisis, diseño, simulación y optimización de procesos y productos"@es .

