<https://guia-kg.skai.etsisi.upm.es/resource/615001001/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Álgebra matricial. Sistemas de ecuaciones lineales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615001001/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Cálculo matricial. Operaciones elementales. Formas escalonada y escalonada reducida. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615001001/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "3. Aplicaciones lineales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615001001/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "3.1. Definición de aplicación lineal u homomorfismo de espacios vectoriales. Tipos de homomorfismos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615001001/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "3.2. Subespacios núcleo e imagen de una aplicación lineal. Fórmula de las dimensiones. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615001001/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "3.3. Construcción de homomorfismos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615001001/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "3.4. Homomorfismos y cambios de base. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615001001/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "4. Diagonalización"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615001001/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "4.1. Endomorfismo diagonalizable. Autovector y autovalor. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615001001/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "4.2. Polinomio característico. Multiplicidad algebraica de un autovalor. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615001001/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "4.3. Subespacios propios. Multiplicidad geométrica. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615001001/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "4.4. Diagonalización de endomorfismos y matrices. Aplicaciones. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615001001/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Algoritmos de Gauss y de Gauss-Jordan. Rango de una matriz. Inversa de una matriz cuadrada. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615001001/2025-26/syllabus/20> a ns1:SyllabusItem ;
    ns1:itemIndex 20 ;
    ns1:syllabusDescription "5. Espacio vectorial euclídeo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615001001/2025-26/syllabus/21> a ns1:SyllabusItem ;
    ns1:itemIndex 21 ;
    ns1:syllabusDescription "5.1. Producto escalar. Norma. Ángulo. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615001001/2025-26/syllabus/22> a ns1:SyllabusItem ;
    ns1:itemIndex 22 ;
    ns1:syllabusDescription "5.2. Base ortogonal. Base ortonormal. Algoritmo de Ortogonalización de Gram-Schmidt Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615001001/2025-26/syllabus/23> a ns1:SyllabusItem ;
    ns1:itemIndex 23 ;
    ns1:syllabusDescription "5.3. Complemento ortogonal. Factorización QR. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615001001/2025-26/syllabus/24> a ns1:SyllabusItem ;
    ns1:itemIndex 24 ;
    ns1:syllabusDescription "5.4. Proyección ortogonal. Distancia entre vector y subespacio. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615001001/2025-26/syllabus/25> a ns1:SyllabusItem ;
    ns1:itemIndex 25 ;
    ns1:syllabusDescription "5.5. Problemas de mínimos cuadrados. Ajuste de datos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615001001/2025-26/syllabus/26> a ns1:SyllabusItem ;
    ns1:itemIndex 26 ;
    ns1:syllabusDescription "6. Aplicaciones lineales entre espacio vectoriales euclideos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615001001/2025-26/syllabus/27> a ns1:SyllabusItem ;
    ns1:itemIndex 27 ;
    ns1:syllabusDescription "6.1. Endomorfismos y Matrices simétricas Diagonalización ortogonal. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615001001/2025-26/syllabus/28> a ns1:SyllabusItem ;
    ns1:itemIndex 28 ;
    ns1:syllabusDescription "6.2. Aplicaciones ortogonales y matrices ortogonales. Propiedades. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615001001/2025-26/syllabus/29> a ns1:SyllabusItem ;
    ns1:itemIndex 29 ;
    ns1:syllabusDescription "6.3. Aplicaciones ortogonales en el plano y el espacio. Construcción y clasificación. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615001001/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "1.3. Resolución de sistemas de ecuaciones lineales mediante algoritmo de Gauss y Gauss-Jordan. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615001001/2025-26/syllabus/30> a ns1:SyllabusItem ;
    ns1:itemIndex 30 ;
    ns1:syllabusDescription "7. Descomposición en valores singulares (SVD)"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615001001/2025-26/syllabus/31> a ns1:SyllabusItem ;
    ns1:itemIndex 31 ;
    ns1:syllabusDescription "7.1. Valores singulares. Descomposición en valores singulares completa y reducida. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615001001/2025-26/syllabus/32> a ns1:SyllabusItem ;
    ns1:itemIndex 32 ;
    ns1:syllabusDescription "7.2. Aplicaciones: pseudoinversa de Moore-Penrose, problema de ajuste por mínimos cuadrados, low rank decomposition. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615001001/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "1.4. Factorización LU. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615001001/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "2. Espacios vectoriales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615001001/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "2.1. Espacio vectorial. Dependencia lineal. Sistema generador. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615001001/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "2.2. Base de un espacio vectorial. Dimensión. Coordenadas. Cambios de base. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615001001/2025-26/syllabus/8> a ns1:SyllabusItem ;
