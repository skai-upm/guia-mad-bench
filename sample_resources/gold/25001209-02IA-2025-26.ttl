<https://guia-kg.skai.etsisi.upm.es/resource/25001209/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/25001209/2025-26/CE15>,
        <https://guia-kg.skai.etsisi.upm.es/resource/25001209/2025-26/CG16>,
