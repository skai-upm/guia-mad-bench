        <https://guia-kg.skai.etsisi.upm.es/resource/manuel.tarifa%40upm.es> ;
    schema:name "Geotecnia"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005406/2025-26/CE59> a ns1:Competency ;
    ns1:competencyCode "CE59" ;
    ns1:competencyDescription "Conocimiento adecuado y aplicado a la Ingeniería de: Los métodos de cálculo y de desarrollo de las diferentes soluciones de edificación y pavimentación de aeropuertos; el cálculo de los sistemas específicos de los aeropuertos y sus infraestructuras; la evaluación de las actuaciones técnicas y económicas de las aeronaves; el manejo de las técnicas experimentales, equipamiento e instrumentos de medida propios de la disciplina; las técnicas de inspección, de control de calidad y de detección de fallos; los planes de seguridad y control en aeropuertos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005406/2025-26/CE60> a ns1:Competency ;
    ns1:competencyCode "CE60" ;
    ns1:competencyDescription "Conocimiento aplicado de: edificación; electricidad; electrotecnia; electrónica; mecánica del vuelo; hidráulica; instalaciones aeroportuarias; ciencia y tecnología de los materiales; teoría de estructuras; mantenimiento y explotación de aeropuertos; transporte aéreo, cartografía, topografía, geotecnia y meteorología."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005406/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Capacidad para identificar y resolver problemas aplicando, con creatividad, los conocimientos adquiridos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005406/2025-26/CG5> a ns1:Competency ;
    ns1:competencyCode "CG5" ;
    ns1:competencyDescription "Liderazgo de equipos y organizaciones"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005406/2025-26/CG9> a ns1:Competency ;
    ns1:competencyCode "CG9" ;
    ns1:competencyDescription "Razonamiento crítico y capacidad de asociación que posibiliten el aprendizaje continuo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005406/2025-26/RA300> a ns1:LearningResult ;
    ns1:learningResultCode "RA300" ;
    ns1:learningResultDescription "Capacidad de análisis y síntesis para saber redactar e interpretar informes técnicos referentes a ensayos geotécnicos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005406/2025-26/RA70> a ns1:LearningResult ;
    ns1:learningResultCode "RA70" ;
    ns1:learningResultDescription "Conocimiento, comprensión, análisis y valoración de los distintos tipos de suelo identificando su composición, sus principales propiedades y características, así como el comportamiento del suelo bajo cargas aplicadas, cálculo de tensiones, cálculo de asientos y flujos de caudales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005406/2025-26/RA71> a ns1:LearningResult ;
    ns1:learningResultCode "RA71" ;
    ns1:learningResultDescription "Conocimiento y aplicación de los ensayos tipo a realizar en los suelos para identificarlos y determinar su comportamiento."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005406/2025-26/RA72> a ns1:LearningResult ;
    ns1:learningResultCode "RA72" ;
    ns1:learningResultDescription "Conocimiento, comprensión, aplicación y análisis de las diferentes tipologías de cimentación calculando las cargas de hundimiento en cimentaciones."@es .

