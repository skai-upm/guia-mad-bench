<https://guia-kg.skai.etsisi.upm.es/resource/595000208/2025-26/CE%20B4> a ns1:Competency ;
    ns1:competencyCode "CE B4" ;
    ns1:competencyDescription "Comprensión y dominio de los conceptos básicos de sistemas lineales y las funciones y transformadas relacionadas, teoría de circuitos eléctricos, circuitos electrónicos, principio físico de los semiconductores y familias lógicas, dispositivos electrónicos y fotónicos, tecnología de materiales y su aplicación para la resolución de problemas propios de la ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000208/2025-26/CE%20TEL12> a ns1:Competency ;
    ns1:competencyCode "CE TEL12" ;
    ns1:competencyDescription "Capacidad de utilizar distintas fuentes de energía y en especial la solar fotovoltaica y térmica, así como los fundamentos de la electrotecnia y de la electrónica de potencia."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000208/2025-26/CG%2002> a ns1:Competency ;
    ns1:competencyCode "CG 02" ;
    ns1:competencyDescription "Capacidad de búsqueda y selección de información, de razonamiento crítico y de elaboración y defensa de argumentos dentro del área."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000208/2025-26/CG%2004> a ns1:Competency ;
    ns1:competencyCode "CG 04" ;
    ns1:competencyDescription "Capacidad de abstracción, de análisis y de síntesis y de resolución de problemas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000208/2025-26/CG%2005> a ns1:Competency ;
    ns1:competencyCode "CG 05" ;
    ns1:competencyDescription "Capacidad de trabajo en equipo y en entornos multidisciplinares."@es .

