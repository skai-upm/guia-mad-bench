    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/95000589/2025-26/RA061>,
        <https://guia-kg.skai.etsisi.upm.es/resource/95000589/2025-26/RA062>,
        <https://guia-kg.skai.etsisi.upm.es/resource/95000589/2025-26/RA063>,
        <https://guia-kg.skai.etsisi.upm.es/resource/95000589/2025-26/RA157>,
