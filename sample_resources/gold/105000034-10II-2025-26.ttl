<https://guia-kg.skai.etsisi.upm.es/resource/105000034/2025-26/RA563> a ns1:LearningResult ;
    ns1:learningResultCode "RA563" ;
    ns1:learningResultDescription "Comprender y aplicar los principios tecnológicos involucrados en una instalación informática (eléctricos, electro"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000034/2025-26/RA564> a ns1:LearningResult ;
    ns1:learningResultCode "RA564" ;
    ns1:learningResultDescription "Comprender y aplicar los principios de diseño y gestión integrada de la infraestructura de una instalación informática"@es .

