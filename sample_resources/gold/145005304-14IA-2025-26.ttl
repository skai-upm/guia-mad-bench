    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/145005304/2025-26/eventSchedule> ;
    schema:description "En esta asignatura se estudian los elementos de radiofrecuencia que conforman los sistemas de radiofrecuencia utilizados en el entorno aeronáutico, tanto en sistemas de comunicaciones como de vigilancia y ayudas a la navegación. Tras considerar la propagación de ondas electromagnéticas planas en espacio libre de materia se pasa al estudio de la propagación de la energía electromagnética en medios confinados como líneas de transmisión y guiaondas. A continuación se aborda el estudio de los dispositivos llamados antenas, que se usan para la radiación de energía electromagnética hacia el espacio vacío o el aire y para la recogida eficiente de tal radiación desde el aire o del espacio vacío. La aplicación de todo lo anterior permite entender los susodichos sistemas de radiofrecuencia de interés aeronáutico."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/joseignacio.izpura%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/joseignacio.izpura%40upm.es> ;
    schema:name "Sistemas de Radiofrecuencia"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005304/2025-26/CE71> a ns1:Competency ;
    ns1:competencyCode "CE71" ;
    ns1:competencyDescription "Conocimiento aplicado de: Transmisores y receptores; Líneas de transmisión y sistemas radiantes de señales para la navegación aérea; Sistemas de navegación; Instalaciones eléctricas en el sector tierra y sector aire; Mecánica del Vuelo; Cartografía; Cosmografía; Meteorología; Distribución, gestión y economía del transporte aéreo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005304/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Capacidad para identificar y resolver problemas aplicando, con creatividad, los conocimientos adquiridos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005304/2025-26/CG9> a ns1:Competency ;
    ns1:competencyCode "CG9" ;
    ns1:competencyDescription "Razonamiento crítico y capacidad de asociación que posibiliten el aprendizaje continuo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005304/2025-26/RA119> a ns1:LearningResult ;
    ns1:learningResultCode "RA119" ;
    ns1:learningResultDescription "Comprensión, aplicación, análisis y síntesis de las Líneas de Transmisión, Guías de Ondas, Fibra Óptica, Antenas y Redes de antenas, aplicadas a los dispositivos que forman parte de los equipos que conforman el Sistema de Navegación Aérea."@es .

