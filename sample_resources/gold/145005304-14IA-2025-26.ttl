<https://guia-kg.skai.etsisi.upm.es/resource/145005304/2025-26/syllabus> a ns1:Syllabus ;
    ns1:hasItem <https://guia-kg.skai.etsisi.upm.es/resource/145005304/2025-26/syllabus/0>,
        <https://guia-kg.skai.etsisi.upm.es/resource/145005304/2025-26/syllabus/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/145005304/2025-26/syllabus/10>,
        <https://guia-kg.skai.etsisi.upm.es/resource/145005304/2025-26/syllabus/11>,
        <https://guia-kg.skai.etsisi.upm.es/resource/145005304/2025-26/syllabus/12>,
        <https://guia-kg.skai.etsisi.upm.es/resource/145005304/2025-26/syllabus/13>,
        <https://guia-kg.skai.etsisi.upm.es/resource/145005304/2025-26/syllabus/2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/145005304/2025-26/syllabus/3>,
        <https://guia-kg.skai.etsisi.upm.es/resource/145005304/2025-26/syllabus/4>,
        <https://guia-kg.skai.etsisi.upm.es/resource/145005304/2025-26/syllabus/5>,
        <https://guia-kg.skai.etsisi.upm.es/resource/145005304/2025-26/syllabus/6>,
        <https://guia-kg.skai.etsisi.upm.es/resource/145005304/2025-26/syllabus/7>,
        <https://guia-kg.skai.etsisi.upm.es/resource/145005304/2025-26/syllabus/8>,
        <https://guia-kg.skai.etsisi.upm.es/resource/145005304/2025-26/syllabus/9> .

<https://guia-kg.skai.etsisi.upm.es/resource/145005304/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. PRINCIPIOS FUNDAMENTALES DE LOS SISTEMAS DE RADIOFRECUENCIA."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005304/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Generalidades. 1.2. Esquemas de bloques de dispositivos de radioemisión y radio recepción. 1.3. Transmisión de energía electromagnética. 1.4. Rangos de frecuencias. 1.5. Tensión, corriente y potencias eléctricas. 1.6. Ley de Ohm compleja. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005304/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "5. ANTENAS"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005304/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "5.1. Introducción. 5.2. Dipolo infinitesimal. 5.3. Campos cercano y lejano, inducido y radiado. 5.4. Diagramas de radiación. 5.5. Ganancia, directividad y eficiencia. 5.6. Polarización. 5.7. Teorema de reciprocidad. 5.8. Efecto del suelo. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005304/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "6. TIPOS Y REDES DE ANTENAS"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005304/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "6.1. Introducción. 6.2. Dipolos de media onda, una onda y 3/2 de onda. 6.3. Antenas mono polo. 6.4. Antenas parabólicas. 6.5. Antenas ranura: campos radiados, impedancia, directividad y apertura. 6.6. Sistemas de dos antenas. 6.7. Sistemas de n antenas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005304/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "2. ONDAS ELECTROMAGNÉTICAS: NATURALEZA Y PROPAGACIÓN"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005304/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "2.1. Introducción. 2.1.1. Ecuaciones de Maxwell y ondas electromagnéticas (EM). 2.1.2. Ec. de ondas EM en el dominio del tiempo y de la frecuencia. 2.1.3. Propagación de energía EM como onda plana TEM. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005304/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "2.2. Teorema de Poynting. 2.2.2. Condiciones de contorno, cambio de medio, reflexión y transmisión. 2.2.3. Propagación en medios disipativos. 2.2.4. Propagación junto a la superficie de la Tierra. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005304/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "3. LINEAS DE TRANSMISION."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005304/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "3.1. Introducción. 3.1.2. Tipos de líneas y parámetros básicos. 3.1.3. Ecuaciones en el dominio del tiempo y de la frecuencia. 3.1.4. Solución de las ecuaciones en líneas sin pérdidas. 3.1.5. Solución en líneas con pérdidas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005304/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "3.2. Constante de propagación e Impedancias de línea. 3.2.2. Coeficientes de reflexión y transmisión. 3.2.3. Ondas estacionarias. ROE. 3.2.4. Diagrama de Smith. Fundamento y manejo. 3.2.5. Adaptación de impedancias mediante trozos de línea (\"stubs\"). Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005304/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "4. GUIAS DE ONDA"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005304/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "4.1. Introducción. Guiaondas rectangulares. 4.2. Ec. en coordenadas rectangulares. 4.3. Modos TM y TE en guías rectangulares. 4.4. Potencia transmitida y perdida. 4.5 Cavidades resonantes, factor de calidad Q. 4.6 Guíaonda dieléctrica: fibra óptica. Sin subniveles"@es .

