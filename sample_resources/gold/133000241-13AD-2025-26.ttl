    ns1:competencyCode "CE 2.8" ;
    ns1:competencyDescription "Capacidad para la redacción, dirección y ejecución de Proyectos de Ordenación de Montes"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000241/2025-26/CE%206.1> a ns1:Competency ;
    ns1:competencyCode "CE 6.1" ;
    ns1:competencyDescription "Capacidad para la gestion de recursos naturales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000241/2025-26/CT02> a ns1:Competency ;
    ns1:competencyCode "CT02" ;
    ns1:competencyDescription "Integrar los conocimientos previos (propios de grado) de manera crítica y relacionada de forma que se puedan aplicar al estudio de situaciones reales y a la propuesta de alternativas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000241/2025-26/CT06> a ns1:Competency ;
    ns1:competencyCode "CT06" ;
    ns1:competencyDescription "Búsqueda bibliográfica, análisis de documentación y tratamiento de la información procedente de diversas fuentes y de su análisis y síntesis aplicándola a la resolución de problemas complejos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000241/2025-26/RA132> a ns1:LearningResult ;
    ns1:learningResultCode "RA132" ;
    ns1:learningResultDescription "Conocimiento con sentido crítico del amplio contexto multidisciplinar de la ingeniería y de la interrelación que existe entre los conocimientos de los distintos campos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000241/2025-26/RA134> a ns1:LearningResult ;
    ns1:learningResultCode "RA134" ;
    ns1:learningResultDescription "Capacidad para realizar búsquedas bibliográficas, consultar y utilizar con criterio bases de datos y otras fuentes de información, para llevar a cabo simulaciones con el objetivo de realizar investigaciones sobre temas complejos de su especialidad"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000241/2025-26/RA162> a ns1:LearningResult ;
    ns1:learningResultCode "RA162" ;
    ns1:learningResultDescription "Conocer cómo utilizar la información disponible en la toma de decisiones en gestión forestal."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000241/2025-26/RA163> a ns1:LearningResult ;
    ns1:learningResultCode "RA163" ;
    ns1:learningResultDescription "Conocer las herramientas de investigación operativa que se pueden utilizar para resolver problemas de gestión forestal."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000241/2025-26/RA164> a ns1:LearningResult ;
    ns1:learningResultCode "RA164" ;
    ns1:learningResultDescription "Elaborar proyectos de Ordenación de Montes, planes dasocráticos y otros instrumentos de gestión forestal."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000241/2025-26/RA165> a ns1:LearningResult ;
    ns1:learningResultCode "RA165" ;
    ns1:learningResultDescription "Analizar y cuantificar la sostenibilidad de la gestión de recursos naturales."@es .

