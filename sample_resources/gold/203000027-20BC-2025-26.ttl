    schema:courseCode 203000027 ;
    schema:hasCourseInstance <https://guia-kg.skai.etsisi.upm.es/resource/203000027/2025-26> ;
    schema:name "Computational Approaches In Evolutionary Biology"@en,
        "Herramientas Computacionales en Biología Evolutiva"@es ;
    schema:numberOfCredits 3.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/203000027/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/203000027/2025-26/CE02>,
        <https://guia-kg.skai.etsisi.upm.es/resource/203000027/2025-26/CE03>,
        <https://guia-kg.skai.etsisi.upm.es/resource/203000027/2025-26/CE05>,
        <https://guia-kg.skai.etsisi.upm.es/resource/203000027/2025-26/CE10>,
        <https://guia-kg.skai.etsisi.upm.es/resource/203000027/2025-26/CG03>,
        <https://guia-kg.skai.etsisi.upm.es/resource/203000027/2025-26/CG05>,
        <https://guia-kg.skai.etsisi.upm.es/resource/203000027/2025-26/CT02> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/203000027/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/203000027/2025-26/didactic_resource/2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/203000027/2025-26/didactic_resource/3> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/203000027/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/203000027/2025-26/RA16>,
        <https://guia-kg.skai.etsisi.upm.es/resource/203000027/2025-26/RA17>,
        <https://guia-kg.skai.etsisi.upm.es/resource/203000027/2025-26/RA18>,
        <https://guia-kg.skai.etsisi.upm.es/resource/203000027/2025-26/RA19> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/203000027/2025-26/syllabus> ;
    ns1:inpersonHours "30 horas (38.5%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation "Part of the course syllabus is related to the ODS 12: Life in terrestrial ecosystems. For instance, the students will learn how to measure the genetic diversity in natural populations of any organisms. Togenther with the number of species, the genetic diversity of these species are the two major components of ecosystem biodiversity. Understanding how to calculate biodiversity components is central to preserve it in terrestrial ecosystems."@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "46 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/203000027/2025-26/eventSchedule> ;
    schema:description "The course combines a solid formation in theoretical aspects on the mechanisms and forces determining the evolution of living organisms, with a strong practical component developed to familiarize students with computational tools frequently used in evolutionary studies. In particular, students will learn which are the most important mechanisms of generating genetic diversity in natural populations, what forces determine the genetic variants that become fixed in the population, and which are the processes influencing the relative abundance of these variants. At the same time, the student will learn how to use bioinformatics tools commonly utilized to analyze how organisms evolve, including phylogenetic and population genetics approaches. Many examples will relate (but are not exclusively limited) to fast-evolving organisms in which evolution is measurable in a timely manner such as viruses and bacteria."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/jesusisrael.pagan%40upm.es> ;
    schema:inLanguage "Inglés"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/cristina.saez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/jesusisrael.pagan%40upm.es> ;
    schema:name "Herramientas Computacionales en Biología Evolutiva"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000027/2025-26/CE02> a ns1:Competency ;
    ns1:competencyCode "CE02" ;
    ns1:competencyDescription "Utilizar sistemas operativos, programas y herramientas de uso común en biología computacional, así como, manejar plataformas de cómputo de altas prestaciones, lenguajes de programación y análisis bioinformáticos/ Utilizing operative systems, software and tools commonly used in computational biology, and working with high throughput platforms, programing languages and bioinformatics tools."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000027/2025-26/CE03> a ns1:Competency ;
    ns1:competencyCode "CE03" ;
    ns1:competencyDescription "Analizar e interpretar bioinformáticamente los datos que se derivan de las tecnologías ómicas, y proponer soluciones bioinformáticas en relación a dichos datos/ Analyzing and interpreting bioinformatically data derived from ?omics technologies, and proposing bioinformatics solutions according to such data."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000027/2025-26/CE05> a ns1:Competency ;
    ns1:competencyCode "CE05" ;
    ns1:competencyDescription "Utilizar herramientas de biología computacional para el análisis genómico, incluida la genómica comparativa y biología evolutiva/ Using computational biology tools for genomics analyses, including comparative genomics and evolutionary biology."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000027/2025-26/CE10> a ns1:Competency ;
    ns1:competencyCode "CE10" ;
    ns1:competencyDescription "Conocimiento de las técnicas de representación del conocimiento reutilizables y modelos de razonamiento en entornos centralizados y distribuidos a utilizar en la resolución de problemas que impliquen conducta inteligente/ Knowing reusable techniques for knowledge representation and reasoning models in centralized and distributed environments, and when to used them for problem solving."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000027/2025-26/CG03> a ns1:Competency ;
    ns1:competencyCode "CG03" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en entornos nuevos o poco conocidos dentro de contextos más amplios (o multidisciplinares) relacionados con el area de la Biología Computacional/ Provide students with the ability to apply the acquired knowledge to solve problems in new environments within ample or multidisciplinary contexts in the field of Computational Biology."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000027/2025-26/CG05> a ns1:Competency ;
    ns1:competencyCode "CG05" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de integrar conocimientos en el area de la Biología Computacional, de formular conclusiones, hipótesis o líneas de trabajo a partir de la información disponible, y de formarse una opinion fundamentada sobre las responsabilidades sociales y éticas vinculadas a la aplicación de sus conocimientos/ Provide students with the capacity to integrate knowledge in the area of Computational Biology, formulate conclusions, hypotheses or research lines from the available information, and with the ability to elaborate solid opinions about the social and ethic responsibilities derived from the application of their knowledge."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000027/2025-26/CT02> a ns1:Competency ;
    ns1:competencyCode "CT02" ;
    ns1:competencyDescription "Capacidad para aplicar el método científico para la resolución de problemas de forma efectiva y creativa/ Capacity to apply the scientific method to solve problems in an efective and creative way."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000027/2025-26/RA16> a ns1:LearningResult ;
    ns1:learningResultCode "RA16" ;
    ns1:learningResultDescription "Aprender los conceptos básicos en Biología Evolutiva"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000027/2025-26/RA17> a ns1:LearningResult ;
    ns1:learningResultCode "RA17" ;
    ns1:learningResultDescription "Conocer cuáles son las aproximaciones más utilizadas para el estudio de la evolución de los organismos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000027/2025-26/RA18> a ns1:LearningResult ;
    ns1:learningResultCode "RA18" ;
    ns1:learningResultDescription "Conocer los supuestos teóricos y la base bioestadística en la que se apoyan los diferentes métodos de análisis computacional de la evolución de los organismos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000027/2025-26/RA19> a ns1:LearningResult ;
    ns1:learningResultCode "RA19" ;
    ns1:learningResultDescription "Adquirir los conocimientos necesarios para el uso e interpretación de paquetes informáticos enfocados al estudio de la evolución de los organismo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000027/2025-26/didactic_resource/1> a ns1:DidacticResource ;
    ns1:bibliographyTitle "Nei, M. (1987) Molecular Evolutionary Genetics. Columbia University Press, New York"@es ;
    ns1:bibliographyType "Bibliografía"@es .

