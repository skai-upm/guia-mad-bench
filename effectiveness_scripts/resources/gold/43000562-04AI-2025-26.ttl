    ns1:inpersonHours "62 horas (51%)"@es ;
    ns1:numberOfCredits 4.5 ;
    ns1:otherInformation "The subject is related to the following Sustainable Development Goals: 7 (Affordable and Clean Energy), 11 (Sustainable Cities and Communities), 13 (Climate Action), and 14 (Life Below Water)."@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "62 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/43000562/2025-26/eventSchedule> ;
    schema:description "This subject is optional within the specialty of Hydraulics, Energy and Environment. The course offers an overview of the use of renewable energies in the marine environment such as waves, currents, tides or wind. The content is structured into ten topics which deal with the evaluation of the resource of each one of the existing sources, the technologies or devices to be considered, the components of an exploitation installation, the types of foundations or supports for said devices, the description of the construction and maintenance phases, the environmental impact produced by this type of installation, as well as other aspects such as economic and legislative ones."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/josesantos.lopez%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/josesantos.lopez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/mariadolores.esteban%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/pedro.fernandez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/vicente.negro%40upm.es> ;
    schema:name "Marine Energies"@es .

