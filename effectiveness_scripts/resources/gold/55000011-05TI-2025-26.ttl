<https://guia-kg.skai.etsisi.upm.es/resource/55000011/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Ecuaciones diferenciales ordinarias de primer orden."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000011/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Modelización matemática en problemas de ingeniería y medio ambiente: ley de enfriamiento y calentamiento de un cuerpo, modelos de población. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000011/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "2.3. Matriz diagonalizable en R y en C. Expresión de la solución general del sistema de ecuaciones diferenciales en términos de autovalores y autovectores de la matriz asociada al sistema. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000011/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "2.4. Caso general: exponencial de una matriz. Métodos de cálculo. Expresión de la solución de un problema de valor inicial. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000011/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "2.5. Espacios de fases de los sistemas de ecuaciones diferenciales lineales en el plano. Clasificación: nodos, puertos, focos y centros. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000011/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "2.6. Sistemas de ecuaciones diferenciales no homogéneos. Fórmula de variación de las constantes. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000011/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "3. Ecuaciones diferenciales lineales de orden n."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000011/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "3.1. Modelización matemática en problemas de ingeniería y medio ambiente: sistemas masa-resorte. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000011/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "3.2. E.D.O. lineales de orden n con coeficientes constantes. El sistema diferencial equivalente. Sistema fundamental de soluciones. Problema de valor inicial. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000011/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "3.3. Caso no homogéneo: métodos de variación de las constantes y de los coeficientes indeterminados. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000011/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "3.4. E.D.O. lineales de orden n y coeficientes variables. Reducción del orden. Ecuaciones de Euler. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000011/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "4. Ecuaciones en derivadas parciales de primer orden."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000011/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Definiciones sobre E.D.O. Problemas de valor inicial o de Cauchy. Existencia y unicidad. Prolongabilidad de soluciones. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000011/2025-26/syllabus/20> a ns1:SyllabusItem ;
    ns1:itemIndex 20 ;
    ns1:syllabusDescription "4.1. Modelización matemática en problemas de ingeniería y medio ambiente: leyes de conservación, flujo de tráfico. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000011/2025-26/syllabus/21> a ns1:SyllabusItem ;
    ns1:itemIndex 21 ;
    ns1:syllabusDescription "4.2. E.D.P. cuasilineal de primer orden. Problema de valor inicial. Curvas características. Ondas de choque y la condición de Rankine-Hugoniot. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000011/2025-26/syllabus/22> a ns1:SyllabusItem ;
    ns1:itemIndex 22 ;
    ns1:syllabusDescription "4.3. Resolución numérica de E.D.P de primer orden. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000011/2025-26/syllabus/23> a ns1:SyllabusItem ;
    ns1:itemIndex 23 ;
    ns1:syllabusDescription "5. Introducción a las ecuaciones en derivadas parciales de segundo orden."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000011/2025-26/syllabus/24> a ns1:SyllabusItem ;
    ns1:itemIndex 24 ;
    ns1:syllabusDescription "5.1. Modelización matemática en problemas de ingeniería y medio ambiente: la ecuación del calor. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000011/2025-26/syllabus/25> a ns1:SyllabusItem ;
    ns1:itemIndex 25 ;
    ns1:syllabusDescription "5.2. El método de separación de variables. Problema de autovalores y autofunciones. Series de Fourier. Nociones sobre convergencia. Obtención de solución formal. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000011/2025-26/syllabus/26> a ns1:SyllabusItem ;
    ns1:itemIndex 26 ;
    ns1:syllabusDescription "5.3. La ecuación de Laplace y la ecuación de Poisson. Resolución mediante el método de separación de variables. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000011/2025-26/syllabus/27> a ns1:SyllabusItem ;
    ns1:itemIndex 27 ;
    ns1:syllabusDescription "5.4. Modelización matemática en problemas de ingeniería y medio ambiente: la ecuación de ondas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000011/2025-26/syllabus/28> a ns1:SyllabusItem ;
    ns1:itemIndex 28 ;
    ns1:syllabusDescription "5.5. El método de sepación de variables para cuerdas finitas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000011/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "1.3. E.D.O. de variables separables. E.D.O. homogéneas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000011/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "1.4. E.D.O. exactas. Función potencial. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000011/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "1.5. E.D.O. lineales de primer orden. E.D.O. de Bernoulli. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000011/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "1.6. Introducción a los métodos numéricos para E.D.O. de primer orden. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000011/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "2. Sistemas de ecuaciones diferencial lineales de primer orden."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000011/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "2.1. Modelización matemática en problemas de ingeniería y medio ambiente: mezclas de sustancias. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000011/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "2.2. Sistemas de E.D.O. lineales de primer orden y coeficientes constantes. Escritura matricial. Problema de valor inicial. Matriz fundamental y conjunto fundamental de soluciones. Sin subniveles"@es .

