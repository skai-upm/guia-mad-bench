    ns1:otherInformation """La modalidad de docencia a impartir se corresponderá en cada momento con lo que establezca la normativa/legislación vigente.
En caso de que se dé un evento no contemplado en esta guía, el tribunal de la asignatura tendrá capacidad para decidir cómo proceder."""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
