    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/55000011/2025-26/eventSchedule> ;
    schema:description """Los contenidos de esta asignatura se orientan especialmente al estudio de las ecuaciones diferenciales ordinarias así como a problemas de contorno y de valor inicial formulados en términos de ecuaciones en derivadas parciales.
Uno de los objetivos que se persigue en el desarrollo de esta asignatura es el de iniciar a los alumnos en procedimientos de modelado de procesos naturales (físicos, químicos, biológicos, etc.) proporcionando un panorama de técnicas lo más amplio posible, dirigido hacia las aplicaciones."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/victor.munoz%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/anasoledad.merono%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/pablo.gomez.mourelo%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/pedro.galan%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/victor.munoz%40upm.es> ;
    schema:name "Ecuaciones Diferenciales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000011/2025-26/CE1> a ns1:Competency ;
    ns1:competencyCode "CE1" ;
    ns1:competencyDescription "Capacidad para la resolución de los problemas matemáticos que puedan plantearse en la ingeniería. Aptitud para aplicar los conocimientos sobre: álgebra lineal; geometría; geometría diferencial; cálculo diferencial e integral; ecuaciones diferenciales ordinarias y en derivadas parciales; métodos numéricos; algorítmica numérica; optimización"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000011/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Conocer y aplicar conocimientos de ciencias y tecnologías básicas a la práctica de la Ingeniería Industrial."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000011/2025-26/CG10> a ns1:Competency ;
    ns1:competencyCode "CG10" ;
    ns1:competencyDescription "Capacidad para generar nuevas ideas (Creatividad)."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000011/2025-26/CG2> a ns1:Competency ;
    ns1:competencyCode "CG2" ;
    ns1:competencyDescription "Poseer capacidad para diseñar, desarrollar, implementar, gestionar y mejorar productos, sistemas y procesos en los distintos ámbitos industriales, usando técnicas analíticas, computacionales o experimentales apropiadas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000011/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Aplicar los conocimientos adquiridos para identificar, formular y resolver problemas dentro de contextos amplios y multidisciplinarios, siendo capaces de integrar conocimientos, trabajando en equipos multidisciplinares."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000011/2025-26/CG6> a ns1:Competency ;
    ns1:competencyCode "CG6" ;
    ns1:competencyDescription "Poseer habilidades de aprendizaje que permitan continuar estudiando a lo largo de la vida para su adecuado desarrollo profesional."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000011/2025-26/RA232> a ns1:LearningResult ;
    ns1:learningResultCode "RA232" ;
    ns1:learningResultDescription "Proporciona un abanico muy diverso de herramientas para abordar el tratamiento de modelos de procesos naturales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000011/2025-26/RA242> a ns1:LearningResult ;
    ns1:learningResultCode "RA242" ;
    ns1:learningResultDescription "Capacidad de abstracción y reconocimiento de conceptos generales en situaciones prácticas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000011/2025-26/RA243> a ns1:LearningResult ;
    ns1:learningResultCode "RA243" ;
    ns1:learningResultDescription "Capacidad para formular y analizar modelos de procesos naturales. Capacidad de interpretar los resultados obtenidos y evaluar los modelos utilizados."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000011/2025-26/RA244> a ns1:LearningResult ;
    ns1:learningResultCode "RA244" ;
    ns1:learningResultDescription "Habilidad para aplicación de métodos analíticos a la resolución de problemas técnicos conocidos que han aparecido en otras materias."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000011/2025-26/RA245> a ns1:LearningResult ;
    ns1:learningResultCode "RA245" ;
    ns1:learningResultDescription "Proporciona una panorámica muy amplia de modelos clásicos aplicados en muy diversos campos: mecánica, ecología teórica, economía, epidemiología, etc."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000011/2025-26/didactic_resource/1> a ns1:DidacticResource ;
    ns1:bibliographyDescription "Libro escrito por profesores del Departamento, cuyo contenido se adapta al programa de la asignatura. Es de orientación práctica."@es ;
    ns1:bibliographyTitle "E. Sánchez, J. González y J. Gutiérrez. Sistemas Dinámicos. Una introducción a través de ejercicios. Sección de Publicaciones de la E.T.S.I. Industriales de la U.P.M."@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000011/2025-26/didactic_resource/2> a ns1:DidacticResource ;
    ns1:bibliographyDescription "Es una publicación que contiene todas las pruebas globales de Ecuaciones Diferenciales que se han propuesto desde la implantación de los estudios de Grado. Contiene la solución de dichas pruebas y se actualiza cada curso académico."@es ;
    ns1:bibliographyTitle "Ecuaciones Diferenciales. Exámenes resueltos de Grado"@es ;
    ns1:bibliographyType "Otros"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000011/2025-26/didactic_resource/3> a ns1:DidacticResource ;
    ns1:bibliographyTitle "M. Braun. Ecuaciones diferenciales y sus aplicaciones. Grupo Editorial Iberoamericana, 1990."@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000011/2025-26/didactic_resource/4> a ns1:DidacticResource ;
    ns1:bibliographyTitle "R. K. Nagle, E. B. Saff. Fundamentos de ecuaciones diferenciales 2ª ed. Addison-Wesley Iberoamericana, 1992."@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000011/2025-26/didactic_resource/5> a ns1:DidacticResource ;
    ns1:bibliographyTitle "R. Haberman. Applied partial differential equations with fourier series and boundary value problems. Pearson Prentice Hall, 2004."@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000011/2025-26/evaluation> a ns1:EvaluationSystem ;
    ns1:evaluationDescription """La evaluación progresiva consta de las siguientes pruebas:
Dos prácticas de computación científica, que se realizarán en equipo, con un peso total del 10% (P=nota sobre 10). Las fechas que aparecen en el cronograma son meramente ilustrativas y dependerán del desarrollo del temario.
Una primera prueba escrita con un valor del 40% que se realizará en la primera semana habilitada para ello por la Subdirección de Ordenación Académica (T=nota sobre 10).
Una segunda prueba escrita con un valor del 50% que se celebrará conjuntamente con el examen global en la fecha establecida por Subdirección de Ordenación Académica para la convocatoria ordinaria (N=nota sobre 10). Esta prueba abarcará la asignatura completa.
Observaciones a la evaluación en la convocatoria ordinaria:
Para aprobar la asignatura será necesario obtener una nota igual o superior a 2.5 sobre 10 en la segunda prueba escrita.
Todos los alumnos deberán tener las prácticas superadas en todas las convocatorias para poder aprobar la asignatura, para lo cual será requisito obtener una nota media de, al menos, 3.5 sobre 10 entre las dos prácticas. Los estudiantes que no superen las prácticas a lo largo de la evaluación progresiva responderán en el examen global a una cuestión teórica extra sobre los epígrafes 1.6 y 4.3 (P=nota sobre 10). En este último caso, para aprobar la asignatura, es requisito obtener una nota mínima de 3.5 sobre 10 en dicha pregunta teórica.
Si los puntos anteriores se superan, entonces la calificación en acta se calculará mediante la fórmula
max{0.1 P + 0.4 T + 0.5 N; 0.1 P + 0.9 N}.
En caso contrario, la calificación en acta se calculará mediante
min{0.1 P + 0.4 T + 0.5 N; 4.5}.
La calificación de las prácticas y las pruebas de evaluación es válida solamente durante el curso académico actual.
Podrá haber un test eliminatorio de 3 puntos en cada prueba de evaluación. Para superar este test, hay que obtener un 1.5 sobre 3. En caso de no superarlo, la calificación de esa prueba completa será la obtenida en el test (sobre 10 puntos), es decir, el resto de la prueba no se calificará. Además del test eliminatorio, en cada prueba de evaluación podrá haber preguntas de tipo test y/o de desarrollo.
Observaciones a la evaluación en la convocatoria extraordinaria:
El examen extraordinario se celebrará en la fecha establecida por Subdirección de Ordenación Académica para la convocatoria extraordinaria (E=nota sobre 10). Esta prueba abarcará la asignatura completa.
Los estudiantes que no hayan superado las prácticas a lo largo de la evaluación progresiva y se presenten al examen extraordinario, tendrán que responder en dicho examen a una cuestión teórica extra sobre los epígrafes 1.6 y 4.3 (P=nota sobre 10). Para aprobar la asignatura es requisito obtener una nota mínima de 3.5 sobre 10 en dicha pregunta teórica.
Si el punto anterior se supera, entonces la calificación en acta se calculará mediante la fórmula
0.1 P + 0.9 E.
En caso contrario, la calificación en acta se calculará mediante
min{0.1 P + 0.9 E; 4.5}.
La calificación de las prácticas y las pruebas de evaluación es válida solamente durante el curso académico actual.
Podrá haber un test eliminatorio de 3 puntos en esta prueba de evaluación. Para superar este test, hay que obtener un 1.5 sobre 3. En caso de no superarlo, la calificación de esta prueba completa será la obtenida en el test (sobre 10 puntos), es decir, el resto de la prueba no se calificará. Además del test eliminatorio, en esta prueba de evaluación podrá haber preguntas de tipo test y/o de desarrollo."""@es .

