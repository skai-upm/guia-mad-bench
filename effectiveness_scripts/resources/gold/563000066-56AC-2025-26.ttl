<https://guia-kg.skai.etsisi.upm.es/resource/563000066/2025-26/CE1> a ns1:Competency ;
    ns1:competencyCode "CE1" ;
    ns1:competencyDescription "Capacidad de diseñar, innovar y gestionar nuevos productos teniendo en cuenta criterios de calidad y medioambientales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000066/2025-26/CE4> a ns1:Competency ;
    ns1:competencyCode "CE4" ;
    ns1:competencyDescription "Capacidad de manejar e integrar las herramientas de representación, simulación y cálculo CAD"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000066/2025-26/CE5> a ns1:Competency ;
    ns1:competencyCode "CE5" ;
    ns1:competencyDescription "Capacidad para seleccionar los materiales adecuados para un correcto diseño de producto"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000066/2025-26/CE8> a ns1:Competency ;
    ns1:competencyCode "CE8" ;
    ns1:competencyDescription "Capacidad para aplicar herramientas de visualización y generación virtual de productos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000066/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Capacidad para fomentar, en contextos académicos y profesionales, el avance tecnológico, social o cultural dentro de una sociedad basada en el conocimiento"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000066/2025-26/CG2> a ns1:Competency ;
    ns1:competencyCode "CG2" ;
    ns1:competencyDescription "Capacidad para integrar aspectos estéticos en los productos de diseño sin perder la funcionalidad"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000066/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Conocimiento de las herramientas de visualización y generación de productos de diseño"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000066/2025-26/CG4> a ns1:Competency ;
    ns1:competencyCode "CG4" ;
    ns1:competencyDescription "Conocimiento de los procesos industriales para ser capaz de decidir sobre los criterios adecuados en la fabricación de productos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000066/2025-26/CG5> a ns1:Competency ;
    ns1:competencyCode "CG5" ;
    ns1:competencyDescription "Capacidad de integrar herramientas de representación en los procesos de fabricación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000066/2025-26/CG7> a ns1:Competency ;
    ns1:competencyCode "CG7" ;
    ns1:competencyDescription "Capacidad de integrar metodologías, tecnologías, procesos y herramientas en el campo de la ingeniería y el diseño industrial"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000066/2025-26/CT2> a ns1:Competency ;
    ns1:competencyCode "CT2" ;
    ns1:competencyDescription "Ser capaz de negociar y trabajar en equipo así como de manera autónoma en un contexto internacional, multidisciplinar y multicultura"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000066/2025-26/CT3> a ns1:Competency ;
    ns1:competencyCode "CT3" ;
    ns1:competencyDescription "Ser capaz de organizar y planificar el tiempo de trabajo propio o de un equipo de trabajo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000066/2025-26/CT5> a ns1:Competency ;
    ns1:competencyCode "CT5" ;
    ns1:competencyDescription "Capacidad para desarrollar y ejercitar la creatividad"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000066/2025-26/CT7> a ns1:Competency ;
    ns1:competencyCode "CT7" ;
    ns1:competencyDescription "Capacidad para comunicarse en lengua inglesa en un entorno profesional"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000066/2025-26/RA44> a ns1:LearningResult ;
    ns1:learningResultCode "RA44" ;
    ns1:learningResultDescription "Conocer los distintos tipos y técnicas de prototipado rápido, sus características, requisitos técnicos, ventajas y limitaciones."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000066/2025-26/RA45> a ns1:LearningResult ;
    ns1:learningResultCode "RA45" ;
    ns1:learningResultDescription "Gestionar y procesar la información generada desde diferentes herramientas para realizar proyectos de prototipado rápido."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000066/2025-26/RA46> a ns1:LearningResult ;
    ns1:learningResultCode "RA46" ;
    ns1:learningResultDescription "Materializar formas y conceptos obtenidos a partir de modelos virtuales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000066/2025-26/RA47> a ns1:LearningResult ;
    ns1:learningResultCode "RA47" ;
    ns1:learningResultDescription "Realizar series cortas mediante técnicas de fabricación rápida."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000066/2025-26/RA48> a ns1:LearningResult ;
    ns1:learningResultCode "RA48" ;
    ns1:learningResultDescription "Motivar la búsqueda y producción de soluciones, tanto formales como técnicas, basadas en la experiencia proporcionada por el diseño rápido de prototipos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000066/2025-26/RA49> a ns1:LearningResult ;
    ns1:learningResultCode "RA49" ;
    ns1:learningResultDescription "Conocer las distintas técnicas para el tratamiento final o acabado de un prototipo."@es .

