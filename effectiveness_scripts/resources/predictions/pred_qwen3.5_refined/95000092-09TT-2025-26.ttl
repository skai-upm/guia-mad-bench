    guide:learningResultCode "RA357"^^xsd:string ;
    sch:description "Concreción de los conocimientos en aplicaciones prácticas en los ámbitos de las Tecnologías de la Información y la Comunicación (TIC), y la electrificación rural."^^rdf:langString .

<http://guia-mad-bench.es/data/guia/#RA354> rdf:type :LearningResult ;
    guide:learningResultCode "RA354"^^xsd:string ;
    sch:description "Adquisición de una visión objetiva y amplia de los actuales desequilibrios sociales y medioambientales; de sus causas, alcance y perspectivas de evolución."^^rdf:langString .

<http://guia-mad-bench.es/data/guia/#RA45> rdf:type :LearningResult ;
    guide:learningResultCode "RA45"^^xsd:string ;
    sch:description "Conocimientos y habilidades de las temáticas científico tecnológicas desarrolladas en las asignaturas ofertadas."^^rdf:langString .

<http://guia-mad-bench.es/data/guia/#RA355> rdf:type :LearningResult ;
    guide:learningResultCode "RA355"^^xsd:string ;
    sch:description "Conocimiento de la estructura y los instrumentos de la cooperación internacional para el desarrollo y sean conscientes de su potencial contribución, como ingenieros, a la lucha contra la pobreza y la exclusión social."^^rdf:langString .

<http://guia-mad-bench.es/data/guia/#RA356> rdf:type :LearningResult ;
    guide:learningResultCode "RA356"^^xsd:string ;
    sch:description "Conocimiento y aplicación de metodologías de planificación e intervención en proyectos de desarrollo con componente tecnológica."^^rdf:langString .

