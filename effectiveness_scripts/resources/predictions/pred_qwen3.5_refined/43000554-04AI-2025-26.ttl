<http://w3id.org/def/guia#CourseGuide_ANX_PR_CL_001_01> rdf:type :CourseGuide, sch:CourseInstance ;
    dct:title "ANX-PR/CL/001 - LEARNING GUIDE"@en ;
    guide-mad-bench:numberOfCredits 4.5^^xsd:decimal ;
    guide-mad-bench:teachingPeriodMonths "September-January" ;
    sch:name "Experimental Structural Analysis" ;
    guide-mad-bench:syllabusDescription "This course deals with the fundamentals and applications of experimental techniques in structural engineering."@en .

