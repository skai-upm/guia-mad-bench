<http://guia-mad-bench.es/data/guia#Competency_CB10> rdf:type guide:Competency ;
    guide:competencyCode "CB10"@en ;
    guide:competencyDescription "Que los estudiantes posean las habilidades de aprendizaje que les permitan continuar estudiando de un modo que habrá de ser en gran medida autodirigido o autónomo"^^xsd:string .

<http://guia-mad-bench.es/data/guia#Competency_CG5> rdf:type guide:Competency ;
    guide:competencyCode "CG5"@en ;
    guide:competencyDescription "Desarrollo de la habilidades humanas necesarias para el trabajo en equipo y de ese modo asumir el compromiso de la investigación científica con valores humanos que favorezcan la sana convivencia."^^xsd:string .

<http://guia-mad-bench.es/data/guia#Competency_CG6> rdf:type guide:Competency ;
    guide:competencyCode "CG6"@en ;
    guide:competencyDescription "Capacidad para comunicarse y relacionarse en un ámbito científico en la lengua inglesa."^^xsd:string .

