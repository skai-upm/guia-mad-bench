<http://guia-mad-bench.es/data/guia#CourseGuide_11AB_113000033> rdf:type guide:CourseGuide ;
    sch:name "Redaccion Técnica De Inglés Aplicada A La Actividad Fisica Y El Deporte"@en ;
    dc:title "ANX-PR/CL/001 - GUÍA DE APRENDIZAJE"@es ;
    guide:numberOfCredits 3^^xsd:decimal ;
    sch:description "This module supports students whose first language is not English over a semester of academic study, and helps them to refine their writing through extensive language input, practice and feedback."@en .

