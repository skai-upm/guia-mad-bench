@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix sch: <https://schema.org/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://guia-mad-bench.es/data/courseguide-ANXPRCL001> rdf:type :CourseGuide ;
    dct:title "Ampliación De Sistemas de Información Geográfica"@en ;
    sch:name "Ampliación De Sistemas de Información Geográfica" ;
    guide:numberOfCredits 3.0^^xsd:decimal ;
    guide:courseYear 2025-26^^xsd:string ; # Document says Curso Académico Y Semestre, but property is xsd:integer in ontology for Course class? Wait, document table has "Curso" (Cuarto curso) and "Semestre". Property `guide:courseYear` range is integer. I will use the year 2025-26 as string or extract just 2025 if needed. Document says "2025/26 - Segundo semestre". Let's assume Year property applies to Course class, but Guide has it too? Ontology `guide:courseYear` domain is `guide:Course`. I will use data properties on the Guide instance where available or link via Degree/Course if needed. Document table "Datos de la asignatura" lists Curso (Cuarto curso).
    guide:syllabusDescription "Herramientas avanzadas de análisis vectorial y ráster, Hidrología, Ordenación de montes..."@en ; # Extracted from Section 5 description summary or Syllabus items. I will use the full syllabus content as a property if possible, but ontology has `guide:syllabusDescription` on `SyllabusItem`.
    guide:teachingPeriod "2025-26"@en ;
    guide:periodStartingMonth "Febrero"^^xsd:string ;
    guide:periodEndingMonth "Junio"^^xsd:string ;
    sch:inLanguage "Castellano"^^rdf:langString .

<http://guia-mad-bench.es/data/degree-GradoEnIngenieriaDelMedioNatural> rdf:type :Degree, :BachelorDegree ;
    guide:numberOfCredits 3.0^^xsd:decimal ; # Assuming degree credits match course or use specific property on Degree? Ontology has `guide:numberOfCredits` domain CourseGuide and sch:numberOfCredits domain Course. I will link via Guide properties mostly as it's the main document entity.
    dct:title "Grado En Ingenieria Del Medio Natural"@en ;
    guide:degreeCode "13MP"^^xsd:string .

<http://guia-mad-bench.es/data/universitycenter-ETSIMontes> rdf:type sch:Organization, :UniversityCenter ;
    sch:name "E.T.S.I Montes, Forestal Y Medio Natur." ;
    dct:title "Centro responsable de la titulación"@en ;
    guide:numberOfCredits 3.0^^xsd:decimal .

<http://guia-mad-bench.es/data/lecturer-emilioortegaperez> rdf:type sch:Person, :Lecturer ;
    sch:name "Emilio Ortega Perez" ;
    dct:title "(Coordinador/a)"@en ;
    guide:office "07B.01.004.0"@en ;
    sch:email <mailto:emilio.ortega.perez@upm.es> .

<http://guia-mad-bench.es/data/lecturer-rodrigocuevaswizner> rdf:type :Lecturer, sch:Person ;
    sch:name "Cuevas Wizner, Rodrigo" ;
    guide:tutorshipsSchedule "N/A"@en ; # Not specified in detail other than email.

<http://guia-mad-bench.es/data/syllabus-ANXPRCL001> rdf:type :Syllabus, sch:Syllabus ;
    dct:title "Temario de la asignatura" .

<http://guia-mad-bench.es/data/competency-CB02> rdf:type :Competency ;
    guide:competencyCode "CB02"@en ;
    guide:competencyDescription "Que los estudiantes sepan aplicar sus conocimientos a su trabajo o vocación de una forma profesional y posean las competencias que suelen demostrarse por medio de la elaboración y defensa de argumentos y la resolución de problemas dentro de su área estudio."@en .

<http://guia-mad-bench.es/data/competency-CE101> rdf:type :Competency ;
    guide:competencyCode "CE 1.01"@en ;
    guide:competencyDescription "Conocer los campos de aplicación de la Ingeniería del Medio Natural, y tener una apreciación de la necesidad de poseer unos conocimientos técnicos profundos en ciertas áreas de aplicación; apreciación del grado de esta necesidad en, por lo menos, una situación."@en .

<http://guia-mad-bench.es/data/learningresult-RA204> rdf:type :LearningResult ;
    guide:learningResultCode "RA204"@en ;
    guide:learningResultDescription "Capacidad para integrar en un Sistemas de Información Geográfica información espacial y alfanumérica de diferentes fuentes" .

<http://guia-mad-bench.es/data/learningresult-RA206> rdf:type :LearningResult ;
    guide:learningResultCode "RA206"@en ;
    guide:learningResultDescription "El alumno será capaz de realizar proyectos de gestión ambiental mediante los Sistemas de Información Geográfica" .

<http://guia-mad-bench.es/data/learningresult-RA207> rdf:type :LearningResult ;
    guide:learningResultCode "RA207"@en ;
    guide:learningResultDescription "El alumno será capaz de manejar con destreza herramientas para aplicar los conocimientos adquiridos previamente sobre planificación territorial, evaluación de impacto ambiental..." .

<http://guia-mad-bench.es/data/learningresult-RA203> rdf:type :LearningResult ;
    guide:learningResultCode "RA203"@en ;
    guide:learningResultDescription "Capacidad para adquirir, procesar y analizar datos geográficos." .

<http://guia-mad-bench.es/data/learningresult-RA205> rdf:type :LearningResult ;
    guide:learningResultCode "RA205"@en ;
    guide:learningResultDescription "El alumno/a conocerá las herramientas disponibles en los Sistemas de Información Geográfica con aplicaciones en el campo de la gestión forestal y ambiental..." .

