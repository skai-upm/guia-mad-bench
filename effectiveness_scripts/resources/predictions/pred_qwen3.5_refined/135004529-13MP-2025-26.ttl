    guide:gradePercentage 0.5^^xsd:string ; # Document table shows weight in column "Peso en la nota" (e.g., 50%). I will use string or decimal? Ontology `guide:gradePercentage` range is rdf:langString. So string.
    guide:minimumScore 4 / 10 .

