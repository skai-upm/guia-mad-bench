@prefix : <http://w3id.org/def/guia#> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix om: <http://www.ontology-of-units-of-measure.org/resource/om-2/> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix sch: <https://schema.org/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

#################################################################
#    Classes (Reference) - Used for Types in Instances
#################################################################

<http://w3id.org/def/guia#CourseGuide> rdf:type owl:Class ;
                                         rdfs:subClassOf sch:CourseInstance ,
                                                         <http://www.w3.org/2000/01/rdf-schema#Resource> .

<http://w3id.org/def/guia#Lecturer> rdf:type owl:Class ;
                                      rdfs:subClassOf sch:Person .

