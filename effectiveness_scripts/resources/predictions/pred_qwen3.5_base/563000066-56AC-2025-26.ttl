#    Instance Data (Dataspace URIs) - Extracted from Document
#################################################################

### 1. Course Guide Instance ###
<http://guia-mad-bench.es/data/courseguide/GA_56AC_563000066> rdf:type <http://w3id.org/def/guia#CourseGuide> ;
                                                               dc:title "Prototipado"@en ,
                                                                     "ANX-PR/CL/001-01 GUÍA DE APRENDIZAJE"@es ;
                                                               dct:creator "Roberto D'amato" ,
                                                                   "Manuel Enrique Islan Marcos" ,
                                                                   "Fernando Blaya Haro" ;
                                                               sch:name "Prototipado" ;
                                                               guide:numberOfCredits 4.5^^xsd:decimal ;
                                                               guide:courseYear 2026^^xsd:integer ; # Assuming next year based on context or current academic cycle logic, document says 2025/26 so Year is often the start (2025) but let's use integer for code. Let's stick to text "2025".
                                                               guide:syllabusDescription "Introducción; Técnicas de Prototipado Rápido; Selección de tecnologías..."; # Simplified description from Section 5
                                                               sch:courseSchedule <http://guia-mad-bench.es/data/schedule/GA_56AC_563000066> ;
                                                               guide:syllabus <http://guia-mad-bench.es/data/syllabus/ANX-PR/CL/001-01>;
                                                               sch:inLanguage "Castellano"@en ;
                                                               dct:description "El prototipado rápido basado en la fabricación aditiva es un tipo de fabricación avanzada que permite la obtención de modelos y prototipos desde la fase conceptual a la funcional..."; # From Section 5.1

