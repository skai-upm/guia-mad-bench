<http://guia-mad-bench.es/data/guia#55001039> rdf:type :CourseGuide ;
    dc:title "Ingenieria Procesos Y Productos"@en ;
    sch:name "55001039 - Ingenieria Procesos Y Productos" ;
    guide:numberOfCredits 4.5^^xsd:decimal ;
    guide:syllabusDescription "La asignatura es eminentemente práctica, aunque tiene una base teórica que es importante manejar con soltura."@en ;
    sch:description "El objetivo de la asignatura es familiarizarse con las distintas etapas necesarias para llevar a cabo el diseño de procesos y productos..."@en ;
    guide:teachingPeriodMonths "Septiembre-Enero"@en ;
    dct:creator <http://guia-mad-bench.es/data/guia#Maria_Gonzalez_Miquel> ,
                <http://guia-mad-bench.es/data/guia#Francisco_Ismael_Diaz_Moreno> .

