@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix guide: <http://w3id.org/def/guia#> .
@prefix om: <http://www.ontology-of-units-of-measure.org/resource/om-2/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sch: <https://schema.org/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix data: <http://guia-mad-bench.es/data/guide/> .

#################################################################
#    Classes (from Ontology Reference)
#################################################################

###  http://w3id.org/def/guia#CourseGuide
guide:CourseGuide rdf:type owl:Class ;
                  rdfs:subClassOf sch:CourseInstance ;
                  rdfs:comment "A structured academic document that describes a course, including objectives, contents, methodology, resources, schedule, and evaluation."@en .

###  http://w3id.org/def/guia#Degree
guide:Degree rdf:type owl:Class ;
             rdfs:subClassOf guide:BachelorDegree ,
                            guide:MastersDegree ; # Assuming generic Degree structure if needed, but text says Bachelor.
             rdfs:comment "An academic degree programme that structures and groups courses within a formal higher education curriculum."@en .

###  http://w3id.org/def/guia#BachelorDegree
guide:BachelorDegree rdf:type owl:Class ;
                     rdfs:subClassOf guide:Degree ;
                     rdfs:comment "An undergraduate degree programme that provides foundational higher education in a given field of study."@en .

###  http://w3id.org/def/guia#Lecturer
guide:Lecturer rdf:type owl:Class ;
               rdfs:subClassOf sch:Person ;
               rdfs:comment "A teaching person responsible for delivering, coordinating, or supporting a course within an academic programme."@en .

###  http://w3id.org/def/guia#Competency
guide:Competency rdf:type owl:Class ;
                 rdfs:comment "A capability, skill, or integrated learning outcome that students are expected to develop through the course."@en .

###  http://w3id.org/def/guia#LearningResult
guide:LearningResult rdf:type owl:Class ;
                     rdfs:comment "A specific and assessable statement of what a student is expected to know, understand, or be able to do after completing the course."@en .

#################################################################
#    Object Properties (from Ontology Reference)
#################################################################

###  http://w3id.org/def/guia#hasSyllabus
guide:hasSyllabus rdf:type owl:ObjectProperty ;
                  rdfs:domain guide:CourseGuide ;
                  rdfs:range guide:Syllabus .

###  http://w3id.org/def/guia#hasActivity
guide:hasActivity rdf:type owl:ObjectProperty ;
                  rdfs:domain guide:ScheduleEvent ;
                  rdfs:range guide:Activity .

###  http://w3id.org/def/guia#hasCompetency
guide:hasCompetency rdf:type owl:ObjectProperty ;
                    rdfs:domain guide:CourseGuide ;
                    rdfs:range guide:Competency .

###  http://w3id.org/def/guia#hasEvaluationTrial
guide:hasEvaluationTrial rdf:type owl:ObjectProperty ;
                         rdfs:domain guide:EvaluationSystem ;
                         rdfs:range guide:EvaluationTrial .

#################################################################
#    Data Properties (from Ontology Reference)
#################################################################

###  http://w3id.org/def/guia:numberOfCredits
guide:numberOfCredits rdf:type owl:DatatypeProperty ;
                      rdfs:domain guide:CourseGuide ;
                      rdfs:range xsd:decimal .

###  https://schema.org/name
sch:name rdf:type owl:DatatypeProperty ;
         rdfs:domain guide:Lecturer ,
                    guide:SyllabusItem ,
                    guide:EvaluationTrial ;
         rdfs:comment "Provides the name of an entity such as a course, person, or university center."@en .

###  https://schema.org/email
sch:email rdf:type owl:DatatypeProperty ;
          rdfs:domain guide:Lecturer ;
          rdfs:range xsd:string .

#################################################################
#    Instances (Extraction from Document)
#################################################################

data:gauge/GA_08NV_85003112 rdf:type guide:CourseGuide ,
                                      sch:CourseInstance ;
                             dct:title "Guía de Aprendizaje"@en ;
                             dc:description "Cálculo I - Grado En Arquitectura Naval 2025/26" .

data:gauge/GA_08NV_85003112 guide:numberOfCredits "6.0"^^xsd:decimal ;
                            sch:name "85003112 - Cálculo I"@en ;
                            dct:creator <http://guia-mad-bench.es/data/guide/lecturer/CJ_Meroño> ,
                                     <http://guia-mad-bench.es/data/guide/lecturer/AP_Pire> .

data:gauge/GA_08NV_85003112 guide:teachingPeriod "Septiembre-Enero"@en ;
                             sch:inLanguage "Castellano"^^xsd:string ;
                             dct:publisher <http://guia-mad-bench.es/data/guide/organization/E.T.S._de_Ingenieros_Navales> .

data:gauge/GA_08NV_85003112 guide:hasCourseInstance data:gauge/course/CALCULO_I ;
                            sch:courseCode "85003112"^^xsd:string .

#################################################################
#    Degree Instance
#################################################################

data:gauge/degree/GRADE_08NV rdf:type guide:BachelorDegree ,
                                      guide:Degree ;
                             dct:title "Grado En Arquitectura Naval"@en ;
                             sch:name "08 - E.T.S. De Ingenieros Navales" .

data:gauge/course/CALCULO_I rdf:type guide:Course ,
                                     sch:Course ;
                            guide:numberOfCredits "6.0"^^xsd:decimal ;
                            guide:courseYear 2025-26 ; # Using integer as per ontology range for course year if applicable, though text says academic year string. Ontology defines xsd:integer. I'll use the numeric part or just leave it out to be safe with data types in document context (text is "2025/26").
                            sch:description "Cálculo I - Primer curso".

