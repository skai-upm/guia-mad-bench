<http://guia-mad-bench.es/data/syllabus-item/txm-1> rdf:type :SyllabusItem ,
        sch:SyllabusItem ;
    guide:itemIndex 1 ;
    guide:syllabusDescription "PRINCIPIOS FUNDAMENTALES DE LOS SISTEMAS DE RADIOFRECUENCIA. Generalidades, esquemas de bloques..."@es .

<http://guia-mad-bench.es/data/syllabus-item/txm-2> rdf:type :SyllabusItem ,
        sch:SyllabusItem ;
    guide:itemIndex 2 ;
    guide:syllabusDescription "ONDAS ELECTROMAGNÉTICAS: NATURALEZA Y PROPAGACIÓN. Ecuaciones de Maxwell..."@es .

<http://guia-mad-bench.es/data/syllabus-item/txm-3> rdf:type :SyllabusItem ,
        sch:SyllabusItem ;
    guide:itemIndex 3 ;
    guide:syllabusDescription "LINEAS DE TRANSMISION. Constante de propagación, Impedancias..."@es .

<http://guia-mad-bench.es/data/syllabus-item/txm-4> rdf:type :SyllabusItem ,
        sch:SyllabusItem ;
    guide:itemIndex 4 ;
    guide:syllabusDescription "GUIAS DE ONDA. Modos TM y TE, Cavidades resonantes..."@es .

<http://guia-mad-bench.es/data/syllabus-item/txm-5> rdf:type :SyllabusItem ,
        sch:SyllabusItem ;
    guide:itemIndex 5 ;
    guide:syllabusDescription "ANTENAS. Dipolo, campos cercano y lejano..."@es .

<http://guia-mad-bench.es/data/syllabus-item/txm-6> rdf:type :SyllabusItem ,
        sch:SyllabusItem ;
    guide:itemIndex 6 ;
    guide:syllabusDescription "TIPOS Y REDES DE ANTENAS. Dipolos de media onda, sistemas..."@es .

