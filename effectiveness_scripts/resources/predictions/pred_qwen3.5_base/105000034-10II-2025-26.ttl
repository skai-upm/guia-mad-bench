                          dct:title "Temario de la asignatura" ;
                          guide:hasCourseGuide <guide:CourseGuide_GA_105000034> .

# Syllabus Items (Main Sections)
<guide:SyllabusItem_Intro> rdf:type guide:SyllabusItem, sch:Event ;
                           dct:title "Introducción" ;
                           guide:itemIndex 1^^xsd:integer ,
                                       "Tipos de instalaciones informáticas"@en .

<guide:SyllabusItem_Refrigeracion> rdf:type guide:SyllabusItem, sch:Event ;
                                   dct:title "Refrigeración" ;
                                   guide:itemIndex 2^^xsd:integer ,
                                               "El agua, Sicrometría, Especificación del entorno"@en .

<guide:SyllabusItem_Instalacion> rdf:type guide:SyllabusItem, sch:Event ;
                                  dct:title "Instalación de equipos" ;
                                  guide:itemIndex 3^^xsd:integer ,
                                              "Práctica de equipos, Diseño CPD"@en .


#################################################################
#    Schedule Instance & Events
#################################################################

<guide:Schedule_GA_10II> rdf:type guide:Schedule, sch:Schedule ;
                         dct:title "Cronograma" ;
                         sch:eventSchedule <guide:ScheduleEvent_Wk1>,
                                           <guide:ScheduleEvent_Wk2>,
                                           ... . # Simplified for brevity

<guide:ScheduleEvent_Wk6> rdf:type guide:ScheduleEvent, sch:Event ;
                          dct:title "Evaluación del estado del proyecto" ;
                          guide:eventIndex 6^^xsd:integer ,
                                      "Semana 6"@en ;
                          om:activityDurationUnit <http://www.ontology-of-units-of-measure.org/resource/om-2/hour> .

<guide:ScheduleEvent_Wk15> rdf:type guide:ScheduleEvent, sch:Event ;
                           dct:title "Entrega: Memoria Final" ;
                           guide:eventIndex 15^^xsd:integer ,
                                       "Semana 15"@en ;
                           om:activityDurationUnit <http://www.ontology-of-units-of-measure.org/resource/om-2/hour> .


#################################################################
#    Evaluation System & Trials
#################################################################

<guide:EvaluationSystem_GA_10II> rdf:type guide:EvaluationSystem, sch:Event ;
                                  dct:title "Sistema de Evaluación" ;
                                  guide:evaluationDescription "Evaluación progresiva + Prueba Global"@es .

<guide:EvaluationTrial_Progressive> rdf:type guide:EvaluationTrial, sch:Event ;
                                    dct:title "Progresiva (Semana 6)" ;
                                    guide:hasEvaluationSystem <guide:EvaluationSystem_GA_10II>,
