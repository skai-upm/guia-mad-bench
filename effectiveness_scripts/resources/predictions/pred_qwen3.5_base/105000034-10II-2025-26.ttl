                                                                     <guide:CourseGuide_GA_105000034> .

<guide:EvaluationTrial_Progressive_Wk6> rdf:type guide:EvaluationTrial, sch:Event ;
                                         dct:title "Evaluación del estado del proyecto" ;
                                         guide:hasEvaluationSystem <guide:EvaluationSystem_GA_10II>,
                                                                         <guide:CourseGuide_GA_105000034> .

