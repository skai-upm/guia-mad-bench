#    Instance Data Extraction
#################################################################

###  Course Guide Instance (ANX-PR/CL/001-01)
<http://guia-mad-bench.es/data/guia/courseguide/GA_53001726> rdf:type guide:CourseGuide ;
                                                          dc:title "Dirección Estratégica Y De La Innovación"@en ;
                                                          dct:creator <http://w3id.org/def/guia#Rafael_Ramos_Diaz> ,
                                                                                     <http://w3id.org/def/guia#Ebru_Susur_Donerkan> ;
                                                          guide:numberOfCredits "3"^^xsd:decimal ;
                                                          sch:name "53001726 - Dirección Estratégica Y De La Innovación"@en ;
                                                          dct:description "La asignatura tiene como objetivos fundamentales que los alumnos sean capaces de abordar proyectos de innovación en un entorno real mediante trabajo colaborativo."@es .

