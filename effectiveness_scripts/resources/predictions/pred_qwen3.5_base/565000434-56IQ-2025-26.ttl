#################################################################
#    Instances - Syllabus and Items
#################################################################

<http://w3id.org/def/guia#Syllabus_56IQ> rdf:type guide:Syllabus ;
                                          sch:name "Temario de la asignatura" ,
                                            dct:title "Resistencia De Materiales"@en .

###  Syllabus Item: Intro (1)
<http://w3id.org/def/guia#Item_Intro> rdf:type guide:SyllabusItem ;
                                      guide:itemIndex 1 ;
                                      sch:name "Introducción a la Resistencia de Materiales" ,
                                        guide:syllabusDescription "Concepto, objetivos, sólidos rígido/elástico/prisma mecánico."@en .

###  Syllabus Item: Axial (2)
<http://w3id.org/def/guia#Item_Axial> rdf:type guide:SyllabusItem ;
                                      guide:itemIndex 2 ;
                                      sch:name "Cálculo y diseño de elementos axiales" ,
                                        guide:syllabusDescription "Tracción-compresión, diagramas de esfuerzos."@en .

###  Syllabus Item: Bending (3)
<http://w3id.org/def/guia#Item_Bending> rdf:type guide:SyllabusItem ;
                                      guide:itemIndex 3 ;
                                      sch:name "Cálculo y diseño de elementos flexión" ,
                                        guide:syllabusDescription "Flexión pura, diagramas momentos flectores."@en .

###  Syllabus Item: Buckling (4)
<http://w3id.org/def/guia#Item_Buckling> rdf:type guide:SyllabusItem ;
                                      guide:itemIndex 4 ;
                                      sch:name "Pandeo" ,
                                        guide:syllabusDescription "Estabilidad, fórmula de Euler."@en .

###  Syllabus Item: Torsion (5)
<http://w3id.org/def/guia#Item_Torsion> rdf:type guide:SyllabusItem ;
                                      guide:itemIndex 5 ;
                                      sch:name "Cálculo y diseño torsión" ,
                                        guide:syllabusDescription "Secciones circulares, diagramas momentos torsores."@en .

#################################################################
#    Instances - Schedule and Activities
#################################################################

<http://w3id.org/def/guia#Schedule_56IQ> rdf:type sch:Schedule ;
                                         sch:name "Cronograma 2025-26" ,
                                           guide:syllabusDescription "Planificación de la asignatura"@en .

###  Schedule Event (Weeks) - Example Week 1
<http://w3id.org/def/guia#Event_Week1> rdf:type sch:Event ; # Using Schema Class as base for event structure if available, or generic. Ontology has guide:ScheduleEvent subClassOf sch:Event. I will use the provided ontology class `guide:ScheduleEvent`.
                                        rdf:type guide:ScheduleEvent , sch:Event ;
                                        guide:eventIndex 1 ;
                                        guide:eventWeek "Semestre 2025-26"@en ; # Using langString as per some props or specific prop if available. Ontology has eventWeek range rdf:langString.
                                        sch:description "Explicación teórica tema 1" .

###  Activity linked to Event (LM)
<http://w3id.org/def/guia#Activity_LeccionMagistral> rdf:type guide:Activity ;
                                                      sch:name "Explicación Teórica Tema 1" ,
                                                        guide:activityDescription "Teoría de Resistencia"@en .

#################################################################
#    Instances - Evaluation System and Trials
#################################################################

<http://w3id.org/def/guia#EvalSystem_56IQ> rdf:type guide:EvaluationSystem ;
                                             sch:name "Evaluación Progresiva y Global" ,
                                               guide:evaluationDescription "Control de temas + Examen Final"@en .

###  Evaluation Trial (Final Exam)
<http://w3id.org/def/guia#Trial_FinalExam> rdf:type guide:EvaluationTrial ;
                                            sch:name "Examen final de la asignatura" ,
                                              guide:trialType "EX: Técnica del tipo Examen Escrito"@en .

###  Evaluation Trial (Control)
<http://w3id.org/def/guia#Trial_Control1> rdf:type guide:EvaluationTrial ;
                                           sch:name "Control temas 1 y 2" ,
                                             guide:trialType "EX: Técnica del tipo Examen Escrito"@en .

#################################################################
#    Data Properties - Course Guide Details
#################################################################

<http://w3id.org/def/guia#ANX-PRCL001> sch:description "Guía de Aprendizaje para Resistencia De Materiales" ;
                                         guide:inLanguage <https://schema.org/es> , # Assuming Spanish based on document content. Ontology has inLanguage range rdf:langString. I will use the property if available, but `sch:inLanguage` is defined with range `rdf:langString`. The ontology defines it as such.
                                         guide:syllabusDescription "Temario completo"@en ; # Reusing prop for description context or specific one. Ontology has syllabusDescription on SyllabusItem. I'll use sch:description here if available, but stick to ontology props where possible. `sch:description` is defined with range rdf:langString and domain guide:CourseGuide.
                                         dct:publisher <http://w3id.org/def/guia#EtsIdi> .

#################################################################
#    Data Properties - Evaluation Trials Details (Weights, Scores)
#################################################################

<http://w3id.org/def/guia#Trial_FinalExam> guide:gradePercentage "60%" ; # Ontology range rdf:langString. Document says 60%.
                                             guide:minimumScore "4 / 10" ,
                                               sch:description "Examen final"@en .

<http://w3id.org/def/guia#Trial_Control1> guide:gradePercentage "10%" ; # Ontology range rdf:langString. Document says 10%.
                                           guide:minimumScore "/ 10" ,
                                             sch:name "Control temas 1 y 2"@en .

#################################################################
#    Data Properties - Activities (Duration, Format)
#################################################################

<http://w3id.org/def/guia#Activity_LeccionMagistral> guide:activityDescription "Explicación teórica" ; # Ontology range rdf:langString. Document says LM.
                                                       guide:attendanceType "Presencial"@en . # Using langString as per ontology definition for attendanceType (range is rdf:langString).

<http://w3id.org/def/guia#Activity_LeccionMagistral> guide:activityDuration 180 ; # Ontology range xsd:decimal. Document says "Duración: 03:00". I'll use minutes as decimal value (assuming hours*60).
                                                       sch:name "Explicación Teórica Tema 1"@en .

