                                           dc:title "565000434 - Resistencia De Materiales"@en ;
                                         dct:publisher <http://w3id.org/def/guia#EtsIdi> ; # Center responsible
                                         guide:numberOfCredits 4.5 ;
                                         sch:courseCode 565000434 ;
                                         guide:syllabusDescription "Cálculo de tensiones y deformaciones en sólidos elásticos."@en ;
                                         guide:teachingPeriodMonths "Septiembre-Enero"@en ;
                                         guide:periodStartingMonth "Septiembre" ,
                                           guide:periodEndingMonth "Enero" .

<http://w3id.org/def/guia#56IQ> rdf:type guide:BachelorDegree ;
                                 sch:name "Grado en Ingeniería Química" ;
                                 guide:degreeCode "56IQ"@en ;
                                 dct:title "Plan de Estudios 56IQ"@en .

