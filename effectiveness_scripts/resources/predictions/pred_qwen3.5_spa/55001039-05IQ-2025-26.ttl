@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://guia-mad-bench.es/data/course-guide-anx-pr-cl-001-01> rdf:type :CourseGuide ;
    sch:name "Ingenieria Procesos Y Productos"@en ,
        "55001039 - Ingenieria Procesos y Productos"@en ;
    dct:title "ANX-PR/CL/001-01 GUÍA DE APRENDIZAJE"@es ;
    sch:description "El objetivo de la asignatura es familiarizarse con las distintas etapas necesarias para llevar a cabo el diseño de procesos y productos, de forma que el estudiante sea capaz de realizar un diseño de un proceso y/o producto partiendo de una información acotada."@en ;
    guide:courseYear 2025-26 ;
    sch:numberOfCredits "4.5"^^xsd:decimal ;
    guide:teachingPeriodMonths "Septiembre-Enero"@es ;
    guide:syllabus <http://guia-mad-bench.es/data/syllabus-anx-pr-cl-001> .

<http://guia-mad-bench.es/data/degree-grado-iq> rdf:type :BachelorDegree ;
    sch:name "Grado En Ingeniería Química"@es ;
    guide:degreeCode "05IQ"^^xsd:string ;
    guide:hasCourse <http://guia-mad-bench.es/data/course-guide-anx-pr-cl-001-01> .

<http://guia-mad-bench.es/data/lecturer-gonzalez> rdf:type :Lecturer , sch:Person ;
    sch:name "Maria Gonzalez Miquel"@es ;
    guide:sch:email <mailto:maria.gonzalezmiquel@upm.es> ;
    guide:office "Sin horario. Escribir a la profesora para concertar tutoría."^^xsd:string .

<http://guia-mad-bench.es/data/lecturer-diaz> rdf:type :Lecturer , sch:Person ;
    sch:name "Francisco Ismael Diaz Moreno"@es ;
    guide:sch:email <mailto:ismael.diaz@upm.es> ;
    guide:office "Lab Tec Quimica"^^xsd:string .

<http://guia-mad-bench.es/data/course-guide-anx-pr-cl-001-01> sch:director :lecturer-gonzalez ;
    sch:instructor :lecturer-diaz .

