    guide:learningResultDescription "Se comunica de forma oral y escrita en lengua inglesa, empleando fluidamente la terminología profesional"@es .

<http://guia-mad-bench.es/data/learning-result-RA219> rdf:type guide:LearningResult ;
    guide:learningResultCode "RA219"^^xsd:string ;
    guide:learningResultDescription "Elabora y redacta correctamente informes y resúmenes sobre contenidos de ingeniería civil en inglés"@es .

<http://guia-mad-bench.es/data/learning-result-RA36> rdf:type guide:LearningResult ;
    guide:learningResultCode "RA36"^^xsd:string ;
