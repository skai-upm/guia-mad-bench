<http://guia-mad-bench.es/data/competency-CT8> rdf:type guide:Competency ;
    guide:competencyCode "CT8"^^xsd:string ;
    guide:competencyDescription "Capacidad de comunicación técnica oral y escrita en lengua inglesa, con acreditación previa del nivel B2."@es .

