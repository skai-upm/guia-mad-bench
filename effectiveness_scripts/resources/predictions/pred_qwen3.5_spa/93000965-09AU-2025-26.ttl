    guide:office "B-316"^^xsd:string .

<http://w3id.org/def/guia#Jose_Tapia_Galisteo> a :Lecturer ;
    sch:name "Jose Tapia Galisteo"@en ;
    sch:email <mailto:jose.tapia.galisteo@upm.es> .

<http://guia-mad-bench.es/data/syllabus/ANX_PR_CL_001_01> a :Syllabus ;
    guide:hasItem <http://guia-mad-bench.es/data/syllabus-item/intro-modeling>,
                  <http://guia-mad-bench.es/data/syllabus-item/model-construction>,
                  <http://guia-mad-bench.es/data/syllabus-item/math-techniques>,
                  <http://guia-mad-bench.es/data/syllabus-item/compartmental-modeling>,
                  <http://guia-mad-bench.es/data/syllabus-item/chronobiological-modeling>,
                  <http://guia-mad-bench.es/data/syllabus-item/applications> .

<http://guia-mad-bench.es/data/syllabus-item/intro-modeling> a :SyllabusItem ;
    guide:itemIndex 1^^xsd:integer ;
    sch:description "Introduction to the modelling of physiological systems"@en .

<http://guia-mad-bench.es/data/syllabus-item/model-construction> a :SyllabusItem ;
    guide:itemIndex 2^^xsd:integer ;
    sch:description "Model construction: modelling the system, modelling from data"@en .

<http://guia-mad-bench.es/data/syllabus-item/math-techniques> a :SyllabusItem ;
    guide:itemIndex 3^^xsd:integer ;
    sch:description "Mathematical modelling techniques: Compartmental modelling, data-driven modelling, distributred models"@en .

<http://guia-mad-bench.es/data/syllabus-item/compartmental-modeling> a :SyllabusItem ;
    guide:itemIndex 4^^xsd:integer ;
    sch:description "Compartmental modelling"^^xsd:string .

<http://guia-mad-bench.es/data/syllabus-item/chronobiological-modeling> a :SyllabusItem ;
    guide:itemIndex 5^^xsd:integer ;
    sch:description "Chronobiological modelling"^^xsd:string .

<http://guia-mad-bench.es/data/syllabus-item/applications> a :SyllabusItem ;
    guide:itemIndex 6^^xsd:integer ;
    sch:description "Applications"@en .

<http://w3id.org/def/guia#CB06> a :Competency ;
    guide:competencyCode "CB06"^^xsd:string ;
    guide:competencyDescription "Poseer y comprender conocimientos que aportan una base u oportunidad de ser originales en el desarrollo y/o aplicación de ideas"@en .

<http://w3id.org/def/guia#CG-MIB11> a :Competency ;
    guide:competencyCode "CG-MIB11"^^xsd:string ;
    guide:competencyDescription "Seleccionar y aplicar métodos avanzados de modelado para el diseño y simulación de sistemas biomédicos"@en .

<http://w3id.org/def/guia#RA15> a :LearningResult ;
    guide:learningResultCode "RA15"^^xsd:string ;
    sch:description "Aplicar los fundamentos del modelado matemático de sistemas fisiológicos, siendo capaz de expresar las ecuaciones que rigen los fenómenos físicos y químicos más sencillos"@en .

<http://w3id.org/def/guia#Schedule> a :Schedule ;
