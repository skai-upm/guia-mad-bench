<http://guia-mad-bench.es/data/course-guide/anx-pr-cl-001-01> a :CourseGuide ;
    dc:title "Guía de Aprendizaje - Modelado De Sistemas Biomédicos"@en ;
    dct:creator <http://w3id.org/def/guia#Gema_Garcia_Saez>,
               <http://w3id.org/def/guia#Maria_Elena_Hernando_Perez> ;
    sch:name "Modelado De Sistemas Biomédicos"@en ;
    guide:numberOfCredits 3^^xsd:decimal ;
    dct:license <http://purl.org/NET/rdflicense/cc-by4.0> ;
    rdfs:comment "Guía de aprendizaje para el Master Universitario En Ingenieria Biomedica, Curso Académico 2025-26"@en .

<http://guia-mad-bench.es/data/course-guide/anx-pr-cl-001-01> sch:courseCode "93000965"^^xsd:string ;
    guide:syllabus <http://guia-mad-bench.es/data/syllabus/ANX_PR_CL_001_01> .

