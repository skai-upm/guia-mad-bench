data:c_cb02 a guide:Competency ;
    guide:competencyCode "CB02"^^xsd:string ;
    guide:competencyDescription "Que los estudiantes sepan aplicar sus conocimientos a su trabajo o vocación de una forma profesional y posean las competencias que suelen demostrarse por medio de la elaboración y defensa de argumentos y la resolución de problemas dentro de su área de estudio"@es .

data:c_ce17 a guide:Competency ;
    guide:competencyCode "CE17"^^xsd:string ;
    guide:competencyDescription "Conocer y gestionar los principales sistemas de producción de materias primas de origen animal"@es .

data:c_cg07 a guide:Competency ;
    guide:competencyCode "CG07"^^xsd:string ;
    guide:competencyDescription "Adquirir la formación profesional necesaria para desarrollar estrategias sostenibles de producción vegetal y animal de forma eficiente y acorde a los recursos disponibles"@es .

data:c_ct03 a guide:Competency ;
    guide:competencyCode "CT03"^^xsd:string ;
    guide:competencyDescription "Tener compromiso ético y profesional y respeto por el medio ambiente"@es .

data:r_ra318 a guide:LearningResult ;
    guide:learningResultCode "RA318"^^xsd:string ;
    guide:learningResultDescription "Conocer y aplicar el análisis de la estructura de costes a la explotación del ganado vacuno, ovino y caprino para identificar los principales caracteres que determinan la rentabilidad de una explotación ganadera"@es .

data:r_ra163 a guide:LearningResult ;
    guide:learningResultCode "RA163"^^xsd:string ;
    guide:learningResultDescription "Aplicar el análisis de la estructura de costes a las explotaciones de monogástricos e identificar los principales factores que determinan su rentabilidad"@es .

data:r_ra171 a guide:LearningResult ;
    guide:learningResultCode "RA171"^^xsd:string ;
    guide:learningResultDescription "Aplicar el análisis de la estructura de costes a las explotaciones de rumiantes e identificar los principales factores que determinan la rentabilidad de una explotación ganadera"@es .

data:r_ra336 a guide:LearningResult ;
    guide:learningResultCode "RA336"^^xsd:string ;
    guide:learningResultDescription "Aplicar programas de gestión de explotaciones ganaderas y evaluar los resultados según distintos criterios"@es .

