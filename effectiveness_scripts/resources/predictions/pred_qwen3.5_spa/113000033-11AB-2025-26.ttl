<http://guia-mad-bench.es/data/course-guide-ANXPRCL001> rdf:type guide:CourseGuide ;
    dc:title "Redaccion Técnica De Inglés Aplicada A La Actividad Fisica Y El Deporte"@en ;
    sch:name "113000033 - Redaccion Técnica De Inglés Aplicada a la Actividad Física y el Deporte" ;
    guide:numberOfCredits 3^^xsd:decimal ;
    guide:courseYear 2025^^xsd:integer ;
    guide:syllabusDescription "This module supports students whose first language is not English over a semester of academic study, and helps them to refine their writing through extensive language input, practice and feedback. The syllabus focuses on issues such as coping with organisation and coherence in the text and with range and accuracy of the language used."@en ;
    guide:hasCourse <http://guia-mad-bench.es/data/course-ANXPRCL001> ;
    sch:director <http://guia-mad-bench.es/data/lecturer-MariaJoseGomezOrtiz> .

<http://guia-mad-bench.es/data/course-guide-ANXPRCL001> guide:syllabusDescription "Structure of a Research Article. Introduction Section and main linguistic characteristics."@en ;
    <http://w3id.org/def/guia#hasSyllabus> <http://guia-mad-bench.es/data/syllabus-ANXPRCL001> .

<http://guia-mad-bench.es/data/course-guide-ANXPRCL001> guide:teachingPeriod "2025/26 - Primer semestre"@en ;
