<http://guia-mad-bench.es/data/course-instance-Master11AB-2025> rdf:type guide:CourseGuide ;
    sch:name "Master Universitario En Ciencias De La Actividad Fisica Y Del Deporte" ;
    <https://schema.org/numberOfCredits> 3^^xsd:decimal .

<http://guia-mad-bench.es/data/lr-Ra94> rdf:type guide:LearningResult ;
    guide:learningResultCode "RA94"@en ;
    guide:learningResultDescription "Mejorar la calidad de la escritura técnica en inglés beneficiándose de herramientas digitales y sus sugerencias en tiempo real sobre corrección de spelling, grammar and punctuation."@en .

<http://guia-mad-bench.es/data/lr-Ra91> rdf:type guide:LearningResult ;
    guide:learningResultCode "RA91"@en ;
    guide:learningResultDescription "Write a Research Article in English"^^xsd:string .

<http://guia-mad-bench.es/data/lr-RA19> rdf:type guide:LearningResult ;
    guide:learningResultCode "RA19"@en ;
    guide:learningResultDescription "El objetivo principal del curso es dotar al estudiante de las herramientas y estrategias necesarias para afrontar de forma autónoma y satisfactoria la redacción de artículos de investigación en inglés."@es .

<http://guia-mad-bench.es/data/lr-Ra95> rdf:type guide:LearningResult ;
    guide:learningResultCode "RA95"@en ;
    guide:learningResultDescription "Expandir el vocabulario académico y la terminología específica en inglés de las ciencias de la actividad física y el deporte."@es .

<http://guia-mad-bench.es/data/cb-CB10> rdf:type guide:Competency ;
    guide:competencyCode "CB10"@en ;
    guide:competencyDescription "Que los estudiantes posean las habilidades de aprendizaje que les permitan continuar estudiando de un modo que habrá de ser en gran medida autodirigido o autónomo"^^xsd:string .

<http://guia-mad-bench.es/data/cg-CG5> rdf:type guide:Competency ;
    guide:competencyCode "CG5"@en ;
    guide:competencyDescription "Desarrollo de la habilidades humanas necesarias para el trabajo en equipo y de ese modo asumir el compromiso de la investigación científica con valores humanos que favorezcan la sana convivencia."^^xsd:string .

<http://guia-mad-bench.es/data/cg-CG6> rdf:type guide:Competency ;
    guide:competencyCode "CG6"@en ;
    guide:competencyDescription "Capacidad para comunicarse y relacionarse en un ámbito científico en la lengua inglesa."^^xsd:string .

<http://guia-mad-bench.es/data/t-T2> rdf:type guide:Competency ;
    guide:competencyCode "T2"@en ;
    guide:competencyDescription "Capacidad para el aprendizaje autónomo y la actualización de conocimientos, y reconocimiento de su necesidad en el área de las Ciencias de la Actividad Física y del Deporte."^^xsd:string .

<http://guia-mad-bench.es/data/t-T3> rdf:type guide:Competency ;
    guide:competencyCode "T3"@en ;
    guide:competencyDescription "Capacidad para trabajar dentro de un equipo, organizado, planificado, tomando decisiones, negociando y resolviendo conflictos, relacionándose y criticando y haciendo autocrítica."^^xsd:string .

<http://guia-mad-bench.es/data/t-T6> rdf:type guide:Competency ;
    guide:competencyCode "T6"@en ;
    guide:competencyDescription "Capacidad para usar las tecnologías de la información y la comunicación"^^xsd:string .

