<http://guia-mad-bench.es/data/courseguide/anx-pr-cl-001-01> a guide:CourseGuide ;
    sch:name "Electronica De Comunicaciones I"@en ;
    dc:title "595024328 - Electronica De Comunicaciones I"@es ;
    dct:creator <http://guia-mad-bench.es/data/lecturer/fco-javier-ortega> ,
             <http://guia-mad-bench.es/data/lecturer/jose-manuel-pardo> ,
             <http://guia-mad-bench.es/data/lecturer/jose-luis-jimenez> ;
    guide:teachingPeriod "2025-26"@en ;
    sch:description "El propósito que anima a esta asignatura es el de servir de introducción al alumno en el mundo de la generación de señales de alta frecuencia y elevada estabilidad. Se estudiará en detalle el análisis y diseño de diferentes circuitos osciladores..."@es ;
    guide:numberOfCredits 6^^xsd:decimal ;
    sch:courseCode "595024328"^^xsd:string .

<http://guia-mad-bench.es/data/course/anx-pr-cl-001> a guide:Course ;
