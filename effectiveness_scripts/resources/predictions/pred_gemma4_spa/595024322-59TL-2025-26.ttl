# Competency Instances (Samples)
:Comp_CE_B1 rdf:type guide:Competency ;
    guide:competencyCode "CE B1" ;
    guide:competencyDescription "Capacidad para la resolución de los problemas matemáticos que puedan plantearse en la ingeniería." .

:Comp_CE_EC05 rdf:type guide:Competency ;
    guide:competencyCode "CE EC05" ;
    guide:competencyDescription "Capacidad de diseñar circuitos de electrónica analógica y digital, de conversión analógico-digital y digital-analógica, de radiofrecuencia, de alimentación y conversión de energía eléctrica para aplicaciones de telecomunicación y computación." .

# Learning Result Instance
:LR_RA232 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA232" ;
    guide:learningResultDescription "Se concretarán para cada asignatura optativa o para la realización de prácticas en empresas." .

# Syllabus and Items
:Syllabus_ElectronicaAnalogica rdf:type guide:Sylabus ;
    guide:hasItem :SyllabusItem_Intro, :SyllabusItem_Polarizacion, :SyllabusItem_Modelos, :SyllabusItem_Amplificadores, :SyllabusItem_Frecuencia .

:SyllabusItem_Intro rdf:type guide:SyllabusItem ;
    guide:itemIndex 1 ;
    guide:syllabusDescription "Introducción a los componentes electrónicos (Resistores, Condensadores, Inductores, Semiconductores, Unión PN)." .

# Evaluation System and Trials
:EvalSystem_ElectronicaAnalogica rdf:type guide:EvaluationSystem ;
    guide:evaluationDescription "La nota final será N=(0.85*Nota Teoría)+(0.15*Nota de Laboratorio), y deberá ser mayor o igual a 5 puntos." ;
    guide:hasEvaluationTrial :Trial_Examen_Parcial_1_2, :Trial_Praticas .

:Trial_Examen_Parcial_1_2 rdf:type guide:EvaluationTrial ;
    guide:evaluationType "Examen Escrito" ;
    guide:gradePercentage "25%" ;
    guide:minimumScore "4 / 10" ;
    guide:trialWeek "3" ;
    guide:trialMode "Presencial" .

:Trial_Praticas rdf:type guide:EvaluationTrial ;
    guide:evaluationType "Presentación Individual" ;
    guide:gradePercentage "100%" ;
    guide:minimumScore "5 / 10" ;
    guide:trialWeek "11" ;
    guide:trialMode "Presencial" .

