    guide:hasCompetency :Comp_CE_B1, :Comp_CE_B2, :Comp_CE_B4, :Comp_CE_EC04, :Comp_CE_EC05, :Comp_CE_EC08, :Comp_CE_SC03, :Comp_CG_02, :Comp_CG_04, :Comp_CG_11 ;
