    guide:hasCompetency guide:Competency_MUCTN_CT08, guide:Competency_MUII_A, guide:Competency_MUII_E, guide:Competency_MUII_H, guide:Competency_MUII_J, guide:Competency_MUII_CB07, guide:Competency_MUII_CB08, guide:Competency_MUII_CB10, guide:Competency_MUII_CE21, guide:Competency_MUII_CG01, guide:Competency_MUII_CG08, guide:Competency_MUII_CG09, guide:Competency_MUII_CG11 ;
