# Competencies
guide:Competency_MUCTN_CT08
    rdf:type guide:Competency ;
    guide:competencyCode "MUCTN.CT08" ;
    guide:competencyDescription "Entiende los impactos. Educación amplia necesaria para entender el impacto de las<0xC2> soluciones ingenieriles en un contexto social global" .

guide:Competency_MUII_A
    rdf:type guide:Competency ;
    guide:competencyCode "MUII. (a)" ;
    guide:competencyDescription "APLICA. Habilidad para aplicar conocimientos científicos, matemáticos y tecnológicos en sistemas relacionados con la práctica de la ingeniería." .

guide:Competency_MUII_E
    rdf:type guide:Competency ;
    guide:competencyCode "MUII. (e)" ;
    guide:competencyDescription "RESUELVE. Habilidad para identificar, formular y resolver problemas de ingeniería." .

guide:Competency_MUII_H
    rdf:type guide:Competency ;
    guide:competencyCode "MUII. (h)" ;
    guide:competencyDescription "ENTIENDE LOS IMPACTOS. Educación amplia necesaria para entender el impacto de las soluciones ingenieriles en un contexto social global." .

guide:Competency_MUII_J
    rdf:type guide:Competency ;
    guide:competencyCode "MUII. (j)" ;
    guide:competencyDescription "CONOCE. Conocimiento de los temas contemporáneos." .

guide:Competency_MUII_CB07
    rdf:type guide:Competency ;
    guide:competencyCode "MUII.CB07" ;
    guide:competencyDescription "Que los estudiantes sepan aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en entornos nuevos o poco conocidos dentro de contextos más amplios" .

guide:Competency_MUII_CB08
    rdf:type guide:Competency ;
    guide:competencyCode "MUII.CB08" ;
    guide:competencyDescription "Que los estudiantes sean capaces de integrar conocimientos y enfrentarse a la complejidad de formular juicios..." .

guide:Competency_MUII_CB10
    rdf:type guide:Competency ;
    guide:competencyCode "MUII.CB10" ;
    guide:competencyDescription "Que los estudiantes posean las habilidades de aprendizaje que les permitan continuar estudiando de un modo que habrá de ser en gran medida autodirigido o autónomo." .

guide:Competency_MUII_CE21
    rdf:type guide:Competency ;
    guide:competencyCode "MUII.CE21" ;
    guide:competencyDescription "Conocimientos sobre métodos y técnicas del transporte y manutención industrial." .

guide:Competency_MUII_CG01
    rdf:type guide:Competency ;
    guide:competencyCode "MUII.CG01" ;
    guide:competencyDescription "Tener conocimientos adecuados de los aspectos científicos y tecnológicos de: métodos matemáticos, analíticos y numéricos..." .

guide:Competency_MUII_CG08
    rdf:type guide:Competency ;
    guide:competencyCode "MUII.CG08" ;
    guide:competencyDescription "Aplicar los conocimientos adquiridos y resolver problemas en entornos nuevos o poco conocidos dentro de contextos más amplios y multidisciplinares." .

guide:Competency_MUII_CG09
    rdf:type guide:Competency ;
    guide:competencyCode "MUII.CG09" ;
    guide:competencyDescription "Ser capaz de integrar conocimientos y enfrentarse a la complejidad de formular juicios..." .

guide:Competency_MUII_CG11
    rdf:type guide:Competency ;
    guide:competencyCode "MUII.CG11" ;
    guide:competencyDescription "Poseer las habilidades de aprendizaje que permitan continuar estudiando de un modo autodirigido o autónomo." .

# Learning Results
guide:LearningResult_RA75
    rdf:type guide:LearningResult ;
    guide:learningResultCode "RA75" ;
    guide:learningResultDescription "Identificar, analizar, e interpretar los datos del problema planteado por el profesor" .

guide:LearningResult_RA78
    rdf:type guide:LearningResult ;
    guide:learningResultCode "RA78" ;
    guide:learningResultDescription "Comprender los sistemas y principios que definen el transporte interior en plantas de fabricación" .

guide:Learning_RA54
    rdf:type guide:LearningResult ;
    guide:learningResultCode "RA54" ;
    guide:learningResultDescription "Conocer y comprender la naturaleza del fenómeno del transporte" .

guide:Learning_RA71
    rdf:type guide:LearningResult ;
    guide:learningResultCode "RA71" ;
    guide:learningResultDescription "Conocer y saber aplicar los modelos de demanda de transporte" .

guide:Learning_RA77
    rdf:type guide:LearningResult ;
    guide:learningResultCode "RA77" ;
    guide:learningResultDescription "Ejecutar el procedimiento previsto. Valoración y validación del resultado obtenido" .

guide:Learning_RA80
    rdf:type guide:LearningResult ;
    guide:learningResultCode "RA80" ;
    guide:learningResultDescription "Conocer los conceptos relacionados con el transporte y sus modos" .

guide:Learning_RA76
    rdf:type guide:LearningResult ;
    guide:learningResultCode "RA76" ;
    guide:learningResultDescription "Valoración y validación del resultado obtenido" .

guide:Learning_RA81
    rdf:type guide:LearningResult ;
    guide:learningResultCode "RA81" ;
    guide:learningResultDescription "Conocer los impactos del transporte en cuanto a seguridad e impacto medioambiental" .

guide:Learning_RA73
    rdf:type guide:LearningResult ;
    guide:learningResultCode "RA73" ;
    guide:learningResultDescription "Conocer las distintas tecnologías de seguridad de los vehículos automóviles" .

guide:Learning_RA70
    rdf:type guide:LearningResult ;
    guide:learningResultCode "RA70" ;
    guide:learningResultDescription "Conocer y saber aplicar los modelos de flujo de tráfico" .

guide:Learning_RA74
    rdf:type guide:LearningResult ;
    guide:learningResultCode "RA74" ;
    guide:learningResultDescription "Organiza la información" .

guide:Learning_RA79
    rdf:type guide:LearningResult ;
    guide:learningResultCode "RA79" ;
    guide:learningResultDescription "Conocer los equipos destinados a los procesos de manutención y transporte" .

guide:Learning_RA72
    rdf:type guide:LearningResult ;
    guide:learningResultCode "RA72" ;
    guide:learningResultDescription "Plantear un procedimiento/método de resolución" .

