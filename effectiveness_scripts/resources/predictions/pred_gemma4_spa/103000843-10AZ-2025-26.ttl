    guide:hasSyllabus :Syllabus_103000843 ;
    guide:hasCompetency :Comp_CB07, :Comp_CB08, :Comp_CB09, :Comp_CEEIT03, :Comp_CG01, :Comp_CG03, :Comp_CG07, :Comp_CG08, :Comp_CG09 ;
