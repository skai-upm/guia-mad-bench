# Competencies
:competency_imce03 a guide:Competency ;
    guide:competencyCode "IM.CE 03" ;
    guide:competencyDescription "Conocimientos básicos sobre el uso y programación de los ordenadores, sistemas operativos, bases de datos y programas informáticos con aplicación en ingeniería." .

:competency_imcg02 a guide:Competency ;
    guide:competencyCode "IM.CG 02" ;
    guide:competencyDescription "Poseer la capacidad para diseñar, desarrollar, implementar, gestionar y mejorar productos, sistemas y procesos en los de distintos ámbitos industriales..." .

:competency_imcg03 a guide:Competency ;
    guide:competencyCode "IM.CG 03" ;
    guide:competencyDescription "Aplicar los conocimientos adquiridos para identificar, formular y resolver problemas en contextos amplios..." .

:competency_imcg06 a guide:Competency ;
    guide:competencyCode "IM.CG 06" ;
    guide:competencyDescription "Poseer las habilidades de aprendizaje que permitan continuar estudiando a lo largo de toda la vida..." .

:competency_imcg07 a guide:Competency ;
    guide:competencyCode "IM.CG 07" ;
    guide:competencyDescription "Incorporar las TIC y las tecnologías y herramientas de la Ingeniería Industrial en sus actividades profesionales." .

:competency_imcg10 a guide:Competency ;
    guide:competencyCode "IM.CG 10" ;
    guide:competencyDescription "Creatividad." .

# Learning Results
:learning_result_ra142 a guide:LearningResult ;
    guide:learningResultCode "RA142" ;
    guide:learningResultDescription "Conocimientos y capacidades de pensamiento y razonloamiento necesarios para el análisis, enfoque y resolución de problemas concretos." .

:learning_result_ra151 a guide:LearningResult ;
    guide:learningResultCode "RA151" ;
    guide:learningResultDescription "Capacidad para diseñar y programar algoritmos modularles en lenguaje C que resuelven problemas relacionados con la ingeniería." .

:learning_result_ra152 a guide:LearningResult ;
    guide:learningResultCode "RA152" ;
    guide:learningResultDescription "Implementar ejemplos y ejercicios de variada índole... que permitan ilustrar los conceptos de eficiencia y robustez..." .

:learning_result_ra21 a guide:LearningResult ;
    guide:learningResultCode "RA21" ;
    guide:learningResultDescription "Actitudes de razonamiento crítico y actuaciones creativas basadas en situaciones abiertas" .

:learning_result_ra116 a guide:LearningResult ;
    guide:learningResultCode "RA116" ;
    guide:learningResultDescription "PROGRAMACION" .

:learning_result_ra143 a guide:LearningResult ;
    guide:learningResultCode "RA143" ;
    guide:learningResultDescription "Saber aplicar el método científico y el lenguaje científicotecnológico a la resolución de problemas concretos de la Ingeniería." .

:learning_result_ra18 a guide:LearningResult ;
    guide:learningResultCode "RA18" ;
    guide:learningResultDescription "Conocimientos y capacidades para entender las ideas principales de textos complejos de carácter general y de especialidad" .

# Syllabus
:syllabus_informatica a guide:Syllabus ;
    guide:hasItem :item_intro, :item_lenguaje_c, :item_elementos_c, :item_sentencias_control, :item_funciones, :item_punteros, :item_datos_avanzados, :item_ficheros .

:item_intro a guide:SyllabusItem ;
    guide:itemIndex 1 ;
    guide:syllabusDescription "Introducción. 1.1. Estructura funcional de un ordenador. 1.2. Representación de la información. 1.3. Lenguajes de programación." .

:item_lenguaje_c a guide:SyllabusItem ;
    guide:itemIndex 2 ;
    guide:syllabusDescription "El lenguaje C. 2.1. Programas básicos. 2.2. Estructura de un código en C. 2.3. Normas básicas y estilo. 2.4. El entorno de programación." .

# Evaluation System and Trials
:evaluation_system_progresiva a guide:EvaluationSystem ;
    guide:evaluationDescription "Modalidad de evaluación por defecto será la Progresiva, con tres pruebas de evaluación." ;
    guide:hasEvaluationTrial :trial_sem8, :trial_sem12, :trial_sem15 .

:trial_sem8 a guide:EvaluationTrial ;
    guide:evaluationType "Examen de Prácticas" ;
    guide:trialMode "Presencial" ;
    guide:gradePercentage "30%" ;
    guide:minimumScore "/ 10" ;
    guide:evaluationDuration "02:00" ;
    guide:involvesCompetency :competency_imcg10, :competency_imce03, :competency_imcg03 .

:trial_sem12 a guide:EvaluationTrial ;
    guide:evaluationType "Examen de Prácticas" ;
    guide:trialMode "Presencial" ;
    guide:gradePercentage "30%" ;
    guide:minimumScore "/ 10" ;
    guide:evaluationDuration "02:00" ;
    guide:involvesCompetency :competency_imcg02, :competency_imce03, :competency_imcg03, :competency_imcg10 .

:trial_sem15 a guide:EvaluationTrial ;
    guide:evaluationType "Examen de Prácticas" ;
    guide:trialMode "Presencial" ;
    guide:gradePercentage "40%" ;
    guide:minimumScore "/ 10" ;
    guide:evaluationDuration "02:00" ;
    guide:involvesCompetency :competency_imce03, :competency_imcg06, :competency_imcg07, :competency_imcg03, :competency_imcg10 .

