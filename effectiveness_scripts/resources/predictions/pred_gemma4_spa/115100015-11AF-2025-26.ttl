# Course Instance / Guide
data:CourseGuide_115100015 a guide:CourseGuide ;
    sch:name "Guía de Aprendizaje - Biomecánica de la Afyd" ;
    sch:description "Aplica las leyes de la mecánica a los movimientos del cuerpo humano teniendo en cuenta sus características anatómicas y biológicas" ;
    guide:teachingPeriod "2025-26" ;
    guide:teachingPeriodMonths "Febrero-Junio" ;
    guide:numberOfCredits 6.0 ;
    guide:inpersonHours "No especificado" ;
    guide:remoteHours "No especificado" ;
    sch:instructor data:EnriqueNavarroCabello ;
    sch:director data:EnriqueNavarroCabello ;
    guide:hasSyllabus data:Syllabus_115100015 ;
    guide:hasEvaluation data:EvalSystem_115100015 ;
    guide:hasCompetency data:CE08, data:CE09 ;
    guide:hasLearningResult data:RA9, data:RA84, data:RA14, data:RA189 ;
    guide:hasDidacticResource data:Res_LabBiomecanica, data:Res_Moodle, data:Res_Barlett1997, data:Res_Barlett1999, data:Res_Beer1992a, data:Res_Beer1992b, data:Res_Cavanagh1990, data:Res_Gutierrez1998, data:Res_Hamill1995, data:Res_Hochmuth1973, data:Res_Kapandji1990, data:Res_Kreighbaum1996, data:Res_Leva1996, data:Res_McGinnis1999, data:Res_Ozkaya1999, data:Res_Perry1992, data:Res_Plas1996, data:Res_Prat1992 ;
    sch:courseSchedule data:Schedule_115100015 .

