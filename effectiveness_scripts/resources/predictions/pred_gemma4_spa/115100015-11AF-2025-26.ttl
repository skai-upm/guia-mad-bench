# Competencies
data:CE08 a guide:Competency ;
    guide:competencyCode "CE08" ;
    guide:competencyDescription "Aplicar de manera fundamentada y argumentada los principios fisiológicos, biomecánicos, comportamentales y sociales, durante la dirección del entrenamiento deportivo. Nivel 3." .

data:CE09 a guide:Competency ;
    guide:competencyCode "CE09" ;
    guide:competencyDescription "Identificar y prevenir los riesgos que se derivan para la salud de los deportistas por la práctica de actividades físicas inadecuadas, en el contexto del entrenamiento deportivo. Nivel 2." .

# Learning Results
data:RA9 a guide:LearningResult ;
    guide:learningResultCode "RA9" ;
    guide:learningResultDescription "Capacidad de trabajar en equipo" .

data:RA84 a guide:LearningResult ;
    guide:learningResultCode "RA84" ;
    guide:learningResultDescription "Seleccionar y utilizar el material y el equipamiento deportivo adecuado en cada caso" .

data:RA14 a guide:LearningResult ;
    guide:learningResultCode "RA14" ;
    guide:learningResultDescription "Saber aplicar los principios del entrenamiento y así como los fundamentos fisiológicos y biomecánicos a los programas de entrenamiento" .

data:RA189 a guide:LearningResult ;
    guide:learningResultCode "RA189" ;
    guide:learningResultDescription "Saber realizar el análisis mecánico de cualquier ejercicio físico, entendiendo las características articulares y musculares de cualquier movimiento humano." .

