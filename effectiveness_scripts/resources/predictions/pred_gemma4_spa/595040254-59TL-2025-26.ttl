_:comp_ce_tel03 a guide:Competency ;
    guide:competencyCode "CE TEL03" ;
    guide:competencyDescription "Capacidad para utilizar herramientas informáticas de búsqueda de recursos bibliográficos o de información relacionada con las telecomunicaciones y la electrónica." .

_:comp_ce_tel16 a guide:Competency ;
    guide:competencyCode "CE TEL16" ;
    guide:competencyDescription "Conocimiento de la normativa y la regulación de las telecomunicaciones en los ámbitos nacional, europeo e internacional." .

_:comp_cg02 a guide:Competency ;
    guide:competencyCode "CG 02" ;
    guide:competencyDescription "Capacidad de búsqueda y selección de información, de razonamiento crítico y de elaboración y defensa de argumentos dentro del área." .

_:comp_cg05 a guide:Competency ;
    guide:competencyCode "CG 05" ;
    guide:competencyDescription "Capacidad de trabajo en equipo y en entornos multidisciplinares." .

_:comp_cg09 a guide:Competency ;
    guide:competencyCode "CG 09" ;
    guide:competencyDescription "Capacidad de analizar y valorar el impacto social y medioambiental de las soluciones técnicas." .

_:lr_ra232 a guide:LearningResult ;
    guide:learningResultCode "RA232" ;
    guide:learningResultDescription "Se concretarán para cada asignatura optativa o para la realización de prácticas en empresas." .

_:syllabus a guide:Syllabus ;
    guide:hasItem _:item1, _:item2, _:item3, _:item4, _:item5, _:item6, _:item7 .

_:item1 a guide:SyllabusItem ;
    guide:itemIndex 1 ;
    guide:syllabusDescription "Sociedad de la Información, sociedad del ruido y brecha digital" .

_:item2 a guide:SyllabusItem ;
    guide:itemIndex 2 ;
    guide:syllabusDescription "TIC emergentes y retos sociales" .

_:item3 a guide:SyllabusItem ;
