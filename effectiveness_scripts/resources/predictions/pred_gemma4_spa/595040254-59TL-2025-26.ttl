    guide:hasCompetency _:comp_ce_tel03, _:comp_ce_tel16, _:comp_cg02, _:comp_cg05, _:comp_cg09 ;
    guide:hasLearningResult _:lr_ra232 ;
    guide:hasEvaluation _:evalSystem ;
    guide:hasDidacticResource _:res_book1, _:res_web1, _:res_web2 ;
    sch:instructor _:prof_aurelio, _:prof_miguel ;
    sch:description "En esta asignatura se profundizará en los conceptos y herramientas estudiadas en CIENCIA, TECNOLOGÍA y SOCIEDAD sobre un temario amplio y concreto de temas de actualidad en las TIC." .

