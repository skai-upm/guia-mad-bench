# Course Guide
guide:CourseGuide_105000015 a guide:CourseGuide ;
    sch:name "Guía de Aprendizaje - Programación II" ;
    sch:description "Introducción a la programación orientada a objetos (POO). Su objetivo principal es presentar a los estudiantes los principios de la resolución de problemas en el paradigma POO y el estudio de los modelos de datos básicos en que se basa." ;
    guide:teachingPeriod "2025-26" ;
    guide:periodStartingMonth "Febrero" ;
    guide:periodEndingMonth "Junio" ;
    sch:inLanguage "Inglés/Castellano" ;
    guide:numberOfCredits 6.0 ;
    guide:totalHours "150" ; # Calculated based on ECTS (approx 25h per credit)
    guide:hasCourse guide:Course_105000015 ;
    guide:hasSyllabus guide:Syllabus_ProgII ;
    guide:hasEvaluation guide:EvalSystem_ProgII ;
    guide:hasCompetency guide:Comp_CG1, guide:Comp_CG2, guide:Comp_Ce3, guide:Comp_Ce6, guide:Comp_Ce8, guide:Comp_Ce9 ;
    guide:hasLearningResult guide:LR_RA288, guide:LR_RA2_287, guide:LR_RA2_290, guide:LR_RA2_289 ;
    guide:hasDidacticResource guide:Res_Moodle, guide:Res_JavaManual, guide:Res_JavaNotes ;
    sch:instructor guide:Lecturer_SantiagoTapia, guide:Lecturer_JavierGalve .

