# Syllabus
guide:Syllabus_CS rdf:type guide:Syllabus ;
    guide:hasItem guide:SI_1, guide:SI_2, guide:SI_3 .

guide:SI_1 rdf:type guide:SyllabusItem ;
    guide:itemIndex 1 ;
    guide:syllabusDescription "Introduction to Security" .

guide:SI_2 rdf:type guide:SyllabusItem ;
    guide:itemIndex 2 ;
    guide:syllabusDescription "Network and web security" .

guide:SI_3 rdf:type guide:SyllabusItem ;
    guide:itemIndex 3 ;
    guide:syllabusDescription "Software security" .

# Competencies
guide:Comp_CG1 rdf:type guide:Competency ;
    guide:competencyCode "CG1" ;
    guide:competencyDescription "Que los estudiantes sepan aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en entornos nuevos o poco conocidos dentro de contextos más amplios (o multidisciplinares) relacionados con su área de estudio." .

guide:Comp_CG13 rdf:type guide:Competency ;
    guide:competencyCode "CG13" ;
    guide:competencyDescription "Apreciación de los límites del conocimiento actual y de la aplicación práctica de la<0xC2>encia más reciente." .

guide:Comp_CG4 rdf:type guide:Competency ;
    guide:competencyCode "CG4" ;
    guide:competencyDescription "Que los estudiantes posean las habilidades de aprendizaje que les permitan continuar estudiando de un modo que habrá de ser en gran medida autodirigido o autónomo." .

guide:Comp_CG8 rdf:type guide:Competency ;
    guide:competencyCode "CG8" ;
    guide:competencyDescription "Planteamiento y resolución de problemas también en áreas nuevas y emergentes de su disciplina" .

guide:Comp_CG9 rdf:type guide:Competency ;
    guide:competencyCode "CG9" ;
    guide:competencyDescription "Aplicación de los métodos de resolución de problemas más recientes o innovadores y que puedan implicar el uso de otras disciplinas" .

guide:Comp_CGI20 rdf:type guide:Competency ;
    guide:competencyCode "CGI20" ;
    guide:competencyDescription "Adquirir conocimientos científicos avanzados del campo de la informática que le permitan generar nuevas ideas dentro de una línea de investigación." .

guide:Comp_CGI23 rdf:type guide:Competency ;
    guide:competencyCode "CGI23" ;
    guide:competencyDescription "Capacidad de leer y comprender publicaciones dentro de su ámbito de estudio/investigación, así como su catalogación y valor científico" .

# Learning Results
guide:LR_RA12 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA12" ;
    guide:learningResultDescription "Be familiar with examples of real applications and research trends and lines" .

guide:LR_RA112 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA112" ;
    guide:learningResultDescription "Identify computer security threats and decide the best proactive and reactive measures against them" .

# Evaluation System
guide:EvalSystem_CS rdf:type guide:EvaluationSystem ;
    guide:evaluationDescription "The evaluation will be based on two exams: mid-term and final." ;
    guide:hasEvaluationTrial guide:Trial_Midterm, guide:Trial_Global .

guide:Trial_Midterm rdf:type guide:EvaluationTrial ;
    guide:trialType "Written test" ;
    guide:evaluationType "Progressive assessment" ;
    guide:gradePercentage "50%" ;
    guide:minimumScore "2 / 10" ;
    guide:eventWeek "9" ;
    guide:trialMode "Presential" .

guide:Trial_Global rdf:type guide:EvaluationTrial ;
    guide:trialType "Written test" ;
    guide:evaluationType "Global examination" ;
    guide:gradePercentage "100%" ;
    guide:minimumScore "5 / 10" ;
    guide:eventWeek "17" ;
    guide:trialMode "Presential" .

