    guide:gradePercentage "25%" ;
    guide:minimumScore "3 / 10" ;
    guide:trialMode "Presencial" ;
    guide:involvesCompetency :comp_CG_02, :comp_CG_03, :comp_CG_05, :comp_CE_TEL16, :comp_CG_06, :comp_CG_09, :comp_CG_11, :comp_CG_14 .

:trial_examen_final a guide:EvaluationTrial ;
    guide:trialType "Examen Escrito" ;
