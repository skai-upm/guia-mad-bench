# Competencies
:comp_ce1 rdf:type guide:Competency ;
    guide:competencyCode "CE1" ;
    guide:competencyDescription "Capacidad para la resolución de los problemas matemáticos que puedan plantearse en la ingeniería. Aptitud para aplicar los conocimientos sobre: álgebra lineal; geometría; geometría diferencial; cálculo diferencial e integral; ecuaciones diferenciales ordinarias y en derivadas parciales; métodos numéricos; algorítmica numérica; optimización" .

:comp_cg1 rdf:type guide:Competency ;
    guide:competencyCode "CG1" ;
    guide:competencyDescription "Conocer y aplicar conocimientos de ciencias y tecnologías básicas a la práctica de la Ingeniería Industrial." .

:comp_cg10 rdf:type guide:Competency ;
    guide:competencyCode "CG10" ;
    guide:competencyDescription "Capacidad para generar nuevas ideas (Creatividad)." .

:comp_cg2 rdf:type guide:Competency ;
    guide:competencyCode "CG2" ;
    guide:competencyDescription "Poseer capacidad para diseñar, desarrollar, implementar, gestionar y mejorar productos, sistemas y procesos en los distintos ámbitos industriales, usando técnicas analíticas, computacionales o experimentales apropiadas." .

:comp_cg3 rdf:type guide:Competency ;
    guide:competencyCode "CG3" ;
    guide:competencyDescription "Aplicar los conocimientos adquiridos para identificar, formular y resolver problemas dentro de contextos amplios y multidisciplinarios, siendo capaces de integrar conocimientos, trabajando en equipos multidisciplinares." .

:comp_cg6 rdf:type guide:Competency ;
    guide:competencyCode "CG6" ;
    guide:competencyDescription "Poseer habilidades de aprendizaje que permitan continuar estudiando a lo largo de la vida para su adecuado desarrollo profesional." .

# Learning Results
:lr_ra242 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA242" ;
    guide:learningResultDescription "Capacidad de abstracción y reconocimiento de conceptos generales en situaciones prácticas." .

:lr_ra243 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA243" ;
    guide:learningResultDescription "Capacidad para formular y analizar modelos de procesos naturales. Capacidad de interpretar los resultados obtenidos y evaluar los modelos utilizados." .

:lr_ra244 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA244" ;
    guide:learningResultDescription "Habilidad para aplicación de métodos analíticos a la resolución de problemas técnicos conocidos que han aparecido en otras materias." .

:lr_ra232 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA232" ;
    guide:learningResultDescription "Proporciona un abanico muy diverso de herramientas para abordar el tratamiento de modelos de procesos naturales." .

:lr_ra245 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA245" ;
    guide:learningResultDescription "Proporciona una panorámica muy amplia de modelos clásicos aplicados en muy diversos campos: mecánica, ecología teórica, economía, epidemiología, etc." .

# Syllabus
:syllabus_ecuaciones_diferenciales rdf:type guide:Syllabus ;
    guide:hasItem :item_tema1, :item_tema2, :item_tema3, :item_tema4, :item_tema5 .

:item_tema1 rdf:type guide:SyllabusItem ;
    guide:syllabusDescription "Ecuaciones diferenciales ordinarias de primer orden. Modelización matemática en problemas de ingeniería y medio ambiente; E.D.O. de variables separables, homogéneas, exactas, lineales de primer orden, Bernoulli, métodos numéricos." .

:item_tema2 rdf:type guide:SyllabusItem ;
    guide:syllabusDescription "Sistemas de ecuaciones diferencial lineales de primer orden. Modelización matemática; Sistemas E.D.O. lineales y coeficientes constantes; Matriz diagonalizable; Espacios de fases." .

:item_tema3 rdf:type guide:SyllabusItem ;
    guide:syllabusDescription "Ecuaciones diferenciales lineales de orden n. Modelización matemática; E.D.O. lineales con coeficientes constantes y variables; Reducción del orden; Ecuaciones de Euler." .

:item_tema4 rdf:type guide:SyllabusItem ;
    guide:syllabusDescription "Ecuaciones en derivadas parciales de primer orden. Modelización matemática; E.P.D. cuasilineal; Curvas características; Ondas de choque y condición de Rankine-Hugoniot; Resolución numérica." .

:item_tema5 rdf:type guide:SyllabusItem ;
    guide:syllabusDescription "Introducción a las ecuaciones en derivadas parciales de segundo orden. Modelización matemática (calor, Laplace, Poisson, ondas); Método de separación de variables; Series de Fourier." .

# Evaluation System
:eval_system_ecuaciones rdf:type guide:EvaluationSystem ;
    guide:evaluationDescription "La evaluación progresiva consta de dos prácticas de computación científica (10%), una primera prueba escrita (40%) y una segunda prueba escrita global (50%)." ;
    guide:hasEvaluationTrial :trial_practica_1, :trial_examen_escrito, :trial_practica_2, :trial_examen_global .

:trial_practica_1 rdf:type guide:EvaluationTrial ;
    guide:evaluationType "Examen de Prácticas" ;
    guide:gradePercentage "5%" ;
    guide:minimumScore "0 / 10" ;
    guide:trialMode "Presencial" ;
    guide:involvesCompetency :comp_ce1, :comp_cg1, :comp_cg2, :comp_cg3 .

:trial_examen_escrito rdf:type guide:EvaluationTrial ;
    guide:evaluationType "Examen Escrito" ;
    guide:gradePercentage "40%" ;
    guide:minimumScore "0 / 10" ;
    guide:trialMode "Presencial" ;
    guide:involvesCompetency :comp_ce1, :comp_cg2, :comp_cg6, :comp_cg10 .

:trial_practica_2 rdf:type guide:EvaluationTrial ;
    guide:evaluationType "Examen de Prácticas" ;
    guide:gradePercentage "5%" ;
    guide:minimumScore "0 / 10" ;
    guide:trialMode "Presencial" ;
    guide:involvesCompetency :comp_cg3, :comp_ce1, :comp_cg1, :comp_cg2 .

:trial_examen_global rdf:type guide:EvaluationTrial ;
    guide:evaluationType "Examen Escrito" ;
    guide:gradePercentage "50%" ;
    guide:minimumScore "2.5 / 10" ;
    guide:trialMode "Presencial" ;
    guide:involvesCompetency :comp_ce1, :comp_cg1, :comp_cg2, :comp_cg6, :comp_cg10 .

# Didactic Resources
:res_sanchez rdf:type guide:DidacticResource ;
    guide:bibliographyTitle "Sistemas Dinámicos. Una introducción a través de ejercicios." ;
    guide:bibliographyDescription "Libro escrito por profesores del Departamento, cuyo contenido se adapta al programa de la asignatura. Es de orientación práctica." .

:res_braun rdf:type guide:DidacticResource ;
    guide:bibliographyTitle "Ecuaciones diferenciales y sus aplicaciones" ;
    guide:bibliographyDescription "M. Braun. Grupo Editorial Iberoamericana, 1990." .

:res_nagle rdf:type guide:DidacticResource ;
    guide:bibliographyTitle "Fundamentos de ecuaciones diferenciales 2ª ed." ;
    guide:bibliographyDescription "R. K. Nagle, E. B. Saff. Addison-Wesley Iberoamericana, 1992." .

:res_haberman rdf:type guide:DidacticResource ;
    guide:bibliographyTitle "Applied partial differential equations with fourier series and boundary value problems" ;
    guide:bibliographyDescription "R. Haberman. Pearson Prentice Hall, 2004." .

# Required Knowledge
:req_knowledge_ecuaciones rdf:type guide:RequiredKnowledge ;
    guide:previousKnowledge "Técnicas del cálculo infinitesimal con funciones de varias variables reales; Conocimientos básicos de Física General; Técnicas elementales de Cálculo Infinitesimal; Técnicas elementales de Álgebra Lineal; Operaciones básicas con números complejos." ;
    guide:previousCourses "Algebra, Calculo I, Calculo II" .

