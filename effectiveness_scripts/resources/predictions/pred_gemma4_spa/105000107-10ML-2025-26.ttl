# Competencies
:Comp_C1 rdf:type guide:Competency ;
    guide:competencyCode "C1" ;
    guide:competencyDescription "Capacidad de resolución de problemas aplicando conocimientos de matemáticas, ciencias e ingeniería." .

:Comp_C10 rdf:type guide:Competency ;
    guide:competencyCode "C10" ;
    guide:competencyDescription "Capacidad para usar las tecnologías de la información y la comunicación." .

:Comp_C13 rdf:type guide:Competency ;
    guide:competencyCode "C13" ;
    guide:competencyDescription "Capacidad de elegir y usar los métodos analíticos y de modelización relevantes, y de describir una solución de forma abstracta." .

:Comp_C2 rdf:type guide:Competency ;
    guide:competencyCode "C2" ;
    guide:competencyDescription "Capacidad para el aprendizaje autónomo y la actualización de conocimientos." .

:Comp_C3 rdf:type guide:Competency ;
    guide:competencyCode "C3" ;
    guide:competencyDescription "Saber trabajar en situaciones carentes de información y bajo presión, teniendo nuevas ideas, siendo creativo." .

:Comp_C4 rdf:type guide:Competency ;
    guide:competencyCode "C4" ;
    guide:competencyDescription "Capacidad de gestión de la información." .

:Comp_C5 rdf:type guide:Competency ;
    guide:competencyCode "C5" ;
    guide:competencyDescription "Capacidad de abstracción, análisis y síntesis." .

# Learning Results
:LR_RA35 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA35" ;
    guide:learningResultDescription "Utilizar diversas técnicas para la resolución de problemas con ayuda de software matemático" .

:LR_RA19 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA19" ;
    guide:learningResultDescription "Modelizar matemáticamente problemas reales y conocer las técnicas para resolverlos" .

:LR_RA26 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA26" ;
    guide:learningResultDescription "Adquirir destreza en la aplicación de los diferentes métodos de demostración." .

:LR_RA33 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA33" ;
    guide:learningResultDescription "Comprender las nociones de complejidad de un algoritmo y de complejidad de un problema" .

:LR_RA31 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA31" ;
    guide:learningResultDescription "Conocer, comprender y aplicar los conceptos, técnicas y algoritidades básicos de la teoría de grafos" .

# Syllabus
:MatematicaDiscretaII_Syllabus rdf:type guide:Syllabus ;
    guide:hasItem :SyllabusItem_1, :SyllabusItem_2, :SyllabusItem_3, :SyllabusItem_4, :SyllabusItem_5, :SyllabusItem_6, :SyllabusItem_7 .

:SyllabusItem_1 rdf:type guide:SyllabusItem ;
    guide:itemIndex 1 ;
    guide:syllabusDescription "Nociones básicas de grafos y digrafos" .

:SyllabusItem_2 rdf:type guide:SyllabusItem ;
    guide:itemIndex 2 ;
    guide:syllabusDescription "Árboles: Búsquedas y optimización. Orientabilidad." .

:SyllabusItem_3 rdf:type guide:SyllabusItem ;
    guide:itemIndex 3 ;
    guide:syllabusDescription "Distancias y caminos mínimos. Conectividad." .

:SyllabusItem_4 rdf:type guide:SyllabusItem ;
    guide:itemIndex 4 ;
    guide:syllabusDescription "Flujos en redes. Emparejamientos. Recubrimientos." .

:SyllabusItem_5 rdf:type guide:SyllabusItem ;
    guide:itemIndex 5 ;
    guide:syllabusDescription "Recorridos en grafos" .

:SyllabusItem_6 rdf:<0xC2>type guide:SyllabusItem ;
    guide:itemIndex 6 ;
    guide:syllabusDescription "Planaridad. Coloración de grafos." .

:SyllabusItem_7 rdf:type guide:SyllabusItem ;
    guide:itemIndex 7 ;
    guide:syllabusDescription "Complejidad de algoritmos" .

# Evaluation System
:EvalSystem_MatematicaDiscretaII rdf:type guide:EvaluationSystem ;
    guide:evaluationDescription "Sistema mediante pruebas de evaluación progresiva y prueba de evaluación global." ;
    guide:hasEvaluationTrial :Trial_CuestionarioMoodle, :Trial_PrimerExamen, :Trial_Trabajo, :Trial_SegundoExamen, :Trial_ExamenFinal .

:Trial_CuestionarioMoodle rdf:type guide:EvaluationTrial ;
    guide:trialType "Prueba Telemática" ;
    guide:evaluationType "Evaluación Progresiva" ;
    guide:gradePercentage "5%" ;
    guide:minimumScore "/ 10" ;
    guide:trialMode "Presencial" .

:Trial_PrimerExamen rdf:type guide:EvaluationTrial ;
    guide:trialType "Examen Escrito" ;
    guide:evaluationType "Evaluación Progresiva" ;
    guide:gradePercentage "42.5%" ;
    guide:minimumScore "3 / 10" ;
    guide:trialMode "Presencial" .

:Trial_Trabajo rdf:type guide:EvaluationTrial ;
    guide:trialType "Otras técnicas evaluativas" ;
    guide:evaluationType "Evaluación Progresiva" ;
    guide:gradePercentage "5%" ;
    guide:minimumScore "0 / 10" ;
    guide:trialMode "No presencial" .

:Trial_SegundoExamen rdf:type guide:EvaluationTrial ;
    guide:trialType "Examen Escrito" ;
    guide:evaluationType "Evaluación Progresiva" ;
    guide:gradePercentage "42.5%" ;
    guide:minimumScore "3 / 10" ;
    guide:trialMode "Presencial" .

:Trial_ExamenFinal rdf:type guide:EvaluationTrial ;
    guide:trialType "Examen Escrito" ;
    guide:evaluationType "Evaluación Global" ;
    guide:gradePercentage "85%" ;
    guide:minimumScore "/ 10" ;
    guide:trialMode "Presencial" .

