# Competencies
:comp_CE21A rdf:type guide:Competency ;
    guide:competencyCode "CE21A" ;
    guide:competencyDescription "Conocimiento de los fundamentos y aplicaciones de la electrónica digital y microprocesadores." .

:comp_CE24A rdf:type guide:Competency ;
    guide:competencyCode "CE24A" ;
    guide:competencyDescription "Capacidad para diseñar sistemas electrónicos analógicos, digitales y de potencia." .

:comp_CG1 rdf:type guide:Competency ;
    guide:competencyCode "CG1" ;
    guide:competencyDescription "Conocer y aplicar conocimientos de ciencias y tecnologías básicas a la práctica de la Ingeniería Industrial." .

:comp_CG10 rdf:type guide:Competency ;
    guide:competencyCode "CG10" ;
    guide:competencyDescription "Capacidad para generar nuevas ideas (Creatividad)." .

:comp_CG2 rdf:type guide:Competency ;
    guide:competencyCode "CG2" ;
    guide:competencyDescription "Poseer capacidad para diseñar, desarrollar, implementar, gestionar y mejorar productos, sistemas y procesos en los distintos ámbitos industriales..." .

:comp_CG3 rdf:type guide:Competency ;
    guide:competencyCode "CG3" ;
    guide:competencyDescription "Aplicar los conocimientos adquiridos para identificar, formular y resolver problemas dentro de contextos amplios y multidisciplinarios..." .

:comp_CG5 rdf:type guide:Competency ;
    guide:competencyCode "CG5" ;
    guide:competencyDescription "Saber comunicar los conocimientos y conclusiones, de forma oral, escrita y gráfica..." .

:comp_CG6 rdf:type guide:Competency ;
    guide:competencyCode "CG6" ;
    guide:competencyDescription "Poseer habilidades de aprendizaje que permitan continuar estudiando a lo largo de la vida..." .

:comp_CG7 rdf:type guide:Competency ;
    guide:competencyCode "CG7" ;
    guide:competencyDescription "Incorporar nuevas tecnologías y herramientas de la Ingeniería Industrial en sus actividades profesionales." .

:comp_CG9 rdf:type guide:Competency ;
    guide:competencyCode "CG9" ;
    guide:competencyDescription "Organización y planificación en el ámbito de la empresa, y otras instituciones y organizaciones de proyectos y equipos humanos." .

# Learning Results
:lr_RA8 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA8" ;
    guide:learningResultDescription "Capacidad y habilidades para diseñar circuitos digitales de complejidad intermedia, a partir de bloques funcionales conocidos, combinados con máquinas de estados." .

:lr_RA9 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA9" ;
    guide:learningResultDescription "Adquirir criterios para seleccionar las diferentes posibilidades tecnológicas de implementación de circuitos." .

# Syllabus
:syllabus_electronica_digital rdf:type guide:Syllabus ;
    guide:hasItem :item_1, :item_2, :item_3, :item_4, :item_5, :item_6, :item_7 .

:item_1 rdf:type guide:SyllabusItem ;
    guide:itemIndex 1 ;
    guide:syllabusDescription "Introducción a los Sistemas Digitales" .

:item_2 rdf:type guide:SyllabusItem ;
    guide:itemIndex 2 ;
    guide:syllabusDescription "Diseño Digital con Lenguajes de descripción Hardware (VHDL)" .

:item_3 rdf:type guide:SyllabusItem ;
    guide:itemIndex 3 ;
    guide:syllabusDescription "Diseño de Circuitos Combinacionales" .

:item_4 rdf:type guide:SyllabusItem ;
    guide:itemIndex 4 ;
    guide:syllabusDescription "Diseño de Circuitos Secuenciales Síncronos" .

:item_5 rdf:type guide:SyllabusItem ;
    guide:itemIndex 5 ;
    guide:syllabusDescription "Síntesis de Circuitos Secuenciales Síncronos" .

:item_6 rdf:type guide:SyllabusItem ;
    guide:itemIndex 6 ;
    guide:syllabusDescription "Implementación física" .

:item_7 rdf:type guide:SyllabusItem ;
    guide:itemIndex 7 ;
    guide:syllabusDescription "Arquitectura de sistemas digitales" .

# Evaluation System
:eval_system_main rdf:type guide:EvaluationSystem ;
    guide:evaluationDescription "Evaluación progresiva y global." ;
    guide:hasEvaluationTrial :trial_ev_prac1, :trial_ev_prac2, :trial_ev_prac3, :trial_ev_prac4, :trial_exam_vhd, :trial_work_review, :trial_final_exam .

:trial_ev_prac1 rdf:type guide:EvaluationTrial ;
    guide:evaluationType "Examen de Prácticas" ;
    guide:gradePercentage "2.5%" ;
    guide:trialMode "Presencial" ;
    guide:eventIndex 2 .

:trial_exam_vhd rdf:type guide:EvaluationTrial ;
    guide:evaluationType "Examen Escrito" ;
    guide:gradePercentage "20%" ;
    guide:trialMode "Presencial" ;
    guide:eventIndex 6 .

:trial_work_review rdf:type guide:EvaluationTrial ;
    guide:evaluationType "Trabajo en Grupo" ;
    guide:gradePercentage "30%" ;
    guide:trialMode "Presencial" ;
    guide:eventIndex 13 .

:trial_final_exam rdf:type guide:EvaluationTrial ;
    guide:evaluationType "Examen Escrito" ;
    guide:gradePercentage "40%" ;
    guide:minimumScore "4 / 10" ;
    guide:trialMode "Presencial" ;
    guide:eventIndex 17 .

