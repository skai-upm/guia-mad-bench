# Course Guide Instance
:CourseGuide_85004612 rdf:type guide:CourseGuide ;
    sch:name "85004612 - Turbomáquinas Térmicas para Aplicaciones Navales" ;
    sch:description "El objetivo de la asignatura es que el alumno obtenga un conocimiento suficiente de los procesos de la termodinámica y de la mecánica de fluidos, que son propios de estas turbomáquinas térmicas así como de los procedimientos básicos de diseño de las mismas." ;
    guide:numberOfCredits 4.5 ;
    guide:teachingPeriod "2025-26" ;
    guide:periodStartingMonth "Septiembre" ;
    guide:periodEndingMonth "Enero" ;
    sch:inLanguage "Castellano" ;
    guide:hasCourse :Course_85004612 ;
    guide:hasCompetency :Competency_CB2, :Competency_CB5, :Competency_CE13, :Competency_CE19, :Competency_CE2_23, :Competency_CE7, :Competency_CG3 ;
    guide:hasLearningResult :LearningResult_RA32, :LearningResult_RA33 ;
    guide:hasSyllabus :Syllabus_85004612 ;
    guide:hasEvaluation :EvaluationSystem_85004612 ;
    guide:hasDidacticResource :Resource_Coates, :Resource_Kostyuk, :Resource_Munoz, :Resource_MuñozRodríguez, :Resource_Boyce, :Resource_Schegliaiev, :Resource_Woodward ;
    sch:instructor :Lecturer_RodrigoPerez, :Lecturer_MariaDelCarmen .

