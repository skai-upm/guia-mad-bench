# Learning Results
:lr_ra357 a guide:LearningResult ;
    guide:learningResultCode "RA357"@es ;
    guide:learningResultDescription "Concreción de los conocimientos en aplicaciones prácticas en los ámbitos de las TIC y la electrificación rural"@es .

:lr_ra354 a guide:LearningResult ;
    guide:learningResultCode "RA354"@es ;
    guide:learningResultDescription "Adquisión de una visión objetiva y amplia de los actuales desequilibrios sociales y medioambientales"@es .

:lr_ra45 a guide:LearningResult ;
    guide:learningResultCode "RA45"@es ;
    guide:learningResultDescription "Conocimientos y habilidades de las temáticas científico tecnológicas desarrolladas en las asignaturas ofertadas"@es .

:lr_ra355 a guide:LearningResult ;
    guide:learningResultCode "RA355"@es ;
    guide:learningResultDescription "Conocimiento de la estructura y los instrumentos de la cooperación internacional para el desarrollo"@es .

:lr_ra356 a guide:LearningResult ;
    guide:learningResultCode "RA356"@es ;
    guide:learningResultDescription "Conocimiento y aplicación de metodologías de planificación e intervención en proyectos de desarrollo"@es .

# Syllabus
:syllabus_95000092 a guide:Syllabus ;
    guide:hasItem :item_tema1, :item_tema2, :item_tema3, :item_tema4, :item_tema5 .

:item_tema1 a guide:SyllabusItem ;
    guide:itemIndex 1 ;
    guide:syllabusDescription "Tema 1: El mundo en que vivimos"@es .

:item_tema2 a guide:SyllabusItem ;
    guide:itemIndex 2 ;
    guide:syllabusDescription "Tema 2: Estrategias de la cooperación para el desarrollo"@es .

:item_tema3 a guide:SyllabusItem ;
    guide:itemIndex 3 ;
    guide:syllabusDescription "Tema 3: Metodología de proyectos en cooperación"@es .

:item_tema4 a guide:SyllabusItem ;
    guide:itemIndex 4 ;
    guide:syllabusDescription "Tema 4: Aplicaciones TIC para el Desarrollo"@es .

:item_tema5 a guide:SyllabusItem ;
    guide:itemIndex 5 ;
    guide:syllabusDescription "Tema 5: Aplicaciones de electrificación rural"@es .

# Evaluation System and Trials
:eval_system_95000092 a guide:EvaluationSystem ;
    guide:evaluationDescription "La evaluación progresiva se basa en la participación activa, análisis de libro, proyecto y examen final."@es ;
    guide:hasEvaluationTrial :trial_examen_final, :trial_analisis_libro, :trial_proyecto_cooperacion .

:trial_examen_final a guide:EvaluationTrial ;
    guide:evaluationType "Examen Escrito"@es ;
    guide:trialMode "Presencial"@es ;
    guide:gradePercentage "25%"@es ;
    guide:minimumScore "0 / 10"@es ;
    guide:trialDescription "Examen final tipo test"@es .

:trial_analisis_libro a guide:EvaluationTrial ;
    guide:evaluationType "Presentación en Grupo"@es ;
    guide:trialMode "Presencial"@es ;
    guide:gradePercentage "20%"@es ;
    guide:trialDescription "Análisis de un libro: Evaluación de trabajo individual con presentación en grupo"@es .

:trial_proyecto_cooperacion a guide:EvaluationTrial ;
    guide:evaluationType "Presentación en Grupo"@es ;
    guide:trialMode "Presencial"@es ;
    guide:gradePercentage "35%"@es ;
    guide:trialDescription "Proyecto de cooperación: Evaluación de trabajo en grupo"@es .

