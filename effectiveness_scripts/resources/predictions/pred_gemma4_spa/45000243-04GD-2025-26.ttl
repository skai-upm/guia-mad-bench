# Competencies
guide:Comp_CM40_2
    rdf:type guide:Competency ;
    guide:competencyCode "04GC. CM40.2" ;
    guide:competencyDescription "Comprensión del fenómeno urbano y sus factores determinantes (historia, economía, actividad humana, movilidad)." .

guide:Comp_CM41_1
    rdf:type guide:Competency ;
    guide:competencyCode "04GC. CM41.1" ;
    guide:competencyDescription "Conocimiento de la influencia de las infraestructuras en la ordenación del territorio..." .

guide:Comp_CT1
    rdf:type guide:Competency ;
    guide:competencyCode "04GC. CT1" ;
    guide:competencyDescription "Compromiso y capacidad para aplicar los principios de sostenibilidad en las actuaciones profesionales." .

# Learning Results
guide:LR_RA180_RA03
    rdf:type guide:LearningResult ;
    guide:learningResultCode "RA180 - RA04" ;
    guide:learningResultDescription "Trabajar de forma autónoma y con iniciativa personal" .

guide:LR_RA137
    rdf:type guide:LearningResult ;
    guide:learningResultCode "RA137" ;
    guide:learningResultDescription "Interioriza los principios de deontología profesional de ingeniería civil." .

# Syllabus
guide:Syllabus_Transportes
    rdf:type guide:Syllabus ;
    guide:hasItem guide:Tema_1, guide:Tema_2, guide:Tema_3, guide:Tema_4, guide:Tema_5, guide:Tema_6, guide:Tema_7, guide:Tema_8, guide:Tema_9, guide:Tema_10, guide:Tema_11, guide:Tema_12 .

guide:Tema_1
    rdf:type guide:SyllabusItem ;
    guide:syllabusDescription "Características y funciones. La actividad del sector del transporte" ;
    guide:itemIndex 1 .

guide:Tema_6
    rdf:type guide:SyllabusItem ;
    guide:syllabusDescription "Intermodalidad" ;
    guide:itemIndex 6 .

# Evaluation System
guide:EvalSystem_Transportes
    rdf:type guide:EvaluationSystem ;
    guide:evaluationDescription "Evaluación continua y prueba final" ;
    guide:hasEvaluationTrial guide:Examen_Parcial, guide:Examen_Final, guide:Test_Tema_1 .

guide:Test_Tema_1
    rdf:type guide:EvaluationTrial ;
    guide:trialType "Test" ;
    guide:trialMode "Presencial" ;
    guide:gradePercentage "2.3%" ;
    guide:minimumScore "5 / 10" ;
    guide:evaluationDuration "00:15" .

guide:Examen_Parcial
    rdf:type guide:EvaluationTrial ;
    guide:trialType "Examen Escrito" ;
    guide:trialMode "Presencial" ;
    guide:gradePercentage "35%" ;
    guide:minimumScore "5 / 10" .

guide:Examen_Final
    rdf:type guide:EvaluationTrial ;
    guide:trialType "Examen Escrito" ;
    guide:trialMode "Presencial" ;
    guide:gradePercentage "100%" ;
    guide:minimumScore "5 / 10" .

# Schedule and Activities
guide:Schedule_Transportes
    rdf:type guide:Schedule ;
    sch:eventSchedule guide:Act_Tema1, guide:Act_Tema2, guide:Act_Examen_Parcial .

guide:Act_Tema1
    rdf:type guide:Activity ;
    guide:activityDescription "Tema 1 Características y funciones del transporte" ;
    guide:activityDuration 2.16 ;
    guide:activityFormat "Lección Magistral" ;
    guide:attendanceType "Presencial" .

guide:Act_Examen_Parcial
    rdf:type guide:Activity ;
    guide:activityDescription "Examen parcial" ;
    guide:activityDuration 2.5 ;
    guide:activityFormat "Examen Escrito" ;
    guide:attendanceType "Presencial" .

