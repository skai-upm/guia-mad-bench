# Evaluation System and Trials
:eval_system_electronica_comunicaciones_i rdf:type guide:EvaluationSystem ;
    guide:evaluationDescription "La evaluación de la asignatura se divide en dos partes: teoría (70%) y práctica (3ally 30%)." ;
    guide:hasEvaluationTrial :trial_1er_examen_parcial, :trial_2do_examen_parcial, :trial_examen_final .

:trial_1er_examen_parcial rdf:type guide:EvaluationTrial ;
    guide:evaluationType "Examen Escrito" ;
    guide:gradePercentage "50%" ;
    guide:minimumScore "5 / 10" ;
    guide:trialMode "Presencial" ;
    guide:trialDescription "Primer examen parcial de evaluación continua." ;
    guide:involvesCompetency :comp_ce_sc03, :comp_ce_tel01 .

:trial_examen_final rdf:type guide:EvaluationTrial ;
    guide:evaluationType "Examen Escrito" ;
    guide:gradePercentage "100%" ;
    guide:minimumScore "5 / 10" ;
    guide:trialMode "Presencial" ;
    guide:trialDescription "Examen final de teoría." .

