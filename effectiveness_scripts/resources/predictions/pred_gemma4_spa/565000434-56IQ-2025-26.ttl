# Course Guide Instance
:course_guide_resistencia_materiales a guide:CourseGuide ;
    sch:name "Resistencia De Materiales" ;
    sch:description "En la asignatura se abordará el cálculo de las tensiones y deformaciones que se producen en sólidos elásticos sometidos a diferentes solicitaciones (axil, flexión, cortante torsión) con objeto de evitar que se superen los valores admisibles." ;
    guide:numberOfCredits 4.5 ;
    guide:courseType "Obligatoria" ;
    guide:teachingPeriod "2025-26" ;
    guide:periodStartingMonth "Septiembre" ;
    guide:periodEndingMonth "Enero" ;
    sch:inLanguage "Castellano" ;
    guide:hasCourse :course_resistencia_materiales ;
    guide:hasCompetency :comp_ce14, :comp_cg1, :comp_cg10, :comp_cg3, :comp_cg4, :comp_cg6, :comp_cg7 ;
    guide:hasLearningResult :lr_ra59 ;
    guide:hasSyllabus :syllabus_resistencia_materiales ;
    guide:hasEvaluation :eval_system_resistencia ;
    guide:hasDidacticResource :res_vazquez, :res_ortiz, :res_timoshenko, :res_beer, :res_gere, :res_lab_elasticidad, :res_lab_medios, :res_moodle ;
    sch:activitiesWorkload "26-27 horas por crédito ECTS" .

# Course Instance
:course_resistencia_materiales a guide:Course ;
    sch:courseCode "565000434" ;
    guide:semester "Tercer semestre" ;
    guide:courseYear 2025 ;
    sch:hasCourseInstance :course_guide_resistencia_materiales .

