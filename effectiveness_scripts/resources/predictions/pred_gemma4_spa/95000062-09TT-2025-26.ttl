# Evaluation System
gmb:EvalSystem_95000062 rdf:type guide:EvaluationSystem ;
    guide:evaluationDescription "La evaluación comprobará si los estudiantes han adquirido las competencias de la asignatura." ;
    guide:hasEvaluationTrial gmb:Trial_Prog, gmb:Trial_Global .

gmb:Trial_Prog rdf:type guide:EvaluationTrial ;
    guide:evaluationType "Progresiva" ;
    guide:gradePercentage "10%" ;
    guide:hasScheduleEvent gmb:Event_Week4 .

gmb:Trial_Global rdf:type guide:EvaluationTrial ;
    guide:evaluationType "Global" ;
    guide:gradePercentage "50%" ;
    guide:hasScheduleEvent gmb:Event_Week17 .

