# Competencies
gmb:Comp_SE1 rdf:type guide:Competency ;
    guide:competencyCode "CE-SE1" ;
    guide:competencyDescription "Capacidad de construir, explotar y gestionar sistemas de captación, transporte, representación, procesado, almacenamiento, gestión y presentación de información multimedia..." .

gmb:Comp_SE3 rdf:type guide:Competency ;
    guide:competencyCode "CE-SE3" ;
    guide:competencyDescription "Capacidad de realizar la especificación, implementación, documentación y puesta a punto de equipos y sistemas electrónicos..." .

gmb:Comp_SE5 rdf:type guide:Competency ;
    guide:competencyCode "CE-SE5" ;
    guide:competencyDescription "Capacidad de diseñar circuitos de electrónica analógica y digital, de conversión analógico-digital y digital analógica..." .

gmb:Comp_SE9 rdf:type guide:Competency ;
    guide:competencyCode "CE-SE9" ;
    guide:competencyDescription "Capacidad de analizar y solucionar los problemas de interferencias y compatibilidad electromagnética" .

gmb:Comp_CG7 rdf:type guide:Competency ;
    guide:competencyCode "CG7" ;
    guide:competencyDescription "Trabajo en equipo" .

gmb:Comp_CG12 rdf:type guide:Competency ;
    guide:competencyCode "CG12" ;
    guide:competencyDescription "Organización y planificación" .

gmb:Comp_CG13 rdf:type guide:Competency ;
    guide:competencyCode "CG13" ;
    guide:competencyDescription "Respeto medioambiental" .

gmb:Comp_CG9 rdf:type guide:Competency ;
    guide:competencyCode "CG9" ;
    guide:competencyDescription "Uso de Tecnologías de la Información y de las Comunicaciones" .

# Learning Results
gmb:LR_732 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA732" ;
    guide:learningResultDescription "Diseñar una placa de circuito impreso orientada a fabricación" .

gmb:LR_733 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA733" ;
    guide:learningResultDescription "Distinguir las distintas fases del desarrollo de producto" .

gmb:LR_76 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA76" ;
    guide:learningResultDescription "Conocimientos de las normativas reguladoras aplicables a los equipos electrónicos." .

gmb:LR_734 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA734" ;
    guide:learningResultDescription "Conocimientos básicos de técnicas de soldadura de sistemas electrónicos" .

gmb:LR_71 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA71" ;
    guide:learningResultDescription "Conocimiento de las técnicas de diseño de circuitos electrónicos." .

gmb:LR_70 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA70" ;
    guide:learningResultDescription "Conocimientos de dispositivos, circuitos, equipos y sistemas electrónicos." .

gmb:LR_74 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA74" ;
    guide:learningResultDescription "Conocimientos de interferencias y compatibilidad electromagnética." .

