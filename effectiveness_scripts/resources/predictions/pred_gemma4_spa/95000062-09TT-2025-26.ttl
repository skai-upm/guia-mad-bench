    guide:hasCompetency gmb:Comp_SE1, gmb:Comp_SE3, gmb:Comp_SE5, gmb:Comp_SE9, gmb:Comp_CG7, gmb:Comp_CG12, gmb:Comp_CG13, gmb:Comp_CG9 ;
