# Competencies
data:comp_CB7 a guide:Competency ;
    guide:competencyCode "CB7" ;
    guide:competencyDescription "Que los estudiantes sepan aplicar los conocimientos adquiramos y su capacidad de resolución de problemas en entornos nuevos o poco conocidos dentro de contextos más amplios (o multidisciplinares) relacionados con su área de estudio" .

data:comp_CE1 a guide:Competency ;
    guide:competencyCode "CE1" ;
    guide:competencyDescription "Conocer los fundamentos de la Limnología" .

data:comp_CG3 a guide:Competency ;
    guide:competencyCode "CG3" ;
    guide:competencyDescription "Capacidad para participar en proyectos de investigación, desarrollo e innovación vinculados con el uso sostenible de los recursos hídricos" .

data:comp_CT6 a guide:Competency ;
    guide:competencyCode "CT6" ;
    guide:competencyDescription "Liderar equipos de trabajo de diversa índole, con actitud proactiva y motivadora, comunicando con claridad los objetivos y las tareas de cada componente del equipo." .

# Learning Results
data:lr_RA57 a guide:LearningResult ;
    guide:learningResultCode "RA57" ;
    guide:learningResultDescription "Desarrollo de un trabajo original en el ámbito del uso y gestión del agua en el medio natural." .

# Syllabus
data:syllabus_133000050 a guide:Syllabus ;
    guide:hasItem data:item_1, data:item_2, data:item_3, data:item_4, data:item_5, data:item_6, data:item_7 .

data:item_1 a guide:SyllabusItem ; guide:syllabusDescription "Conceptos y fundamentos del Ocio, Tiempo Libre y la Recreación Deportiva" ; guide:itemIndex 1 .
data:item_2 a guide:SyllabusItem ; guide:syllabusDescription "Demanda de actividades físicas y deportivas en el tiempo libre y de ocio" ; guide:itemIndex 2 .
data:item_3 a guide:SyllabusItem ; guide:syllabusDescription "Dimensiones y manifestaciones actuales del ocio" ; guide:itemIndex 3 .
data:item_4 a guide:SyllabusItem ; guide:syllabusDescription "Actividades deportivas y recreativas fluviales. Clasificación." ; guide:itemIndex 4 .
data:item_5 a guide:SyllabusItem ; guide:syllabusDescription "Diseño de programas de actividades acuáticas en la naturaleza" ; guide:itemIndex 5 .
data:item_6 a guide:SyllabusItem ; guide:syllabusDescription "Experiencia práctica de piragüismo. Maniobras básicas de paleo para el descenso de aguas bravas" ; guide:itemIndex 6 .
data:item_7 a guide:SyllabusItem ; guide:syllabusDescription "Gestión del riesgo en actividades fluviales y barrancos" ; guide:itemIndex 7 .

