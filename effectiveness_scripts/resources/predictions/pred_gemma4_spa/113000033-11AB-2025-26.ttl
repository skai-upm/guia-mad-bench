    guide:evaluationDuration "02:00" ;
    guide:gradePercentage "25%" ;
    guide:minimumScore "5 / 10" ;
    guide:eventWeek "8" ;
    guide:involvesCompetency guide:Comp_CG6, guide:Comp_CG5, guide:Comp_T2, guide:Comp_T6, guide:Comp_CB10, guide:Comp_T3 .

guide:Trial_Global rdf:type guide:EvaluationTrial ;
