# Competencies
guide:Comp_CB10 rdf:type guide:Competency ;
    guide:competencyCode "CB10" ;
    guide:competencyDescription "Que los estudiantes posean las habilidades de aprendizaje que les permitan continuar estudiando de un modo que habrá de ser en gran medida autodirigido o autónomo" .

guide:Comp_CG5 rdf:type guide:Competency ;
    guide:competencyCode "CG5" ;
    guide:competencyDescription "Desarrollo de la habilidades humanas necesarias para el trabajo en equipo y de ese modo asumir el compromiso de la investigación científica con valores humanos que favorezcan la sana convivencia." .

guide:Comp_CG6 rdf:type guide:Competency ;
    guide:competencyCode "CG6" ;
    guide:competencyDescription "Capacidad para comunicarse y relacionarse en un ámbito científico en la lengua inglesa." .

guide:Comp_T2 rdf:type guide:Competency ;
    guide:competencyCode "T2" ;
    guide:competencyDescription "Capacidad para el aprendizaje autónomo y la actualización de conocimientos, y reconocimiento de su necesidad en el área de las Ciencias de la Actividad Física y del Deporte." .

guide:Comp_T3 rdf:type guide:Competency ;
    guide:competencyCode "T3" ;
    guide:competencyDescription "Capacidad para trabajar dentro de un equipo, organizado, planificado, tomando decisiones, negociando y resolviendo conflictos, relacionándose y criticando y haciendo autocrítica." .

guide:Comp_T6 rdf:type guide:Competency ;
    guide:competencyCode "T6" ;
    guide:competencyDescription "Capacidad para usar las tecnologías de la información y la comunicación." .

# Learning Results
guide:LR_RA94 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA94" ;
    guide:learningResultDescription "Mejorar la calidad de la escritura técnica en inglés beneficiándose de herramientas digitales y sus sugerencias en tiempo real sobre corrección de spelling, grammar y punctuation." .

guide:LR_RA91 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA91" ;
    guide:learningResultDescription "Write a Research Article in English" .

guide:LR_RA96 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA9<0xC2>6" ;
    guide:learningResultDescription "Redactar en inglés con claridad, precisión y cohesión cuidando la gramática." .

guide:LR_RA19 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA19" ;
    guide:learningResultDescription "El objetivo principal del curso es dotar al estudiante de las herramientas y estrategias necesarias para afrontar de forma autónoma y satisfactoria la redacción de artículos de investigación en inglés." .

guide:LR_RA95 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA95" ;
    guide:learningResultDescription "Expandir el vocabulario académico y la terminología específica en inglés de las ciencias de la actividad física y el deporte." .

# Syllabus
guide:Syllabus_113000033 rdf:type guide:Syllabus ;
    guide:hasItem guide:SyllabusItem_1, guide:SyllabusItem_2 .

guide:SyllabusItem_1 rdf:type guide:SyllabusItem ;
    guide:syllabusDescription "Structure of a Research Article (Introduction, Method, Results, Discussion and Conclusions)" ;
    guide:itemIndex 1 .

guide:SyllabusItem_2 rdf:type guide:SyllableItem ;
    guide:syllabusDescription "How to write a good abstract and get published" ;
    guide:itemIndex 2 .

# Evaluation System
guide:EvalSystem_113000033 rdf:type guide:EvaluationSystem ;
    guide:evaluationDescription "Progressive assessment and compulsory attendance in a 75%" .

