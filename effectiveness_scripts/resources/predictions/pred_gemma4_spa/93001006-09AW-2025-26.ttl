# Competency Instances
guide:Competency_CE04
    rdf:type guide:Competency ;
    guide:competencyCode "CE04" ;
    guide:competencyDescription "Capacidad para establecer una categorización de servicios de ciberseguridad para proteger a las infraestructuras conectadas en red." .

guide:Competency_CE05
    rdf:type guide:Competency ;
    guide:competencyCode "CE05" ;
    guide:competencyDescription "Capacidad de analizar y diseñar servicios de seguridad de control de acceso, protección de la información en tránsito y protección perimetral." .

guide:Competency_CG03
    rdf:type guide:Competency ;
    guide:competencyCode "CG03" ;
    guide:competencyDescription "Dotar al alumno de la capacidad de diseñar e implantar procedimientos de protección de la información asociados con los sistemas de información, las redes y comunicaciones telemáticas y los servicios de Internet." .

# Learning Result Instance
guide:LearningResult_RA10
    rdf:type guide:LearningResult ;
    guide:learningResultCode "RA10" ;
    guide:learningResultDescription "Analizar y seleccionar los mecanismos adecuados para proteger las comunicaciones." .

# Evaluation System and Trials
guide:EvaluationSystem_93001006
    rdf:type guide:EvaluationSystem ;
    guide:evaluationDescription "Sistema de evaluación progresiva que consiste en la realización de cuatro trabajos prácticos y un examen escrito." ;
    guide:hasEvaluationTrial guide:Trial_ExamenTeoria, guide:Trial_PracticasMemorias, guide:Trial_PracticasExamen .

guide:Trial_ExamenTeoria
    rdf:type guide:EvaluationTrial ;
    guide:trialType "Examen Escrito" ;
    guide:trialMode "Presencial" ;
    guide:gradePercentage "60%" ;
    guide:minimumScore "3.5 / 10" ;
    guide:evaluationDuration "01:00" .

guide:Trial_PracticasMemorias
    rdf:type guide:EvaluationTrial ;
    guide:trialType "Trabajo en Grupo" ;
    guide:trialMode "Presencial" ;
    guide:gradePercentage "20%" ;
    guide:minimumScore "3.5 / 10" ;
    guide:evaluationDuration "01:00" .

guide:Trial_PracticasExamen
    rdf:type guide:EvaluationTrial ;
    guide:trialType "Examen de Prácticas" ;
    guide:trialMode "Presencial" ;
    guide:gradePercentage "20%" ;
    guide:minimumScore "3.5 / 10" ;
    guide:evaluationDuration "01:00" .

# Syllabus and Items
guide:Syllabus_93001006
    rdf:type guide:Syllabus ;
    guide:hasItem guide:SyllabusItem_Tema1, guide:SyllabusItem_Tema2, guide:SyllabusItem_Tema3, guide:SyllabusItem_Tema4, guide:SyllabusItem_Tema5, guide:SyllablesItem_Tema6 .

guide:SyllabusItem_Tema1
    rdf:type guide:SyllabusItem ;
    guide:syllabusDescription "Protección de redes telemáticas y sistemas. Infraestructuras de seguridad." ;
    guide:itemIndex 1 .

guide:SyllabusItem_Tema2
    rdf:type guide:SyllabusItem ;
    guide:syllabusDescription "Redes Privadas Virtuales (VPN)" ;
    guide:itemIndex 2 .

guide:SyllabusItem_Tema3
    rdf:type guide:SyllabusItem ;
    guide:syllabusDescription "Seguridad en nivel de enlace, redes móviles y WiFi" ;
    guide:itemIndex 3 .

guide:SyllabusItem_Tema4
    rdf:type guide:SyllabusItem ;
    guide:syllabusDescription "Seguridad en nivel de red: IPSEC" ;
    guide:itemIndex 4 .

guide:SyllabusItem_Tema5
    rdf:type guide:SyllabusItem ;
    guide:syllabusDescription "Seguridad en nivel de transporte: SSL/TLS" ;
    guide:itemIndex 5 .

guide:SyllabusItem_Tema6
    rdf:type guide:SyllabusItem ;
    guide:syllabusDescription "Seguridad en nivel de aplicación: SRTP, S/MIME, PGP" ;
    guide:itemIndex 6 .

