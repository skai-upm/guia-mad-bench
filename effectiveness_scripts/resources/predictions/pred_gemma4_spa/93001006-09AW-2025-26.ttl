# Course Guide Instance
guide:CourseGuide_93001006
    rdf:type guide:CourseGuide ;
    sch:name "Servicios De Seguridad En Red" ;
    sch:description "La asignatura trata sobre los servicios de seguridad que permiten proteger la información en tránsito a través de las redes de comunicaciones." ;
    guide:numberOfCredits 3.0 ;
    guide:teachingPeriod "2025-26" ;
    guide:periodStartingMonth "Septiembre" ;
    guide:periodEndingMonth "Enero" ;
    sch:inLanguage "Castellano" ;
    guide:hasCourse guide:Course_93001006 ;
    guide:hasCompetency guide:Competency_CE04, guide:Competency_CE05, guide:Competency_CG03 ;
    guide:hasLearningResult guide:LearningResult_RA10 ;
    sch:instructor guide:Lecturer_DiegoRivera ;
    guide:hasEvaluation guide:EvaluationSystem_93001006 ;
    guide:hasSyllabus guide:Syllabus_93001006 ;
    guide:hasDidacticResource guide:Resource_Moodle ;
    guide:otherInformation "Esta asignatura puede contribuir a los Objet: 5 y 9 de la ONU." .

