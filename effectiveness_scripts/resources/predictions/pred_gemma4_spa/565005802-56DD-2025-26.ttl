# Competencies (Sample)
:Comp_C113 rdf:type guide:Competency ;
    guide:competencyCode "C.11.3" ;
    guide:competencyDescription "Conocer el estado actual de las técnicas de impresión 3D así como los criterios para realizar un diseño eficiente con las características y materiales más adecuados a cada proyecto." .

:Comp_CE10 rdf:type guide:Competency ;
    guide:competencyCode "CE10" ;
    guide:competencyDescription "Conocimiento y utilización de los principios de teoría de circuitos y máquinas eléctricas." .

:Comp_CG10 rdf:type guide:Competency ;
    guide:competencyCode "CG10" ;
    guide:competencyDescription "Creatividad." .

# Evaluation System and Trials
:EvalSystem_565005802 rdf:type guide:EvaluationSystem ;
    guide:evaluationDescription "The evaluation methodology will consist of individual tasks and a summary of the sessions attended (40%), presentations (40%), and final project (20%)." ;
