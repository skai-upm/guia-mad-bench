    sch:email "miguel.montes@upm.es" .

# Competency Instances
guide:CE06 rdf:type guide:Competency ;
    guide:competencyCode "CE06" ;
    guide:competencyDescription "Comprender y saber calcular el equilibrio y la dinámica de sistemas mecánicos" .

guide:CG04 rdf:type guide:Competency ;
    guide:competencyCode "CG04" ;
    guide:competencyDescription "Trabajar de forma adecuada en un laboratorio incluyendo un registro anotado de las actividades y seguridad, manipulación y eliminación de residuos químicos o biológicos" .

# Learning Result Instances
guide:RA31_RA34 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA31 - RA34" ;
    guide:learningResultDescription "Conocer, comprender y dominar los conceptos y principios básicos de la Dinámica de sistemas" .

guide:RA4 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA4" ;
    guide:learningResultDescription "Capacidad para emplear con rigor el lenguaje matemático" .

# Evaluation System and Trials
guide:Fisica_EvalSystem rdf:type guide:EvaluationSystem ;
    guide:evaluationDescription "Evaluación progresiva y global" ;
    guide:hasEvaluationTrial guide:Prueba1_Trial, guide:Laboratorio_Trial, guide:ExamenFinal_Trial .

guide:Prueba1_Trial rdf:type guide:EvaluationTrial ;
    guide:trialType "Examen Escrito" ;
    guide:evaluationType "Progresiva" ;
    guide:gradePercentage "37.5%" ;
    guide:trialMode "Presencial" .

guide:Laboratorio_Trial rdf:type guide:EvaluationTrial ;
    guide:trialType "Trabajo en Grupo" ;
    guide:evaluationType "Progresiva" ;
    guide:gradePercentage "15%" ;
    guide:trialMode "Presencial" .

# Syllabus and Items
guide:Fisica_Syllabus rdf:type guide:Syllabus ;
    guide:hasItem guide:Topic_Mecanica, guide:Topic_Elasticidad, guide:Topic_Fluidos, guide:Topic_Termodinamica .

guide:Topic_Mecanica rdf:type guide:SyllabusItem ;
    guide:itemIndex 1 ;
    guide:syllabusDescription "Mecánica: Análisis dimensional, Vectores, Dinámica y cinemática de la partícula, Trabajo y energía, Sistemas de partículas y sólido rígido, Equilibrio y estática" .

# Didactic Resources
guide:Tipler_Resource rdf:type guide:DidacticResource ;
    guide:bibliographyTitle "Tipler, P.A., Mosca, G. Física, vol. 1 y 2" ;
    guide:bibliographyType "Bibliografía" .

guide:KhanAcademy_Resource rdf:type guide:DidacticResource ;
    guide:bibliographyTitle "Khan Academy Physics" ;
    guide:bibliographyType "Recurso web" .

# Schedule Events (Examples from Cronograma)
guide:Event_Semana1 rdf:type guide:ScheduleEvent ;
    guide:eventWeek "Semana 1" ;
    guide:eventIndex 1 ;
    guide:hasActivity guide:Actividad_Leccion_Magistral_1 .

guide:Actividad_Leccion_Magistral_1 rdf:type guide:Activity ;
    guide:activityDescription "Análisis dimensional. Vectores." ;
    guide:activityFormat "Lección Magistral" ;
    guide:activityDuration 2.0 .