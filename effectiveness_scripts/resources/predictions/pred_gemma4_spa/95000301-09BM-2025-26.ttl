# Course Guide Instance
guide:Fisica_CourseGuide rdf:type guide:CourseGuide ;
    sch:name "Guía de Aprendizaje: Física" ;
    guide:teachingPeriod "2025-26" ;
    guide:numberOfCredits 6.0 ;
    guide:courseType "Básica" ;
    guide:hasSyllabus guide:Fisica_Syllabus ;
    guide:hasCompetency guide:CE06, guide:CE07, guide:CE10, guide:CE11, guide:CG01, guide:CG04, guide:CG05, guide:CG07, guide:CG08, guide:CG09, guide:CG11 ;
    guide:hasLearningResult guide:RA31_RA34, guide:RA4, guide:RA30_RA32, guide:RA17, guide:RA55, guide:RA132, guide:RA155, guide:RA212, guide:RA209, guide:RA34_RA41, guide:RA35_RA42, guide:RA33_RA40, guide:RA131, guide:RA150, guide:RA36_RA43, guide:RA37_RA44 ;
    guide:hasEvaluation guide:Fisica_EvalSystem ;
    guide:hasDidacticResource guide:Tipler_Resource, guide:Sears_Resource, guide:KhanAcademy_Resource ;
    sch:instructor guide:Elisa_Antolin_Lecturer ;
    sch:director guide:Elisa_Antolin_Lecturer .

# Course Instance
guide:Fisica_Course rdf:type guide:Course ;
    sch:name "95000301 - Física" ;
    sch:courseCode 95000301 ;
    guide:courseYear 2025 ;
    guide:semester "Primer semestre" ;
    sch:hasCourseInstance guide:Fisica_CourseGuide .

# Degree Instance
guide:Ingenieria_Biomedica_Degree rdf:type guide:BachelorDegree ;
    sch:name "09BM - Grado en Ingenieria Biomedica" ;
    guide:degreeCode "09BM" ;
    guide:hasCourse guide:Fisica_Course .

# University Center Instance
guide:ETS_Telecomunicacion_Center rdf:type guide:UniversityCenter ;
    sch:name "E.T.S. de Ingenieros de Telecomunicacion" ;
    guide:offers guide:Ingenieria_Biomedica_Degree .

# Lecturer Instances
guide:Elisa_Antolin_Lecturer rdf:type guide:Lecturer ;
    sch:name "Elisa Antolin Fernandez" ;
    sch:email "elisa.antolin@upm.es" ;
    guide:office "Sin despacho asignado" .

guide:Simon_Aurel_Svatek_Lecturer rdf:type guide:Lecturer ;
    sch:name "Simon Aurel Svatek" ;
    sch:email "simon.svatek@upm.es" .

guide:Miguel_Montes_Bajo_Lecturer rdf:type guide:Lecturer ;
