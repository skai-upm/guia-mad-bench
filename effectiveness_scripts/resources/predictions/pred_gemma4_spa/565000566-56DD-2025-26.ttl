# Evaluation System and Trials
:Sistema_Evaluacion_Ampliacion_Expresion_Grafica rdf:type guide:EvaluationSystem ;
    guide:evaluationDescription "La asignatura cuenta con una prueba de evaluación progresiva y una prueba global." ;
    guide:hasEvaluationTrial :Trial_Progresivo, :Trial_Global .

:Trial_Progresivo rdf:type guide:EvaluationTrial ;
    guide:evaluationType "Examen de Prácticas" ;
    guide:trialWeek "8" ;
    guide:gradePercentage "30%" ;
    guide:minimumScore "5/10" ;
    guide:trialMode "Presencial" .

:Trial_Global rdf:type guide:EvaluationTrial ;
    guide:evaluationType "Examen de Prácticas" ;
    guide:trialWeek "17" ;
    guide:gradePercentage "70%" ;
    guide:minimumScore "5/10" ;
    guide:trialMode "Presencial" .

