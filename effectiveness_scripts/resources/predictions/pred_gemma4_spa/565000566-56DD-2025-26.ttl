# Competencies
:Comp_CE5 rdf:type guide:Competency ;
    guide:competencyCode "CE5" ;
    guide:competencyDescription "Capacidad de visión espacial y conocimiento de las técnicas de representación gráfica..." .

:Comp_CG1 rdf:type guide:Competency ;
    guide:competencyCode "CG1" ;
    guide:competencyDescription "Conocer y aplicar los conocimientos de ciencias y tecnologías básicas." .

:Comp_CG10 rdf:type guide:Competency ;
    guide:competencyCode "CG10" ;
    guide:competencyDescription "Creatividad." .

# Learning Results
:LR_RA36 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA36" ;
    guide:learningResultDescription "Comprender y aplicar las propiedades de las curvas técnicas y de las superficies..." .

:LR_RA37 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA37" ;
    guide:learningResultDescription "Ser capaz de elaborar e interpretar información gráfica, posibilitando el trabajo y la comunicación entre técnicos." .

# Syllabus
:Syllabus_Ampliacion_Expresion_Grafica rdf:type guide:Syllabus ;
