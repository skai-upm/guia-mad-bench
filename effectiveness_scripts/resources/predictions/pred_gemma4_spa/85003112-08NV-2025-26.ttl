    guide:previousKnowledge "Los correspondientes a las matemáticas de la ESO y de primero y segundo de Bachillerato" .

# Competencies
data:CB1 rdf:type guide:Competency ;
    guide:competencyCode "CB1" ;
    guide:competencyDescription "Que los estudiantes hayan demostrado poseer y comprender conocimientos en un área de estudio que parte de la base de la educación secundaria general..." .

data:CB5 rdf:type guide:Competency ;
    guide:competencyCode "CB5" ;
    guide:competencyDescription "Que los estudiantes hayan desarrollado aquellas habilidades de aprendizaje necesarias para emprender estudios posteriores con un alto grado de autonomía" .

data:CE1 rdf:type guide:Competency ;
    guide:competencyCode "CE 1" ;
    guide:competencyDescription "Capacidad para la resolución de los problemas matemáticos que puedan plantearse en la ingeniería." .

data:CG3 rdf:type guide:Competency ;
    guide:competencyCode "CG3" ;
    guide:competencyDescription "Capacidad para el aprendizaje de nuevos métodos y teorías, y en la versatilidad para adaptarse a nuevas situaciones..." .

guide:hasCompetency data:Guia_Aprendizaje_Calculo_I, data:CB1, data:CB5, data:CE1, data:CG3 .

# Learning Results
data:RA22 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA22" ;
    guide:learningResultDescription "Estudiar la convergencia de sucesiones y series numéricas. Determinar el conjunto de convergencia de una serie de potencias..." .

data:RA20 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA20" ;
    guide:learningResultDescription "Resolver límites de funciones. Analizar la continuidad y derivabilidad..." .

data:RA23 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA23" ;
    guide:learningResultDescription "Manejar la aritmética compleja con soltura. Representar en forma binómica, trigonométrica o exponencial..." .

data:RA21 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA21" ;
    guide:learningResultDescription "Aplicar correctamente los métodos de integración elementales..." .

data:RA24 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA24" ;
    guide:learningResultDescription "Métodos numéricos: método de la bisección, interpolación de Lagrange e integración numérica." .

guide:hasLearningResult data:Guia_Aprendizaje_Calculo_I, data:RA22, data:RA20, data:RA23, data:RA21, data:RA24 .

# Syllabus
