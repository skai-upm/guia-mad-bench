    guide:itemIndex 1 ;
    guide:syllabusDescription "Números complejos" .

data:Syllabus_Unit_2 rdf:type guide:SyllabusItem ;
    guide:itemIndex 2 ;
    guide:syllabusDescription "Funciones de variable real. Límites y derivadas" .

data:Syllabus_Unit_3 rdf:type guide:SyllabusItem ;
    guide:itemIndex 3 ;
    guide:syllabusDescription "Integración" .

data:Syllabus_Unit_4 rdf:type guide:SyllablesItem ;
    guide:itemIndex 4 ;
    guide:syllabusDescription "Sucesiones y series. Series de potencias" .

guide:hasSyllabus data:Guia_Aprendizaje_Calculo_I .

