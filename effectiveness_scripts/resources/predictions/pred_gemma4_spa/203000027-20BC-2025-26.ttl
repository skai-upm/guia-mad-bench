    guide:degreeCode "20BC" .

:Etsi_Agronomica_Aliment_y_Biosistemas guide:offers :Master_Biologia_Computacional .

# Course
:Computational_Approaches_In_Evolutionary_Biology rdf:type guide:Course ;
    sch:name "203000027 - Computational Approaches In Evolutionary Biology" ;
    sch:courseCode 203000027 ;
    guide:courseType "Optional/elective" ;
    sch:numberOfCredits 3.0 ;
    sch:hasCourseInstance :CourseGuide_203000027 .

:Master_Biologia_Computacional guide:hasCourse :Computational_Approaches_In_Evolutionary_Biology .

# Course Guide
:CourseGuide_203000027 rdf:type guide:CourseGuide ;
    sch:name "Learning Guide - Computational Approaches In Evolutionary Biology" ;
    guide:teachingPeriod "2025-26" ;
    guide:semester "Semester 1" ;
    guide:periodStartingMonth "September" ;
    guide:periodEndingMonth "January" ;
    sch:inLanguage "English" ;
    guide:hasSyllabus :Syllabus_203000027 ;
    guide:hasEvaluation :EvaluationSystem_203000027 ;
