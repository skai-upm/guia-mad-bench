# Learning Results
data:LR_RA204 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA204" ;
    guide:learningResultDescription "Capacidad para integrar en un Sistemas de Información Geográfica información espacial y alcanumérica de diferentes fuentes" .

data:LR_RA206 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA206" ;
    guide:learningResultDescription "El alumno será capaz de realizar proyectos de gestión ambiental mediante los Sistemas de Información Geográfica" .

# Syllabus
data:Syllabus_1350_SIG rdf:type guide:Syllabus ;
    guide:hasItem data:SyllabusItem_1, data:SyllabusItem_2, data:SyllabusItem_3 .

data:SyllabusItem_1 rdf:type guide:SyllabusItem ;
    guide:syllabusDescription "Herramientas avanzadas de análisis vectorial y ráster" ;
    guide:itemIndex 1 .

data:SyllabusItem_2 rdf:type guide:SyllabusItem ;
    guide:syllabusDescription "Hidrología: Delimitación de cuencas; red de drenaje" ;
    guide:itemIndex 2 .

data:SyllabusItem_3 rdf:type guide:SyllabusItem ;
    guide:syllabusDescription "Ordenación de montes: Creación de mapas; creación de bases de datos" ;
    guide:itemIndex 3 .

