guide:Trial_Cuestionarios_1 rdf:type guide:EvaluationTrial ;
    guide:trialType "Prueba Telemática" ;
    guide:trialMode "No Presencial" ;
    guide:evaluationDuration "00:30" ;
    guide:gradePercentage "2.5%" ;
