# Competencies
guide:Comp_MUII_l rdf:type guide:Competency ;
    guide:competencyCode "MUII. (l)" ;
    guide:competencyDescription "ES BILINGÜE. Capacidad de trabajar en un $\text{entorno}$ bilingüe (inglés/castellano)." .

guide:Comp_MUAR_CB06 rdf:type guide:Competency ;
    guide:competencyCode "MUAR.CB06" ;
    guide:competencyDescription "Poseer y comprender conocimientos que aporten una base u oportunidad de ser originales en el desarrollo y/o aplicación de ideas, a menudo en un contexto de investigación" .

guide:Comp_MUAR_CB07 rdf:type guide:Competency ;
    guide:competencyCode "MUAR.CB07" ;
    guide:competencyDescription "Que los estudiantes sepan aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en entornos nuevos o poco conocidos dentro de contextos más amplios (o multidisciplinares) relacionados con su área de estudio" .

# Learning Results
guide:LR_RA87 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA87" ;
    guide:learningResultDescription "Aplicar distintas herramientas y metodologías para el diseño y puesta en práctica de estrategias y políticas de innovación en contextos competitivos" .

guide:LR_RA9 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA9" ;
    guide:learningResultDescription "Identificar, analizar, e interpretar los datos del problema planteado por el profesor." .

# Evaluation System and Trials
guide:EvalSystem_Progresiva rdf:type guide:EvaluationSystem ;
    guide:evaluationDescription "Evaluación progresiva de la asignatura" ;
    guide:hasEvaluationTrial guide:Trial_Entrega_Intermedia_1, guide:Trial_Cuestionarios_1 .

guide:Trial_Entrega_Intermedia_1 rdf:type guide:EvaluationTrial ;
    guide:trialType "Trabajo en Grupo" ;
