# Competencies
:comp_ce1 a guide:Competency ;
    guide:competencyCode "CE1" ;
    guide:competencyDescription "Comprender y utilizar el lenguaje matemático. Adquirir la capacidad para enunciar propiedades en distintos campos de la Matemática..." .

:comp_ce3 a guide:Competency ;
    guide:competencyCode "CE3" ;
    guide:competencyDescription "Asimilar la definición de un nuevo objeto matemático, en términos de otros ya conocidos, y ser capaz de utilizar este objeto en diferentes contextos." .

:comp_ce6 a guide:Competency ;
    guide:competencyCode "CE6" ;
    guide:competencyDescription "Proponer, analizar, validar e interpretar modelos matemáticos de sistemas reales..." .

:comp_cg2 a guide:Competency ;
    guide:competencyCode "CG2" ;
    guide:competencyDescription "Reconocer la presencia de la Matemática subyacente en la Naturaleza, en la Ciencia, en la Tecnología y en el Arte." .

# Learning Results
:lr_ra146 a guide:LearningResult ;
    guide:learningResultCode "RA146" ;
    guide:learningResultDescription "Programar, realizar e interpretar simulaciones de los modelos utilizados" .

:lr_ra193 a guide:LearningResult ;
    guide:learningResultCode "RA193" ;
    guide:learningResultDescription "Conocer y explicar los usos de las curvas y superficies NURBS para resolver problemas de la vida real." .

:lr_ra194 a guide:LearningResult ;
    guide:learningResultCode "RA194" ;
    guide:learningResultDescription "Identificar superficies mínimas en el espacio tridimensional." .

# Syllabus
:syllabus_305000127 a guide:Syllabus ;
    guide:hasItem :item_design_geometrico, :item_robotica .

:item_design_geometrico a guide:SyllabusItem ;
    guide:itemIndex 1 ;
    guide:syllabusDescription "Diseño geométrico asistido por ordenador" .

:item_robotica a guide:SyllablesItem ;
    guide:itemIndex 3 ;
    guide:syllabusDescription "Métodos geométricos en robótica" .

# Evaluation System
:eval_system_305000127 a guide:EvaluationSystem ;
    guide:evaluationDescription "La evaluación progresiva constará de pruebas escritas, prácticas y trabajos. Existe una prueba global de examen teórico-práctico." ;
    guide:hasEvaluationTrial :trial_exam_theory, :trial_control_curvas .

:trial_exam_theory a guide:EvaluationTrial ;
    guide:evaluationType "Examen Escrito" ;
    guide:gradePercentage "100%" ;
    guide:minimumScore "5 / 10" ;
    guide:trialMode "Presencial" .

:trial_control_curvas a guide:EvaluationTrial ;
    guide:evaluationType "Examen Escrito" ;
    guide:gradePercentage "10%" ;
    guide:minimumScore "3 / 10" ;
    guide:trialMode "Presencial" .

