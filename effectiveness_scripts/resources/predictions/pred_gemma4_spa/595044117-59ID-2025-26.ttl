_:courseGuide a guide:CourseGuide ;
    sch:name "595044117 - Ciencia, Tecnología y Sociedad" ;
    guide:numberOfCredits 3.0 ;
    guide:teachingPeriod "2025-26" ;
    guide:periodStartingMonth "Febrero" ;
    guide:periodEndingMonth "Junio" ;
    sch:inLanguage "Castellano" ;
    guide:hasSyllabus _:syllabus ;
    guide:hasCompetency _:compCB02, _:compCB03, _:compCE21, _:compCG02, _:compCG03, _:compCG05, _:compCG06, _:compCG07, _:compCG08, _:compCG09, _:compCG10, _:compCG11 ;
    guide:hasLearningResult _:lrRA027, _:lrRA028, _:lrRA031, _:lrRA047, _:lrRA061, _:lrRA112, _:lrRA098, _:lrRA111, _:lrRA057, _:lrRA032, _:lrRA113, _:lrRA115, _:lrRA123, _:lrRA125, _:lrRA126, _:lrRA127 ;
    guide:hasEvaluation _:evalSystem ;
    guide:hasDidacticResource _:resKuhn, _:resMoodle, _:resIEEE ;
    sch:instructor _:lecturerIvan, _:lecturerMiguel ;
    sch:director _:lecturerIvan ;
    sch:courseSchedule _:schedule ;
    guide:otherInformation "La asignatura estudia todos los ODS en el Tema 1. En el Tema 2 se tratan especialmente ODS-1, ODS-4, ODS-7, ODS-8, ODS-9 y ODS-10." .

_:course a guide:Course ;
    sch:name "595044117 - Ciencia, Tecnología y Sociedad" ;
    guide:courseYear 2025 ;
    guide:courseType "Optativa" ;
    sch:numberOfCredits 3.0 .

_:degree a guide:Degree ;
    sch:name "59ID - Grado en Ingenieria y Sistemas de Datos" ;
    guide:degreeCode "59ID" .

_:center a guide:UniversityCenter ;
    sch:name "E.T.S. De Ingeniería Y Sist. De Telecom." ;
    guide:offers _:degree .

_:lecturerIvan a guide:Lecturer ;
    sch:name "Ivan Pau De La Cruz" ;
    sch:email "ivan.pau@upm.es" ;
    guide:office "-" .

_:lecturerMiguel a guide:Lecturer ;
    sch:name "Miguel Angel Valero Duboy" ;
    sch:email "miguelangel.valero@upm.es" ;
    guide:office "A4422" .

_:compCB02 a guide:Competency ;
    guide:competencyCode "CB02" ;
    guide:competencyDescription "Que los estudiantes sepan aplicar sus conocimientos a su trabajo o vocación de una forma profesional..." .

_:compCB03 a guide:Competency ;
    guide:competencyCode "CB03" ;
    guide:competencyDescription "Que los estudiantes tengan la capacidad de reunir e interpretar datos relevantes..." .

_:compCE21 a guide:Competency ;
    guide:competencyCode "CE21" ;
    guide:competencyDescription "Que los estudiantes sean capaces de aplicar de manera adecuada la normativa, legislación y regulaciones..." .

_:lrRA027 a guide:LearningResult ;
    guide:learningResultCode "RA027" ;
    guide:learningResultDescription "Comprender las implicaciones éticas asociadas al tratamiento de datos y la gestión de la Información." .

_:lrRA126 a guide:LearningResult ;
    guide:learningResultCode "RA126" ;
    guide:learningResultDescription "Valorar el impacto social, económico y medioambiental de un proyecto en el ámbito de la ingeniería de datos y sistemas." .

_:syllabus a guide:Syllabus ;
    guide:hasItem _:item1, _:item2, _:item3, _:item4 .

_:item1 a guide:SyllabusItem ;
    guide:itemIndex 1 ;
    guide:syllabusDescription "Sostenibilidad ecológica y social" .

_:item2 a guide:SyllabusItem ;
    guide:itemIndex 2 ;
    guide:syllabusDescription "Las revoluciones tecnológicas" .

_:item3 a guide:SyllabusItem ;
    guide:itemIndex 3 ;
    guide:syllabusDescription "TIC, ética y derechos humanos" .

_:item4 a guide:SyllabusItem ;
    guide:itemIndex 4 ;
    guide:syllabusDescription "Casos de uso de tecnología social" .

_:evalSystem a guide:EvaluationSystem ;
    guide:evaluationDescription "La evaluación progresiva libera cada tema a partir de una nota de 3 sobre 10. Se aprueba la asignatura por evaluación progresiva si se tiene más de un 3 en los tres temas y la media ponderada es 5 o más." ;
    guide:hasEvaluationTrial _:trialTema1, _:trialTema2, _:trialTema3, _:trialTrabajoFin, _:trialGlobal .

_:trialTema1 a guide:EvaluationTrial ;
    guide:trialType "Examen Escrito" ;
    guide:trialMode "Presencial" ;
    guide:gradePercentage "25%" ;
    guide:minimumScore "3 / 10" ;
    guide:evaluationDuration "01:00" .

_:trialTrabajoFin a guide:EvaluationTrial ;
    guide:trialType "Trabajo en Grupo" ;
    guide:trialMode "Presencial" ;
    guide:gradePercentage "25%" ;
    guide:minimumScore "3 / 10" ;
    guide:evaluationDuration "02:00" .

_:trialGlobal a guide:EvaluationTrial ;
    guide:trialType "Examen Escrito" ;
    guide:trialMode "Presencial" ;
    guide:gradePercentage "100%" ;
    guide:minimumScore "5 / 10" ;
    guide:evaluationDuration "01:30" .

_:schedule a guide:Schedule ;
    sch:eventSchedule _:event1, _:event4, _:event9, _:event13, _:event14, _:event17 .

_:event1 a guide:ScheduleEvent ;
    guide:eventWeek "1" ;
    guide:hasActivity _:act1 .

_:act1 a guide:Activity ;
    guide:activityDescription "Introducción a la asignatura / Sostenibilidad ecológica y social" ;
    guide:activityDuration 3.5 ;
    guide:activityFormat "Lección Magistral" ;
    guide:attendanceType "Presencial" .

_:event4 a guide:ScheduleEvent ;
