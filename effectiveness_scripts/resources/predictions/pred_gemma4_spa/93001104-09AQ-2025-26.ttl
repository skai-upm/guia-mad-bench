# --- Competencies ---

:comp_CE12 rdf:type guide:Competency ;
    guide:competencyCode "CE12" ;
    guide:competencyDescription "Capacidad para utilizar dispositivos lógicos programables, así como para diseñar sistemas electrónicos avanzados, tanto analógicos como digitales. Capacidad para diseñar componentes de comunicaciones..." .

:comp_CE15 rdf:type guide:Competency ;
    guide:competencyCode "CE15" ;
    guide:competencyDescription "Capacidad para la integración de tecnologías y sistemas propios de la Ingeniería de Telecomunicación, con carácter generalista, y en contextos más amplios y multidisciplinares..." .

:comp_CG2 rdf:type guide:Competency ;
    guide:competencyCode "CG2" ;
    guide:competencyDescription "Que los estudiantes sepan aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en entornos nuevos o poco conocidos..." .

# --- Learning Results ---

:lr_RA116 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA116" ;
    guide:learningResultDescription "Diseñar e implementar aplicaciones reales usando plataformas de diseño basadas en procesadores avanzados" .

:lr_RA218 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA218" ;
    guide:learningResultDescription "Analizar y diseñar el software de un sistema electrónico" .

:lr_RA217 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA21．7" ;
    guide:learningResultDescription "Analizar la fiabilidad de un sistema electrónico y diseñar sistemas en base a restricciones de fiabilidad" .

:lr_RA115 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA115" ;
    guide:learningResultDescription "Implementar aplicaciones sobre un Sistema Operativo de tiempo real en sistemas avanzados de procesadores" .

:lr_RA327 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA327" ;
    guide:learningResultDescription "Conocimientos cualitativos y cuantitativos del diseño de sistemas electrónicos" .

:lr_RA215 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA215" ;
    guide:learningResultDescription "Analizar y diseñar sistemas electrónicos teniendo en cuenta aspectos de compatibilidad electromagnética" .

# --- Syllabus ---

:syllabus_93001104 rdf:type guide:Syllabus ;
    guide:hasItem :item_1, :item_2, :item_3, :item_4, :item_5, :item_6 .

:item_1 rdf:type guide:SyllabusItem ;
    guide:itemIndex 1 ;
    guide:syllabusDescription "Introducción a los sistemas empotrados (Aplicaciones, Ejemplo motivante, Proceso de diseño)" .

:item_2 rdf:type guide:SyllabusItem ;
    guide:itemIndex 2 ;
    guide:syllabusDescription "Diseño hardware de sistemas empotrados (Microcontroladores, Arquitectura de memoria, Entrada/Salida)" .

:item_3 rdf:type guide:SyllabusItem ;
    guide:itemIndex 3 ;
    guide:syllabusDescription "Diseño software de sistemas empotrados (Capa de abstracción hardware y BSP, Sistemas Operativos para un único núcleo, Tareas, Mecanismos de comunicación)" .

:item_4 rdf:type guide:SyllabusItem ;
    guide:itemIndex 4 ;
    guide:syllabusDescription "Sistemas en tiempo real (Métodos de planificación, Ejecutivo cíclico, Planificación con prioridades)" .

:item_5 rdf:type guide:SyllabusItem ;
    guide:itemIndex 5 ;
    guide:syllabusDescription "Entorno de pruebas para sistemas empotrados (Diseño orientado a test, Diseño guiado por test, Test unitarios, Test de integración, Modularización y abstracción)" .

:item_6 rdf:type guide:SyllabusItem ;
    guide:itemIndex 6 ;
    guide:syllabusDescription "Seguridad en Sistemas Empotrados (Protección de código, Integridad y privacidad, Ataques, Mejoras arquitecturales)" .

# --- Evaluation System and Trials ---

:eval_system_93001104 rdf:type guide:EvaluationSystem ;
    guide:evaluationDescription "La asignatura se aprobará con una calificación mayor o igual a 5 puntos. Incluye evaluación progresiva y global." ;
    guide:hasEvaluationTrial :trial_prac0, :trial_prac1, :trial_prac2, :trial_prac3, :trial_exam_prog, :trial_exam_global, :trial_prac4, :trial_prac5 .

:trial_prac0 rdf:type guide:EvaluationTrial ;
    guide:trialDescription "Práctica 0: Introducción al entorno de desarrollo y placa de diseño" ;
    guide:evaluationType "Prueba Telemática" ;
    guide:gradePercentage "5%" ;
    guide:minimumScore "5 / 10" ;
    guide:trialMode "No presencial" ;
    guide:involvesCompetency :comp_CG2, :comp_CE12, :comp_CE15 .

:trial_prac1 rdf:type guide:EvaluationTrial ;
    guide:trialDescription "Práctica 1: FSM y entrada/salida" ;
    guide:evaluationType "Prueba Telemática" ;
    guide:gradePercentage "15%" ;
    guide:minimumScore "5 / 10" ;
    guide:trialMode "No presencial" ;
    guide:involvesCompetency :comp_CE12, :comp_CE15, :comp_CG2 .

:trial_exam_prog rdf:type guide:EvaluationTrial ;
    guide:trialDescription "Examen para evaluación progresiva" ;
    guide:evaluationType "Examen Escrito" ;
    guide:gradePercentage "50%" ;
    guide:minimumScore "5 / 10" ;
    guide:trialMode "Presencial" ;
    guide:involvesCompetency :comp_CE12, :comp_CE15, :comp_CG2 .

:trial_exam_global rdf:type guide:EvaluationTrial ;
    guide:trialDescription "Examen global" ;
    guide:evaluationType "Examen Escrito" ;
    guide:gradePercentage "70%" ;
    guide:minimumScore "5 / 10" ;
    guide:trialMode "Presencial" ;
    guide:involvesCompetency :comp_CE12, :comp_CE15, :comp_CG2 .

