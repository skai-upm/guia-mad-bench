# --- Didactic Resources ---

:res_moodle rdf:type guide:DidacticResource ;
    sch:name "Moodle de la asignatura" ;
    guide:bibliographyType "Recursos web" .

:res_book_lee rdf:type guide:DidacticResource ;
    guide:bibliographyTitle "Introduction to Embedded Systems, A Cyber-Physical Systems Approach" ;
    guide:bibliographyDescription "Edward A. Lee and Sanjit A. Seshia, 2011." .

:res_book_wolf rdf:type guide:DidacticResource ;
    guide:bibliographyTitle "Computers as Components: Principles of Embedded Computing System Design" ;
    guide:bibliographyDescription "Marilyn Wolf, 3rd edition, 2012. Complementario, nivel básico." .

:res_book_liu rdf:type guide:DidacticResource ;
    guide:bibliographyTitle "Real-Time Systems" ;
    guide:bibliographyDescription "Jane W. S. Liu, 2000. Complementario, planificación de sistemas de tiempo real." .

:res_book_grenning rdf:type guide:DidacticResource ;
    guide:bibliographyTitle "Test-Driven Development for Embedded C" ;
    guide:bibliographyDescription "James W. Grenning. Complementario, módulo de pruebas." .