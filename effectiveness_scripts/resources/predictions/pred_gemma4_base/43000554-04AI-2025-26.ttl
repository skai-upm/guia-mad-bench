# --- Competencies ---

:comp_MICCPCE38 rdf:type guide:Competency ;
    guide:competencyCode "MICCPCE38"^^xsd:string ;
    guide:competencyDescription "Capacidad para integrar y aplicar los conocimientos técnicos en asesoría, análisis,<0xC2>lama, diseño y modelización físico-matemática en ingeniería estructural."@en .

:comp_MICCPCGP11 rdf:type guide:Competency ;
    guide:competencyCode "MICCPCGP11"^^xsd:string ;
    guide:competencyDescription "Capacidad para el proyecto, ejecución e inspección de estructuras (puentes, edificaciones, etc.), de obras de cimentación y de obras subterráneas de uso civil (túneles, aparcamientos), y el diagnóstico sobre su integridad."@en .

:comp_MICCPCT01 rdf:type guide:Competency ;
    guide:competencyCode "MICCPCT01"^^xsd:string ;
    guide:competencyDescription "Capacidad de preparar y presentar comunicaciones orales, escritas y gráficas, estructurada y argumentadamente."@en .

:comp_MICCPCT03 rdf:type guide:Competency ;
    guide:competencyCode "MICCPCT03"^^xsd:string ;
    guide:competencyDescription "Capacidad de comunicación técnica oral y escrita en lengua inglesa."@en .

:comp_MICCPCT08 rdf:type guide:Competency ;
    guide:competencyCode "MICCRCT08"^^xsd:string ;
    guide:competencyDescription "Capacidad de diseñar, analizar e interpretar experimentos relevantes en ingeniería civil."@en .

# --- Learning Results ---

:lr_RA121 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA121"^^xsd:string ;
    guide:learningResultDescription "The student knows the fundamentals and applications of the most relevant transducers for instrumentation of structures."@en .

:lr_RA12_2 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA122"^^xsd:string ;
    guide:learningResultDescription "The student acquires the fundamentals of static and dynamic experimental techniques in structural engineering, and understands the structural implications of taken measurements."@en .

# --- Syllabus ---

:syllabus_43000554 rdf:type guide:Syllabus ;
    guide:hasItem :item_unit1, :item_unit2, :item_unit3, :item_unit4, :item_unit5, :item_unit6, :item_unit7, :item_unit8, :item_unit9, :item_unit10, :item_unit11, :item_unit12 .

:item_unit1 rdf:type guide:SyllabusItem ;
    guide:itemIndex 1 ;
    guide:syllabusDescription "Introduction to instrumentation"@en .

:item_unit2 rdf:type guide:SyllabusItem ;
    guide:itemIndex 2 ;
    guide:syllabusDescription "Signal conditioning"@en .

:item_unit3 rdf:type guide:SyllabusItem ;
    guide:itemIndex 3 ;
    guide:syllabusDescription "Strain measurement"@en .

# --- Evaluation System and Trials ---

:eval_system_43000554 rdf:type guide:EvaluationSystem ;
    guide:evaluationDescription "Continuous assessment (EM1) and Final exam (EM2)."@en ;
    guide:hasEvaluationTrial :trial_tasks, :trial_final_exam .

:trial_tasks rdf:type guide:EvaluationTrial ;
    guide:trialType "Progressive assessment"@en ;
    guide:evaluationType "progressive"@en ;
    guide:gradePercentage "5.7%"@en ;
    guide:minimumScore "3.5 / 10"@en ;
    guide:trialMode "Not Presential"@en ;
    guide:trialDescription "Resolution and submission of assigned tasks (exercises and case-studies) during the course."@en .

:trial_final_exam rdf:type guide:EvaluationTrial ;
    guide:trialType "Written test"@en ;
    guide:evaluationType "final"@en ;
    guide:gradePercentage "60.1%"@en ;
    guide:minimumScore "3.5 / 10"@en ;
    guide:trialMode "Face-to-face"@en ;
    guide:trialDescription "Final exam consisting of applied theory and practical exercises."@en .

