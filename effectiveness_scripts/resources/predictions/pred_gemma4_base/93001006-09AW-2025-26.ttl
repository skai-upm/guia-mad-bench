# Degree and University Center
:master_ciberseguridad rdf:type guide:MasterDegree ;
    sch:name "09AW - Master Universitario en Ciberseguridad" ;
    guide:degreeCode "09AW" .

:ets_telecomunicacion rdf:type guide:UniversityCenter ;
    sch:name "E.T.S. De Ingenieros De Telecomunicacion" .

:ets_telecomunicacion guide:offers :master_ciberseguridad .

# Course
:servicios_seguridad_red rdf:type guide:Course ;
    sch:name "93001006 - Servicios de Seguridad en Red" ;
    sch:courseCode 93001006 ;
    guide:courseType "Obligatoria" ;
    guide:semester "Primer semestre" ;
    sch:numberOfCredits 3.0 .

# Course Guide
:guia_servicios_seguridad_red rdf:type guide:CourseGuide ;
    sch:name "Guía de Aprendizaje - Servicios De Seguridad En Red" ;
    sch:hasCourseInstance :servicios_seguridad_red ;
    sch:instructor :diego_rivera_pinto ;
    guide:hasSyllabus :syllabus_servicios_seguridad_red ;
    guide:hasEvaluation :eval_system_servicios_seguridad_red ;
    guide:hasCompetency :ce04, :ce05, :cg03 ;
    guide:hasLearningResult :ra10 ;
    sch:inLanguage "Castellano" ;
    guide:teachingPeriod "2:\ 2025-26" ;
    guide:periodStartingMonth "Septiembre" ;
    guide:periodEndingMonth "Enero" ;
    guide:numberOfCredits 3.0 ;
    guide:totalHours "78.0" ; # Based on 26-27 hours per ECTS provided in text
    sch:activitiesWorkload "Estimación de 26-27 horas por crédito ECTS" .

# Faculty
:diego_rivera_pinto rdf:type guide:Lecturer ;
    sch:name "Diego Rivera Pinto" ;
    sch:email "diego.rivera@upm.es" ;
    guide:office "C-216" ;
    guide:tutorshipsSchedule "Sin horario. Concertar cita por correo electrónico." .

