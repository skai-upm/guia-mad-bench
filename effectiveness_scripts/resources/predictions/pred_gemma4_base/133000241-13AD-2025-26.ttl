# Competencies
:Comp_CB09 rdf:type guide:Competency ;
    guide:competencyCode "CB09" ;
    guide:competencyDescription "Que los estudiantes sepan comunicar sus conclusiones y los conocimientos y razones últimas que las sustentan a públicos especializados y no especializados de un modo claro y sin ambigüedades" .

:Comp_CE28 rdf:type guide:Competency ;
    guide:competencyCode "CE 2.8" ;
    guide:competencyDescription "Capacidad para la redacción, dirección y ejecución de Proyectos de Ordenación de Montes" .

:Comp_CE61 rdf:type guide:Competency ;
    guide:competencyCode "CE 6.1" ;
    guide:competencyDescription "Capacidad para la gestion de recursos naturales" .

:Comp_CT02 rdf:type guide:Competency ;
    guide:competencyCode "CT02" ;
    guide:competencyDescription "Integrar los conocimientos previos (propios de grado) de manera crítica y relacionada de forma que se puedan aplicar al estudio de situaciones reales y a la propuesta de alternativas" .

:Comp_CT06 rdf:type guide:Competency ;
    guide:competencyCode "CT06" ;
    guide:competencyDescription "Búsqueda bibliográfica, análisis de documentación y tratamiento de la información procedente de diversas fuentes y de su análisis y síntesis aplicándola a la resolución de problemas complejos" .

# Learning Results
:LR_RA162 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA162" ;
    guide:learningResultDescription "Conocer cómo utilizar la información disponible en la toma de decisiones en gestión forestal." .

:LR_RA163 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA163" ;
    guide:learningResultDescription "Conocer las herramientas de investigación operativa que se pueden utilizar para resolver problemas de gestión forestal." .

:LR_RABB_132 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA132" ;
    guide:learningResultDescription "Conocimiento con sentido crítico del amplio contexto multidisciplinar de la ingeniería y de la interrelación que existe entre los conocimientos de los distintos campos" .

:LR_RA164 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA164" ;
    guide:learningResultDescription "Elaborar proyectos de Ordenación de Montes, planes dasocráticos y otros instrumentos de gestión forestal." .

:LR_RA165 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA165" ;
    guide:learningResultDescription "Analizar y cuantificar la sostenibilidad de la gestión de recursos naturales." .

:LR_RA134 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA134" ;
    guide:learningResultDescription "Capacidad para realizar búsquedas bibliográficas, consultar y utilizar con criterio bases de datos y otras fuentes de información, para llevar a cabo simulaciones con el objetivo de realizar investigaciones sobre temas complejos de su especialidad" .

# Syllabus
:Syllabus_133000241 rdf:type guide:Syllabus ;
    guide:hasItem :SyllabusItem_Unit1, :SyllabusItem_Unit2, :SyllabusItem_Unit3, :SyllabusItem_Unit4 .

:SyllabusItem_Unit1 rdf:type guide:SyllabusItem ;
    guide:itemIndex 1 ;
    guide:syllabusDescription "Introducción a la Ordenación de Montes" .

:SyllabusItem_Unit2 rdf:type guide:SyllabusItem ;
    guide:itemIndex 2 ;
    guide:syllabusDescription "Métodos de decisión: Programación lineal" .

:SyllabusItem_Unit3 rdf:type guide:SyllabusItem ;
    guide:itemIndex 3 ;
    guide:syllabusDescription "Introducción a las técnicas de decisión multicriterio" .

:SyllabusItem_Unit4 rdf:type guide:SyllabusItem ;
    guide:itemIndex 4 ;
    guide:syllabusDescription "Sostenibilidad y uso múltiple" .

