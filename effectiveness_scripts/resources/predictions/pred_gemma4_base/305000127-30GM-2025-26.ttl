### Syllabus
:syllabus_305000127 rdf:type guide:Syllabus ;
    guide:hasItem :item_topic_1, :item_topic_2, :item_topic_3 .

:item_topic_1 rdf:type guide:SyllabusItem ;
    guide:itemIndex 1 ;
    guide:syllabusDescription "Diseño geométrico asistido por ordenador (Curvas y superficies de forma libre)" .

:item_topic_2 rdf:type guide:SyllabustItem ;
    guide:itemIndex 2 ;
    guide:syllabusDescription "Modelización de superficies mínimas" .

:item_topic_3 rdf:type guide:SyllabusItem ;
    guide:itemIndex 3 ;
    guide:syllabusDescription "Métodos geométricos en robótica (Grupos y álgebras de Lie, Manipuladores)" .

### Competencies
:comp_CB2 rdf:type guide:Competency ;
    guide:competencyCode "CB2" ;
    guide:competencyDescription "Que los estudiantes sepan aplicar sus conocimientos a su trabajo o vocación de una forma profesional..." .

:comp_CE1 rdf:type guide:Competency ;
    guide:competencyCode "CE1" ;
    guide:competencyDescription "Comprender y utilizar el lenguaje matemático. Adquirir la capacidad para enunciar propiedades..." .

:comp_CE3 rdf:type guide:Competency ;
    guide:competencyCode "CE3" ;
    guide:competencyDescription "Asimilar la definición de un<0xC2>mac nuevo objeto matemático, en términos de otros ya conocidos..." .

:comp_CE4 rdf:type guide:Competency ;
    guide:competencyCode "CE4" ;
    guide:competencyDescription "Abstraer las propiedades estructurales de objetos matemáticos..." .

:comp_CE6 rdf:type guide:Competency ;
    guide:competencyCode "CE6" ;
    guide:competencyDescription "Proponer, analizar, validar e interpretar modelos matemáticos de sistemas reales..." .

:comp_CE7 rdf:type guide:Competency ;
    guide:competencyCode "CE7" ;
    guide:competencyDescription "Resolver problemas de Matemáticas, mediante habilidades de cálculo básico y tecnologías de computación..." .

:comp_CE8 rdf:type guide:Competency ;
    guide:competencyCode "CE8" ;
    guide:competencyDescription "Utilizar aplicaciones informáticas de análisis estadístico, cálculo numérico y simbólico..." .

:comp_CE9 rdf:type guide:Competency ;
    guide:competencyCode "CE9" ;
    guide:competencyDescription "Desarrollar programas que ejecuten algoritmos de resolución de modelos matemáticos..." .

:comp_CG2 rdf:type guide:Competency ;
    guide:competencyCode "CG2" ;
    guide:competencyDescription "Reconocer la presencia de la Matemática subyacente en la Naturaleza, en la Ciencia, en la Tecnología y en el Arte." .

:comp_CG3 rdf:type guide:Competency ;
    guide:competencyCode "CG3" ;
    guide:competencyDescription "Utilizar las capacidades analíticas y de abstracción, la intuición y el pensamiento lógico..." .

:comp_CG4 rdf:type guide:Competency ;
    guide:competencyCode "CG4" ;
    guide:competencyDescription "Utilizar los conocimientos teóricos y prácticos adquiridos en la definición y planteamiento de problemas..." .

:comp_CG5 rdf:type guide:Competency ;
    guide:competencyCode "CG5" ;
    guide:competencyDescription "Sintetizar conocimientos y habilidades adquiridas en el campo de la matemática..." .

:comp_CT3 rdf:type guide:Competency ;
    guide:competencyCode "CT3" ;
    guide:competencyDescription "Asumir el liderazgo para dirigir y gestionar equipos o proyectos..." .

### Learning Results
:res_RA146 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA146" ;
    guide:learningResultDescription "Programar, realizar e interpretar simulaciones de los modelos utilizados" .

:res_RA193 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA193" ;
    guide:learningResultDescription "Conocer y explicar los usos de las curvas y superficies NURBS para resolver problemas de la vida real." .

:res_RA194 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA194" ;
    guide:learningResultDescription "Identificar superficies mínimas en el espacio tridimensional." .

:res_RA196 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA196" ;
    guide:learningResultDescription "Discretizar superficies y analizar las propiedades geométricas asociadas." .

:res_RA187 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA187" ;
    guide:learningResultDescription "Aplicar las herramientas del cálculo diferencial al estudio de la geometría de curvas y superficies..." .

:res_RA191 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA191" ;
    guide:learningResultDescription "Adquirir conocimientos básicos sobre curvas y superficies NURBS." .

:res_RA192 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA192" ;
    guide:learningResultDescription "Manejar programas de diseño geométrico asistido por ordenador." .

:res_RA198 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA198" ;
    guide:learningResultDescription "Aplicar la teoría helicoidal para describir el movimiento de manipuladores robóticos." .

:res_RA199 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA199" ;
    guide:learningResultDescription "Modelar y simular problemas robóticos sencillos." .

:res_RA197 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA197" ;
    guide:learningResultDescription "Utilizar grupos de Lie y álgebras de Lie para describir la dinámica del sólido rígido." .

