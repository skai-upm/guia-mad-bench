# --- Competencies ---
:CE_SE3 rdf:type guide:Competency ;
    guide:competencyCode "CE-SE3" ;
    guide:competencyDescription "Capacidad de realizar la especificación, implementación, documentación y puesta a punto de equipos y sistemas..." .

:CE_SE5 rdf:type guide:Competency ;
    guide:competencyCode "CE-SE5" ;
    guide:compet competencyDescription "Capacidad de diseñar circuitos de electrónica analógica y digital..." .

:CE_SE8 rdf:type guide:Competency ;
    guide:competencyCode "CE-SE8" ;
    guide:competencyDescription "Capacidad para especificar y utilizar instrumentación electrónica y sistemas de medida" .

:CG10 rdf:type guide:Competency ;
    guide:competencyCode "CG10" ;
    guide:competencyDescription "Creatividad" .

:CG12 rdf:type guide:Competency ;
    guide:competencyCode "CG12" ;
    guide:competencyDescription "Organización y planificación" .

:CG8 rdf:type guide:Competency ;
    guide:competencyCode "CG8" ;
    guide:competencyDescription "Comunicación oral y escrita" .

# --- Learning Results ---
:RA70 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA70" ;
    guide:learningResultDescription "Conocimientos de dispositivos, circuitos, equipos y sistemas electrónicos." .

:RA210 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA210" ;
    guide:learningResultDescription "Realizar una documentación técnica completa sobre el diseño realizado..." .

# --- Syllabus ---
:Syllabus_Circuitos rdf:type guide:Syllabus ;
    guide:hasItem :Topic_1, :Topic_2, :Topic_3, :Topic_4 .

:Topic_1 rdf:type guide:SyllabusItem ;
    guide:itemIndex 1 ;
    guide:syllabusDescription "Descripción del sistema electrónico a diseñar" .

:Topic_2 rdf:type guide:SyllabusItem ;
    guide:itemIndex 2 ;
    guide:syllabusDescription "Desarrollo de la parte analógica (Distribución de la alimentación, Reglas generales de montaje, Implementación de los módulos, Búsqueda y solución de problemas)" .

:Topic_3 rdf:type guide:SyllabusItem ;
    guide:itemIndex 3 ;
    guide:syllabusDescription "Desarrollo de la parte digital (Familiarización con el entorno de desarrollo, Simulación de circuitos VHDL, Síntesis de la parte digital, Búsqueda y solución de problemas)" .

:Topic_4 rdf:type guide:SyllabusItem ;
    guide:itemIndex 4 ;
    guide:syllabusDescription "Elaboración de documentación técnica" .

# --- Evaluation System ---
:EvalSystem_Circuitos rdf:type guide:EvaluationSystem ;
    guide:evaluationDescription "La evaluación progresiva tendrá en cuenta el seguimiento del desarrollo del proyecto por parte del profesor." ;
    guide:hasEvaluationTrial :Trial_Presentation, :Trial_Validation, :Trial_Exam .

:Trial_Presentation rdf:type guide:EvaluationTrial ;
    guide:trialType "Trabajo en Grupo" ;
    guide:trialMode "No Presencial" ;
    guide:evaluationType "progresiva" ;
    guide:gradePercentage "20%" ;
    guide:trialWeek "12" ;
    guide:hasScheduleEvent :Event_Presentation .

:Trial_Validation rdf:type guide:EvaluationTrial ;
    guide:trialType "Examen de Prácticas" ;
    guide:trialMode "Presencial" ;
    guide:evaluationType "progresiva" ;
    guide:gradePercentage "30%" ;
    guide:trialWeek "13" ;
    guide:hasScheduleEvent :Event_Validation .

:Trial_Exam rdf:type guide:EvaluationTrial ;
    guide:trialType "Examen Escrito" ;
    guide:trialMode "Presencial" ;
    guide:evaluationType "progresiva" ;
    guide:gradePercentage "50%" ;
    guide:minimumScore "3 / 10" ;
    guide:trialWeek "17" ;
    guide:hasScheduleEvent :Event_Exam .

# --- Schedule & Events ---
:Schedule_Circuitos rdf:type guide:Schedule ;
    sch:eventSchedule :Event_Lab_Week2, :Event_Presentation, :Event_Validation, :Event_Exam .

:Event_Lab_Week2 rdf:type guide:ScheduleEvent ;
    guide:eventIndex 2 ;
    guide:eventWeek "Semana 2" ;
    guide:hasActivity :Activity_Lab_Practice .

:Activity_Lab_Practice rdf:type guide:Activity ;
    guide:activityDescription "Familiarización con los sistemas del laboratorio" ;
    guide:activityFormat "Prácticos de Laboratorio" ;
    guide:attendanceType "Presencial" ;
    guide:activityDuration 2.5 .

:Event_Presentation rdf:type guide:ScheduleEvent ;
    guide:eventIndex 12 ;
    guide:eventWeek "Semana 12" ;
    guide:hasActivity :Activity_Presentation .

:Activity_Presentation rdf:type guide:Activity ;
    guide:activityDescription "Presentación de la documentación técnica y medidas del circuito completo" ;
    guide:activityFormat "Trabajo en Grupo" ;
    guide:attendanceType "No presencial" .

:Event_Validation rdf:type guide:ScheduleEvent ;
    guide:eventIndex 13 ;
    guide:eventWeek "Semana 13" ;
    guide:hasActivity :Activity_Validation .

:Activity_Validation rdf:type guide:Activity ;
    guide:activityDescription "Prueba de validación del funcionamiento del circuito" ;
    guide:activityFormat "Examen de Prácticas" ;
    guide:attendanceType "Presencial" .

:Event_Exam rdf:type guide:ScheduleEvent ;
    guide:eventIndex 17 ;
    guide:eventWeek "Semana 17" ;
    guide:hasActivity :Activity_Written_Exam .

:Activity_Written_Exam rdf:type guide:Activity ;
    guide:activityDescription "Examen escrito" ;
    guide:activityFormat "Examen Escrito" ;
    guide:attendanceType "Presencial" ;
    guide:activityDuration 1.5 .

