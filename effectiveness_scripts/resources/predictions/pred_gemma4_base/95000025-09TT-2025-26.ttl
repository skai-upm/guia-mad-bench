:Res_Wakerly rdf:type guide:DidacticResource ;
    guide:bibliographyTitle "Digital Design" ;
    guide:bibliographyType "Bibliografía" ;
    guide:bibliographyDescription "J.F. Wakerly 4ª edición, Prentice Hall, 2005" .

:Res_Ferreiros rdf:type guide:DidacticResource ;
    guide:bibliographyTitle "Aspectos prácticos de diseño y medida en Laboratorios de Electrónica" ;
    guide:bibliographyType "Bibliografía" ;
    guide:bibliographyDescription "2ª ed, Autores: J. Ferreiros et al." .

:Res_Oppenheim rdf:type guide:DidacticResource ;
    guide:bibliographyTitle "Señales y Sistemas" ;
    guide:bibliographyType "Bibliografía" ;
    guide:bibliographyDescription "Alan V. Oppenheim y Alan S. Willsky, 2ª edición, Prentice-Hall, 1998" .

:Res_Malik rdf:type guide:DidacticResource ;
