# --- University Center ---
:ETS_Telecomunicacion rdf:type guide:UniversityCenter ;
    sch:name "E.T.S. de Ingenieros de Telecomunicación" .

# --- Degree ---
:Grado_Ingenieria_Telecoms rdf:type guide:BachelorDegree ;
    sch:name "09TT - Grado en Ingeniería de Tecnologías y Servicios de Telecomunicación" ;
    guide:degreeCode "09TT" .

:ETS_Telecomunicacion guide:offers :Grado_Ingenieria_Telecoms .

# --- Course ---
:Circuitos_Electronicos rdf:type guide:Course ;
    sch:name "95000025 - Circuitos Electrónicos" ;
    sch:courseCode 95000025 ;
    guide:courseYear 2025 ;
    guide:courseType "Obligatoria" ;
    guide:semester "Quinto semestre" ;
    sch:hasCourseInstance :Guia_Aprendizaje_Circuitos .

:Grado_Ingenieria_Telecoms guide:hasCourse :Circuitos_Electronicos .

# --- Course Guide ---
:Guia_Aprendizaje_Circuitos rdf:type guide:CourseGuide ;
    sch:name "Guía de Aprendizaje - Circuitos Electrónicos" ;
    sch:inLanguage "Castellano" ;
    guide:teachingPeriod "2025-26" ;
    guide:teachingPeriodMonths "Septiembre-Enero" ;
    guide:numberOfCredits 3.0 ;
    guide:totalHours "78.0" ; # Based on 3 ECTS * ~26 hours
    guide:inpersonHours "..." ;
    guide:remoteHours "..." ;
    sch:description "Esta es una asignatura que sigue un esquema de aprendizaje basado en proyecto (PBL). El objetivo es aprender la metodología para el diseño de un prototipo consistente en un sistema electrónico analógico-digital." ;
    guide:hasSyllabus :Syllabus_Circuitos ;
    guide:hasEvaluation :EvalSystem_Circuitos ;
    guide:hasCompetency :CE_SE3, :CE_SE5, :CE_SE8, :CG10, :CG12, :CG8 ;
    guide:hasLearningResult :RA70, :RA210, :RA555, :RA73, :RA556, :RA209, :RA554, :RA553, :RA71, :RA552, :RA75 ;
    guide:hasDidacticResource :Res_Moodle, :Res_Manual_BASYS, :Res_Franco, :Res_Wakerly, :Res_Ferreiros, :Res_Oppenheim, :Res_Malik ;
    sch:instructor :Prof_Dharo, :Prof_Sanchez, :Prof_Nieto, :Prof_Alvaro, :Prof_Bosca, :Prof_Lopez ;
    sch:courseSchedule :Schedule_Circuitos .

