:Res_Moodle rdf:type guide:DidacticResource ;
    guide:bibliographyTitle "Pagina web de Moodle de la asignatura" ;
    guide:bibliographyType "Recursos web" ;
    guide:bibliographyDescription "Contiene el enunciado, ficheros necesarios, manuales..." .

:Res_Manual_BASYS rdf:type guide:DidacticResource ;
    guide:bibliographyTitle "Manual de referencia de la tarjeta BASYS-2" ;
    guide:bibliographyType "Recursos web" ;
    guide:bibliographyDescription "Tutorial de la placa con la FPGA con ejemplos ilustrativos." .

:Res_Franco rdf:type guide:DidacticResource ;
    guide:bibliographyTitle "Design with Operational Amplifiers and Analog Integrated Circuits" ;
    guide:bibliographyType "Bibliografía" ;
