    guide:hasCompetency guide:MICCPCE27, guide:MICCPCE30, guide:MICCPCE33, guide:MICCPCE35, guide:MICCPCE37, guide:MICCPCGP01, guide:MICCPCGP02, guide:MICCPCGP05, guide:MICCPCGP06, guide:MICCPCGP07, guide:MICCPCGP10, guide:MICCPCGP12, guide:MICCPCGP15, guide:MICCPCGP18, guide:MICCPCT01, guide:MICCPCT08, guide:MSICCG05 ;
    guide:hasLearningResult guide:RA124, guide:RA114, guide:RA99, guide:RA60, guide:RA12, guide:RA107, guide:RA118 ;
    sch:instructor guide:Vicente_Negro_Valdecantos, guide:Jose_Santos_Lopez_Gutierrez, guide:Pedro_Fernandez_Carrasco, guide:Maria_Dolores_Esteban_Perez ;
    sch:director guide:Jose_Santos_Lopez_Gutierrez ;
    guide:hasEvaluation guide:EvalSystem_MarineEnergies ;
    guide:hasDidacticResource guide:Res_Esteban_2009, guide:Res_Coastal_Eng_Manual, guide:Res_Twidell_2009, guide:Res_BSH_2007, guide:Res_Charlier_2009, guide:Res_Cruz_2008, guide:Res_DNV_2011, guide:Res_Esteban_2011, guide:Res_Germanischer_Lloyd, guide:Res_IEC_61400_3, guide:Res_IEC_61400_3_2, guide:Res_Ley_2_2013, guide:Res_Lynn_2014, guide:Res_Matutano_2013, guide:Res_Multon_2011, guide:Res_Negro_2014 ;
    sch:activitiesWorkload "26-27 hours per ECTS" .

