    sch:hasCourseInstance guide:Course_43000562 ;
    sch:name "Marine Energies - 2025/26" ;
    sch:inLanguage "Castellano" ;
    guide:teachingPeriod "2025-26" ;
    guide:periodStartingMonth "Febrero" ;
    guide:periodEndingMonth "Junio" ;
    guide:numberOfCredits 4.5 ;
    sch:description "This subject is optional within the specialty of Hydraulics, Energy and Environment. The course offers an overview of the use of renewable energies in the marine environment such as waves, currents, tides or wind."@en ;
