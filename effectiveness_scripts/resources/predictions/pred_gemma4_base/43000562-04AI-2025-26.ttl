# --- Competencies ---
guide:MICCPCE27 rdf:type guide:Competency ; guide:competencyCode "MICCPCE27" ; guide:competencyDescription "Conocimientos y capacidades que permiten comprender los fenómenos dinámical..."@en .
guide:MICCPCE30 rdf:type guide:Competency ; guide:competencyCode "MICCPCE30" ; guide:competencyDescription "Capacidad de planificación, gestión y explotación de infraestructuras..."@en .
guide:MICCPCE33 rdf:type guide:Competency ; guide:competencyCode "MICCPCE33" ; guide:competencyDescription "Capacidad para aplicar los conocimientos técnicos en actividades de I+D+i..."@en .
guide:MICCPCE35 rdf:type guide:Competency ; guide:competencyCode "MICCPCE35" ; guide:competencyDescription "Capacidad para integrar y aplicar los conocimientos técnicos en asesoría, análisis..."@en .
guide:MICCPCE37 rdf:type guide:Competency ; guide:competencyCode "MICCPCE37" ; guide:competencyDescription "Capacidad para integrar y aplicar los conocimientos técnicos en asesoría... efectos medioambientales..."@en .
guide:MICCPCGP01 rdf:type guide:Competency ; guide:competencyCode "MICCPCGP01" ; guide:competencyDescription "Capacitación científico-técnica y metodológica para el reciclaje continuo..."@en .
guide:MICCPCGP02 rdf:type guide:Competency ; guide:competencyCode "MICCPCGP02" ; guide:competencyDescription "alternativas válidas, elegir la óptima..."@en .
guide:MICCPCGP05 rdf:type guide:Competency ; guide:competencyCode "MICCPCGP05" ; guide:competencyDescription "Conocimiento de la profesión de Ingeniero de Caminos..."@en .
guide:MICCPCGP06 rdf:type guide:Competency ; guide:competencyCode "MICCPCGP06" ; guide:competencyDescription "Conocimiento para aplicar las capacidades técnicas y gestoras en actividades de I+D+i..."@en .
guide:MICCPCGP07 rdf:type guide:Competency ; guide:competencyCode "MICCPCGP07" ; guide:competencyDescription "Capacidad para planificar, proyectar, inspeccionar y dirigir obras..."@en .
guide:MICCPCGP10 rdf:type guide:Competency ; guide:loscompetencyCode "MICCPCGP10" ; guide:competencyDescription "Capacidad para la realización de estudios de planificación territorial..."@en .
guide:MICCPCGP12 rdf:type guide:Competency ; guide:competencyCode "MICCPCGP12" ; guide:competencyDescription "Capacidad para planificar, diseñar y gestionar infraestructuras..."@en .
guide:MICCPCGP15 rdf:type guide:Compet competencyCode "MICCPCGP15" ; guide:competencyDescription "Capacidad para evaluar y acondicionar medioambientalmente las obras..."@en .
guide:MICCPCGP18 rdf:type guide:Competency ; guide:competencyCode "MICCPCGP18" ; guide:competencyDescription "Conocimientos adecuados de los aspectos científicos y tecnológicos..."@en .
guide:MICCPCT01 rdf:type guide:Competency ; guide:competencyCode "MICCPCT01" ; guide:competencyDescription "Capacidad de preparar y presentar comunicaciones orales, escritas y gráficas..."@en .
guide:MICCPCT08 rdf:type guide:Competency ; guide:competencyCode "MICCPCT08" ; guide:competencyDescription "Capacidad de diseñar, analizar e interpretar experimentos relevantes..."@en .
guide:MSICCG05 rdf:type guide:Competency ; guide:competencyCode "MSICCG05" ; guide:competencyDescription "Uso de la lengua inglesa"@en .

# --- Learning Results ---
guide:RA124 rdf:type guide:LearningResult ; guide:learningResultCode "RA124" ; guide:learningResultDescription "Explica, conoce y tiene capacidad para conocer los aspectos técnicos..."@en .
guide:RA114 rdf:type guide:LearningResult ; guide:learningResultCode "RA114" ; guide:learningResultDescription "Capacidad para analizar y sintetizar los diversos contenidos de información..."@en .
guide:RA99 rdf:type guide:LearningResult ; guide:learningResultCode "RA99" ; guide:learningResultDescription "Analizar con carácter crítico la parte metodológica de un proyecto de investigación..."@en .
guide:RA60 rdf:type guide:LearningResult ; guide:learningResultCode "RA60" ; guide:learningResultDescription "Conocer el medio marino y los recursos oceanicos"@en .
guide:RA12 rdf:type guide:LearningResult ; guide:learningResultCode "RA12" ; guide:learningResultDescription "Planifica, proyecta, dirige y gestiona obras marítimas..."@en .
guide:RA107 rdf:type guide:LearningResult ; guide:learningResultCode "RA107" ; guide:learningResultDescription "Comunicar y exponer las conclusiones de sus análisis a un público científico"@en .
guide:RA118 rdf:type guide:LearningResult ; guide:learningResultCode "RA118" ; guide:learningResultDescription "Capacidad para comunicarse de forma escrita y oral"@en .

# --- Syllabus ---
guide:Syllabus_MarineEnergies rdf:type guide:Syllabus ;
    guide:hasItem guide:Unit1, guide:Unit2, guide:Unit3, guide:Unit4, guide:Unit5, guide:Unit6, guide:Unit7, guide:Unit8, guide:Unit9, guide:Unit10 .

guide:Unit1 rdf:type guide:SyllabusItem ; guide:itemIndex 1 ; guide:syllabusDescription "Introduction" .
guide:Unit2 rdf:type guide:SyllabusItem ; guide:itemIndex 2 ; guide:syllabusDescription "Technologies for the exploitation of marine energy" .
guide:Unit3 rdf:type guide:SyllabusItem ; guide:itemIndex 3 ; guide:syllabusDescription "Energy resource" .
guide:Unit4 rdf:type guide:SyllabusItem ; guide:itemIndex 4 ; guide:syllabusDescription "Components of an installation" .
guide:Unit5 rdf:type guide:SyllabusItem ; guide:itemIndex 5 ; guide:syllabusDiscription "Foundations and supporting structures" .
guide:Unit6 rdf:type guide:SyllabusItem ; guide:itemIndex 6 ; guide:syllabusDescription "Construction and operation phases" .
guide:Unit7 rdf:type guide:SyllabusItem ; guide:itemIndex 7 ; guide:syllabusDescription "Environmental impact" .
guide:Unit8 rdf:type guide:SyllabusItem ; guide:itemIndex 8 ; guide:syllabusDescription "Other aspects" .
guide:Unit9 rdf:type guide:SyllabusItem ; guide:itemIndex 9 ; guide:syllabusDescription "Minority marine energies" .
guide:Unit10 rdf:type guide:SyllabusItem ; guide:itemIndex 10 ; guide:syllabusDescription "The future of marine energies" .

