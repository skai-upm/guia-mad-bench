# --- Competencies ---

data:CE12 rdf:type guide:Competency ;
    guide:competencyCode "CE12" ;
    guide:competencyDescription "Capacidad para utilizar dispositivos lógicos programables, así como para diseñar sistemas electrónicos avanzados, tanto analógicos como digitales. Capacidad para diseñar componentes de comunicaciones como por ejemplo encaminadores, conmutadores, concentradores, emisores y receptores en diferentes bandas." .

data:CE15 rdf:type guide:Competency ;
    guide:competencyCode "CE15" ;
    guide:competencyDescription "Capacidad para la integración de tecnologías y sistemas propios de la Ingeniería de Telecomunicación, con carácter generalista, y en contextos más amplios y multidisciplinares como por ejemplo en bioingeniería, conversión fotovoltaica, nanotecnología, telemedicina." .

data:CG2 rdf:type guide:Competency ;
    guide:competencyCode "CG2" ;
    guide:competencyDescription "Que los estudiantes sepan aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en entornos nuevos o poco conocidos dentro de contextos más amplios (o multidisciplinares) relacionados con su área de estudio." .

# --- Learning Results ---

data:RA116 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA116" ;
    guide:learningResultDescription "Diseñar e implementar aplicaciones reales usando plataformas de diseño basadas en procesadores avanzados" .

data:RA218 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA218" ;
    guide:learningResultDescription "Analizar y diseñar el software de un sistema electrónico" .

data:RA217 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA217" ;
    guide:learningResultDescription "Analizar la fiabilidad de un sistema electrónico y diseñar sistemas en base a restricciones de fiabilidad" .

data:RA115 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA115" ;
    guide:learningResultDescription "Implementar aplicaciones sobre un Sistema Operativo de tiempo real en sistemas avanzados de procesadores" .

data:RA327 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA327" ;
    guide:learningResultDescription "Conocimientos cualitativos y cuantitativos del diseño de sistemas electrónicos" .

data:RA215 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA215" ;
    guide:learningResultDescription "Analizar y diseñar sistemas electrónicos teniendo en cuenta aspectos de compatibilidad electromagnética" .

# --- Syllabus ---

data:Syllabus_IoT rdf:type guide:Syllabus ;
    guide:hasItem data:Topic_1, data:Topic_2, data:Topic_3, data:Topic_4, data:Topic_5, data:Topic_6 .

data:Topic_1 rdf:type guide:SyllabusItem ;
    guide:itemIndex 1 ;
    guide:syllabusDescription "Introducción a los sistemas empotrados (Aplicaciones, Ejemplo motivante, Proceso de diseño)" .

data:Topic_2 rdf:type guide:SyllabusItem ;
    guide:itemIndex 2 ;
    guide:syllabusDescription "Diseño hardware de sistemas empotrados (Microcontroladores, Arquitectura de memoria, Entrada/Salidad)" .

data:Topic_3 rdf:type guide:SyllabusItem ;
    guide:itemIndex 3 ;
    guide:syllabusDescription "Diseño software de sistemas empotrados (Capa de abstracción hardware y BSP, Sistemas Operativos para un único núcleo, Tareas, Mecanismos de comunicación entre procesos)" .

data:Topic_4 rdf:type guide:SyllabusItem ;
    guide:itemIndex 4 ;
    guide:syllabusDescription "Sistemas en tiempo real (Métodos de planificación en tiempo real, Ejecutivo cíclico, Planificación con prioridades)" .

data:Topic_5 rdf:type guide:SyllabusItem ;
    guide:itemIndex 5 ;
    guide:syllabusDescription "Entorno de pruebas para sistemas empotrados (Diseño orientado a test, Diseño guiado por test, Test unitarios, Test de integración, Modularización y abstracción)" .

data:Topic_6 rdf:type guide:SyllabusItem ;
    guide:itemIndex 6 ;
    guide:syllabusDescription "Seguridad en Sistemas Empotrados (Protección de código, Integridad y privacidad, Ataques, Mejoras arquitecturales)" .

# --- Evaluation System ---

data:EvalSystem_IoT rdf:type guide:EvaluationSystem ;
    guide:evaluationDescription "La asignatura se aprobará con una calificación >= 5. La evaluación consta de modalidades progresiva y global." ;
    guide:hasEvaluationTrial data:Trial_Prog_P0, data:Trial_Prog_P1, data:Trial_Prog_P2, data:Trial_Prog_P3, data:Trial_Prog_Exam, data:Trial_Glob_Exam, data:Trial_Glob_P4, data:Trial_Glob_P5 .

data:Trial_Prog_P0 rdf:type guide:EvaluationTrial ;
    guide:trialType "Práctica 0" ;
    guide:evaluationType "progresiva" ;
    guide:gradePercentage "5%" ;
    guide:minimumScore "5/10" ;
    guide:trialMode "No presencial" .

data:Trial_Prog_P1 rdf:type guide:EvaluationTrial ;
    guide:trialType "Práctica 1" ;
    guide:evaluationType "progresiva" ;
    guide:gradePercentage "15%" ;
    guide:minimumScore "5/10" ;
    guide:trialMode "No presencial" .

data:Trial_Prog_Exam rdf:type guide:EvaluationTrial ;
    guide:trialType "Examen para evaluación progresiva" ;
    guide:evaluationType "progresiva" ;
    guide:gradePercentage "50%" ;
    guide:minimumScore "5/10" ;
    guide:trialMode "Presencial" .

data:Trial_Glob_Exam rdf:type guide:EvaluationTrial ;
    guide:trialType "Examen global" ;
    guide:evaluationType "global" ;
    guide:gradePercentage "70%" ;
    guide:minimumScore "5/10" ;
    guide:trialMode "Presencial" .

