### Competencies
:comp_12TG_CG8 a guide:Competency ;
    guide:competencyCode "12TG-CG8" ;
    guide:competencyDescription "Diseñar, desarrollar, gestionar y ejecutar proyectos relacionados con esta ingeniería en el ámbito de la investigación, innovación o producción" .

:comp_12TG_CIST1 a guide:Competency ;
    guide:competencyCode "12TG-CIST1" ;
    guide:competencyDescription "Conocimiento y utilización de los conceptos de arquitectura de red, protocolos e interfaces de comunicaciones" .

:comp_CT1 a guide:Competency ;
    guide:competencyCode "CT1" ;
    guide:competencyDescription "COMUNICACIÓN ORAL Y ESCRITA Capacidad para transmitir conocimientos y expresar ideas y argumentos..." .

:comp_CT10 a guide:Competency ;
    guide:competencyCode "CT10" ;
    guide:competencyDescription "ANÁLISIS Y SÍNTESIS Capacidad de reconocer y describir los elementos constitutivos de una realidad..." .

:comp_CT2 a guide:Competency ;
    guide:competencyCode "CT2" ;
    guide:competencyDescription "USO DE LAS TIC Capacidad sobre conocimientos tecnológicos que permitan desenvolverse cómodamente..." .

:comp_CT9 a guide:Competency ;
    guide:competencyCode "CT9" ;
    guide:competencyDescription "RESOLUCIÓN DE PROBLEMAS Desarrollar en los alumnos una actitud mental mediante la aplicación de procedimientos estructurados..." .

### Learning Results
:lr_RA218 a guide:LearningResult ; guide:learningResultCode "RA218" ; guide:learningResultDescription "Contextualizar las redes de área local en la arquitectura Internet." .
:lr_RA221 a guide:LearningResult ; guide:learningResultCode "RA221" ; guide:learningResultDescription "Identificar los elementos de las redes de telecomunicación" .
:lr_RA229 a guide:LearningResult ; guide:learningResultCode "RA229" ; guide:learningResultDescription "Describir los servicios, mecanismos y protocolos de seguridad empleados en las redes de telecomunicación." .
:lr_RA228 a guide:LearningResult ; guide:learningResultCode "RA228" ; guide:learningResultDescription "Describir los protocolos del nivel de red Internet." .
:lr_RA219 a guide:LearningResult ; guide:learningResultCode "RA219" ; guide:learningResultDescription "Explicar las principales amenazas y ataques a la seguridad en las redes de telecomunicación." .
:lr_RA220 a guide:LearningResult ; guide:learningResultCode "RA220" ; guide:learningResultDescription "Identificar los dispositivos de interconexión en redes de área local." .
:lr_RA222 a guide:LearningResult ; guide:learningResultCode "RA222" ; guide:learningResultDescription "Describir los protocolos del nivel de transporte de Internet" .
:lr_RA224 a guide:LearningResult ; guide:learningResultCode "RA224" ; guide:learningResultDescription "Diferenciar los elementos de interconexión en Internet" .
:lr_RA226 a guide:LearningResult ; guide:learningResultCode "RA226" ; guide:learningResultDescription "Clasificar las redes de telecomunicación atendiendo al ámbito geográfico" .
:lr_RA230 a guide:LearningResult ; guide:learningResultCode "RA230" ; guide:learningResultDescription "Describir las características y el modo de funcionamiento de Ethernet" .
:lr_RA225 a guide:LearningResult ; guide:learningResultCode "RA225" ; guide:learningResultDescription "Describir los principales servicios y aplicaciones de Internet" .
:lr_RA223 a guide:LearningResult ; guide:learningResultCode "RA223" ; guide:learningResultDescription "Reconocer la necesidad de modelos estratificados de arquitecturas de comunicación" .
:lr_RA227 a guide:LearningResult ; guide:learningResultCode "RA227" ; guide:learningResultDescription "Indicar la estructura de organismos implicados en la organización de Internet" .
:lr_RA231 a guide:LearningResult ; guide:learningResultCode "RA231" ; guide:learningResultDescription "Contextualizar las redes de área local en la arquitectura Internet" .

### Syllabus
:syllabus_125009030 a guide:Syllabus ;
    guide:hasItem :item_unit1, :item_unit2, :item_unit3, :item_unit4, :item_unit5, :item_prac1, :item_prac2, :item_prac3 .

:item_unit1 a guide:SyllabusItem ; guide:itemIndex 1 ; guide:syllabusDescription "UNIDAD 1: INTRODUCCIÓN A LAS REDES DE TELECOMUNICACIÓN" .
:item_unit2 a guide:SyllabusItem ; guide:itemIndex 2 ; guide:syllabusDescription "UNIDAD 2: ARQUITECTURAS DE COMUNICACIÓN ESTRATIFICADAS EN NIVELES" .
:item_unit3 a guide:SyllabusItem ; guide:itemIndex 3 ; guide:syllabusDescription "UNIDAD 3: LA CAPA DE ENLACE Y REDES DE ÁREA LOCAL" .
:item_unit4 a guide:SyllabusItem ; guide:itemIndex 4 ; guide:syllabusDescription "UNIDAD 4: LA CAPA DE RED" .
:item_unit5 a guide:SyllabusItem ; guide:itemIndex 5 ; guide:syllabusDescription "UNIDAD 5: INTRODUCCIÓN A LAS APLICACIONES Y SERVICIOS DE INTERNET" .
:item_prac1 a guide:SyllabusItem ; guide:itemIndex 6 ; guide:syllabusDescription "PRÁCTICA 1: Análisis de protocolos. WireShark" .
:item_prac2 a guide:SylllabusItem ; guide:itemIndex 7 ; guide:syllabusDescription "PRÁCTICA 2: Análisis y diseño de un protocolo de comunicación (NOC y OC)" .
:item_prac3 a guide:SyllabusItem ; guide:itemIndex 8 ; guide:syllabusDescription "PRÁCTICA 3: El protocolo HTTP" .

