:comp_ce_b2 rdf:type guide:Competency ;
    guide:competencyCode "CE B2" ;
    guide:competencyDescription "Conocimientos básicos sobre el uso y programación de los ordenadores, sistemas operativos, bases de datos y programas informáticos con aplicación en ingeniería." .

:comp_ce_tel01 rdf:type guide:Competency ;
    guide:competencyCode "CE TEL01" ;
    guide:competencyDescription "Capacidad para aprender de manera autónoma nuevos conocimientos y técnicas adecuados para la concepción, el desarrollo o la explotación de sistemas y servicios de telecomunicación." .

:comp_ce_tel02 rdf:type guide:Competency ;
    guide:competencyCode "CE TEL02" ;
    guide:competencyDescription "Capacidad de utilizar aplicaciones de comunicación e informáticas para apoyar el desarrollo y explotación de redes, servicios y aplicaciones de telecomunicación y electrónica." .

:comp_comp_ce_tel03 rdf:type guide:Competency ;
    guide:competencyCode "CE TEL03" ;
    guide:competencyDescription "Capacidad para utilizar herramientas informáticas de búsqueda de recursos bibliográficos o de información relacionada con las telecomunicaciones y la electrónica." .

:comp_ce_tel07 rdf:type guide:Competency ;
    guide:competencyCode "CE TEL07" ;
    guide:competencyDescription "Conocimiento y utilización de los fundamentos de la programación en redes, sistemas y servicios de telecomunicación." .

:comp_cg_03 rdf:type guide:Competency ;
    guide:competencyCode "CG 03" ;
    guide:competencyDescription "Capacidad para expresarse correctamente de forma oral y escrita y transmitir información mediante documentos y exposiciones en público." .

:comp_cg_10 rdf:type guide:Competency ;
    guide:competencyCode "CG 10" ;
    guide:competencyDescription "Capacidad para manejar especificaciones, reglamentos y normativas y la aplicación de las mismas en el desarrollo de la profesión." .

:lr_ra1463 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA1463" ;
    guide:learningResultDescription "Entender cómo realizar un modelado de datos de cualquier aspecto de la realidad e implementarlo sobre diversas tecnologías de bases de datos relacionales" .

:lr_ra1462 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA1462" ;
    guide:learningResultDescription "Dominar los principios de una arquitectura basada en servicios para darles soporte y aplicar los elementos técnicos necesarios para implantarla..." .

:lr_ra1464 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA1464" ;
    guide:learningResultDescription "Construir modelos y transformaciones a estos modelos para su aplicación en el desarrollo y operación de los servicios..." .

