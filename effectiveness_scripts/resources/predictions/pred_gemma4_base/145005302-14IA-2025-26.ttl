# Competencies
:comp_ce67 rdf:type guide:Competency ;
    guide:competencyCode "CE67" ;
    guide:competencyDescription "Conocimiento adecuado y aplicado a la Ingeniería de: Las instalaciones eléctricas y electrónicas." .

:comp_ce71 rdf:type guide:Competency ;
    guide:competencyCode "CE71" ;
    guide:competencyDescription "Conocimiento aplicado de: Transmisores y receptores; Líneas de transmisión y sistemas radiantes..." .

:comp_cg3 rdf:type guide:Competency ;
    guide:competencyCode "CG3" ;
    guide:competencyDescription "Capacidad para identificar y resolver problemas aplicando, con creatividad, los conocimientos adquiridos." .

:comp_cg9 rdf:type guide:Competency ;
    guide:competencyCode "CG9" ;
    guide:competencyDescription "Razonamiento crítico y capacidad de asociación que posibiliten el aprendizaje continuo." .

# Learning Results
:lr_ra144 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA144" ;
    guide:learningResultDescription "Conocimiento, comprensión, aplicación, análisis y síntেরesis de los fundamentos... de los sistemas eléctricos..." .

:lr_ra143 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA143" ;
    guide:learningResultDescription "Aplicación de las técnicas utilizadas en el laboratorio y conocimiento de las medidas de seguridad dispuestas." .

# Didactic Resources
:res_moodle rdf:type guide:DidacticResource ;
