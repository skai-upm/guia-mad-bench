# Course Guide Instance
:course_guide_inst_elec rdf:type guide:CourseGuide ;
    sch:name "Guía de Aprendizaje - Instalaciones Eléctricas" ;
    sch:description "En esta asignatura se estudia la configuración y el funcionamiento de los sistemas eléctricos de las enseñanzas aeronáuticas." ;
    guide:teachingPeriod "2025-26" ;
    guide:periodStartingMonth "Septiembre" ;
    guide:periodEndingMonth "Enero" ;
    guide:numberOfCredits 4.5 ;
    sch:inLanguage "Castellano" ;
    guide:hasSyllabus :syllabus_inst_elec ;
    guide:hasEvaluation :eval_system_inst_elec ;
    guide:hasLearningResult :lr_ra144, :lr_ra143 ;
    guide:hasCompetency :comp_ce67, :comp_ce71, :comp_cg3, :comp_cg9 ;
    guide:hasDidacticResource :res_moodle, :res_book_sanjurjo, :res_book_pallet, :res_book_toole, :res_book_eismin, :res_book_martinez ;
    sch:instructor :prof_victoria ;
    sch:courseSchedule :schedule_inst_el_2526 ;
    sch:activitiesWorkload "Entre 26 y 27 horas de trabajo presencial y no presencial por cada crédito ECTS" .

# Course Instance
:course_inst_elec rdf:type guide:Course ;
    sch:name "145005302 - Instalaciones Electricas" ;
    sch:courseCode 145005302 ;
    guide:courseType "Obligatoria" ;
    guide:courseYear 3 ;
    guide:semester "Quinto semestre" .

# Degree Instance
:degree_aeroespacial rdf:type guide:BachelorDegree ;
    sch:name "14IA - Grado En Ingeniería Aeroespacial" ;
    guide:degreeCode "14IA" ;
    guide:hasCourse :course_inst_elec .

# University Center Instance
:center_etsi_aeronautica rdf:type guide:UniversityCenter ;
    sch:name "E.T.S.I. Aeronáutica y del Espacio" ;
    guide:offers :degree_aeroespacial .

# Lecturer Instance
:prof_victoria rdf:type guide:Lecturer ;
    sch:name "M Victoria Alonso Maldonado" ;
    sch:email "mariavictoria.alonso@upm.es" ;
    guide:office "A-208" ;
    guide:tutorshipsSchedule "Sin horario definido al inicio del curso." .

# Syllabus Instance
:syllabus_inst_elec rdf:type guide:Syllabus ;
    guide:hasItem :item_topic1, :item_topic2, :item_topic3, :item_topic4, :item_topic5, :item_topic6, :item_topic7, :item_topic8, :item_topic9, :item_topic10, :item_topic11, :item_topic12 .

:item_topic1 rdf:type guide:SyllabusItem ; guide:itemIndex 1 ; guide:syllabusDescription "LA ENERGÍA ELÉCTRICA EN LAS AERONAVES" .
:item_topic2 rdf:type guide:SyllabusItem ; guide:itemIndex 2 ; guide:syllabusDescription "CONFIGURACIÓN DEL SISTEMA ELÉCTRICO" .
:item_topic3 rdf:type guide:SyllabusItem ; guide:itemIndex 3 ; guide:syllabusDescription "LOS CONSUMIDORES ELÉCTRICOS" .
:item_topic4 rdf:type guide:SyllabusItem ; guide:itemIndex 4 ; guide:syllabusDescription "LOS GENERADORES DE CC" .
:item_topic5 rdf:type guide:SyllabusItem ; guide:itemIndex 5 ; guide:syllabusDescription "LOS GENERADORES DE CA" .
:item_topic6 rdf:type guide:SyllabusItem ; guide:itemIndex 6 ; guide:syllabusDescription "LAS BATERÍAS" .
:item_topic7 rdf:type guide:SyllabusItem ; guide:itemIndex 7 ; guide:syllabusDescription "LOS CONVERTIDORES" .
:item_topic8 rdf:type guide:SyllabusItem ; guide:itemIndex 8 ; guide:syllabusDescription "EL MANDO Y CONTROL" .
:item_topic9 rdf:type guide:SyllabusItem ; guide:itemIndex 9 ; guide:syllabusDescription "LAS PROTECCIONES" .
:item_topic10 rdf:type guide:SyllabusItem ; guide:itemIndex 10 ; guide:syllabusDescription "LA DISTRIBUCIÓN" .
:item_topic11 rdf:type guide:SyllabusItem ; guide:itemIndex 11 ; guide:syllabusDescription "LA MEDIDA, LA SEÑALIZACIÓN, LA PRESENTACIÓN Y EL REGISTRO DE LA INFORMACIÓN" .
:item_topic12 rdf:type guide:SyllabusItem ; guide:itemIndex 12 ; guide:syllabusDescription "EL SISTEMA ELÉCTRICO DE LOS AEROPUERTOS" .

# Evaluation System Instance
:eval_system_inst_elec rdf:type guide:EvaluationSystem ;
    guide:evaluationDescription "Evaluación progresiva (BLOQUE 1) y Evaluación Global (Examen Final)." ;
    guide:hasEvaluationTrial :trial_intermedia, :trial_final_ord, :trial_extraordinario .

# Evaluation Trials
:trial_intermedia rdf:type guide:EvaluationTrial ;
    guide:trialType "Examen Escrito" ;
    guide:trialMode "Presencial" ;
    guide:evaluationType "Progresiva" ;
    guide:gradePercentage "50%" ;
    guide:minimumScore "3 / 10" ;
    guide:evaluationDuration "01:30" ;
    guide:trialWeek "Semana 10" ;
    guide:involvesCompetency :comp_ce67, :comp_ce71, :comp_cg3, :comp_cg9 .

:trial_final_ord rdf:type guide:EvaluationTrial ;
    guide:trialType "Examen Esc</strong>" ;
    guide:trialMode "Presencial" ;
    guide:evaluationType "Global" ;
    guide:gradePercentage "50%" ;
    guide:minimumScore "5 / 10" ;
    guide:evaluationDuration "03:00" ;
    guide:trialWeek "Semana 17" ;
    guide:involvesCompetency :comp_ce67, :comp_ce71, :comp_cg3, :comp_cg9 .

:trial_extraordinario rdf:type guide:EvaluationTrial ;
    guide:trialType "Examen Escrito" ;
    guide:trialMode "Pres</strong>" ;
    guide:evaluationType "Global" ;
    guide:gradePercentage "100%" ;
