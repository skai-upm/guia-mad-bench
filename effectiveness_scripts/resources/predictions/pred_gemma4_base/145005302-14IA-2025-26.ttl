    guide:bibliographyType "Bibliografía" .

:res_book_toole rdf:type guide:DidacticResource ;
    sch:name "AIRCRAFT ELECTRICAL & ELECTRONICS SYSTEMS (2ª Edición). M. Toole y D. Wyatt." ;
    guide:bibliographyType "Bibliografía" .

:res_book_eismin rdf:type guide:DidacticResource ;
    sch:name "AIRCRAFT ELECTRICITY & ELECTRONICS (6ª Edición). Thomas K. Eismin." ;
    guide:bibliographyType "Bibliografía" .

:res_book_martinez rdf:type guide:DidacticResource ;
    sch:name "SISTEMAS ELÉCTRICOS Y ELECTRÓNICOS DE LAS AERONAVES. J. Martínez Rueda." ;
    guide:bibliographyType "Bibliografía" .

