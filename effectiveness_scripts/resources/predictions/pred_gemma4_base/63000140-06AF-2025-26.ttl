# --- Competencies ---
:CB09 rdf:type guide:Competency ;
    guide:competencyCode "CB09" ;
    guide:competencyDescription "Que los estudiantes sepan comunicar sus conclusiones y los conocimientos y razones últimas que las sustentamos a públicos especializados y no especializados de un modo claro y sin ambigüedades" .

:CE06 rdf:type guide:Competency ;
    guide:competencyCode "CE06" ;
    guide:competencyDescription "Capacidad para planificar y gestionar recursos energéticos, incluyendo generación, transporte, distribución y utilización" .

:CG01 rdf:type guide:Competency ;
    guide:competencyCode "CG01" ;
    guide:competencyDescription "Capacitación científico-técnica y metodológica para el reciclaje continuo de conocimientos..." .

# --- Learning Results ---
:RA22 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA22" ;
    guide:learningResultDescription "Proyectar instalaciones de generación, transporte y distribución de combustibles" .

:RA135 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA13<0xC2>cover" ;
    guide:learningResultDescription "Capacidad para seleccionar, integrar y utilizar en ingeniería, las herramientas informáticas más adecuadas al caso concreto que aborda el proyecto de diseño" .

# --- Syllabus ---
:Syllabus_63000140 rdf:type guide:Syllabus ;
    guide:hasItem :Topic_1, :Topic_2, :Topic_3 .

:Topic_1 rdf:type guide:SyllabusItem ;
    guide:itemIndex 1 ;
    guide:syllabusDescription "Estrategias para la planificación, control y seguimiento de proyectos de infraestructuras de combustibles." .

:Topic_2 rdf:type guide:SyllabusItem ;
    guide:itemIndex 2 ;
    guide:syllabusDescription "Análisis de Inversiones y Financiación de proyectos de infraestructuras de combustibles." .

:Topic_3 rdf:type guide:SyllabusItem ;
    guide:itemIndex 3 ;
    guide:syllabusDescription "Aplicación de programas informáticos (Microsoft Project, CAYRA, etc.) a la planificación de proyectos de infraestructuras de combustibles." .

# --- Evaluation System ---
:EvalSystem_63000140 rdf:type guide:EvaluationSystem ;
    guide:evaluationDescription "Evaluación continua y prueba final para alumnos que opten por ella." ;
    guide:hasEvaluationTrial :Trial_MarketStudy, :Trial_Excel, :Trial_ProjectTests, :Trial_FinalExam .

:Trial_MarketStudy rdf:type guide:EvaluationTrial ;
    guide:trialType "Evaluación Progresiva" ;
    guide:gradePercentage "5%" ;
    guide:evaluationDuration "02:00" ;
    guide:trialMode "Presencial" ;
    guide:trialDescription "Estudio de mercado a través de encuestas oficiales, información de administraciones, datos de oferta y de demanda, etc." ;
    guide:involvesCompetency :CE06, :CG01 .

:Trial_Excel rdf:type guide:EvaluationTrial ;
    guide:trialType "Evaluación Progresiva" ;
    guide:gradePercentage "10%" ;
    guide:evaluationDuration "02:00" ;
    guide:trialMode "No presencial" ;
    guide:trialDescription "Ejercicios con Excel relacionados con la materia explicada" .

:Trial_FinalExam rdf:type guide:EvaluationTrial ;
    guide:trialType "Examen Escrito" ;
    guide:gradePercentage "100%" ;
    guide:evaluationDuration "00:00" ;
    guide:trialMode "No presencial" ;
    guide:trialDescription "Examen para alumnos que han optado por la Evaluación Solo Examen Final" .

