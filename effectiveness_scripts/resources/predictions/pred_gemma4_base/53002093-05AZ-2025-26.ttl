:guide_53002093_2025_26 a guide:CourseGuide ;
    sch:name "Guía de Aprendizaje - Procesado De Señales En La Ingeniería" ;
    sch:description "En esta asignatura se imparten contenidos teórico-prácticos sobre métodos numéricos de utilidad para los alumnos en su futuro profesional."@en ;
    guide:teachingPeriod "2025-26" ;
    guide:teachingPeriodMonths "Septiembre-Enero" ;
    guide:numberOfCredits 3.0 ;
    sch:inLanguage "Inglés/Castellano" ;
    sch:instructor :lecturer_m_elena_dominguez ;
    sch:courseSchedule :schedule_53002093 ;
    guide:hasSyllabus :syllabus_53002093 ;
    guide:hasEvaluation :eval_system_53002093 ;
    guide:hasLearningResult :lr_ra445, :lr_ra393 ;
    guide:hasCompetency :comp_cg01, :comp_cg11 ;
    guide:hasDidacticResource :res_moodle, :res_matlab, :res_book_wavelets, :res_book_strang, :res_book_folland, :res_book_oppenheim ;
    sch:activitiesWorkload "26-27 horas de trabajo presencial y no presencial por cada crédito ECTS" ;
    guide:otherInformation "El curso 23/24 fue el primero en que se impartió esta asignatura, y desde el curso 24/25 se imparte en inglés."@en .

