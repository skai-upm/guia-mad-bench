# Competencies
:comp_EC01 rdf:type guide:Competency ;
    guide:competencyCode "CE EC01" ;
    guide:competencyDescription "Capacidad de construir, explotar y gestionar sistemas de captación, transporte, representación, procesado, almacenamiento, gestión y presentación de información multimedia, desde el punto de vista de los sistemas electrónicos." .

:comp_SC01 rdf:type guide:Competency ;
    guide:competencyCode "CE SC01" ;
    guide:competencyDescription "Capacidad para construir, explotar y gestionar las redes, servicios, procesos y aplicaciones de telecomunicaciones..." .

:comp_SC02 rdf:type guide:Competency ;
    guide:competencyCode "CE SC02" ;
    guide:competencyDescription "Capacidad para aplicar las técnicas en que se basan las redes, servicios y aplicaciones de telecomunicación tanto en entornos fijos como móviles..." .

:comp_CG02 rdf:type guide:Competency ;
    guide:competencyCode "CG 02" ;
    guide:competencyDescription "Capacidad de búsqueda y selección de información, de razonamiento crítico y de elaboración y defensa de argumentos dentro del área." .

:comp_CG04 rdf:type guide:Competency ;
    guide:competencyCode "CG 04" ;
    guide:competencyDescription "Capacidad de abstracción, de análisis y de síntesis y de resolución de problemas." .

# Learning Results
:lr_RA170 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA170" ;
    guide:learningResultDescription "Comprensión y manejo de las señales de audio y video (digitalización, formatos y sistemas de codificación)" .

:lr_RA408 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA408" ;
    guide:learningResultDescription "Conocer los aspectos específicos en la digitalización de la señal de audio." .

:lr_RA409 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA409" ;
    guide:learningResultDescription "Analizar las características y diseñar la interconexión entre equipos de audio." .

# Syllabus
:syllabus_audio2 rdf:type guide:Syllabus ;
    guide:hasItem :item_daw, :item_estudios, :item_digitalizacion, :item_almacenamiento, :item_codificacion .

:item_daw rdf:type guide:SyllabusItem ;
    guide:itemIndex 1 ;
    guide:syllabusDescription "Estaciones de trabajo con audio digital (DAW)" .

:item_estudios rdf:type guide:SyllabusItem ;
    guide:itemIndex 2 ;
    guide:syllabusDescription "Diseño de Estudios" .

:item_digitalizacion rdf:type guide:SyllabusItem ;
    guide:itemIndex 3 ;
    guide:syllabusDescription "Digitalización de la señal de audio" .

# Evaluation System
:eval_system_audio2 rdf:type guide:EvaluationSystem ;
    guide:evaluationDescription "La evaluación es progresiva (controles y proyecto) y global (recuperación)." ;
    guide:hasEvaluationTrial :trial_control1, :trial_control2, :trial_control3, :trial_control4, :trial_control5, :trial_proyecto .

:trial_control1 rdf:type guide:EvaluationTrial ;
    sch:name "Control 1" ;
    guide:evaluationType "Progresiva" ;
    guide:gradePercentage "18%" ;
    guide:minimumScore "4 / 10" ;
    guide:evaluationDuration "00:10" ;
    guide:trialMode "Presencial" .

:trial_proyecto rdf:type guide:EvaluationTrial ;
    sch:name "Presentación de proyectos de diseño" ;
    guide:evaluationType "Progresiva" ;
    guide:gradePercentage "10%" ;
    guide:minimumScore "5 / 10" ;
    guide:trialMode "Presencial" .

