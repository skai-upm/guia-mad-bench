    guide:hasLearningResult :lr_RA48, :lr_RA49, :lr_RA45 ;
    guide:hasEvaluation :evalSystem_53001640 ;
    guide:hasDidacticResource :res_web_info, :res_slides, :res_cad_tools ;
    sch:courseSchedule :schedule_53001640 .

# --- Lecturer ---

:lecturer_alberto_delgado rdf:type guide:Lecturer ;
    sch:name "Alberto Delgado Exposito" ;
    sch:email "a.delgado@upm.es" ;
    guide:office "CEI" ;
    guide:tutorshipsSchedule "L - 14:00 - 16:00, X - 14:00 - 16:00" .

# --- Competencies ---

:comp_MUEI_CB06 rdf:type guide:Competency ;
    guide:competencyCode "MUEI.CB06" ;
    guide:competencyDescription "Poseer y comprender conocimientos que aportamos una base u oportunidad de ser originales en el desarrollo y/o aplicación de ideas, a menudo en un contexto de investigación" .

:comp_MUEI_CE01 rdf:type guide:Competency ;
    guide:competencyCode "MUEI.CE01" ;
    guide:competencyDescription "Comprender, diseñar y analizar sistemas y componentes electrónicos en el ámbito de la electrónica industrial." .

:comp_MUEI_CT01 rdf:type guide:Competency ;
    guide:competencyCode "MUEI.CT01" ;
    guide:competencyDescription "Uso de la lengua inglesa" .

# --- Learning Results ---

:lr_RA48 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA48" ;
    guide:learningResultDescription "Comprensión de los principios de operación de la conversión de la energía y de las principales tecnologías de semiconductores" .

:lr_RA49 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA49" ;
    guide:learningResultDescription "Diseñar controladores para convertidores electrónicos de potencia" .

:lr_RA45 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA45" ;
    guide:learningResultDescription "Conocer y aplicar las técnicas de diseño de fuentes de alimentación para minimizar el consumo de energía" .

# --- Syllabus ---

:syllabus_53001640 rdf:type guide:Syllabus ;
    guide:hasItem :item_intro, :item_winding, :item_cores, :item_thermal, :item_induct, :item_transf, :item_links .

:item_intro rdf:type guide:SyllabusItem ; guide:itemIndex 1 ; guide:syllabusDescription "Introduction" .
:item_winding rdf:type guide:SylabusItem ; guide:itemIndex 2 ; guide:syllabusDescription "State of the art in winding technology" .
:item_cores rdf:type guide:SyllabusItem ; guide:itemIndex 3 ; guide:syllabusDescription "State of the art in magnetic cores technology" .
:item_thermal rdf:type guide:SyllabusItem ; guide:itemIndex 4 ; guide:syllabusDescription "State of the art in thermal management" .
:item_induct rdf:type guide:SyllabusItem ; guide:itemIndex 5 ; guide:syllabusDescription "Design guidelines for Power Inductors" .
:item_transf rdf:type guide:SyllabusItem ; guide:itemIndex 6 ; guide:syllabusDescription "Design guidelines for Power Transformers" .
:item_links rdf:type guide:SyllabusItem ; guide:itemIndex 7 ; guide:syllabusDescription "Design guidelines for Inductive links" .

# --- Evaluation System ---

:evalSystem_53001640 rdf:type guide:EvaluationSystem ;
    guide:evaluationDescription "The student evaluation will be implemented as a global evaluation through an Exam, a practical design, and a Training CAD tool course." ;
    guide:hasEvaluationTrial :trial_cad_training, :trial_practical_design, :trial_exam .

:trial_cad_training rdf:type guide:EvaluationTrial ;
    guide:trialType "Prueba Telemática" ;
    guide:evaluationType "Progresiva" ;
    guide:gradePercentage "10%" ;
    guide:evaluationDuration "03:00" ;
    guide:trialMode "No Presencial" .

:trial_practical_design rdf:type guide:EvaluationTrial ;
    guide:trialType "Trabajo Individual" ;
    guide:evaluationType "Global" ;
    guide:gradePercentage "20%" ;
    guide:minimumScore "5/10" ;
    guide:evaluationDuration "01:00" ;
    guide:trialMode "Presencial" .

:trial_exam rdf:type guide:EvaluationTrial ;
    guide:trialType "Examen Escrito" ;
    guide:evaluationType "Global" ;
    guide:gradePercentage "70%" ;
    guide:minimumScore "5/10" ;
    guide:evaluationDuration "02:00" ;
    guide:trialMode "Presencial" .

