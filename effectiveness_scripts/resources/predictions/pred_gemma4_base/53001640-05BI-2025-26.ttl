# --- Degree and University Center ---

:degree_05BI rdf:type guide:MasterDegree ;
    sch:name "Doble Master Universitario Ingenieria Industrial - Electronica Industrial" ;
    guide:degreeCode "05BI" .

:center_05 rdf:type guide:UniversityCenter ;
    sch:name "E.T.S. De Ingenieros Industriales" .

:degree_05BI guide:hasCourse :course_53001640 .
:center_05 guide:offers :degree_05BI .

# --- Course and Course Guide ---

:course_53001640 rdf:type guide:Course ;
    sch:name "Design Of Magnetic Components" ;
    sch:courseCode 53001640 ;
    guide:courseType "Optativa" ;
    guide:courseYear 2025 ;
    guide:semester "Tercer semestre" .

:courseGuide_53001640 rdf:type guide:CourseGuide ;
    sch:hasCourseInstance :course_53001640 ;
    sch:instructor :lecturer_alberto_delgado ;
    sch:inLanguage "Inglés/Castell．ano" ;
    guide:numberOfCredits 3.0 ;
    guide:teachingPeriod "2025-26" ;
    guide:periodStartingMonth "Septiembre" ;
    guide:periodEndingMonth "Enero" ;
    guide:hasSyllabus :syllabus_53001640 ;
