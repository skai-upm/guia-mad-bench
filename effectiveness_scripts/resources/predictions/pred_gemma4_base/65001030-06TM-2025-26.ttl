# Course Guide
:courseGuide_65001030 rdf:type guide:CourseGuide ;
    sch:name "Guía de Aprendizaje - Laboreo De Minas I" ;
    sch:description "Introducción al conjunto de la industria minera actual, sus funciones, procesos, tecnologías, etapas y procesos."@en ;
    guide:numberOfCredits 4.5 ;
    guide:teachingPeriod "2025-26" ;
    guide:periodStartingMonth "Septiembre" ;
    guide:periodEndingMonth "Enero" ;
    guide:totalHours "Variable según créditos ECTS" ;
    sch:inLanguage "Castellano" ;
    sch:instructor :lecturer_juan_herrera ;
    sch:instructor :lecturer_carlos_lopez ;
    sch:instructor :lecturer_jesus_caceres ;
    guide:hasSyllabus :syllabus_65001030 ;
    guide:hasEvaluation :evalSystem_65001030 ;
    guide:hasCompetency :comp_CG1, :comp_CG2, :comp_CG4, :comp_F29 ;
    guide:hasLearningResult :lr_RA162, :lr_RA294, :lr_RA297 ;
    guide:hasDidacticResource :res_book_herrera_2006, :res_equip_lab ;
    sch:activitiesWorkload "Entre 26 y 27 horas por crédito ECTS" .

