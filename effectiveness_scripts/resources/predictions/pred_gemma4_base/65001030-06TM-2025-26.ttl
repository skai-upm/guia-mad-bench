# Competencies
:comp_CG1 rdf:type guide:Competency ;
    guide:competencyCode "CG 1" ;
    guide:competencyDescription "Conocer y aplicar conocimientos de ciencias y tecnologías básicas a la práctica de la Tecnología Minera."@en .

:comp_CG2 rdf:type guide:Competency ;
    guide:competencyCode "CG 2" ;
    guide:competencyDescription "Poseer capacidad para diseñar, analizar, calcular, proyectar, construir, mantener, conservar, explotar, desarrollar, implementar, gestionar y mejorar productos, sistemas y procesos..."@en .

:comp_CG4 rdf:type guide:Competency ;
    guide:competencyCode "CG 4" ;
    guide:competencyDescription "Comprender el impacto de la tecnología minera en el medio ambiente, el desarrollo sostenible de la sociedad."@en .

:comp_F29 rdf:type guide:Competency ;
    guide:competencyCode "F29" ;
    guide:competencyDescription "Diseño y ejecución de obras superficiales y subterráneas."@en .

# Learning Results
:lr_RA162 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA1deg2" ;
    guide:learningResultDescription "Conocer los distintos métodos de explotación de los recursos minerales"@en .

:lr_RA294 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA294" ;
    guide:learningResultDescription "Conocer la naturaleza de la industria minera, su situación actual y el marco de desarrollo."@en .

:lr_RA297 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA297" ;
    guide:learningResultDescription "Adquirir los conocimientos teóricos y prácticos sobre los criterios, medios y métodos para la explotación de recursos minerales y energéticos."@en .

# Syllabus
:syllabus_65001030 rdf:type guide:Syllabus ;
    guide:hasItem :item_B1T1, :item_B2T1, :item_B3T1, :item_B4T1, :item_B5T1, :item_B6T1 .

:item_B1T1 rdf:type guide:SyllabusItem ;
    guide:itemIndex 1 ;
    guide:syllabusDescription "El abastecimiento de materias primas"@en .

:item_B2T1 rdf:type guide:SyllabusItem ;
    guide:itemIndex 2 ;
    guide:syllabusDescription "Fundamentos de las técnicas de arranque de rocas"@en .

:item_B3T1 rdf:type guide:SyllabusItem ;
    guide:itemIndex 3 ;
    guide:syllabusDescription "Características Generales de los Métodos de Minería a Cielo Abierto"@en .

# Evaluation System
:evalSystem_65001030 rdf:type guide:EvaluationSystem ;
    guide:evaluationDescription "La calificación final se expresará en una cifra numérica en una escala entre 0 y 10. Se compone de pruebas telemáticas progresivas y examen final."@en ;
    guide:hasEvaluationTrial :trial_prog_sem7, :trial_final .

:trial_prog_sem7 rdf:type guide:EvaluationTrial ;
    guide:evaluationType "Evaluación Progresiva" ;
    guide:gradePercentage "25%" ;
    guide:minimumScore "5 / 10" ;
    guide:trialWeek "Semana 7" ;
    guide:trialMode "Presencial" ;
    guide:involvesCompetency :comp_CG1, :comp_F29 .

:trial_final rdf:type guide:EvaluationTrial ;
    guide:evaluationType "Evaluación Global" ;
    guide:gradePercentage "100%" ;
    guide:minimumScore "5 / 10" ;
    guide:trialWeek "Semana 17" ;
    guide:trialMode "Presencial" ;
    guide:involvesCompetency :comp_CG1, :comp_F29 .

# Schedule Events and Activities
:event_sem1 rdf:type guide:ScheduleEvent ;
    guide:eventIndex 1 ;
