# Required Knowledge
:reqKnowledge_135004529 rdf:type guide:RequiredKnowledge ;
    guide:previousCourses "Topografía Y Sistemas De Información Geográfica" ;
    guide:previousKnowledge "Planificación territorial" .

# Competencies
:comp_CB02 rdf:type guide:Competency ;
    guide:competencyCode "CB02" ;
    guide:competencyDescription "Que los estudiantes sepan aplicar sus conocimientos a su trabajo o vocación de una forma profesional y posean las competencias que suelen demostrarse por medio de la elaboración y defensa de argumentos y la resolución de problemas dentro de su área de estudio" .

:comp_CE101 rdf:type guide:Competency ;
    guide:competencyCode "CE 1.01" ;
    guide:competencyDescription "Conocer los campos de aplicación de la Ingeniería del Medio Natural, y tener una apreciación de la necesidad de poseer unos conocimientos técnicos profundos en ciertas áreas de aplicación" .

# Learning Results
:lr_RA204 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA204" ;
    guide:learningResultDescription "Capacidad para integrar en un Sistemas de Información Geográfica información espacial y alfanumérica de diferentes fuentes" .

:lr_RA206 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA206" ;
    guide:learningResultDescription "El alumno será capaz de realizar proyectos de gestión ambiental mediante los Sistemas de Información Geográfica" .

:lr_RA207 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA207" ;
    guide:learningResultDescription "El alumno será capaz de manejar con destreza herramientas para aplicar los conocimientos adquiridos previamente sobre planificación territorial, evaluación de impacto ambiental, parques y jardines, paisajismo, ordenación de montes, hidrología, incendios forestales o cálculos de volúmenes de tierras" .

:lr_RA203 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA203" ;
    guide:learningResultDescription "Capacidad para adquirir, procesamente y analizar datos geográficos" .

:lr_RA205 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA205" ;
    guide:learningResultDescription "El alumno/a conocerá las herramientas disponibles en los Sistemas de Información Geográfica con aplicaciones en el campo de la gestión forestal y ambiental y de los recursos naturales" .

# Syllabus
:syllabus_135004529 rdf:type guide:Syllabus ;
    guide:hasItem :item_topic1, :item_topic2, :item_topic3, :item_topic4, :item_topic5, :item_topic6, :item_topic7, :item_topic8, :item_topic9, :item_topic10, :item_topic11, :item_topic12 .

:item_topic1 rdf:type guide:SyllabusItem ;
    guide:itemIndex 1 ;
    guide:syllabusDescription "Herramientas avanzadas de análisis vectorial y ráster" .

:item_topic2 rdf:type guide:SyllabusItem ;
    guide:itemIndex 2 ;
    guide:syllabusDescription "Hidrología: Delimitación de cuencas; red de drenaje" .

:item_topic3 rdf:type guide:SyllabusItem ;
    guide:itemIndex 3 ;
    guide:syllabusDescription "Ordenación de montes: Creación de mapas; creación de bases de datos" .

:item_topic4 rdf:type guide:SyllabusItem ;
    guide:itemIndex 4 ;
    guide:syllabusDescription "MDT: Gestión de MDT; cálculo de volúmenes; movimientos de tierras" .

:item_topic5 rdf:type guide:SyllabusItem ;
    guide:itemIndex 5 ;
    guide:syllabusDescription "Análisis de redes (Network analyst): Preparación de redes; cálculos de camino mínimo; áreas de<0xC2>servicio; matrices origen-destino" .

:item_topic6 rdf:type guide:SyllabusItem ;
    guide:itemIndex 6 ;
    guide:syllabusDescription "Procesado de datos LIDAR: Descarga de datos; Visualización; Creación de modelos digitales" .

:item_topic7 rdf:type guide:SyllabusItem ;
    guide:itemIndex 7 ;
    guide:syllabusDescription "Tratamiento de imágenes: Herramientas de tratamiento de ortofotos en la gestión forestal" .

:item_topic8 rdf:type guide:SyllabusItem ;
    guide:itemIndex 8 ;
    guide:syllabusDescription "Modelos digitales 3D: Creación de modelos 3D; Modelado de vegetación" .

:item_topic9 rdf:type guide:SyllabusItem ;
    guide:itemIndex 9 ;
    guide:syllabusDescription "Conversión de formatos SIG; Conversión CAD-SIG; Otras conversiones" .

:item_topic10 rdf:<0xC2>type guide:SyllabusItem ;
    guide:itemIndex 10 ;
    guide:syllabusDescription "Topología: Concepto; herramientas topológicas" .

:item_topic11 rdf:type guide:SyllabusItem ;
    guide:itemIndex 11 ;
    guide:syllabusDescription "Programación de procesos: Comandos básicos de programación; programación visual; bucles" .

:item_topic12 rdf:type guide:SyllabusItem ;
    guide:itemIndex 12 ;
    guide:syllabusDescription "Cartografía temática: Metodologías para la creación de cartografía temática" .

