# Competencies
_:comp_CE12 a guide:Competency ;
    guide:competencyCode "CE12" ;
    guide:competencyDescription "Saber buscar, obtener e interpretar la información de las principales bases de datos biomédicas y bibliográficos." .

_:comp_CE49 a guide:Competency ;
    guide:competencyCode "CE49" ;
    guide:competencyDescription "Conocer los sistemas fisiológicos y órganos humanos tanto a nivel estructural como funcional y sus patologías más relevantes." .

_:comp_CE52 a guide:Competency ;
    guide:competencyCode "CE52" ;
    guide:competencyDescription "Comprender el funcionamiento de los diferentes órganos y sistemas del cuerpo humano y la regulación de sus funciones para el mantenimiento de la homeostasis." .

_:comp_CE53 a guide:Competency ;
    guide:competencyCode "CE53" ;
    guide:competencyDescription "Conocer y comprender las modificaciones fisiológicas y morfológicas que los procesos patológicos más relevantes ocasionan en el organismo humano." .

_:comp_CE54 a guide:Competency ;
    guide:competencyCode "CE54" ;
    guide:competencyDescription "Aplicar de manera fundamentada, crítica y argumentada los principios fisiológicos para contribuir al desarrollo tecnológico en el ámbito de la salud." .

_:comp_CG01 a guide:Competency ;
    guide:competencyCode "CG01" ;
    guide:competencyDescription "Desarrollar las habilidades de aprendizaje necesarias para emprender actividades o estudios posteriores de forma autónoma y con confianza." .

# Learning Results
_:lr_RA99 a guide:LearningResult ;
    guide:learningResultCode "RA99" ;
    guide:learningResultDescription "Adquirir una participación creativa, como tecnólogos, en el análisis de los problemas biomédicos planteados con el fin de obtener resultados válidos en cuestiones multidisciplinares" .

_:lr_RA96 a guide:LearningResult ;
    guide:learningResultCode "RA96" ;
    guide:learningResultDescription "Identificar las funciones de los distintos sistemas fisiológicos y los mecanismos biológicos que permiten el mantenimiento de la homeostasis" .

