:course_55000104 a guide:CourseGuide ;
    sch:name "Electronica Digital" ;
    sch:description "La asignatura cubre los aspectos principales del diseño de sistemas digitales empleando para ello un Lenguaje de Descripción Hardware (VHDL). Se estudiarán tanto el diseño de circuitos combinacionales como el de circuitos secuenciales síncronos." ;
    guide:teachingPeriod "2025-26" ;
    guide:teachingPeriodMonths "Septiembre-Enero" ;
    guide:numberOfCredits 3.0 ;
    sch:inLanguage "Castellano" ;
    guide:hasSyllabus :syllabus_55000104 ;
    guide:hasEvaluation :eval_system_55000104 ;
    guide:hasCompetency :comp_CE21A, :comp_CE24A, :comp_CG1, :comp_CG10, :comp_CG2, :comp_CG3, :comp_CG5, :comp_CG6, :comp_CG7, :comp_CG9 ;
    guide:hasLearningResult :lr_RA8, :lr_RA9 ;
    guide:hasDidacticResource :res_transparencias, :res_fpgas, :res_sw_estudiante, :res_weblab, :res_videotutoriales ;
    sch:instructor :lecturer_otero_marnotes, :lecturer_portilla_berrueco ;
    sch:courseSchedule :schedule_55000104 ;
    guide:otherInformation "Curso: Cuarto curso. Semestre: Séptimo semestre. Carácter: Optativa." .

:degree_05TI a guide:BachelorDegree ;
    sch:name "Grado En Ingeniería En Tecnologías Industriales" ;
    guide:degreeCode "05TI" ;
    guide:hasCourse :course_55000104 .

:center_ets_industriales a guide:UniversityCenter ;
    sch:name "E.T.S. de Ingenieros Industriales" ;
    guide:offers :degree_05TI .

