:comp_CE11 a guide:Competency ;
    guide:competencyCode "CE11" ;
    guide:competencyDescription "Comprender las leyes generales de la mecánica y aplicarlas a la resolución de problemas propios de la ingeniería." .

:comp_CE19 a guide:Competency ;
    guide:competencyCode "CE19" ;
    guide:competencyDescription "Comprender los principios de mecánica de fluidos e hidráulica y aplicarlos en la Ingeniería de la Energía." .

:comp_CE23 a guide:Competency ;
    guide:competencyCode "CE23" ;
    guide:competencyDescription "Aplicar los conceptos básicos de la transferencia de calor y materia en la Ingeniería de la Energía." .

:comp_CG1 a guide:Competency ;
    guide:competencyCode "CG1" ;
    guide:competencyDescription "Conocer y aplicar conocimientos de ciencias y tecnologías básicas a la práctica de la Ingeniería de la Energía." .

:comp_CG5 a guide:Competency ;
    guide:competencyCode "CG5" ;
    guide:competencyDescription "Saber comunicar los conocimientos y conclusiones, tanto de forma oral, escrita y gráfica, a públicos especializados y no especializados de un modo claro y sin ambigüedades." .

:comp_CG6 a guide:Competency ;
    guide:competencyCode "CG6" ;
    guide:competencyDescription "Poseer habilidades de aprendizaje que permitan continuar estudiando a lo

    lo largo de la vida para su adecuado desarrollo profesional." .

:comp_CG7 a guide:Competency ;
    guide:competencyCode "CG7" ;
    guide:competencyDescription "Incorporar nuevas tecnologías y herramientas de la Ingeniería Energética en sus actividades profesionales." .

:lr_RA324 a guide:LearningResult ;
    guide:learningResultCode "RA324" ;
    guide:learningResultDescription "Poseer capacidad para diseñar, desarrollar, implementar, gestionar y mejorar productos, sistemas y procesos en los distintos ámbitos industriales, usando técnicas analíticas, computacionales o experimentales apropiadas." .

:lr_RA325 a guide:LearningResult ;
    guide:learningResultCode "RA325" ;
    guide:learningResultDescription "Aplicar los conocimientos adquiridos para identificar, formular y resolver problemas dentro de contextos amplios y multidisciplinarios, siendo capaces de integrar conocimientos, trabajando en equipos multidisciplinarios" .

:lr_RA323 a guide:LearningResult ;
    guide:learningResultCode "RA323" ;
    guide:learningResultDescription "Conocer y aplicar conocimientos de ciencias y tecnologías básicas a la práctica de la Ingeniería Energética." .

:lr_RA326 a guide:LearningResult ;
    guide:learningResultCode "RA326" ;
    guide:learningResultDescription "Comprender el impacto de la ingeniería en su rama energética sobre el medio ambiente, el desarrollo sostenible de la sociedad y la importancia de trabajar en un entorno profesional y responsable." .

:lr_RA327 a guide:LearningResult ;
    guide:learningResultCode "RA327" ;
    guide:learningResultDescription "Poseer habilidades de aprendizaje que permitan continuar estudiando a lo largo de la vida para su adecuado desarrollo profesional." .

:lr_RA328 a guide:LearningResult ;
    guide:learningResultCode "RA328" ;
    guide:learningResultDescription "Incorporar nuevas tecnologías y herramientas de la Ingeniería Energética en sus actividades profesionales." .

:lr_RA150 a guide:LearningResult ;
    guide:learningResultCode "RA150" ;
    guide:learningResultDescription "Capacidad para caracterizar y comprender el comportamiento de los fluidos en distintas situaciones de interés para el ingeniero industrial de la especialidad de Técnicas Energéticas" .

