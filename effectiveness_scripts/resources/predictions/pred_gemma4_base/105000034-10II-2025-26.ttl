# Competencies
:comp_CG1 rdf:type guide:Competency ;
    guide:competencyCode "CG-1/21" ;
    guide:competencyDescription "Capacidad de resolución de problemas aplicando conocimientos de matemáticas, ciencias e ingeniería."@en .

:comp_CG2 rdf:type guide:Competency ;
    guide:competencyCode "CG-2/CE45" ;
    guide:competencyDescription "Capacidad para el aprendizaje autónomo y la actualización de conocimientos, y reconocimiento de su necesidad en el área de la informática."@en .

:comp_Ce32 rdf:type guide:Competency ;
    guide:competencyCode "Ce 32" ;
    guide:competencyDescription "Comprender el concepto de ciclo de vida, que abarca el significado de sus fases (planificación, desarrollo, instalación y evolución)..."@en .

:comp_Ce36 rdf:type guide:Competency ;
    guide:competencyCode "Ce 36" ;
    guide:competencyDescription "Capacidad para diseñar, planificar, documentar y presupuestar la instalación de un sistema hardware y de puestos de trabajo en un espacio físico."@en .

# Learning Results
:lr_RA564 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA564" ;
    guide:learningResultDescription "Comprender y aplicar los principios de diseño y gestión integrada de la infraestructura de una instalación informática"@en .

:lr_RA562 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA562" ;
    guide:learningResultDescription "Seleccionar y definir las especificaciones de funcionamiento de equipos informáticos."@en .

:lr_RA563 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA563" ;
    guide:learningResultDescription "Comprender y aplicar los principios tecnológicos involucrados en una instalación informática (eléctricos, electro-magnéticos, térmicos y mecánicos)."@en .

# Syllabus
:syllabus_105000034 rdf:type guide:Syllabus ;
    guide:hasItem :item_intro, :item_refrig, :item_instala, :item_seguridad, :item_alimentacion, :item_cableado, :item_emc, :item_multicomputer .

:item_intro rdf:type guide:SyllabusItem ;
    guide:itemIndex 1 ;
    guide:syllabusDescription "Introducción: Tipos de instalaciones, Especificaciones, Ciclo de vida, Criterios generales."@en .

:item_refrig rdf:type guide:SyllabusItem ;
    guide:itemIndex 2 ;
    guide:syllabusDescription "Refrigeración: El agua, Sicrometría, Transferencia del calor, Sistemas de refrigeración."@en .

:item_instala rdf:type guide:SyllabusItem ;
    guide:itemIndex 3 ;
    guide:syllabusDescription "Instalación de equipos: Práctica de equipos, Diseño de CPD y sala informática."@en .

:item_seguridad rdf:type guide:SyllabusItem ;
    guide:itemIndex 4 ;
    guide:syllabusDescription "Seguridad: Incendios, Otros sistemas, Centro de gestión, Seguridad en los equipos."@en .

:item_alimentacion rdf:type guide:SyllabusItem ;
    guide:itemIndex 5 ;
    guide:syllabusDescription "Alimentación eléctrica: Generación, Distribución, Baja tensión, UPS, Iluminación."@en .

:item_cableado rdf:type guide:SyllabusItem ;
    guide:itemIndex 6 ;
    guide:syllabusDescription "Sistemas de cableado estructurado en CPD: Áreas, Clasificación, Estandarización (SCE), Certificación."@en .

:item_emc rdf:type guide:SyllabusItem ;
    guide:itemIndex 7 ;
    guide:syllabusDescription "Compatibilidad electromagnética: Conceptos básicos, Mecanismos de propagación, Medición, Regulación EMC."@en .

:item_multicomputer rdf:type guide:SyllabusItem ;
    guide:itemIndex 8 ;
    guide:syllabusDescription "Construcción de sistemas multicomputador: Nodos, Interconexión, Almacenamiento NAS y SAN."@en .

# Evaluation System
:eval_system_105000034 rdf:type guide:EvaluationSystem ;
    guide:evaluationDescription "Evaluación mediante Project Based Learning (proyecto en grupo) y prueba global."@en ;
    guide:hasEvaluationTrial :trial_prog_6, :trial_prog_8, :trial_prog_10, :trial_prog_11, :trial_prog_13, :trial_prog_14, :trial_memoria, :trial_global, :trial_extraordinary .

:trial_prog_6 rdf:type guide:EvaluationTrial ;
    guide:trialType "Evaluación Progresiva" ;
    guide:trialDescription "Entrega: Propuesta de Proyecto (Objeto y Alcance)"@en ;
    guide:gradePercentage "5%" ;
    guide:trialMode "No presencial" ;
    guide:involvesCompetency :comp_CG1, :comp_CG2, :comp_Ce32, :comp_Ce36 .

:trial_memoria rdf:type guide:EvaluationTrial ;
    guide:trialType "Evaluación Progresiva" ;
    guide:trialDescription "Entrega: Memoria Final"@en ;
    guide:gradePercentage "70%" ;
    guide:trialMode "Presencial" ;
    guide:evaluationDuration "02:00" ;
    guide:involvesCompetency :comp_CG1, :comp:comp_CG2, :comp_Ce32, :comp_Ce36 .

:trial_global rdf:type guide:EvaluationTrial ;
    guide:trialType "Evaluación Global" ;
    guide:trialDescription "Examen Global: Desarrollo de un proyecto"@en ;
    guide:gradePercentage "100%" ;
    guide:trialMode "Presencial" ;
    guide:evaluationDuration "03:00" ;
    guide:minimumScore "5/10" .

:trial_extraordinary rdf:type guide:EvaluationTrial ;
    guide:trialType "Evaluación Extraordinaria" ;
    guide:trialDescription "Realización de un proyecto original e individual"@en ;
    guide:gradePercentage "100%" ;
    guide:trialMode "Presencial" ;
    guide:evaluationDuration "08:00" ;
    guide:minimumScore "5/10" .

