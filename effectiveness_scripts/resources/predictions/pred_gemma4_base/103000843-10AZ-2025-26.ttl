### Competencies and Learning Results
:comp_CB07 a guide:Competency ;
    guide:competencyCode "CB07" ;
    guide:competencyDescription "Que los estudiantes sepan aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en entornos nuevos o poco conocidos dentro de contextos más amplios (o multidisciplinares) relacionados con su área de estudio" .

:comp_CB08 a guide:Competency ;
    guide:competencyCode "CB08" ;
    guide:competencyDescription "Que los estudiantes sean capaces de integrar conocimientos y enfrentarse a la complejidad de formular juicios a partir de una información que, siendo incompleta o limitada, incluya reflexiones sobre las responsabilidades sociales y éticas vinculadas a la aplicación de sus conocimientos y juicios" .

:comp_CB09 a guide:Competency ;
    guide:competencyCode "CB09" ;
    guide:competencyDescription "Que los estudiantes sepan comunicar sus conclusiones y los conocimientos y razones últimas que las sustentan a públicos especializados y no especializados de un modo claro y sin ambigüedades" .

:comp_CEEIT03 a guide:Competency ;
    guide:competencyCode "CE-EIT03" ;
    guide:competencyDescription "Capacidad para identificar el nivel de academic maturity of a technology and develop and interpret a technological roadmap..." .

:comp_CG01 a guide:Competency ;
    guide:competencyCode "CG01" ;
    guide:competencyDescription "Que los estudiantes sean capaces de predecir y controlar la evolución de situaciones complejas mediante el desarrollo de nuevas e innovadoras metodologías de trabajo..." .

:comp_CG03 a guide:Competency ;
    guide:competencyCode "CG03" ;
    guide:competencyDescription "La capacidad de usar la lengua inglesa de manera competente..." .

:comp_CG07 a guide:Competency ;
    guide:competencyCode "CG07" ;
    guide:competencyDescription "Capacidad de trabajar y comunicarse también en contextos internacionales." .

:comp_CG08 a guide:Competency ;
    guide:competencyCode "CG08" ;
    guide:competencyDescription "La capacidad de traducir innovaciones en soluciones comerciales factibles." .

:comp_CG09 a guide:Competency ;
    guide:competencyCode "CG09" ;
    guide:competencyDescription "La capacidad de transformar las experiencias prácticas en problemas y desafíos de investigación." .

:res_RA104 a guide:LearningResult ;
    guide:learningResultCode "RA104" ;
    guide:learningResultDescription "In depth understanding the basics of technology watch and transfer" .

### Syllabus
:syllabus_10300<0xC2>0843 a guide:Syllabus ;
    guide:hasItem :item_welcome, :item_tw_basics, :item_tw_purpose, :item_tw_report_critical, :item_tw_report_sci, :item_tw_report_market, :item_tw_report_analysis .

:item_welcome a guide:SyllabusItem ;
    guide:itemIndex 1 ;
    guide:syllabusDescription "Welcome session: Contents, grading processes and groups creation" .

:item_tw_basics a guide:SyllabusItem ;
    guide:itemIndex 2 ;
    guide:syllabusDescription "Technology watch basics: Technology watch basic concepts, procedure and tools" .

:item_tw_purpose a guide:SyllabusItem ;
    guide:itemIndex 3 ;
    guide:syllabusDescription "Definition of the technology watch purpose: Definition of the purpose and identification of application points" .

:item_tw_report_critical a guide:SyllabusItem ;
    guide:itemIndex 4 ;
    guide:syllabusDescription "TW Report - Critical watch factors: Introduction to the technology watch report and identification of critical watch factors" .

:item_tw_report_sci a guide:SyllabusItem ;
    guide:itemIndex 5 ;
    guide:syllabusDescription "TW Report - Scientific-technological information: Identification and analysis of scientific-technological sources of information" .

:item_tw_report_market a guide:SyllabusItem ;
    guide:itemIndex 6 ;
    guide:syllabusDescription "TW Report - Market and industry information: Identification and analysis of market and industrial sources of information" .

:item_tw_report_analysis a guide:SyllabusItem ;
    guide:itemIndex 7 ;
    guide:syllabusDescription "TW Report - Analysis of information: Analysis of the information gathered and drawing conclusions to complete the TW report" .

