# --- Competencies ---

:comp_CE06 rdf:type guide:Competency ;
    guide:competencyCode "CE06" ;
    guide:competencyDescription "Comprender y saber calcular el equilibrio y la $\text{dinámica}$ de sistemas mecánicos" .

:comp_CE07 rdf:type guide:Competency ;
    guide:competencyCode "CE07" ;
    guide:competencyDescription "Saber aplicar las ecuaciones elementales de la mecánica de fluidos en el cálculo de sistemas de conducción convencionales macroscópicos y en microfluídica." .

:comp_CG04 rdf:type guide:Competency ;
    guide:competencyCode "CG04" ;
    guide:competencyDescription "Trabajar de forma adecuada en un laboratorio incluyendo un registro anotado de las actividades y seguridad, manipulación y eliminación de residuos químicos o biológicos." .

# --- Learning Results ---

:lr_RA31_34 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA31-RA34" ;
    guide:learningResultDescription "Conocer, comprender y dominar los conceptos y principios básicos de la Dinámica de sistemas" .

:lr_RA4 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA4" ;
    guide:learningResultDescription "Capacidad para emplear con rigor el lenguaje matemático." .

# --- Syllabus ---

:syllabus_fisica rdf:type guide:Syllabus ;
    guide:hasItem :item_mecánica, :item_elasticidad, :item_fluidos, :item_termodinamica .

:item_mecánica rdf:type guide:SyllabusItem ;
    guide:itemIndex 1 ;
    guide:syllabusDescription "Mecánica: Análisis dimensional, Vectores, Dinámica y cinemática de la partícula, Trabajo y energía, Sistemas de partículas y sólido rígido, Equilibrio y estática." .

:item_elasticidad rdf:type guide:SyllabusItem ;
    guide:itemIndex 2 ;
    guide:syllabusDescription "Elasticidad: Ley de Hooke, coeficientes elásticos, Flexión y torsión." .

# --- Evaluation System ---

:eval_system_fisica rdf:type guide:EvaluationSystem ;
    guide:evaluationDescription "Evaluación progresiva. La nota final se calcula según la realización de pruebas de control, exámenes y prácticas de laboratorio." ;
    guide:hasEvaluationTrial :trial_exam_control1, :trial_exam_p1, :trial_lab_eval, :trial_exam_final .

:trial_exam_control1 rdf:type guide:EvaluationTrial ;
    guide:trialType "Examen Escrito" ;
    guide:evaluationType "progresiva" ;
    guide:gradePercentage "5%" ;
    guide:minimumScore "/ 10" ;
    guide:eventWeek "4" .

:trial_exam_p1 rdf:type guide:EvaluationTrial ;
    guide:trialType "Examen Escrito" ;
    guide:evaluationType "progresiva" ;
    guide:gradePercentage "37.5%" ;
    guide:minimumScore "4 / 10" ;
    guide:eventWeek "9" .

:trial_lab_eval rdf:type guide:EvaluationTrial ;
    guide:trialType "Trabajo en Grupo" ;
    guide:evaluationType "progresiva" ;
    guide:gradePercentage "15%" ;
    guide:eventWeek "14" .

# --- Schedule and Activities ---

:schedule_fisica rdf:type guide:Schedule ;
    sch:eventSchedule :event_week1, :event_week3, :event_week4 .

:event_week1 rdf:type guide:ScheduleEvent ;
    guide:eventWeek "Semana 1" ;
    guide:hasActivity :act_leccion_magistral_1, :act_clase_problemas_1 .

:act_leccion_magistral_1 rdf:type guide:Activity ;
    guide:activityDescription "Análisis dimensional. Vectores." ;
    guide:activityDuration 2.0 ;
    guide:activityFormat "Lección Magistral" ;
    guide:attendanceType "Presencial" .

:act_clase_problemas_1 rdf:type guide:Activity ;
    guide:activityDescription "Análisis dimensional. Vectores. Ejemplos y problemas" ;
    guide:activityDuration 1.0 ;
    guide:activityFormat "Clase de Problemas" ;
    guide:attendanceType "Presencial" .

