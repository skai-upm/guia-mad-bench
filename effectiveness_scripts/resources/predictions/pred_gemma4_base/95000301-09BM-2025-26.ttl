# --- Degree and University Center ---

:degree_09BM rdf:type guide:BachelorDegree ;
    sch:name "09BM - Grado en Ingenieria Biomedica" ;
    guide:degreeCode "09BM" ;
    guide:hasCourse :course_fisica .

:ets_telecom rdf:type guide:UniversityCenter ;
    sch:name "E.T.S. de Ingenieros de Telecomunicacion" ;
    guide:offers :degree_09BM .

# --- Course and Course Guide ---

:course_fisica rdf:type guide:Course ;
    sch:name "95000301 - Física" ;
    sch:courseCode 95000301 ;
    guide:courseYear 2025 ;
    guide:courseType "Básica" ;
    sch:hasCourseInstance :guide_fisica_2526 .

:guide_fisica_2526 rdf:type guide:CourseGuide ;
    sch:name "Guía de Aprendizaje - Física" ;
    sch:description "Programa de la asignatura que cubre los temas de mecánica clásica, elasticidad, dinámica de fluidos y termodinámica." ;
    sch:inLanguage "Castellano" ;
    guide:teachingPeriod "2025-26" ;
    guide:periodStartingMonth "Septiembre" ;
    guide:periodEndingMonth "Enero" ;
    guide:numberOfCredits 6.0 ;
    guide:totalHours "150" ; # Estimated based on ECTS (25h per credit)
    sch:instructor :lecturer_elisa_antolin, :lecturer_simon_svatek ;
    guide:hasSyllabus :syllabus_fisica ;
    guide:hasCompetency :comp_CE06, :comp_CE07, :comp_CE10, :comp_CE11, :comp_CG01, :comp_CG04, :comp_CG05, :comp_CG07, :comp_CG08, :comp_CG09, :comp_CG11 ;
    guide:hasLearningResult :lr_RA31_34, :lr_RA4, :lr_RA30_32, :lr_RA17, :lr_RA55, :lr_RA132, :lr_RA155, :lr_RA212, :lr_RA209, :lr_RA34_41, :lr_RA35_42, :lr_RA33_40, :lr_RA131, :lr_RA150, :lr_RA36_43, :lr_RA37_44 ;
    guide:hasEvaluation :eval_system_fisica ;
    guide:hasDidacticResource :res_tipler, :res_sears, :res_kane, :res_burbano, :res_jou, :res_moodle, :res_khan ;
    sch:courseSchedule :schedule_fisica .

