# Competencies
:comp_cg1_21 a guide:Competency ;
    guide:competencyCode "CG-1/21" ;
    guide:competencyDescription "Capacidad de resolución de problemas aplicando conocimientos de matemáticas, ciencias e ingeniería."@en .

:comp_cg2_ce45 a guide:Competency ;
    guide:competencyCode "CG-2/CE45" ;
    guide:competencyDescription "Capacidad para el aprendizaje autónomo y la actualización de conocimientos, y reconocimiento de su necesidad en el área de la informática."@en .

:comp_cg3_4 a guide:Competency ;
    guide:competencyCode "CG-3/4" ;
    guide:competencyDescription "Saber trabajar en situaciones carentes de información y bajo presión, teniendo nuevas ideas, siendo creativo."@en .

:comp_cg6 a guide:Competency ;
    guide:competencyCode "CG-6" ;
    guide:competencyDescription "Capacidad de abstracción, análisis y síntesis"@en .

:comp_cg7_10_16_17 a guide:Competency ;
    guide:competencyCode "CG-7:10/16/17" ;
    guide:competencyDescription "Capacidad para trabajar dentro de un equipo, organizando, planificando, tomando decisiones, negociando y resolviendo conflictos..."@en .

:comp_ce19_20 a guide:Competency ;
    guide:competencyCode "Ce 19/20" ;
    guide:competencyDescription "Conocimiento de los tipos apropiados de soluciones, y comprensión de la complejidad de los problemas informáticos..."@en .

# Learning Results
:lr_ra278 a guide:LearningResult ;
    guide:learningResultCode "RA278" ;
    guide:learningResultDescription "Desarrollar la solución matemática y algorítmica mas apropiada a un problema informático que requiera un tratamiento especialmente complejo, analizando y exponiendo su viabilidad."@en .

# Syllabus
:syllabus_105000439 a guide:Syllabus ;
    guide:hasItem :item_intro, :item_efficiency, :item_basic_tech, :item_design_tech .

:item_intro a guide:SyllabusItem ;
    guide:itemIndex 1 ;
    guide:syllabusDescription "Introducción. Presentación de la asignatura. Programación competitiva. Familiarización con el entorno de trabajo. Jueces."@en .

:item_efficiency a guide:SyllabusItem ;
    guide:itemIndex 2 ;
    guide:syllabusDescription "Eficiencia y complejidad de algoritmos. Análisis de tiempo, Notación O(), Tratabilidad, Reducciones."@en .

:item_basic_tech a guide:SyllabusItem ;
    guide:itemIndex 3 ;
    guide:syllabusDescription "Técnicas básicas. Cadenas alfanuméricas, Estructuras de datos, Algoritmos sobre árboles y grafos."@en .

:item_design_tech a guide:SyllabusItem ;
    guide:itemIndex 4 ;
    guide:syllabusDescription "Técnicas de diseño de algoritmos. Divide y vencerás, Voraces, Backtracking, Heurística, Programación dinámica."@en .

# Evaluation System
:eval_system_105000439 a guide:EvaluationSystem ;
    guide:evaluationDescription "La nota de evaluación progresiva se calcula como 0,3 * (Test de Teoría) + 0,7 * (Nota Concursos). La evaluación global es similar para la recuperación."@en ;
    guide:hasEvaluationTrial :trial_concursos, :trial_ada_byron, :trial_test_teoria, :trial_examen_practico .

:trial_concursos a guide:EvaluationTrial ;
    guide:trialType "Concursos de Programación" ;
    guide:trialMode "Presencial" ;
    guide:trialWeek "6-15" ;
    guide:gradePercentage "7%" ;
    guide:minimumScore "0 / 10" ;
    guide:involvesCompetency :comp_cg1_21, :comp_cg2_ce45, :comp_cg3_4, :comp_cg6, :comp_cg7_10_16_17, :comp_ce19_20 .

:trial_ada_byron a guide:EvaluationTrial ;
    guide:trialType "Fase Local Ada Byron" ;
    guide:trialMode "Presencial" ;
    guide:trialWeek "11" ;
    guide:gradePercentage "10%" ;
    guide:minimumScore "0 / 10" ;
    guide:involvesCompetency :comp_cg1_21, :comp_cg2_ceelle45, :comp_cg3_4, :comp_cg6, :comp_cg7_10_16_17, :comp_ce19_20 .

:trial_test_teoria a guide:EvaluationTrial ;
    guide:trialType "Test teoría" ;
    guide:trialMode "Presencial" ;
    guide:trialWeek "15" ;
    guide:gradePercentage "30%" ;
    guide:minimumScore "5 / 10" ;
    guide:involvesCompetency :comp_cg2_ce45, :comp_cg3_4, :comp_cg6, :comp_ce19_20 .

:trial_examen_practico a guide:EvaluationTrial ;
    guide:trialType "Examen Práctico" ;
    guide:trialMode "Presural" ;
    guide:trialWeek "17" ;
    guide:gradePercentage "70%" ;
    guide:minimumScore "5 / 10" ;
    guide:involvesCompetency :comp_cg1_21, :comp_cg2_ce45, :comp_cg3_4, :comp_cg6, :comp_cg7_10_16_17, :comp_ce19_20 .

