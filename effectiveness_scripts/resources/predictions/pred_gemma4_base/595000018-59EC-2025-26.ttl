# Competencies
:comp_ce_tel16 rdf:type guide:Competency ;
    guide:competencyCode "CE TEL16" ;
    guide:competencyDescription "Conocimiento de la normativa y la regulación de las telecomunicaciones en los ámbitos nacional, europeo e internacional."@en .

:comp_cg_02 rdf:type guide:Competency ;
    guide:competencyCode "CG 02" ;
    guide:competencyDescription "Capacidad de búsqueda y selección de información, de razonamiento crítico y de elaboración y defensa de argumentos dentro del área."@en .

:comp_cg_03 rdf:type guide:Competency ;
    guide:competencyCode "CG 03" ;
    guide:competencyDescription "Capacidad para expresarse correctamente de forma oral y escrita y transmitir información mediante documentos y exposiciones en público."@en .

:comp_cg_05 rdf:type guide:Competency ;
    guide:competencyCode "CG 05" ;
    guide:competencyDescription "Capacidad de trabajo en equipo y en entornos multidisciplinares."@en .

:comp_cg_06 rdf:type guide:Competency ;
    guide:competencyCode "CG 06" ;
    guide:competencyDescription "Capacidad de adaptación, negociación, resolución de conflictos y de liderazgo."@en .

:comp_cg_09 rdf:type guide:Competency ;
    guide:competencyCode "CG 09" ;
    guide:competencyDescription "Capacidad de analizar y valorar el impacto social y medioambiental de las soluciones técnicas."@en .

:comp_cg_11 rdf:type guide:Competency ;
    guide:competencyCode "CG 11" ;
    guide:competencyDescription "Habilidades para la utilización de las Tecnologías de la Información y las Comunicaciones."@en .

:comp_cg_14 rdf:type guide:Competency ;
    guide:competencyCode "CG 14" ;
    guide:competencyDescription "Actitudes de ética y responsabilidad profesional, respeto a los Derechos Humanos y a la diversidad cultural."@en .

# Learning Results
:lr_ra195 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA195" ;
    guide:learningResultDescription "Podrá contrastar las ideas aportadas por diferentes fuentes"@en .

:lr_ra197 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA197" ;
    guide:learningResultDescription "Podrá relacionar los aspectos científico-tecnológicos con un entorno social de creciente complejidad"@en .

:lr_ra194 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA194" ;
    guide:learningResultDescription "Podrá procesar la información de diferentes fuentes y sintetizarla adecuadamente"@en .

:lr_ra196 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA196" ;
    guide:learningResultDescription "Podrá hacer una valoración sobre el rigor de la fuente de procedencia de la información"@en .

:lr_ra192 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA192" ;
    guide:learningResultDescription "Podrá localizar con acierto la información requerida"@en .

:lr_ra193 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA193" ;
    guide:learningResultDescription "Podrá analizar la información encontrada y descartar la irrelevante"@en .

# Syllabus
:syllabus_595000018 rdf:type guide:Syllabus ;
    guide:hasItem :item_1, :item_2, :item_3, :item_4 .

:item_1 rdf:type guide:SyllabusItem ;
    guide:itemIndex 1 ;
    guide:syllabusDescription "Sostenibilidad ecológica y social"@en .

:item_2 rdf:type guide:SyllabusItem ;
    guide:itemIndex 2 ;
    guide:syllabusDescription "Las revoluciones tecnológicas"@en .

:item_3 rdf:type guide:SyllabusItem ;
    guide:itemIndex 3 ;
    guide:syllabusDescription "TIC, ética y derechos humanos"@en .

:item_4 rdf:type guide:SyllabusItem ;
    guide:itemIndex 4 ;
    guide:syllabusDescription "Casos de uso de tecnología social. Evaluación Voluntaria"@en .

# Evaluation System
:eval_system_595000018 rdf:type guide:EvaluationSystem ;
    guide:evaluationDescription "La evaluación progresiva libera cada tema a partir de una nota de 3 sobre 10. Se aprueba la asignatura por evaluación progresiva si se tiene más de un 3 en los tres temas y la media ponderada de todas las notas da un 5 o más."@en ;
    guide:hasEvaluationTrial :trial_tema1, :trial_tema2, :trial_tema3, :trial_trabajo_fin, :trial_global, :trial_extraordinario .

