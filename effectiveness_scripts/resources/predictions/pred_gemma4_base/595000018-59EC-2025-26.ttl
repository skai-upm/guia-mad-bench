# Course Guide
:guide_595000018 rdf:type guide:CourseGuide ;
    sch:name "Guía de Aprendizaje - Ciencia, Tecnologia y Sociedad" ;
    sch:description "La asignatura pretende promover la reflexión sobre las interacciones entre la sociedad actual y el desarrollo tecnológico."@en ;
    sch:instructor :lecturer_ivan, :lecturer_miguel ;
    sch:director :lecturer_ivan ;
    guide:hasSyllabus :syllabus_595000018 ;
    guide:hasEvaluation :eval_system_595000018 ;
    guide:hasCompetency :comp_ce_tel16, :comp_cg_02, :comp_cg_03, :comp_cg_05, :comp_cg_06, :comp_cg_09, :comp_cg_11, :comp_cg_14 ;
    guide:hasLearningResult :lr_ra195, :lr_ra197, :lr_ra194, :lr_ra196, :lr_ra192, :lr_ra193 ;
    guide:hasDidacticResource :res_kuhn, :res_moodle, :res_ieee, :res_anguera ;
    sch:courseSchedule :schedule_595000018 ;
    guide:numberOfCredits 3.0 ;
    guide:teachingPeriod "2025-26" ;
    guide:periodStartingMonth "Febrero" ;
    guide:periodEndingMonth "Junio" ;
    sch:inLanguage "Castellano" ;
    guide:totalHours "..." ; 
    sch:activitiesWorkload "..." .

