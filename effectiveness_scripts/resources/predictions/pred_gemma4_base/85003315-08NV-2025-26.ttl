# Competencies
:comp_CB1 rdf:type guide:Competency ;
    guide:competencyCode "CB1" ;
    guide:competencyDescription "Que los estudiantes hayan demostrado poseer y comprender conocimientos en un área de estudio..." .

:comp_CB5 rdf:type guide:Competency ;
    guide:competencyCode "CB5" ;
    guide:competencyDescription "Que los estudiantes hayan desarrollado aquellas habilidades de aprendizaje necesarias para emprender estudios posteriores con un alto grado de autonomía" .

:comp_CE14 rdf:type guide:Competency ;
    guide:competencyCode "CE 14" ;
    guide:competencyDescription "Conocimiento de la termodinámica aplicada y de la transmisión del calor" .

:comp_CG3 rdf:type guide:Competency ;
    guide:competencyCode "CG3" ;
    guide:competencyDescription "Capacidad para el aprendizaje de nuevos métodos y teorías, y en la versatilidad para adaptarse a nuevas situaciones..." .

# Learning Results
:lr_RA192 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA192" ;
    guide:learningResultDescription "Conocer los ciclos termodinámicos" .

:lr_RA193 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA193" ;
    guide:learningResultDescription "Comprender y aplicar el concepto de rendimiento de los dispositivos" .

:lr_RA190 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA190" ;
    guide:learningResultDescription "Conocer la formulación de los Principios Primero y Segundo de la Termodinámica en sistemas abiertos y cerrados" .

:lr_RA189 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA189" ;
    guide:learningResultDescription "Conocer y comprender el comportamiento termodinámico de las sustancias puras" .

:lr_RA188 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA188" ;
    guide:learningResultDescription "Conocer la composición del aire húmedo y el diagrama psicrométrico" .

:lr_RA191 rdf:<0xE2><0x80><0x89>type guide:LearningResult ;
    guide:learningResultCode "RA191" ;
    guide:learningResultDescription "Conocer los distintos mecanismos de transferencia de calor" .

