:item_5 rdf:type guide:SyllabusItem ;
    guide:itemIndex 5 ;
    sch:description "Superficies poliédricas" .

:item_6 rdf:type guide:SyllabusItem ;
    guide:itemIndex 6 ;
    sch:description "Conos cuádricos" .

:item_7 rdf:type guide:SyllabusItem ;
    guide:itemIndex 7 ;
    sch:description "Cilindros cuádricos" .

:item_8 rdf:type guide:SyllabusItem ;
    guide:itemIndex 8 ;
    sch:description "Superficies esféricas" .

:item_9 rdf:type guide:SyllabusItem ;
    guide:itemIndex 9 ;
    sch:description "Fundamentos de otros sistemas de representación" .

:item_10 rdf:type guide:SyllabusItem ;
    guide:itemIndex 10 ;
    sch:description "Introducción a la normalización industrial" .

:item_11 rdf:type guide:SyllabusItem ;
    guide:itemIndex 11 ;
    sch:description "Formatos normalizados" .

:item_12 rdf:type guide:SyllabusItem ;
    guide:itemIndex 12 ;
    sch:description "Principios generales de representación" .

:item_13 rdf:type guide:SyllabusItem ;
    guide:itemIndex 13 ;
    sch:description "Cortes y secciones" .

:item_14 rdf:type guide:SyllabusItem ;
    guide:itemIndex 14 ;
