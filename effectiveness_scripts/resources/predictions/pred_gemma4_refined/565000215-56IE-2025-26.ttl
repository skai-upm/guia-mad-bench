# Evaluation System
:eval_system_565000215 rdf:type guide:EvaluationSystem ;
    guide:evaluationDescription "La asignatura se compone de dos partes que se cursan en paralelo: Concepción Espacial y Normalización, cada una de ellas con un 50% del peso final de la evaluación." ;
    guide:hasEvaluationTrial :trial_control1_ce, :trial_control1_norm, :trial_control2_ce, :trial_control2_norm, :trial_examen_final .

:trial_control1_ce rdf:type guide:EvaluationTrial ;
    guide:trialType "Examen de Prácticas" ;
    guide:evaluationType "Evaluación Progresiva" ;
    guide:gradePercentage "15%" ;
    guide:evaluationDuration "01:00" ;
    guide:trialMode "Presencial" ;
    guide:involvesCompetency :comp_CE5, :comp_CG1, :comp_CG6, :comp_CG7, :comp_CG10 .

:trial_control1_norm rdf:type guide:EvaluationTrial ;
    guide:trialType "Examen de Prácticas" ;
    guide:evaluationType "Evaluación Progresiva" ;
    guide:gradePercentage "15%" ;
    guide:evaluationDuration "02:00" ;
    guide:trialMode "Presencial" ;
    guide:involvesCompetency :comp_CE5, :comp_CG1, :comp_CG6, :comp_CG7, :comp_CG10 .

:trial_examen_final rdf:type guide:EvaluationTrial ;
    guide:trialType "Examen de Prácticas" ;
    guide:evaluationType "Evaluación Global" ;
    guide:gradePercentage "100%" ;
    guide:minimumScore "5 / 10" ;
    guide:evaluationDuration "03:00" ;
    guide:trialMode "Presencial" ;
    guide:involessCompetency :comp_CE5, :comp_CG1, :comp_CG6, :comp_CG7, :comp_CG10 .

