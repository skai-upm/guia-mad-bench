# Competencies
:competency_CE_SE1 a guide:Competency ;
    guide:competencyCode "CE-SE1" ;
    guide:competencyDescription "Capacidad de construir, explotar y gestionar sistemas de captación, transporte, representación, procesado, almacenamiento, gestión y presentación de información multimedia, desde el punto de vista de los sistemas electrónicos" .

:competency_CE_SE3 a guide:Competency ;
    guide:competencyCode "CE-SE3" ;
    guide:competencyDescription "Capacidad de realizar la especificación, implementación, documentación y puesta a punto de equipos y sistemas, electrónicos, de instrumentación y de control, considerando tanto los aspectos técnicos como las normativas reguladoras correspondientes" .

:competency_CE_SE5 a guide:Competency ;
    guide:competencyCode "CE-SE5" ;
    guide:competencyDescription "Capacidad de diseñar circuitos de electrónica analógica y digital, de conversión analógico-digital y digital analógica, de radiofrecuencia, de alimentación y conversión de energía eléctrica para aplicaciones de telecomunicación y computación" .

:competency_CE_SE9 a guide:Competency ;
    guide:competencyCode "CE-SE9" ;
    guide:competencyDescription "Capacidad de analizar y solucionar los problemas de interferencias y compatibilidad electromagnética" .

:competency_CG7 a guide:Competency ;
    guide:competencyCode "CG7" ;
    guide:competencyDescription "Trabajo en equipo" .

:competency_CG12 a guide:Competency ;
    guide:competencyCode "CG12" ;
    guide:competencyDescription "Organización y planificación" .

:competency_CG13 a guide:Competency ;
    guide:competencyCode "CG13" ;
    guide:competencyDescription "Respeto medioambiental" .

:competency_CG9 a guide:Competency ;
    guide:competencyCode "CG9" ;
    guide:competencyDescription "Uso de Tecnologías de la Información y de las Comunicaciones" .

# Learning Results
:learning_result_RA732 a guide:LearningResult ;
    guide:learningResultCode "RA732" ;
    guide:learningResultDescription "Diseñar una placa de circuito impreso orientada a fabricación" .

:learning_result_RA733 a guide:LearningResult ;
    guide:learningResultCode "RA733" ;
    guide:learning_resultDescription "Distinguir las distintas fases del desarrollo de producto" .

:learning_result_RA76 a guide:LearningResult ;
    guide:learningResultCode "RA76" ;
    guide:learningResultDescription "Conocimientos de las normativas reguladoras aplicables a los equipos electrónicos" .

:learning_result_RA734 a guide:LearningResult ;
    guide:learningResultCode "RA734" ;
    guide:learningResultDescription "Conocimientos básicos de técnicas de soldadura de sistemas electrónicos" .

:learning_result_RA71 a guide:LearningResult ;
    guide:learningResultCode "RA71" ;
    guide:learningResultDescription "Conocimiento de las técnicas de diseño de circuitos electrónicos" .

:learning_result_RA70 a guide:LearningResult ;
    guide:learningResultCode "RA70" ;
    guide:learningResultDescription "Conocimientos de dispositivos, circuitos, equipos y sistemas electrónicos" .

:learning_result_RA74 a guide:LearningResult ;
    guide:learningResultCode "RA74" ;
    guide:learningResultDescription "Conocimientos de interferencias y compatibilidad electromagnética" .

# Evaluation System
:eval_system_95000062 a guide:EvaluationSystem ;
    guide:evaluationDescription "La evaluación comprobará si los estudiantes han adquirido las competencias de la asignatura." ;
    guide:hasEvaluationTrial :trial_exam_global, :trial_exam_progresiva .

:trial_exam_global a guide:EvaluationTrial ;
    guide:trialType "Examen Escrito" ;
    guide:gradePercentage "50%" ;
    guide:minimumScore "4 / 10" ;
    guide:evaluationDuration "03:00" .

:trial_exam_progresiva a guide:EvaluationTrial ;
    guide:trialType "Presentación en Grupo" ;
    guide:gradePercentage "10%" ;
    guide:minimumScore "5 / 10" ;
    guide:evaluationDuration "02:00" .

