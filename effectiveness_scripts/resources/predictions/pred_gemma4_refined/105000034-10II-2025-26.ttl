@prefix guide: <http://w3id.org/def/guia#> .
@prefix sch: <https://schema.org/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

# Course Guide Instance
:course_guide_105000034 a guide:CourseGuide ;
    sch:name "Proyecto De Instalacion Informatica" ;
    sch:description "Asignatura que permite al alumno adquirir conocimientos sobre la demanda del mercado de proyectos de instalaciones informáticas y construcción de Data Centers." ;
    guide:numberOfCredits 3.0 ;
    guide:courseType "Obligatoria" ;
    guide:teachingPeriod "2025-26" ;
    guide:semester "Sexto semestre" ;
    sch:inLanguage "Castellano" ;
    guide:hasCompetency :comp_cg1_21, :comp_cg2_ce45, :comp_ce32, :comp_ce36 ;
    guide:hasLearningResult :lr_ra564, :lr_ra562, :lr_ra563 ;
    sch:instructor :lecturer_antonio_latorre, :lecturer_juan_carlos_crespo, :lecturer_jorge_ruiz, :lecturer_pablo_toharia ;
    sch:director :lecturer_juan_carlos_crespo ;
    guide:hasEvaluation :eval_system_progressive, :eval_system_global, :eval_system_extraordinary ;
    guide:hasDidacticResource :res_book_instalaciones, :res_normas, :res_moodle ;
    guide:otherInformation "La Asignatura se estructura en 1s horas de clase magistral y el trabajo en equipo para la realización del Proyecto de Instalación Informática (CPD). Criterios ODS: Educación de Calidad, Igualdad de Género, Industria, innovación e infraestructura, Energía asequible y medioambiente, Trabajo decente y crecimiento económico." .

# Degree Instance
:degree_10II a guide:Degree ;
    sch:name "Grado En Ingenieria Informatica" ;
    guide:degreeCode "10II" ;
    guide:hasCourse :course_105000034 .

# University Center Instance
:center_ets_informaticos a guide:UniversityCenter ;
    sch:name "E.T.S. De Ingenieros Informáticos" ;
    guide:offers :degree_10II .

