    sch:name "595024131 - Ingenieria de Audio II" ;
    guide:numberOfCredits 6.0 ;
    guide:courseType "Optativa" ;
    guide:teachingPeriod "2025-26" ;
    guide:semester "Sexto semestre" ;
    sch:inLanguage "Castellano" ;
    guide:periodStartingMonth "Febrero" ;
    guide:periodEndingMonth "Junio" ;
    sch:instructor :lecturer_lino, :lecturer_daniel, :lecturer_maria ;
    guide:hasCompetency :comp_EC01, :comp_SC01, :comp_SC02, :comp_CG02, :comp_CG04 ;
    guide:hasLearningResult :lr_RA170, :lr_RA408, :lr_RA409, :lr_RA411, :lr_RA412, :lr_RA410, :lr_RA406, :lr_RA169 ;
