:comp_EC01 a guide:Competency ;
    guide:competencyCode "CE EC01" ;
    guide:competencyDescription "Capacidad de construir, explotar y gestionar sistemas de captación, transporte, representación, procesado, almacenamiento, gestión y presentación de información multimedia, desde el punto de vista de los sistemas electrónicos." .

:comp_SC01 a guide:Competency ;
    guide:competencyCode "CE SC01" ;
    guide:competencyDescription "Capacidad para construir, explotar y gestionar las redes, servicios, procesos y aplicaciones de telecomunicaciones..." .

:comp_SC02 a guide:Competency ;
    guide:competencyCode "CE SC02" ;
    guide:competencyDescription "Capacidad para aplicar las técnicas en que se basan las redes, servicios y aplicaciones de telecomunicación..." .

:comp_CG02 a guide:Competency ;
    guide:competencyCode "CG 02" ;
    guide:competencyDescription "Capacidad de búsqueda y selección de información, de razonamiento crítico y de elaboración y defensa de argumentos dentro del área." .

:comp_CG04 a guide:Competency ;
    guide:competencyCode "CG 04" ;
    guide:competencyDescription "Capacidad de abstracción, de análisis y de síntesis y de resolución de problemas." .

:lr_RA170 a guide:LearningResult ;
    guide:learningResultCode "RA170" ;
    guide:learningResultDescription "Comprensión y manejo de las señales de audio y video (digitalización, formatos y sistemas de codificación)" .

:lr_RA408 a guide:LearningResult ;
    guide:learningResultCode "RA408" ;
    guide:learningResultDescription "Conocer los aspectos específicos en la digitalización de la señal de audio." .

:lr_RA409 a guide:LearningResult ;
    guide:learningResultCode "RA409" ;
    guide:learningResultDescription "Analizar las características y diseñar la interconexión entre equipos de audio." .

:lr_RA411 a guide:LearningResult ;
    guide:learningResultCode "RA411" ;
    guide:learningResultDescription "Conocer y entender en detalle las técnicas de codificación de audio que reducen el régimen binario." .

:lr_RA412 a guide:LearningResult ;
    guide:learningResultCode "RA412" ;
    guide:learningResultDescription "Comprender las técnicas que se emplean en el almacenamiento de la señal de audio y los sistemas ópticos más importantes." .

:lr_RA410 a guide:LearningResult ;
    guide:learningResultCode "RA410" ;
    guide:learningResultDescription "Comprender y analizar las características de los diferentes entornos en instalaciones de audio." .

:lr_RA406 a guide:LearningResult ;
    guide:learningResultCode "RA406" ;
    guide:learningResultDescription "Comprender y analizar las características de los diferentes equipos utilizados en ingeniería de audio para una utilización concreta." .

:lr_RA169 a guide:LearningResult ;
    guide:learningResultCode "RA1rag169" ;
    guide:learningResultDescription "Identificar, caracterizar y utilizar los dispositivos de captura y reproducción de audio y video..." .

