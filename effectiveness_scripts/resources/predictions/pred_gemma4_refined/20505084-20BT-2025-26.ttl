# Competencies
guide:CB03
    rdf:type guide:Competency ;
    guide:competencyCode "CB03" ;
    guide:competencyDescription "Que los estudiantes tengan la capacidad de reunir e interpretar datos relevantes (normalmente dentro de su área de estudio) para emitir juicios que incluyan una reflexión sobre temas relevantes de índole social, científica - ética" .

guide:CE05
    rdf:type guide:Competency ;
    guide:competencyCode "CE05" ;
    guide:competencyDescription "Capacidad para comprender los principales conceptos de Biología y saber relacionarlos con otras ciencias." .

# Learning Results
guide:RA121
    rdf:type guide:LearningResult ;
    guide:learningResultCode "RA121" ;
    guide:learningResultDescription "Comprender la dimensión ética y social de la biotecnología" .

guide:RA203
    rdf:type guide:LearningResult ;
    guide:learningResultCode "RA203" ;
    guide:learningResultDescription "Conocimiento profundo de los conceptos fundamentales de la Biología" .

