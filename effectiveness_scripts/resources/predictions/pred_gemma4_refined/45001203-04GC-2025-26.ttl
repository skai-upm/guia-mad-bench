# Course and Guide
:EnglishCourseGuide rdf:type guide:CourseGuide ;
    sch:name "45001203 - Inglés" ;
    guide:numberOfCredits 6.0 ;
    guide:courseType "Compulsory" ;
    guide:teachingPeriod "2025-26" ;
    guide:periodStartingMonth "September" ;
    guide:periodEndingMonth "January" ;
    sch:inLanguage "English" ;
    guide:hasSyllabus :EnglishSyllabus ;
    guide:hasCompetency :CT4, :CT5, :CT7, :CT8 ;
    guide:hasLearningResult :RA243, :RA53, :RA36, :RA219, :RA220 ;
    guide:hasEvaluation :EnglishEvaluationSystem ;
    guide:hasDidacticResource :TextbookResource, :VideoResource ;
    sch:instructor :SlavkaMadarova .

:EnglishCourse rdf:type guide:Course ;
    sch:name "45001203 - Inglés" ;
    guide:courseYear 2025 ;
    guide:courseType "Compulsory" ;
    sch:hasCourseInstance :EnglishCourseGuide .

:CivilEngineeringDegree rdf:type guide:BachelorDegree ;
    sch:name "04GC - Grance En Ingenieria Civil Y Territorial" ;
    guide:degreeCode "04GC" ;
    guide:hasCourse :EnglishCourse .

# University Center
:ETS_Caminos rdf:type guide:UniversityCenter ;
    sch:name "E.T.S. de Ing. de Caminos Canales y P." .

# Faculty
:SlavkaMadarova rdf:type guide:Lecturer ;
    sch:name "Slavka Madarova" ;
    sch:email "s.madarova@upm.es" ;
    guide:office "476" ;
    guide:tutorshipsSchedule "Sin horario. Tutoring schedule available at the start of the semester; appointments should be requested via email." .

# Competencies
:CT4 rdf:type guide:Competency ;
    guide:competencyCode "CT4" ;
    guide:competencyDescription "Capacidad de preparar y presentar con efectividad comunicaciones orales, escritas y gráficas. Completa el desarrollo de la competencia transversal 4ª del real decreto y desarrolla la competencia transversal 2ª de la normativa UPM." .

:CT5 rdf:type guide:Competency ;
    guide:competencyCode "CT5" ;
    guide:competencyDescription "Polivalencia y capacidad de aprendizaje autónomo. Desarrolla la competencia transversal 5ª del real decreto." .

:CT7 rdf:type guide:Competency ;
    guide:competencyCode "CT7" ;
    guide:competencyDescription "Comprensión y capacidad de utilización de los servicios de información y comunicación que ofrece INTERNET, en particular las plataformas telemáticas UPM de apoyo a la docencia. Desarrolla la competencia transversal 3ª de la normativa UPM." .

:CT8 rdf:type guide:Competency ;
    guide:competencyCode "CT8" ;
    guide:competencyDescription "Capacidad de comunicación técnica oral y escrita en lengua inglesa, con acreditación previa del nivel B2 del Common European Framework of Lenguages." .

# Learning Results
:RA243 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA243" ;
    guide:learningResultDescription "Interactúa correctamente en registros formales utilizando el inglés especializado" .

:RA53 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA53" ;
    guide:learningResultDescription "Se comunica de forma oral y escrita en lengua inglesa, empleando fluidamente la terminología profesional y académica de la ingeniería civil." .

:RA36 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA36" ;
    guide:learningResultDescription "Prepara y presenta exposiciones orales y escritas." .

:RA219 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA219" ;
    guide:learningResultDescription "Elabora y redacta correctamente informes y resúmenes sobre contenidos de ingeniería civil en inglés" .

:RA220 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA220" ;
    guide:learningResultDescription "Elabora y redacta correctamente cartas de solicitud de empleo y CVs adecuados a su preparación académica en ingeniería civil" .

# Syllabus
:EnglishSyllabus rdf:type guide:Syllabus ;
    guide:hasItem :SyllabusItem_Reading, :SyllabusItem_Writing, :SyllabusItem_Listening, :SyllabusItem_Speaking, :SyllabusItem_Translation, :SyllabusItem_Terminology .

:SyllabusItem_Reading rdf:type guide:SyllabusItem ;
    guide:itemIndex 1 ;
    guide:syllabusDescription "Reading skills in academic and professional English for civil engineering" .

:SyllabusItem_Writing rdf:type guide:SyllabusItem ;
    guide:itemIndex 2 ;
    guide:syllabusDescription "Writing skills in academic and professional English for civil engineering" .

# Evaluation System
:EnglishEvaluationSystem rdf:type guide:EvaluationSystem ;
    guide:evaluationDescription "By default, the evaluation system is progressive. To pass the course, students must complete all five mandatory partial assessments, obtain a minimum grade of 5 in each, and attend at least 70-80% of total class hours." ;
    guide:hasEvaluationTrial :GlobalExamTrial, :AssessmentActivity_1, :AssessmentActivity_2, :AssessmentActivity_3, :AssessmentActivity_4, :AssessmentActivity_5 .

:GlobalExamTrial rdf:type guide:EvaluationTrial ;
    guide:evaluationType "Global examination" ;
    guide:trialType "Written test" ;
    guide:trialMode "Face-to-face" ;
    guide:evaluationDuration "03:00" ;
    guide:gradePercentage "100%" ;
    guide:minimumScore "5 / 10" .

:AssessmentActivity_1 rdf:type guide:EvaluationTrial ;
    guide:trialType "Individual presentation" ;
    guide:trialMode "Face-to-face" ;
    guide:evaluationDuration "02:00" ;
    guide:gradePercentage "20%" ;
    guide:minimumScore "5 / 10" .

# Activities (from Schedule)
:AssessmentActivity_1 rdf:type guide:Activity ;
    guide:activityDescription "Write an abstract/essay" ;
    guide:activityFormat "Individual presentation" ;
    guide:attendanceType "Face-to-face" ;
    guide:activityDuration 2.0 .

# Required Knowledge
:Prerequisite_B2 rdf:type guide:RequiredKnowledge ;
    guide:previousKnowledge "Nivelación B2 en Lengua Inglesa" .

:Recommended_B1 rdf:type guide:RequiredKnowledge ;
    guide:previousKnowledge "To enroll in this course, students must provide prior certification of B1 level in English according to the CEFR." .

# Resources
:TextbookResource rdf:type guide:DidacticResource ;
    guide:bibliographyTitle "Textbooks, CDs, Dictionaries" ;
    guide:bibliographyType "Bibliography" ;
    guide:bibliographyDescription "The Linguistics Department offers access to a library containing books on linguistic theory, textbooks, exercise materials, and dictionaries." .

:VideoResource rdf:type guide:DidacticResource ;
    guide:bibliographyTitle "Videos and Specialised Texts" ;
    guide:bibliographyType "Web resource" .