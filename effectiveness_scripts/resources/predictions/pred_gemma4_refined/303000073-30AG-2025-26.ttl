# Evaluation System and Trials
guide:EvalSystem_Progresiva rdf:type guide:EvaluationSystem ;
    guide:evaluationDescription "Evaluación continua formativa. Se tendrá en cuenta el proceso de aprendizaje a lo largo de la materia." ;
    guide:hasEvaluationTrial guide:Trial_Desafio_Escuela, guide:Trial_Pacto_Educativo, guide:Trial_Analisis_LOMLOE, guide:Trial_Supuestos_Practicos, guide:Trial_Entrega_Practicas, guide:Trial_Autoevaluacion, guide:Trial_Prueba_Escrita .

guide:Trial_Desafio_Escuela rdf:type guide:EvaluationTrial ;
    guide:trialType "Trabajo Individual" ;
    guide:gradePercentage "0%" ;
    guide:minimumScore "5 / 10" ;
    guide:involvesCompetency guide:Competency_CT05, guide:Competency_CE29 ;
    guide:trialMode "Presencial" .

guide:Trial_Entrega_Practicas rdf:type guide:EvaluationTrial ;
    guide:trialType "Otras técnicas evaluativas" ;
    guide:gradePercentage "50%" ;
    guide:minimumScore "5 / 10" ;
    guide:trialMode "Presencial" .

guide:Trial_Prueba_Escrita rdf:type guide:EvaluationTrial ;
    guide:trialType "Examen Escrito" ;
    guide:gradePercentage "40%" ;
    guide:minimumScore "5 / 10" ;
    guide:trialMode "Presencial" .

