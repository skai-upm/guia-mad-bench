# Course Guide Instance
guide:course_565000434 rdf:type guide:CourseGuide ;
    sch:name "Resistencia De Materiales" ;
    sch:description "En la asignatura se abordará el cálculo de las tensiones y deformaciones que se producen en sólidos elásticos sometidos a diferentes solicitaciones (axil, flexión, cortante torsión) con objeto de evitar que se superen los valores admisibles." ;
    guide:numberOfCredits 4.5 ;
    guide:teachingPeriod "2025-26" ;
    guide:periodStartingMonth "Septiembre" ;
    guide:periodEndingMonth "Enero" ;
    sch:inLanguage "Castellano" ;
    guide:hasSyllabus guide:syllabus_resistencia ;
    guide:hasEvaluation guide:eval_system_resistencia ;
    guide:hasLearningResult guide:lr_ra59 ;
    guide:hasCompetency guide:comp_ce14, guide:comp_cg1, guide:comp_cg10, guide:comp_cg3, guide:comp_cg4, guide:comp_cg6, guide:comp_cg7 ;
    sch:instructor guide:prof_rafael_cascon, guide:prof_rafael_gomez ;
    guide:hasDidacticResource guide:res_vazquez, guide:res_ortiz, guide:res_timoshenko, guide:res_beer, guide:res_gere, guide:res_moodle ;
    guide:otherInformation "Curso: Segundo curso. Semestre: Tercer semestre. Carácter: Obligatoria." .

