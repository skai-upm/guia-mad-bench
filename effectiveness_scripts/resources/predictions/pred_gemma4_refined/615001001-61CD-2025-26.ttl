    rdf:type guide:Competency ;
    sch:name "CE01" ;
    guide:competencyDescription "Capacidad para utilizar con destreza los conceptos y métodos matemáticos que subyacen a los problemas de la ciencia de datos y la inteligencia artificial..." .

guide:CG06
    rdf:type guide:Competency ;
    sch:name "CG06" ;
    guide:competencyDescription "Identificar y utilizar las tecnologías de la información y las comunicaciones más adecuadas en el ámbito de la ingeniería." .

