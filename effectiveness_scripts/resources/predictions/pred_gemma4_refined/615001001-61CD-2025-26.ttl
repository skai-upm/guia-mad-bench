guide:RA28_9
    rdf:type guide:LearningResult ;
    guide:learningResultCode "RA28-9" ;
    guide:learningResultDescription "Resolver problemas con ayuda de software matemático" .

guide:RA10_8
    rdf:type guide:LearningResult ;
    guide:learningResultCode "RA10-8" ;
    guide:learningResultDescription "Modelizar matemáticamente problemas reales y conocer técnicas para resolverlos." .

guide:RA40
    rdf:type guide:LearningResult ;
    guide:learningResultCode "RA40" ;
    guide:learningResultDescription "Conocer y manejar ecuaciones lineales, matrices, geometría del plano y del espacio y espacios vectoriales." .

# Syllabus and Items
guide:Syllabus_AlgebraLineal
    rdf:type guide:Syllabus ;
    guide:hasItem guide:Topic_1, guide:Topic_2, guide:Topic_3, guide:Topic_4, guide:Topic_5, guide:Topic_6, guide:Topic_7 .

guide:Topic_1
    rdf:type guide:SyllabusItem ;
    guide:itemIndex 1 ;
    guide:syllabusDescription "Álgebra matricial. Sistemas de ecuaciones lineales." .

guide:Topic_2
    rdf:type guide:SyllabusItem ;
    guide:itemIndex 2 ;
    guide:syllabusDescription "Espacios vectoriales" .

guide:Topic_3
    rdf:type guide:SyllabusItem ;
    guide:itemIndex 3 ;
    guide:syllabusDescription "Aplicaciones lineales" .

guide:Topic_4
    rdf:type guide:SyllabusItem ;
    guide:itemIndex 4 ;
    guide:syllabusDescription "Diagonalización" .

guide:Topic_5
    rdf:type guide:SyllabusItem ;
    guide:itemIndex 5 ;
    guide:syllabusDescription "Espacio vectorial euclídeo" .

guide:Topic_6
    rdf:type guide:SyllabusItem ;
    guide:itemIndex 6 ;
    guide:syllabusDescription "Aplicaciones lineales entre espacio vectoriales euclideos" .

guide:Topic_7
    rdf:type guide:SyllabusItem ;
    guide:itemIndex 7 ;
    guide:syllabusDescription "Descomposición en valores singulares (SVD)" .

