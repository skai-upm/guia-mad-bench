# Degree and University Center
:Grado_En_Ingenieria_Agroambiental rdf:type guide:Degree ;
    sch:name "02IA - Grado En Ingenieria Agroambiental" ;
    guide:degreeCode "02IA" .

:Etsi_Agronomica_Aliment_y_Biosistemas rdf:type guide:UniversityCenter ;
    sch:name "Etsi Agronómica, Aliment. y Biosistemas" ;
    guide:offers :Grado_En_Ingenieria_Agroambiental .

# Course
:Botanica_Agricola_Y_Flora rdf:type guide:Course ;
    sch:name "25001209 - Botanica Agricola Y Flora" ;
    sch:courseCode 25001209 ;
    guide:courseType "Obligatoria" ;
    guide:courseYear 2025 ;
    guide:semester "Segundo semestre" .

:Grado_En_Ingenieria_Agroambiental guide:hasCourse :Botanica_Agricola_Y_Flora .

# Course Guide
:Botanica_Agricola_Y_Flora_Guide rdf:type guide:CourseGuide ;
    sch:name "Guía de Aprendizaje - Botanica Agricola Y Flora" ;
    sch:hasCourseInstance :Botanica_Agricola_Y_Flora ;
    sch:inLanguage "Castellano" ;
    guide:numberOfCredits 4.0 ;
    guide:teachingPeriod "2025-26" ;
    guide:periodStartingMonth "Febrero" ;
    guide:periodEndingMonth "Junio" ;
    guide:totalHours "104" ; # Calculated based on ECTS (4 * 26)
    sch:description "La asignatura se estructura en torno al objetivo establecido en la Orden CIN 323/2009 relativo a la adquisición de la capacidad de conocer, comprender y utilizar los principios de la identificación y caracterización de especies vegetales." ;
    guide:hasCompetency :CE15, :CG16, :CG3, :CG5, :CG7 ;
    guide:hasLearningResult :RA47, :RA48, :RA49, :RA50, :RA45, :RA46 ;
    guide:hasSyllabus :Syllabus_Botanica ;
    guide:hasEvaluation :EvalSystem_Botanica ;
    guide:hasDidacticResource :Recurso_Biblioteca, :Recurso_Web_Anthos, :Recurso_Herbario ;
    sch:instructor :M_Dolores_Curt_Fernandez_De_Sch_La_Mora, :Pedro_Luis_Aguado_Cortijo ;
    sch:director :Agustin_Garzon_Hidalgo ;
    sch:courseSchedule :Schedule_Botanica .

