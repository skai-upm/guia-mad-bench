# Competencies
:CE15 rdf:type guide:Competency ;
    guide:competencyCode "CE15" ;
    guide:competencyDescription "Capacidad para aplicar los principios de la botánica en la identificación y caracterización de especies vegetales..." .

:CG16 rdf:type guide:Competency ;
    guide:competencyCode "CG16" ;
    guide:competencyDescription "Aplicar conocimientos adquiridos a la práctica de la ingeniería agraria" .

:CG3 rdf:type guide:Competency ;
    guide:competencyCode "CG3" ;
    guide:competencyDescription "Que los estudiantes tengan la capacidad de reunir e interpretar datos relevantes..." .

:CG5 rdf:type guide:Competency ;
    guide:competencyCode "CG5" ;
    guide:competencyDescription "Que los estudiantes hayan desarrollado aquellas habilidades de aprendizaje necesarias para emprender estudios posteriores con un alto grado de autonomía" .

:CG7 rdf:type guide:Competency ;
    guide:competencyCode "CG7" ;
    guide:competencyDescription "Compromiso ético y profesional y respeto por el medio ambiente y la diversidad" .

# Learning Results
:RA47 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA47" ;
    guide:learningResultDescription "Reconocer y caracterizar las principales especies vegetales de interés en los campos de la agronomía y la flora española" .

:RA48 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA48" ;
    guide:learningResultDescription "Relacionar caracteres botánicos con las aplicaciones de las especies vegetales y sus requerimientos de hábitat" .

# Syllabus
:Syllabus_Botanica rdf:type guide:Syllabus ;
    guide:hasItem :SyllabusItem_1, :SyllabusItem_2, :SyllabusItem_3 .

:SyllabusItem_1 rdf:type guide:SyllabusItem ;
    guide:itemIndex 1 ;
    guide:syllabusDescription "Principios generales" .

:SyllabusItem_2 rdf:type guide:SyllabusItem ;
    guide:itemIndex 2 ;
    guide:syllabusDescription "Terminología" .

:SyllabusItem_3 rdf:type guide:SyllabusItem ;
    guide:itemIndex 3 ;
    guide:syllabusDescription "Gimnospermas de interés agrícola y medioambiental" .

# Evaluation System
:EvalSystem_Botanica rdf:type guide:EvaluationSystem ;
    guide:evaluationDescription "Sistema de evaluación progresiva y global." ;
    guide:hasEvaluationTrial :Trial_Prog_1, :Trial_Global_Examen .

:Trial_Prog_1 rdf:type guide:EvaluationTrial ;
    guide:trialType "Examen Escrito" ;
    guide:evaluationType "Evaluación Progresiva" ;
    guide:gradePercentage "35%" ;
    guide:evaluationDuration "01:00" ;
    guide:trialMode "Presencial" ;
    guide:minimumScore "5/10" .

:Trial_Global_Examen rdf:type guide:EvaluationTrial ;
    guide:trialType "Examen Escrito" ;
    guide:evaluationType "Evaluación Global" ;
    guide:gradePercentage "75%" ;
    guide:evaluationDuration "02:00" ;
    guide:trialMode "Presencial" ;
    guide:minimumScore "5/10" .

