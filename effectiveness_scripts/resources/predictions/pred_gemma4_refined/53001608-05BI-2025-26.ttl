# Course Guide
g:course_guide_53001608 rdf:type guide:CourseGuide ;
    sch:name "Sistemas Integrados de Fabricación" ;
    sch:description "La asignatura de Sistemas Integrados de Fabricación tiene como objetivo principal adquirir una visión global de la influencia que los principales aspectos de los procesos de fabricación tienen en un sistema de producción." ;
    guide:numberOfCredits 3.0 ;
    guide:teachingPeriod "2025-26" ;
    guide:teachingPeriodMonths "Septiembre-Enero" ;
    sch:inLanguage "Castellano" ;
    guide:inpersonHours "Presencial" ;
    guide:remoteHours "0" ;
    guide:hasSyllabus g:syllabus_53001608 ;
    guide:hasEvaluation g:eval_system_53001608 ;
    guide:hasLearningResult g:lr_ra40, g:lr_ra110, g:lr_ra108, g:lr_ra38, g:lr_ra39 ;
    guide:hasCompetency g:comp_muii_c, g:comp_muii_e, g:comp_muii_g, g:comp_muii_cb07, g:comp_muii_cb09, g:comp_muii_ce02, g:comp_muii_cg02, g:comp_muii_cg06, g:comp_muii_cg08, g:comp_muii_cg10 ;
    guide:hasDidacticResource g:res_flexsim, g:res_kalpakjian, g:res_lean_manufacturing, g:res_flexsim_help ;
    sch:director g:lecturer_jose_rios ;
    sch:instructor g:lecturer_carlos_polvorinos, g:lecturer_jose_rios ;
    sch:courseSchedule g:schedule_53001608 .

