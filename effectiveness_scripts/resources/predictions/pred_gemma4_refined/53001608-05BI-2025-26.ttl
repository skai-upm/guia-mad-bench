# Competencies
g:comp_muii_c rdf:type guide:Competency ;
    guide:competencyCode "MUII. (c)" ;
    guide:competencyDescription "DISEÑA Habilidad para diseñar un sistema, componente o proceso que alcance los requisitos deseados" .

g:comp_muii_e rdf:type guide:Competency ;
    guide:competencyCode "MUII. (e)" ;
    guide:competencyDescription "RESUELVE. Habilidad para identificar, formular y resolver problemas de ingeniería." .

g:comp_muii_g rdf:type guide:Competency ;
    guide:competencyCode "MUII. (g)" ;
    guide:competencyDescription "COMUNICA Habilidad para comunicar eficazmente." .

# Learning Results
g:lr_ra40 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA40" ;
    guide:learningResultDescription "Capacidad para analizar la influencia de determinadas variables en la eficiencia de un proceso" .

g:lr_ra110 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA110" ;
    guide:learningResultDescription "Definir actuaciones de mejora y evolución sistemática" .

