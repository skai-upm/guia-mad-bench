# Evaluation System and Trials
g:eval_system_53001608 rdf:type guide:EvaluationSystem ;
    guide:evaluationDescription "La calificación final de la asignatura viene definida por la suma ponderada de las Pruebas de Evaluación Intermedia según: T1 (15%) + T2 (25%) + T3 (60%)." ;
    guide:hasEvaluationTrial g:trial_t1, g:trial_t2, g:trial_t3, g:trial_global .

g:trial_t1 rdf:type guide:EvaluationTrial ;
    guide:evaluationType "Evaluación Progresiva" ;
    guide:gradePercentage "15%" ;
    guide:minimumScore "5 / 10" ;
    guide:evaluationDuration "06:00" ;
    guide:trialType "Trabajo en Grupo" ;
    guide:trialMode "No Presencial" ;
    guide:involvesCompetency g:comp_muii_ce02, g:comp_muii_cg02 .

g:trial_t3 rdf:type guide:EvaluationTrial ;
    guide:evaluationType "Evaluación Progresiva" ;
    guide:gradePercentage "60%" ;
    guide:minimumScore "5 / 10" ;
    guide:evaluationDuration "32:00" ;
    guide:trialType "Trabajo en Grupo" ;
    guide:trialMode "No Presencial" ;
    guide:involvesCompetency g:comp_muii_c, g:comp_muii_e, g:comp_muii_g .

g:trial_global rdf:type guide:EvaluationTrial ;
    guide:evaluationType "Evaluación Global" ;
    guide:gradePercentage "100%" ;
    guide:minimumScore "5 / 10" ;
    guide:evaluationDuration "02:30" ;
    guide:trialType "Trabajo Individual" ;
    guide:trialMode "Presencial" .

