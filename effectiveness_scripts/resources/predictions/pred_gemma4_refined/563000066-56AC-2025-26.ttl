# Competencies
:comp_CE1 a guide:Competency ;
    guide:competencyCode "CE1" ;
    guide:competencyDescription "Capacidad de diseñar, innovar y gestionar nuevos productos teniendo en cuenta criterios de calidad y medioambientales" .

:comp_CE4 a guide:Competency ;
    guide:competencyCode "CE4" ;
    guide:competencyDescription "Capagidad de manejar e integrar las herramientas de representación, simulación y cálculo CAD-CAM-CAE para una correcta definición del producto diseñado" .

:comp_CE5 a guide:Competency ;
    guide:competencyCode "CE5" ;
    guide:competencyDescription "Capacidad para seleccionar los materiales adecuados para un correcto diseño de producto" .

:comp_CE8 a guide:Competency ;
    guide:competencyCode "CE8" ;
    guide:competencyDescription "Capacidad para aplicar herramientas de visualización y generación virtual de productos" .

# Learning Results
:lr_RA45 a guide:LearningResult ;
    guide:learningResultCode "RA45" ;
    guide:learningResultDescription "Gestionar y procesar la información generada desde diferentes herramientas para realizar proyectos de prototipado rápido." .

:lr_RA47 a guide:LearningResult ;
    guide:learningResultCode "RA47" ;
    guide:learningResultDescription "Realizar series cortas mediante técnicas de fabricación rápida." .

# Syllabus
:syllabus_563000066 a guide:Syllabus ;
    guide:hasItem :item_intro, :item_tecnicas, :item_seleccion, :item_proceso_rp, :item_slicing .

:item_intro a guide:SyllabusItem ;
    guide:itemIndex 1 ;
    guide:syllabusDescription "Introducción" .

:item_tecnicas a guide:SyllabusItem ;
    guide:itemIndex 2 ;
    guide:syllabusDescription "Técnicas de Prototipado Rápido (Fundamentos, Corte y laminado, Estereolitografía, Fotopolimerización, Tecnologías polímeros sólidos, Sinterizado selectivo láser)" .

