    guide:learningResultDescription "Entender el marco legal en el que desarrolla su actividad el ingeniero de datos." .

# Syllabus
guide:Syllabus_CTS rdf:type guide:Syllabus ;
    guide:hasItem guide:SyllabusItem_1, guide:SyllabusItem_2, guide:SyllabusItem_3, guide:SyllabusItem_4 .

guide:SyllabusItem_1 rdf:type guide:SyllabusItem ;
    guide:itemIndex 1 ;
    guide:syllabusDescription "Sostenibilidad ecológica y social" .

guide:SyllabusItem_2 rdf:type guide:SyllabusItem ;
    guide:itemIndex 2 ;
    guide:syllabusDescription "Las revoluciones tecnológicas" .

guide:SyllabusItem_3 rdf:type guide:SyllabusItem ;
    guide:itemIndex 3 ;
    guide:syllabusDescription "TIC, ética y derechos humanos" .

guide:SyllabusItem_4 rdf:type guide:SyllabusItem ;
    guide:itemIndex 4 ;
    guide:syllabusDescription "Casos de uso de tecnología social" .

# Evaluation System and Trials
guide:EvalSystem_CTS rdf:type guide:EvaluationSystem ;
    guide:evaluationDescription "La evaluación progresiva libera cada tema a partir de una nota de 3 sobre 10. Se aprueba la asignatura por evaluación progresiva si se tiene más de un 3 en los tres temas y la media ponderada de todas las notas da un 5 o más." ;
    guide:hasEvaluationTrial guide:Trial_Tema1, guide:Trial_Tema2, guide:Trial_Tema3, guide:Trial_Final .

guide:Trial_Tema1 rdf:type guide:EvaluationTrial ;
    guide:trialType "Examen Escrito" ;
    guide:evaluationType "Progresiva" ;
    guide:gradePercentage "25%" ;
    guide:minimumScore "3 / 10" ;
    guide:trialWeek "4" ;
    guide:trialMode "Presencial" .

guide:Trial_Tema2 rdf:type guide:EvaluationTrial ;
    guide:trialType "Examen Escrito" ;
    guide:evaluationType "Progresiva" ;
    guide:gradePercentage "25%" ;
    guide:minimumScore "3 / 10" ;
    guide:trialWeek "9" ;
    guide:trialMode "Presencial" .

guide:Trial_Tema3 rdf:type guide:EvaluationTrial ;
    guide:trialType "Presentación en Grupo" ;
    guide:evaluationType "Progresiva" ;
    guide:gradePercentage "2．25%" ;
    guide:minimumScore "3 / 10" ;
    guide:trialWeek "13" ;
    guide:trialMode "Presencial" .

guide:Trial_Final rdf:type guide:EvaluationTrial ;
    guide:trialType "Examen Escrito" ;
    guide:evaluationType "Global" ;
    guide:gradePercentage "100%" ;
    guide:minimumScore "5 / 10" ;
    guide:trialWeek "17" ;
    guide:trialMode "Presencial" .

# Schedule and Activities
guide:Schedule_CTS rdf:type guide:Schedule ;
    sch:eventSchedule guide:Event_W1, guide:Event_W4, guide:Event_W9, guide:Event_W13, guide:Event_W14, guide:Event_W17 .

guide:Event_W1 rdf:type guide:ScheduleEvent ;
    guide:eventWeek "1" ;
    guide:hasActivity guide:Act_Intro .

guide:Act_Intro rdf:type guide:Activity ;
    guide:activityDescription "Introducción a la asignatura" ;
    guide:activityDuration 2.5 ;
    guide:activityFormat "Lección Magistral" .

guide:Event_W4 rdf:type guide:ScheduleEvent ;
    guide:eventWeek "4" ;
    guide:hasActivity guide:Act_Tema1_Eval .

guide:Act_Tema1_Eval rdf:type guide:Activity ;
    guide:activityDescription "Evaluación contenidos Tema 1" ;
    guide:activityDuration 1.0 ;
    guide:attendanceType "Presencial" .

