    guide:competencyCode "CB02" ;
    guide:competencyDescription "Que los estudiantes sepan aplicar sus conocimientos a su trabajo o vocación de una forma profesional..." .

guide:CB03 rdf:type guide:Competency ;
    guide:competencyCode "CB03" ;
    guide:competencyDescription "Que los estudiantes tengan la capacidad de reunir e interpretar datos relevantes..." .

guide:CG02 rdf:type guide:Competency ;
    guide:competencyCode "CG02" ;
    guide:competencyDescription "Desarrollar la capacidad de trabajar en equipo empleando metod．metodologías ágiles..." .

# Learning Results
