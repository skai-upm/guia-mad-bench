:item_nervous rdf:type guide:SylabusItem ; guide:syllabusDescription "Sistema nervioso" ; guide:itemIndex 2 .
:item_circulatory rdf:type guide:SyllabusItem ; guide:syllabusDescription "Sistema circulatorio. Sistema hematopoyetico" ; guide:itemIndex 3 .
:item_respiratory rdf:type guide:SyllabusItem ; guide:syllabusDescription "Sistema respiratorio" ; guide:itemIndex 4 .
:item_endocrine rdf:type guide:SyllabusItem ; guide:syllabusDescription "Sistema endocrino" ; guide:itemIndex 5 .
:item_renal rdf:type guide:SyllabusItem ; guide:syllabusDescription "Sistema Renal" ; guide:itemIndex 6 .
:item_digestive rdf:type guide:SyllabusItem ; guide:syllabusDescription "Sistema digestivo" ; guide:itemIndex 7 .
:item_immune rdf:type guide:SyllabusItem ; guide:syllabusDescription "Sistema inmunológico" ; guide:itemIndex 8 .

