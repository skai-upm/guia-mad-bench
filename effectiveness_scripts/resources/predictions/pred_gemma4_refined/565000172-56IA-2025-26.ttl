# Competencies
guide:comp_CE24 rdf:type guide:Competency ;
    guide:competencyCode "CE 24" ;
    guide:competencyDescription "Capacidad para diseñar sistemas electrónicos analógicos, digitales y de potencia." .

guide:comp_CE25 rdf:type guide:Competency ;
    guide:competencyCode "CE 25" ;
    guide:competencyDescription "Conocimiento y capacidad para el modelado y simulación de sistemas." .

guide:comp_CG1 rdf:type guide:Competency ;
    guide:competencyCode "CG 1" ;
    guide:competencyDescription "Conocer y aplicar los conocimientos de ciencias y tecnologías básicas a la práctica de la Ingeniería Industrial" .

guide:comp_CG10 rdf:type guide:Competency ;
    guide:competencyCode "CG 10" ;
    guide:competencyDescription "Creatividad." .

guide:comp_CG3 rdf:type guide:Competency ;
    guide:competencyCode "CG 3" ;
    guide:competencyDescription "Aplicar los conocimientos adquiridos para identificar, formular y resolver problemas en contextos amplios..." .

guide:comp_CG4 rdf:type guide:Competency ;
    guide:competencyCode "CG 4" ;
    guide:competencyDescription "Comprender el impacto de la ingeniería en el medio ambiente, el desarrollo sostenible de la sociedad..." .

guide:comp_CG6 rdf:type guide:Competency ;
    guide:competencyCode "CG 6" ;
    guide:competencyDescription "Poseer las habilidades de aprendizaje que permitan continuar estudiando a lo largo de toda la vida..." .

guide:comp_CG7 rdf:type guide:Competency ;
    guide:competencyCode "CG 7" ;
    guide:competencyDescription "Incorporar las TIC y las tecnologías y herramientas de la Ingeniería Industrial en sus actividades profesionales" .

# Learning Results
guide:lr_RA58 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA58" ;
    guide:learningResultDescription "Conocimiento y capacidad para el modelado y simulación de sistemas electrónicos digitales." .

guide:lr_RA59 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA59" ;
    guide:learningResultDescription "Capacidad para el diseño de sistemas electrónicos digitales." .

guide:lr_RA238 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA238" ;
    guide:learningResultDescription "Realizar descripciones de circuitos mediante VHDL." .

