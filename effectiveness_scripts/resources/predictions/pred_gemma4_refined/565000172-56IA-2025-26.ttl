    guide:evaluationType "Examen" ;
    guide:gradePercentage "25%" ;
    guide:minimumScore "0 / 10" ;
    guide:trialMode "Presencial" ;
    guide:trialDescription "Examen parcial en la semana decimoprimera." .

guide:trial_global rdf:type guide:EvaluationTrial ;
    guide:evaluationType "Examen" ;
    guide:gradePercentage "40%" ;
    guide:minimumScore "4 / 10" ;
    guide:trialMode "Presencial" ;
    guide:trialDescription "Examen global en aula." .

guide:trial_trabajo rdf:type guide:EvaluationTrial ;
