# Competencies
_:compCE1 a guide:Competency ;
    guide:competencyCode "CE1" ;
    guide:competencyDescription "Capacidad para la resolución de los problemas matemáticos que puedan plantemos en la ingeniería. Aptitud para aplicar los conocimientos sobre: álgebra lineal; geometría; geometría diferencial; cálculo diferencial e integral; ecuaciones diferenciales ordinarias y en derivadas parciales; métodos numéricos; algorítmica numérica; optimización" .

_:compCG1 a guide:Competency ;
    guide:competencyCode "CG1" ;
    guide:competencyDescription "Conocer y aplicar conocimientos de ciencias y tecnologías básicas a la práctica de la Ingeniería Industrial." .

_:compCG10 a guide:Competency ;
    guide:competencyCode "CG10" ;
    guide:competencyDescription "Capacidad para generar nuevas ideas (Creatividad)." .

_:compCG2 a guide:Competency ;
    guide:competencyCode "CG2" ;
    guide:competencyDescription "Poseer capacidad para diseñar, desarrollar, implementar, gestionar y mejorar productos, sistemas y procesos en los distintos ámbitos industriales, usando técnicas analíticas, computacionales o experimentales apropiadas." .

_:compCG3 a guide:Competency ;
    guide:competencyCode "CG3" ;
    guide:competencyDescription "Aplicar los conocimientos adquiridos para identificar, formular y resolver problemas dentro de contextos amplios y multidisciplinarios, siendo capaces de integrar conocimientos, trabajando en equipos multidisciplinares." .

_:compCG6 a guide:Competency ;
    guide:competencyCode "CG6" ;
    guide:competencyDescription "Poseer habilidades de aprendizaje que permitan continuar estudiando a lo largo de la vida para su adecuado desarrollo profesional." .

# Learning Results
_:lrRA242 a guide:LearningResult ;
    guide:learningResultCode "RA242" ;
    guide:learningResultDescription "Capacidad de abstracción y reconocimiento de conceptos generales en situaciones prácticas." .

_:lrRA243 a guide:LearningResult ;
    guide:learningResultCode "RA243" ;
    guide:learningResultDescription "Capacidad para formular y analizar modelos de procesos naturales. Capacidad de interpretar los resultados obtenidos y evaluar los modelos utilizados." .

_:lrRA244 a guide:LearningResult ;
    guide:learningResultCode "RA244" ;
    guide:learningResultDescription "Habilidad para aplicación de métodos analíticos a la resolución de problemas técnicos conocidos que han aparecido en otras materias." .

_:lrRA232 a guide:LearningResult ;
    guide:learningResultCode "RA232" ;
    guide:learningResultDescription "Proporciona un abanico muy diverso de herramientas para abordar el tratamiento de modelos de procesos naturales." .

_:lrRA245 a guide:LearningResult ;
    guide:learningResultCode "RA245" ;
    guide:learningResultDescription "Proporciona una panorámica muy amplia de modelos clásicos aplicados en muy diversos campos: mecánica, ecología teórica, economía, epidemiología, etc." .

# Syllabus
_:syllabus a guide:Syllabus ;
    guide:hasItem _:item1, _:item2, _:item3, _:item4, _:item5 .

_:item1 a guide:SyllabusItem ;
    guide:itemIndex 1 ;
    guide:syllabusDescription "Ecuaciones diferenciales ordinarias de primer orden." .

_:item2 a guide:SyllabusItem ;
    guide:itemIndex 2 ;
    guide:syllabusDescription "Sistemas de ecuaciones diferencial lineales de primer orden." .

_:item3 a guide:SyllabusItem ;
    guide:itemIndex 3 ;
    guide:syllabusDescription "Ecuaciones diferenciales lineales de orden n." .

_:item4 a guide:SyllabusItem ;
    guide:itemIndex 4 ;
    guide:syllabusDescription "Ecuaciones en derivadas parciales de primer orden." .

_:item5 a guide:SyllabusItem ;
    guide:itemIndex 5 ;
    guide:syllabusDescription "Introducción a las ecuaciones en derivadas parciales de segundo orden." .

# Evaluation System
_:evalSystem a guide:EvaluationSystem ;
    guide:evaluationDescription "La evaluación progresiva consta de las siguientes pruebas: Dos prácticas de computación científica... Una primera prueba escrita con un valor del 40%... Una segunda prueba escrita con un valor del 50%..." ;
    guide:hasEvaluationTrial _:trial1, _:trial2, _:trial3, _:trial4 .

_:trial1 a guide:EvaluationTrial ;
    guide:trialType "Examen de Prácticas" ;
    guide:gradePercentage "5%" ;
    guide:evaluationDuration "02:00" ;
    guide:trialMode "Presencial" ;
    guide:involvesCompetency _:compCG1, _:compCG2, _:compCG3, _:compCE1 .

_:trial2 a guide:EvaluationTrial ;
    guide:trialType "Examen Escrito" ;
    guide:gradePercentage "40%" ;
    guide:evaluationDuration "02:00" ;
    guide:trialMode "Presencial" ;
    guide:involvesCompetency _:compCG1, _:compCG2, _:compCG6, _:compCG10, _:compCE1 .

_:trial3 a guide:EvaluationTrial ;
    guide:trialType "Examen de Prácticas" ;
    guide:gradePercentage "5%" ;
    guide:evaluationDuration "02:00" ;
    guide:trialMode "Presencial" ;
    guide:involvesCompetency _:compCG3, _:compCE1, _:compCG1, _:compCG2 .

_:trial4 a guide:EvaluationTrial ;
    guide:trialType "Examen Escrito" ;
    guide:gradePercentage "50%" ;
    guide:evaluationDuration "02:30" ;
    guide:trialMode "Presencial" ;
    guide:involvesCompetency _:compCG1, _:compCG2, _:compCG6, _:compCG10, _:compCE1 .

