# Competencies
guide:comp_CB01 a guide:Competency ;
    guide:competencyCode "CB01" ;
    guide:competencyDescription "Que los estudiantes hayan demostrado poseer y comprender conocimientos en un área de estudio..." .

guide:comp_CC12 a guide:Competency ;
    guide:competencyCode "CC12" ;
    guide:competencyDescription "Conocimiento y aplicación de las características, funcionalidades y estructura de las bases de datos..." .

guide:comp_CC13 a guide:Competency ;
    guide:competencyCode "CC13" ;
    guide:competencyDescription "Conocimiento y aplicación de las herramientas necesarias para el almacenamiento, procesamiento y acceso a los Sistemas de información..." .

guide:comp_CC7 a guide:Competency ;
    guide:competencyCode "CC7" ;
    guide:competencyDescription "Conocimiento, diseño y utilización de forma eficiente los tipos y estructuras de datos más adecuados..." .

guide:comp_CT1 a guide:Competency ;
    guide:competencyCode "CT1" ;
    guide:competencyDescription "Análisis y síntesis: Descomponer la información en unidades más pequeñas..." .

guide:comp_CT2 a guide:Competency ;
    guide:competencyCode "CT2" ;
    guide:competencyDescription "Resolución de problemas: Identificar, analizar y definir los elementos significativos que constituyen un problema..." .

# Learning Results
guide:lr_RA1 a guide:LearningResult ;
    guide:learningResultCode "RA1" ;
    guide:learningResultDescription "Conoce y utiliza correctamente las estructuras y tipos de ficheros de datos que conforman un sistema de información." .

guide:lr_RA2 a guide:LearningResult ;
    guide:learningResultCode "RA2" ;
    guide:learningResultDescription "Conoce la estructura y utilización de ficheros índices para manejar ficheros de datos" .

guide:lr_RA7 a guide:LearningResult ;
    guide:learningResultCode "RA7" ;
    guide:learningResultDescription "Lee un texto un artículo científico de cierta complejidad..." .

guide:lr_RA6 a guide:LearningResult ;
    guide:learningResultCode "RA6" ;
    guide:learningResultDescription "Identifica las estructuras y problemas derivados de la integridad referencial en bases de datos" .

guide:lr_RA3 a guide:LearningResult ;
    guide:learningResultCode "RA3" ;
    guide:learningResultDescription "Conoce las bases teóricas del modelado conceptual de datos..." .

guide:lr_RA4 a guide:LearningResult ;
    guide:learningResultCode "RA4" ;
    guide:learningResultDescription "Conoce los fundamentos de los lenguajes de acceso a bases de datos relaciones..." .

guide:lr_RA5 a guide:LearningResult ;
    guide:learningResultCode "RA5" ;
    guide:learningResultDescription "Conoce los fundamentos teóricos del proceso concurrente de transacciones en bases de datos..." .

# Syllabus
guide:syllabus_db a guide:Syllabus ;
    guide:hasItem guide:item_intro, guide:item_modeling, guide:item_relational, guide:item_sql, guide:item_security, guide:item_programming, guide:item_storage .

guide:item_intro a guide:SyllabusItem ;
    guide:itemIndex 1 ;
    guide:syllabusDescription "Introducción a las bases de datos, Tipos de bases de datos, Arquitectura cliente-servidor" .

guide:item_modeling a guide:SyllabusItem ;
    guide:itemIndex 2 ;
    guide:syllabusDescription "Modelado de datos: Modelo entidad-relación" .

guide:item_relational a guide:SyllabusItem ;
    guide:itemIndex 3 ;
    guide:syllabusDescription "Modelo relacional: Introducción, Transformación, Normalización, Álgebra relacional" .

guide:item_sql a guide:SyllabusItem ;
    guide:itemIndex 4 ;
    guide:syllabusDescription "El lenguaje SQL: DDL, DML, DQL, DCL, TCL" .

guide:item_security a guide:SyllabusItem ;
    guide:itemIndex 5 ;
    guide:syllabusDescription "Seguridad en bases de datos: Amenazas, Estrategias, Mejores prácticas" .

guide:item_programming a guide:SyllabusItem ;
    guide:itemIndex 6 ;
    guide:syllabusDescription "Programación contra bases de datos: Introducción, Drivers nativos, ORM" .

guide:item_storage a guide:SyllabusItem ;
    guide:itemIndex 7 ;
    guide:syllabusDescription "Almacenamiento de información basada en ficheros: CSV, JSON, XML" .

# Evaluation System
guide:eval_system_db a guide:EvaluationSystem ;
    guide:evaluationDescription "La evaluación se llevará a cabo mediante dos sistemas: evaluación progresiva y evaluación global." ;
    guide:hasEvaluationTrial guide:trial_oral_practice, guide:trial_final_exam, guide:trial_written_practice, guide:trial_extraordinary_exam .

guide:trial_oral_practice a guide:EvaluationTrial ;
    guide:trialType "Examen de Prácticas" ;
    guide:evaluationType "Evaluación Progresiva" ;
    guide:gradePercentage "40%" ;
    guide:minimumScore "/ 10" ;
    guide:evaluationDuration "06:00" ;
    guide:trialMode "Presencial" .

guide:trial_final_exam a guide:EvaluationTrial ;
    guide:trialType "Examen Escrito" ;
    guide:evaluationType "Evaluación Progresiva" ;
    guide:gradePercentage "50%" ;
    guide:minimumScore "4 / 10" ;
    guide:evaluationDuration "02:15" ;
    guide:trialMode "Presencial" .

guide:trial_written_practice a guide:EvaluationTrial ;
    guide:trialType "Examen de Prácticas" ;
    guide:evaluationType "Evaluación Progresiva" ;
    guide:gradePercentage "10%" ;
    guide:minimumScore "3 / 10" ;
    guide:evaluationDuration "00:15" ;
    guide:trialMode "Presencial" .

guide:trial_extraordinary_exam a guide:EvaluationTrial ;
    guide:trialType "Examen Escrito" ;
    guide:evaluationType "Convocatoria Extraordinaria" ;
    guide:gradePercentage "100%" ;
    guide:minimumScore "5 / 10" ;
    guide:evaluationDuration "02:30" ;
    guide:trialMode "Presencial" .

