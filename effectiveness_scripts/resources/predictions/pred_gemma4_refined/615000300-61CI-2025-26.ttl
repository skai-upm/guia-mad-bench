# Course and Course Guide
guide:course_615000300 a guide:Course ;
    sch:name "Bases De Datos" ;
    sch:courseCode 615000300 ;
    guide:courseType "Obligatoria" ;
    sch:hasCourseInstance guide:course_guide_615000300 .

guide:course_guide_615000300 a guide:CourseGuide ;
    sch:name "Guía de Aprendizaje - Bases De Datos" ;
    guide:numberOfCredits 9.0 ;
    guide:teachingPeriod "2025-26" ;
    guide:periodStartingMonth "Septiembre" ;
    guide:periodEndingMonth "Enero" ;
    sch:inLanguage "Castellano" ;
    sch:description "En esta asignatura el alumno aprenderá los conceptos fundamentales, tanto te<0xC2>óricos como prácticos, necesarios para conocer el funcionamiento de las bases de datos." ;
    guide:hasSyllabus guide:syllabus_db ;
    guide:hasCompetency guide:comp_CB01, guide:comp_CC12, guide:comp_CC13, guide:comp_CC7, guide:comp_CT1, guide:comp_CT2 ;
    guide:hasLearningResult guide:lr_RA1, guide:lr_RA2, guide:lr_RA7, guide:lr_RA6, guide:lr_RA3, guide:lr_RA4, guide:lr_RA5 ;
    guide:hasEvaluation guide:eval_system_db ;
    guide:hasDidacticResource guide:res_moodle, guide:res_elmasri, guide:res_silberschatz, guide:res_date .

