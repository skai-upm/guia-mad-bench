# Competency Instances
:comp_CB10 rdf:type guide:Competency ;
    guide:competencyCode "CB10" ;
    guide:competencyDescription "Que los estudiantes posean las habilidades de aprendizaje que les permitan continuar estudiando de un modo que habrá de ser en gran medida autodirigido o autónomo." .

:comp_CEA1 rdf:type guide:Competency ;
    guide:competencyCode "CE-A1" ;
    guide:competencyDescription "Capacitación científico-técnica y metodológica suficiente para el proyecto, análisis, planificación, explotación y mantenimiento de obras civiles..." .

:comp_CEA2 rdf:type guide:Competency ;
    guide:competencyCode "CE-A2" ;
    guide:competencyDescription "Conocimiento y capacidad para proyectar y dimensionar obras e instalaciones de ingeniería civil" .

# Learning Result Instances
:lr_RA10 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA10" ;
    guide:learningResultDescription "Argumenta la resolucion de los problemas de gestion mediante logica cientifica y aplicando una metodologia razonada." .

:lr_RA103 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA103" ;
    guide:learningResultDescription "Aplica técnicas de optimización a la resolución de problemas de sistemas de ingeniería civil" .

# Syllabus Instance
:syllabus_43000139 rdf:type guide:Syllabus ;
    guide:hasItem :item_tema1, :item_tema2, :item_tema3 .

:item_tema1 rdf:type guide:SyllabusItem ;
    guide:itemIndex 1 ;
    guide:syllabusDescription "El proyecto ferroviario: Fundamentos y normativa, Proyectos de trazado, Proyectos de instalaciones, Material móvil, Métodos constructivos" .

:item_tema2 rdf:type guide:SyllabusItem ;
    guide:itemIndex 2 ;
    guide:syllabusDescription "Comportamiento de la vía ferroviaria: Esfuerzos estáticos, Dinámica de la vía" .

# Evaluation System and Trials
:eval_system_43000139 rdf:type guide:EvaluationSystem ;
    guide:evaluationDescription "Evaluación continua y prueba final." ;
    guide:hasEvaluationTrial :trial_control_w4, :trial_examen_parcial_w9, :trial_examen_ordinario_w17 .

