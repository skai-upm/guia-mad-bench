# Competencies
:Competency_12TG_CG8 rdf:type guide:Competency ;
    guide:competencyCode "12TG-CG8" ;
    guide:competencyDescription "Diseñar, desarrollar, gestionar y ejecutar proyectos relacionados con esta ingeniería en el ámbito de la investigación, innovación o producción" .

:Competency_CT1 rdf:type guide:Competency ;
    guide:competencyCode "CT1" ;
    guide:competencyDescription "COMUNICACIÓN ORAL Y ESCRITA Capacidad para transmitir conocimientos y expresar ideas y argumentos de manera clara..." .

:Competency_CT2 rdf:type guide:Competency ;
    guide:competencyCode "CT2" ;
    guide:competencyDescription "USO DE LAS TIC Capacidad sobre conocimientos tecnológicos que permitan desenvolverse cómodamente..." .

:Competency_CT9 rdf:type guide:Competency ;
    guide:competencyCode "CT9" ;
    guide:competencyDescription "RESOLUCIÓN DE PROBLEMAS Desarrollar en los alumnos una actitud mental mediante la aplicación de procedimientos estructurados..." .

:Competency_CT10 rdf:type guide:Competency ;
    guide:competencyCode "CT10" ;
    guide:competencyDescription "ANÁLISIS Y SÍNTESIS Capacidad de reconocer y describir los elementos constitutivos de una realidad..." .

# Learning Results
:LR_RA218 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA218" ;
    guide:learningResultDescription "Contextualizar las redes de área local en la arquitectura Internet." .

:LR_RA221 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA221" ;
    guide:learningResultDescription "Identificar los elementos de las redes de telecomunicación" .

:LR_RA229 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA229" ;
    guide:learningResultDescription "Describir los servicios, mecanismos y protocolos de seguridad empleados en las redes de telecomunicación." .

# Evaluation System and Trials
:EvalSystem_RedesTelecom rdf:type guide:EvaluationSystem ;
    guide:evaluationDescription "Sistema de evaluación progresiva y global." ;
    guide:hasEvaluationTrial :Trial_EP1, :Trial_GlobalExam .

:Trial_EP1 rdf:type guide:EvaluationTrial ;
    guide:trialType "Examen Escrito" ;
    guide:evaluationType "progresiva" ;
    guide:gradePercentage "50%" ;
    guide:minimumScore "0 / 10" ;
    guide:trialMode "Presencial" ;
    guide:evaluationDuration "02:00" .

:Trial_GlobalExam rdf:type guide:EvaluationTrial ;
    guide:trialType "Examen Escrito" ;
    guide:evaluationType "global" ;
    guide:gradePercentage "100%" ;
    guide:minimumScore "5 / 10" ;
    guide:trialMode "Presencial" ;
    guide:evaluationDuration "03:00" .

