# Competency Instances
:comp_ec02 rdf:type guide:Competency ;
    guide:competencyCode "CE EC02" ;
    guide:competencyDescription "Capacidad para seleccionar circuitos y dispositivos electrónicos especializados para la transmisión, el encaminamiento o enrutamiento y los terminales, tanto en entornos fijos como móviles." .

:comp_ec05 rdf:type guide:Competency ;
    guide:competencyCode "CE EC05" ;
    guide:competencyDescription "Capacidad de diseñar circuitos de electrónica analógica y digital, de conversión analógico-digital y digital-analógica, de radiofrecuencia, de alimentación y conversión de energía eléctrica para aplicaciones de telecomunicación y computación." .

:comp_cg04 rdf:type guide:Competency ;
    guide:competencyCode "CG 04" ;
    guide:competencyDescription "Capacidad de abstracción, de análisis y de síntesis y de resolución de problemas." .

:comp_cg11 rdf:type guide:Competency ;
    guide:competencyCode "CG 11" ;
    guide:competencyDescription "Habilidades para la utilización de las Tecnologías de la Información y las Comunicaciones." .

# Learning Result Instances
:lr_ra546 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA546" ;
    guide:learning_result_description "Comprender e interpretar las especificaciones y parámetros de un amplificador operacional a partir de las hojas de características del fabricante" .

:lr_ra550 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA550" ;
    guide:learning_result_description "Calcular, de forma aproximada y rápida, el ancho de banda de un amplificador construido con amplificador operacional compensado en frecuencia." .

:lr_ra553 rdf:type guide:LearningResult ;
    guide:learningResultCode "RA553" ;
    guide:learning_result_description "Aplicar la teoría de circuitos realimentados al cálculo de la ganancia y resistencias terminales de un amplificador realimentado negativamente y construido con amplificador operacional" .

# Evaluation System Instance
:eval_system_eaii rdf:type guide:EvaluationSystem ;
    guide:evaluationDescription "Sistema de evaluación distribuida o progresiva. La calificación final se obtiene de la suma del 70% de la parte de Teoría y el 30% de la parte de Laboratorio." ;
    guide:hasEvaluationTrial :trial_bt1a_moodle , 
                             :trial_bt2_moodle .

