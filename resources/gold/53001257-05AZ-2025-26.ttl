    ns1:inpersonHours "24 horas (30.8%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation ""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "24 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/53001257/2025-26/eventSchedule> ;
    schema:description """La asignatura persigue el aprendizaje de los sistemas de transporte interior en plantas de procesos industriales (fabricación, extraccción, transformación, etc).
Tema 1: Unidad de carga.
Tema 2: Instalaciones de cargas a granel.
Tema 3: Instalaciones de carga unitaria.
Tema 4: Equipos autónomos
Tema 5: Modelos de manutención
Ejemplo de taller de mecanizado
Ejemplo de planta de baterías de plomo ácido
Ejemplo de planta de fabricación de paneles solares
La asignatura está orientada a un aprendizaje 50% basado en exposiciones realizadas por el profesor y 50% en trabajo personal del alumno que seleccionará un proceso de fabricación y analizará el sistema de manutención del proceso completo, seleccionará unos equipos de manutención o transporte y realizará su dimensionamiento."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/enrique.alcala%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/enrique.alcala%40upm.es> ;
    schema:name "Manutencion y Transporte"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001257/2025-26/%28c%29> a ns1:Competency ;
    ns1:competencyCode "(c)" ;
    ns1:competencyDescription "DISEÑA. Habilidad para diseñar un sistema, componente o proceso que alcance los requisitos deseados teniendo en cuenta restricciones realistas tales como las económicas, medioambientales, sociales, políticas, éticas, de salud y seguridad, de fabricación y de sostenibilidad."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001257/2025-26/%28e%29> a ns1:Competency ;
    ns1:competencyCode "(e)" ;
    ns1:competencyDescription "RESUELVE. Habilidad para identificar, formular y resolver problemas de ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001257/2025-26/%28g%29> a ns1:Competency ;
    ns1:competencyCode "(g)" ;
    ns1:competencyDescription "COMUNICA. Habilidad para comunicar eficazmente."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001257/2025-26/RA222> a ns1:LearningResult ;
    ns1:learningResultCode "RA222" ;
    ns1:learningResultDescription "Comprender los sistemas y principios que definen el transporte interior en plantas de fabricación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001257/2025-26/RA223> a ns1:LearningResult ;
    ns1:learningResultCode "RA223" ;
    ns1:learningResultDescription "Diseñar y defender un sistema de transporte interior en un proceso concreto de producción seleccionado por el alumno."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001257/2025-26/RA299> a ns1:LearningResult ;
    ns1:learningResultCode "RA299" ;
    ns1:learningResultDescription "Conocer los equipos destinados a los procesos de manutención y transporte"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001257/2025-26/RA300> a ns1:LearningResult ;
    ns1:learningResultCode "RA300" ;
    ns1:learningResultDescription "Fundamentos técnicos para el diseño de sistemas en base a capacidad de carga y condiciones de contorno del transporte, distancia, altura a salvar, flexibilidad del material de carga, etc."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001257/2025-26/RA301> a ns1:LearningResult ;
    ns1:learningResultCode "RA301" ;
    ns1:learningResultDescription "Conocer y aplicar los requisitos normativos y especificaciones técnicas vigentes y que condicionantes implican en los diseños."@es .

