<https://guia-kg.skai.etsisi.upm.es/resource/135005305/2025-26/CE%201.16> a ns1:Competency ;
    ns1:competencyCode "CE 1.16" ;
    ns1:competencyDescription "Conocer la anatomía y función de las células, tejidos y órganos vegetales. Comprender los principales procesos funcionales de las plantas (Fotosíntesis, transpiración, respiración, absorción, nutrición, crecimiento y reproducción) y los factores ecológicos que los condicionan."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005305/2025-26/CE%201.32> a ns1:Competency ;
