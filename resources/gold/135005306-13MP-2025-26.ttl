<https://guia-kg.skai.etsisi.upm.es/resource/135005306/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Aspectos generales en Microbiología. Microorganismos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005306/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Unidad 1. Concepto de Microbiología. Desarrollo de la Microbiología. Historia de la Microbiología. Importancia de la Microbiología aplicada al Medio Natural. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005306/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "2.2. Unidad 9. Microorganismos del suelo. Formación del suelo. Rizosfera. Micorrización y grupos más significativos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005306/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "2.3. Unidad 10. Biodegradación de compuestos aromáticos por hongos. Tipos de pudrición. Microorganismos degradadores. Potencial biotecnológico. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005306/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "2.4. Unidad 11. Control Biológico de plagas y enfermedades forestales. Mecanismos de control. Uso de bacterias y hongos fundamentalmente. Ventajas e inconvenientes. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005306/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "2.5. Unidad 12. Tratamiento de aguas residuales. Digestión aerobia y anaerobia. Ventajas e Inconvenientes. Nuevas tendencias y Perspectivas de futuro. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005306/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "2.6. Unidad 13. Biorremediación. Conceptos esenciales. Técnicas \"in situ\" y \"ex situ\". Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005306/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "2.7. Unidad 14. Compostaje. Procesos fundamentales. Sistemas de Compostaje. Características del compost. Microorganismos participantes. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005306/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "2.8. Unidad 15. Biocombustibles. Producción de Bioetanol y Biodiésel. Biocombustibles de 1ª, 2ª y 3ª generación. Uso de microalgas para producir bioetanol. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005306/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "2.9. Unidad 16. Mareas rojas. Tipos y agentes más importantes. Toxinas generadas. Causas y Efectos. Posibles tratamientos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005306/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "3. Programa práctico."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005306/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "3.1. Unidad 17. Manejo de equipos ópticos y Técnicas de tinción. Técnicas de siembra y cultivo para hongos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005306/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Unidad 2. Microorganismos simples, los Virus. Características generales. Ciclos vitales. Clasificación taxonómica. Grupos más significativos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005306/2025-26/syllabus/20> a ns1:SyllabusItem ;
    ns1:itemIndex 20 ;
    ns1:syllabusDescription "3.2. Unidad 18. Desarrollo miceliar en especies fúngicas. Reconocimiento específico. Curva de Crecimiento. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005306/2025-26/syllabus/21> a ns1:SyllabusItem ;
    ns1:itemIndex 21 ;
    ns1:syllabusDescription "3.3. Unidad 19. Análisis biológico de suelos. Técnicas de siembra y análisis de datos. Micorrización. Técnicas de extracción y conteo. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005306/2025-26/syllabus/22> a ns1:SyllabusItem ;
    ns1:itemIndex 22 ;
    ns1:syllabusDescription "3.4. Unidad 20. Análisis de bacterias. Técnicas de reconocimiento por tinción de Gram. Uso de indicadores biológicos. Análisis biológico de aguas mediante protozoarios. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005306/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "1.3. Unidad 3. Microorganismos Procariontes, las Bacterias. Características generales. Ciclos vitales. Clasificación taxonómica. Grupos más significativos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005306/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "1.4. Unidad 4. Microorganismos Eucariontes, los Protozoarios. Características generales. Ciclos vitales. Clasificación taxonómica. Grupos más significativos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005306/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "1.5. Unidad 5. Microorganismos Eucariontes, las Algas microscópicas. Características generales. Ciclos vitales. Clasificación taxonómica. Grupos más significativos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005306/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "1.6. Unidad 6. Microorganismos Eucariontes, los Hongos. Características generales. Ciclos vitales. Clasificación taxonómica. Grupos más significativos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005306/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "1.7. Unidad 7. Dinámica de comunidades microbianas, Crecimiento microbiano. Cultivos. Ecología microbiana. Influencia de los factores ambientales. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005306/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "2. Aplicaciones Microbianas en el Medio Natural."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005306/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "2.1. Unidad 8. Uso de los Protozoarios y otros microorganismos como bioindicadores de calidad de agua. Niveles sapróbicos y niveles tróficos. Protozoarios bioindicadores. Análisis biológico de aguas. Sin subniveles"@es .

