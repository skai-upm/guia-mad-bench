    ns1:inpersonHours "30 horas (38.5%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation """This subject is related to SDG 7: Affordable and clean energy, SDG 11: Sustainable cities and communities.
Part of the subjects can be given in Spanish, for instance, external speakers conferences."""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "30 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/53002065/2025-26/eventSchedule> ;
    schema:description "This subject will show the technological foundations for the generation and use of hydrogen, reviewing its thermophysical properties and the most common applications from fuel cells to automotive engines. Forms of storage and its application as an energy vector in Power-to-gas schemes are included."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/alberto.abanades%40upm.es> ;
    schema:inLanguage "Inglés"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/a.jimenez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/alberto.abanades%40upm.es> ;
    schema:name "Hydrogen And Fuel Cell Technologies"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002065/2025-26/CB7> a ns1:Competency ;
    ns1:competencyCode "CB7" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en entornos nuevos o poco conocidos dentro de contextos más amplios (o multidisciplinares) relacionados con su área de estudio/ Students are capable of applying their knowledge, understanding, and problem"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002065/2025-26/CE17> a ns1:Competency ;
    ns1:competencyCode "CE17" ;
    ns1:competencyDescription "Comprender los procesos que integran el ciclo de vida de los procesos energéticos, desde la obtención del recurso primario, hasta su desmantelamiento, y su integración en la economía circular./ Understand the processes that make up the life cycle of energy processes, from obtaining the primary resource, to its dismantling, and its integration into the circular economy."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002065/2025-26/CE3> a ns1:Competency ;
    ns1:competencyCode "CE3" ;
    ns1:competencyDescription "Utilizar las herramientas necesarias para el diseño y análisis de sistemas de generación, trasformación, almacenamiento y utilización de energías nucleares, mecánicas, eléctricas, térmicas e hidráulicas./ Use the necessary tools for the design and analysis of systems for the generation, transformation, storage and use of nuclear, mechanical, electrical, thermal and hydraulic energies."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002065/2025-26/CE7> a ns1:Competency ;
    ns1:competencyCode "CE7" ;
    ns1:competencyDescription "Conocer y aplicar las alternativas para la operación segura de instalaciones energéticas, tanto renovables, como no renovables, y de transformación de vectores energéticos, como refinerías o biorrefinerías/ Know and apply the alternatives for the safe operation of energy facilities, both renewable and non"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002065/2025-26/CE9> a ns1:Competency ;
    ns1:competencyCode "CE9" ;
    ns1:competencyDescription "Disponer de criterios y herramientas para entender la composición y características de los diferentes tipos de combustibles convencionales y no convencionales./ Skills, criteria and knowledge to research, develop and innovate in the field of energy: renewable and non"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002065/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Aplicar conocimientos de ciencias y tecnologías avanzadas a la práctica profesional o investigadora de la Ingeniería Energética./ Apply knowledge of advanced science and technology to the professional or research practice of Energy Engineering."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002065/2025-26/CG8> a ns1:Competency ;
    ns1:competencyCode "CG8" ;
    ns1:competencyDescription "Incorporar nuevas tecnologías y herramientas avanzadas de la Ingeniería Energética en sus actividades profesionales o investigadoras./ Incorporate new technologies and advanced tools of Energy Engineering in their professional or research activities."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002065/2025-26/CT10> a ns1:Competency ;
    ns1:competencyCode "CT10" ;
    ns1:competencyDescription "Conoce. Conocimiento de los temas contemporáneos./ Knowledge of contemporary issues."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002065/2025-26/CT12> a ns1:Competency ;
    ns1:competencyCode "CT12" ;
    ns1:competencyDescription "Es bilingüe. Capacidad de trabajar en un entorno bilingüe (inglés/español). / Bilingual. Ability to work in a bilingual environment (English / Spanish)."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002065/2025-26/CT8> a ns1:Competency ;
    ns1:competencyCode "CT8" ;
    ns1:competencyDescription "Entiende los impactos. Educación amplia necesaria para entender el impacto de las soluciones ingenieriles en un contexto social global./ Understand the impacts. Broad education to understand the impact of engineering solutions in a global social context."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002065/2025-26/RA20> a ns1:LearningResult ;
    ns1:learningResultCode "RA20" ;
    ns1:learningResultDescription "Conocimiento y habilidades de cálculo y diseño de pilas de combustible"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002065/2025-26/RA21> a ns1:LearningResult ;
    ns1:learningResultCode "RA21" ;
    ns1:learningResultDescription "Conocimientos y habilidades de cálculo y diseño de tecnologías de producción, almacenamiento y distribución de hidrógeno."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002065/2025-26/RA22> a ns1:LearningResult ;
    ns1:learningResultCode "RA22" ;
    ns1:learningResultDescription "Conocimiento de tecnologías aplicadas en la economía del Hidrógeno."@es .

