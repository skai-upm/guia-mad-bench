    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/103000607/2025-26/syllabus> ;
    ns1:inpersonHours "37 horas (31.6%)"@es ;
    ns1:numberOfCredits 4.5 ;
    ns1:otherInformation "Regarding the Sustainable Developing Goals, broadly speaking, proper data analysis leads to an understanding of processes and the generation of information available to everyone. This information can help clarify and make more transparent the way in wich institutions, for instance, try to meet people's needs. This information icreases transparency, accountability and citizen participation in institutions and facilitates information-sharing between different actors. In this particular case, proper analysis of data might help in achieving SDG 16: Promote peaceful and inclusive societies for sustainable development, provide access to justice for all and build effective, accountable and inclusive institutions at all levels."@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "37 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/103000607/2025-26/eventSchedule> ;
    schema:description "The course is intended to be a non-exhaustive survey of techinques to convert multivariate data into useful information so that good decisions can be made. The perspective is twofold, theorical and applied, covering topics such as: exploratory data analysis, statistical summaries and graphical representations, dimensionality reduction, regression techniques, time series analysis, decision theory and probabilistic graphical models. There will be an emphasis on hands-on application of the theory and methods throughout, with extensive use of R."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/arminda.moreno%40upm.es> ;
    schema:inLanguage "Inglés/Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/arminda.moreno%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/jacinto.gonzalez.pachon%40upm.es> ;
    schema:name "Intelligent Data Analysis"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000607/2025-26/CB10> a ns1:Competency ;
    ns1:competencyCode "CB10" ;
    ns1:competencyDescription "Que los estudiantes posean las habilidades de aprendizaje que les permitan continuar estudiando de un modo que habrá de ser en gran medida autodirigido o autónomo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000607/2025-26/CB7> a ns1:Competency ;
    ns1:competencyCode "CB7" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en entornos nuevos o poco conocidos dentro de contextos más amplios (o multidisciplinares) relacionados con su área de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000607/2025-26/CG19> a ns1:Competency ;
    ns1:competencyCode "CG19" ;
    ns1:competencyDescription "Capacidad para el modelado matemático, cálculo y simulación en centros tecnológicos y de ingeniería de empresa, particularmente en tareas de investigación, desarrollo e innovación en todos los ámbitos relacionados con la Ingeniería en Informática"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000607/2025-26/RA42> a ns1:LearningResult ;
    ns1:learningResultCode "RA42" ;
    ns1:learningResultDescription "Conocer y aplicar las principales técnicas de análisis de datos multivariantes."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000607/2025-26/RA43> a ns1:LearningResult ;
    ns1:learningResultCode "RA43" ;
    ns1:learningResultDescription "Conocer y aplicar técnicas de reducción de la dimensionalidad en un conjunto de datos multivariantes."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000607/2025-26/RA44> a ns1:LearningResult ;
    ns1:learningResultCode "RA44" ;
    ns1:learningResultDescription "Formular, analizar y validar modelos de regresión, análisis discriminante, clasificación y \"clustering\"."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000607/2025-26/RA45> a ns1:LearningResult ;
    ns1:learningResultCode "RA45" ;
    ns1:learningResultDescription "Aplicar la metodología apropiada para el ajuste de series temporales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000607/2025-26/RA46> a ns1:LearningResult ;
    ns1:learningResultCode "RA46" ;
    ns1:learningResultDescription "Ser capaz de estructurar problemas de toma de decisiones bajo el paradigma bayesiano."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000607/2025-26/didactic_resource/1> a ns1:DidacticResource ;
    ns1:bibliographyDescription """Main communication channel with students.
Repository: slides, scripts, data sets, other resources."""@es ;
    ns1:bibliographyTitle "Moodle"@es ;
    ns1:bibliographyType "Recursos web"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000607/2025-26/didactic_resource/10> a ns1:DidacticResource ;
    ns1:bibliographyTitle "Chatfield, C. (2003) The Analysis of Time Series: An Introduction. Chapman and Hall."@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000607/2025-26/didactic_resource/11> a ns1:DidacticResource ;
    ns1:bibliographyDescription """A comprehensive introduction to time series analysis and other forecasting methods.
Available online at: https://otexts.com/fpp2/"""@es ;
    ns1:bibliographyTitle "Forecasting: Principles and Practice. R. J. Hyndman and G. Athanasopoulos. Monash University, Australia."@es ;
    ns1:bibliographyType "Recursos web"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000607/2025-26/didactic_resource/12> a ns1:DidacticResource ;
    ns1:bibliographyDescription "Available on line at: https://people.duke.edu/~rnau/411home.htm"@es ;
    ns1:bibliographyTitle "Statistical forecasting: notes on regression and time series analysis. Robert Nau. Fuqua School of Business. Duke University."@es ;
    ns1:bibliographyType "Recursos web"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000607/2025-26/didactic_resource/13> a ns1:DidacticResource ;
    ns1:bibliographyTitle "French, S. Decision Theory. Ellis Horwood Ltd."@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000607/2025-26/didactic_resource/2> a ns1:DidacticResource ;
    ns1:bibliographyDescription "Computer Room for hands-on sessions."@es ;
    ns1:bibliographyTitle "Computer Lab"@es ;
    ns1:bibliographyType "Equipamiento"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000607/2025-26/didactic_resource/3> a ns1:DidacticResource ;
    ns1:bibliographyDescription "Friendly exposition of the most important multivariate techiques, including clustering. They also introduce other Artificial Intelligence techniques like neural networks."@es ;
    ns1:bibliographyTitle "Johnson, R.A., Whichern, D.W. (2007) Applied Multivariate Statistical Analysis. Pearson Education."@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000607/2025-26/didactic_resource/4> a ns1:DidacticResource ;
    ns1:bibliographyDescription "Clear exposition of Multivariate Analysis Techniques, from a statistical point of view. Many examples."@es ;
    ns1:bibliographyTitle "Rencher, A.C. Methods of Multivariate Analysis."@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000607/2025-26/didactic_resource/5> a ns1:DidacticResource ;
    ns1:bibliographyDescription "Excellent exposition of multivariate techniques. They make the Generalised Linear Model easily understandable."@es ;
    ns1:bibliographyTitle "Everitt, B.S. and Dunn G. (1997) Applied Multivariate Data Analysis. Arnold."@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000607/2025-26/didactic_resource/6> a ns1:DidacticResource ;
    ns1:bibliographyDescription "A Global Perspective on multivariate Techniques. Very detailed examples. In almost every topic, a \"Rules of Thumb\" section summarizes the relevant facts."@es ;
    ns1:bibliographyTitle "Hair, J.F., Black, W.C., Babin, B.J., Anderson R.E. Multivariate Data Analysis."@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000607/2025-26/didactic_resource/7> a ns1:DidacticResource ;
    ns1:bibliographyDescription """http://www.fbbva.es/TLFU/tlfu/esp/publicaciones/libros/fichalibro/index.jsp?codigo=769

Excellent compilation and description of multivariate techniques applied to Ecological Data. Clear, educational, didactic explanations. Lots of examples"""@es ;
    ns1:bibliographyTitle "Multivariate Analysis of Ecological Data. Greenacre, Primicerio. Fundación BBVA."@es ;
    ns1:bibliographyType "Recursos web"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000607/2025-26/didactic_resource/8> a ns1:DidacticResource ;
    ns1:bibliographyDescription """http://www.multivariatestatistics.org/biplots.html

Excellent Monograph on Biplots."""@es ;
    ns1:bibliographyTitle "Biplots in Practice. Michael Greenacre. Fundación BBVA."@es ;
    ns1:bibliographyType "Recursos web"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000607/2025-26/didactic_resource/9> a ns1:DidacticResource ;
    ns1:bibliographyDescription "Almost everything about Regression Models."@es ;
    ns1:bibliographyTitle "Rawlings, J.O., Pantula, S.G., Dickey, D.A. Applied Regression Analysis."@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000607/2025-26/evaluation> a ns1:EvaluationSystem ;
    ns1:evaluationDescription """Progressive evaluation:
The course grade will be based on the performance on two assignments on Modules 1 and 4 respectively (25% each one) and one exam (50%). The exam will consist of multiple choice questions, short-answer questions or interpretations on data analysis software outputs. Each assignment and the exam should obtain a grade equal or greater than 3 (0-10 scale) for the final grade to be computed. This final grade must be equal or greater than 5 to pass the course. Eventually, students may be asked to present orally the conclusions of their work.
If any of the evaluation items doesn't meet the requirments exposed above, they can be presented or taken again in the January exams session. Again, grade requirements apply to compute the course overall grade.
January Exam:
If an assignment or the exam was not delivered when requested, it can be presented or taken in the January exams session. If this is the case, the work submitted will only be corrected once and there will be no further opportunity to improve it. Again, grade requirements apply.

Extraordinary exam:
In case you are opting for the extraordinary exam in July's session, you have to warn the instructor(s) in advance (at least two weeks before the exam, by email, but the sooner the better). In this case, all 2 assignments are to be delivered and the exam has to be taken in the corresponding date. Grade requirements apply to compute the overall grade."""@es .

