    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000026/2025-26/didactic_resource/5> a ns1:DidacticResource ;
    ns1:bibliographyTitle "Heslot N, Yang HP, Sorrells ME, Jannink JL (2012) Genomic selec- tion in plant breeding: a comparison of models. Crop Sci 52:146-160"@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000026/2025-26/didactic_resource/6> a ns1:DidacticResource ;
    ns1:bibliographyTitle "Isidro, J., Jannink, J. L., Akdemir, D., Poland, J., Heslot, N., & Sorrells, M. E. (2015). Training set optimization under population structure in genomic selection. Theoretical and applied genetics, 128, 145-158."@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000026/2025-26/didactic_resource/7> a ns1:DidacticResource ;
