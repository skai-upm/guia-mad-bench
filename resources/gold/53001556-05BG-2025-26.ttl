<https://guia-kg.skai.etsisi.upm.es/resource/53001556/2025-26/CB07> a ns1:Competency ;
    ns1:competencyCode "CB07" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en entornos nuevos o poco conocidos dentro de contextos más amplios (o multidisciplinares) relacionados con su área de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001556/2025-26/CE01> a ns1:Competency ;
    ns1:competencyCode "CE01" ;
    ns1:competencyDescription "Comprender, diseñar y analizar sistemas y componentes electrónicos en el ámbito de la electrónica industrial. Modelización y caracterización de sistemas electrónicos complejos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001556/2025-26/CE02> a ns1:Competency ;
    ns1:competencyCode "CE02" ;
    ns1:competencyDescription "Ser capaz de desarrollar un proyecto de diseño de un sistema electrónico, identificando sus principales retos, en ámbitos de aplicación tales como el aeroespacial, la automoción, la ingeniería médica, las energías renovables o las comunicaciones"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001556/2025-26/CT01> a ns1:Competency ;
    ns1:competencyCode "CT01" ;
    ns1:competencyDescription "Uso de la lengua inglesa"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001556/2025-26/RA1> a ns1:LearningResult ;
    ns1:learningResultCode "RA1" ;
    ns1:learningResultDescription "Comprensión de los principios de operación de la conversión de la energía y de las principales tecnologías de semiconductores"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001556/2025-26/RA101> a ns1:LearningResult ;
    ns1:learningResultCode "RA101" ;
    ns1:learningResultDescription "Examinar el rol de la electrónica de potencia en las diferentes arquitecturas de red."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001556/2025-26/RA126> a ns1:LearningResult ;
    ns1:learningResultCode "RA126" ;
    ns1:learningResultDescription "Conocer los circuitos inversores de potencia ac"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001556/2025-26/RA2> a ns1:LearningResult ;
    ns1:learningResultCode "RA2" ;
    ns1:learningResultDescription "Analizar y diseñar topologías avanzadas de electrónica de potencia, especialmente aquellas más relevantes que se utilizan en diferentes sectores de la industria."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001556/2025-26/RA30> a ns1:LearningResult ;
    ns1:learningResultCode "RA30" ;
    ns1:learningResultDescription "Conocer la problemática básica de los circuitos electrónicos conectados a la red eléctrica."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001556/2025-26/RA41> a ns1:LearningResult ;
    ns1:learningResultCode "RA41" ;
    ns1:learningResultDescription "Examinar el rol de la electrónica de potencia en las diferentes arquitecturas de red."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001556/2025-26/RA93> a ns1:LearningResult ;
    ns1:learningResultCode "RA93" ;
    ns1:learningResultDescription "Conocer la problemática básica de los circuitos electrónicos conectados a la red eléctrica"@es .

