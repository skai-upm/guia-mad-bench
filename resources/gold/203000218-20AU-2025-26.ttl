<https://guia-kg.skai.etsisi.upm.es/resource/203000218> a ns1:Course ;
    ns1:courseType "Optativa"@es ;
    ns1:courseYear 2 ;
    ns1:semester "Tercer semestre"@es ;
    schema:courseCode 203000218 ;
    schema:hasCourseInstance <https://guia-kg.skai.etsisi.upm.es/resource/203000218/2025-26> ;
    schema:name "Seminars On Innovation And Carrer Guidance"@en,
        "Seminarios de Innovación y Orientación Profesional"@es ;
    schema:numberOfCredits 2.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/203000218/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/203000218/2025-26/CG4>,
        <https://guia-kg.skai.etsisi.upm.es/resource/203000218/2025-26/CG6>,
        <https://guia-kg.skai.etsisi.upm.es/resource/203000218/2025-26/CG7/CT4> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/203000218/2025-26/didactic_resource/1> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/203000218/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/203000218/2025-26/RA57> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/203000218/2025-26/syllabus> ;
    ns1:inpersonHours "25 horas (48.1%)"@es ;
    ns1:numberOfCredits 2.0 ;
    ns1:otherInformation """La asignatura se relaciona con el ODS9: Construir infraestructuras resilientes, promover la industrialización sostenible y fomentar la innovación
Meta 9.5 Aumentar la investigación científica y mejorar la capacidad tecnológica
Meta 9.b Apoyar el desarrollo de tecnologías, la investigación y la innovación nacionales"""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "25 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/203000218/2025-26/eventSchedule> ;
    schema:description "La asignatura consiste en conferencias de profesores de la Universidad, profesores extranjeros y profesionales de prestigio, que presentan temas avanzados de interés para la titulación y permiten al alumnoado expandir su conocimiento y deseos de aprendizaje más allá de lo recibido en la titulación."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/francisco.ayuga%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/eutiquio.gallego%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/francisco.ayuga%40upm.es> ;
    schema:name "Seminarios de Innovación y Orientación Profesional"@es .

