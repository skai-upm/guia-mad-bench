    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/143005008/2025-26/eventSchedule> ;
    schema:description """Esta asignatura tiene como objetivo presentar la metodología y las actividades que deben llevarse a cabo en el desarrollo del concepto de un espacio aéreo en general.
Se expondrán los aspectos principales a considerar en cada uno de los posibles casos proponiendo ejercicios prácticos que faciliten la asimilación de los conceptos por los alumnos.
La asignatura se orientará a identificar los requisitos operacionales que deberían conseguirse como objetivo en la definición del concepto de espacio aéreo. Se hará particular énfasis en la implementación de especificaciones PBN como uno de los habilitadores principales en la definición del concepto de espacio aéreo mencionado.
Se realizará un caso práctico de diseño de un TMA."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/l.perez%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/l.perez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/lidia.serrano%40upm.es> ;
    schema:name "Desarrollo del Concepto de Espacio Aereo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005008/2025-26/CE3> a ns1:Competency ;
    ns1:competencyCode "CE3" ;
    ns1:competencyDescription "Establecer las funciones esenciales necesarias para la definición de los escenarios de Gestión del Tránsito Aéreo (ATM)"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005008/2025-26/CE4> a ns1:Competency ;
    ns1:competencyCode "CE4" ;
    ns1:competencyDescription "Identificar las necesidades técnicas y operativas asociadas a la definición de un concepto operacional ATM"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005008/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Poseer y comprender conocimientos que aporten una base u oportunidad de ser originales en el desarrollo de nuevos conceptos y técnicas aplicados al Sistema del Transporte Aéreo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005008/2025-26/CG2> a ns1:Competency ;
    ns1:competencyCode "CG2" ;
    ns1:competencyDescription "Aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en los entornos de evolución previstos en los Sistemas de Transporte Aéreo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005008/2025-26/CG4> a ns1:Competency ;
    ns1:competencyCode "CG4" ;
    ns1:competencyDescription "Comunicar sus conclusiones y los conocimientos y razones últimas que las sustentan a públicos especializados, y no especializados de un modo claro y sin ambigüedades"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005008/2025-26/CG6> a ns1:Competency ;
    ns1:competencyCode "CG6" ;
    ns1:competencyDescription "Que los estudiantes posean las habilidades de aprendizaje que les permitan continuar estudiando de un modo que habrá de ser en gran medida autodirigido o autónomo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005008/2025-26/CT4> a ns1:Competency ;
    ns1:competencyCode "CT4" ;
    ns1:competencyDescription "Analizar implicaciones económicas, administrativas, sociales o medioambientales ligadas a la aplicación de nuevos conceptos y técnicas en el Sistema del Transporte Aéreo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005008/2025-26/RA74> a ns1:LearningResult ;
    ns1:learningResultCode "RA74" ;
    ns1:learningResultDescription "El alumno identifica las limitaciones operacionales de un volumen de espacio aéreo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005008/2025-26/RA75> a ns1:LearningResult ;
    ns1:learningResultCode "RA75" ;
    ns1:learningResultDescription "El alumno comprende los criterios para realizar el diseño conceptual de un volumen de espacio aéreo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005008/2025-26/RA76> a ns1:LearningResult ;
    ns1:learningResultCode "RA76" ;
    ns1:learningResultDescription "El alumno comprende los conceptos básicos para el diseño de los procedimientos de vuelo instrumental basados en navegación convencional y en PBN"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005008/2025-26/RA77> a ns1:LearningResult ;
