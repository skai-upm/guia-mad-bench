<https://guia-kg.skai.etsisi.upm.es/resource/53001932/2025-26/MUCTN.CE01> a ns1:Competency ;
    ns1:competencyCode "MUCTN.CE01" ;
    ns1:competencyDescription "Entiende a fondo las leyes básicas y avanzadas de la física atómica y nuclear y las ciencias de la ingeniería pertinentes aplicables a la tecnología de las plantas de energía nuclear de fisión y/o fusión"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001932/2025-26/MUCTN.CE02> a ns1:Competency ;
    ns1:competencyCode "MUCTN.CE02" ;
    ns1:competencyDescription "Es capaz de realizar análisis matemático avanzado y simulación numérica de los diferentes procesos y sistemas de la física y de la ingeniería de los reactores de energía nuclear de fisión y/o fusión"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001932/2025-26/MUCTN.CE06> a ns1:Competency ;
    ns1:competencyCode "MUCTN.CE06" ;
    ns1:competencyDescription "Concibe la utilización de los aceleradores de partículas como herramientas avanzadas en la investigación física, y sus aplicaciones en la medicina e industria"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001932/2025-26/MUCTN.CE08> a ns1:Competency ;
    ns1:competencyCode "MUCTN.CE08" ;
    ns1:competencyDescription "Es capaz de elaborar, redactar y defender un proyecto original en el ámbito de la ingeniería nuclear de contenido científico en el que se sinteticen e integren las competencias adquiridas durante el Máster."@es .

