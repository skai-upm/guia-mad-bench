    ns1:inpersonHours "44 horas (42.3%)"@es ;
    ns1:numberOfCredits 4.0 ;
    ns1:otherInformation """La planificación temporal podría sufrir alguna modificación de orden en función de la planificación del profesor y serán comunicados con la mayor anterioridad posible.
La asignatura se relaciona con el ODS7 y el ODS11"""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "44 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/63000215/2025-26/eventSchedule> ;
    schema:description "A través de esta asignatura y los temas incluidos se pretende que los alumnos adquieran conocimientos relacionados con la movilidad, el transporte como un sector estratégico para el desarrollo de las relaciones e intercambios de flujos de personas y mercancías, así como los relacionados con los impactos sobre el consumo, emisiones y otras externalidades."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/blanca.arenas%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/blanca.arenas%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/felipe.jimenez%40upm.es> ;
    schema:name "Movilidad y Transporte"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000215/2025-26/CB07> a ns1:Competency ;
    ns1:competencyCode "CB07" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en entornos nuevos o poco conocidos dentro de contextos más amplios (o multidisciplinares) relacionados con su área de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000215/2025-26/CB10> a ns1:Competency ;
    ns1:competencyCode "CB10" ;
    ns1:competencyDescription "Que los estudiantes posean las habilidades de aprendizaje que les permitan continuar estudiando de un modo que habrá de ser en gran medida autodirigido o autónomo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000215/2025-26/CG04> a ns1:Competency ;
    ns1:competencyCode "CG04" ;
    ns1:competencyDescription "Aplicar, con una perspectiva global e interdisciplinar, los conocimientos adquiridos en el resto de materias del Máster"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000215/2025-26/CG14> a ns1:Competency ;
    ns1:competencyCode "CG14" ;
    ns1:competencyDescription "Capacidad de expresarse correctamente, comunicación efectiva, tanto por escrito como oralmente, de conocimientos, procedimientos, resultados e ideas, mejorando la capacidad de síntesis y análisis, y de defensa en debate de las ideas propias."@es .

