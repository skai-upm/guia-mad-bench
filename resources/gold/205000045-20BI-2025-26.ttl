    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/205000045/2025-26/eventSchedule> ;
    schema:description "Esta asignatura permitirá al alumno profundizar en el estudio del suelo haciendo hincapié en los aspectos relacionados con la degradación, conservación y la rehabilitación de suelos en el ámbito agrario. El alumno será capaz de identificar y describir los principales procesos de la degradación química, física y biológica del suelo, con énfasis en la erosión y contaminación de suelos. Una vez conocidas las técnicas disponibles, el alumno tendrá la capacidad para proponer medidas de conservación y recuperación de los suelos degradados. A nivel metodológico, se combinará la teoría con la resolución de problemas de aplicación, las prácticas de campo y la realización de un trabajo de curso que incidirá en aspectos como la búsqueda de información, análisis y síntesis, elaboración de un informe escrito, diseño de una presentación y defensa oral."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/c.hontoria%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/ana.moliner%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/c.hontoria%40upm.es> ;
    schema:name "Conservación y Recuperación de Suelos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000045/2025-26/CE07> a ns1:Competency ;
    ns1:competencyCode "CE07" ;
    ns1:competencyDescription "Conocer las propiedades físicas, químicas y biológicas de los suelos como sustrato del crecimiento vegetal, su susceptibilidad a la degradación, y su manejo en condiciones agrícolas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000045/2025-26/CE16> a ns1:Competency ;
    ns1:competencyCode "CE16" ;
    ns1:competencyDescription "Conocer los efectos ambientales de la actividad agraria sobre el suelo, los recursos hídricos y la atmósfera, así como las principales técnicas para su mitigación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000045/2025-26/CE24> a ns1:Competency ;
    ns1:competencyCode "CE24" ;
    ns1:competencyDescription "Capacidad de proponer estrategias de optimización del proceso productivo en términos de un uso sostenible agronómico y ambiental."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000045/2025-26/CG01> a ns1:Competency ;
    ns1:competencyCode "CG01" ;
    ns1:competencyDescription "Conocimiento en materias básicas, científicas y tecnológicas que permitan un aprendizaje continuo, así como una capacidad de adaptación a nuevas situaciones o entornos cambiantes."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000045/2025-26/CG07> a ns1:Competency ;
    ns1:competencyCode "CG07" ;
    ns1:competencyDescription "Adquirir la formación profesional necesaria para desarrollar estrategias sostenibles de producción vegetal y animal de forma eficiente y acorde a los recursos disponibles."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000045/2025-26/CT04> a ns1:Competency ;
    ns1:competencyCode "CT04" ;
    ns1:competencyDescription "Capacidad para comunicar a todo tipo de audiencias en lengua castellana e inglesa y tanto de forma oral como escrita."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000045/2025-26/CT05> a ns1:Competency ;
    ns1:competencyCode "CT05" ;
    ns1:competencyDescription "Habilidad de aprendizaje para emprender actividades o estudios posteriores de forma autónoma."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000045/2025-26/RA259> a ns1:LearningResult ;
    ns1:learningResultCode "RA259" ;
    ns1:learningResultDescription "Reconocer la importancia del suelo, como interfase atmósfera # litosfera, su relevancia en los procesos ecológicos y las principales causas y consecuencias de su degradación;"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000045/2025-26/RA261> a ns1:LearningResult ;
    ns1:learningResultCode "RA261" ;
    ns1:learningResultDescription "Conocer y evaluar la incidencia de las diferentes técnicas de manejo agrícola en la calidad del suelo, así como el desarrollo de técnicas de manejo de este recurso más sostenibles (agricultura de conservación, agricultura ecológica)."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000045/2025-26/RA262> a ns1:LearningResult ;
    ns1:learningResultCode "RA262" ;
    ns1:learningResultDescription "Conocer las distintas técnicas tradicionales de conservación de suelos y saber seleccionar y aplicarlas en distintos ámbitos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000045/2025-26/RA263> a ns1:LearningResult ;
    ns1:learningResultCode "RA263" ;
    ns1:learningResultDescription "Comprender los distintos procesos de degradación de suelos y las limitaciones que imponen al uso del suelo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000045/2025-26/RA264> a ns1:LearningResult ;
    ns1:learningResultCode "RA264" ;
    ns1:learningResultDescription "Conocer los criterios utilizados en la normativa española para determinar si un suelo está contaminado"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000045/2025-26/RA265> a ns1:LearningResult ;
    ns1:learningResultCode "RA265" ;
    ns1:learningResultDescription "Seleccionar la tecnología más adecuada para la recuperación de suelo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000045/2025-26/RA266> a ns1:LearningResult ;
    ns1:learningResultCode "RA266" ;
    ns1:learningResultDescription "Conocer los problemas de degradación de suelos que afectan al ámbito mediterráneo y plantear soluciones adecuadas a cada una de los condiciones."@es .

