    ns1:learningResultDescription "Utilizar con soltura la comunicación oral y escrita en lengua española e inglesa"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000110/2025-26/RA28> a ns1:LearningResult ;
    ns1:learningResultCode "RA28" ;
    ns1:learningResultDescription "Saber trabajar en equipo. Ejecutar el trabajo con responsabilidad y respeto a los demás."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000110/2025-26/RA29> a ns1:LearningResult ;
    ns1:learningResultCode "RA29" ;
    ns1:learningResultDescription "Entender, asimilar y manejar los conceptos básicos que describen el comportamiento electrónico, magnético, térmico y óptico de los materiales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000110/2025-26/RA30> a ns1:LearningResult ;
    ns1:learningResultCode "RA30" ;
    ns1:learningResultDescription "Conocer y saber relacionar dicho comportamiento con la estructura del material a nivel atómico, molecular y macroscópico."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000110/2025-26/RA31> a ns1:LearningResult ;
    ns1:learningResultCode "RA31" ;
    ns1:learningResultDescription "Conocer y saber calcular mediante las teorías más relevantes la respuesta electrónica, magnética, térmica y óptica de los materiales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000110/2025-26/RA32> a ns1:LearningResult ;
    ns1:learningResultCode "RA32" ;
    ns1:learningResultDescription "Conocer los principios de funcionamiento y ser capaces de experimentar con dispositivos electrónicos elementales; transistores, láseres y otros sistemas"@es .

