    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/123000722/2025-26/eventSchedule> ;
    schema:description "La asignatura tiene dos unidades temáticas, cada una con 3 temas, los cuales analizan la resolución de distintos casos prácticos de aplicación de los conocimientos teóricos a problemas de ingeniería y territorio. La primera unidad temática está dedicada al recordatorio de la estadística descriptiva e inferencial. A continuación, se da los fundamentos del análisis multivariado y se estudian algunas técnicas de clasificación. En las prácticas de esta unidad se resuelven distintas aplicaciones de ámbitos variados. En la segunda unidad temática se comienza con el análisis de patrones y mapas de densidad, además se da los fundamentos de la geoestadística. Dando una especial importancia al estudio de los parámetros que intervienen en el cálculo del semivariograma experimental y su ajuste a modelos teóricos, así como al estudio y aplicación de técnicas de krigeado. Las prácticas de esta unidad están dedicadas a resolver aplicaciones a la estimación de fenómenos naturales. Se utilizan los programas SPSS y ArcGisPro."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/mariadelcarmen.morillo%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/mariadelcarmen.morillo%40upm.es> ;
    schema:name "Análisis Geoespacial"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/123000722/2025-26/CB10> a ns1:Competency ;
    ns1:competencyCode "CB10" ;
    ns1:competencyDescription "Que los estudiantes posean las habilidades de aprendizaje que les permitan continuar estudiando de un modo que habrá de ser en gran medida autodirigido o autónomo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/123000722/2025-26/CB6> a ns1:Competency ;
    ns1:competencyCode "CB6" ;
    ns1:competencyDescription "Poseer y comprender conocimientos que aporten una base u oportunidad de ser originales en el desarrollo y/o aplicación de ideas, a menudo en un contexto de investigación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/123000722/2025-26/CE4> a ns1:Competency ;
    ns1:competencyCode "CE4" ;
    ns1:competencyDescription "Integrar y aplicar los métodos geoestadísticos y de análisis estadístico multivariante para la modelización de la información geoespacial en los ámbitos de la Ingeniería y la Arquitectura"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/123000722/2025-26/RA14> a ns1:LearningResult ;
    ns1:learningResultCode "RA14" ;
    ns1:learningResultDescription "Conocer las distintas funciones estadísticas, intervalos de confianza y test de hipótesis"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/123000722/2025-26/RA19> a ns1:LearningResult ;
    ns1:learningResultCode "RA19" ;
    ns1:learningResultDescription "Aplicar las diferentes técnicas de ajuste en distintos problemas relacionados con el tratamiento de la información geomática"@es .

