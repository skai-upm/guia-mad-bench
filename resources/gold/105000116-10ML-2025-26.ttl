<https://guia-kg.skai.etsisi.upm.es/resource/105000116/2025-26/K1> a ns1:Competency ;
    ns1:competencyCode "K1" ;
    ns1:competencyDescription "Comprender y utilizar el lenguaje matemático. Conocer demostraciones de teoremas clásicos. Comprender las definiciones de objetos matemáticos. TIPO: Conocimientos o contenidos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000116/2025-26/K12> a ns1:Competency ;
    ns1:competencyCode "K12" ;
    ns1:competencyDescription "Conocer las propiedades elementales de las estructuras algebraicas básicas. TIPO: Conocimientos o contenidos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000116/2025-26/K3> a ns1:Competency ;
    ns1:competencyCode "K3" ;
    ns1:competencyDescription "Comprender intelectualmente el papel central que tienen los algoritmos y las estructuras de datos, así como una apreciación del mismo. TIPO: Conocimientos o contenidos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000116/2025-26/K8> a ns1:Competency ;
    ns1:competencyCode "K8" ;
    ns1:competencyDescription "Conocer las nociones básicas de la teoría de conjuntos y aplicaciones, de la teoría elemental de números y de la combinatoria enumerativa. TIPO: Conocimientos o contenidos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000116/2025-26/RA202> a ns1:LearningResult ;
    ns1:learningResultCode "RA202" ;
    ns1:learningResultDescription "Los resultados del aprendizaje correspondientes a esta asignatura han quedado definidos en el apartado de competencias de este documento, señalando los que corresponden a conocimientos, habilidades y competencias propiamente dichas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000116/2025-26/S1> a ns1:Competency ;
    ns1:competencyCode "S1" ;
    ns1:competencyDescription "Plantear nuevas definiciones. Poder enunciar resultados y construir demostraciones, detectar errores en ellas o encontrar contraejemplos. TIPO: Habilidades o destrezas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000116/2025-26/S11> a ns1:Competency ;
    ns1:competencyCode "S11" ;
    ns1:competencyDescription "Manejar los conceptos y resultados básicos de teoría de grafos y las técnicas básicas de optimización. TIPO: Habilidades o destrezas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000116/2025-26/S15> a ns1:Competency ;
    ns1:competencyCode "S15" ;
    ns1:competencyDescription "Manejar las correspondientes subestructuras algebraicas, cocientes y conocer ejemplos de todas ellas. TIPO: Habilidades o destrezas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000116/2025-26/S2> a ns1:Competency ;
    ns1:competencyCode "S2" ;
    ns1:competencyDescription "Ser capaz de extraer de un objeto matemático aquellas propiedades fundamentales que lo caracterizan, distinguiéndolas de aquellas otras ocasionales compartidas con otros objetos matemáticos. TIPO: Habilidades o destrezas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000116/2025-26/S4> a ns1:Competency ;
    ns1:competencyCode "S4" ;
    ns1:competencyDescription "Comprender y ser capaz de encontrar soluciones a problemas matemáticos en diferentes áreas, utilizando para resolverlos las herramientas analíticas, numéricas o estadísticas disponibles. TIPO: Habilidades o destrezas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000116/2025-26/S5> a ns1:Competency ;
    ns1:competencyCode "S5" ;
    ns1:competencyDescription "Utilizar herramientas informáticas (de cálculo simbólico, de análisis estadístico, de cálculo numérico, de visualización) para resolver problemas planteados en términos matemáticos, bien de forma experimental, bien de forma rigurosa. TIPO: Habilidades o destrezas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000116/2025-26/S6> a ns1:Competency ;
    ns1:competencyCode "S6" ;
    ns1:competencyDescription "Diseñar algoritmos y desarrollar programas para resolver problemas en matemáticas. TIPO: Habilidades o destrezas."@es .

