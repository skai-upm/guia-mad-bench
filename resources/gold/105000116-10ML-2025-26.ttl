<https://guia-kg.skai.etsisi.upm.es/resource/105000116/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Grupos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000116/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Grupos y subgrupos. Generadores. Conjugación. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000116/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "2. Anillos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000116/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "2.1. Anillos y subanillos. Ideales y cocientes. Operaciones con ideales. Dominio de integridad y dominio de ideales principales. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000116/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "2.2. Operaciones con ideales. Ideales primos y maximales. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000116/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "2.3. Homomorfismos de anillos. Teoremas de isomorfía. Teorema chino de los restos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000116/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "2.4. Divisibilidad y factorización. Anillos de congruencias. Otros ejemplos de dominios. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000116/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "2.5. Anillos de polinomios en una variable. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000116/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "3. Cuerpos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000116/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "3.1. Cuerpos. Cuerpos de fracciones. Cuerpos finitos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000116/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "3.2. Extensiones algebraicas y trascendentes. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000116/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "3.3. Construcciones con regla y compás. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000116/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Ejemplos de grupos: cíclicos, diédricos, congruencias y cuaterniones. Órdenes y fórmula de Lagrange. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000116/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "1.3. Subgrupos normales. Normalizador. Grupo cociente. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000116/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "1.4. Homomorfismos. Teoremas de isomorfía. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000116/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "1.5. Grupos de permutaciones. Grupo simétrico y grupo alternado. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000116/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "1.6. Acción de un grupo sobre un conjunto. Fórmula de las órbitas y ecuación de clases de conjugación. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000116/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "1.7. Teoremas de Sylow. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000116/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "1.8. Estructura de los grupos abelianos finitos. Clasificación de grupos finitos de orden bajo. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000116/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "1.9. Estructura de los grupos abelianos finitamente generados. Sin subniveles"@es .

