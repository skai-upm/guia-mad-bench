    ns1:inpersonHours "54 horas (34.6%)"@es ;
    ns1:numberOfCredits 6.0 ;
    ns1:otherInformation "This course is related to United Nations' Sustainable Development Goals, specially SDG3 (Good health and well-being) but also SDG4 (Quality education), SDG9 (industry, innovation, and infrastructure) and SDG10 (Reduced inequalities)"@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
