<https://guia-kg.skai.etsisi.upm.es/resource/125000423/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Introducción a las bases de datos espaciales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125000423/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. La información geográfica. Tipos de información geográfica: Vectorial, raster, topología, TIN, nubes de puntos 3D. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125000423/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "2.2. Nuevos tipos de datos y geometrías: GEOMETRY, GEOGRAPHY, raster Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125000423/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "2.3. Índices espaciales Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125000423/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "2.4. Funciones de PostGIS para datos vectoriales. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125000423/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "2.5. Datos ráster, bandas, overviews. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125000423/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "2.6. Funciones para datos raster. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125000423/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "2.7. Otras extensiones sobre POSTGIS: Point Cloud, pgRouting, tiger_geocoder Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125000423/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "3. Creación y gestión de funciones y procedimientos almacenados (PL/PgSQL)"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125000423/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "3.1. Sintaxis Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125000423/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "3.2. Tipos de datos, tablas, cursores Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125000423/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "3.3. Sentencias y estructuras de control Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125000423/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Los sistemas de referencia: geográficos, cartesianos (proyectados), direcciones postales, sistemas de referencia lineales (LRS). Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125000423/2025-26/syllabus/20> a ns1:SyllabusItem ;
    ns1:itemIndex 20 ;
    ns1:syllabusDescription "3.4. Manejo de errores y disparadores Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125000423/2025-26/syllabus/21> a ns1:SyllabusItem ;
    ns1:itemIndex 21 ;
    ns1:syllabusDescription "4. Tipos de datos y geometrías en Oracle"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125000423/2025-26/syllabus/22> a ns1:SyllabusItem ;
    ns1:itemIndex 22 ;
    ns1:syllabusDescription "4.1. Tipos de datos y geometrías en Oracle Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125000423/2025-26/syllabus/23> a ns1:SyllabusItem ;
    ns1:itemIndex 23 ;
    ns1:syllabusDescription "4.2. Índices espaciales Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125000423/2025-26/syllabus/24> a ns1:SyllabusItem ;
    ns1:itemIndex 24 ;
    ns1:syllabusDescription "4.3. Funciones de oracle para manejar datos vectoriales. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125000423/2025-26/syllabus/25> a ns1:SyllabusItem ;
    ns1:itemIndex 25 ;
    ns1:syllabusDescription "4.4. Funciones y procedimientos almacenados en Oracle Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125000423/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "1.3. La codificación y el almacenamiento de la información geográfica. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125000423/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "1.4. La indexación espacial. Conceptos generales. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125000423/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "1.5. La topología del plano (I). Conceptos generales. El interior, la frontera, el exterior, la clausura de las distintas primitivas vectoriales. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125000423/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "1.6. La topología del plano (II). El modelo DE-9IM. Las posiciones relativas de las primitivas geométricas del plano. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125000423/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "1.7. La topología de las redes lineales. Conceptos generales. El interior, la frontera, el exterior, la clausura de las distintas primitivas vectoriales. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125000423/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "2. PostgreSQL/PostGIS"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125000423/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "2.1. Uso de la extensión espacial. Versiones de librerías, Metadatos, Sistemas de coordenadas. Sin subniveles"@es .

