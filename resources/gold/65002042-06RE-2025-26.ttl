<https://guia-kg.skai.etsisi.upm.es/resource/65002042/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/65002042/2025-26/CG1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/65002042/2025-26/CG3>,
        <https://guia-kg.skai.etsisi.upm.es/resource/65002042/2025-26/CG4>,
        <https://guia-kg.skai.etsisi.upm.es/resource/65002042/2025-26/F22> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/65002042/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/65002042/2025-26/didactic_resource/2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/65002042/2025-26/didactic_resource/3> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/65002042/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/65002042/2025-26/RA230>,
        <https://guia-kg.skai.etsisi.upm.es/resource/65002042/2025-26/RA231>,
        <https://guia-kg.skai.etsisi.upm.es/resource/65002042/2025-26/RA232> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/65002042/2025-26/syllabus> ;
    ns1:inpersonHours "56 horas y 20 minutos (48.1%)"@es ;
    ns1:numberOfCredits 4.5 ;
    ns1:otherInformation "Esta asignatura está relacionada con el Objetivo de Desarrollo Sostenible de la ONU número 7: energía asequible y no contaminante"@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "56 horas y 20 minutos"@es ;
    schema:activitiesWorkload "180%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/65002042/2025-26/eventSchedule> ;
    schema:description "El objetivo de la asignatura es analizar el proceso de descarbonización del suministro energético. Para ello, una parte del análisis consiste identificar las diferentes tecnologías que permiten descarbonizar el consumo energético, analizando sus costes y las características de su utilización (flexibilidad, etc.) y utilizar esta información para discutir cuál es la solución más adecuada, teniendo en cuenta que no es suficiente con que una solución sea descarbonizada, sino que hay que encontrar cuál es la solución óptima teniendo en cuenta los costes, los tiempos de desarrollo de cada propuesta, etc. La segunda parte del análisis aborda cómo se pueden implantar en la práctica esas soluciones: cuáles son los procesos de decisión que suceden en el mercado mediante los que se decide si se realizan unas inversiones u otras, y con qué herramientas la política energético-ambiental puede influir sobre ellos."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/vazquez.martinez%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/vazquez.martinez%40upm.es> ;
    schema:name "Economía de los Recursos Energéticos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65002042/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Conocer y aplicar conocimientos de ciencias y tecnologías básicas a la práctica de la Ingeniería de los Recursos Energéticos, Combustibles y Explosivos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65002042/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Aplicar los conocimientos adquiridos para identificar, formular y resolver problemas dentro de contextos amplios y multidisciplinarios, siendo capaces de integrar conocimientos, trabajando en equipos multidisciplinares."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65002042/2025-26/CG4> a ns1:Competency ;
    ns1:competencyCode "CG4" ;
    ns1:competencyDescription "Comprender el impacto de la Ingeniería de los Recursos Energéticos, Combustibles y Explosivos en el medio ambiente, el desarrollo sostenible de la sociedad . desarrollando la capacidad para la realización de estudios de ordenación del territorio y de los aspectos medioambientales relacionados con los proyectos, plantas e instalaciones, en su ámbito."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65002042/2025-26/F22> a ns1:Competency ;
    ns1:competencyCode "F22" ;
    ns1:competencyDescription "Aprovechamiento, transformación y gestión de los recursos energéticos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65002042/2025-26/RA230> a ns1:LearningResult ;
    ns1:learningResultCode "RA230" ;
    ns1:learningResultDescription "Comprender los mecanismos que explican el funcionamiento de los mercados"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65002042/2025-26/RA231> a ns1:LearningResult ;
    ns1:learningResultCode "RA231" ;
    ns1:learningResultDescription "Aplicar los conceptos teóricos de la microeconomía a los mercados reales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65002042/2025-26/RA232> a ns1:LearningResult ;
    ns1:learningResultCode "RA232" ;
    ns1:learningResultDescription "Analizar la importancia de los sectores energéticos en la economía"@es .

