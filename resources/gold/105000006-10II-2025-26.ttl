    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/105000006/2025-26/eventSchedule> ;
    schema:description "Esta asignatura forma parte de los fundamentos matemáticos que todo ingeniero debe poseer. Trata del estudio de los espacios vectoriales y la relación de dependencia lineal que los define. Se estudian y emplean para ello las matrices y los sistemas de ecuaciones lineales."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/jesus.martinez.mateo%40upm.es> ;
    schema:inLanguage "Inglés/Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/agueda.mata%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/jesus.martinez.mateo%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/mariafrancisca.martinez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/mariapaloma.gomez%40upm.es> ;
    schema:name "Algebra Lineal"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000006/2025-26/CG> a ns1:Competency ;
    ns1:competencyCode "CG" ;
    ns1:competencyDescription "1/21"@es,
        "6"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000006/2025-26/Ce%200> a ns1:Competency ;
    ns1:competencyCode "Ce 0" ;
    ns1:competencyDescription "Capacidad para la resolución de los problemas matemáticos que puedan plantearse en la ingeniería. Aptitud para aplicar los conocimientos sobre: álgebra lineal; cálculo diferencial e integral; métodos numéricos; algorítmica numérica; estadística y optimización"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000006/2025-26/RA269> a ns1:LearningResult ;
    ns1:learningResultCode "RA269" ;
    ns1:learningResultDescription "Resolver sistemas de ecuaciones lineales. Conocer y manejar las propiedades de los espacios vectoriales y sus aplicaciones a la informática."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000006/2025-26/RA270> a ns1:LearningResult ;
    ns1:learningResultCode "RA270" ;
    ns1:learningResultDescription "Utilizar las matrices para la representación y manejo de datos y transformaciones, así como su aplicación a la geometría del plano y del espacio. Cálculo de autovalores y autovectores y sus aplicaciones a la informática."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000006/2025-26/RA271> a ns1:LearningResult ;
    ns1:learningResultCode "RA271" ;
    ns1:learningResultDescription "Modelar matemáticamente problemas reales y conocer las técnicas para resolverlos."@es .

