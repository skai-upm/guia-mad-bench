<https://guia-kg.skai.etsisi.upm.es/resource/105000420/2025-26/RA142> a ns1:LearningResult ;
    ns1:learningResultCode "RA142" ;
    ns1:learningResultDescription "Escuchar, negociar, persuadir y defender argumentos oralmente o por escrito."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000420/2025-26/RA179> a ns1:LearningResult ;
    ns1:learningResultCode "RA179" ;
    ns1:learningResultDescription "Conocer el intercambio de recursos económicos a lo largo del tiempo entre los individuos, empresas e instituciones financieras, lo que implica el análisis de las decisiones de inversiones y financiación en la empresa, la teoría de carteras, la valoración de activos y el funcionamiento de los mercados financieros."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000420/2025-26/RA180> a ns1:LearningResult ;
    ns1:learningResultCode "RA180" ;
    ns1:learningResultDescription "Aplicar el análisis cuantitativo de la empresa y su entorno."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000420/2025-26/RA181> a ns1:LearningResult ;
