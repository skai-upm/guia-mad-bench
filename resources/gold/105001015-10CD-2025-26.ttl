    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation "El curso es eminentemente práctico, por lo que es aconsejable que los alumnos traigan a clase sus portátiles para poder trabajar durante las horas de clase"@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
