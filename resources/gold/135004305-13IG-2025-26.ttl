<https://guia-kg.skai.etsisi.upm.es/resource/135004305/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Elementos básicos de circuitos. Principales leyes que rigen los fenómenos electromagnéticos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004305/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Ley de Coulomb, campo eléctrico y diferencia de potencial. Conductores y dieléctricos. Condensadores. Capacidad de un condensador. Asociación de condensadores. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004305/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "2.5. Corrección del factor de potencia. Medida de potencia y energía Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004305/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "3. Métodos generales de análisis de circuitos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004305/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "3.1. Definiciones en un circuito eléctrico. Método de análisis por nudos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004305/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "3.2. Método de análisis por mallas. Conversión de fuentes Teoremas de Helmholtz Thévenin y Helmholtz Norton. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004305/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "4. Sistemas trifásicos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004305/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "4.1. Tensiones y corrientes trifásicas. Sistemas a 3 y 4 hilos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004305/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "4.2. Receptores desequilibrados conectados en triángulo. Receptores desequilibrados conectados en estrella Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004305/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "4.3. Receptores equilibrados. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004305/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "4.4. Potencia demandada en circuitos trifásicos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004305/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "4.5. Corrección del factor de potencia en sistemas trifásicos Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004305/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Corriente eléctrica: Intensidad y densidad de corriente. Conductividad, resistividad, resistencia y ley de Ohm. Fuentes de tensión y de corriente. Leyes de Kirchoff. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004305/2025-26/syllabus/20> a ns1:SyllabusItem ;
    ns1:itemIndex 20 ;
    ns1:syllabusDescription "4.6. Medida de potencia y de energía en sistemas trifásicos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004305/2025-26/syllabus/21> a ns1:SyllabusItem ;
    ns1:itemIndex 21 ;
    ns1:syllabusDescription "5. Instalaciones eléctricas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004305/2025-26/syllabus/22> a ns1:SyllabusItem ;
    ns1:itemIndex 22 ;
    ns1:syllabusDescription "5.1. Transporte y distribución de energía eléctrica. Tipos de líneas. Elementos constructivos Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004305/2025-26/syllabus/23> a ns1:SyllabusItem ;
    ns1:itemIndex 23 ;
    ns1:syllabusDescription "5.2. Conceptos y Cálculos de la caída de tensión y pérdida de en líneas eléctricas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004305/2025-26/syllabus/24> a ns1:SyllabusItem ;
    ns1:itemIndex 24 ;
    ns1:syllabusDescription "5.3. Reglamento Electrotécnico de Baja Tensión. Instalación de enlace: definición y partes de que consta. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004305/2025-26/syllabus/25> a ns1:SyllabusItem ;
    ns1:itemIndex 25 ;
    ns1:syllabusDescription "5.4. Dispositivos de mando y protección en instalaciones de baja tensión Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004305/2025-26/syllabus/26> a ns1:SyllabusItem ;
    ns1:itemIndex 26 ;
    ns1:syllabusDescription "5.5. Instalaciones de interior o receptoras. Intensidades admisibles en los conductores empleados en las instalaciones de baja tensión Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004305/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "1.3. Campo magnético. Campo creado por una corriente. Ley de Biot y Savat. Teorema de Ampere. Fuerza electromotriz inducida. Ley de Faraday. Corrientes de Foucault. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004305/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "1.4. Inducción mutua y autoinducción. Inducción Magnética en los medios materales y circuito magnéticos Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004305/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "2. Corriente alterna."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004305/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "2.1. Régimen transitorio de corriente continua. Formas de onda sinusoidales y valores asociados. Corriente alterna en un circuito serie RLC. Reactancia e impedancia. Representación cartesiana, vectorial y compleja de la corriente alterna. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004305/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "2.2. Expresión simbólica de la ley de Ohm. Leyes de Kirchoff aplicadas a la corriente alterna. Comportamiento de los elementos pasivos ante una tensión alterna senoidal. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004305/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "2.3. Metodología general de resolución de problemas. Resolución de circuitos serie, paralelo y mixtos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004305/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "2.4. Potencia instantánea, media y fluctuante en un dipolo pasivo. Potencia aparente y reactiva. Teorema de Boucherot. Sin subniveles"@es .

