    ns1:learningResultCode "RA114" ;
    ns1:learningResultDescription "Formular opiniones, a partir de información incompleta o limitada, sobre las responsabilidades sociales y éticas vinculadas a los cultivos energéticos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002026/2025-26/RA115> a ns1:LearningResult ;
    ns1:learningResultCode "RA115" ;
    ns1:learningResultDescription "Conocer procesos de producción de bioproductos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002026/2025-26/RA13> a ns1:LearningResult ;
    ns1:learningResultCode "RA13" ;
    ns1:learningResultDescription "Comprender un diagrama de flujo de un proceso"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002026/2025-26/RA15> a ns1:LearningResult ;
    ns1:learningResultCode "RA15" ;
    ns1:learningResultDescription "Analizar el concepto de sostenibilidad ambiental, económica y de recursos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002026/2025-26/RA16> a ns1:LearningResult ;
    ns1:learningResultCode "RA16" ;
    ns1:learningResultDescription "Comprender los problemas medioambientales de la producción energética"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002026/2025-26/RA26> a ns1:LearningResult ;
    ns1:learningResultCode "RA26" ;
    ns1:learningResultDescription "Habilidad de cálculos relativos a procesos de combustión y sus combustibles"@es .

