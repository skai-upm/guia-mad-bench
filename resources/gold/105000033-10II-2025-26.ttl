    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/105000033/2025-26/eventSchedule> ;
    schema:description "Estudio de métodos numéricos y algorítmicos para resolver problemas matemáticos que aparecen en ciencia e ingeniería. Aprender a diseñar, implementar y analizar dichos métodos y algoritmos numéricos, utilizando el software científico Matlab."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/juan.robles%40upm.es> ;
