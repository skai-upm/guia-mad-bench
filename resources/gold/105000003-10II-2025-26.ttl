    ns1:itemIndex 22 ;
    ns1:syllabusDescription "4.1. Principios básicos de recuento. Principios de las cajas, adición, multiplicación y complementario. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000003/2025-26/syllabus/23> a ns1:SyllabusItem ;
    ns1:itemIndex 23 ;
    ns1:syllabusDescription "4.2. Listas y selecciones, sin repetir elementos o repitiéndolos. Sin subniveles"@es .

