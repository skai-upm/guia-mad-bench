    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Conjuntos, Relaciones y aplicaciones. Relaciones en un conjunto. Relaciones de equivalencia. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000003/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "2.5. Ecuaciones diofánticas lineales. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000003/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "2.6. Números primos. Factorización. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000003/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "2.7. Polinomios. Divisibilidad de polinomios. Algoritmo de Euclides. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000003/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "2.8. Factorización de polinomios. Polinomios irreducibles. Criterio de Eisenstein. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000003/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "3. Aritmética modular"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000003/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "3.1. Congruencias en Z. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000003/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "3.2. Aritmética en Zn. Divisores de cero y elementos inversibles. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000003/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "3.3. Teoremas de Euler, Fermat y Wilson. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000003/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "3.4. Ecuaciones en congruencias. Ecuaciones lineales. Sistemas de congruencias. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000003/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "3.5. Teorema chino del resto. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000003/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Relaciones de orden. Conjuntos ordenados. Elementos maximales y minimales. Diagramas de Hasse. Retículos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000003/2025-26/syllabus/20> a ns1:SyllabusItem ;
    ns1:itemIndex 20 ;
    ns1:syllabusDescription "3.6. Criptografía RSA. Sin subniveles"@es .

