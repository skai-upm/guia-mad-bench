    ns1:numberOfCredits 5.0 ;
    ns1:otherInformation """La asignatura contribuye desde la educación superior universitaria de formación en ingeniería a los Objetivos de Desarrollo Sostenible (ODS) formulados por Organización de las Naciones Unidas (ONU):
ODS 9: Construir infraestructuras resilientes, promover la industrialización sostenible y fomentar la innovación.
ODS 12: Garantizar modalidades de consumo y producción sostenibles."""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "48 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/563000140/2025-26/eventSchedule> ;
    schema:description "Se aborda una selección de procesos de fabricación mecánica de especial interés en la transformación de materiales metálicos y materiales plásticos desde la perspectiva de sistemas, con enfoque en los modelos de ingeniería. Se aborda así mismo la modelización de sistemas de producción."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/roque.calvo%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/carmen.fonseca%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/cecilia.garcia%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/roque.calvo%40upm.es> ;
    schema:name "Ingeniería de Procesos Productivos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000140/2025-26/CEI02> a ns1:Competency ;
    ns1:competencyCode "CEI02" ;
    ns1:competencyDescription "Completar su formación con relación a los diferentes tipos de procesos industriales, proporcionando una formación avanzada y competencias en la aplicación tecnológica y de ingeniería en el ámbito de la producción"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000140/2025-26/CEI03> a ns1:Competency ;
    ns1:competencyCode "CEI03" ;
    ns1:competencyDescription "Desarrollar capacidades de aplicación de los conocimientos adquiridos al diseño de procesos industriales, en función de las características de los elementos a producir, con criterios de máxima calidad, productividad, seguridad y respeto al medio ambiente"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000140/2025-26/CEI11> a ns1:Competency ;
    ns1:competencyCode "CEI11" ;
    ns1:competencyDescription "Comprensión sistemática en el campo de la producción"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000140/2025-26/CEI16> a ns1:Competency ;
    ns1:competencyCode "CEI16" ;
    ns1:competencyDescription "Capacidad de comunicar con sus colegas, con la comunidad académica en su conjunto y con la sociedad en general acerca de sus áreas de conocimiento"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000140/2025-26/CG08> a ns1:Competency ;
    ns1:competencyCode "CG08" ;
    ns1:competencyDescription "Poseer habilidades para el aprendizaje continuado, autodirigido y autónomo."@es .

