    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/595010342/2025-26/eventSchedule> ;
    schema:description """This course is intended for senior undergraduate students in telecommunication systems engineering who wish to get acquainted with the state of the art on both modern mobile communication systems, like LTE and 5G, and broadband wireless data networks, like WiFi, Bluetooth, or UWB.
Fundamental concepts of cellular systems, mobile wireless channel, and wireless networks and systems will be examined. A number of practical abilities will be developed through some hands-on guided activities.
Keywords: Mobile Communications, Wireless Communications, LTE, E-UTRAN, 5G, NR, WLAN, WiFi, Bluetooth, UWB"""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/antonio.perez%40upm.es> ;
    schema:inLanguage "Inglés"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/antonio.perez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/juan.moreno.garcia-loygorri%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/pedro.gdelpino%40upm.es> ;
    schema:name "Mobile Communications"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595010342/2025-26/CE%20B3> a ns1:Competency ;
    ns1:competencyCode "CE B3" ;
    ns1:competencyDescription "Comprensión y dominio de los conceptos básicos sobre las leyes generales de la mecánica, termodinámica, campos y ondas y electromagnetismo y su aplicación para la resolución de problemas propios de la ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595010342/2025-26/CE%20SC02> a ns1:Competency ;
    ns1:competencyCode "CE SC02" ;
    ns1:competencyDescription "Capacidad para aplicar las técnicas en que se basan las redes, servicios y aplicaciones de telecomunicación tanto en entornos fijos como móviles, personales, locales o a gran distancia, con diferentes anchos de banda, incluyendo telefonía, radiodifusión, televisión y datos, desde el punto de vista de los sistemas de transmisión."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595010342/2025-26/CE%20SC05> a ns1:Competency ;
    ns1:competencyCode "CE SC05" ;
    ns1:competencyDescription "Capacidad para la selección de antenas, equipos y sistemas de transmisión, propagación de ondas guiadas y no guiadas, por medios electromagnéticos, de radiofrecuencia u ópticos y la correspondiente gestión del espacio radioeléctrico y asignación de frecuencias."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595010342/2025-26/CE%20SC07> a ns1:Competency ;
    ns1:competencyCode "CE SC07" ;
    ns1:competencyDescription "Capacidad para realizar proyectos en el ámbito de las tecnologías específicas de la Ingeniería de Telecomunicación, de naturaleza profesional en que se sinteticen e integren las competencias adquiridas en las enseñanzas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595010342/2025-26/CE%20TEL01> a ns1:Competency ;
    ns1:competencyCode "CE TEL01" ;
    ns1:competencyDescription "Capacidad para aprender de manera autónoma nuevos conocimientos y técnicas adecuados para la concepción, el desarrollo o la explotación de sistemas y servicios de telecomunicación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595010342/2025-26/CE%20TEL16> a ns1:Competency ;
    ns1:competencyCode "CE TEL16" ;
    ns1:competencyDescription "Conocimiento de la normativa y la regulación de las telecomunicaciones en los ámbitos nacional, europeo e internacional."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595010342/2025-26/CG%2002> a ns1:Competency ;
    ns1:competencyCode "CG 02" ;
    ns1:competencyDescription "Capacidad de búsqueda y selección de información, de razonamiento crítico y de elaboración y defensa de argumentos dentro del área."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595010342/2025-26/CG%2004> a ns1:Competency ;
    ns1:competencyCode "CG 04" ;
    ns1:competencyDescription "Capacidad de abstracción, de análisis y de síntesis y de resolución de problemas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595010342/2025-26/CG%2005> a ns1:Competency ;
    ns1:competencyCode "CG 05" ;
    ns1:competencyDescription "Capacidad de trabajo en equipo y en entornos multidisciplinares."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595010342/2025-26/CG%2010> a ns1:Competency ;
    ns1:competencyCode "CG 10" ;
    ns1:competencyDescription "Capacidad para manejar especificaciones, reglamentos y normativas y la aplicación de las mismas en el desarrollo de la profesión."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595010342/2025-26/RA280> a ns1:LearningResult ;
    ns1:learningResultCode "RA280" ;
    ns1:learningResultDescription "Análisis y simulación del canal móvil y de los modelos de propagación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595010342/2025-26/RA281> a ns1:LearningResult ;
    ns1:learningResultCode "RA281" ;
    ns1:learningResultDescription "Cálculo de los balances de enlace y de la calidad de los sistemas de Comunicaciones Móviles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595010342/2025-26/RA282> a ns1:LearningResult ;
    ns1:learningResultCode "RA282" ;
    ns1:learningResultDescription "Descripción y comparación de los principales sistemas digitales de comunicaciones móviles europeos (TETRA, GSM/GPRS, UMTS, LTE), incluidas la arquitectura, servicios, interfaces, las diferentes capas y en especial la correspondiente al interfaz radio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595010342/2025-26/RA283> a ns1:LearningResult ;
    ns1:learningResultCode "RA283" ;
    ns1:learningResultDescription "Análisis de la estructura de ráfagas y tramas y de los procedimientos de codificación y modulación utilizados"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595010342/2025-26/RA284> a ns1:LearningResult ;
    ns1:learningResultCode "RA284" ;
    ns1:learningResultDescription "Diseño y planificación de redes y sistemas de comunicaciones móviles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595010342/2025-26/RA285> a ns1:LearningResult ;
    ns1:learningResultCode "RA285" ;
    ns1:learningResultDescription "Utilización de los procedimientos y técnicas de medida y caracterización de estos sistemas y de los elementos de comunicaciones implicados"@es .

