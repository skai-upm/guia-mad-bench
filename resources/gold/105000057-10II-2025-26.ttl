<https://guia-kg.skai.etsisi.upm.es/resource/105000057/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/105000057/2025-26/CG>,
        <https://guia-kg.skai.etsisi.upm.es/resource/105000057/2025-26/Ce%2017>,
        <https://guia-kg.skai.etsisi.upm.es/resource/105000057/2025-26/Ce%2044> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/105000057/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/105000057/2025-26/didactic_resource/2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/105000057/2025-26/didactic_resource/3>,
