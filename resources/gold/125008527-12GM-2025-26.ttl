    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/125008527/2025-26/eventSchedule> ;
    schema:description """Los sistemas y vehículos de control remoto representan nuevas capacidades de captación de información y procesamiento métrico de señales e imágenes ligadas a ecuaciones fotogramétricas. Mediante la aplicación de algoritmos basados en el tratamiento masivo de información digital y su apoyo en ecuaciones fotogramétricas se consigue su extracción, posicionamiento y explotación métrica; configurando bases de datos geomáticas de gran interés para proyectos de ingeniería. Esta asignatura estudia tanto los sistemas de captura y los sensores, como los procedimientos de cálculo primero y extracción de productos fotogramétricos tanto cartográficos como de modelos 3D, cuidando tanto los aspectos legales necesarios para el desarrollo de los vuelos, como los métricos necesarios para la extracción de calidad.
Todas las unidades didácticas tienen sus correspondientes ejercicios de laboratorio que ayudan a la comprensión de los conceptos teóricos y su aplicación en la actividad profesional."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/s.lopezc%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/s.lopezc%40upm.es> ;
    schema:name "Aplicaciones Geomáticas de los Sistemas Autónomos de Control Remoto"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125008527/2025-26/CG05> a ns1:Competency ;
    ns1:competencyCode "CG05" ;
    ns1:competencyDescription "Determinar, medir, evaluar y representar el terreno, objetos tridimensionales, puntos y trayectorias"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125008527/2025-26/CG06> a ns1:Competency ;
    ns1:competencyCode "CG06" ;
    ns1:competencyDescription "Reunir e interpretar información del terreno y toda aquélla relacionada geográfica y económicamente con él"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125008527/2025-26/CG07> a ns1:Competency ;
    ns1:competencyCode "CG07" ;
    ns1:competencyDescription "Gestión y ejecución de proyectos de investigación desarrollo e innovación en el ámbito de esta ingeniería"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125008527/2025-26/CG08> a ns1:Competency ;
    ns1:competencyCode "CG08" ;
    ns1:competencyDescription "Planificación, proyecto, dirección, ejecución, y gestión de procesos de medida, sistemas de información, explotación de imágenes, posicionamiento y navegación; modelización, representación y visualización de la información territorial en, bajo y sobre la superficie terrestre"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125008527/2025-26/CRT2> a ns1:Competency ;
    ns1:competencyCode "CRT2" ;
    ns1:competencyDescription "Conocimiento, utilización y aplicación de instrumentos y métodos fotogramétricos adecuados para la realización de cartografía."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125008527/2025-26/CRT3> a ns1:Competency ;
    ns1:competencyCode "CRT3" ;
    ns1:competencyDescription "Conocimiento, utilización y aplicación de las técnicas de tratamiento. Análisis de datos espaciales. Estudio de modelos aplicados a la ingeniería y arquitectura."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125008527/2025-26/RA132> a ns1:LearningResult ;
    ns1:learningResultCode "RA132" ;
    ns1:learningResultDescription "Elegir el sistema de referencia adecuado para cada fase del proceso fotogramétrico y para la expresión de sus resultados, aplicando las transformaciones necesarias"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125008527/2025-26/RA134> a ns1:LearningResult ;
    ns1:learningResultCode "RA134" ;
    ns1:learningResultDescription "Diseñar y aplicar el modelo estocástico adecuado a cada ajuste fotogramétrico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125008527/2025-26/RA135> a ns1:LearningResult ;
    ns1:learningResultCode "RA135" ;
    ns1:learningResultDescription "Valorar la calidad de los resultados fotogramétricos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125008527/2025-26/RA139> a ns1:LearningResult ;
    ns1:learningResultCode "RA139" ;
    ns1:learningResultDescription "Proyectar el levantamiento fotogramétrico de objetos distintos del terreno, utilizando cámaras métricas o no métricas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125008527/2025-26/RA141> a ns1:LearningResult ;
    ns1:learningResultCode "RA141" ;
    ns1:learningResultDescription "Diseñar y construir redes fotogramétricas capaces de proporcionar coordenadas de alta precisión en aplicaciones de ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125008527/2025-26/RA142> a ns1:LearningResult ;
    ns1:learningResultCode "RA142" ;
    ns1:learningResultDescription "Diseñar y aplicar secuencias operativas para la generación de modelos tridimensionales de objetos por métodos fotogramétricos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125008527/2025-26/RA148> a ns1:LearningResult ;
    ns1:learningResultCode "RA148" ;
    ns1:learningResultDescription "Conocer el ámbito de aplicación de las materias de Fotogrametría y Teledetección"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125008527/2025-26/RA315> a ns1:LearningResult ;
    ns1:learningResultCode "RA315" ;
    ns1:learningResultDescription "Conocimiento de las propiedades espectrales y parámetros biofísicos básicos de las cubiertas terrestres y la tipificación de las mismas a partir de imágenes capturadas por plataformas aéreas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125008527/2025-26/RA316> a ns1:LearningResult ;
    ns1:learningResultCode "RA316" ;
    ns1:learningResultDescription "Diseñar, planificar y gestionar la captura de información desde vehículos de control remoto"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125008527/2025-26/RA317> a ns1:LearningResult ;
    ns1:learningResultCode "RA317" ;
    ns1:learningResultDescription "Conocer y distinguir entre los distintos tipos de vehículos de control remoto"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125008527/2025-26/RA320> a ns1:LearningResult ;
    ns1:learningResultCode "RA320" ;
    ns1:learningResultDescription "Capacidad para elegir sensores y aplicar técnicas de captura de datos con aplicación en la ingeniería desde vehículos de control remoto"@es .

