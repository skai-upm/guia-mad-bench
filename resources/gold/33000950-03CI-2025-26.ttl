    ns1:inpersonHours "120 horas (38.5%)"@es ;
    ns1:numberOfCredits 12.0 ;
    ns1:otherInformation ""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "120 horas"@es ;
    schema:activitiesWorkload "300%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/33000950/2025-26/eventSchedule> ;
    schema:description """Elaboración de actividades prácticas de investigación tutorizadas, tanto colectivas como individuales, enmarcadas en la simulación de un contexto profesional o académico real, que integren los conocimientos adquiridos en el módulo instrumental y el módulo teórico.

Se espera que al finalizar el módulo los estudiantes tengan pleno conocimiento de la aplicación práctica y capacidad de realizar investigaciones en las posibles intersecciones disciplinares entre los conocimientos adquiridos durante el módulo teórico y el módulo instrumental, además de que adquiera la pericia practica y el know-how necesario para llevar a cabo las actividades propuestas en el módulo de fin de master de forma exitosa de manera más autónoma y con una tutorización menor."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/almudena.ribot%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/almudena.ribot%40upm.es> ;
    schema:name "Proyecto"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000950/2025-26/CE11> a ns1:Competency ;
    ns1:competencyCode "CE11" ;
    ns1:competencyDescription "Capacidad para desenvolverse con soltura en entornos de trabajo multidisciplinares vinculados a la innovación y la investigación aplicada a los ámbitos de la construcción Industrializada y el prototipado en el proyecto arquitectónico.Tipo: Competencias"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000950/2025-26/CE12> a ns1:Competency ;
    ns1:competencyCode "CE12" ;
    ns1:competencyDescription "Capacidad para diseñar, desarrollar y llevar a cabo procesos avanzados de investigación e innovación aplicada a los ámbitos de la construcción Industrializada y el prototipado en el proyecto arquitectónico.Tipo: Competencias"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000950/2025-26/CE13> a ns1:Competency ;
    ns1:competencyCode "CE13" ;
    ns1:competencyDescription "Capacidad para proponer y gestionar procesos avanzados de colaboración con agentes pertenecientes al ámbito empresarial en iniciativas vinculadas a la construcción Industrializada y el prototipado en el proyecto arquitectónico. Tipo: Competencias"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000950/2025-26/CE4> a ns1:Competency ;
    ns1:competencyCode "CE4" ;
    ns1:competencyDescription "Capacidad para conocer en profundidad la base teórica de los procesos de la construcción industrializada y del prototipado en el proyecto arquitectónico.Tipo: Competencias"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000950/2025-26/CE5> a ns1:Competency ;
    ns1:competencyCode "CE5" ;
    ns1:competencyDescription "Capacidad para comprender los fundamentos e identificar las variables y sus categorías dentro de los procesos y estrategias de la construcción industrializada y el prototipado en el proyecto arquitectónico.Tipo: Competencias"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000950/2025-26/CE8> a ns1:Competency ;
    ns1:competencyCode "CE8" ;
    ns1:competencyDescription "Capacidad para integrar y aplicar los conocimientos y herramientas adquiridos articulando para la elaboración de proyectos, prototipos arquitectónicos, procesos avanzados y componentes constructivos industrializables.Tipo: Competencias"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000950/2025-26/CT1> a ns1:Competency ;
    ns1:competencyCode "CT1" ;
    ns1:competencyDescription "Capacidad para dinamizar y liderar equipos de trabajo multidisciplinares.Tipo: Habilidades"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000950/2025-26/CT3> a ns1:Competency ;
    ns1:competencyCode "CT3" ;
    ns1:competencyDescription "Capacidad para trabajar individualmente de forma efectiva, organizando y planificando su propio trabajo, de forma independiente o como miembro de un equipo.Tipo: Habilidades"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000950/2025-26/CT6> a ns1:Competency ;
    ns1:competencyCode "CT6" ;
    ns1:competencyDescription "Capacidad para trabajar en contextos internacionales.Tipo: Habilidades"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000950/2025-26/RA1> a ns1:LearningResult ;
    ns1:learningResultCode "RA1" ;
    ns1:learningResultDescription "El alumnado será capaz de incorporar aspectos relativos al clima en el proyecto arquitectónico."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000950/2025-26/RA2> a ns1:LearningResult ;
    ns1:learningResultCode "RA2" ;
    ns1:learningResultDescription "El alumnado será capaz de reconocer en que consisten las distintas áreas de la sostenibilidad y su relación con el proyecto arquitectónico."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000950/2025-26/RA3> a ns1:LearningResult ;
    ns1:learningResultCode "RA3" ;
    ns1:learningResultDescription "El alumnado podrá considerar los condicionantes logísticos en el proyecto arquitectónico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000950/2025-26/RA4> a ns1:LearningResult ;
    ns1:learningResultCode "RA4" ;
    ns1:learningResultDescription "El alumnado conocerá cuales son sus responsabilidades como técnico."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000950/2025-26/RA5> a ns1:LearningResult ;
    ns1:learningResultCode "RA5" ;
    ns1:learningResultDescription "El alumnado conocerá la normativa existente."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000950/2025-26/RA6> a ns1:LearningResult ;
    ns1:learningResultCode "RA6" ;
    ns1:learningResultDescription "El alumnado será capaz de planificar las fases del proyecto."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000950/2025-26/RA7> a ns1:LearningResult ;
    ns1:learningResultCode "RA7" ;
    ns1:learningResultDescription "El alumnado podrá identificar posibles soluciones a patentar."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000950/2025-26/RA8> a ns1:LearningResult ;
