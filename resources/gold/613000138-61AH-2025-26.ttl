    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/613000138/2025-26/eventSchedule> ;
    schema:description """En esta asignatura se trabajará la comprensión de las tecnologías en su inserción en ámbitos sociales, su reglamentación jurídica, y las cuestiones éticas que han planteado, y sobre todo plantean, en la actualidad.
Esta asignatura seguirá un esquema clásico en el cual se avanzará en la comprensión de conceptos más generales hacia aquellos más particulares, persiguiendo obtener una comprensión de la aplicabilidad práctica de cada uno de ellos. Se persigue dotar al estudiantado de herramientas contemporáneas que permitan contextualizar y comprender los orígenes y posibles consecuencias de las tecnologías.
Por ello, esta asignatura está orientada a ofrecer el aparato conceptual imprescindible para incluir en los TFM este abanico de dimensiones."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/aureamaria.angueradesojo%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/aureamaria.angueradesojo%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/sergio.dantonio%40upm.es> ;
    schema:name "Aspectos éticos , Legales y Sociales del Big Data y la Inteligencia Artificial"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000138/2025-26/CB10> a ns1:Competency ;
    ns1:competencyCode "CB10" ;
    ns1:competencyDescription "Que los estudiantes posean las habilidades de aprendizaje que les permitan continuar estudiando de un modo que habrá de ser en gran medida autodirigido o autónomo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000138/2025-26/CB6> a ns1:Competency ;
    ns1:competencyCode "CB6" ;
    ns1:competencyDescription "Poseer y comprender conocimientos que aporten una base u oportunidad de ser originales en el desarrollo y/o aplicación de ideas, a menudo en un contexto de investigación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000138/2025-26/CB7> a ns1:Competency ;
    ns1:competencyCode "CB7" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en entornos nuevos o poco conocidos dentro de contextos más amplios (o multidisciplinares) relacionados con su área de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000138/2025-26/CB8> a ns1:Competency ;
    ns1:competencyCode "CB8" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de integrar conocimientos y enfrentarse a la complejidad de formular juicios a partir de una información que, siendo incompleta o limitada, incluya reflexiones sobre las responsabilidades sociales y éticas vinculadas a la aplicación de sus conocimientos y juicios"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000138/2025-26/CB9> a ns1:Competency ;
    ns1:competencyCode "CB9" ;
    ns1:competencyDescription "Que los estudiantes sepan comunicar sus conclusiones y los conocimientos y razones últimas que las sustentan a públicos especializados y no especializados de un modo claro y sin ambigüedades"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000138/2025-26/CE09> a ns1:Competency ;
    ns1:competencyCode "CE09" ;
    ns1:competencyDescription "Entender y valorar las implicaciones éticas, legales y sociales de la inteligencia artificial, así como la seguridad y privacidad de los datos masivos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000138/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Capacidad para aplicar el método científico y saber organizar y planificar experimentos con rigor metodológico en el ámbito del aprendizaje automático y los datos masivos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000138/2025-26/CG2> a ns1:Competency ;
    ns1:competencyCode "CG2" ;
    ns1:competencyDescription "Participar en la aplicación de mecanismos de descripción, cuantificación, análisis, interpretación y evaluación de resultados experimentales del ámbito de los datos masivos y el aprendizaje automático"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000138/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Capacidad para reunir e interpretar datos masivos relevantes para emitir juicios que incluyan una reflexión sobre temas importantes de índole científico, social o ético en el ámbito del aprendizaje automático y los datos masivos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000138/2025-26/CG4> a ns1:Competency ;
    ns1:competencyCode "CG4" ;
    ns1:competencyDescription "Capacidad de aplicar iniciativa, integración, colaboración y potenciación de la discusión crítica en el ámbito del trabajo en equipo dentro del ámbito del aprendizaje automático y datos masivos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000138/2025-26/CG5> a ns1:Competency ;
    ns1:competencyCode "CG5" ;
    ns1:competencyDescription "Participar en la transmisión de la información generada, las ideas, los problemas y las soluciones de forma oral y escrita para un público tanto especializado como no especializado"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000138/2025-26/CT1> a ns1:Competency ;
    ns1:competencyCode "CT1" ;
    ns1:competencyDescription "Creatividad"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000138/2025-26/CT2> a ns1:Competency ;
    ns1:competencyCode "CT2" ;
    ns1:competencyDescription "Organización y planificación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000138/2025-26/CT3> a ns1:Competency ;
    ns1:competencyCode "CT3" ;
    ns1:competencyDescription "Gestión de la información"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000138/2025-26/CT4> a ns1:Competency ;
    ns1:competencyCode "CT4" ;
    ns1:competencyDescription "Liderazgo de equipos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000138/2025-26/CT5> a ns1:Competency ;
    ns1:competencyCode "CT5" ;
    ns1:competencyDescription "Trabajo en contextos internacionales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000138/2025-26/RA60> a ns1:LearningResult ;
    ns1:learningResultCode "RA60" ;
    ns1:learningResultDescription "Conocer el marco legal europeo y Nacional de la Inteligencia Artificial y el procesamiento y almacenamiento masivo de datos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000138/2025-26/RA61> a ns1:LearningResult ;
    ns1:learningResultCode "RA61" ;
    ns1:learningResultDescription "· Evaluar el impacto social, legal y ético de proyectos de Big Data y aprendizaje automático"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000138/2025-26/RA62> a ns1:LearningResult ;
    ns1:learningResultCode "RA62" ;
    ns1:learningResultDescription "· Comprender el sesgo y los problemas éticos debidos al procesado y gestión de datos mediante algoritmos"@es .

