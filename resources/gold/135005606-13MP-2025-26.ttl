    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/135005606/2025-26/syllabus> ;
    ns1:inpersonHours "42 horas y 45 minutos (52.8%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation "LAS COMPETENCIAS Y LOS RESULTADOS DE APRENDIZAJE DE ESTA ASIGNATURA SON LOS ACORDES CON LA MEMORIA VERIFICA DEL TÍTULO"@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "42 horas y 45 minutos"@es ;
    schema:activitiesWorkload "101%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/135005606/2025-26/eventSchedule> ;
    schema:description """1. Conceptos generales de turismo. La aportación del turismo a la economía española y mundial.
2. El turismo de naturaleza. La interpretación del patrimonio natural y cultural. Productos del turismo de naturaleza. La cuantificación del turismo de naturaleza, oferta y demanda.
3. El turismo activo o de aventura. Productos del turismo activo o de aventura. La caracterización y cuantificación del turismo activo desde la oferta y desde la demanda.
4. El ecoturismo.
5. La regulación de la empresa turística en el medio natural.
6. Iniciativas internacionales y nacionales para la promoción del turismo.
7. El turismo y el desarrollo sostenible. Buenas prácticas para la sostenibilidad del turismo. La certificación de la actividad turística."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/sigfredo.ortuno%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/belen.vazquezdequevedo%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/miguel.aguilar%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/sigfredo.ortuno%40upm.es> ;
    schema:name "Turismo y Ocio en el Medio Natural"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005606/2025-26/CB04> a ns1:Competency ;
    ns1:competencyCode "CB04" ;
    ns1:competencyDescription "Que los estudiantes puedan transmitir información, ideas, problemas y soluciones a un público tanto especializado como no especializado"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005606/2025-26/CE%201.03> a ns1:Competency ;
    ns1:competencyCode "CE 1.03" ;
    ns1:competencyDescription "Formalización y especificación de problemas reales de gestión del Medio Natural cuya solución requiere de aplicaciones de Ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005606/2025-26/CE%202.05> a ns1:Competency ;
    ns1:competencyCode "CE 2.05" ;
    ns1:competencyDescription "Conocer las características técnicas de las distintas infraestructuras susceptibles de ser implementadas en el Medio Natural: (energéticas, informáticas, habitacionales, de investigación, viarias, de telecomunicación, de servicios turísticos...)"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005606/2025-26/CE%202.17> a ns1:Competency ;
    ns1:competencyCode "CE 2.17" ;
    ns1:competencyDescription "Conocer el concepto y tipología de turismo y ocio en el Medio Natural. Planificar territorialmente las actividades de turismo y ocio en espacios naturales. Diseñar instalaciones de turismo y ocio en espacios naturales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005606/2025-26/CG15> a ns1:Competency ;
    ns1:competencyCode "CG15" ;
    ns1:competencyDescription "Concebir, planificar, organizar y coordinar las actividades educativas, de turismo y de ocio en el Medio Natural"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005606/2025-26/CT03> a ns1:Competency ;
    ns1:competencyCode "CT03" ;
    ns1:competencyDescription "Transmitir conocimientos y expresar ideas y argumentos de manera clara, rigurosa y convincente, tanto de forma oral como escrita, utilizando adecuadamente los recursos gráficos y los medios necesarios y adaptándose a las características de la situación y de la audiencia."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005606/2025-26/CT05> a ns1:Competency ;
    ns1:competencyCode "CT05" ;
    ns1:competencyDescription "Proponer alternativas creativas y originales, valorando su viabilidad en la solución de problemas en el ámbito de la ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005606/2025-26/RA224> a ns1:LearningResult ;
    ns1:learningResultCode "RA224" ;
    ns1:learningResultDescription "Conocer la importancia del turismo como actividad económica, cultural y social a nivel mundial"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005606/2025-26/RA225> a ns1:LearningResult ;
    ns1:learningResultCode "RA225" ;
    ns1:learningResultDescription "Conocer la aportación del turismo a la economía española"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005606/2025-26/RA226> a ns1:LearningResult ;
    ns1:learningResultCode "RA226" ;
    ns1:learningResultDescription "Conocer las principales características de las corrientes turísticas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005606/2025-26/RA227> a ns1:LearningResult ;
    ns1:learningResultCode "RA227" ;
    ns1:learningResultDescription "Conocer la relación entre turismo y desarrollo sostenible, así como el concpeto de ecoturismo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005606/2025-26/RA228> a ns1:LearningResult ;
    ns1:learningResultCode "RA228" ;
    ns1:learningResultDescription "Conocer las principales iniciativas adoptadas por instituciones internacionales para la promoción el turismo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005606/2025-26/RA229> a ns1:LearningResult ;
    ns1:learningResultCode "RA229" ;
    ns1:learningResultDescription "Conocer la regulación de la actividad turística en la normativa de conservación del patrimonio natural"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005606/2025-26/RA230> a ns1:LearningResult ;
    ns1:learningResultCode "RA230" ;
    ns1:learningResultDescription "Conocer los aspectos empresariales del turismo de aventura o de naturaleza"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005606/2025-26/RA231> a ns1:LearningResult ;
    ns1:learningResultCode "RA231" ;
    ns1:learningResultDescription "Conocer los fundamentos de la interpretación del patrimonio natural y cultural"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005606/2025-26/RA232> a ns1:LearningResult ;
    ns1:learningResultCode "RA232" ;
    ns1:learningResultDescription "Capacitar para explicar en profundidad los diferentes valores presentes en el medio natural"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005606/2025-26/RA233> a ns1:LearningResult ;
    ns1:learningResultCode "RA233" ;
    ns1:learningResultDescription "Familiarizarse con el manejo de técnicas interpretativas y expositivas aplicadas al medio natural"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005606/2025-26/didactic_resource/1> a ns1:DidacticResource ;
