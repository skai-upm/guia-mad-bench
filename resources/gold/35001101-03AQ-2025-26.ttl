<https://guia-kg.skai.etsisi.upm.es/resource/35001101/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Sistemas de representación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35001101/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Conceptos generales. Proyección plana, tipos e invariantes. Sistemas de representación, aproximación histórica. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35001101/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "4.2. Restitución de una perspectiva para obtener medidas del modelo representado y reconstruir la posición original del punto de vista y dirección principal. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35001101/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "5. Terrenos y cubiertas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35001101/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "5.1. Fundamentos del Sistema Acotado Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35001101/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "5.2. Terrenos. Definición de superficie topográfica. Interpretación de curvas de nivel. Trazado de perfiles y caminos de pendiente limitada. Trazado de explanaciones horizontales y viales rectos: control de taludes de desmonte y terraplén. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35001101/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "5.3. Cubiertas inclinadas. Pendientes iguales o distintas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35001101/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "6. Esfera"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35001101/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "6.1. Representación de la circunferencia en proyección cilíndrica Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35001101/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "6.2. Contorno aparente de la esfera, situación de puntos y secciones de esferas Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35001101/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "6.3. Tipos de bóvedas que contienen superficies esféricas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35001101/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "7. Conos, cilindros"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35001101/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "2. Axonometría"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35001101/2025-26/syllabus/20> a ns1:SyllabusItem ;
    ns1:itemIndex 20 ;
    ns1:syllabusDescription "7.1. Contorno aparente y situación de puntos Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35001101/2025-26/syllabus/21> a ns1:SyllabusItem ;
    ns1:itemIndex 21 ;
    ns1:syllabusDescription "7.2. Control de proyecciones, reconociendo sus propiedades geométricas y constructivas de bóvedas de arista, rincón, lunetos, vaídas, pechinas Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35001101/2025-26/syllabus/22> a ns1:SyllabusItem ;
    ns1:itemIndex 22 ;
    ns1:syllabusDescription "7.3. Identificación en arquitectura de bóvedas de arista, rincón, lunetos, vaídas, pechinas Sin subniveles"@es .

