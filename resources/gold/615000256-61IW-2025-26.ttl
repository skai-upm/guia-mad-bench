    schema:name "Bases de Datos Avanzadas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000256/2025-26/CC12> a ns1:Competency ;
    ns1:competencyCode "CC12" ;
    ns1:competencyDescription "Conocimiento y aplicación de las características, funcionalidades y estructura de las bases de datos, que permitan su adecuado uso, y el diseño y el análisis e implementación de aplicaciones basadas en ellos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000256/2025-26/CC13> a ns1:Competency ;
    ns1:competencyCode "CC13" ;
    ns1:competencyDescription "Conocimiento y aplicación de las herramientas necesarias para el almacenamiento, procesamiento y acceso a los Sistemas de información, incluidos los basados en web."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000256/2025-26/CC7> a ns1:Competency ;
    ns1:competencyCode "CC7" ;
    ns1:competencyDescription "Conocimiento, diseño y utilización de forma eficiente los tipos y estructuras de datos más adecuados a la resolución de un problema"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000256/2025-26/CE4> a ns1:Competency ;
    ns1:competencyCode "CE4" ;
    ns1:competencyDescription "Capacidad de identificar y analizar problemas y diseñar, desarrollar, implementar, verificar y documentar soluciones software sobre la base de un conocimiento adecuado de las teorías, modelos y técnicas actuales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000256/2025-26/CT1> a ns1:Competency ;
    ns1:competencyCode "CT1" ;
    ns1:competencyDescription "Análisis y síntesis: Descomponer la información en unidades más pequeñas separando los componentes fundamentales de los no relevantes e identificando las relaciones existentes entre ellos. Síntesis: Combinar información para construir un todo a partir de las entidades previamente analizadas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000256/2025-26/RA120> a ns1:LearningResult ;
    ns1:learningResultCode "RA120" ;
    ns1:learningResultDescription "Analiza y sintetiza la información relacionada con el diseño de una base de datos relacional produciendo esquemas de relación correctos aplicando las técnicas, métodos y algoritmos definidos en el modelo relacional de datos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000256/2025-26/RA121> a ns1:LearningResult ;
    ns1:learningResultCode "RA121" ;
    ns1:learningResultDescription "Conoce la estructura de los modelos de datos semiestructurados como XML y demuestra capacidades para el diseño de este modelo de datos y para la expresión de consultas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000256/2025-26/RA122> a ns1:LearningResult ;
    ns1:learningResultCode "RA122" ;
    ns1:learningResultDescription "Conoce los modelos de datos llamados no relacionales, o no sql, demostrando capacidades para su diseño y acceso a datos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000256/2025-26/RA123> a ns1:LearningResult ;
    ns1:learningResultCode "RA123" ;
    ns1:learningResultDescription "Comprende el papel de las bases de datos en la arquitectura de sistema de información y los tipos diferentes de arquitecturas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000256/2025-26/RA124> a ns1:LearningResult ;
    ns1:learningResultCode "RA124" ;
    ns1:learningResultDescription "Conoce los conceptos básicos para el diseño de almacenes de datos y la gestión del conocimiento a partir de ellos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000256/2025-26/RA125> a ns1:LearningResult ;
    ns1:learningResultCode "RA125" ;
    ns1:learningResultDescription "Comprende los conceptos básicos de la administración de datos y de bases de datos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000256/2025-26/RA126> a ns1:LearningResult ;
    ns1:learningResultCode "RA126" ;
    ns1:learningResultDescription "Conoce las tendencias actuales de los modelos de bases de datos y la utilización de los mismos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000256/2025-26/RA248> a ns1:LearningResult ;
    ns1:learningResultCode "RA248" ;
    ns1:learningResultDescription "Conoce y desarrolla adecuadamente soluciones con aspectos avanzados de SQL y optimización de accesos a base de datos relacionales."@es .

