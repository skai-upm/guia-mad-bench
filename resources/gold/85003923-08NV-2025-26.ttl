<https://guia-kg.skai.etsisi.upm.es/resource/85003923/2025-26/CB2> a ns1:Competency ;
    ns1:competencyCode "CB2" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar sus conocimientos a su trabajo o vocación de una forma profesional y posean las competencias que suelen demostrarse por medio de la elaboración y defensa de argumentos y la resolución de problemas dentro de su área de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003923/2025-26/CB5> a ns1:Competency ;
    ns1:competencyCode "CB5" ;
    ns1:competencyDescription "Que los estudiantes hayan desarrollado aquellas habilidades de aprendizaje necesarias para emprender estudios posteriores con un alto grado de autonomía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003923/2025-26/CE%2012> a ns1:Competency ;
    ns1:competencyCode "CE 12" ;
    ns1:competencyDescription "Conocimiento de la elasticidad y resistencia de materiales y capacidad para realizar cálculos de elementos sometidos a solicitaciones diversas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003923/2025-26/CE%2013> a ns1:Competency ;
    ns1:competencyCode "CE 13" ;
    ns1:competencyDescription "Conocimiento de la mecánica y de los componentes de maquinas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003923/2025-26/CE%208> a ns1:Competency ;
    ns1:competencyCode "CE 8" ;
    ns1:competencyDescription "Conocimiento de la ciencia y tecnología de materiales y capacidad para su selección y para la evaluación de su comportamiento."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003923/2025-26/RA11> a ns1:LearningResult ;
    ns1:learningResultCode "RA11" ;
    ns1:learningResultDescription "Conocer el significado y las unidades de las magnitudes físicas, así como su orden de magnitud y resolver problemas básicos de ingeniería, expresando el resultado numérico en las unidades físicas correspondientes."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003923/2025-26/RA115> a ns1:LearningResult ;
    ns1:learningResultCode "RA115" ;
    ns1:learningResultDescription "Redactar informes técnicos y resúmenes ejecutivos bien estructurados"@es .

