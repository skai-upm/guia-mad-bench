    ns1:learningResultCode "RA121" ;
    ns1:learningResultDescription "Conocer la documentación, materiales, medios de producción, procesos y tecnologías empleadas en las distintas fases de la construcción"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003923/2025-26/RA125> a ns1:LearningResult ;
    ns1:learningResultCode "RA125" ;
    ns1:learningResultDescription "Conocer los métodos más relevantes aplicados en la mejora de los procesos y los modelos de simulación de los procesos constructivos."@es .

