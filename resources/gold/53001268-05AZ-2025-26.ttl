    schema:name "Comportamiento en Servicio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001268/2025-26/%28a%29> a ns1:Competency ;
    ns1:competencyCode "(a)" ;
    ns1:competencyDescription "APLICA. Habilidad para aplicar conocimientos científicos, matemáticos y tecnológicos en sistemas relacionados con la práctica de la ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001268/2025-26/%28e%29> a ns1:Competency ;
    ns1:competencyCode "(e)" ;
    ns1:competencyDescription "RESUELVE. Habilidad para identificar, formular y resolver problemas de ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001268/2025-26/%28g%29> a ns1:Competency ;
    ns1:competencyCode "(g)" ;
    ns1:competencyDescription "COMUNICA. Habilidad para comunicar eficazmente."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001268/2025-26/RA103> a ns1:LearningResult ;
    ns1:learningResultCode "RA103" ;
    ns1:learningResultDescription "Profundizar en el conocimiento de los materiales que se emplean en la construcción sus cualidades, su forma de funcionamiento, sus características habituales en el análisis de las estructuras, sus ventajas e inconvenientes."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001268/2025-26/RA127> a ns1:LearningResult ;
    ns1:learningResultCode "RA127" ;
    ns1:learningResultDescription "El alumno es capaz de organizar y dirigir su aprendizaje de forma autónoma para ampliar sus conocimientos en una materia."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001268/2025-26/RA46> a ns1:LearningResult ;
    ns1:learningResultCode "RA46" ;
    ns1:learningResultDescription "Capacidad de comprender lo que significa una inspección y control de calidad y de analizar los resultados"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001268/2025-26/RA80> a ns1:LearningResult ;
    ns1:learningResultCode "RA80" ;
    ns1:learningResultDescription "El alumno es capaz de experimentar, examinar y analizar de forma práctica las propiedades o comportamientos de un componente o sistema. Poseerá la habilidad de descubrir determinados fenómenos o principios científicos y comprobará una o varias hipótesis relacionadas con el comportamiento de un fenómeno."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001268/2025-26/RA83> a ns1:LearningResult ;
    ns1:learningResultCode "RA83" ;
    ns1:learningResultDescription "El alumno ampliará sus destrezas comunicativas, entiendo éstas, como la capacidad para transmitir conocimientos, expresar ideas y argumentos de manera clara, rigurosa y convincente, tanto de forma oral como escrita, utilizando los recursos gráficos y los medios necesarios."@es .

