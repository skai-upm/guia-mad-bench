<https://guia-kg.skai.etsisi.upm.es/resource/45001409/2025-26/CM37.1> a ns1:Competency ;
    ns1:competencyCode "CM37.1" ;
    ns1:competencyDescription "Conocimiento y capacidad para proyectar y dimensionar obras e instalaciones hidráulicas, sistemas energéticos, aprovechamientos hidroeléctricos y planificación y gestión de recursos hidráulicos superficiales y subterráneos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001409/2025-26/CM37.4> a ns1:Competency ;
    ns1:competencyCode "CM37.4" ;
    ns1:competencyDescription "Comprensión del fundamento y de los sistemas de utilización de las energías renovables."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001409/2025-26/CT2> a ns1:Competency ;
    ns1:competencyCode "CT2" ;
    ns1:competencyDescription "Capacidad de organizar y dirigir los esfuerzos de un grupo humano reducido y homogéneo. Desarrolla la competencia transversal 8ª de la normativa UPM."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001409/2025-26/CT3> a ns1:Competency ;
    ns1:competencyCode "CT3" ;
    ns1:competencyDescription "Capacidad de actuar con efectividad como miembro de equipos interdisciplinares. Desarrolla la competencia transversal 5ª de la normativa UPM."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001409/2025-26/CT6> a ns1:Competency ;
    ns1:competencyCode "CT6" ;
    ns1:competencyDescription "Compromiso y capacidad de aplicación de los estándares de deontología profesional."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001409/2025-26/RA91> a ns1:LearningResult ;
    ns1:learningResultCode "RA91" ;
    ns1:learningResultDescription "Interioriza los principios de deontología profesional de ingeniería civil."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001409/2025-26/RA92> a ns1:LearningResult ;
    ns1:learningResultCode "RA92" ;
    ns1:learningResultDescription "Proyecta y dimensiona sistemas energéticos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001409/2025-26/RA93> a ns1:LearningResult ;
    ns1:learningResultCode "RA93" ;
    ns1:learningResultDescription "Proyecta y dimensiona aprovechamientos hidroeléctricos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001409/2025-26/RA95> a ns1:LearningResult ;
    ns1:learningResultCode "RA95" ;
    ns1:learningResultDescription "Explica el fundamento y los sistemas de utilización de las energías renovables."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001409/2025-26/RA99> a ns1:LearningResult ;
    ns1:learningResultCode "RA99" ;
    ns1:learningResultDescription "Valora los efectos social, económico, ambiental, político y globalizador de las infraestructuras hidráulicas y energéticas."@es .

