<https://guia-kg.skai.etsisi.upm.es/resource/145009009/2025-26/CE43> a ns1:Competency ;
    ns1:competencyCode "CE43" ;
    ns1:competencyDescription "Conocimiento adecuado y aplicado a la Ingeniería de: Los fundamentos de sostenibilidad, mantenibilidad y operatividad de los sistemas espaciales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145009009/2025-26/CE54> a ns1:Competency ;
    ns1:competencyCode "CE54" ;
    ns1:competencyDescription "Conocimiento adecuado y aplicado de la Mecánica Orbital de vehículos espaciales (Astrodinámica), incluyendo conceptos preliminares de su Dinámica de Actitud"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145009009/2025-26/RA126> a ns1:LearningResult ;
    ns1:learningResultCode "RA126" ;
    ns1:learningResultDescription "Conocimiento, comprensión, aplicación, análisis y síntesis de los sistemas embarcados en las aeronaves y vehículos espaciales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145009009/2025-26/RA45> a ns1:LearningResult ;
    ns1:learningResultCode "RA45" ;
    ns1:learningResultDescription "Conocimiento, comprensión y aplicación de los fundamentos del vuelo orbital de los vehículos espaciales."@es .

