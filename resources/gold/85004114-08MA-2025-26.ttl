    ns1:inpersonHours "84 horas y 50 minutos (52.4%)"@es ;
    ns1:numberOfCredits 6.0 ;
    ns1:otherInformation "La asignatura se relaciona con el ODS 13 y 14"@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "88 horas y 50 minutos"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/85004114/2025-26/eventSchedule> ;
    schema:description "La aignatura de Química trata de homogeneizar los conocimientos que los alumnos han adquirido a su paso por la ESO y el bachillerato, de forma que al completar el curso, tenga suficientes conocimientos de las partes de la Química que van a necesitar para posteriores estudios en los siguientes cursos de su carrera. Estados de la materia, disoluciones, calor y equilibrio, acido base, precipitación, redox, electroquímica y corrosión sin perder de vista, la estequiometría química. Para ello se hace uso de teoría, problemas, casos prácticos y prácticas de laboratorio."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/mamartin.rengel%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/mamartin.rengel%40upm.es> ;
    schema:name "Química"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85004114/2025-26/CE3> a ns1:Competency ;
    ns1:competencyCode "CE3" ;
    ns1:competencyDescription "Conocimientos básicos de la química general, química orgánica e inorgánica y sus aplicaciones en la ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85004114/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Capacidad para el aprendizaje de nuevos métodos y teorías, y en la versatilidad para adaptarse a nuevas situaciones basándose en los conocimientos adquiridos en materias básicas y tecnológicas propias de la Ingeniería Marítima."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85004114/2025-26/RA34> a ns1:LearningResult ;
    ns1:learningResultCode "RA34" ;
    ns1:learningResultDescription "Conocer la estructura de la materia y manejar sus elementos descriptivos en su aplicación a las tareas de ingeniero"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85004114/2025-26/RA35> a ns1:LearningResult ;
    ns1:learningResultCode "RA35" ;
    ns1:learningResultDescription "Conocer los sistemas químicos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85004114/2025-26/RA36> a ns1:LearningResult ;
    ns1:learningResultCode "RA36" ;
    ns1:learningResultDescription "Conocer y comprender los sistemas químicos de aplicación más directa al área de competencia de la ingeniería naval en todas sus vertientes"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85004114/2025-26/RA37> a ns1:LearningResult ;
    ns1:learningResultCode "RA37" ;
    ns1:learningResultDescription "Conocer el mecanismo de la corrosión y su importancia en el ámbito naval."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85004114/2025-26/RA38> a ns1:LearningResult ;
    ns1:learningResultCode "RA38" ;
    ns1:learningResultDescription "Comprender y manejar los sistemas de prevención y lucha contra la corrosión marina."@es .

