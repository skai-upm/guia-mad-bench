    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/103000379/2025-26/syllabus> ;
    ns1:inpersonHours "47 horas y 30 minutos (45.7%)"@es ;
    ns1:numberOfCredits 4.0 ;
    ns1:otherInformation """En la asignatura se implementa la siguiente metodología docente innovadora (https://innovacioneducativa.upm.es/guias-pdi) con el fin de motivar y reforzar el aprendizaje por parte del estudiantado:
Aprendizaje orientado a proyectos: La evaluación de la asignatura incluye la realización de un proyecto, relativo a la planificación de un experimento real en el ámbito de la Ingeniería del Software."""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "69 horas y 30 minutos"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/103000379/2025-26/eventSchedule> ;
    schema:description """Software Engineering technologies are not being adequately evaluated. That is, professionals do not know for sure whether a technology is effective or not and, if so, cannot be sure how effective and applicable it is. This lack of proper evaluation undermines the ability of the industry to produce competitive quality software.
Experimental Software Engineering (ESE) is a discipline of Software Engineering that aims to produce reliable information for professionals about what technologies should be used in software development projects. ESE uses empirical studies (experiments, quasi-experiments, case studies, etc.) to evaluate the effectiveness of technologies for software development."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/sira.vegas%40upm.es> ;
    schema:inLanguage "Inglés/Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/natalia.juristo%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/sira.vegas%40upm.es> ;
    schema:name "Experimentacion en Ingenieria del Software"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000379/2025-26/CEM1> a ns1:Competency ;
    ns1:competencyCode "CEM1" ;
    ns1:competencyDescription "Identificar, a partir del estado de la cuestión, la presencia de problemas de investigación relacionados con la concepción, la construcción, el uso y la evaluación de sistemas sociotécnicos complejos que hagan un uso intensivo de software"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000379/2025-26/CEM3> a ns1:Competency ;
    ns1:competencyCode "CEM3" ;
    ns1:competencyDescription "Aplicar métodos de investigación relevantes a problemas abiertos en el área de la Ingeniería del Software, relacionados tanto con las características peculiares del producto software como con la gestión del desarrollo del mismo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000379/2025-26/CG12> a ns1:Competency ;
    ns1:competencyCode "CG12" ;
    ns1:competencyDescription "Comprensión amplia de las técnicas y métodos aplicables en una especialización concreta, así como de sus límites"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000379/2025-26/CG13> a ns1:Competency ;
    ns1:competencyCode "CG13" ;
    ns1:competencyDescription "Apreciación de los límites del conocimiento actual y de la aplicación práctica de la tecnología más reciente."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000379/2025-26/CG14> a ns1:Competency ;
    ns1:competencyCode "CG14" ;
    ns1:competencyDescription "Conocimiento y comprensión de la informática necesaria para la creación de modelos de información, y de los sistemas y procesos complejos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000379/2025-26/CG17> a ns1:Competency ;
    ns1:competencyCode "CG17" ;
    ns1:competencyDescription "Habilidades de gestión y capacidad de liderar un equipo que puede estar integrado por disciplinas y niveles distintos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000379/2025-26/CG4> a ns1:Competency ;
    ns1:competencyCode "CG4" ;
    ns1:competencyDescription "Que los estudiantes posean las habilidades de aprendizaje que les permitan continuar estudiando de un modo que habrá de ser en gran medida autodirigido o autónomo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000379/2025-26/CG7> a ns1:Competency ;
    ns1:competencyCode "CG7" ;
    ns1:competencyDescription "Especificación y realización de tareas informáticas complejas, poco definidas o no familiares"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000379/2025-26/CG8> a ns1:Competency ;
    ns1:competencyCode "CG8" ;
    ns1:competencyDescription "Planteamiento y resolución de problemas también en áreas nuevas y emergentes de su disciplina"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000379/2025-26/CG9> a ns1:Competency ;
    ns1:competencyCode "CG9" ;
    ns1:competencyDescription "Aplicación de los métodos de resolución de problemas más recientes o innovadores y que puedan implicar el uso de otras disciplinas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000379/2025-26/CGI20> a ns1:Competency ;
    ns1:competencyCode "CGI20" ;
    ns1:competencyDescription "Adquirir conocimientos científicos avanzados del campo de la informática que le permitan generar nuevas ideas dentro de una línea de investigación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000379/2025-26/CGI23> a ns1:Competency ;
    ns1:competencyCode "CGI23" ;
    ns1:competencyDescription "Capacidad de leer y comprender publicaciones dentro de su ámbito de estudio/investigación, así como su catalogación y valor científico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000379/2025-26/RA23> a ns1:LearningResult ;
    ns1:learningResultCode "RA23" ;
    ns1:learningResultDescription "Comprender la aplicación del paradigma experimental en ingeniería del software"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000379/2025-26/RA24> a ns1:LearningResult ;
    ns1:learningResultCode "RA24" ;
    ns1:learningResultDescription "Diseñar experimentos en ingeniería del software, incluyendo replicaciones experimentales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000379/2025-26/RA35> a ns1:LearningResult ;
    ns1:learningResultCode "RA35" ;
    ns1:learningResultDescription "Realizar agregaciones de experimentos en ingeniería del software"@es .

