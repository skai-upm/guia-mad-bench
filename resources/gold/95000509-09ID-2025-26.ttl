<https://guia-kg.skai.etsisi.upm.es/resource/95000509/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Presentación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000509/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Presentación de motivación, objetivos, programa, metodología, métodos de evaluación y bibliografía básica Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000509/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "3.1. La sinusoide compleja y los sistemas SLI. Concepto de autofunción y de respuesta en frecuencia. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000509/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "3.2. Definición de las Series de Fourier (SF) de señales periódicas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000509/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "3.3. Definición de la Transformada de Fourier (TF) y condiciones de existencia. TF generalizada de señales periódicas y relación con SF. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000509/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "3.4. Propiedades de la TF. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000509/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "3.5. Aplicaciones de la transformada de Fourier al análisis de señales y sistemas: Filtrado Ideal; Enventanado (Resolución temporal y frecuencial). Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000509/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "3.6. Problemas resumen tema 3. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000509/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "4. Análisis en el dominio temporal de secuencias y sistemas de tiempo discreto."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000509/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "4.1. Definición de secuencia, operaciones y parámetros (energía, potencia, periodo). Secuencias básicas: sinusoidal, exponencial, impulso unitario, escalón. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000509/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "4.2. Conceptos generales sobre sistemas en tiempo discreto: Definición, Asociación de sistemas (serie y paralelo) y propiedades de los sistemas (invertibilidad, estabilidad, linealidad e invariancia temporal). Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000509/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "4.3. Caracterización de sistemas SLI en tiempo continuo mediante la respuesta al impulso: Suma de convolución y propiedades del operador de convolución. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000509/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Repaso a conceptos básicos de cálculo (funciones complejas, series, integrales propias e impropias, ...). Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000509/2025-26/syllabus/20> a ns1:SyllabusItem ;
    ns1:itemIndex 20 ;
    ns1:syllabusDescription "4.4. Problemas resumen tema 5. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000509/2025-26/syllabus/21> a ns1:SyllabusItem ;
    ns1:itemIndex 21 ;
    ns1:syllabusDescription "4.5. Implementación práctica en Python. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000509/2025-26/syllabus/22> a ns1:SyllabusItem ;
    ns1:itemIndex 22 ;
    ns1:syllabusDescription "5. Análisis en el dominio de la frecuencia de secuencias y sistemas de tiempo discreto."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000509/2025-26/syllabus/23> a ns1:SyllabusItem ;
    ns1:itemIndex 23 ;
    ns1:syllabusDescription "5.1. La sinusoide compleja discreta y los sistemas SLI. Concepto de autofunción y de respuesta en frecuencia. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000509/2025-26/syllabus/24> a ns1:SyllabusItem ;
    ns1:itemIndex 24 ;
    ns1:syllabusDescription "5.2. Definición de las Series de Fourier (SF) de secuencias periódicas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000509/2025-26/syllabus/25> a ns1:SyllabusItem ;
    ns1:itemIndex 25 ;
    ns1:syllabusDescription "5.3. Definición de la Transformada de Fourier (TF) de secuencias y condiciones de existencia. TF generalizada de secuencias periódicas y relación con SF. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000509/2025-26/syllabus/26> a ns1:SyllabusItem ;
    ns1:itemIndex 26 ;
    ns1:syllabusDescription "5.4. Aplicaciones de la transformada de Fourier al análisis de señales y sistemas: Filtrado Ideal; Enventanado (Resolución temporal y frecuencial) Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000509/2025-26/syllabus/27> a ns1:SyllabusItem ;
    ns1:itemIndex 27 ;
    ns1:syllabusDescription "5.5. Problemas resumen tema 5. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000509/2025-26/syllabus/28> a ns1:SyllabusItem ;
    ns1:itemIndex 28 ;
    ns1:syllabusDescription "6. Muestreo e Introducción al Análisis Digital de Señal"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000509/2025-26/syllabus/29> a ns1:SyllabusItem ;
    ns1:itemIndex 29 ;
    ns1:syllabusDescription "6.1. Muestreo ideal en el dominio temporal. Definición de muestreo ideal. Solapamiento espectral y Condición de Nyquist. Reconstrucción ideal de banda limitada. Interpolación temporal. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000509/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "2. Análisis en el dominio temporal de señales y sistemas de tiempo continuo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000509/2025-26/syllabus/30> a ns1:SyllabusItem ;
    ns1:itemIndex 30 ;
    ns1:syllabusDescription "6.2. Interpolación y diezmado. Definición. Efectos en la TF de secuencias. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000509/2025-26/syllabus/31> a ns1:SyllabusItem ;
    ns1:itemIndex 31 ;
    ns1:syllabusDescription "6.3. Discrete Fourier Transform (DFT): Definición; Relación con las Series de Fourier de secuencias; Interpretación física (muestreo en frecuencia). Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000509/2025-26/syllabus/32> a ns1:SyllabusItem ;
    ns1:itemIndex 32 ;
    ns1:syllabusDescription "6.4. Problemas resumen tema 6. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000509/2025-26/syllabus/33> a ns1:SyllabusItem ;
    ns1:itemIndex 33 ;
    ns1:syllabusDescription "6.5. Implementación práctica en Python. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000509/2025-26/syllabus/34> a ns1:SyllabusItem ;
    ns1:itemIndex 34 ;
    ns1:syllabusDescription "7. Introducción al Procesado Digital de Señal."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000509/2025-26/syllabus/35> a ns1:SyllabusItem ;
    ns1:itemIndex 35 ;
    ns1:syllabusDescription "7.1. Simulación en tiempo discreto de sistemas en tiempo continuo. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000509/2025-26/syllabus/36> a ns1:SyllabusItem ;
    ns1:itemIndex 36 ;
    ns1:syllabusDescription "7.2. Sistemas descritos por ecuaciones en diferencias. Filtros reales (FIR y IIR). Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000509/2025-26/syllabus/37> a ns1:SyllabusItem ;
    ns1:itemIndex 37 ;
    ns1:syllabusDescription "7.3. Introducción a la transformada Z (y definición de Transformada de Laplace). Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000509/2025-26/syllabus/38> a ns1:SyllabusItem ;
    ns1:itemIndex 38 ;
    ns1:syllabusDescription "7.4. Análisis de sistemas descritos por ecuaciones en diferencias utilizando la Transformada Z (diagramas polo-cero, invertibilidad y estabilidad). Sistema Inverso. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000509/2025-26/syllabus/39> a ns1:SyllabusItem ;
    ns1:itemIndex 39 ;
    ns1:syllabusDescription "7.5. Filtrado rápido usando DFT (FFT). Método overlapp-add; Método overlap-save. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000509/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "2.1. Definición de señal continua, operaciones y parámetros (energía, potencia, periodo). Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000509/2025-26/syllabus/40> a ns1:SyllabusItem ;
    ns1:itemIndex 40 ;
    ns1:syllabusDescription "7.6. Problemas resumen tema 7. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000509/2025-26/syllabus/41> a ns1:SyllabusItem ;
    ns1:itemIndex 41 ;
    ns1:syllabusDescription "7.7. Implementación práctica en Python. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000509/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "2.2. Señales básicas: sinusoidal, exponencial, impulso unitario, escalón. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000509/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "2.3. Conceptos generales sobre sistemas en tiempo continuo: Definición, asociación de sistemas (serie y paralelo) y propiedades de los sistemas (invertibilidad, estabilidad, linealidad e invariancia temporal). Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000509/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "2.4. Caracterización de sistemas SLI en tiempo continuo mediante la respuesta al impulso: Integral de convolución y propiedades del operador de convolución. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000509/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "2.5. Problemas resumen tema 2. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000509/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "3. Análisis en el dominio de la frecuencia de señales y sistemas de tiempo continuo."@es .

