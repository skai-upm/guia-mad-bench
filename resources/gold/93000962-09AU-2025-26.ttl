    schema:courseCode 93000962 ;
    schema:hasCourseInstance <https://guia-kg.skai.etsisi.upm.es/resource/93000962/2025-26> ;
    schema:name "Biomedical Engineering Research And Development Pr"@en,
        "Proyectos de Investigación y Desarrollo de Ib"@es ;
    schema:numberOfCredits 3.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/93000962/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/93000962/2025-26/CB06>,
        <https://guia-kg.skai.etsisi.upm.es/resource/93000962/2025-26/CB07>,
