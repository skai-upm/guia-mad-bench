    ns1:learningResultCode "RA5" ;
    ns1:learningResultDescription "To know what sensor types are present in a modern mobile terminal, together with their applicability in IoT environments"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/593000502/2025-26/RA6> a ns1:LearningResult ;
