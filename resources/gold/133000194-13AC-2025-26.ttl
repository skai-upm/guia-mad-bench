<https://guia-kg.skai.etsisi.upm.es/resource/133000194/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Tema 1. Servicios ecosistémicos y capital natural."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000194/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Externalidades y capital natural. Tipos de capitales (físico, natural, humano, etc.). Biodiversidad, recursos y servicios ecosistémicos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000194/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "4.1. Análisis de ciclo de vida. Modelos gerenciales sostenibles. Corrección y compensación ambiental eficiente. Certificación de gestión sostenible (FSC, GFS, etc.). Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000194/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "4.2. Big data, toma de decisiones, heurísticos en decisiones medioambientales, e inteligencia artificial. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000194/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "5. Tema 5. Gobernanza y participación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000194/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "5.1. Principio de subsidiariedad y multiescalaridad en la UE. Participación ciudadana en gestión ambiental (Convenio de Aarhus, etc.). ONGs medioambientales, activismo, ecologismo, greenwashing, capitalismo woke. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000194/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "5.2. Empresas EGS (Environmental, Social and Governance). Gobernanza colaborativa y transfronterizas (ej. Pirineos). Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000194/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "6. Tema 6. Contabilidad del capital natural (CCN)."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000194/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "6.1. Propiedad y derechos sobre el capital natural. Contabilidad Ambiental y Económica (SEEA). PIB, Índice de Capital Natural (ICN), y bienestar humano. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000194/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "6.2. Impuestos ambientales, y mercados de carbono, huella y deuda de capital natural. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000194/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "7. Tema 7. Política y legislación medioambiental."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000194/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "7.1. Estrategias nacionales e internacionales, planificación adaptativa. CITES (Convención sobre el Comercio Internacional de Especies Amenazadas de Fauna y Flora Silvestres). Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000194/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Clasificación CICES. Indicadores europeos: MAES (Mapping and Asessment of Ecosystems and their Services). Tipos de capital natural (renovable, no renovable, recuperable, cultivada). Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000194/2025-26/syllabus/20> a ns1:SyllabusItem ;
    ns1:itemIndex 20 ;
    ns1:syllabusDescription "7.2. Directivas europeas (Marco del Agua, Hábitat, Aves.) Ley del Clima Europea. Leyes y normativas medioambientales. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000194/2025-26/syllabus/21> a ns1:SyllabusItem ;
    ns1:itemIndex 21 ;
    ns1:syllabusDescription "8. Tema 8. Gestión de los servicios hídricos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000194/2025-26/syllabus/22> a ns1:SyllabusItem ;
    ns1:itemIndex 22 ;
    ns1:syllabusDescription "8.1. Explotación de ríos, lagos y acuíferos. Gestión de cuencas hidrográficas (explotación, regadíos, control de erosión y avenidas, y zonas inundables). Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000194/2025-26/syllabus/23> a ns1:SyllabusItem ;
    ns1:itemIndex 23 ;
    ns1:syllabusDescription "8.2. Monitorización (bioindicadores). Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000194/2025-26/syllabus/24> a ns1:SyllabusItem ;
    ns1:itemIndex 24 ;
    ns1:syllabusDescription "9. Tema 9. Gestión del capital natural terrestre."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000194/2025-26/syllabus/25> a ns1:SyllabusItem ;
    ns1:itemIndex 25 ;
    ns1:syllabusDescription "9.1. Manejo de bosques, explotaciones forestales, pastos, explotaciones agrícolas, carboneo. Gestión de plagas y enfermedades forestales, explotación de minas y turberas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000194/2025-26/syllabus/26> a ns1:SyllabusItem ;
    ns1:itemIndex 26 ;
    ns1:syllabusDescription "9.2. lan de ordenación urbana. Gestión de la red verde y de la contaminación. Gestión de fauna urbana. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000194/2025-26/syllabus/27> a ns1:SyllabusItem ;
    ns1:itemIndex 27 ;
    ns1:syllabusDescription "10. Tema 10. Gestión del capital natural marino"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000194/2025-26/syllabus/28> a ns1:SyllabusItem ;
    ns1:itemIndex 28 ;
    ns1:syllabusDescription "10.1. Pesca sostenible. Recolección de algas. Bioplásticos. Gestión de especies invasoras. Huellas de carbono de productos marinos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000194/2025-26/syllabus/29> a ns1:SyllabusItem ;
    ns1:itemIndex 29 ;
    ns1:syllabusDescription "10.2. Monitorización (algas como bioindicadores, etc.). Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000194/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "2. Tema 2. Bioeconomía, biotecnología y diseño sostenible."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000194/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "2.1. Bioeconomía circular. El ciclo de vida del producto sostenibles.La Nueva Bauhaus Europea (belleza, sostenibilidad e integración). Reciclado, upcycling. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000194/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "2.2. ACV sostenibles y cálculos medioambientales y software para realizarlos. Calculo de huella ecológica Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000194/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "3. Tema 3. Evaluación de los servicios ecosistémicos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000194/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "3.1. Toma de datos, inventariado, monitoreo. Bioindicadores, sensores, drones, fotogravimetría y LIDAR, datos de satélites. Sistemas de información geográfica (SIG). Copernicus Land Monitoring Servicies (CLMS). Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000194/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "3.2. Capital Natural en las estadísticas nacionales (Eurostat). Entrevistas, encuestas, etc. Noticias en los medios de comunicación. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000194/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "4. Tema 4. Herramientas de gestión y planificación, y certificación."@es .

