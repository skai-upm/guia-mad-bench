        <https://guia-kg.skai.etsisi.upm.es/resource/133000194/2025-26/syllabus/23>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000194/2025-26/syllabus/24>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000194/2025-26/syllabus/25>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000194/2025-26/syllabus/26>,
