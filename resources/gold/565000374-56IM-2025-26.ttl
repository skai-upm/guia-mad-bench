<https://guia-kg.skai.etsisi.upm.es/resource/565000374/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/565000374/2025-26/CE26>,
        <https://guia-kg.skai.etsisi.upm.es/resource/565000374/2025-26/CG1>,
