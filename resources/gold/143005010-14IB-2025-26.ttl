    ns1:inpersonHours "50 horas (38.5%)"@es ;
    ns1:numberOfCredits 5.0 ;
    ns1:otherInformation "Se recomiendo a los alumnos tener conocimientos de programación en Matlab o Python ya que será necesario para realizar la simulación de trayectorias"@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
