    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/55000107/2025-26/syllabus> ;
    ns1:inpersonHours "49 horas y 30 minutos (61.1%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation ""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "49 horas y 30 minutos"@es ;
    schema:activitiesWorkload "105%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/55000107/2025-26/eventSchedule> ;
    schema:description "La asignatura de Sistemas Microprocesadores pretende aportar las capacidades necesarias para analizar y diseñar sistemas electrónicos basados en el uso de microprocesadores y micocontroladores. La asignatura comienza con el estudio de la arquitectura interna de un microprocesador para posteriormente entrar en la programación en ensamblador y su relación con la programación en alto nivel. Se ven también los procedimientos de entrada salida más comunes así como técnicas de interfaz entre los microprocesadores/microcontroladores y el mundo físico u otros circuitos electrónicos. Por último, se finaliza con una introducción al diseño de sistemas basados en microprocesadores y sistemas empotrados. La asignatura tiene una gran componente práctica y una buena parte del aprendizaje está basada en la programación del control de sistemas realistas a escala."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/gabriel.mujica%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/alfonso.rodriguezm%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/gabriel.mujica%40upm.es> ;
    schema:name "Sistemas Microprocesadores"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000107/2025-26/CE21A> a ns1:Competency ;
    ns1:competencyCode "CE21A" ;
    ns1:competencyDescription "Conocimiento de los fundamentos y aplicaciones de la electrónica digital y microprocesadores."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000107/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Conocer y aplicar conocimientos de ciencias y tecnologías básicas a la práctica de la Ingeniería Industrial."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000107/2025-26/CG10> a ns1:Competency ;
    ns1:competencyCode "CG10" ;
    ns1:competencyDescription "Capacidad para generar nuevas ideas (Creatividad)."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000107/2025-26/CG2> a ns1:Competency ;
    ns1:competencyCode "CG2" ;
    ns1:competencyDescription "Poseer capacidad para diseñar, desarrollar, implementar, gestionar y mejorar productos, sistemas y procesos en los distintos ámbitos industriales, usando técnicas analíticas, computacionales o experimentales apropiadas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000107/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Aplicar los conocimientos adquiridos para identificar, formular y resolver problemas dentro de contextos amplios y multidisciplinarios, siendo capaces de integrar conocimientos, trabajando en equipos multidisciplinares."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000107/2025-26/CG6> a ns1:Competency ;
    ns1:competencyCode "CG6" ;
    ns1:competencyDescription "Poseer habilidades de aprendizaje que permitan continuar estudiando a lo largo de la vida para su adecuado desarrollo profesional."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000107/2025-26/CG7> a ns1:Competency ;
    ns1:competencyCode "CG7" ;
    ns1:competencyDescription "Incorporar nuevas tecnologías y herramientas de la Ingeniería Industrial en sus actividades profesionales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000107/2025-26/RA19> a ns1:LearningResult ;
    ns1:learningResultCode "RA19" ;
    ns1:learningResultDescription "Capacidad para comprender la arquitectura de un sistema microprocesador."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000107/2025-26/RA20> a ns1:LearningResult ;
    ns1:learningResultCode "RA20" ;
    ns1:learningResultDescription "Capacidad para programar en lenguajes de bajo nivel y comprender su relación con los lenguajes de alto nivel."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000107/2025-26/RA21> a ns1:LearningResult ;
