    ns1:inpersonHours "32 horas y 50 minutos (42.1%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation """La asignatura está diseñada para la evaluación progresiva, desarrollándose en el aula numerosas actividades de aplicación de los contenidos del programa. A lo largo del curso se realizarán trabajos colaborativos, ejercicios, cuestionarios en Moodle, pruebas de aplicación y evaluación. No se recomienda la Evaluación global debido al carácter técnico y al enfoque práctico de la asignatura.
La asignatura se relaciona con el ODS 7 (Energía asequible y no contaminante), con el ODS 8 (Trabajo decente y crecimiento económico), con el ODS 9 (Industria, innovación e infraestructuras) y con el ODS 13 (Acción por el clima)"""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "34 horas y 50 minutos"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/53002031/2025-26/eventSchedule> ;
    schema:description "Esta asignatura proporciona una visión integral de las tecnologías limpias de combustión, abarcando desde los principios básicos hasta las innovaciones más recientes en el campo. La combinación de teoría, estudios de caso y proyectos prácticos está diseñada para equipar a los estudiantes con los conocimientos y habilidades necesarios para contribuir a un futuro energético más limpio y sostenible."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/javier.garciat%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/isabel.amez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/javier.garciat%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/liliana.medic%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/mf.ortega%40upm.es> ;
    schema:name "Tecnologías Limpias de Combustión"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002031/2025-26/CB10> a ns1:Competency ;
    ns1:competencyCode "CB10" ;
    ns1:competencyDescription "Que los estudiantes posean las habilidades de aprendizaje que les permitan continuar estudiando de un modo que habrá de ser en gran medida autodirigido o autónomo./ Students have the learning skills that they require to pursue their studies in a largely self"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002031/2025-26/CB9> a ns1:Competency ;
    ns1:competencyCode "CB9" ;
    ns1:competencyDescription "Que los estudiantes sepan comunicar sus conclusiones y los conocimientos y razones últimas que las sustentan a públicos especializados y no especializados de un modo claro y sin ambigüedades/ Students are capable of clearly and unambiguously communicating their conclusions, and the underlying knowledge and rationale to specialist and non"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002031/2025-26/CE3> a ns1:Competency ;
    ns1:competencyCode "CE3" ;
    ns1:competencyDescription "Utilizar las herramientas necesarias para el diseño y análisis de sistemas de generación, trasformación, almacenamiento y utilización de energías nucleares, mecánicas, eléctricas, térmicas e hidráulicas./ Use the necessary tools for the design and analysis of systems for the generation, transformation, storage and use of nuclear, mechanical, electrical, thermal and hydraulic energies."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002031/2025-26/CE7> a ns1:Competency ;
    ns1:competencyCode "CE7" ;
    ns1:competencyDescription "Conocer y aplicar las alternativas para la operación segura de instalaciones energéticas, tanto renovables, como no renovables, y de transformación de vectores energéticos, como refinerías o biorrefinerías/ Know and apply the alternatives for the safe operation of energy facilities, both renewable and non"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002031/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Aplicar conocimientos de ciencias y tecnologías avanzadas a la práctica profesional o investigadora de la Ingeniería Energética./ Apply knowledge of advanced science and technology to the professional or research practice of Energy Engineering."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002031/2025-26/CG2> a ns1:Competency ;
    ns1:competencyCode "CG2" ;
    ns1:competencyDescription "Poseer capacidad para diseñar, desarrollar, implementar, gestionar y mejorar productos, sistemas y procesos en los distintos ámbitos energéticos, usando técnicas analíticas, computacionales o experimentales avanzadas./ Ability to design, develop, implement, manage and improve products, systems and processes in the different energy fields, using advanced analytical, computational or experimental techniques."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002031/2025-26/CG5> a ns1:Competency ;
    ns1:competencyCode "CG5" ;
    ns1:competencyDescription "Comprender el impacto de la Ingeniería Energética en el medio ambiente, el desarrollo sostenible de la sociedad y la importancia de trabajar en un entorno profesional y responsable./ Understand the impact of Energy Engineering on the environment, the sustainable development of society and the importance of working in a professional and responsible environment."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002031/2025-26/CG8> a ns1:Competency ;
    ns1:competencyCode "CG8" ;
    ns1:competencyDescription "Incorporar nuevas tecnologías y herramientas avanzadas de la Ingeniería Energética en sus actividades profesionales o investigadoras./ Incorporate new technologies and advanced tools of Energy Engineering in their professional or research activities."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002031/2025-26/CT1> a ns1:Competency ;
    ns1:competencyCode "CT1" ;
    ns1:competencyDescription "Aplica. Habilidad para aplicar conocimientos científicos, matemáticos y tecnológicos en sistemas relacionados con la práctica de la ingeniería./ Apply. Ability to apply scientific, mathematical and technological knowledge in systems related to the practice of engineering."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002031/2025-26/CT10> a ns1:Competency ;
    ns1:competencyCode "CT10" ;
    ns1:competencyDescription "Conoce. Conocimiento de los temas contemporáneos./ Knowledge of contemporary issues."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002031/2025-26/CT11> a ns1:Competency ;
    ns1:competencyCode "CT11" ;
    ns1:competencyDescription "Usa herramientas. Habilidad para usar las técnicas, destrezas y herramientas ingenieriles modernas necesarias para la práctica de la ingeniería./ Use tools. Ability to use modern engineering techniques, skills, and tools necessary for engineering practice."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002031/2025-26/CT12> a ns1:Competency ;
    ns1:competencyCode "CT12" ;
    ns1:competencyDescription "Es bilingüe. Capacidad de trabajar en un entorno bilingüe (inglés/español). / Bilingual. Ability to work in a bilingual environment (English / Spanish)."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002031/2025-26/CT3> a ns1:Competency ;
    ns1:competencyCode "CT3" ;
    ns1:competencyDescription "Diseña. Habilidad para diseñar un sistema, componente o proceso que alcance los requisitos deseados teniendo en cuenta restricciones realistas tales como las económicas, medioambientales, sociales, políticas, éticas, de salud y seguridad, de fabricación y de sostenibilidad./ Design. Ability to design a system, component or process that meets the desired requirements taking into account realistic constraints such as economic, environmental, social, political, ethical, health and safety, manufacturing and sustainability."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002031/2025-26/CT5> a ns1:Competency ;
    ns1:competencyCode "CT5" ;
    ns1:competencyDescription "Resuelve. Habilidad para identificar, formular y resolver problemas de ingeniería./ Solve. Ability to identify, formulate and solve engineering problems."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002031/2025-26/CT7> a ns1:Competency ;
    ns1:competencyCode "CT7" ;
    ns1:competencyDescription "Comunica. Habilidad para comunicar eficazmente./ Communicate. Ability to communicate effectively."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002031/2025-26/CT8> a ns1:Competency ;
    ns1:competencyCode "CT8" ;
    ns1:competencyDescription "Entiende los impactos. Educación amplia necesaria para entender el impacto de las soluciones ingenieriles en un contexto social global./ Understand the impacts. Broad education to understand the impact of engineering solutions in a global social context."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002031/2025-26/CT9> a ns1:Competency ;
    ns1:competencyCode "CT9" ;
    ns1:competencyDescription "Se actualiza. Reconocimiento de la necesidad y la habilidad para comprometerse al aprendizaje continuo./ Updating. Recognition of the need and ability to commit to continuous learning."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002031/2025-26/RA197> a ns1:LearningResult ;
    ns1:learningResultCode "RA197" ;
    ns1:learningResultDescription "Aplicar los ciclos termodinámicos a la eficiencia energética"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002031/2025-26/RA198> a ns1:LearningResult ;
    ns1:learningResultCode "RA198" ;
    ns1:learningResultDescription "Aplicar las tecnologías de captura y almacenamiento de CO2"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002031/2025-26/RA199> a ns1:LearningResult ;
    ns1:learningResultCode "RA199" ;
    ns1:learningResultDescription "Aplicar las tecnologías de desulfuración y desnitrificación de gases de combustión"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002031/2025-26/RA200> a ns1:LearningResult ;
    ns1:learningResultCode "RA200" ;
    ns1:learningResultDescription "Analizar las aplicaciones de la combustión en la generación de energía"@es .

