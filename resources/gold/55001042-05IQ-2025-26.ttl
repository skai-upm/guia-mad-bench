    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/esteban.climent%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/joaquin.martinez%40upm.es> ;
    schema:name "Quimica Inorganica"@es .

