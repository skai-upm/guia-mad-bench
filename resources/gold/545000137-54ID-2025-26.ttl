    schema:name "Analisis de Estados Financieros"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000137/2025-26/CE42> a ns1:Competency ;
    ns1:competencyCode "CE42" ;
    ns1:competencyDescription "Conocer la técnica contable en relación con la situación y los resultados de la empresa, y los flujos habidos en un período."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000137/2025-26/CE43> a ns1:Competency ;
    ns1:competencyCode "CE43" ;
    ns1:competencyDescription "Comprender el impacto de las operaciones económicas que desarrollan las empresas en su patrimonio empresarial."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000137/2025-26/CE45> a ns1:Competency ;
    ns1:competencyCode "CE45" ;
    ns1:competencyDescription "Aplicar las herramientas de análisis de la información contable."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000137/2025-26/CE46> a ns1:Competency ;
    ns1:competencyCode "CE46" ;
    ns1:competencyDescription "Comprender los métodos de consolidación contable, la contabilidad de los grupos y las operaciones de fusión, escisión y absorción."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000137/2025-26/CE51> a ns1:Competency ;
    ns1:competencyCode "CE51" ;
    ns1:competencyDescription "Comprender los procesos para la gestión financiera de las empresas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000137/2025-26/CE52> a ns1:Competency ;
    ns1:competencyCode "CE52" ;
    ns1:competencyDescription "Comprender la operativa de las operaciones financieras."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000137/2025-26/CG14> a ns1:Competency ;
    ns1:competencyCode "CG14" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de comprender, interpretar, sintetizar y evaluar de forma crítica información proveniente de fuentes diversas en el ámbito de la administración y dirección de empresas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000137/2025-26/CG15> a ns1:Competency ;
    ns1:competencyCode "CG15" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de planificar eficientemente los trabajos en el ámbito de la administración y dirección de empresas, priorizando las tareas a desempeñar y evaluando los recursos y el tiempo necesario para llevarlas a cabo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000137/2025-26/CG18> a ns1:Competency ;
    ns1:competencyCode "CG18" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de aportar soluciones creativas en la resolución de problemas en el ámbito de la administración y dirección de empresas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000137/2025-26/CG23> a ns1:Competency ;
    ns1:competencyCode "CG23" ;
    ns1:competencyDescription "Que los estudiantes adquieran un compromiso ético en su trabajo en el ámbito de la administración y dirección de empresas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000137/2025-26/RA119> a ns1:LearningResult ;
    ns1:learningResultCode "RA119" ;
    ns1:learningResultDescription "Identificación de la operativa con el lenguaje específico de la contabilidad, así como exposición de ideas y reflexiones utilizando la terminología contable."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000137/2025-26/RA120> a ns1:LearningResult ;
    ns1:learningResultCode "RA120" ;
    ns1:learningResultDescription "Utilización de las principales prácticas de la contabilidad cumpliendo la normativa nacional, y completando ésta con determinados aspectos de la normativa internacional."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000137/2025-26/RA121> a ns1:LearningResult ;
    ns1:learningResultCode "RA121" ;
    ns1:learningResultDescription "El alumno sabrá distinguir los diferentes contextos en los que opera la contabilidad representados en los sistemas de información contables, así como su conexión financiera."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000137/2025-26/RA122> a ns1:LearningResult ;
    ns1:learningResultCode "RA122" ;
    ns1:learningResultDescription "El alumno será capaz de elaborar un sistema de información así como la utilización de herramientas necesarias para dicho propósito."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000137/2025-26/RA123> a ns1:LearningResult ;
    ns1:learningResultCode "RA123" ;
    ns1:learningResultDescription "Resolución de problemas, planteados de formas diferentes, en los que sea preciso definir la situación inicial, la meta y las acciones que conducirán a la misma. La resolución del problema y su trazado será diseñado de forma individual y/o en grupo."@es .

