    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/303000060/2025-26/eventSchedule> ;
    schema:description "En esta asignatura obligatoria se tratan los métodos y estrategias para abordar la didáctica en Física en Educación Secundaria y Bachillerato."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/javier.galeano%40upm.es> ;
