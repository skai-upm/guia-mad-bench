<https://guia-kg.skai.etsisi.upm.es/resource/565000182/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Presentaciones"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000182/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Competencias funcionales: Presentarse, saludar, dar informaciones sobre sí mismo. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000182/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "3.2. Gramática: Presente de indicativo de algunos verbos, algunas preposiciones, indicadores de tiempo, expresión de la causa. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000182/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "3.3. Vocabulario: Comunicación telefónica e informática, descripción de materiales y operaciones. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000182/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "4. Viajes profesionales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000182/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "4.1. Competencias funcionales: Dar instrucciones, pedir e indicar direcciones o localizaciones, hablar de medios de transporte y alojamiento. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000182/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "4.2. Gramática: Imperativo, formación del femenino y del plural, expresiones impersonales. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000182/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "4.3. Vocabulario: Viajes, medios de transporte, alojamiento, localización, matemáticas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000182/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "5. Organización de la jornada profesional"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000182/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "5.1. Competencias funcionales: Hablar de las actividades cotidianas, dar consignas e instrucciones, concertar citas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000182/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "5.2. Gramática: Verbos pronominales, futuro próximo, algunas preposiciones, partitivos, demostrativos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000182/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "5.3. Vocabulario: Actividades profesionales, comida, cronología, instrucciones. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000182/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Gramática: Presente de indicativo de algunos verbos, artículos, interrogación, posesivos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000182/2025-26/syllabus/20> a ns1:SyllabusItem ;
    ns1:itemIndex 20 ;
    ns1:syllabusDescription "6. Elegir"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000182/2025-26/syllabus/21> a ns1:SyllabusItem ;
    ns1:itemIndex 21 ;
    ns1:syllabusDescription "6.1. Competencias funcionales: Elegir y pedir en establecimientos comerciales, indicar y pedir precios, hablar de hechos pasados. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000182/2025-26/syllabus/22> a ns1:SyllabusItem ;
    ns1:itemIndex 22 ;
    ns1:syllabusDescription "6.2. Gramática: Pronombres personales directos, comparativos, \"passé composé\", indicadores temporales de pasado. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000182/2025-26/syllabus/23> a ns1:SyllabusItem ;
    ns1:itemIndex 23 ;
    ns1:syllabusDescription "6.3. Vocabulario: Restaurantes, venta, alquiler, alojamiento, compras, ropa, función de máquinas y herramientas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000182/2025-26/syllabus/24> a ns1:SyllabusItem ;
    ns1:itemIndex 24 ;
    ns1:syllabusDescription "7. Presentación de una empresa"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000182/2025-26/syllabus/25> a ns1:SyllabusItem ;
    ns1:itemIndex 25 ;
    ns1:syllabusDescription "7.1. Competencias funcionales: Hablar de una empresa y su organización, describir procesos de fabricación, describir cualidades personales y profesionales, indicar la composición de un producto, expresar la obligación y la prohibición. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000182/2025-26/syllabus/26> a ns1:SyllabusItem ;
    ns1:itemIndex 26 ;
    ns1:syllabusDescription "7.2. Gramática: Relativos, algunos pronombres personales. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000182/2025-26/syllabus/27> a ns1:SyllabusItem ;
    ns1:itemIndex 27 ;
    ns1:syllabusDescription "7.3. Vocabulario: Empresas y su organización, procesos, experimentos de laboratorio. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000182/2025-26/syllabus/28> a ns1:SyllabusItem ;
    ns1:itemIndex 28 ;
    ns1:syllabusDescription "8. Búsqueda de empleo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000182/2025-26/syllabus/29> a ns1:SyllabusItem ;
    ns1:itemIndex 29 ;
    ns1:syllabusDescription "8.1. Competencias funcionales: Comprender y redactar una oferta de empleo, redactar un currículum vítae, hacer una entrevista de trabajo. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000182/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "1.3. Vocabulario: Profesiones, funciones en la empresa, descripción de objetos, formas geométricas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000182/2025-26/syllabus/30> a ns1:SyllabusItem ;
    ns1:itemIndex 30 ;
    ns1:syllabusDescription "8.2. Gramática: Pasado reciente, expresiones de tiempo, pretérito imperfecto. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000182/2025-26/syllabus/31> a ns1:SyllabusItem ;
    ns1:itemIndex 31 ;
    ns1:syllabusDescription "8.3. Vocabulario: Ofertas de empleo, currículum vítae, función de máquinas y herramientas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000182/2025-26/syllabus/32> a ns1:SyllabusItem ;
    ns1:itemIndex 32 ;
    ns1:syllabusDescription "9. Proyectos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000182/2025-26/syllabus/33> a ns1:SyllabusItem ;
    ns1:itemIndex 33 ;
    ns1:syllabusDescription "9.1. Competencias funcionales: Participar en reuniones profesionales, hacer y aceptar sugerencias, describir el entorno de trabajo. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000182/2025-26/syllabus/34> a ns1:SyllabusItem ;
    ns1:itemIndex 34 ;
