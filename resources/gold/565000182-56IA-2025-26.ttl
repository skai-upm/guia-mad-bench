<https://guia-kg.skai.etsisi.upm.es/resource/565000182/2025-26/CG%2010.> a ns1:Competency ;
    ns1:competencyCode "CG 10." ;
    ns1:competencyDescription "Creatividad."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000182/2025-26/CG%203.> a ns1:Competency ;
    ns1:competencyCode "CG 3." ;
    ns1:competencyDescription "Aplicar los conocimientos adquiridos para identificar, formular y resolver problemas en contextos amplios, siendo capaces de integrar los trabajando en equipos multidisciplinares"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000182/2025-26/CG%205.> a ns1:Competency ;
    ns1:competencyCode "CG 5." ;
    ns1:competencyDescription "Comunicar conocimientos y conclusiones, tanto de forma oral como escrita, a públicos especializados y no especializados de modo claro y sin ambigüedades."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000182/2025-26/CG%206.> a ns1:Competency ;
    ns1:competencyCode "CG 6." ;
    ns1:competencyDescription "Poseer las habilidades de aprendizaje que permitan continuar estudiando a lo largo de toda la vida para un desarrollo profesional adecuado"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000182/2025-26/CG%209.> a ns1:Competency ;
    ns1:competencyCode "CG 9." ;
    ns1:competencyDescription "Organización y planificación de proyectos y equipos humanos. Trabajo en equipo y capacidad de liderazgo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000182/2025-26/RA81> a ns1:LearningResult ;
    ns1:learningResultCode "RA81" ;
    ns1:learningResultDescription "Conocimientos y capacidades para entender las ideas principales de textos complejos de carácter general y de especialidad."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000182/2025-26/RA82> a ns1:LearningResult ;
    ns1:learningResultCode "RA82" ;
    ns1:learningResultDescription "Capacidad de relación con hablantes francófonos con un grado suficiente de fluidez y naturalidad."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000182/2025-26/RA83> a ns1:LearningResult ;
    ns1:learningResultCode "RA83" ;
    ns1:learningResultDescription "Capacidad de producción de textos claros y detallados sobre temas diversos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000182/2025-26/RA84> a ns1:LearningResult ;
    ns1:learningResultCode "RA84" ;
    ns1:learningResultDescription "Capacidad de defender ideas y puntos de vista indicando pros y contras de las distintas opciones."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000182/2025-26/RA85> a ns1:LearningResult ;
