<https://guia-kg.skai.etsisi.upm.es/resource/145006205/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Tema 1. COMPORTAMIENTO EN SERVICIO A ALTA TEMPERATURA."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145006205/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. 1.1. Comportamiento a fluencia. Diseño de aleaciones para trabajar a fluencia. 1.2. Comportamiento a fatiga. Interacción fluencia-fatiga. 1.3. Oxidación a alta temperatura. 1.4. Corrosión en caliente Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145006205/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "6. Tema 7. MATERIALES CERÁMICOS."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145006205/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "6.1. 7.1. Propiedades físicas y mecánicas. 7.2. Tipos de cerámicos para alta temperatura. 7.3. Aplicaciones de los materiales cerámicos para alta temperatura Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145006205/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "2. Tema 2. SUPERALEACIONES BASE NÍQUEL."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145006205/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "2.1. 2.1. Mecanismos de refuerzo en aleaciones para alta temperatura. 2.2. Microestructura de las superaleaciones base níquel. 2.3. Tratamientos térmicos. 2.4. Superaleaciones policristalinas y monocristalinas. 2.5. Aplicaciones. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145006205/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "3. Tema 3. SUPERALEACIONES BASE COBALTO."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145006205/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "3.1. 3.1. Microestructura de las superaleaciones base cobalto. 3.2. Tratamientos térmicos. 3.3. Aplicaciones de las superaleaciones base cobalto. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145006205/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "4. Tema 4. RECUBRIMIENTOS PROTECTORES."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145006205/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "4.1. 4.1. Recubrimientos para protección a alta temperatura. 4.2. Barreras térmicas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145006205/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "5. Tema 5. METALES REFRACTARIOS."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145006205/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "5.1. 5.1. Molibdeno, wolframio, niobio, tántalo y renio. 5.2. Características y principales aplicaciones de los metales refractarios Sin subniveles"@es .

