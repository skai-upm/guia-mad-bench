<https://guia-kg.skai.etsisi.upm.es/resource/43000411/2025-26/CE28> a ns1:Competency ;
    ns1:competencyCode "CE28" ;
    ns1:competencyDescription "Conocimientos de la ingeniería y planificación del transporte, funciones y modos de transporte, el transporte urbano, la gestión de los servicios públicos de transporte, la demanda, los costes, la logística y la financiación de las infraestructuras y servicios de transporte."@es .

