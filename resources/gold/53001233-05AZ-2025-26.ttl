    ns1:inpersonHours "29 horas (37.2%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation ""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "43 horas y 30 minutos"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/53001233/2025-26/eventSchedule> ;
    schema:description """This is a course designed for students in the Master of Science in Industrial Engineering that have a background in Engineering, but do not have a minor in the mechanical subjects. As such, the goals of the course is to provide a solid understanding of the fundamentals of Stength of Materials and Structural Analysis, and the link it with other branches of Engineering. More specifically, the course will knowingly leave aside traditionally taught skills such as the analytical solution of simple problems and focus on general principles and the computational implementation of solution methods. For that, the main goals of the course are:
To understand the underlying principles behind structural analysis
To calculate stress resultants and displacements in 2d structures of bars and beams
To be able to determine when a structure will withstand given loads or fail
To learn how to develop a "general purpose" program to calculate structures and use it to design simple ones"""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/ignacio.romero%40upm.es> ;
    schema:inLanguage "Inglés"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/ignacio.romero%40upm.es> ;
    schema:name "Ampliacion de Resistencia de Materiales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001233/2025-26/%28a%29> a ns1:Competency ;
    ns1:competencyCode "(a)" ;
    ns1:competencyDescription "APLICA. Habilidad para aplicar conocimientos científicos, matemáticos y tecnológicos en sistemas relacionados con la práctica de la ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001233/2025-26/%28e%29> a ns1:Competency ;
    ns1:competencyCode "(e)" ;
    ns1:competencyDescription "RESUELVE. Habilidad para identificar, formular y resolver problemas de ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001233/2025-26/%28k%29> a ns1:Competency ;
    ns1:competencyCode "(k)" ;
    ns1:competencyDescription "USA HERRAMIENTAS. Habilidad para usar las técnicas, destrezas y herramientas ingenieriles modernas necesarias para la práctica de la ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001233/2025-26/RA104> a ns1:LearningResult ;
    ns1:learningResultCode "RA104" ;
    ns1:learningResultDescription "Comprender que el Cálculo de Estructuras es una de las fases que conforman el proceso global del proyecto de una estructura; y en ella habrá de determinarse, mediante la aplicación de los Principios de la Mecánica de los Sólidos Deformables, si la estructura podrá desempeñar la función para la que inicialmente fue concebida."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001233/2025-26/RA105> a ns1:LearningResult ;
    ns1:learningResultCode "RA105" ;
    ns1:learningResultDescription "Relacionar los desplazamientos y esfuerzos que se producen en una estructura de barras con el sistema de solicitaciones aplicado sobre la misma; teniendo en cuenta que han de satisfacerse las relaciones básicas de Equilibrio, Compatibilidad y Comportamiento."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001233/2025-26/RA106> a ns1:LearningResult ;
    ns1:learningResultCode "RA106" ;
    ns1:learningResultDescription "Comprender la sistematización en el cálculo y su implementación en ordenadores como aproximación al uso de esta herramienta en el cálculo de estructuras."@es .

