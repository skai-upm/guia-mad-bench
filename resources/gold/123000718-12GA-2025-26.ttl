    ns1:inpersonHours "97 horas y 20 minutos (72.1%)"@es ;
    ns1:numberOfCredits 5.0 ;
    ns1:otherInformation """El material didáctico que compone la asignatura será el siguiente:
-Presentaciones tanto para la parte de teoría como de prácticas.
-Datos que permitirán llevar a cabo las prácticas planteadas."""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "97 horas y 20 minutos"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/123000718/2025-26/eventSchedule> ;
    schema:description """TEMARIO DE TEORÍA.
1. SENSORES PASIVOS AEROTRANSPORTADOS.
2. SISTEMAS DE REFERENCIA EN FOTOGRAMETRÍA.
3. SISTEMA DE POSICIONAMIENTO GNSS APLICADOS A FOTOGRAMETRÍA
4. PRINCIPIOS DE LA NAVEGACIÓN INERCIAL.
5. INTEGRACIÓN DE DATOS INS/GNSS.
6. ORIENTACIÓN EXTERNA.
7. SENSORES PASIVOS ORBITALES.
8. PRODUCCIÓN FOTOGRAMÉTRICA CON SENSORES PASIVOS ORBITALES.
9. SENSORES ACTIVOS TRANSPORTADOS MMS Y LIDAR.

TEMARIO DE PRÁCTICAS.
1. COMPARATIVA OE INDIRECTA FRENTE A OE DIRECTA.
2. ORIENTACIÓN EXTERNA DATOS VHR.
3. OBTENCIÓN DE UN MDT POR TÉCNICAS ESTEREOSCÓPICAS A PARTIR DE IMÁGENES VHR DE 0,5 m DE GSD.
4. ORTORRECTIFICACIÓN FOTOGRAMÉTRICA DE IMÁGENES SATÉLITE.
5. OBTENCIÓN DE MODELOS A PARTIR DE TÉCNICAS DE CLASIFICACIÓN Y EDICIÓN DE DATOS LiDAR TRANSPORTADO."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/s.lopezc%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/alejandro.saenz%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/s.lopezc%40upm.es> ;
    schema:name "Integración de Sensores Aplicados a la Fotogrametría"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/123000718/2025-26/CB7> a ns1:Competency ;
    ns1:competencyCode "CB7" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en entornos nuevos o poco conocidos dentro de contextos más amplios (o multidisciplinares) relacionados con su área de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/123000718/2025-26/CE3> a ns1:Competency ;
    ns1:competencyCode "CE3" ;
    ns1:competencyDescription "Proyectar, coordinar y dirigir proyectos de producción de información geoespacial en el ámbito de la Ingeniería y de la Arquitectura"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/123000718/2025-26/CG5> a ns1:Competency ;
    ns1:competencyCode "CG5" ;
    ns1:competencyDescription "Desarrollar la capacidad de razonamiento, dominar y aplicar en la práctica los conocimientos avanzados en Geodesia, Fotogrametría y Teledetección y Cartografía."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/123000718/2025-26/RA32> a ns1:LearningResult ;
    ns1:learningResultCode "RA32" ;
    ns1:learningResultDescription "Conocimiento preciso de las características de los sensores fotogramétricos más importantes en el mercado."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/123000718/2025-26/RA33> a ns1:LearningResult ;
    ns1:learningResultCode "RA33" ;
    ns1:learningResultDescription "Aplicación de las técnicas de orientación externa de sensores fotogramétricos en el ámbito de la fotogrametría."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/123000718/2025-26/RA34> a ns1:LearningResult ;
    ns1:learningResultCode "RA34" ;
    ns1:learningResultDescription "Estudio detallado de los sistemas de medición GNSS aplicados a la orientación externa de sensores."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/123000718/2025-26/RA35> a ns1:LearningResult ;
    ns1:learningResultCode "RA35" ;
    ns1:learningResultDescription "Profundo conocimiento de los principios de navegación inercial y las ecuaciones que rigen la orientación externa directa de los sensores de observación de la tierra."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/123000718/2025-26/RA36> a ns1:LearningResult ;
    ns1:learningResultCode "RA36" ;
    ns1:learningResultDescription "Aplicación de las técnicas de orientación externa de sensores orbitales en el ámbito de la captura de imágenes Very High Resolution."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/123000718/2025-26/RA37> a ns1:LearningResult ;
    ns1:learningResultCode "RA37" ;
    ns1:learningResultDescription "Estudio detallado de las técnicas de correlación de imágenes para la obtención de Modelos Digitales de Elevación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/123000718/2025-26/RA38> a ns1:LearningResult ;
    ns1:learningResultCode "RA38" ;
    ns1:learningResultDescription "Conocimiento del sistema LiDAR y de las técnicas de clasificación de los ficheros LAS para la obtención directa de la orografía del terreno."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/123000718/2025-26/RA39> a ns1:LearningResult ;
    ns1:learningResultCode "RA39" ;
    ns1:learningResultDescription "Utilización de los datos de elevación directa e indirecta para la ortorrectificación de imágenes."@es .

