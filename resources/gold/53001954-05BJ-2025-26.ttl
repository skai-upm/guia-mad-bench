    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/53001954/2025-26/didactic_resource/1> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/53001954/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/53001954/2025-26/RA13>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001954/2025-26/RA24>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001954/2025-26/RA27>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001954/2025-26/RA30>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001954/2025-26/RA39>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001954/2025-26/RA47>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001954/2025-26/RA48> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/53001954/2025-26/syllabus> ;
    ns1:inpersonHours "30 horas (38.5%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation """La asignatura está directamente relacionada con el ODS 7: Energía asequible y no contaminante y ODS 13: Acción por el clima.
La relación entre energía y medioambiente es directa, siendo el sector de la energía uno de los claves para entender la sostenibilidad de la Sociedad, y los cambios que se prevén.
Algunas sesiones pueden darse en inglés."""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "36 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/53001954/2025-26/eventSchedule> ;
    schema:description "La asignatura pretende ilustrar a los alumnos en las características más importantes de la extracción de recursos energéticos y generación de energía, encuadrándolos en el contexto del impacto ambiental que provocan y las técnicas disponibles para la mitigación de esos efectos."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/alberto.abanades%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/alberto.abanades%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/elisa.alonso%40upm.es> ;
    schema:name "Aprovechamiento de Recursos Energéticos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001954/2025-26/CB07> a ns1:Competency ;
    ns1:competencyCode "CB07" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en entornos nuevos o poco conocidos dentro de contextos más amplios (o multidisciplinares) relacionados con su área de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001954/2025-26/CB08> a ns1:Competency ;
    ns1:competencyCode "CB08" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de integrar conocimientos y enfrentarse a la complejidad de formular juicios a partir de una información que, siendo incompleta o limitada, incluya reflexiones sobre las responsabilidades sociales y éticas vinculadas a la aplicación de sus conocimientos y juicios"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001954/2025-26/CE01> a ns1:Competency ;
    ns1:competencyCode "CE01" ;
    ns1:competencyDescription "Capacidad para aplicar técnicas numéricas a la modelización, cuantificación de impactos y resolución de problemas de calidad y gestión de aire, agua y suelos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001954/2025-26/CE02> a ns1:Competency ;
    ns1:competencyCode "CE02" ;
    ns1:competencyDescription "Habilidad para profundizar en los conocimientos relativos a la emisión y dispersión de contaminantes atmosféricos y sus impactos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001954/2025-26/CE06> a ns1:Competency ;
    ns1:competencyCode "CE06" ;
    ns1:competencyDescription "Capacidad para aplicar las teorías de diseño sostenible a los procesos de diseño de productos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001954/2025-26/CE07> a ns1:Competency ;
    ns1:competencyCode "CE07" ;
    ns1:competencyDescription "Habilidad para profundizar en el conocimiento del aprovechamiento de los recursos energéticos y sus implicaciones."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001954/2025-26/CE08> a ns1:Competency ;
    ns1:competencyCode "CE08" ;
    ns1:competencyDescription "Capacidad de comprensión y dominio de la legislación y normativa nacional e internacional y su aplicación para la resolución de problemas propios de la ingeniería ambiental."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001954/2025-26/CG04> a ns1:Competency ;
    ns1:competencyCode "CG04" ;
    ns1:competencyDescription "Capacidad para la toma de decisiones y la emisión de juicios ante el estudio de casos reales presentados por el profesorado en la forma práctica, científica y profesional."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001954/2025-26/CG05> a ns1:Competency ;
    ns1:competencyCode "CG05" ;
    ns1:competencyDescription "Capacidad para comunicar correcta y adecuadamente las conclusiones obtenidas mediante la exposición del análisis de casos prácticos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001954/2025-26/CT01> a ns1:Competency ;
    ns1:competencyCode "CT01" ;
    ns1:competencyDescription "Aplica. Habilidad para aplicar conocimientos científicos, matemáticos y tecnológicos en sistemas relacionados con la práctica de la ingeniería ambiental."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001954/2025-26/CT05> a ns1:Competency ;
    ns1:competencyCode "CT05" ;
    ns1:competencyDescription "Resuelve. Habilidad para identificar, formular y resolver problemas de ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001954/2025-26/RA13> a ns1:LearningResult ;
    ns1:learningResultCode "RA13" ;
    ns1:learningResultDescription "Será capaz de análizar e interpretar de forma crítica un estudio/informe/resultado sobre sostenibilidad energética"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001954/2025-26/RA24> a ns1:LearningResult ;
    ns1:learningResultCode "RA24" ;
    ns1:learningResultDescription "Conocer el contexto multidisciplinar de la asignatura."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001954/2025-26/RA27> a ns1:LearningResult ;
    ns1:learningResultCode "RA27" ;
    ns1:learningResultDescription "Capacidad de preparar y exponer trabajos relacionados con el contenido de la asignatura."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001954/2025-26/RA30> a ns1:LearningResult ;
    ns1:learningResultCode "RA30" ;
    ns1:learningResultDescription "Ser capaz de comunicarse con claridad tanto con especialistas como con responsables políticos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001954/2025-26/RA39> a ns1:LearningResult ;
    ns1:learningResultCode "RA39" ;
    ns1:learningResultDescription "Entender el impacto de las soluciones ingenieriles en un contexto social global."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001954/2025-26/RA47> a ns1:LearningResult ;
    ns1:learningResultCode "RA47" ;
    ns1:learningResultDescription "Entender las características de los combustibles alternativos y de otras fuentes de energía y su aplicación al transporte, analizando rendimientos y su ciclo de vida"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001954/2025-26/RA48> a ns1:LearningResult ;
    ns1:learningResultCode "RA48" ;
    ns1:learningResultDescription "Conocer el problema energético e impacto medioambiental de los distintos modos de transporte, su legislación y normalización"@es .

