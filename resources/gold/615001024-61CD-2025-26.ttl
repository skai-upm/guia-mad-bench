    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/615001024/2025-26/didactic_resource/1> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/615001024/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/615001024/2025-26/RA100>,
        <https://guia-kg.skai.etsisi.upm.es/resource/615001024/2025-26/RA126>,
