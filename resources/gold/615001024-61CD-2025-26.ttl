    schema:courseCode 615001024 ;
    schema:hasCourseInstance <https://guia-kg.skai.etsisi.upm.es/resource/615001024/2025-26> ;
    schema:name "Architectures For Massive Data Processing"@en,
        "Arquitecturas para el Procesamiento Masivo de Datos"@es ;
    schema:numberOfCredits 6.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/615001024/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/615001024/2025-26/CB01>,
