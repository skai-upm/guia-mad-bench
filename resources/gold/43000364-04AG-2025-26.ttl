    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/43000364/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/43000364/2025-26/RA209>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000364/2025-26/RA210>,
