<https://guia-kg.skai.etsisi.upm.es/resource/145006401/2025-26/CE60> a ns1:Competency ;
    ns1:competencyCode "CE60" ;
    ns1:competencyDescription "Conocimiento aplicado de: edificación; electricidad; electrotecnia; electrónica; mecánica del vuelo; hidráulica; instalaciones aeroportuarias; ciencia y tecnología de los materiales; teoría de estructuras; mantenimiento y explotación de aeropuertos; transporte aéreo, cartografía, topografía, geotecnia y meteorología."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145006401/2025-26/CE64> a ns1:Competency ;
    ns1:competencyCode "CE64" ;
    ns1:competencyDescription "Comprensión de la aerodinámica, mecánica del vuelo e ingeniería de aeronaves en el entorno aeroportuario"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145006401/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Capacidad para identificar y resolver problemas aplicando, con creatividad, los conocimientos adquiridos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145006401/2025-26/CG9> a ns1:Competency ;
    ns1:competencyCode "CG9" ;
    ns1:competencyDescription "Razonamiento crítico y capacidad de asociación que posibiliten el aprendizaje continuo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145006401/2025-26/RA1> a ns1:LearningResult ;
    ns1:learningResultCode "RA1" ;
    ns1:learningResultDescription "Conocimiento de la aerodinámica de las aeronaves y su influencia en el entorno aeroportuario."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145006401/2025-26/RA2> a ns1:LearningResult ;
    ns1:learningResultCode "RA2" ;
    ns1:learningResultDescription "Conocimiento y comprensión de las actuaciones, y la estabilidad y controlabilidad estáticas de las aeronaves."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145006401/2025-26/RA3> a ns1:LearningResult ;
    ns1:learningResultCode "RA3" ;
    ns1:learningResultDescription "Conocimiento, comprensión, aplicación, análisis y síntesis de los aspectos más destacados del vuelo para su aplicación a las operaciones en el entorno aeroportuario."@es .

