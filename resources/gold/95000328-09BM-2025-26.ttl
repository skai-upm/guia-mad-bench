    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/95000328/2025-26/eventSchedule> ;
    schema:description "Estructura de los materiales. Diagramas de fases y transformaciones. Defectos. Solicitaciones de los materiales biológicos y biomateriales. Materiales Biológicos Duros. Materiales Biológicos Blandos. Biomateriales metálicos. Biomateriales cerámicos. Biomateriales poliméricos. Biomateriales compuestos. Biomateriales biológicos. Procesos biológicos implicados en la biocompatibilidad. Degradación de Biomateriales."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/gustavo.plaza%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
