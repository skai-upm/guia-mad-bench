        <https://guia-kg.skai.etsisi.upm.es/resource/53002037/2025-26/CT10>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53002037/2025-26/CT11>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53002037/2025-26/CT3>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53002037/2025-26/CT9> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/53002037/2025-26/didactic_resource/1> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/53002037/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/53002037/2025-26/RA67>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53002037/2025-26/RA95> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/53002037/2025-26/syllabus> ;
    ns1:inpersonHours "64 horas (79%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation """En caso de tener que recurrir a la telenseñanza por medidas de confinamiento, las clases se realizarán por vía telemática, preferentemente por Windows Teams.
La comunicación con el profesor también se realizará por esta vía.
La asignatura permite trabajar algunos de los Objetivos de Desarrollo Sostenible como el ODS 7 "Garantizar el acceso a una energía asequible, segura, sostenible y moderna para todos" (tema reactores nucleares avanzados)."""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "66 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/53002037/2025-26/eventSchedule> ;
    schema:description "La asignatura de Tecnologías avanzadas en reactores nucleares pretende dar una visión completa pero a la vez detallada de los reactores nucleares que actualmente están en diseño y construcción en todo el mundo. En una primera parte de la asignatura, se abordan los reactores que están actualmente licenciándose y construyendose en distintos países como EEUU. Francia, Finlandia, China, Reino Unido y Rusia. En la segunda parte, se tratan los reactores de fisión del futuro (Generación IV), que por otra parte cuentan con muchos precedentes experimentales del pasado."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/gonzalo.jimenez%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/emilio.castro%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/gonzalo.jimenez%40upm.es> ;
    schema:name "Tecnologías Avanzadas de Fisión"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002037/2025-26/CB7> a ns1:Competency ;
    ns1:competencyCode "CB7" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en entornos nuevos o poco conocidos dentro de contextos más amplios (o multidisciplinares) relacionados con su área de estudio/ Students are capable of applying their knowledge, understanding, and problem"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002037/2025-26/CB9> a ns1:Competency ;
    ns1:competencyCode "CB9" ;
    ns1:competencyDescription "Que los estudiantes sepan comunicar sus conclusiones y los conocimientos y razones últimas que las sustentan a públicos especializados y no especializados de un modo claro y sin ambigüedades/ Students are capable of clearly and unambiguously communicating their conclusions, and the underlying knowledge and rationale to specialist and non"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002037/2025-26/CE14> a ns1:Competency ;
    ns1:competencyCode "CE14" ;
    ns1:competencyDescription "Ser capaces de integrar conocimientos y enfrentarse a la complejidad de formular juicios, en el tratamiento y almacenamiento de los residuos radiactivos generados en instalaciones nucleares y radiactivas, incluyendo reflexiones sobre las responsabilidades sociales y éticas vinculadas a la aplicación de sus conocimientos y juicios./ Ability to integrate knowledge and face the complexity of formulating judgments, in the treatment and storage of radioactive waste generated in nuclear and radioactive facilities, including reflections on the social and ethical responsibilities linked to the application of their knowledge and judgments."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002037/2025-26/CE15> a ns1:Competency ;
    ns1:competencyCode "CE15" ;
    ns1:competencyDescription "Conocer los criterios básicos de seguridad y protección radiológica, el impacto de las radiaciones ionizantes y las tecnologías del blindaje contra las mismas./ Knowledge of the basic criteria of safety and radiological protection, the impact of ionizing radiation and shielding technologies against them."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002037/2025-26/CE17> a ns1:Competency ;
    ns1:competencyCode "CE17" ;
    ns1:competencyDescription "Comprender los procesos que integran el ciclo de vida de los procesos energéticos, desde la obtención del recurso primario, hasta su desmantelamiento, y su integración en la economía circular./ Understand the processes that make up the life cycle of energy processes, from obtaining the primary resource, to its dismantling, and its integration into the circular economy."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002037/2025-26/CE3> a ns1:Competency ;
    ns1:competencyCode "CE3" ;
    ns1:competencyDescription "Utilizar las herramientas necesarias para el diseño y análisis de sistemas de generación, trasformación, almacenamiento y utilización de energías nucleares, mecánicas, eléctricas, térmicas e hidráulicas./ Use the necessary tools for the design and analysis of systems for the generation, transformation, storage and use of nuclear, mechanical, electrical, thermal and hydraulic energies."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002037/2025-26/CE8> a ns1:Competency ;
    ns1:competencyCode "CE8" ;
    ns1:competencyDescription "Disponer de habilidades, criterios y conocimientos para investigar, desarrollar e innovar en el campo de la energía: tecnologías renovables y no renovables, almacenamiento, vectores energéticos, en un contexto de decarbonización del sistema./ Skills, criteria and knowledge to research, develop and innovate in the field of energy: renewable and non"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002037/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Aplicar conocimientos de ciencias y tecnologías avanzadas a la práctica profesional o investigadora de la Ingeniería Energética./ Apply knowledge of advanced science and technology to the professional or research practice of Energy Engineering."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002037/2025-26/CT1> a ns1:Competency ;
    ns1:competencyCode "CT1" ;
    ns1:competencyDescription "Aplica. Habilidad para aplicar conocimientos científicos, matemáticos y tecnológicos en sistemas relacionados con la práctica de la ingeniería./ Apply. Ability to apply scientific, mathematical and technological knowledge in systems related to the practice of engineering."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002037/2025-26/CT10> a ns1:Competency ;
    ns1:competencyCode "CT10" ;
    ns1:competencyDescription "Conoce. Conocimiento de los temas contemporáneos./ Knowledge of contemporary issues."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002037/2025-26/CT11> a ns1:Competency ;
    ns1:competencyCode "CT11" ;
    ns1:competencyDescription "Usa herramientas. Habilidad para usar las técnicas, destrezas y herramientas ingenieriles modernas necesarias para la práctica de la ingeniería./ Use tools. Ability to use modern engineering techniques, skills, and tools necessary for engineering practice."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002037/2025-26/CT3> a ns1:Competency ;
    ns1:competencyCode "CT3" ;
    ns1:competencyDescription "Diseña. Habilidad para diseñar un sistema, componente o proceso que alcance los requisitos deseados teniendo en cuenta restricciones realistas tales como las económicas, medioambientales, sociales, políticas, éticas, de salud y seguridad, de fabricación y de sostenibilidad./ Design. Ability to design a system, component or process that meets the desired requirements taking into account realistic constraints such as economic, environmental, social, political, ethical, health and safety, manufacturing and sustainability."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002037/2025-26/CT9> a ns1:Competency ;
    ns1:competencyCode "CT9" ;
    ns1:competencyDescription "Se actualiza. Reconocimiento de la necesidad y la habilidad para comprometerse al aprendizaje continuo./ Updating. Recognition of the need and ability to commit to continuous learning."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002037/2025-26/RA67> a ns1:LearningResult ;
    ns1:learningResultCode "RA67" ;
    ns1:learningResultDescription "Saber realizar el diseño y análisis de reactores nucleares de fisión"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002037/2025-26/RA95> a ns1:LearningResult ;
    ns1:learningResultCode "RA95" ;
    ns1:learningResultDescription "Conocer la tecnología de las centrales nucleares avanzadas de nueva generación, sus características de operación y de seguridad"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002037/2025-26/didactic_resource/1> a ns1:DidacticResource ;
    ns1:bibliographyDescription "Se encuentran accesibles para los alumnos en la plataforma moodle de la UPM"@es ;
    ns1:bibliographyTitle "Todas las Presentaciones de clase"@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002037/2025-26/evaluation> a ns1:EvaluationSystem ;
    ns1:evaluationDescription """El examen global escrito consta de varias cuestiones de desarrollo sobre la materia impartida. Por tratarse de una asignatura descriptiva no hay problemas numéricos que resolver.
Hay una práctica de laboratorio, que se desarrollará en el simulador de la Central Nuclear de José Cabrera, ubicado en el departamento. Por sus características (baja potencia y un solo lazo), se asemeja a un reactor SMR tipo PWR, por tanto se simularán situaciones operacionales que también se dan en este tipo de reactores.
El último día de clase hay un debate obligatorio para la evaluación continua en el que se discutirá una estrategia energética basada en reactores avanzados para el caso español. Los detalles de la realización de esta actividad se darán durante el curso."""@es ;
    ns1:hasEvaluationTrial <https://guia-kg.skai.etsisi.upm.es/resource/53002037/2025-26/evaluation/trial1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53002037/2025-26/evaluation/trial2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53002037/2025-26/evaluation/trial3>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53002037/2025-26/evaluation/trial4>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53002037/2025-26/evaluation/trial5> .

