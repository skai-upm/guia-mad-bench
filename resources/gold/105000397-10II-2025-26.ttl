<https://guia-kg.skai.etsisi.upm.es/resource/105000397/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/105000397/2025-26/Ce%2019/20> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/105000397/2025-26/didactic_resource/1>,
