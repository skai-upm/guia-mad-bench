    ns1:learningResultCode "RA48" ;
    ns1:learningResultDescription "Presentar de forma veraz, clara y apropiada, estadísticamente hablando, dichas conclusiones."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003036/2025-26/RA60> a ns1:LearningResult ;
    ns1:learningResultCode "RA60" ;
    ns1:learningResultDescription "Conocer la normativa ambiental vigente en gestión de residuos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003036/2025-26/RA62> a ns1:LearningResult ;
    ns1:learningResultCode "RA62" ;
    ns1:learningResultDescription "Capacidad para analizar el ciclo de vida de los materiales, y gestionar productos de acuerdo a la normativa ambiental vigente"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003036/2025-26/RA77> a ns1:LearningResult ;
    ns1:learningResultCode "RA77" ;
    ns1:learningResultDescription "Conocimiento de los sistemas de certificación y de las normas que rigen los Sistemas de Gestión Ambiental."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003036/2025-26/RA81> a ns1:LearningResult ;
    ns1:learningResultCode "RA81" ;
    ns1:learningResultDescription "Identificación y valoración de los distintos impactos ambientales asociados a un proyecto, de acuerdo a la normativa europea, nacional y autonómica vigentes"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003036/2025-26/RA82> a ns1:LearningResult ;
    ns1:learningResultCode "RA82" ;
    ns1:learningResultDescription "Aplicación correcta de las distintas herramientas e indicadores en el estudio del impacto ambiental tanto en la prevención como en la corrección"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003036/2025-26/RA83> a ns1:LearningResult ;
