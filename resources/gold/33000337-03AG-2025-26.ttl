    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/33000337/2025-26/eventSchedule> ;
    schema:description "La asignatura recorre la historia de los modos de construir, buscando la reflexión crítica activa del estudiante sobre la justificación de los procedimientos y las formas resultantes en función de las circunstancias de cada momento histórico. Se asume la explicación monográfica del uso de materiales (madera, hierro, hormigón) en la asignatura Sistemas constructivos."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/enrique.rabasa%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/ana.lopez.mozo%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/enrique.rabasa%40upm.es> ;
    schema:name "Historia de la Construccion"@es .

