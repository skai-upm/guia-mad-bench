    ns1:inpersonHours "36 horas y 5 minutos (46.3%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation """La asignatura está diseñada para la evaluaciónprogresiva, desarrollándose en el aula numerosas actividades de aplicación de los contenidos del programa. A lo largo del curso se realizarán trabajos colaborativos, ejercicios, cuestionarios en Moodle, pruebas de aplicación y evaluación. No se recomienda la Evaluación global debido al carácter técnico y al enfoque práctico de la asignatura.
La asignatura se relaciona con el ODS 7 (Energía asequible y no contaminante), con el ODS 8 (Trabajo decente y crecimiento económico) y con el ODS 9 (Industria, innovación e infraestructuras)"""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "36 horas y 5 minutos"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/63000154/2025-26/eventSchedule> ;
    schema:description """La asignatura presenta una visión actual de la seguridad industrial, incluyendo los fundamentos generales de la evaluación de riesgos y su aplicación a diversos sectores industriales.
Se presentan las reglamentaciones europeas y nacionales y se plantean los principios básicos y las soluciones técnicas aplicables a la seguridad en las industrias con presencia de sustancias capaces de generar atmósferas explosivas."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/javier.garciat%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/b.castells%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/david.leon.ruiz%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/isabel.amez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/javier.garciat%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/liliana.medic%40upm.es> ;
    schema:name "Seguridad Industrial en Atmósferas Explosivas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000154/2025-26/CE08> a ns1:Competency ;
    ns1:competencyCode "CE08" ;
    ns1:competencyDescription "Capacidad para proyectar y ejecutar instalaciones de transporte, distribución y almacenamiento de sólidos, líquidos y gases"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000154/2025-26/CG01> a ns1:Competency ;
    ns1:competencyCode "CG01" ;
    ns1:competencyDescription "Capacitación científico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000154/2025-26/CG02> a ns1:Competency ;
    ns1:competencyCode "CG02" ;
    ns1:competencyDescription "Comprensión de los múltiples condicionamientos de carácter técnicos, legal y de la propiedad que se plantean en el proyectos de una planta o instalación, y capacidad para establecer diferentes alternativas válidas, elegir la óptima y plasmarla adecuadamente, previendo los problemas de su desarrollo, y empleando los métodos y tecnologías más adecuadas, tanto tradicionales como innovadores, con la finalidad de conseguir la mayor eficacia y favorecer el progreso y un desarrollo de la sociedad sostenible y respetuoso con el medio ambiente"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000154/2025-26/CG12> a ns1:Competency ;
    ns1:competencyCode "CG12" ;
    ns1:competencyDescription "Capacidad para proyectar y ejecutar instalaciones de transporte, distribución y almacenamiento de sólidos, líquidos y gases."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000154/2025-26/CT03> a ns1:Competency ;
    ns1:competencyCode "CT03" ;
    ns1:competencyDescription "Capacidad para adoptar soluciones creativas que satisfagan adecuadamente las diferentes necesidades planteadas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000154/2025-26/CT04> a ns1:Competency ;
    ns1:competencyCode "CT04" ;
    ns1:competencyDescription "Capacidad para trabajar de forma efectiva como individuo, organizando y planificando su propio trabajo, de forma independiente o como miembro de un equipo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000154/2025-26/CT05> a ns1:Competency ;
    ns1:competencyCode "CT05" ;
    ns1:competencyDescription "Capacidad para gestionar la información, identificando las fuentes necesarias, los principales tipos de documentos técnicos y científicos, de una manera adecuada y eficiente"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000154/2025-26/RA100> a ns1:LearningResult ;
    ns1:learningResultCode "RA100" ;
    ns1:learningResultDescription "Aplicar las técnicas de análisis y evaluación de riesgos a industrias con riesgo de incendio y explosión"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000154/2025-26/RA101> a ns1:LearningResult ;
    ns1:learningResultCode "RA101" ;
    ns1:learningResultDescription "Aplicar las reglamentaciones específicas a instalaciones con riesgo de atmósfera explosiva"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000154/2025-26/RA102> a ns1:LearningResult ;
    ns1:learningResultCode "RA102" ;
    ns1:learningResultDescription "Diseñar conjuntos de medidas de prevención y protección contra el riesgo de explosión"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000154/2025-26/RA99> a ns1:LearningResult ;
    ns1:learningResultCode "RA99" ;
    ns1:learningResultDescription "Analizar las situaciones industriales en las que se pueden formar atmósferas explosivas"@es .

