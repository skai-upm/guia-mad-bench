    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/33000835/2025-26/eventSchedule> ;
    schema:description "En esta primera asignatura de la materia introductoria se estudian los fundamentos del Patrimonio Cultural y su historia, la naturaleza de su gestión, con los siguientes aspectos: definición del concepto moderno de Patrimonio Cultural y sus caracteres básicos, historia de la gestión del Patrimonio Cultural desde finales del siglo XIX hasta el momento actual, análisis de la evolución de las distintas teorías aplicables o aplicadas al tratamiento de los bienes culturales, presentación de la normativa al respecto, explicación y análisis de los distintos tipos de Patrimonio Cultural y de los modelos de gestión empleados para los bienes muebles, para los inmuebles y para los inmateriales y, finalmente, una serie de ejemplos concretos para analizar: ciudades históricas, sitios arqueológicos y manifestaciones inmateriales."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/jorge.bernabeu%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/jorge.bernabeu%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/patricia.hlamas%40upm.es> ;
    schema:name "Conceptos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000835/2025-26/CE01> a ns1:Competency ;
    ns1:competencyCode "CE01" ;
    ns1:competencyDescription "Distinguir cuáles han sido las consecuencias para el Patrimonio Cultural, de la sucesión de conceptos y normativas a lo largo de los dos últimos siglos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000835/2025-26/CG01> a ns1:Competency ;
    ns1:competencyCode "CG01" ;
    ns1:competencyDescription "Identificar los principios básicos del Patrimonio Cultural, de su gestión y de su investigación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000835/2025-26/CG02> a ns1:Competency ;
    ns1:competencyCode "CG02" ;
    ns1:competencyDescription "Analizar los distintos modelos de gestión empleados en la tutela de los bienes culturales con una orientación crítica y proactiva"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000835/2025-26/CG05> a ns1:Competency ;
    ns1:competencyCode "CG05" ;
    ns1:competencyDescription "Distinguir entre los distintos tipos de Patrimonios específicos, muy en especial el mueble, inmueble e inmaterial, aplicando los modelos de gestión e investigación adecuados para cada uno de ellos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000835/2025-26/CT01> a ns1:Competency ;
    ns1:competencyCode "CT01" ;
    ns1:competencyDescription "Analizar y sintetizar la información disponible y/o los resultados obtenidos, en un trabajo de investigación, en el ámbito que aquí compete"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000835/2025-26/CT02> a ns1:Competency ;
    ns1:competencyCode "CT02" ;
    ns1:competencyDescription "Desarrollar el proceso marcado por el método científico en el planteamiento y en la realización de trabajos de investigación y/o profesionales diversos, fomentando el espíritu crítico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000835/2025-26/CT04> a ns1:Competency ;
    ns1:competencyCode "CT04" ;
    ns1:competencyDescription "Organizar y planificar sistemas de gestión adecuados para el Patrimonio Cultural en cada una de sus especialidades"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000835/2025-26/CT10> a ns1:Competency ;
    ns1:competencyCode "CT10" ;
    ns1:competencyDescription "Desarrollar una capacidad permanente de compromiso ético y de respeto, en lo que se refiere al bienestar de la ciudadanía y al medio ambiente"@es .

