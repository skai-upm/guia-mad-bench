    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/33000840/2025-26/eventSchedule> ;
    schema:description """Esta materia es una aproximación a los principios, las condiciones y métodos de cualquier investigación científica, así como su desarrollo y aplicación al caso del Patrimonio Cultural. Igualmente se formará al estudiantado para hacer la carrera investigadora y el contexto en que ésta se desenvuelve, presentando especial atención a la publicación científica y al trabajo en equipo.
Como en otros campos de la gestión, las tecnologías de la información y las comunicaciones (TIC) facilitan un conjunto de nuevas oportunidades en el ámbito del Patrimonio Cultural que van desde el uso de las redes hasta todo tipo de nuevas aplicaciones y contenidos que facilitan la investigación. Se buscará su experimentación a través de la difusión en redes del Máster y sus actividades.
Este módulo tiene como antecedente varios proyectos de innovación docente y sigue una línea de aprendizaje basado en proyectos.
Se busca cubrir un hueco entre la formación básica universitaria y la más especializada, que supone ya experiencias prácticas vinculadas al contacto con agentes sociales vinculados con el patrimonio cultural.
Además, pretende generar relaciones más cooperativas entre el estudiantado basando la producción de propuestas a través del conocimiento colectivo, que son incentivadas desde la creatividad y la presentación pública de carácter lúdico con el uso de metodologías de aprendizaje por proyectos."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/nicolas.marine%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/anabelen.berrocal%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/m.fernandez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/nicolas.marine%40upm.es> ;
    schema:name "Introducción a la Investigación en Patrimonio Cultural y su Gestión"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000840/2025-26/CB06> a ns1:Competency ;
    ns1:competencyCode "CB06" ;
    ns1:competencyDescription "Poseer y comprender conocimientos que aporten una base u oportunidad de ser originales en el desarrollo y/o aplicación de ideas, a menudo en un contexto de investigación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000840/2025-26/CB07> a ns1:Competency ;
    ns1:competencyCode "CB07" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en entornos nuevos o poco conocidos dentro de contextos más amplios (o multidisciplinares) relacionados con su área de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000840/2025-26/CB08> a ns1:Competency ;
    ns1:competencyCode "CB08" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de integrar conocimientos y enfrentarse a la complejidad de formular juicios a partir de una información que, siendo incompleta o limitada, incluya reflexiones sobre las responsabilidades sociales y éticas vinculadas a la aplicación de sus conocimientos y juicios"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000840/2025-26/CB09> a ns1:Competency ;
    ns1:competencyCode "CB09" ;
    ns1:competencyDescription "Que los estudiantes sepan comunicar sus conclusiones y los conocimientos y razones últimas que las sustentan a públicos especializados y no especializados de un modo claro y sin ambigüedades"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000840/2025-26/CB10> a ns1:Competency ;
    ns1:competencyCode "CB10" ;
    ns1:competencyDescription "Que los estudiantes posean las habilidades de aprendizaje que les permitan continuar estudiando de un modo que habrá de ser en gran medida autodirigido o autónomo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000840/2025-26/CG02> a ns1:Competency ;
    ns1:competencyCode "CG02" ;
    ns1:competencyDescription "Analizar los distintos modelos de gestión empleados en la tutela de los bienes culturales con una orientación crítica y proactiva"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000840/2025-26/CG06> a ns1:Competency ;
    ns1:competencyCode "CG06" ;
    ns1:competencyDescription "Identificar y analizar los ámbitos y los contextos en los que se sitúan o deben situarse las iniciativas sociales a favor del Patrimonio Cultural"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000840/2025-26/CG13> a ns1:Competency ;
    ns1:competencyCode "CG13" ;
    ns1:competencyDescription "Resolver problemas interconectados con las diferentes disciplinas con las que se relaciona la gestión y la investigación del Patrimonio Cultural"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000840/2025-26/CG17> a ns1:Competency ;
    ns1:competencyCode "CG17" ;
    ns1:competencyDescription "Desarrollar instrumentos de protección y salvaguarda del Patrimonio Cultural"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000840/2025-26/CT01> a ns1:Competency ;
    ns1:competencyCode "CT01" ;
    ns1:competencyDescription "Analizar y sintetizar la información disponible y/o los resultados obtenidos, en un trabajo de investigación, en el ámbito que aquí compete"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000840/2025-26/CT04> a ns1:Competency ;
    ns1:competencyCode "CT04" ;
    ns1:competencyDescription "Organizar y planificar sistemas de gestión adecuados para el Patrimonio Cultural en cada una de sus especialidades"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000840/2025-26/CT06> a ns1:Competency ;
    ns1:competencyCode "CT06" ;
    ns1:competencyDescription "Analizar adecuadamente la bibliografía y recopilar referencias en el área de la gestión e investigación del Patrimonio Cultura"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000840/2025-26/RA49> a ns1:LearningResult ;
    ns1:learningResultCode "RA49" ;
    ns1:learningResultDescription "Recopilar e identificar las nociones básicas sobre la ciencia y la profesionalidad del tema."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000840/2025-26/RA50> a ns1:LearningResult ;
    ns1:learningResultCode "RA50" ;
    ns1:learningResultDescription "Examinar el propósito de su investigación sobre el tema del máster, a partir de sus propios intereses profesionales y personales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000840/2025-26/RA51> a ns1:LearningResult ;
    ns1:learningResultCode "RA51" ;
    ns1:learningResultDescription "Reconocer los recursos y estrategias básicas para ser especialista en investigación de la Gestión de Patrimonio Cultural."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000840/2025-26/RA52> a ns1:LearningResult ;
    ns1:learningResultCode "RA52" ;
    ns1:learningResultDescription "Revisar las metodologías de investigación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000840/2025-26/RA53> a ns1:LearningResult ;
    ns1:learningResultCode "RA53" ;
    ns1:learningResultDescription "Presentar de manera estructurada un proyecto de investigación, así como su trabajo fin de máster"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000840/2025-26/RA54> a ns1:LearningResult ;
    ns1:learningResultCode "RA54" ;
    ns1:learningResultDescription "Demostrar ser capaz de hacer una recensión, una comunicación y un artículo científico. Reonocer el proceso de valoración y evaluación de los artículos científicos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000840/2025-26/RA55> a ns1:LearningResult ;
    ns1:learningResultCode "RA55" ;
    ns1:learningResultDescription "Identificar los géneros y tipologías textuales más frecuentes en el ámbito del Patrimonio Cultural."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000840/2025-26/RA56> a ns1:LearningResult ;
    ns1:learningResultCode "RA56" ;
    ns1:learningResultDescription "Valorar el trabajo en equipo, como forma básica para avanzar hoy en la ciencia."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000840/2025-26/RA57> a ns1:LearningResult ;
    ns1:learningResultCode "RA57" ;
    ns1:learningResultDescription "Experimentar con las iniciativas de hablar en público, intervenir en debates y defender posturas científicas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000840/2025-26/RA58> a ns1:LearningResult ;
    ns1:learningResultCode "RA58" ;
    ns1:learningResultDescription "Resolver un proyecto de investigación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000840/2025-26/RA59> a ns1:LearningResult ;
    ns1:learningResultCode "RA59" ;
    ns1:learningResultDescription "Identificar una visión estratégica sobre el impacto de las TIC en el ámbito del Patrimonio Cultural."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000840/2025-26/RA60> a ns1:LearningResult ;
    ns1:learningResultCode "RA60" ;
    ns1:learningResultDescription "Reconocer los conceptos fundamentales de las TIC aplicadas al Patrimonio Cultural"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000840/2025-26/RA61> a ns1:LearningResult ;
    ns1:learningResultCode "RA61" ;
    ns1:learningResultDescription "Reconocer las principales aplicaciones prácticas de las TIC al ámbito del Patrimonio Cultural y disponer de la capacidad de enfrentar casos concretos de uso"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000840/2025-26/RA62> a ns1:LearningResult ;
    ns1:learningResultCode "RA62" ;
    ns1:learningResultDescription "Desarrollar una visión que comprenda tanto las infraestructuras como los servicios y aplicaciones y que permita construir sobre estos elementos soluciones de interés en el ámbito del Patrimonio Cultural, en particular desde una perspectiva de innovación abierta"@es .

