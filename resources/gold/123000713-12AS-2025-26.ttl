<https://guia-kg.skai.etsisi.upm.es/resource/123000713/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Introducción."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/123000713/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Introducción y conceptos asociados a los deslizamientos de taludes y laderas y efectos sísmicos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/123000713/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "5. Algoritmos de dirección de flujo sobre modelos digitales de elevación (MDE) para estimar movilidad de deslizamientos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/123000713/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "6. Modelos numéricos que permiten analizar tanto el proceso de iniciación de un deslizamiento (mecanismo rotura) como su propagación (mecanismo post-rotura). Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/123000713/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "7. Efectos ambientales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/123000713/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "7.1. Balsas de residuos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/123000713/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "7.2. Vertederos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/123000713/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "7.3. Fracturas, grietas y fallamiento. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/123000713/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "7.4. Análisis de la susceptibilidad a la ruptura superficial. Escala macrosísmica ESI07. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/123000713/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Características y clasificación de deslizamientos inducidos por sismos: relación magnitud terremoto, tipo de inestabilidad, área afectada y volumen movilizado. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/123000713/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "1.3. Mapas de susceptibilidad de deslizamientos inducidos por sismos: estimación del Factor de seguridad y Aceleración crítica. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/123000713/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "2. Análisis de susceptibilidad y peligrosidad de deslizamientos mediante el método del Desplazamiento de Newmark"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/123000713/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "2.1. El análisis de la susceptibilidad mediante métodos analíticos: análisis pseudoestático y estimación del coeficiente sísmico. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/123000713/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "3. Introducción y conceptos asociados a la licuefacción y movilidad cíclica."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/123000713/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "3.1. Daños producidos por procesos de licuefacción y movilidad cíclica. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/123000713/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "4. Ensayos de laboratorio para la estimación del potencial de licuefacción."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/123000713/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "4.1. Materiales geológicos susceptibles al proceso de licuefacción: Factores Geológicos, Físicos, Geotécnicos e Hidrogeológicos. Evaluación del Potencial (susceptibilidad) de licuefacción. Sin subniveles"@es .

