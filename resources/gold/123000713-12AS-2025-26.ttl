    schema:courseCode 123000713 ;
    schema:hasCourseInstance <https://guia-kg.skai.etsisi.upm.es/resource/123000713/2025-26> ;
    schema:name "Landslides, Liquefaction And Environmental Effects"@en,
        "Deslizamientos, Licuefacción y Efectos Ambientales"@es ;
    schema:numberOfCredits 4.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/123000713/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/123000713/2025-26/C11>,
        <https://guia-kg.skai.etsisi.upm.es/resource/123000713/2025-26/K3> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/123000713/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/123000713/2025-26/didactic_resource/2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/123000713/2025-26/didactic_resource/3> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/123000713/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/123000713/2025-26/RA1> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/123000713/2025-26/syllabus> ;
    ns1:inpersonHours "80 horas (74.1%)"@es ;
    ns1:numberOfCredits 4.0 ;
    ns1:otherInformation """Esta asignatura es impartida por profesores de la ETSI de Caminos, Canales y Puertos de la Universidad Politécnica de Madrid. El profesor coordinador que aparece en la guía de aprendizaje de la asignatura es sólo a efectos administrativos, el profesor responsable de la docencia de esta asignatura (contenidos y evaluación) es la profesor Rubén Galindo de dicha Escuela.
Esta asignatura se imparte de forma intensiva durante aproximadamente 4 semanas en clases de 5 horas."""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "82 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/123000713/2025-26/eventSchedule> ;
    schema:description "La asignatura Deslizamientos, licuefacción y efectos ambientales persigue transferir los conocimientos necesarios para adquirir las competencias necesarias para abordar el riesgo asociado a fenómenos derivados de un terremoto, como son la amplificación dinámica, la licuefacción, la movilidad cíclica, los deslizamientos de ladera y la ruptura superficial que, a pesar de ser efectos indirectos, son los que generan en determinadas regiones el mayor volumen de daños. Para ello es necesario conocer las distintas tipologías de fenómenos secundarios y su relación con la geología-geotecnia y magnitud y/o intensidad del terremoto. Por ello, el objetivo principal se centra en proveer al estudiante de las competencias necesarias para determinar los parámetros de interés y preparar esos datos necesarios para el análisis de susceptibilidad y/o peligrosidad a escala regional y local mediante herramientas geoespaciales (SIG), estudios analíticos, estocásticos y numéricos."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/rubenangel.galindo%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/angel.yague%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/d.manzanal%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/mariateresa.mateos%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/miguel.martins%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/rubenangel.galindo%40upm.es> ;
    schema:name "Deslizamientos, Licuefacción y Efectos Ambientales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/123000713/2025-26/C11> a ns1:Competency ;
    ns1:competencyCode "C11" ;
    ns1:competencyDescription "Gestión de la información.Capacidad de recopilar, generar, analizar, procesar, transformar, almacenar y seleccionar la información relevante para el desarrollo de las actividades de investigación o profesionales.TIPO: Competencias."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/123000713/2025-26/K3> a ns1:Competency ;
    ns1:competencyCode "K3" ;
    ns1:competencyDescription "Evaluar los riesgos derivados de un terremoto: deslizamientos y tsunamis.TIPO: Conocimientos o contenidos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/123000713/2025-26/RA1> a ns1:LearningResult ;
    ns1:learningResultCode "RA1" ;
    ns1:learningResultDescription "Este plan está adaptado al RD 822/2021.Los resultados del aprendizaje correspondientes a esta asignatura han quedado definidos en el apartado de competencias de este documento, señalando los que corresponden a conocimientos, habilidades y competencias propiamente dichas."@es .

