        <https://guia-kg.skai.etsisi.upm.es/resource/85004954/2025-26/CT%20UPM%204> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/85004954/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/85004954/2025-26/didactic_resource/2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/85004954/2025-26/didactic_resource/3>,
        <https://guia-kg.skai.etsisi.upm.es/resource/85004954/2025-26/didactic_resource/4> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/85004954/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/85004954/2025-26/RA1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/85004954/2025-26/RA43>,
        <https://guia-kg.skai.etsisi.upm.es/resource/85004954/2025-26/RA44>,
        <https://guia-kg.skai.etsisi.upm.es/resource/85004954/2025-26/RA46>,
        <https://guia-kg.skai.etsisi.upm.es/resource/85004954/2025-26/RA8> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/85004954/2025-26/syllabus> ;
    ns1:inpersonHours "46 horas (39.3%)"@es ;
    ns1:numberOfCredits 4.5 ;
    ns1:otherInformation ""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "46 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/85004954/2025-26/eventSchedule> ;
    schema:description """Se pretende que los alumnos conozcan y apliquen distintas técnicas numéricas con el objetivo de realizar simulación de fluidos, y que tiene aplicación al cálculo y optimización de carenas, hélices y otros objetos flotantes en el campo naval. Se comenzará con una revisión de los conceptos fundamentales de la Hidrodinámica: ecuaciones de Euler y de Navier-Stokes.
Se hará especial énfasis en aplicaciones con flujo multifásico utilizando el método de volumen de fluido (VOF). Los conocimientos teóricos se aplicarán de forma práctica mediante distintos códigos, que tendrán en común ser de carácter abierto (OpenFOAM, Python, etc.), y en el entorno abierto Linux, a través de casos estándar en la mecánica de fluidos computacional."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/daniel.duque%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/daniel.duque%40upm.es> ;
    schema:name "Simulación de Fluidos con Código Abierto"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85004954/2025-26/CE4> a ns1:Competency ;
    ns1:competencyCode "CE4" ;
    ns1:competencyDescription "Conocimientos básicos sobre el uso y programación de los ordenadores, sistemas operativos, bases de datos y programas informáticos con aplicación en ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85004954/2025-26/CE5> a ns1:Competency ;
    ns1:competencyCode "CE5" ;
    ns1:competencyDescription "Capacidad de visión espacial y conocimiento de las técnicas de representación gráfica, tanto por métodos tradicionales de geometría métrica y geometría descriptiva, como mediante las aplicaciones de diseño asistido por ordenador."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85004954/2025-26/CE7> a ns1:Competency ;
    ns1:competencyCode "CE7" ;
    ns1:competencyDescription "Conocimiento de los conceptos fundamentales de la mecánica de fluidos y de su aplicación a las carenas de buques y artefactos, y a las máquinas, equipos y sistemas navales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85004954/2025-26/CT%20UPM%204> a ns1:Competency ;
    ns1:competencyCode "CT UPM 4" ;
    ns1:competencyDescription "Uso de las TIC"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85004954/2025-26/RA1> a ns1:LearningResult ;
    ns1:learningResultCode "RA1" ;
    ns1:learningResultDescription "Resolver problemas de mecánica, mecánica de fluidos, oscilaciones y ondas relacionados con la ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85004954/2025-26/RA43> a ns1:LearningResult ;
    ns1:learningResultCode "RA43" ;
    ns1:learningResultDescription "Escribir un programa básico implementando algoritmos para resolución de problemas de aplicación en ingeniería naval"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85004954/2025-26/RA44> a ns1:LearningResult ;
    ns1:learningResultCode "RA44" ;
    ns1:learningResultDescription "Entender un programa informático"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85004954/2025-26/RA46> a ns1:LearningResult ;
    ns1:learningResultCode "RA46" ;
    ns1:learningResultDescription "Conocer cómo usar programas para visualizar los resultados de cálculos, tendencias estadísticas y otras aplicaciones en ingeniería"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85004954/2025-26/RA8> a ns1:LearningResult ;
    ns1:learningResultCode "RA8" ;
    ns1:learningResultDescription "Resolver problemas sencillos de hidrodinámica."@es .

