    schema:name "Open-Source Computational Fluid Dynamics (Cfd)"@en,
        "Simulación de Fluidos con Código Abierto"@es ;
    schema:numberOfCredits 4.5 .

<https://guia-kg.skai.etsisi.upm.es/resource/85004954/2025-26> a ns1:CourseGuide ;
