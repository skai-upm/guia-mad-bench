    schema:name "Tecnicas de Procesado de Materiales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000136/2025-26/CE13> a ns1:Competency ;
    ns1:competencyCode "CE13" ;
    ns1:competencyDescription "Capacidad para planificar, diseñar y gestionar instalaciones de tratamientos de recursos minerales, plantas metalúrgicas, siderúrgicas e industrias de materiales de construcción, incluyendo materiales metálicos, cerámicos, sinterizados, refractarios y otros."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000136/2025-26/CG10> a ns1:Competency ;
    ns1:competencyCode "CG10" ;
    ns1:competencyDescription "Capacidad para planificar, diseñar y gestionar instalaciones de beneficio de recursos minerales y plantas metalúrgicas, siderúrgicas e industrias de materiales de construcción"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000136/2025-26/CG19> a ns1:Competency ;
    ns1:competencyCode "CG19" ;
    ns1:competencyDescription "Capacidad para planificar, diseñar y gestionar plantas de tratamiento de minerales metalúrgicos y siderúrgicos e instalaciones de procesado de materiales metálicos, cerámicos, sinterizados, refractarios y otros."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000136/2025-26/CT03> a ns1:Competency ;
    ns1:competencyCode "CT03" ;
    ns1:competencyDescription "Capacidad para adoptar soluciones creativas que satisfagan adecuadamente las diferentes necesidades planteadas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000136/2025-26/CT04> a ns1:Competency ;
    ns1:competencyCode "CT04" ;
    ns1:competencyDescription "Capacidad para trabajar de forma efectiva como individuo, organizando y planificando su propio trabajo, de forma independiente o como miembro de un equipo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000136/2025-26/CT05> a ns1:Competency ;
    ns1:competencyCode "CT05" ;
    ns1:competencyDescription "Capacidad para gestionar la información, identificando las fuentes necesarias, los principales tipos de documentos técnicos y científicos, de una manera adecuada y eficiente"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000136/2025-26/RA50> a ns1:LearningResult ;
    ns1:learningResultCode "RA50" ;
    ns1:learningResultDescription "Conocer las técnicas avanzadas en el tratamiento de minerales y el procesado de materiales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000136/2025-26/RA53> a ns1:LearningResult ;
    ns1:learningResultCode "RA53" ;
    ns1:learningResultDescription "Conocer los criterios de selección de materiales y de sus procesos de fabricación y procesado"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000136/2025-26/RA54> a ns1:LearningResult ;
    ns1:learningResultCode "RA54" ;
    ns1:learningResultDescription "Aplicar las técnicas de planificación, diseño y gestión a instalaciones de procesado de materiales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000136/2025-26/RA97> a ns1:LearningResult ;
    ns1:learningResultCode "RA97" ;
    ns1:learningResultDescription "Conocer las técnicas de pulvimetaúrgicas de obtención de metales, cerámicas técnicas y Materiales compuestos que se obtienen por estas técnicas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000136/2025-26/RA98> a ns1:LearningResult ;
    ns1:learningResultCode "RA98" ;
    ns1:learningResultDescription "Diseñar las composiciones y las condiciones de fabricación de los distintos materiales sinterizados"@es .

