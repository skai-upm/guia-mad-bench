    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/63000136/2025-26/eventSchedule> ;
    schema:description "El objetivo de la asignatura es el estudio de las técnicas de procesado de los materiales metálicos, cerámicos y poliméricos así com la relación entre el procesado y las propiedades del material."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/teresa.palacios%40upm.es> ;
