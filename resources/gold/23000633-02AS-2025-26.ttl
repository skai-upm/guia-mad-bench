<https://guia-kg.skai.etsisi.upm.es/resource/23000633/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Introducción a la bioinformática. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000633/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "2. Bases de datos bibliográficas. Bases de datos de genes y proteínas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000633/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "11. Programación y simulaciones usando R. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000633/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "3. Algoritmos de alineamiento de secuencias. Búsquedas en bases de datos de secuencias. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000633/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "4. Bases de datos de dominios y familias de proteínas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000633/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "5. Bases de datos de estructuras 3D en proteínas. Predicción y visualización estructura-función en proteínas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000633/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "6. Bases de datos genómicos. Plataforma Galaxy. Ensamblaje y anotación genómica de novo. Identificación de genes y variantes de interés. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000633/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "7. Herramientas en metagenómica y análisis de microbiomas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000633/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "8. Introducción al lenguaje R. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000633/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "9. Visualización y análisis estadístico en R. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000633/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "10. Análisis de datos genómicos usando R. Sin subniveles"@es .

