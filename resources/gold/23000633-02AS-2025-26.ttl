<https://guia-kg.skai.etsisi.upm.es/resource/23000633/2025-26/RA76> a ns1:LearningResult ;
    ns1:learningResultCode "RA76" ;
    ns1:learningResultDescription "Conocer las principales bases de datos biológicos públicas y saber acceder a la información necesaria para realizar cualquier análisis bioinformático"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000633/2025-26/RA77> a ns1:LearningResult ;
    ns1:learningResultCode "RA77" ;
    ns1:learningResultDescription "Ser capaz de construir correctamente un alineamiento de secuencias, y de utilizarlo para realizar búsquedas en bases de datos públicas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000633/2025-26/RA78> a ns1:LearningResult ;
    ns1:learningResultCode "RA78" ;
    ns1:learningResultDescription "Saber manejar ficheros y bases de datos de gran tamaño"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000633/2025-26/RA79> a ns1:LearningResult ;
