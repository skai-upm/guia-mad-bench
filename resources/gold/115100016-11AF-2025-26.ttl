        <https://guia-kg.skai.etsisi.upm.es/resource/rocio.cupeiro%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/sofia.peregrina%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/thomas.yvert%40upm.es> ;
    schema:name "Kinesiología y Sistemática de la Afyd"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100016/2025-26/CE01> a ns1:Competency ;
    ns1:competencyCode "CE01" ;
    ns1:competencyDescription "Diseñar, desarrollar y evaluar los procesos de enseñanza¿aprendizaje relativos a la actividad física y el deporte con atención a las características individuales y contextuales de las personas. Nivel 3."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100016/2025-26/CE02> a ns1:Competency ;
    ns1:competencyCode "CE02" ;
    ns1:competencyDescription "Aplicar, de manera fundamentada y argumentada, los principios fisiológicos, biomecánicos, comportamentales y sociales en el diseño y puesta en práctica de propuestas y programas de Educación Física en el contexto educativo. Nivel 3."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100016/2025-26/CE08> a ns1:Competency ;
    ns1:competencyCode "CE08" ;
    ns1:competencyDescription "Aplicar de manera fundamentada y argumentada los principios fisiológicos, biomecánicos, comportamentales y sociales, durante la dirección del entrenamiento deportivo. Nivel 3."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100016/2025-26/CG02> a ns1:Competency ;
    ns1:competencyCode "CG02" ;
    ns1:competencyDescription "Desarrollar habilidades y estrategias que incidan en la capacidad para trabajar en forma autónoma."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100016/2025-26/CG05> a ns1:Competency ;
    ns1:competencyCode "CG05" ;
    ns1:competencyDescription "Gestionar con eficacia y eficiencia la información procedente de diferentes fuentes integrando sus aspectos relevantes para el cumplimiento de los objetivos propuestos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100016/2025-26/RA188> a ns1:LearningResult ;
    ns1:learningResultCode "RA188" ;
    ns1:learningResultDescription "Conocer las características del ejercicio físico, los criterios para su clasificación, la terminología específica, así como la descripción y representación gráfica del mismo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100016/2025-26/RA189> a ns1:LearningResult ;
    ns1:learningResultCode "RA189" ;
    ns1:learningResultDescription "Saber realizar el análisis mecánico de cualquier ejercicio físico, entendiendo las características articulares y musculares de cualquier movimiento humano."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100016/2025-26/RA190> a ns1:LearningResult ;
    ns1:learningResultCode "RA190" ;
    ns1:learningResultDescription "Identificar la función de cualquier ejercicio físico y saber aplicar los mismos para el desarrollo y mantenimiento de la condición física en cualquier ámbito y etapa de la vida."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100016/2025-26/RA22> a ns1:LearningResult ;
    ns1:learningResultCode "RA22" ;
    ns1:learningResultDescription "Incorporar e interpretar la terminología básica que permita una mayor comprensión de los contenidos específicos de otras asignaturas relacionadas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100016/2025-26/RA3> a ns1:LearningResult ;
    ns1:learningResultCode "RA3" ;
    ns1:learningResultDescription "Capacidad de análisis de las estructuras y sistemas del movimiento físico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100016/2025-26/RA4> a ns1:LearningResult ;
    ns1:learningResultCode "RA4" ;
    ns1:learningResultDescription "Conocimiento de los sistemas y bases del funcionamiento del cuerpo humano"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100016/2025-26/RA7> a ns1:LearningResult ;
