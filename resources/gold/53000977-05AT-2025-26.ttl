        <https://guia-kg.skai.etsisi.upm.es/resource/53000977/2025-26/didactic_resource/3> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/53000977/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/53000977/2025-26/RA47>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53000977/2025-26/RA48>,
