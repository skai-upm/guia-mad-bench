    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/43000536/2025-26/syllabus> ;
    ns1:inpersonHours "52 horas y 45 minutos (45.1%)"@es ;
    ns1:numberOfCredits 4.5 ;
    ns1:otherInformation "The course analyses sustainable development goals 8, 9, 10 and 12."@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "52 horas y 45 minutos"@es ;
    schema:activitiesWorkload "60%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/43000536/2025-26/eventSchedule> ;
    schema:description """The objectives of the course are:
To know in detail the key challenges of financing infrastructure and public services related to civil engineering systems from the:
Public sector point of view
Private sector point of view
To understand the budgetary constraints borne by many governments to promote infrastructure
To know the role of the EU in financing large-scale infrastructure in Europe.
To get familiar with sophisticated procurement mechanisms (specially PPPs)
To understand how to manage the most important risks in PPP projects
To get basic knowledge of the theory of finance
To learn to design project finance deals
To interact with professional people involved in real life projects through: Professional sessions, Group work."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/josemanuel.vassallo%40upm.es> ;
    schema:inLanguage "Inglés"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/josemanuel.vassallo%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/juan.gomez.sanchez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/natalia.sobrino%40upm.es> ;
    schema:name "Financiación de Infraestructuras y Servicios"@es .

