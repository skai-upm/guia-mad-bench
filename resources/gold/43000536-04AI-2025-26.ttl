    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/43000536/2025-26/MSICCE> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/43000536/2025-26/didactic_resource/1>,
