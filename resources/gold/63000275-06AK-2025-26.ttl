<https://guia-kg.skai.etsisi.upm.es/resource/63000275/2025-26/CE12> a ns1:Competency ;
    ns1:competencyCode "CE12" ;
    ns1:competencyDescription "Evaluar la interrelación entre el diseño de la explotación minera y los impactos en el entorno social y medioambiental; diseñar y evaluar el lay"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000275/2025-26/CE19> a ns1:Competency ;
    ns1:competencyCode "CE19" ;
    ns1:competencyDescription "Capacidad para zonificar el territorio con criterios de ordenación y aplicar los SIG en la evaluación de los factores culturales, sociales y ambientales asociados a las operaciones mineras, incluyendo el cierre de instalaciones, operaciones y emplazamientos mineros / Land zoning skills and application of GIS for the assessment of cultural, social and environmental factors connected with mining operations, including mine closing"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000275/2025-26/CE7> a ns1:Competency ;
    ns1:competencyCode "CE7" ;
    ns1:competencyDescription "Comprender los conceptos de ordenación territorial en su relación con las actividades mineras/ To understand the concepts of land management connected with mining activities"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000275/2025-26/CE9> a ns1:Competency ;
    ns1:competencyCode "CE9" ;
    ns1:competencyDescription "Aplicar los Sistemas de Información Geográfica a la minería / To apply Geographical Information Systems to mining"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000275/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Comprender el impacto de la Ingeniería Minera y la extracción de recursos minerales y energéticos en el medio ambiente, el desarrollo sostenible de la sociedad y la importancia de trabajar en un entorno profesional y responsable / To understand the impact that Mining of mineral and energetic resources has on the environment, the sustainable development of society and the importance of working in a professional and responsible environment."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000275/2025-26/CG4> a ns1:Competency ;
    ns1:competencyCode "CG4" ;
    ns1:competencyDescription "Capacity to learn in an international context and complex environments, multidisciplinary and bilingual (English"@es .

