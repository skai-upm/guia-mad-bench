    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation """Si el número de alumnos matriculados excediera la capacidad del aula de informática para la realización de las prácticas, se harán dos grupos de prácticas, teniendo que sacar, al menos a uno de ellos, del horario de mañana establecido.
La asignatura contempla de forma especial los Objetivos de Desarrollo Sostenible (ODS) establecidos por Naciones Unidas: ODS2, ODS12, ODS13, ODS14 y ODS15."""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "49 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/205000035/2025-26/eventSchedule> ;
    schema:description """La asignatura estudia los conceptos básicos de la Ecología y la Biodiversidad.
Desde la descripción del concepto de Biodiversidad, los factores que le afectan y las técnicas de estudio y determinación de la diversidad se irán desarrollando los conceptos básicos de Ecología: población, comunidad, ecosistema. En cada uno de esos niveles se profundizará en el estudio de factores clave como son el crecimiento de poblaciones, capacidad de extracción en función del crecimiento de poblaciones naturales, interacciones dentro de la comunidad (competencia, mutualismo, depredación, simbiosis.. ), estructura y energía dentro de un ecosistema."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/mariacarmen.martin%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/mariacarmen.martin%40upm.es> ;
    schema:name "Conceptos de Ecología y Biodiversidad"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000035/2025-26/CG10> a ns1:Competency ;
    ns1:competencyCode "CG10" ;
    ns1:competencyDescription "Familiarizarse con el estudio de las interrelaciones entre las distintas perspectivas ecológicas, tecnológicas, económicas y sociales en relación con las Ciencias Agrarias y la Bioeconomía."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000035/2025-26/CT09> a ns1:Competency ;
    ns1:competencyCode "CT09" ;
    ns1:competencyDescription "Tener capacidad de análisis y síntesis para interpretar datos relevantes y abordar los problemas desde diferentes perspectivas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000035/2025-26/RA113> a ns1:LearningResult ;
    ns1:learningResultCode "RA113" ;
    ns1:learningResultDescription "Conocer los principales procesos simbióticos y otros procesos de promoción del crecimiento vegetal que se establecen entre plantas y microorganismos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000035/2025-26/RA123> a ns1:LearningResult ;
    ns1:learningResultCode "RA123" ;
    ns1:learningResultDescription "Conocer la importancia de la variabilidad genética, su estima y su aplicación en estudios poblacionales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000035/2025-26/RA194> a ns1:LearningResult ;
    ns1:learningResultCode "RA194" ;
    ns1:learningResultDescription "Conocer y valorar los potenciales efectos contaminantes de los residuos y subproductos sobre los distintos ecosistemas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000035/2025-26/RA213> a ns1:LearningResult ;
    ns1:learningResultCode "RA213" ;
    ns1:learningResultDescription "Conocer los conceptos de ecosistema, comunidad, población, hábitat y nicho ecológico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000035/2025-26/RA214> a ns1:LearningResult ;
    ns1:learningResultCode "RA214" ;
    ns1:learningResultDescription "Conocer los principales modelos de crecimiento poblacional"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000035/2025-26/RA215> a ns1:LearningResult ;
    ns1:learningResultCode "RA215" ;
    ns1:learningResultDescription "Distinguir las principales interacciones entre poblaciones y comprender sus mecanismos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000035/2025-26/RA216> a ns1:LearningResult ;
    ns1:learningResultCode "RA216" ;
    ns1:learningResultDescription "Comprender el papel de las interacciones en los procesos evolutivos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000035/2025-26/RA217> a ns1:LearningResult ;
    ns1:learningResultCode "RA217" ;
    ns1:learningResultDescription "Comprender el concepto de biodiversidad"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000035/2025-26/RA218> a ns1:LearningResult ;
    ns1:learningResultCode "RA218" ;
    ns1:learningResultDescription "Conocer la influencia de las actividades humanas sobre los ecosistemas y la necesidad de proteger la biodiversidad"@es .

