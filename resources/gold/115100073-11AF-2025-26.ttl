<https://guia-kg.skai.etsisi.upm.es/resource/115100073/2025-26/CE01> a ns1:Competency ;
    ns1:competencyCode "CE01" ;
    ns1:competencyDescription "Diseñar, desarrollar y evaluar los procesos de enseñanza¿aprendizaje relativos a la actividad física y el deporte con atención a las características individuales y contextuales de las personas. Nivel 3."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100073/2025-26/CE16> a ns1:Competency ;
    ns1:competencyCode "CE16" ;
    ns1:competencyDescription "Seleccionar y saber utilizar el material y equipamiento deportivo, adecuado para cada tipo de actividad que practique la población de jóvenes, adultos, mayores y personas con discapacidad. Nivel 3."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100073/2025-26/CE19> a ns1:Competency ;
    ns1:competencyCode "CE19" ;
    ns1:competencyDescription "Elaborar programas para la dirección de organizaciones, entidades e instalaciones deportivas. Nivel 2."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100073/2025-26/CG08> a ns1:Competency ;
    ns1:competencyCode "CG08" ;
    ns1:competencyDescription "Aplicar los conocimientos adquiridos en los procesos de formación en la práctica profesional, en diferentes contextos y situaciones."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100073/2025-26/RA23> a ns1:LearningResult ;
    ns1:learningResultCode "RA23" ;
    ns1:learningResultDescription "Tomar una idea propia, individual y crítica sobre la utilización de los fármacos en el deporte, desarrollando la capacidad de adquirir información objetiva."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100073/2025-26/RA24> a ns1:LearningResult ;
    ns1:learningResultCode "RA24" ;
    ns1:learningResultDescription "Identificar y programar actividades en función de la composición corporal calculando el balance energético del individuo, proponiéndole actividades que puedan ser cuantificadas por el propio alumno."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100073/2025-26/RA25> a ns1:LearningResult ;
    ns1:learningResultCode "RA25" ;
    ns1:learningResultDescription "Desarrollar la capacidad de aplicar los conocimientos científicos en diferentes ámbitos de la actividad física, concretamente en las salas de fitness."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100073/2025-26/RA26> a ns1:LearningResult ;
    ns1:learningResultCode "RA26" ;
    ns1:learningResultDescription "Permitir la asimilación de contenidos en relación a la elección de equipamiento y responsabilidades que un graduado puede obtener en un centro deportivo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100073/2025-26/RA27> a ns1:LearningResult ;
    ns1:learningResultCode "RA27" ;
    ns1:learningResultDescription "Incorporar las capacidades prácticas en el alumno para su correcto trabajo en una sala de entrenamiento con cargas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100073/2025-26/RA28> a ns1:LearningResult ;
    ns1:learningResultCode "RA28" ;
    ns1:learningResultDescription "Comprender y establecer los mecanismos de colaboración en un equipo multidisciplinar para el tratamiento de patologías agudas y crónicas."@es .

