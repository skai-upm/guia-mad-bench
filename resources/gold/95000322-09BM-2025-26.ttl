    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. El entorno Matlab. Estructuras de datos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000322/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "3.3. Métodos de Newton-Raphson, la secante y regula falsi. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000322/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "4. Tema 4: Aproximación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000322/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "4.1. Aproximación discreta por mínimos cuadrados. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000322/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "5. Tema 5: Interpolación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000322/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "5.1. Interpolación 1D: Lagrange, Hermite, splines. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000322/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "6. Tema 6: Integración numérica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000322/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "6.1. Integración de Newton-Cotes. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000322/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "6.2. Cuadratura de Gauss. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000322/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "7. Tema 7: Resolución numérica de problemas de valor inicial y de problemas de valores iniciales y de contorno"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000322/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "7.1. Problemas de valor inicial: métodos unipaso Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000322/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Manejo de matrices. Control de flujo. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000322/2025-26/syllabus/20> a ns1:SyllabusItem ;
    ns1:itemIndex 20 ;
    ns1:syllabusDescription "7.2. Problemas de valores iniciales y de contorno: métodos de diferencias finitas Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000322/2025-26/syllabus/21> a ns1:SyllabusItem ;
    ns1:itemIndex 21 ;
    ns1:syllabusDescription "8. Tema 8: Elementos finitos para biomecánica: principios básicos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000322/2025-26/syllabus/22> a ns1:SyllabusItem ;
    ns1:itemIndex 22 ;
    ns1:syllabusDescription "8.1. Ecuación de difusión. Formulaciones fuerte y débil. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000322/2025-26/syllabus/23> a ns1:SyllabusItem ;
    ns1:itemIndex 23 ;
    ns1:syllabusDescription "8.2. Funciones de forma y Discretización mediante elementos finitos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000322/2025-26/syllabus/24> a ns1:SyllabusItem ;
    ns1:itemIndex 24 ;
    ns1:syllabusDescription "8.3. Interpolación de Galerkin. Ecuaciones matriciales y su resolución. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000322/2025-26/syllabus/25> a ns1:SyllabusItem ;
    ns1:itemIndex 25 ;
    ns1:syllabusDescription "8.4. Aplicación: problemas unidimensionales de difusión. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000322/2025-26/syllabus/26> a ns1:SyllabusItem ;
    ns1:itemIndex 26 ;
    ns1:syllabusDescription "9. Tema 9: Elementos finitos para biomecánica: problemas lineales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000322/2025-26/syllabus/27> a ns1:SyllabusItem ;
    ns1:itemIndex 27 ;
    ns1:syllabusDescription "9.1. Ecuaciones de la elasticidad lineal. Forma débil: principio de los trabajos virtuales. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000322/2025-26/syllabus/28> a ns1:SyllabusItem ;
    ns1:itemIndex 28 ;
    ns1:syllabusDescription "9.2. Aproximación: elementos isoparamétricos. Generación de mallas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000322/2025-26/syllabus/29> a ns1:SyllabusItem ;
    ns1:itemIndex 29 ;
    ns1:syllabusDescription "9.3. Aplicación: modelos elásticos para biomecánica de huesos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000322/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "1.3. Scripts y funciones. Gráficos 2D y 3D. Toolboxes. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000322/2025-26/syllabus/30> a ns1:SyllabusItem ;
    ns1:itemIndex 30 ;
    ns1:syllabusDescription "10. Tema 10: Elementos finitos para biomecánica: aplicaciones no lineales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000322/2025-26/syllabus/31> a ns1:SyllabusItem ;
    ns1:itemIndex 31 ;
    ns1:syllabusDescription "10.1. Elasticidad no lineal. Forma débil y principios variacionales multicampo. Aproximación mediante elementos finitos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000322/2025-26/syllabus/32> a ns1:SyllabusItem ;
    ns1:itemIndex 32 ;
    ns1:syllabusDescription "10.2. Resolución numérica: método de Newton. Rigidez tangente. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000322/2025-26/syllabus/33> a ns1:SyllabusItem ;
    ns1:itemIndex 33 ;
    ns1:syllabusDescription "10.3. Aplicación: biomecánica de tejidos blandos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000322/2025-26/syllabus/34> a ns1:SyllabusItem ;
    ns1:itemIndex 34 ;
    ns1:syllabusDescription "10.4. Aplicación: deformación inelástica de endoprótesis metálicas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000322/2025-26/syllabus/35> a ns1:SyllabusItem ;
    ns1:itemIndex 35 ;
    ns1:syllabusDescription "11. Tema 11: Elementos finitos para biomecánica: mecánica de fluidos y modelos de difusión"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000322/2025-26/syllabus/36> a ns1:SyllabusItem ;
    ns1:itemIndex 36 ;
    ns1:syllabusDescription "11.1. Modelos de difusión: Ecuación de difusión. Modelos físicos (transmisión de calor, potencial eléctrico, concentración de especies). Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000322/2025-26/syllabus/37> a ns1:SyllabusItem ;
    ns1:itemIndex 37 ;
    ns1:syllabusDescription "11.2. Modelos de difusión: Forma débil y aproximación de Galerkin. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000322/2025-26/syllabus/38> a ns1:SyllabusItem ;
    ns1:itemIndex 38 ;
    ns1:syllabusDescription "11.3. Modelos de difusión: Ejemplo de aplicación (sistema de conducción eléctrica en el corazón). Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000322/2025-26/syllabus/39> a ns1:SyllabusItem ;
    ns1:itemIndex 39 ;
    ns1:syllabusDescription "11.4. Mecánica de fluidos: Modelos de convección-difusión. Fluidos Newtonianos. Ecuaciones de Navier-Stokes. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000322/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "2. Tema 2: Resolución de sistemas lineales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000322/2025-26/syllabus/40> a ns1:SyllabusItem ;
    ns1:itemIndex 40 ;
    ns1:syllabusDescription "11.5. Mecánica de fluidos: Aproximación de Galerkin con estabilización upwind. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000322/2025-26/syllabus/41> a ns1:SyllabusItem ;
    ns1:itemIndex 41 ;
    ns1:syllabusDescription "11.6. Mecánica de fluidos: Ejemplo de aplicación (hemodinámica). Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000322/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "2.1. Métodos directos (Gauss). Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000322/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "2.2. Métodos iterativos (Jacobi, Gauss-Seidel). Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000322/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "3. Tema 3: Métodos iterativos de resolución de ecuaciones y sistemas no lineales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000322/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "3.1. Método de bisección. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000322/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "3.2. Iteración de punto fijo. Convergencia en los métodos iterativos. Sin subniveles"@es .

