    ns1:inpersonHours "63 horas y 15 minutos (40.5%)"@es ;
    ns1:numberOfCredits 6.0 ;
    ns1:otherInformation """El Máster Universitario en Ingeniería Web se ofrece en dos modalidades de impartición diferentes:
Modalidad Presencial*, con presencialidad de lunes a jueves, en horario de mañana.
Modalidad Semipresencial, con presencialidad en viernes tarde y sábados mañana.
* por decisión de la Junta de Escuela del 14/03/2022, a partir del curso 2022-2023 el máster sólo se ofrece en modalidad semipresencial.

En ambos casos las actividades formativas llevadas a cabo y las metodologías docentes empleadas permiten evaluar los resultados de aprendizaje descritos en la memoria del programa. La oferta de estas dos modalidades se asienta en tres componentes básicos: las clases presenciales, las tutorías (presenciales, por correo electrónico, foros, chats, videoconferencia, etc.) y los recursos tecnológicos (plataforma virtual Moodle). Para garantizar la adquisición de las competencias definidas en la memoria del título, se emplea un sistema de evaluación común e independiente de la modalidad de enseñanza cursada."""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "161 horas y 30 minutos"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/613000097/2025-26/eventSchedule> ;
    schema:description "El objetivo principal de la asignatura consiste en proporcionar los conceptos fundamentales para el desarrollo de aplicaciones para dispositivos móviles. La asignatura abarca desde los conocimientos más básicos, hasta temas avanzados como la comunicación y utilización de servicios web, el empleo de diferentes APIs, o la conexión con plataformas IoT."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/franciscojavier.gil%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/franciscojavier.gil%40upm.es> ;
    schema:name "Front-End para Móviles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000097/2025-26/CE01> a ns1:Competency ;
    ns1:competencyCode "CE01" ;
    ns1:competencyDescription "Requisitar, analizar y diseñar en un desarrollo Web bajo las metodologías vigentes en el entorno profesional."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000097/2025-26/CE02> a ns1:Competency ;
    ns1:competencyCode "CE02" ;
    ns1:competencyDescription "Programar y probar en un desarrollo Web con los lenguajes y técnicas vigentes en el entorno profesional."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000097/2025-26/CE03> a ns1:Competency ;
    ns1:competencyCode "CE03" ;
    ns1:competencyDescription "Desplegar y mantener un desarrollo Web sobre las plataformas y arquitecturas vigentes en el entorno profesional."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000097/2025-26/CE04> a ns1:Competency ;
    ns1:competencyCode "CE04" ;
    ns1:competencyDescription "Configurar herramientas y entornos de desarrollo Web vigentes en el entorno profesional."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000097/2025-26/CE05> a ns1:Competency ;
    ns1:competencyCode "CE05" ;
    ns1:competencyDescription "Integrar bibliotecas, protocolos y estándares Web vigentes en el entorno profesional."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000097/2025-26/CE06> a ns1:Competency ;
    ns1:competencyCode "CE06" ;
    ns1:competencyDescription "Incorporar seguridad, calidad, usabilidad y persistencia al desarrollo Web vigentes en el entorno profesional."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000097/2025-26/CG00> a ns1:Competency ;
    ns1:competencyCode "CG00" ;
    ns1:competencyDescription "Poseer y comprender conocimientos que aporten una base u oportunidad de ser originales en el desarrollo y/o aplicación de ideas, a menudo en un contexto de investigación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000097/2025-26/CG01> a ns1:Competency ;
    ns1:competencyCode "CG01" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en entornos nuevos o poco conocidos dentro de contextos más amplios (o multidisciplinares) relacionados con su área de estudio."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000097/2025-26/CG02> a ns1:Competency ;
    ns1:competencyCode "CG02" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de integrar conocimientos y enfrentarse a la complejidad de formular juicios a partir de una información que, siendo incompleta o limitada, incluya reflexiones sobre las responsabilidades sociales y éticas vinculadas a la aplicación de sus conocimientos y juicios."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000097/2025-26/CG04> a ns1:Competency ;
    ns1:competencyCode "CG04" ;
    ns1:competencyDescription "Que los estudiantes posean las habilidades de aprendizaje que les permitan continuar estudiando de un modo que habrá de ser en gran medida autodirigido o autónomo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000097/2025-26/CG05> a ns1:Competency ;
    ns1:competencyCode "CG05" ;
    ns1:competencyDescription "Uso de la lengua inglesa"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000097/2025-26/CG07> a ns1:Competency ;
    ns1:competencyCode "CG07" ;
    ns1:competencyDescription "Creatividad"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000097/2025-26/CG09> a ns1:Competency ;
    ns1:competencyCode "CG09" ;
    ns1:competencyDescription "Gestión de la información"@es .

