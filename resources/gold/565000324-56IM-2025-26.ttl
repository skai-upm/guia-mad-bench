    ns1:inpersonHours "66 horas (42.3%)"@es ;
    ns1:numberOfCredits 6.0 ;
    ns1:otherInformation """Debido al elevado componente práctico de la asignatura, es fundamental un trabajo personal constante por parte del alumno.
Desde el primer día, el estudiante debe analizar los ejemplos proporcionados y realizar personalmente las prácticas de programación propuestas.

NOTA: Los profesores de la asignatura no son responsables de los errores ortográficos que aparecen en este documento."""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "66 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/565000324/2025-26/eventSchedule> ;
    schema:description """Es una asignatura que desarrolla los elementos básicos de la programación estructurada, para lo que utiliza el lenguaje C como herramienta de programación.
El objetivo fundamental es diseñar y codificar algoritmos científicos utilizando el lenguaje de programación C. Se trabaja en un entorno de desarrollo integrado (IDE) donde se implementan diferentes ejercicios prácticos de programación."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/mercedes.bermejo%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/javier.martinezmartinez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/juancarlos.sampedro%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/mercedes.bermejo%40upm.es> ;
    schema:name "Informatica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000324/2025-26/CE3> a ns1:Competency ;
    ns1:competencyCode "CE3" ;
    ns1:competencyDescription "Conocimientos básicos sobre el uso y programación de los ordenadores, sistemas operativos, bases de datos y programas informáticos con aplicación en ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000324/2025-26/CG10> a ns1:Competency ;
    ns1:competencyCode "CG10" ;
    ns1:competencyDescription "Creatividad."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000324/2025-26/CG2> a ns1:Competency ;
    ns1:competencyCode "CG2" ;
    ns1:competencyDescription "Poseer la capacidad para diseñar, desarrollar, implementar, gestionar y mejorar productos, sistemas y procesos en los distintos ámbitos industriales, usando técnicas analíticas, computacionales o experimentales apropiadas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000324/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Aplicar los conocimientos adquiridos para identificar, formular y resolver problemas en contextos amplios, siendo capaces de integrar los trabajando en equipos multidisciplinares"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000324/2025-26/CG6> a ns1:Competency ;
    ns1:competencyCode "CG6" ;
    ns1:competencyDescription "Poseer las habilidades de aprendizaje que permitan continuar estudiando a lo largo de toda la vida para un desarrollo profesional adecuado"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000324/2025-26/CG7> a ns1:Competency ;
    ns1:competencyCode "CG7" ;
    ns1:competencyDescription "Incorporar las TIC y las tecnologías y herramientas de la Ingeniería Industrial en sus actividades profesionales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000324/2025-26/RA15> a ns1:LearningResult ;
    ns1:learningResultCode "RA15" ;
    ns1:learningResultDescription "Capacidad para conocer, entender y utilizar los principios de Programación de computadores, sistemas operativos, aplicación y uso de bases de datos y aplicaciones informáticas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000324/2025-26/RA358> a ns1:LearningResult ;
    ns1:learningResultCode "RA358" ;
    ns1:learningResultDescription "Implementar ejemplos y ejercicios de variada índole, en un contexto numérico y alfanumérico, que permitan ilustrar los conceptos de eficiencia y robustez, memoria utilizada y fiabilidad de los códigos."@es .

