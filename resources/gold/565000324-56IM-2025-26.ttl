    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000324/2025-26/didactic_resource/5> a ns1:DidacticResource ;
    ns1:bibliographyDescription "Texto que desarrolla sobradamente los contenidos de la asignatura, con ejemplos y ejercicios propuestos para el trabajo autónomo del estudiante. Disponible en formato PDF en el espacio Moodle de la asignatura."@es ;
    ns1:bibliographyTitle "Sanguino, Javier: \"Programación en C. Primeros pasos\""@es ;
