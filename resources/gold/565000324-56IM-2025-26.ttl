    ns1:learningResultCode "RA360" ;
    ns1:learningResultDescription "Conocer, entender y utilizar los principios de programación mediante el lenguaje C."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000324/2025-26/RA361> a ns1:LearningResult ;
