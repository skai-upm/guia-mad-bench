    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation """This subject focuses on the student, who will have to delve into the field of the philosophy of science and the scientific method through readings, analysis and debates with their classmates.
Continuous, day-to-day work is essential in order to pass this subject."""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
