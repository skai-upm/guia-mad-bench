<https://guia-kg.skai.etsisi.upm.es/resource/43000512/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/43000512/2025-26/MSICCB09>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000512/2025-26/MSICCB10>,
