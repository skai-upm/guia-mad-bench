    ns1:hasItem <https://guia-kg.skai.etsisi.upm.es/resource/43000512/2025-26/syllabus/0>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000512/2025-26/syllabus/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000512/2025-26/syllabus/2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000512/2025-26/syllabus/3>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000512/2025-26/syllabus/4>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000512/2025-26/syllabus/5>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000512/2025-26/syllabus/6>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000512/2025-26/syllabus/7>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000512/2025-26/syllabus/8>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000512/2025-26/syllabus/9> .

<https://guia-kg.skai.etsisi.upm.es/resource/43000512/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. PARTE 1. INDICADORES: ÁREAS Y SECTORES"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000512/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Medida de los parámetros ambientales Se presenta la metodología para la medida de los parámetros ambientales, instrumentos y valoración de errores Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000512/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "2. LOS MATERIALES DE CONSTRUCCIÓN Y EL MEDIO AMBIENTE. Introducción. Metodología ACV. ISO 140xx. Declaración ambiental de productos de construcción (DAP). Metodología y estudio de casos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000512/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "3. EVALUACIÓN AMBIENTAL DE LAS CONSTRUCCIONES"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000512/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "3.1. Legislación, normativa y estado del arte de la evaluación de la sostenibilidad de las construcciones Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000512/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "3.2. Herramientas para la evaluación de la sostenibilidad de las infraestructuras. Método ENVISION. Estudio de las fases. Criterios de evaluación y puntuación. Resultados Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000512/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "4. GESTIÓN DE AGUAS PLUVIALES. Sistemas de evacuación de aguas pluviales en ámbitos urbanos. Sistemas tradicionales (redes de saneamiento de aguas pluviales): tipos, diseño y cálculo. SUDS. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000512/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "5. CONTAMINACIÓN ACÚSTICA. Concepto de contaminación acústica. Parámetros. Sistemas de medición del ruido. Modelos de propagación del ruido. Tecnologías para la atenuación del ruido. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000512/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "6. CONTAMINACIÓN DE SUELOS Y BIORREMEDIACIÓN. Contaminación de suelos. Origen y situación actual. Identificación de un suelo contaminado.Legislación. Remediación de suelos.Métodos Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000512/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "7. EVALUACIÓN DE LA CALIDAD DE LA MASA DE AGUA: Conceptos generales y marco normativo. Indicadores de calidad. Sistemas de seguimiento. Modelización de la calidad Sin subniveles"@es .

