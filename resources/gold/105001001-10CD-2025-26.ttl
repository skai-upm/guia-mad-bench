<https://guia-kg.skai.etsisi.upm.es/resource/105001001/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Matrices. Sistemas de ecuaciones lineales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105001001/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Cálculo matricial. Operaciones elementales. Forma escalonada y escalonada reducida. Rango. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105001001/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "3.2. Clasificación y construcción de homomorfismos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105001001/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "3.3. Cambio de base asociado a un homomorfismo. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105001001/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "3.4. Subespacios invariantes. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105001001/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "4. Diagonalización"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105001001/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "4.1. Valores y vectores propios. Polinomio característico. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105001001/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "4.2. Subespacios propios. Propiedades. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105001001/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "4.3. Diagonalización por semejanza de endomorfismos y matrices. Aplicaciones. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105001001/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "5. Espacio vectorial euclídeo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105001001/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "5.1. Producto escalar. Distancia y ángulo entre vectores. Complemento ortogonal. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105001001/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "5.2. Bases ortonormales. Procedimiento de ortonormalización de Gram-Schmidt. Factorización QR. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105001001/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Resolución de sistemas por el método de Gauss y Gauss-Jordan. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105001001/2025-26/syllabus/20> a ns1:SyllabusItem ;
    ns1:itemIndex 20 ;
    ns1:syllabusDescription "5.3. Proyección ortogonal. Distancia entre vector y subespacio Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105001001/2025-26/syllabus/21> a ns1:SyllabusItem ;
    ns1:itemIndex 21 ;
    ns1:syllabusDescription "5.4. Problemas de mínimos cuadrados. Ajustes de Datos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105001001/2025-26/syllabus/22> a ns1:SyllabusItem ;
    ns1:itemIndex 22 ;
    ns1:syllabusDescription "6. Aplicaciones lineales entre espacios euclídeos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105001001/2025-26/syllabus/23> a ns1:SyllabusItem ;
    ns1:itemIndex 23 ;
    ns1:syllabusDescription "6.1. Endomorfismos y matrices simétricas. Diagonalización de endomorfismos y matrices por semejanza ortogonal. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105001001/2025-26/syllabus/24> a ns1:SyllabusItem ;
    ns1:itemIndex 24 ;
    ns1:syllabusDescription "6.2. Aplicaciones ortogonales. Propiedades. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105001001/2025-26/syllabus/25> a ns1:SyllabusItem ;
    ns1:itemIndex 25 ;
    ns1:syllabusDescription "6.3. Construcción y clasificación de aplicaciones ortogonales. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105001001/2025-26/syllabus/26> a ns1:SyllabusItem ;
    ns1:itemIndex 26 ;
    ns1:syllabusDescription "7. Otras factorizaciones matriciales y aplicaciones."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105001001/2025-26/syllabus/27> a ns1:SyllabusItem ;
    ns1:itemIndex 27 ;
    ns1:syllabusDescription "7.1. Descomposición en valores singulares. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105001001/2025-26/syllabus/28> a ns1:SyllabusItem ;
    ns1:itemIndex 28 ;
    ns1:syllabusDescription "7.2. Inversa generalizada de Moore-Penrose o pseudoinversa. Aplicaciones. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105001001/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "1.3. Factorización LU y aplicaciones. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105001001/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "2. Espacios vectoriales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105001001/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "2.1. Dependencia lineal. Bases. Dimensión. Coordenadas. Cambio de base. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105001001/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "2.2. Subespacios vectoriales. Ecuaciones paramétricas e implícitas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105001001/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "2.3. Operaciones con subespacios. Suma directa. Subespacios complementarios. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105001001/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "3. Aplicaciones lineales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105001001/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "3.1. Aplicaciones lineales. Núcleo e imagen. Fórmula de las dimensiones. Sin subniveles"@es .

