    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/203000067/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/203000067/2025-26/RA11>,
        <https://guia-kg.skai.etsisi.upm.es/resource/203000067/2025-26/RA12>,
        <https://guia-kg.skai.etsisi.upm.es/resource/203000067/2025-26/RA13>,
        <https://guia-kg.skai.etsisi.upm.es/resource/203000067/2025-26/RA14>,
        <https://guia-kg.skai.etsisi.upm.es/resource/203000067/2025-26/RA15> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/203000067/2025-26/syllabus> ;
    ns1:inpersonHours "18 horas (46.2%)"@es ;
    ns1:numberOfCredits 1.5 ;
    ns1:otherInformation "La asignatura se relaciona con el ODS13 y el ODS15."@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "20 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/203000067/2025-26/eventSchedule> ;
    schema:description """Tema 1: El impacto de la producción animal en el medio ambiente.
Tema 2: Estrategias nutricionales y de manejo de los estiércoles para la reducción de emisiones de gases procedentes de la ganadería: Metano.
Tema 3: Estrategias nutricionales y de manejo para la reducción de contaminantes procedentes de la ganadería: compuestos de Nitrógeno.
Tema 4: Estrategias nutricionales y de manejo para la reducción de contaminantes procedentes de la ganadería: Fósforo.
Tema 5: Metodologías de evaluación del impacto de los sistemas ganaderos sobre el medio ambiente."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/paloma.grebollar%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/paloma.grebollar%40upm.es> ;
    schema:name "Producción Animal y Medio Ambiente"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000067/2025-26/CE01> a ns1:Competency ;
    ns1:competencyCode "CE01" ;
    ns1:competencyDescription "Adquirir unos conocimientos y unas destrezas adecuadas en producción y sanidad animal para poder plantear soluciones y resolver las problemáticas inherentes a las explotaciones ganaderas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000067/2025-26/CE02> a ns1:Competency ;
    ns1:competencyCode "CE02" ;
    ns1:competencyDescription "Aplicar conocimientos avanzados acerca de la gestión técnico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000067/2025-26/CE04> a ns1:Competency ;
    ns1:competencyCode "CE04" ;
    ns1:competencyDescription "Diseñar nuevas estrategias para mejorar la productividad de los modelos ganaderos, optimizando la utilización de los factores de producción, afrontando adecuadamente la temática del bienestar animal y minimizando el impacto ambiental de los mencionados modelos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000067/2025-26/CE05> a ns1:Competency ;
    ns1:competencyCode "CE05" ;
    ns1:competencyDescription "Dominar los aspectos éticos, legales, medioambientales y los protocolos de bioseguridad, que deben cumplir las empresas pecuarias y los trabajos experimentales realizados en producción animal y en sanidad animal."@es .

