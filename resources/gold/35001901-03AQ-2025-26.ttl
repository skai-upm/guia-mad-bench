<https://guia-kg.skai.etsisi.upm.es/resource/35001901/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Adquirir la capacidad para integrar todos los grados de definición y fases de desarrollo del proyecto Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35001901/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "2. Planificar desde el estudio de viabilidad y los primeros croquis hasta la definición técnica y constructiva que permite la ejecución de proyectos integrados. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35001901/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "3. Incorporar aspectos técnicos relacionados con las estructuras y con las instalaciones. Sin subniveles"@es .

