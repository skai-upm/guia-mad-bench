    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/43000387/2025-26/eventSchedule> ;
    schema:description """Objetivos
Se pretende que el estudiante aprenda cómo se comportan en rotura los materiales utilizados en las estructuras, el por qué de su comportamiento particular y, en consecuencia, las posibilidades de modificar dicho comportamiento.
Para ello, los conocimientos y capacidades a adquirir por el alumno como resultado de la acción docente son los siguientes:
-conocer los modelos teóricos de comportamiento mecánico en rotura de mayor interés aplicables a los materiales estructurales
-conocer los fundamentos físicos de los comportamientos macroscópicos
-saber aplicar los conocimientos anteriores en diseño, construcción y mantenimiento de estructuras
-familiarizarse con la metodología científica de las disciplinas en que se apoya la asignatura"""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/gustavovictor.guinea%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/david.cendon.franco%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/gustavovictor.guinea%40upm.es> ;
    schema:name "Integridad Structural"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000387/2025-26/CB06> a ns1:Competency ;
    ns1:competencyCode "CB06" ;
    ns1:competencyDescription "Poseer y comprender conocimientos que aporten una base u oportunidad de ser originales en el desarrollo y/o aplicación de ideas, a menudo en un contexto de investigación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000387/2025-26/CB07> a ns1:Competency ;
    ns1:competencyCode "CB07" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en entornos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000387/2025-26/CB08> a ns1:Competency ;
    ns1:competencyCode "CB08" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de integrar conocimientos y enfrentarse a la complejidad de formular juicios a partir de una información que, siendo incompleta o limitada, incluya reflexiones sobre las responsabilidades sociales y éticas vinculadas a la aplicación de sus conocimientos y juicios"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000387/2025-26/CB09> a ns1:Competency ;
    ns1:competencyCode "CB09" ;
    ns1:competencyDescription "Que los estudiantes sepan comunicar sus conclusiones y los conocimientos y razones últimas que las sustentan a públicos especializados y no especializados de un modo claro y sin ambigüedades"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000387/2025-26/CB10> a ns1:Competency ;
    ns1:competencyCode "CB10" ;
    ns1:competencyDescription "Que los estudiantes posean las habilidades de aprendizaje que les permitan continuar estudiando de un modo que habrá de ser en gran medida autodirigido o autónomo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000387/2025-26/CE1> a ns1:Competency ;
    ns1:competencyCode "CE1" ;
    ns1:competencyDescription "Capacitación científico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000387/2025-26/CE11> a ns1:Competency ;
    ns1:competencyCode "CE11" ;
    ns1:competencyDescription "Capacidad para el proyecto, ejecución e inspección de estructuras (puentes, edificaciones, etc.), de obras de cimentación y de obras subterráneas de uso civil (túneles, aparcamientos), y el diagnóstico sobre su integridad."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000387/2025-26/CE18> a ns1:Competency ;
    ns1:competencyCode "CE18" ;
    ns1:competencyDescription "Conocimientos adecuados de los aspectos científicos y tecnológicos de métodos matemáticos, analíticos y numéricos de la ingeniería, mecánica de fluidos, mecánica de medios continuos, cálculo de estructuras, ingeniería del terreno, ingeniería marítima, obras y aprovechamientos hidráulicos y obras lineales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000387/2025-26/CE22> a ns1:Competency ;
    ns1:competencyCode "CE22" ;
    ns1:competencyDescription "Conocimiento y capacidad para el análisis estructural mediante la aplicación de los métodos y programas de diseño y cálculo avanzado de estructuras, a partir del conocimiento y comprensión de las solicitaciones y su aplicación a las tipologías estructurales de la ingeniería civil. Capacidad para realizar evaluaciones de integridad estructural."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000387/2025-26/CE33> a ns1:Competency ;
    ns1:competencyCode "CE33" ;
    ns1:competencyDescription "Capacidad para aplicar los conocimientos técnicos en actividades de I+D+i dentro del ámbito de la ingeniería civil."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000387/2025-26/CE38> a ns1:Competency ;
    ns1:competencyCode "CE38" ;
    ns1:competencyDescription "Capacidad para integrar y aplicar los conocimientos técnicos en asesoría, análisis, diseño y modelización físico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000387/2025-26/CGP18> a ns1:Competency ;
    ns1:competencyCode "CGP18" ;
    ns1:competencyDescription "Conocimientos adecuados de los aspectos científicos y tecnológicos de métodos matemáticos, analíticos y numéricos de la ingeniería, mecánica de fluidos, mecánica de medios continuos, cálculo de estructuras, ingeniería del terreno, ingeniería marítima, obras y aprovechamientos hidráulicos y obras lineales. Incorpora las competencias CB6, CB7 y CB8."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000387/2025-26/CT2> a ns1:Competency ;
    ns1:competencyCode "CT2" ;
    ns1:competencyDescription "Polivalencia y capacidad de aprendizaje autónomo. Desarrolla la competencia transversal 5ª del Real Decreto."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000387/2025-26/RA1> a ns1:LearningResult ;
    ns1:learningResultCode "RA1" ;
    ns1:learningResultDescription "Formula y resuelve problemas matemáticos y numéricos avanzados de ingeniería civil, identificando sus diferentes componentes científicos y técnicos y seleccionando y acoplando con eficacia los métodos de resolución."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000387/2025-26/RA17> a ns1:LearningResult ;
    ns1:learningResultCode "RA17" ;
    ns1:learningResultDescription "Modeliza y dimensiona elementos estructurales aplicando la teoría clásica de la Elasticidad y su extensión a régimen dinámico y a plasticidad de secciones, aplicando métodos analíticos y numéricos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000387/2025-26/RA18> a ns1:LearningResult ;
    ns1:learningResultCode "RA18" ;
    ns1:learningResultDescription "Proyecta estructuras y planifica su ejecución, mantenimiento, y preservación de integridad aplicando modelos y criterios orientados a la optimización resistente, funcional y medioambiental."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000387/2025-26/RA23> a ns1:LearningResult ;
    ns1:learningResultCode "RA23" ;
    ns1:learningResultDescription "Aplica y evalúa modelos avanzados de comportamiento mecánico y medioambiental de suelos y materiales de construcción."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000387/2025-26/RA43> a ns1:LearningResult ;
    ns1:learningResultCode "RA43" ;
    ns1:learningResultDescription "Explica, conoce y tiene conocimientos adecuados de los aspectos científicos y tecnológicos de métodos matemáticos, analíticos y numéricos de la ingeniería, mecánica de fluidos, mecánica de medios continuos, cálculo de estructuras, ingeniería del terreno, ingeniería marítima, obras y aprovechamientos hidráulicos y obras lineales, así como, diseñar, planificar, gestionar, mantener, conservar y explotar las infraestructuras desde la perspectiva ambiental y sostenible."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000387/2025-26/RA59> a ns1:LearningResult ;
    ns1:learningResultCode "RA59" ;
    ns1:learningResultDescription "Desarrolla capacidad autónoma de comprensión y análisis de problemas complejos mediante métodos matemáticos y experimentales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000387/2025-26/RA68> a ns1:LearningResult ;
    ns1:learningResultCode "RA68" ;
    ns1:learningResultDescription "Formula y resuelve problemas matemáticos y numéricos avanzados de ingeniería civil, identificando sus diferentes componentes científicos y técnicos y seleccionando y acoplando con eficacia los métodos de resolución"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000387/2025-26/RA69> a ns1:LearningResult ;
    ns1:learningResultCode "RA69" ;
    ns1:learningResultDescription "Valora con criterio científico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000387/2025-26/didactic_resource/1> a ns1:DidacticResource ;
    ns1:bibliographyDescription """-Anderson, T. L. , Fracture Mechanics, CRC Press, Londres.
-Broek, D., The Practical Use of Fracture Mechanics, Kluwer Academic, Publisher, Dordrecht
-Elices, M., Mecánica de la Fractura, Publicaciones de la ETSICCP de Madrid, Madrid."""@es ;
