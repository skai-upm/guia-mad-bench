        <https://guia-kg.skai.etsisi.upm.es/resource/josemaria.cuellar%40upm.es> ;
    schema:name "Launching Of Ict Product/services To The Market"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000846/2025-26/CB09> a ns1:Competency ;
    ns1:competencyCode "CB09" ;
    ns1:competencyDescription "Que los estudiantes sepan transmitir de un modo claro y sin ambigüedades a un público especializado o no, resultados y conclusiones procedentes de la investigación científica y tecnológica o del ámbito de la innovación más avanzada, así como los fundamentos más relevantes y razones últimas que las sustentan/To know how to convey in a clear and unambiguous way to a specialized or not audience, results and conclusions from scientific and technological research and or from the most advanced innovation field, as well as the fundamentals more relevant and latest reasons supporting them."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000846/2025-26/CE> a ns1:Competency ;
    ns1:competencyCode "CE" ;
    ns1:competencyDescription "EIT05"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000846/2025-26/CG03> a ns1:Competency ;
    ns1:competencyCode "CG03" ;
    ns1:competencyDescription "La capacidad de usar la lengua inglesa de manera competente, es decir, con capacitación para tareas complejas de trabajo y estudio/ The ability to use the English language in a competent way, i.e., with training for work and study complex tasks."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000846/2025-26/CG04> a ns1:Competency ;
    ns1:competencyCode "CG04" ;
    ns1:competencyDescription "La capacidad de toma de decisiones y liderazgo de equipos, basada en una comprensión holística de las contribuciones de la educación superior, la investigación y las empresas para la creación de valor, en equipos y contextos de tamaño limitado /The ability of decision"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000846/2025-26/CG05> a ns1:Competency ;
    ns1:competencyCode "CG05" ;
    ns1:competencyDescription "Comprensión de los principios de la gestión de proyectos, riesgo y cambio, así como poseer la capacidad de aplicar metodologías y procesos para gestionar proyectos y mitigar los riesgos/ To understand the principles of the project management, risk and change, as well as have the ability to apply methodologies and processes to manage projects and mitigate risks."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000846/2025-26/CG06> a ns1:Competency ;
    ns1:competencyCode "CG06" ;
    ns1:competencyDescription "Capacidad para gestionar la información/ To be able to manage information."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000846/2025-26/CG07> a ns1:Competency ;
    ns1:competencyCode "CG07" ;
    ns1:competencyDescription "Capacidad de trabajar y comunicarse también en contextos internacionales/ To be able to communicate and work in international contexts."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000846/2025-26/CG08> a ns1:Competency ;
    ns1:competencyCode "CG08" ;
    ns1:competencyDescription "La capacidad de traducir innovaciones en soluciones comerciales factibles/ To be able to translate innovations into feasible business solutions."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000846/2025-26/CG09> a ns1:Competency ;
    ns1:competencyCode "CG09" ;
    ns1:competencyDescription "La capacidad de transformar las experiencias prácticas en problemas y desafíos de investigación/ To be able to transform the practical experiences into problems and challenges of research."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000846/2025-26/RA79> a ns1:LearningResult ;
    ns1:learningResultCode "RA79" ;
    ns1:learningResultDescription "Identify and assess the impact of ICT technologies and innovations in a thematic area, on its markets and stakeholders (competitors, alliances, networks) and the business opportunities they offer."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000846/2025-26/RA84> a ns1:LearningResult ;
    ns1:learningResultCode "RA84" ;
    ns1:learningResultDescription "Perform a business solution planning and development process (dynamics of developing the business, organization needed to implement it, go"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000846/2025-26/RA92> a ns1:LearningResult ;
    ns1:learningResultCode "RA92" ;
    ns1:learningResultDescription "Develop a business plan and commercial projects client oriented"@es .

