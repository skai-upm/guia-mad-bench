        <https://guia-kg.skai.etsisi.upm.es/resource/105000446/2025-26/RA277>,
        <https://guia-kg.skai.etsisi.upm.es/resource/105000446/2025-26/RA278> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/105000446/2025-26/syllabus> ;
    ns1:inpersonHours "30 horas (38.5%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation ""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "32 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/105000446/2025-26/eventSchedule> ;
    schema:description "El objetivo principal de la asignatura es introducir al alumno en las técnicas modernas (algoritmos) utilizadas en la corrección de errores, y que hoy día forman parte de estándares en tecnologías como Wi-Fi, Wimax, DVB, etc. En la primera parte de la asignatura estudiamos algunos conceptos básicos que alumno necesitara para comprender la calidad de un código corrector: a partir de una medida de información y del cálculo de la capacidad de un canal de información, el alumno podrá determinar cómo se aproxima la tasa de error que puede corregir un código al límite teórico. En la segunda parte de la asignatura presentamos algunos de los tipos de códigos más relevantes en la actualidad. Estudiaremos distintos algoritmos de codificación y decodificación, sus optimizaciones, y métodos para la construcción de códigos."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/jesus.martinez.mateo%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/belen.rios%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/jesus.martinez.mateo%40upm.es> ;
    schema:name "Teoría de la Información y la Codificación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000446/2025-26/CG> a ns1:Competency ;
    ns1:competencyCode "CG" ;
    ns1:competencyDescription "1/21"@es,
        "19"@es,
        "2/CE45"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000446/2025-26/Ce%2012/16> a ns1:Competency ;
    ns1:competencyCode "Ce 12/16" ;
    ns1:competencyDescription "Conocer los campos de aplicación de la informática, y tener una apreciación de la necesidad de poseer unos conocimientos técnicos profundos en ciertas áreas de aplicación; apreciación del grado de esta necesidad en, por lo menos, una situación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000446/2025-26/Ce%2013/18> a ns1:Competency ;
    ns1:competencyCode "Ce 13/18" ;
    ns1:competencyDescription "Comprender lo que pueden y no pueden conseguir las tecnologías actuales, y las limitaciones de la informática, que implica distinguir entre lo que, inherentemente, la informática no es capaz de hacer y lo que puede lograrse a través de la ciencia y la tecnología futuras."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000446/2025-26/Ce%2044> a ns1:Competency ;
    ns1:competencyCode "Ce 44" ;
    ns1:competencyDescription "Conocimiento de tecnologías punteras relevantes y su aplicación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000446/2025-26/RA276> a ns1:LearningResult ;
    ns1:learningResultCode "RA276" ;
    ns1:learningResultDescription "Dado un campo de aplicación de la informática, evaluar y diseñar el sistema informático más apropiado para resolver alguno de sus problemas, exponiendo las dificultades técnicas y los limites de la aplicación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000446/2025-26/RA277> a ns1:LearningResult ;
    ns1:learningResultCode "RA277" ;
    ns1:learningResultDescription "Dado un problema real elegir la tecnología informática existente en el mercado mas apropiada para su solución y diseñar su desarrollo e integración, analizando la viabilidad de su solución, lo que se puede y no se puede conseguir a través del estado actual de desarrollo de la tecnología usada, y lo que se espera que avance en el futuro."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000446/2025-26/RA278> a ns1:LearningResult ;
    ns1:learningResultCode "RA278" ;
    ns1:learningResultDescription "Desarrollar la solución matemática y algorítmica mas apropiada a un problema informático que requiera un tratamiento especialmente complejo, analizando y exponiendo su viabilidad."@es .

