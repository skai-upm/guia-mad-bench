    ns1:inpersonHours "60 horas (46.2%)"@es ;
    ns1:numberOfCredits 5.0 ;
    ns1:otherInformation """La asignatura está relacionada con los siguientes objetivos de desarrollo sostenible (ODS):
2. Hambre cero
12. Garantizar modalidades de consumo y producción sostenibles
13: Adoptar medidas urgentes para combatir el cambio climático y sus efectos
Material para prácticas
Por seguridad en el laboratorio, los alumnos deberán traer una bata de laboratorio así como guantes y gafas de seguridad"""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "60 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/205000019/2025-26/eventSchedule> ;
    schema:description """La asignatura de Edafología está compuesta por cuatro bloques temáticos:
Bloque I: El suelo como ente natural
Bloque 2: Propiedades físicas y químicas del suelo
Bloque 3: Introducción a la clasificación y Evaluación de suelos
Bloque 4: Aplicaciones Ambientales
Además la asignatura tiene una parte práctica cuya realización es obligatoria para poder superar la asignatura"""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/gabriel.gasco%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/gabriel.gasco%40upm.es> ;
    schema:name "Edafología"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000019/2025-26/CE07> a ns1:Competency ;
    ns1:competencyCode "CE07" ;
    ns1:competencyDescription "Conocer las propiedades físicas, químicas y biológicas de los suelos como sustrato del crecimiento vegetal, su susceptibilidad a la degradación, y su manejo en condiciones agrícolas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000019/2025-26/CG02> a ns1:Competency ;
    ns1:competencyCode "CG02" ;
    ns1:competencyDescription "Ser capaces de evaluar y discernir los diferentes mecanismos responsables del desarrollo de plantas y animales con vistas al diseño y utilización de tecnologías y estrategias avanzadas en la producción vegetal y animal."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000019/2025-26/CT09> a ns1:Competency ;
    ns1:competencyCode "CT09" ;
    ns1:competencyDescription "Tener capacidad de análisis y síntesis para interpretar datos relevantes y abordar los problemas desde diferentes perspectivas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000019/2025-26/RA15> a ns1:LearningResult ;
    ns1:learningResultCode "RA15" ;
    ns1:learningResultDescription "Identificar y describir en contextos reales leyes de evolución no lineales mediante sistemas de ecuaciones diferenciales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000019/2025-26/RA150> a ns1:LearningResult ;
    ns1:learningResultCode "RA150" ;
    ns1:learningResultDescription "Evaluar la fertilidad orgánica del suelo y diseñar programas de fertilización orgánica para mantener e incrementar dicho nivel de fertilidad."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000019/2025-26/RA90> a ns1:LearningResult ;
    ns1:learningResultCode "RA90" ;
    ns1:learningResultDescription "Describir los horizontes de un perfil de suelo y evaluar la influencia de los factores y procesos formadores."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000019/2025-26/RA91> a ns1:LearningResult ;
    ns1:learningResultCode "RA91" ;
    ns1:learningResultDescription "Describir, analizar e interpretar datos de suelos tomados en campo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000019/2025-26/RA92> a ns1:LearningResult ;
    ns1:learningResultCode "RA92" ;
    ns1:learningResultDescription "Analizar e interpretar datos de laboratorio y relacionarlos con las propiedades del suelo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000019/2025-26/RA93> a ns1:LearningResult ;
    ns1:learningResultCode "RA93" ;
    ns1:learningResultDescription "Identificar, describir y evaluar los componentes mineral y orgánico del suelo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000019/2025-26/RA94> a ns1:LearningResult ;
    ns1:learningResultCode "RA94" ;
    ns1:learningResultDescription "Relacionar la actividad biológica del suelo con la funcionalidad del mismo, reconociendo su importancia en la sostenibilidad del sistema agrario."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000019/2025-26/RA95> a ns1:LearningResult ;
    ns1:learningResultCode "RA95" ;
    ns1:learningResultDescription "Evaluar el estado del agua en el suelo y su relación con la planta y el manejo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000019/2025-26/RA96> a ns1:LearningResult ;
    ns1:learningResultCode "RA96" ;
    ns1:learningResultDescription "Identificar y describir los factores, procesos y efectos de los distintos tipos de degradación del suelo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000019/2025-26/RA97> a ns1:LearningResult ;
    ns1:learningResultCode "RA97" ;
    ns1:learningResultDescription "Evaluar la problemática ambiental asociada la gestión de recursos sostenible, en concreto el suelo, en un contexto de bioeconomía."@es .

