<https://guia-kg.skai.etsisi.upm.es/resource/145007512> a ns1:Course ;
    ns1:courseType "Optativa"@es ;
    ns1:courseYear 4 ;
    ns1:semester "Séptimo semestre"@es ;
    schema:courseCode 145007512 ;
    schema:hasCourseInstance <https://guia-kg.skai.etsisi.upm.es/resource/145007512/2025-26> ;
    schema:name "Computational Fluid Dynamics"@en,
        "Dinamica de Fluidos Computacional"@es ;
    schema:numberOfCredits 3.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/145007512/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/145007512/2025-26/CE44>,
        <https://guia-kg.skai.etsisi.upm.es/resource/145007512/2025-26/CG3>,
        <https://guia-kg.skai.etsisi.upm.es/resource/145007512/2025-26/CG6>,
        <https://guia-kg.skai.etsisi.upm.es/resource/145007512/2025-26/CG9> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/145007512/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/145007512/2025-26/didactic_resource/2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/145007512/2025-26/didactic_resource/3>,
        <https://guia-kg.skai.etsisi.upm.es/resource/145007512/2025-26/didactic_resource/4> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/145007512/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/145007512/2025-26/RA36> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/145007512/2025-26/syllabus> ;
    ns1:inpersonHours "34 horas (43.6%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation """Sub-resultados de Aorendizaje EUR-ACE
2.2: La capacidad de identificar, formular y resolver problemas de ingeniería en su especialidad; elegir y aplicar de forma adecuada métodos analíticos, de cálculo y experimentales ya establecidos; reconocer la importancia de las restricciones sociales, de salud y seguridad, ambientales, económicas e industriales
3.2: Capacidad de proyecto utilizando algún conocimiento de vanguardia de su especialidad de ingeniería.
4.3: Capacidad y destreza para proyectar y llevar a cabo investigaciones experimentales, interpretar resultados y llegar a conclusiones en su campo de estudio."""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "34 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/145007512/2025-26/eventSchedule> ;
    schema:description "Esta asignatura esta orientada a entender algunos conceptos básicos subyacentes el los códigos de Mecanica de Fluidos Computacional. Se hace enfasis en los problemas asociados a la resolución de flujos compresibles de forma númerica y la forma de abordarlos. Se relacionan problemas físicos con las dificultades numéricas asociadas."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/roque.corral%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/josemiguel.perez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/roque.corral%40upm.es> ;
    schema:name "Dinamica de Fluidos Computacional"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145007512/2025-26/CE44> a ns1:Competency ;
    ns1:competencyCode "CE44" ;
    ns1:competencyDescription "Conocimiento adecuado y aplicado a la Ingeniería de: Los fundamentos de la mecánica de fluidos que describen el flujo en cualquier régimen y determinan las distribuciones de presiones y las fuerzas aerodinámicas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145007512/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Capacidad para identificar y resolver problemas aplicando, con creatividad, los conocimientos adquiridos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145007512/2025-26/CG6> a ns1:Competency ;
    ns1:competencyCode "CG6" ;
    ns1:competencyDescription "Uso de las Tecnologías de la Información y de las Comunicaciones"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145007512/2025-26/CG9> a ns1:Competency ;
    ns1:competencyCode "CG9" ;
    ns1:competencyDescription "Razonamiento crítico y capacidad de asociación que posibiliten el aprendizaje continuo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145007512/2025-26/RA36> a ns1:LearningResult ;
    ns1:learningResultCode "RA36" ;
    ns1:learningResultDescription "Conocimiento de los métodos de cálculo numérico fluidodinámico y capacidad para resolver los problemas de simulación numérica fluidodinámica."@es .

