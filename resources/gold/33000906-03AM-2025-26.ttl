<https://guia-kg.skai.etsisi.upm.es/resource/33000906/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/33000906/2025-26/CE69>,
        <https://guia-kg.skai.etsisi.upm.es/resource/33000906/2025-26/RD10>,
        <https://guia-kg.skai.etsisi.upm.es/resource/33000906/2025-26/RD6>,
