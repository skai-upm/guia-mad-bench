<https://guia-kg.skai.etsisi.upm.es/resource/33000895/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/33000895/2025-26/CB07>,
        <https://guia-kg.skai.etsisi.upm.es/resource/33000895/2025-26/CB08>,
        <https://guia-kg.skai.etsisi.upm.es/resource/33000895/2025-26/CE01>,
        <https://guia-kg.skai.etsisi.upm.es/resource/33000895/2025-26/CE04>,
        <https://guia-kg.skai.etsisi.upm.es/resource/33000895/2025-26/CG01>,
        <https://guia-kg.skai.etsisi.upm.es/resource/33000895/2025-26/CG02>,
        <https://guia-kg.skai.etsisi.upm.es/resource/33000895/2025-26/CG08> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/33000895/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/33000895/2025-26/RA1> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/33000895/2025-26/syllabus> ;
    ns1:inpersonHours "35 horas (22.4%)"@es ;
    ns1:numberOfCredits 6.0 ;
    ns1:otherInformation ""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "35 horas"@es ;
    schema:activitiesWorkload "50%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/33000895/2025-26/eventSchedule> ;
    schema:description """La asignatura consiste en la realización de unas prácticas profesionales de una duración superior a tres meses a media jornada.
Dichas prácvticas tienen la misión de consolidar el aprendizaje iniciado por el alumno en las asignaturas del Mucta, así como en el TFM.
El coordinador de la asignatura tendrá el papel de confirmar que la empresa seleccionada cumple los objetivos perseguidos por las prácticas."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/ramon.araujo%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/ramon.araujo%40upm.es> ;
    schema:name "Practicas Externas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000895/2025-26/CB07> a ns1:Competency ;
    ns1:competencyCode "CB07" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en entornos nuevos o poco conocidos dentro de contextos más amplios (o multidisciplinares) relacionados con su área de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000895/2025-26/CB08> a ns1:Competency ;
    ns1:competencyCode "CB08" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de integrar conocimientos y enfrentarse a la complejidad de formular juicios a partir de una información que, siendo incompleta o limitada, incluya reflexiones sobre las responsabilidades sociales y éticas vinculadas a la aplicación de sus conocimientos y juicios"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000895/2025-26/CE01> a ns1:Competency ;
    ns1:competencyCode "CE01" ;
    ns1:competencyDescription "Criterios de base científica para el proyecto del edificio. Adquisición de conocimientos básicos avanzados en relación a las nuevas tecnologías en construcción y de control ambiental. Introducción a las tipologías arquitectónicas y constructivas. Adquisición de conocimientos y criterios básicos para la integración en el diseño de las diferentes tecnologías arquitectónicas y su aplicación específica a las diferentes tipologías arquitectónicas y constructivas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000895/2025-26/CE04> a ns1:Competency ;
    ns1:competencyCode "CE04" ;
    ns1:competencyDescription "Dominio de conocimiento sobre técnicas innovadoras y sostenibles en edificación. Análisis de riesgos en sistemas innovadores de construcción. Arquitectura de fábrica, diseñar con nuevas técnicas. Investigaciones en la optimización e industrialización de viviendas de los sistemas constructivos. Influencia de la aplicación de nuevos materiales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000895/2025-26/CG01> a ns1:Competency ;
    ns1:competencyCode "CG01" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en entornos nuevos o poco conocidos dentro de contextos más amplios (o multidisciplinares) relacionados con su área de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000895/2025-26/CG02> a ns1:Competency ;
    ns1:competencyCode "CG02" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de integrar conocimientos y enfrentarse a la complejidad de formular juicios a partir de una información que, siendo incompleta o limitada, incluya reflexiones sobre las responsabilidades sociales y éticas vinculadas a la aplicación de sus conocimientos y juicios"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000895/2025-26/CG08> a ns1:Competency ;
    ns1:competencyCode "CG08" ;
    ns1:competencyDescription "Organización y planificación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000895/2025-26/RA1> a ns1:LearningResult ;
    ns1:learningResultCode "RA1" ;
    ns1:learningResultDescription "Los alumnos aprenderán a realizar la captura, almacenamiento, tratamiento y análisis de información requerida para los proyectos de la investigación en materiales de construcción, sistemas constructivos,"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000895/2025-26/evaluation> a ns1:EvaluationSystem ;
    ns1:evaluationDescription "Para aprobar la asignatura bastará haber cumplido con la realización de las prácticas y presentar un informe sobre las mismas al tutor."@es ;
