    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/45000247/2025-26/syllabus> ;
    ns1:inpersonHours "42 horas (51.9%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation """Dado el perfil de la asignatura, cuyo objetivo principal es conocer la estructura económica mundial, la asignatura está relacionada con la consecución de los Objetivos de Desarrollo Sostenible de Naciones Unidas (ODS), concretamente los siguientes:
ODS 1. Fin de la pobreza
ODS 5. Igualdad de género
ODS 8. Trabajo decente y crecimiento económico
ODS 10. Reducción de las desigualdades
ODS 12. Consumo y producción responsable."""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "42 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/45000247/2025-26/eventSchedule> ;
    schema:description """Se enfoca la asignatura al conocimiento de la económica internacional y sus mercados, a través de su realidad
estructural donde se realizan las transacciones internacionales.
Iniciando a través del estudio de la estructura nacional española, se accede al marco general de las diferentes
economías globalizadas. Se expone su crecimiento y desarrollo, así como las situación del mercado internacional.
Se finaliza con el proceso de integración económica, centrándolo en lo cercano, el caso de la Unión Europea."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/jose.balibrea%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/antonio.sanchezso%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/jose.balibrea%40upm.es> ;
    schema:name "Estructura y Mercados Internacionales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000247/2025-26/30AD.%20E15> a ns1:Competency ;
    ns1:competencyCode "30AD. E15" ;
    ns1:competencyDescription "Entender el funcionamiento de los mercados financieros nacionales e internacionales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000247/2025-26/30AD.%20E16> a ns1:Competency ;
    ns1:competencyCode "30AD. E16" ;
    ns1:competencyDescription "Conocer las principales teorías sobre el comportamiento de la economía tanto a nivel individual como agregado."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000247/2025-26/30AD.%20E17> a ns1:Competency ;
    ns1:competencyCode "30AD. E17" ;
    ns1:competencyDescription "Comprender las bases que configuran la actual estructura de la economía mundial y española."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000247/2025-26/30AD.%20E18> a ns1:Competency ;
    ns1:competencyCode "30AD. E18" ;
    ns1:competencyDescription "Conocer la determinación de los principales indicadores y agregados económicos, así como su impacto sobre las decisiones de la empresa."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000247/2025-26/30AD.%20E19> a ns1:Competency ;
    ns1:competencyCode "30AD. E19" ;
    ns1:competencyDescription "Comprender las variables e indicadores que caracterizan la política macroeconómica de un sector y un entorno geográfico."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000247/2025-26/30AD.%20E20> a ns1:Competency ;
    ns1:competencyCode "30AD. E20" ;
    ns1:competencyDescription "Comprender el contexto económico, regional, nacional e internacional que rodea a la empresa así como interpretar su impacto en la misma."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000247/2025-26/30AD.%20G01> a ns1:Competency ;
    ns1:competencyCode "30AD. G01" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de comprender, interpretar, sintetizar y evaluar de forma crítica información proveniente de fuentes diversas en el ámbito de la administración y dirección de empresas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000247/2025-26/30AD.%20G06> a ns1:Competency ;
    ns1:competencyCode "30AD. G06" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de trabajar en equipos multidisciplinares, aplicando los conocimientos adquiridos en el ámbito de la administración y dirección de empresas, fomentando el espíritu de equipo y la coordinación en las tareas de los diversos miembros."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000247/2025-26/30AD.%20G07> a ns1:Competency ;
    ns1:competencyCode "30AD. G07" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de trabajar en entornos diversos, comprendiendo y adaptándose a situaciones nuevas en el ámbito de la administración y dirección de empresas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000247/2025-26/30AD.%20G09> a ns1:Competency ;
    ns1:competencyCode "30AD. G09" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de trabajar en el ámbito de la administración y dirección de empresas aplicando criterios de calidad y sostenibilidad."@es .

