    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/45000247/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/45000247/2025-26/RA184>,
        <https://guia-kg.skai.etsisi.upm.es/resource/45000247/2025-26/RA185>,
