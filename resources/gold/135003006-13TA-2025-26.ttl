<https://guia-kg.skai.etsisi.upm.es/resource/135003006/2025-26/CE4> a ns1:Competency ;
    ns1:competencyCode "CE4" ;
    ns1:competencyDescription "Comprensión y dominio de los conceptos básicos sobre las leyes generales de la mecánica, termodinámica, campos, y ondas y electromagnetismo y su aplicación para la resolución de problemas propios de la ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003006/2025-26/CE5> a ns1:Competency ;
    ns1:competencyCode "CE5" ;
    ns1:competencyDescription "Capacidad de aplicación en situaciones reales la teoría de circuitos eléctricos y de la teoría de circuitos magnéticos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003006/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Capacidad para comprender los fundamentos biológicos, químicos, físicos, matemáticos y de los sistemas de representación necesarios para el desarrollo de la actividad profesional en el ámbito de la ingeniería ambiental."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003006/2025-26/CT2> a ns1:Competency ;
    ns1:competencyCode "CT2" ;
    ns1:competencyDescription "Habilidad para identificar, formular y resolver problemas de ingeniería"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003006/2025-26/RA4> a ns1:LearningResult ;
    ns1:learningResultCode "RA4" ;
    ns1:learningResultDescription "Comprensión y dominio de los conceptos básicos sobre Física. Medir y analizar datos experimentales y aplicar técnicas experimentales relacionadas a los principios físicos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003006/2025-26/RA5> a ns1:LearningResult ;
    ns1:learningResultCode "RA5" ;
    ns1:learningResultDescription "Conocer y aplicar los principios físicos de la teoría electromagnética y su aplicación a la resolución de problemas reales en ingeniería"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003006/2025-26/RA6> a ns1:LearningResult ;
    ns1:learningResultCode "RA6" ;
    ns1:learningResultDescription "Comprensión y dominio de los conceptos básicos sobre termodinámica y su aplicación para la resolución de problemas de ingeniería"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003006/2025-26/RA7> a ns1:LearningResult ;
    ns1:learningResultCode "RA7" ;
    ns1:learningResultDescription "Medir y analizar datos experimentales y aplicar técnicas experimentales relacionadas a los principios físicos"@es .

