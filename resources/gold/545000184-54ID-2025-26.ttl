    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation """La docencia se impartirá en la modalidad de presencial siempre que no haya una causa mayor, ajena al profesorado, que lo imposibilite.
En caso de tener que realizar -en parte o en su totalidad- la docencia en la modalidad " a distancia", se utilizará la plataforma Microsoft TEAMS."""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "36 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/545000184/2025-26/eventSchedule> ;
    schema:description "Se trata de formar profesionales capaces de diseñar y gestionar el uso, conservación y mantenimiento de los edificios, redactando los documentos técnicos necesarios."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/francisco.gonzalez.yunta%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/alicia.zaragoza%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/francisco.gonzalez.yunta%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/jj.orbaneja%40upm.es> ;
    schema:name "Mantenimiento"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000184/2025-26/CE12> a ns1:Competency ;
    ns1:competencyCode "CE12" ;
    ns1:competencyDescription "Conocimiento de los materiales y sistemas constructivos tradicionales o prefabricados empleados en la edificación, sus variedades y las características físicas y mecánicas que los definen."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000184/2025-26/CE17> a ns1:Competency ;
    ns1:competencyCode "CE17" ;
    ns1:competencyDescription "Capacidad para dictaminar sobre las causas y manifestaciones de las lesiones en los edificios, proponer soluciones para evitar o subsanar las patologías, y analizar el ciclo de vida útil de los elementos y sistemas constructivos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000184/2025-26/CE18> a ns1:Competency ;
    ns1:competencyCode "CE18" ;
    ns1:competencyDescription "Aptitud para intervenir en la rehabilitación de edificios y en la restauración y conservación del patrimonio construido."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000184/2025-26/CE19> a ns1:Competency ;
    ns1:competencyCode "CE19" ;
    ns1:competencyDescription "Capacidad para elaborar manuales y planes de mantenimiento y gestionar su implantación en el edificio."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000184/2025-26/CE21> a ns1:Competency ;
    ns1:competencyCode "CE21" ;
    ns1:competencyDescription "Capacidad para aplicar la normativa técnica al proceso de la edificación, y generar documentos de especificación técnica de los procedimientos y métodos constructivos de edificios."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000184/2025-26/CE24> a ns1:Competency ;
    ns1:competencyCode "CE24" ;
    ns1:competencyDescription "Capacidad para desarrollar constructivamente las instalaciones del edificio, controlar y planificar su ejecución y verificar las pruebas de servicio y de recepción, así como su mantenimiento."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000184/2025-26/CG07> a ns1:Competency ;
    ns1:competencyCode "CG07" ;
    ns1:competencyDescription "Dirigir y gestionar el uso, conservación y mantenimiento de los edificios, redactando los documentos técnicos necesarios."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000184/2025-26/CT01> a ns1:Competency ;
    ns1:competencyCode "CT01" ;
    ns1:competencyDescription "Trabajo en equipo. Equipos interdisciplinares."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000184/2025-26/CT02> a ns1:Competency ;
    ns1:competencyCode "CT02" ;
    ns1:competencyDescription "Comunicación oral y escrita. Capacidad de análisis y síntesis y de discusión de ideas propias. Capacidad de comunicación a través de la palabra y la imagen."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000184/2025-26/CT17> a ns1:Competency ;
    ns1:competencyCode "CT17" ;
    ns1:competencyDescription "Habilidades en las relaciones interpersonales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000184/2025-26/RA100> a ns1:LearningResult ;
    ns1:learningResultCode "RA100" ;
    ns1:learningResultDescription "Poder exponer y comunicar las soluciones a los problemas tanto de forma oral como escrita."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000184/2025-26/RA101> a ns1:LearningResult ;
