    ns1:inpersonHours "50 horas (42.7%)"@es ;
    ns1:numberOfCredits 4.5 ;
    ns1:otherInformation """A lo largo de esta asignatura se potenciarán las competencias y capacidades de los alumnos relacionadas con el desarrollo de procesos y productos sostenibles.
En concreto, la asignatura se relaciona con el ODS 9 "Industria, innovación e infraestructuras" y el ODS 12 "Producción y consumo responsables"."""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "50 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/53001275/2025-26/eventSchedule> ;
    schema:description "La asignatura es eminentemente práctica, aunque tiene una base teórica que es importante manejar con soltura. Al comienzo de la asignatura se enseña el manejo de la herramienta informática que posteriormente se empleará en la fase de realización de los diferentes diseños. Una vez conocida la misma, se introducirá la metodología básica para el diseño de procesos, incluyendo el dimensionamiento de los equipos y el análisis de costes del proceso obtenido. Posteriormente, se introducirá la metodología básica para el diseño de productos y la evaluación de las propiedades de éstos a partir de su estructura molecular."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/maria.gonzalezmiquel%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/ismael.diaz%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/maria.gonzalezmiquel%40upm.es> ;
    schema:name "Ingenieria de Procesos y Productos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001275/2025-26/%28a%29> a ns1:Competency ;
    ns1:competencyCode "(a)" ;
    ns1:competencyDescription "APLICA. Habilidad para aplicar conocimientos científicos, matemáticos y tecnológicos en sistemas relacionados con la práctica de la ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001275/2025-26/%28c%29> a ns1:Competency ;
    ns1:competencyCode "(c)" ;
    ns1:competencyDescription "DISEÑA. Habilidad para diseñar un sistema, componente o proceso que alcance los requisitos deseados teniendo en cuenta restricciones realistas tales como las económicas, medioambientales, sociales, políticas, éticas, de salud y seguridad, de fabricación y de sostenibilidad."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001275/2025-26/%28d%29> a ns1:Competency ;
    ns1:competencyCode "(d)" ;
    ns1:competencyDescription "TRABAJA EN EQUIPO. Habilidad para trabajar en equipos multidisciplinares."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001275/2025-26/%28e%29> a ns1:Competency ;
    ns1:competencyCode "(e)" ;
    ns1:competencyDescription "RESUELVE. Habilidad para identificar, formular y resolver problemas de ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001275/2025-26/%28i%29> a ns1:Competency ;
    ns1:competencyCode "(i)" ;
    ns1:competencyDescription "SE ACTUALIZA. Reconocimiento de la necesidad y la habilidad para comprometerse al aprendizaje continuo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001275/2025-26/%28k%29> a ns1:Competency ;
    ns1:competencyCode "(k)" ;
    ns1:competencyDescription "USA HERRAMIENTAS. Habilidad para usar las técnicas, destrezas y herramientas ingenieriles modernas necesarias para la práctica de la ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001275/2025-26/%28l%29> a ns1:Competency ;
    ns1:competencyCode "(l)" ;
    ns1:competencyDescription "ES BILINGÜE. Capacidad de trabajar en un entorno bilingüe (inglés/castellano)."@es .

