    ns1:inpersonHours "76 horas (48.7%)"@es ;
    ns1:numberOfCredits 6.0 ;
    ns1:otherInformation """La plataforma que se utilizara como base con los alumnos será vía Moodle. De igual manera, la aportación de documentación a los alumnos como soporte de estudio será también a través de la plataforma Moodle.
Se respetaran, siempre que sea posible, los horarios de las clases que fije la Escuela . La comunicación será personal con los alumnos en las correspondientes tutorías que se fijaran a conveniencia de las partes o bien mediante el correo electrónico oficial."""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "76 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/545000018/2025-26/eventSchedule> ;
    schema:description """La asignatura Economía de la Empresa tiene como objetivo introducir al alumnado en los conceptos fundamentales del entorno económico y empresarial, proporciona una visión global del funcionamiento de las organizaciones y mercados.
Inicialmente, se abordan los principios generales de la economía y los sistemas económicos, tanto a nivel microeconómico como macroeconómico, con el objetivo de comprender el contexto en el que operan las empresas. A continuación, se estudia la empresa como unidad de producción, se analiza su estructura, funciones, formas jurídicas y su relación con el entorno.
A lo largo del curso se adquirirán conocimientos sobre el funcionamiento de los mercados, macroeconomía, rentabilidad, análisis financiero o toma de decisiones empresariales, sentando así las bases necesarias para interpretar el entorno económico y tomar decisiones en la gestión de empresas, especialmente en el ámbito de la construcción."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/alejandro.segura%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/aida.rodriguez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/alejandro.segura%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/jose.gismero%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/pilarcristina.izquierdo%40upm.es> ;
    schema:name "Economia de la Empresa"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000018/2025-26/CE06> a ns1:Competency ;
    ns1:competencyCode "CE06" ;
    ns1:competencyDescription "Conocimiento adecuado del concepto de empresa, su marco institucional, modelos de organización, planificación, control y toma de decisiones estratégicas en ambientes de certeza, riesgo e incertidumbre; sistemas de producción, costes, planificación, fuentes de financiación y elaboración de planes financieros y presupuestos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000018/2025-26/CE07> a ns1:Competency ;
    ns1:competencyCode "CE07" ;
    ns1:competencyDescription "Capacidad para organizar pequeñas empresas, y de participar como miembro de equipos multidisciplinares en grandes empresas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000018/2025-26/CG02> a ns1:Competency ;
    ns1:competencyCode "CG02" ;
    ns1:competencyDescription "Llevar el control económico de la obra elaborando las certificaciones y la liquidación de la obra ejecutada"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000018/2025-26/CG05> a ns1:Competency ;
    ns1:competencyCode "CG05" ;
    ns1:competencyDescription "Elaborar los proyectos técnicos y desempeñar la dirección de obras de edificación en el ámbito de su habilitación legal."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000018/2025-26/CG11> a ns1:Competency ;
    ns1:competencyCode "CG11" ;
    ns1:competencyDescription "Gestionar el proceso inmobiliario en su conjunto."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000018/2025-26/CG12> a ns1:Competency ;
    ns1:competencyCode "CG12" ;
    ns1:competencyDescription "Ostentar la representación técnica de las empresas constructoras en las obras de edificación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000018/2025-26/CT12> a ns1:Competency ;
    ns1:competencyCode "CT12" ;
    ns1:competencyDescription "Negociaciones, Reuniones."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000018/2025-26/CT13> a ns1:Competency ;
    ns1:competencyCode "CT13" ;
    ns1:competencyDescription "Ética y Deontología"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000018/2025-26/RA155> a ns1:LearningResult ;
    ns1:learningResultCode "RA155" ;
    ns1:learningResultDescription "Conocer la empresa, su marco institucional, los modelos de organización, planificación y control."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000018/2025-26/RA156> a ns1:LearningResult ;
    ns1:learningResultCode "RA156" ;
    ns1:learningResultDescription "Identificar y cuantificar los datos económicos y aplicarlos a la realidad del momento."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000018/2025-26/RA157> a ns1:LearningResult ;
    ns1:learningResultCode "RA157" ;
    ns1:learningResultDescription "Tomar las decisones estratégicas en diferentes ambientes del mundo empresarial."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000018/2025-26/RA158> a ns1:LearningResult ;
    ns1:learningResultCode "RA158" ;
    ns1:learningResultDescription "RA05. Decidir sobre las diferentes formas de financiación de la empresa, así como en la elaboración de planes financieros y de presupuestos."@es .

