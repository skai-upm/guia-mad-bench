    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/95000345/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/95000345/2025-26/RA186>,
        <https://guia-kg.skai.etsisi.upm.es/resource/95000345/2025-26/RA187>,
        <https://guia-kg.skai.etsisi.upm.es/resource/95000345/2025-26/RA188> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/95000345/2025-26/syllabus> ;
    ns1:inpersonHours "40 horas y 20 minutos (38.8%)"@es ;
    ns1:numberOfCredits 4.0 ;
    ns1:otherInformation """Esta asignatura contribuye a los siguientes Objetivos de Desarrollo Sostenible (ODS) establecidos por Naciones Unidas:
- ODS 3: Salud y bienestar. Los sistemas de ayuda a la decisión en medicina y la inteligencia artificial permiten optimizar los procesos de diagnóstico, pronóstico y seguimiento en un amplio rango de enfermedades y es un elemento clave para garantizar la equidad del cuidado.
- ODS 9: Industria, innovación e infraestructura. Los sistemas de ayuda a la decisión y la inteligencia artificial son tecnologías que permiten optimizar los procesos de salud, construyendo sistemas más proactivos y permitiendo un uso más eficiente de los recursos
El cronograma puede sufrir cambios respecto a lo indicado en esta guía.
Las actividades docentes se realizarán preferentemente de forma presencial, pero, si la situación y el número de alumnos lo hacen necesario, algunas actividades podrían organizarse en la modalidad online siguiendo las indicaciones de la UPM."""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "40 horas y 20 minutos"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/95000345/2025-26/eventSchedule> ;
    schema:description "El objetivo de la asignatura es introducir a los alumnos en el campo de los sistemas de ayuda a la decisión, especialmente aquellos que utilizan técnicas de inteligencia artificial. Se pretende que los estudiantes conozcan desde los puntos de vista teórico y práctico los métodos de gestión de datos de estudios clínicos, la visualización analítica de datos médicos en cuadros de mandos, el modelado y representación del conocimiento médico y las técnicas de aprendizaje y extracción de conocimiento."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/mariaelena.hernando%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/gema.garcia.saez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/i.oropesa%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/mariaelena.hernando%40upm.es> ;
    schema:name "Sistemas de Ayuda a la Decisión Médica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000345/2025-26/CE24> a ns1:Competency ;
    ns1:competencyCode "CE24" ;
    ns1:competencyDescription "Comprender, utilizar y diseñar sistemas de ayuda a la gestión de la información biomédica y a la toma de decisiones médicas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000345/2025-26/CE31> a ns1:Competency ;
    ns1:competencyCode "CE31" ;
    ns1:competencyDescription "Conocer los principales problemas bioéticos relacionados con el desarrollo de la Ingeniería Biomédica."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000345/2025-26/CG01> a ns1:Competency ;
    ns1:competencyCode "CG01" ;
    ns1:competencyDescription "Desarrollar las habilidades de aprendizaje necesarias para emprender actividades o estudios posteriores de forma autónoma y con confianza."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000345/2025-26/CG02> a ns1:Competency ;
    ns1:competencyCode "CG02" ;
    ns1:competencyDescription "Aplicar de forma profesional a su trabajo los conocimientos adquiridos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000345/2025-26/CG03> a ns1:Competency ;
    ns1:competencyCode "CG03" ;
    ns1:competencyDescription "Ser capaz de manejar todas las tecnologías de la información y las comunicaciones."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000345/2025-26/CG05> a ns1:Competency ;
    ns1:competencyCode "CG05" ;
    ns1:competencyDescription "Tener capacidad de análisis y síntesis, pensar de forma integrada, abordar los problemas desde diferentes perspectivas y estar siempre preparado para ¿to think out of the box¿"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000345/2025-26/CG06> a ns1:Competency ;
    ns1:competencyCode "CG06" ;
    ns1:competencyDescription "Adoptar una actitud ante los problemas de su competencia que considere que su papel no es exclusivamente aportar soluciones sino, siempre que sea posible, participar además en la propia identificación u definición de dichos problemas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000345/2025-26/CG07> a ns1:Competency ;
    ns1:competencyCode "CG07" ;
    ns1:competencyDescription "Ser capaz de utilizar el método científico."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000345/2025-26/CG08> a ns1:Competency ;
    ns1:competencyCode "CG08" ;
    ns1:competencyDescription "Entender, aplicar, adaptar y desarrollar herramientas, técnicas y protocolos de experimentación con rigor metodológico comprendiendo las limitaciones que tiene la aproximación experimental."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000345/2025-26/CG09> a ns1:Competency ;
    ns1:competencyCode "CG09" ;
    ns1:competencyDescription "Tener capacidad de descripción, cuantificación, análisis y evaluación de resultados experimentales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000345/2025-26/CG10> a ns1:Competency ;
    ns1:competencyCode "CG10" ;
    ns1:competencyDescription "Formular, diseñar y elaborar proyectos siendo capaz de liderar grupos de trabajo y buscar en distintas fuentes de información e integrar nuevos conocimientos en su investigación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000345/2025-26/CG11> a ns1:Competency ;
    ns1:competencyCode "CG11" ;
    ns1:competencyDescription "Elaborar y defender argumentos y resolver los problemas de forma efectiva y creativa."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000345/2025-26/CG12> a ns1:Competency ;
    ns1:competencyCode "CG12" ;
    ns1:competencyDescription "Tener capacidad de iniciativa, integración, colaboración y potenciación de la discusión crítica en el ámbito del trabajo en equipo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000345/2025-26/CG17> a ns1:Competency ;
    ns1:competencyCode "CG17" ;
    ns1:competencyDescription "Tener un comportamiento ético y profesional en todos los aspectos relacionados con el respeto por el medio ambiente y con el bienestar social, para utilizar de forma equilibrada las tecnologías en busca de una economía social y medioambientalmente sostenible."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000345/2025-26/RA186> a ns1:LearningResult ;
    ns1:learningResultCode "RA186" ;
    ns1:learningResultDescription "Conocer las características del conocimiento médico y su implicación en la toma de decisiones"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000345/2025-26/RA187> a ns1:LearningResult ;
    ns1:learningResultCode "RA187" ;
    ns1:learningResultDescription "Conocer técnicas de extracción de conocimiento en el ámbito de la inteligencia artificial"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000345/2025-26/RA188> a ns1:LearningResult ;
    ns1:learningResultCode "RA188" ;
    ns1:learningResultDescription "Conocer técnicas de visualización analítica como soporte a la toma de decisiones"@es .

