    schema:description "Diseño y desarrollo de efectos de audio en tiempo real utilizando plataformas hardware de bajo coste (Raspberry-Pi) y/o entornos de programación específicos."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/lino.garcia%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
