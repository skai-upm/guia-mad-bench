<https://guia-kg.skai.etsisi.upm.es/resource/595010141/2025-26/CE%20SO01> a ns1:Competency ;
    ns1:competencyCode "CE SO01" ;
    ns1:competencyDescription "Capacidad de construir, explotar y gestionar servicios y aplicaciones de telecomunicaciones, entendidas éstas como sistemas de captación, tratamiento analógico y digital, codificación, transporte, representación, procesado, almacenamiento, reproducción, gestión y presentación de servicios audiovisuales e información multimedia."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595010141/2025-26/CG%2002> a ns1:Competency ;
    ns1:competencyCode "CG 02" ;
    ns1:competencyDescription "Capacidad de búsqueda y selección de información, de razonamiento crítico y de elaboración y defensa de argumentos dentro del área."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595010141/2025-26/CG%2003> a ns1:Competency ;
    ns1:competencyCode "CG 03" ;
    ns1:competencyDescription "Capacidad para expresarse correctamente de forma oral y escrita y transmitir información mediante documentos y exposiciones en público."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595010141/2025-26/CG%2004> a ns1:Competency ;
    ns1:competencyCode "CG 04" ;
    ns1:competencyDescription "Capacidad de abstracción, de análisis y de síntesis y de resolución de problemas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595010141/2025-26/CG%2010> a ns1:Competency ;
    ns1:competencyCode "CG 10" ;
    ns1:competencyDescription "Capacidad para manejar especificaciones, reglamentos y normativas y la aplicación de las mismas en el desarrollo de la profesión."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595010141/2025-26/RA1040> a ns1:LearningResult ;
    ns1:learningResultCode "RA1040" ;
    ns1:learningResultDescription "Manipular el espectro de la señal de audio, mediante filtros o transformadas de Fourier, para extraer o modificar algún tipo de información inherente a la propia señal de audio."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595010141/2025-26/RA1042> a ns1:LearningResult ;
    ns1:learningResultCode "RA1042" ;
    ns1:learningResultDescription "Integrar tarjetas de sonido estéreo en el entorno de desarrollo Raspberry Pi para el tratamiento de señales de audio."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595010141/2025-26/RA1043> a ns1:LearningResult ;
    ns1:learningResultCode "RA1043" ;
    ns1:learningResultDescription "Implementar aplicaciones de procesado digital en tiempo real en un entorno hardware de bajo coste (Raspberry Pi)."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595010141/2025-26/RA1044> a ns1:LearningResult ;
    ns1:learningResultCode "RA1044" ;
    ns1:learningResultDescription "Modificar/adaptar los algoritmos de procesado digital de audio que procesan ficheros de audio a entornos de trabajo de tiempo real (procesado basado en frame datos)."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595010141/2025-26/RA1045> a ns1:LearningResult ;
    ns1:learningResultCode "RA1045" ;
    ns1:learningResultDescription "Diseñar aplicaciones/prototipos de audio digital como dispositivos independientes."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595010141/2025-26/RA1046> a ns1:LearningResult ;
    ns1:learningResultCode "RA1046" ;
    ns1:learningResultDescription "Desarrollar algoritmos como Objetos del Sistema de MATLAB"@es .

