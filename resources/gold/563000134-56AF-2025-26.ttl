    ns1:inpersonHours "42 horas y 30 minutos (40.9%)"@es ;
    ns1:numberOfCredits 4.0 ;
    ns1:otherInformation "La asignatura está relacionada con el Objetivo de Desarrollo Sostenible (ODS) nº 17 \"garantizar modalidades de consumo y producción sostenibles\" ya que en ella se abordan aspectos como el etiquetado energético, las ecoetiquetas, el diseño ecológico y la reciclabilidad de los productos. Esta información permite a los consumidores comparar los productos desde el punto de vista de su impacto sobre el medio ambiente y tomar decisiones de compra más responsables."@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "42 horas y 30 minutos"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/563000134/2025-26/eventSchedule> ;
    schema:description "La finalidad de esta asignatura es que el alumno sea capaz de buscar las directivas, reglamentos, etc. que le son de aplicación a un determinado producto y dar soluciones mediante el uso de normas armonizadas u otros procedimientos válidos, a los requisitos incluidos en las primeras. Así mismo se abordarán los procedimientos, ensayos y documentos necesarios previos a la declaración de conformidad y comercialización de un producto al que sea de aplicación el marcado CE dentro de la UE."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/fernando.garnacho%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/antonio.nieto%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/fernando.garnacho%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/roque.calvo%40upm.es> ;
    schema:name "Certificación y Calificación de Productos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000134/2025-26/CB07> a ns1:Competency ;
    ns1:competencyCode "CB07" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en entornos nuevos o poco conocidos dentro de contextos más amplios (o multidisciplinares) relacionados con su área de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000134/2025-26/CB09> a ns1:Competency ;
    ns1:competencyCode "CB09" ;
    ns1:competencyDescription "Que los estudiantes sepan comunicar sus conclusiones y los conocimientos y razones últimas que las sustentan a públicos especializados y no especializados de un modo claro y sin ambigüedades"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000134/2025-26/CEC01> a ns1:Competency ;
    ns1:competencyCode "CEC01" ;
    ns1:competencyDescription "Capacidad para proyectar, calcular y diseñar productos, procesos e instalaciones en todos los ámbitos de la ingeniería de producción."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000134/2025-26/CEC02> a ns1:Competency ;
    ns1:competencyCode "CEC02" ;
    ns1:competencyDescription "Capacidad para la dirección de sistemas y tecnologías de la ingeniería de producción, cumpliendo la normativa vigente, asegurando la calidad del servicio."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000134/2025-26/CEC08> a ns1:Competency ;
    ns1:competencyCode "CEC08" ;
    ns1:competencyDescription "Conocimiento, comprensión y capacidad para aplicar la legislación necesaria en el ámbito de la ingeniería de producción."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000134/2025-26/CEI03> a ns1:Competency ;
    ns1:competencyCode "CEI03" ;
    ns1:competencyDescription "Desarrollar capacidades de aplicación de los conocimientos adquiridos al diseño de procesos industriales, en función de las características de los elementos a producir, con criterios de máxima calidad, productividad, seguridad y respeto al medio ambiente"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000134/2025-26/CEI05> a ns1:Competency ;
    ns1:competencyCode "CEI05" ;
    ns1:competencyDescription "Conocer la legislación sobre la producción con objeto de emitir informes y dictámenes o de realizar proyectos de ingeniería sobre sistemas de producción"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000134/2025-26/CEI16> a ns1:Competency ;
    ns1:competencyCode "CEI16" ;
    ns1:competencyDescription "Capacidad de comunicar con sus colegas, con la comunidad académica en su conjunto y con la sociedad en general acerca de sus áreas de conocimiento"@es .

