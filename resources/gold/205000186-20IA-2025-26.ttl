<https://guia-kg.skai.etsisi.upm.es/resource/205000186/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. UT 1. Dimensión y Localización optima"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000186/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. 1. Teoría de la Localización. 1. Teorías clásicas de localización 2. Factores de localización 3. Localización y economías de aglomeración. 4. Métodos de análisis de localización Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000186/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "2.5. 7. Gestión del aprovisionamiento 1. La función del aprovisionamiento 2. Objetivos y actividades de la gestión de compras 3. Estudio y evaluación de proveedores 4. Pedido y entrega de mercancías Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000186/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "2.6. 8. Gestión y organización de almacenes 1.Concepto y objetivos de los almacenes 2. Materiales y productos almacenados. 3 Clasificación ABC 4. Organización del almacén 5. Procesos operativos 6. Capacidad del almacén 7. Plataformas de distribución Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000186/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "2.7. 9.Operadores y Plataformas logísticas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000186/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "2.7.1. 1. Concepto de operadores logísticos 2. Externalización de las actividades logísticas (Outsourcing) 3. Tipos de externalización Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000186/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "2.7.2. 1. Concepto de plataforma logística 2. Clasificación de las plataformas logísticas Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000186/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "3. 3. Gestión de stock"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000186/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "3.1. 10. Los stocks. 1. Concepto de stock. 2. Clasificación 3. Factores que intervienen en la gestión de stock 4. La demanda 5. Clasificación de la demanda 6. Previsión de la demanda. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000186/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "3.2. 11 Gestión de stock con demanda conocida. 1. Los costes en la gestión de stocks 2. Cantidad económica de pedido 3. Determinación del punto de pedido 4. Descuento para grandes pedidos 5. Aprovisionamiento no instantaneo Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000186/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "3.3. 12. Gestión de stock con demanda aleatoria. 1. Modelo de cantidad fija de pedido. 2. Sistema de restablecimiento del nivel máximo de pedido 3. Cálculo del stock de seguridad 4. Tamaño de pedido para productos perecederos Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000186/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. 2. Dimensión óptima. 1. Criterio para definir la dimensión de una empresa 2. Dimensión óptima y capacidad de producción. 3. Los costes y el proceso de optimización. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000186/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "2. UT 2. Logística"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000186/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "2.1. 3. Introducción a la Logística. 1. Concepto de logística 2. Evolución de la logística 3. Cadena de suministro 4. Ciclos básicos de la gestión logística 5. Ciclos básicos de la gestión logística 6. Concepto de logística integral 7. Costes logísticos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000186/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "2.2. 4. Logística inversa. 1. Concepto de logística inversa 2. Actividades de la logística inversa 3. Opciones de recuperación de productos 4. Sistemas Integrados de Gestión 5. Logística inversa en la distribución de productos agroalimentarios Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000186/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "2.3. 5. Transporte"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000186/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "2.3.1. 1. Función del transporte 2. Tipos y modos de transporte. 3. El coste del transporte. 4. Planificación de las rutas de reparto. 5. Dimensión de la flota de vehículos Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000186/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "2.3.2. Planteamiento y aplicaciones del modelo de transporte 1. Distribución de mercancías entre distintos origenes y distintos destinos 2. Asignación de conductores a vehículos Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000186/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "2.4. 6. Distribución comercial en procesos integrados 1. La distribución comercial como modelo de programación lineal 2. Modelos de distribución comercial para monoproducto y multiproductos. Sin subniveles"@es .

