    ns1:itemIndex 25 ;
    ns1:syllabusDescription "6.2. Cómo generar proximidad y confianza con los demás. Elementos para conocer a su equipo de trabajo Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/73000022/2025-26/syllabus/26> a ns1:SyllabusItem ;
    ns1:itemIndex 26 ;
    ns1:syllabusDescription "6.3. Cómo mostrar resultados y beneficios del trabajo individual y colectivo. Cómo generar compromiso individual y grupal Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/73000022/2025-26/syllabus/27> a ns1:SyllabusItem ;
    ns1:itemIndex 27 ;
    ns1:syllabusDescription "6.4. Planteamiento y determinación de procesos para el logro de objetivos. Verificación y Corrección de procesos de trabajo Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/73000022/2025-26/syllabus/28> a ns1:SyllabusItem ;
    ns1:itemIndex 28 ;
    ns1:syllabusDescription "7. Dirección de equipos: técnicas de dinamización social"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/73000022/2025-26/syllabus/29> a ns1:SyllabusItem ;
    ns1:itemIndex 29 ;
    ns1:syllabusDescription "7.1. Tipos de actitudes en un equipo de trabajo Sin subniveles"@es .

