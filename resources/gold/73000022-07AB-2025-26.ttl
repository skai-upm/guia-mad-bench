    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/73000022/2025-26/eventSchedule> ;
    schema:description """La planificación de las tareas de extinción y prevención de incendios forestales requiere tener muy en cuenta las buenas prácticas de seguridad, tanto activa como pasiva, en los trabajos, así como el uso y mantenimiento de los equipos de protección individual (EPIs), las técnicas de autoprotección, los procedimientos de selección del personal adecuado (de acuerdo con criterios de
salud, físicos y psicológicos) y el manejo, motivación y dirección de los equipos en que se estructura este personal. En el desarrollo de la asignatura se facilitará documentación relevante, se programarán tareas evaluables para abordar parcial y secuencialmente los apartados de un programa de selección de personal, de un plan de prevención de riesgos (incluida la selección de
equipos), de un programa de formación del personal y de actividades de motivación y gestión de personal (liderazgo) de aplicación a este tipo de actividad, usando la plataforma de tele-enseñanza moodle. Además, se expondrán de forma sincrónica varios estudios de caso (por ejemplo, sobre el accidente de Yarnell Hill (USA) y sobre los incendios de interfaz con víctimas en Mati
(Grecia) o Maui (Hawaii, USA)"""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/eduardo.tolosana%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/eduardo.tolosana%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/javier.gonzalezr%40upm.es> ;
    schema:name "Gestion de Recursos Humanos. Seguridad y Salud"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/73000022/2025-26/CB6> a ns1:Competency ;
    ns1:competencyCode "CB6" ;
    ns1:competencyDescription "Poseer y comprender conocimientos que aporten una base u oportunidad de ser originales en el desarrollo y/o aplicación de ideas, a menudo en un contexto de investigación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/73000022/2025-26/CE%202.2> a ns1:Competency ;
    ns1:competencyCode "CE 2.2" ;
    ns1:competencyDescription "Capacidad para coordinar al personal involucrado en la prevención y detección de incendios."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/73000022/2025-26/CE%202.3> a ns1:Competency ;
    ns1:competencyCode "CE 2.3" ;
    ns1:competencyDescription "Capacidad para implantar medidas de seguridad y protección del personal de lucha contra incendios"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/73000022/2025-26/CG%203> a ns1:Competency ;
    ns1:competencyCode "CG 3" ;
    ns1:competencyDescription "Capacidad crítica para el análisis, la síntesis y el aprendizaje mediante el intercambio de opiniones, presentando argumentos sólidos y estructurados"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/73000022/2025-26/RA12> a ns1:LearningResult ;
    ns1:learningResultCode "RA12" ;
    ns1:learningResultDescription "Conocer la bibliografía básica en esta materia desde cualquier plataforma"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/73000022/2025-26/RA27> a ns1:LearningResult ;
    ns1:learningResultCode "RA27" ;
    ns1:learningResultDescription "Conocimientos adecuados para la redacción y estructuración de textos académicos (tanto en inglés como en español): estructura, vocabulario y estilo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/73000022/2025-26/RA34> a ns1:LearningResult ;
    ns1:learningResultCode "RA34" ;
    ns1:learningResultDescription "· Que los estudiantes puedan transmitir información, ideas, problemas y soluciones a un público tanto especializado como no especializado."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/73000022/2025-26/RA45> a ns1:LearningResult ;
    ns1:learningResultCode "RA45" ;
    ns1:learningResultDescription "Que los estudiantes tengan conocimientos para crear e interpretar cartografía temática y aplicarla a la gestión en su campo de trabajo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/73000022/2025-26/RA51> a ns1:LearningResult ;
    ns1:learningResultCode "RA51" ;
    ns1:learningResultDescription "Conocimientos avanzados sobre tácticas de extinción de incendios y métodos de ataque"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/73000022/2025-26/RA52> a ns1:LearningResult ;
    ns1:learningResultCode "RA52" ;
    ns1:learningResultDescription "Capacidad para coordinar y organizar planes de lucha contra incendios, gestionar el personal y la maquinaria"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/73000022/2025-26/RA53> a ns1:LearningResult ;
    ns1:learningResultCode "RA53" ;
    ns1:learningResultDescription "Conocimientos sobre la prevención de riesgos laborales, seguridad del personal y equipos de protección personal"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/73000022/2025-26/RA55> a ns1:LearningResult ;
    ns1:learningResultCode "RA55" ;
    ns1:learningResultDescription "· Que los estudiantes tengan conocimientos y capacidades para tomar, gestionar y analizar datos de detección, prevención o lucha contra incendios."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/73000022/2025-26/RA86> a ns1:LearningResult ;
    ns1:learningResultCode "RA86" ;
    ns1:learningResultDescription "Capacidad para diseñar un programa de selección de personal de equipos de extinción y/o prevención de incendios forestales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/73000022/2025-26/RA87> a ns1:LearningResult ;
    ns1:learningResultCode "RA87" ;
    ns1:learningResultDescription "Capacidad para identificar, comprender y aplicar el marco jurídico que condiciona la actuación en seguridad y salud laborales en el marco de la prevención y extinción de incendios forestales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/73000022/2025-26/RA88> a ns1:LearningResult ;
    ns1:learningResultCode "RA88" ;
    ns1:learningResultDescription "Capacidad para diseñar un plan de prevención de riesgos laborales a partir de la realización de un estudio inicial de riesgos (o su actualización), incluyendo la selección y mantenimiento de los EPIs utilizados en prevención y extinción de incendios."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/73000022/2025-26/RA89> a ns1:LearningResult ;
    ns1:learningResultCode "RA89" ;
    ns1:learningResultDescription "Capacidad para diseñar un programa de entrenamiento y formación en materia de prevención de riesgos para el personal de equipos de extinción y/o prevención"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/73000022/2025-26/RA90> a ns1:LearningResult ;
    ns1:learningResultCode "RA90" ;
    ns1:learningResultDescription "Conociendo los métodos de motivación, comunicación y liderazgo, capacidad para gestionar el trabajo colectivo cotidiano dentro de un operativo de extinción y/o prevención."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/73000022/2025-26/RA91> a ns1:LearningResult ;
    ns1:learningResultCode "RA91" ;
    ns1:learningResultDescription "Capacidad de evaluar el trabajo del personal, verificando y corrigiendo los procesos de trabajo"@es .

