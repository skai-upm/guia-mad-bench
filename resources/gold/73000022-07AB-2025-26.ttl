    ns1:itemIndex 4 ;
    ns1:syllabusDescription "2. Normas de seguridad en la extinción. Seguridad activa y pasiva"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/73000022/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "2.1. Seguridad Pasiva: el Equipo de Protección Individual (EPI). Normativa, composición, normas de uso Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/73000022/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "2.2. Seguridad activa: situaciones de riesgo y protocolos de seguridad: Protocolo LACES-OCELA, TEFF, zona del Hombre Muerto, Método Campbell de evaluación de la situación Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/73000022/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "2.3. Estudio de caso. Ejemplos prácticos y propuestas para el análisis Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/73000022/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "3. Seguridad en operaciones específicas de extinción"@es .

