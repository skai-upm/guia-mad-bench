    ns1:syllabusDescription "1.2. La normativa de Emergencias Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/73000022/2025-26/syllabus/20> a ns1:SyllabusItem ;
    ns1:itemIndex 20 ;
    ns1:syllabusDescription "5.1. Técnicas de selección de personal. Criterios de salud (física y psicotécnica), aptitud y experiencia. Pruebas de selección Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/73000022/2025-26/syllabus/21> a ns1:SyllabusItem ;
    ns1:itemIndex 21 ;
    ns1:syllabusDescription "5.2. Formación del personal. Programas de formación previa y continua Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/73000022/2025-26/syllabus/22> a ns1:SyllabusItem ;
    ns1:itemIndex 22 ;
    ns1:syllabusDescription "5.3. Programas de entrenamiento durante la campaña. Discusión de casos y simulacros Sin subniveles"@es .

