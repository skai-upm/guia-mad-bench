<https://guia-kg.skai.etsisi.upm.es/resource/203000010/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Introducción. Enfoque de Sistemas. Diagramas de Forrester. Evaluación de modelos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000010/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Captura de luz por las cubiertas vegetales. Desarrollo en Excel de un modelo de intercepción de luz. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000010/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "6.1. Generación y calibración de coeficientes de cultivar. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000010/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "7. Aplicaciones de DSSAT I. Optimización productiva y ambiental del riego y la fertilización. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000010/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "8. Aplicaciones de DSSAT II. Rotaciones de cultivo. Evaluación productiva y ambiental. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000010/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "9. Aplicaciones de DSSAT III. Proyecciones de impacto y adaptación al cambio climático. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000010/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "10. Aplicaciones de DSSAT IV. Análisis espacial de resultados. Estudio de caso Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000010/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "2. 2. Crecimiento, reparto de asimilados y producción de los cultivos. Fuentes y sumideros."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000010/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "2.1. Desarrollo en Excel de un modelo de crecimiento potencial, cuajado de sumideros y rendimiento. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000010/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "3. Desarrollo y fenologia. Tiempo térmico. Efectos del fotoperiodo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000010/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "3.1. Desarrollo en Excel de un modelo de fenología. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000010/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "4. Evapotranspiración y nutrición nitrogenada."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000010/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "4.1. Desarrollo en Excel de un modelo potencial de balance hídrico y balance de nitrógeno. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000010/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "5. Introducción al DSSAT. Archivos de entrada y salida. Generación y uso de archivos de clima y suelo. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000010/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "6. Archivos de experimento. Archivos de mediciones (A y T). Archivos de cultivar, ecotipo y especie."@es .

