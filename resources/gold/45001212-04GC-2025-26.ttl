<https://guia-kg.skai.etsisi.upm.es/resource/45001212/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Cinemática del Sólido Rígido"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001212/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Campo de velocidades. Movimiento helicoidal tangente y rotación instantánea. Composición de movimientos. Sólidos tangentes: rodadura, pivotamiento, deslizamiento. Campo de aceleraciones. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001212/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "4.1. El oscilador armónico simple. Oscilaciones con amortiguamiento. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001212/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "4.2. Oscilaciones forzadas. Amplificación dinámica y resonancia. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001212/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "5. Oscilaciones lineales con n grados de libertad"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001212/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "5.1. Estática analítica: Condiciones de equilibrio estático de un sistema. Concepto y condiciones para la estabilidad del equilibrio. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001212/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "5.2. Linealización de las ecuaciones para pequeñas oscilaciones alrededor del equilibrio. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001212/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "5.3. Oscilaciones libres: modos normales de vibración y frecuencias propias. Sistemas con amortiguamiento. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001212/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "5.4. Oscilaciones forzadas. Régimen transitorio y permanente. Participación modal. Resonancia. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001212/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "6. Ecuaciones de la dinámica del Sólido Rígido"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001212/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "6.1. Concepto de Sólido Rígido. Geometría de masas: tensor de inercia. Aplicación de los teoremas generales. Ecuaciones cardinales de la estática y de la dinámica. Ligaduras del sólido Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001212/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "6.2. Aplicación de los teoremas generales: ecuaciones de Euler. Expresiones en el triedro del cuerpo, triedro intermedio y triedro fijo. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001212/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Rotación finita como transformación ortogonal. Rotación activa y pasiva. Parametrización de rotaciones: ángulos de Euler. Composición de rotaciones. Velocidad de rotación como derivada de la rotación finita. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001212/2025-26/syllabus/20> a ns1:SyllabusItem ;
    ns1:itemIndex 20 ;
    ns1:syllabusDescription "7. Aplicaciones de la dinámica del Sólido Rígido"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001212/2025-26/syllabus/21> a ns1:SyllabusItem ;
    ns1:itemIndex 21 ;
    ns1:syllabusDescription "7.1. Movimiento por inercia (Poinsot) Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001212/2025-26/syllabus/22> a ns1:SyllabusItem ;
    ns1:itemIndex 22 ;
    ns1:syllabusDescription "7.2. Movimiento de sólido simétrico pesado (peonza). Efecto giroscópico. Estabilidad del movimiento. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001212/2025-26/syllabus/23> a ns1:SyllabusItem ;
    ns1:itemIndex 23 ;
    ns1:syllabusDescription "8. Cálculo de cables"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001212/2025-26/syllabus/24> a ns1:SyllabusItem ;
    ns1:itemIndex 24 ;
    ns1:syllabusDescription "8.1. Ecuaciones de equilibrio de cables flexibles. Configuraciones de equilibrio: parábola, catenaria. Rigidez geométrica de un cable. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001212/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "2. Principios y teoremas generales de la dinámica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001212/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "2.1. Tipos de fuerzas sobre un sistema mecánico. Magnitudes cinéticas. Principios y teoremas de Newton y Euler. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001212/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "2.2. Principio de los trabajos virtuales. Principio de D'Alembert. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001212/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "3. Dinámica analítica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001212/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "3.1. Concepto de coordenadas generalizadas. Principio de D'Alembert en coordenadas generalizadas. Ecuaciones de Lagrange. Sin subniveles"@es .

