<https://guia-kg.skai.etsisi.upm.es/resource/65001038/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/65001038/2025-26/CG%201>,
