    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/65001038/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/65001038/2025-26/didactic_resource/2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/65001038/2025-26/didactic_resource/3>,
        <https://guia-kg.skai.etsisi.upm.es/resource/65001038/2025-26/didactic_resource/4> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/65001038/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/65001038/2025-26/RA187>,
        <https://guia-kg.skai.etsisi.upm.es/resource/65001038/2025-26/RA188>,
        <https://guia-kg.skai.etsisi.upm.es/resource/65001038/2025-26/RA189>,
        <https://guia-kg.skai.etsisi.upm.es/resource/65001038/2025-26/RA190>,
        <https://guia-kg.skai.etsisi.upm.es/resource/65001038/2025-26/RA191> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/65001038/2025-26/syllabus> ;
    ns1:inpersonHours "51 horas (43.6%)"@es ;
    ns1:numberOfCredits 4.5 ;
    ns1:otherInformation """En esta asignatura se trabajan los siguientes Objetivos de Desarrollo Sostenible
ODS6: Garantizar la disponibilidad y la gestión sostenible del agua y el saneamiento para todos.
ODS9: Desarrollar infraestructuras resilientes, promover la industrialización inclusiva y sostenible, y fomentar la innovación.
ODS12: Garantizar las pautas de consumo y de producción sostenibles."""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "51 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/65001038/2025-26/eventSchedule> ;
    schema:description "En esta asignatura se estudian las principales aplicaciones industriales de la electrometalurgia y la situación actual del reciclaje de metales. Se aplica la electrometalurgia acuosa a la obtención del cobre y del zinc, y la electrolisis ígnea a la obtención del aluminio y magnesio. Se estudian asimismo el reciclaje del acero, y de los cuatro metales no férreos principales (aluminio, cobre, zinc y plomo) así como de otros residuos ricos en metales (chatarras electrónicas, catalizadores, pilas y baterías). Se explica la aplicación del ACV en los procesos de obtención de metales a partir de mineral o residuo."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/anamaria.mendez%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/anamaria.mendez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/inigo.rbustinza%40upm.es> ;
    schema:name "Electrometalurgia y Reciclaje de Materiales Metalicos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001038/2025-26/CG%201> a ns1:Competency ;
    ns1:competencyCode "CG 1" ;
    ns1:competencyDescription "Conocer y aplicar conocimientos de ciencias y tecnologías básicas a la práctica de la Tecnología Minera."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001038/2025-26/CG%202> a ns1:Competency ;
    ns1:competencyCode "CG 2" ;
    ns1:competencyDescription "Poseer capacidad para diseñar, analizar, calcular, proyectar, construir, mantener, conservar, explotar, desarrollar, implementar, gestionar y mejorar productos, sistemas y procesos en los distintos ámbitos de las Tecnologías Mineras, usando técnicas analíticas, computacionales o experimentales apropiadas, incluyendo la función de asesoría en estos campos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001038/2025-26/CG%203> a ns1:Competency ;
    ns1:competencyCode "CG 3" ;
    ns1:competencyDescription "Aplicar los conocimientos adquiridos para identificar, formular y resolver problemas dentro de contextos amplios y multidisciplinarios, siendo capaces de integrar conocimientos, trabajando en equipos multidisciplinares."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001038/2025-26/CG%204> a ns1:Competency ;
    ns1:competencyCode "CG 4" ;
    ns1:competencyDescription "Comprender el impacto de la tecnología minera en el medio ambiente, el desarrollo sostenible de la sociedad. desarrollando la capacidad para la realización de estudios de ordenación del territorio y de los aspectos medioambientales relacionados con los proyectos, plantas e instalaciones, en su ámbito"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001038/2025-26/CG%205> a ns1:Competency ;
    ns1:competencyCode "CG 5" ;
    ns1:competencyDescription "Saber comunicar los conocimientos y conclusiones, tanto de forma oral, escrita y gráfica, a públicos especializados y no especializados de un modo claro y sin ambigüedades."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001038/2025-26/CG%206> a ns1:Competency ;
    ns1:competencyCode "CG 6" ;
    ns1:competencyDescription "Poseer habilidades de aprendizaje que permitan continuar estudiando a lo largo de la vida para su adecuado desarrollo profesional"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001038/2025-26/CG%207> a ns1:Competency ;
    ns1:competencyCode "CG 7" ;
    ns1:competencyDescription "Incorporar nuevas tecnologías y herramientas de la ingeniería en tecnología minera en sus actividades profesionales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001038/2025-26/F37> a ns1:Competency ;
    ns1:competencyCode "F37" ;
    ns1:competencyDescription "Metalurgia y tratamiento de concentrados minerales, metales y aleaciones: Industria metalurgia férrea y no férrea, aleaciones especiales, ensayos metalotécnicos, etc"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001038/2025-26/F41> a ns1:Competency ;
    ns1:competencyCode "F41" ;
    ns1:competencyDescription "Reciclaje de los materiales metálicos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001038/2025-26/RA187> a ns1:LearningResult ;
    ns1:learningResultCode "RA187" ;
    ns1:learningResultDescription "Capacidad para conocer, comprender y utilizar los principios de la ingeniería electrometalúrgica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001038/2025-26/RA188> a ns1:LearningResult ;
    ns1:learningResultCode "RA188" ;
    ns1:learningResultDescription "Capacidad para conocer, comprender y utilizar los principios de reciclaje de los materiales metálicos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001038/2025-26/RA189> a ns1:LearningResult ;
    ns1:learningResultCode "RA189" ;
    ns1:learningResultDescription "Capacidad para diseñar y planificar proyectos de instalaciones electrometalúrgicas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001038/2025-26/RA190> a ns1:LearningResult ;
    ns1:learningResultCode "RA190" ;
    ns1:learningResultDescription "Aplicar los conocimientos económicos, de calidad y medioambientales en el diseño de instalaciones electrometalúrgicas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001038/2025-26/RA191> a ns1:LearningResult ;
    ns1:learningResultCode "RA191" ;
    ns1:learningResultDescription "Aplicar los conocimientos económicos, de calidad y medioambientales en el reciclaje de materiales metálicos"@es .

