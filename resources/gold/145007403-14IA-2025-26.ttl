        <https://guia-kg.skai.etsisi.upm.es/resource/antonia.pacios%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/diego.garcia.ortizdevillajos%40upm.es> ;
    schema:name "Instalaciones de Aeropuertos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145007403/2025-26/CE59> a ns1:Competency ;
    ns1:competencyCode "CE59" ;
    ns1:competencyDescription "Conocimiento adecuado y aplicado a la Ingeniería de: Los métodos de cálculo y de desarrollo de las diferentes soluciones de edificación y pavimentación de aeropuertos; el cálculo de los sistemas específicos de los aeropuertos y sus infraestructuras; la evaluación de las actuaciones técnicas y económicas de las aeronaves; el manejo de las técnicas experimentales, equipamiento e instrumentos de medida propios de la disciplina; las técnicas de inspección, de control de calidad y de detección de fallos; los planes de seguridad y control en aeropuertos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145007403/2025-26/CE60> a ns1:Competency ;
    ns1:competencyCode "CE60" ;
    ns1:competencyDescription "Conocimiento aplicado de: edificación; electricidad; electrotecnia; electrónica; mecánica del vuelo; hidráulica; instalaciones aeroportuarias; ciencia y tecnología de los materiales; teoría de estructuras; mantenimiento y explotación de aeropuertos; transporte aéreo, cartografía, topografía, geotecnia y meteorología."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145007403/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Capacidad para identificar y resolver problemas aplicando, con creatividad, los conocimientos adquiridos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145007403/2025-26/CG9> a ns1:Competency ;
    ns1:competencyCode "CG9" ;
    ns1:competencyDescription "Razonamiento crítico y capacidad de asociación que posibiliten el aprendizaje continuo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145007403/2025-26/RA79> a ns1:LearningResult ;
    ns1:learningResultCode "RA79" ;
    ns1:learningResultDescription "Conocimiento, comprensión, aplicación, análisis y síntesis de los sistemas específicos de los aeropuertos y de sus infraestructuras, así como el manejo de las técnicas experimentales relacionadas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145007403/2025-26/RA80> a ns1:LearningResult ;
    ns1:learningResultCode "RA80" ;
    ns1:learningResultDescription "Conocimiento, comprensión, aplicación y síntesis para el diseño de las instalaciones de las infraestructuras de la zona de actividades aeroportuarias."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145007403/2025-26/RA81> a ns1:LearningResult ;
    ns1:learningResultCode "RA81" ;
    ns1:learningResultDescription "Conocimiento y aplicación de los aspectos más destacados de mantenimiento, explotación y gestión de las distintas instalaciones aeroportuarias."@es .

