<https://guia-kg.skai.etsisi.upm.es/resource/115100001> a ns1:Course ;
    ns1:courseType "Básica"@es ;
    ns1:courseYear 2 ;
    ns1:semester "Tercer semestre"@es ;
    schema:courseCode 115100001 ;
    schema:hasCourseInstance <https://guia-kg.skai.etsisi.upm.es/resource/115100001/2025-26> ;
    schema:name "Sociology And Deontology In Physical Activity And"@en,
        "Sociología y Deontología de la Afyd"@es ;
    schema:numberOfCredits 6.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/115100001/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/115100001/2025-26/CE24>,
        <https://guia-kg.skai.etsisi.upm.es/resource/115100001/2025-26/CE25>,
        <https://guia-kg.skai.etsisi.upm.es/resource/115100001/2025-26/CG16> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/115100001/2025-26/didactic_resource/1> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/115100001/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/115100001/2025-26/RA10>,
        <https://guia-kg.skai.etsisi.upm.es/resource/115100001/2025-26/RA31>,
        <https://guia-kg.skai.etsisi.upm.es/resource/115100001/2025-26/RA8> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/115100001/2025-26/syllabus> ;
    ns1:inpersonHours "62 horas (39.7%)"@es ;
    ns1:numberOfCredits 6.0 ;
    ns1:otherInformation "Esa asignatura está alineada con los ODS 3, 4 Y 5."@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "62 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/115100001/2025-26/eventSchedule> ;
    schema:description "La Sociología y Deontología de la Actividad Física y del Deporte es una materia básica que se encarga de analizar el deporte como uno de los fenómenos sociales más importantes de la sociedad contemporánea. Bien como práctica activa, bien como espectáculo de masas, este fenómeno ha pasado a formar parte esencial en la vida y cultura del hombre moderno. Necesitamos comprender su dimensión social así como su naturaleza ambivalente: su potencialidad para transmitir valores y contravalores. Y también asumir las responsabilidades éticas y deontológicas que nos corresponden."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/javier.duran%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/javier.duran%40upm.es> ;
    schema:name "Sociología y Deontología de la Afyd"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100001/2025-26/CE24> a ns1:Competency ;
    ns1:competencyCode "CE24" ;
    ns1:competencyDescription "Elaborar y comunicar, de manera crítica y fundamentada, argumentos y juicios sobre el valor de la actividad física y el deporte, y sobre sus posibilidades de contribuir al desarrollo y bienestar de las personas y de la sociedad, y al desarrollo sostenible, así como sobre su especial relación con la salud y la calidad de vida. Nivel 3."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100001/2025-26/CE25> a ns1:Competency ;
    ns1:competencyCode "CE25" ;
    ns1:competencyDescription "Analizar e interpretar los diferentes estudios referidos a las prácticas de actividad físico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100001/2025-26/CG16> a ns1:Competency ;
    ns1:competencyCode "CG16" ;
    ns1:competencyDescription "Desarrollar la conciencia de respeto e igualdad entre géneros, igualdad democrática y atención a la diversidad, como principios éticos necesarios para el correcto ejercicio profesional en las Ciencias de la Actividad Física y del Deporte."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100001/2025-26/RA10> a ns1:LearningResult ;
    ns1:learningResultCode "RA10" ;
    ns1:learningResultDescription "Actitudes flexibles y capacidad de adaptación en una sociedad en constante evolución"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100001/2025-26/RA31> a ns1:LearningResult ;
    ns1:learningResultCode "RA31" ;
    ns1:learningResultDescription "Comprender la importancia dela competición y adaptación de las reglas para el proceso formativo y desarrollo de valores"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100001/2025-26/RA8> a ns1:LearningResult ;
    ns1:learningResultCode "RA8" ;
    ns1:learningResultDescription "Actuar con conciencia y respeto ante todas las personas sin distinción de género, cultura o religión"@es .

