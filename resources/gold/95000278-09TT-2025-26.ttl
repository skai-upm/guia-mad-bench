<https://guia-kg.skai.etsisi.upm.es/resource/95000278/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Introducción al IoT y Ciudades Inteligentes y Sostenibles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000278/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Definición y características del IoT: Historia, evolución y componentes electrónicos de los sistemas IoT Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000278/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "3.2. Módulos electrónicos para dispositivos duales Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000278/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "3.3. Aplicaciones y beneficios en la gestión de ciudades inteligentes (Inteligencia Artificial y Gemelos Digitales) Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000278/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "4. Ámbitos de Aplicación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000278/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "4.1. Aplicaciones urbanas: iluminación, movilidad, energía, gestión del agua y residuos, medio ambiente, etc. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000278/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "4.2. Visitas técnicas: Laboratorio de Inteligencia de Ciudad de Madrid y Espacios Urbanos Inteligentes Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000278/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "4.3. Trabajo final: Propuesta de solución IoT para un problema urbano identificado durante las visitas Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000278/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Introducción a las ciudades inteligentes: Concepto, retos y oportunidades Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000278/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "1.3. Arquitectura IoT: electrónica para sensores y actuadores Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000278/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "2. Sistemas IoT para Ciudades Inteligentes"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000278/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "2.1. Electrónica para redes IoT en Ciudades Inteligentes Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000278/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "2.2. Sostenibilidad en Ciudades Inteligentes: energía solar, térmica, vibracional y RF, y electrónica para su integración con Ciudades Inteligentes Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000278/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "2.3. Hardware, Firmware y Integración en Ciudades Inteligentes (p.e. Arduino) Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000278/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "3. Tecnologías facilitadoras para ciudades inteligentes"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000278/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "3.1. Módulos electrónicos para encriptación IoT Sin subniveles"@es .

