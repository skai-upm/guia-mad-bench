    schema:name "Electronic Technologies For Smart Cities Iot Systems"@en,
        "Tecnologías Electrónicas Iot para Ciudades Inteligentes y Sostenibles"@es ;
    schema:numberOfCredits 3.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/95000278/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/95000278/2025-26/CE>,
        <https://guia-kg.skai.etsisi.upm.es/resource/95000278/2025-26/CECT6>,
        <https://guia-kg.skai.etsisi.upm.es/resource/95000278/2025-26/CG10>,
        <https://guia-kg.skai.etsisi.upm.es/resource/95000278/2025-26/CG12>,
        <https://guia-kg.skai.etsisi.upm.es/resource/95000278/2025-26/CG13>,
        <https://guia-kg.skai.etsisi.upm.es/resource/95000278/2025-26/CG7>,
        <https://guia-kg.skai.etsisi.upm.es/resource/95000278/2025-26/CG8>,
        <https://guia-kg.skai.etsisi.upm.es/resource/95000278/2025-26/CG9> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/95000278/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/95000278/2025-26/didactic_resource/2> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/95000278/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/95000278/2025-26/RA45> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/95000278/2025-26/syllabus> ;
    ns1:inpersonHours "30 horas (38.5%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation """La asignatura Tecnologías Electrónicas Iot para Ciudades Inteligentes y Sostenibles está directamente alineada con varios Objetivos de Desarrollo Sostenible (ODS), ya que su contenido y actividades promueven el desarrollo tecnológico responsable, la sostenibilidad urbana y la mejora de la calidad de vida en entornos urbanos mediante la aplicación de soluciones IoT. A continuación se detallan los ODS más relevantes:
ODS 11: Ciudades y comunidades sostenibles. La asignatura aborda tecnologías que permiten mejorar la eficiencia energética, la movilidad, la gestión de residuos y el monitoreo ambiental, todos ellos aspectos fundamentales para construir ciudades más inclusivas, seguras, resilientes y sostenibles. El proyecto final de la asignatura está enfocado, precisamente, en el diseño de una solución IoT orientada a resolver un problema urbano real.
ODS 7: Energía asequible y no contaminante. El temario incluye el estudio de sistemas de alimentación para dispositivos IoT basados en fuentes de energía renovables como solar, térmica, vibracional o RF. Esto fomenta el diseño de soluciones autónomas y sostenibles, compatibles con redes de energía limpias y eficientes.
ODS 9: Industria, innovación e infraestructura. La asignatura promueve la innovación tecnológica mediante el desarrollo de prototipos IoT aplicados a problemas reales. El uso de plataformas abiertas como Arduino y la integración de tecnologías como IA y gemelos digitales favorecen la formación de futuros profesionales capaces de impulsar infraestructuras inteligentes e innovadoras.
ODS 13: Acción por el clima. Mediante el uso de sensores IoT para el monitoreo ambiental y energético, la asignatura contribuye al diseño de soluciones tecnológicas que permiten medir, prevenir y responder a problemas relacionados con el cambio climático (contaminación del aire, consumo energético, gestión del agua).
ODS 4: Educación de calidad. Esta asignatura ofrece una formación interdisciplinar, práctica y alineada con las necesidades tecnológicas del siglo XXI. Promueve el pensamiento crítico, el aprendizaje basado en retos y el desarrollo de competencias digitales avanzadas."""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "32 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/95000278/2025-26/eventSchedule> ;
    schema:description """Esta asignatura proporciona al estudiante una visión aplicada de las tecnologías electrónicas que permiten el desarrollo de soluciones IoT en entornos urbanos. A través de una combinación de teoría, ejemplos prácticos y visitas técnicas, el estudiante explorará cómo integrar sensores, actuadores, comunicaciones inalámbricas, energía sostenible y tecnologías emergentes como la inteligencia artificial o los gemelos digitales en el contexto de las ciudades inteligentes.
Se abordarán aspectos clave como la arquitectura electrónica de los sistemas IoT, la eficiencia energética mediante fuentes renovables, la seguridad de los dispositivos conectados y su aplicación en ámbitos como la movilidad, la gestión del agua y residuos, la iluminación pública o la calidad ambiental. Se utilizará una metodología de aprendizaje basado en proyectos que se culiminará con un proyecto práctico donde los estudiantes propondrán una solución IoT realista para un problema urbano de la ciudad de Madrid."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/guillermo.delcampo%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/asun.santamaria%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/guillermo.delcampo%40upm.es> ;
    schema:name "Tecnologías Electrónicas Iot para Ciudades Inteligentes y Sostenibles"@es .

