<https://guia-kg.skai.etsisi.upm.es/resource/565000134/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Conceptos básicos. Circuitos de corriente continua."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000134/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Conceptos básicos de electricidad: diferencia de potencial, corriente eléctrica, intensidad de corriente Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000134/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "2.3. Respuesta de los circuitos serie a una excitación sinusoidal: Impedancia. Resonancia. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000134/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "2.4. Respuesta de los circuitos paralelos: Admitancia. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000134/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "2.5. Potencia en corriente alterna. Potencias Activa, Reactiva y Aparente. Teorema de Boucherot. Factor de potencia: importancia y mejora. Medida de la potencia: vatímetros. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000134/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "3. Sistemas Trifásicos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000134/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "3.1. Generalidades. Secuencia de fases. Conexiones en estrella y en triángulo. Convenio de situación fasorial. Diagramas fasoriales. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000134/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "3.2. Receptores trifásicos equilibrados y desequilibrados. Acoplamientos en triángulo y en estrella. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000134/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "3.3. Potencia en los receptores trifásicos. Medida de la Potencia en los receptores trifásicos: Sistemas a cuatro hilos. Sistemas a tres hilos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000134/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "3.4. Potencia en los receptores trifásicos. Medida de la potencia activa en sistemas a tres y cuatro hilos. Método de los dos vatímetros. Medida de la potencia reactiva en sistemas equilibrados. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000134/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "3.5. Mejora del factor de potencia. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000134/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "4. Introducción a los Teoremas Generales de los Circuitos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000134/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Elementos pasivos ideales: resistencia, bobina y condensador. Ecuaciones de definición. Energía almacenada. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000134/2025-26/syllabus/20> a ns1:SyllabusItem ;
    ns1:itemIndex 20 ;
    ns1:syllabusDescription "4.1. Teorema de superposición. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000134/2025-26/syllabus/21> a ns1:SyllabusItem ;
    ns1:itemIndex 21 ;
    ns1:syllabusDescription "4.2. Teoremas de Thevenin y Norton. Teorema de la máxima transferencia de potencia. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000134/2025-26/syllabus/22> a ns1:SyllabusItem ;
    ns1:itemIndex 22 ;
    ns1:syllabusDescription "5. Introducción al régimen transitorio de los circuitos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000134/2025-26/syllabus/23> a ns1:SyllabusItem ;
    ns1:itemIndex 23 ;
    ns1:syllabusDescription "5.1. Formas de onda generales. Funciones escalón, rampa e impulso unitario. Síntesis de formas de onda básicas: pulsos rectangulares, ondas triangulares, etc. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000134/2025-26/syllabus/24> a ns1:SyllabusItem ;
    ns1:itemIndex 24 ;
    ns1:syllabusDescription "5.2. Condiciones de continuidad: condensador, bobina. Circuitos equivalentes con condiciones iniciales nulas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000134/2025-26/syllabus/25> a ns1:SyllabusItem ;
    ns1:itemIndex 25 ;
    ns1:syllabusDescription "5.3. Circuitos de primer orden. Carga de un condensador. Respuesta de un circuito R-C a un pulso rectangular. Respuesta de un circuito R-L a un pulso rectangular. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000134/2025-26/syllabus/26> a ns1:SyllabusItem ;
    ns1:itemIndex 26 ;
    ns1:syllabusDescription "5.4. Circuitos de segundo orden. Parámetros que definen un sistema de segundo orden. Clasificación de los sistemas de segundo orden. Respuesta a entrada cero del circuito serie R-L-C. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000134/2025-26/syllabus/27> a ns1:SyllabusItem ;
    ns1:itemIndex 27 ;
    ns1:syllabusDescription "6. Prácticas de Laboratorio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000134/2025-26/syllabus/28> a ns1:SyllabusItem ;
    ns1:itemIndex 28 ;
    ns1:syllabusDescription "6.1. Explicativa Inicial Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000134/2025-26/syllabus/29> a ns1:SyllabusItem ;
    ns1:itemIndex 29 ;
    ns1:syllabusDescription "6.2. Medida industrial de resistencias Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000134/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "1.3. Leyes de Kirchhoff. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000134/2025-26/syllabus/30> a ns1:SyllabusItem ;
    ns1:itemIndex 30 ;
    ns1:syllabusDescription "6.3. Comprobación de las leyes de Kirchhoff Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000134/2025-26/syllabus/31> a ns1:SyllabusItem ;
    ns1:itemIndex 31 ;
    ns1:syllabusDescription "6.4. Medida de impedancias y circuito serie de c.a. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000134/2025-26/syllabus/32> a ns1:SyllabusItem ;
    ns1:itemIndex 32 ;
    ns1:syllabusDescription "6.5. Circuitos paralelo de c.a. y circuitos mixtos de c.a. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000134/2025-26/syllabus/33> a ns1:SyllabusItem ;
    ns1:itemIndex 33 ;
    ns1:syllabusDescription "6.6. Sistemas trifásicos equilibrados. Mejora del f.d.p. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000134/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "1.4. Asociación de resistencias en serie, paralelo y montaje mixto. Divisores de tensión y Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000134/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "1.5. Fuentes independientes de tensión e intensidad ideales y reales. Comportamiento de los generadores ideales y reales: tensión en bornes, intensidad suministrada. Potencia Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000134/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "1.6. Aplicación de las leyes de Kirchhoff: método de las mallas y método de los nudos Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000134/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "2. Corriente alterna monofásica."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000134/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "2.1. Formas de onda periódicas. Valor medio, eficaz y factor de forma. Forma de onda sinusoidal. Concepto de fasor. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000134/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "2.2. Respuesta de los elementos pasivos a una excitación sinusoidal. Impedancia. Sin subniveles"@es .

