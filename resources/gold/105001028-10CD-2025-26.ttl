    ns1:inpersonHours "34 horas (43.6%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation """Esta asignatura está relacionada con el "Objetivo de Desarrollo Sostenible 9" (Industria, innovación e infraestructura) definido por el Programa de las Naciones Unidas para el Desarrollo (www.undp.org) en lo referente a innovación e investigación científica en tecnologías de la información.

La información contenida en esta guía de aprendizaje es orientativa, podría variar por error, omisión, cambios en la situación sanitaria, cambios de normativa a aplicar o incidencias ocurridas a lo largo del semestre."""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "34 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/105001028/2025-26/eventSchedule> ;
    schema:description "Esta asignatura tiene como objetivo estudiar un conjunto de técnicas que permitan extraer información útil de imágenes digitales. Se estudiará el proceso de formación de las imágenes, las técnicas de procesamiento y descripción más habituales y su aplicación en problemas prácticos. Se utilizarán las bibliotecas y entornos más habituales de procesamiento y análisis de imágenes (Python, OpenCV, Scikit-learn, etc.)."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/roberto.valle%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/luis.baumela%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/roberto.valle%40upm.es> ;
    schema:name "Fundamentos de Análisis de Imágenes"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105001028/2025-26/CB02> a ns1:Competency ;
    ns1:competencyCode "CB02" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar sus conocimientos a su trabajo o vocación de una forma profesional y posean las competencias que suelen demostrarse por medio de la elaboración y defensa de argumentos y la resolución de problemas dentro de su área de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105001028/2025-26/CE01> a ns1:Competency ;
    ns1:competencyCode "CE01" ;
    ns1:competencyDescription "Capacidad para utilizar con destreza los conceptos y métodos matemáticos que subyacen a los problemas de la ciencia de datos y la inteligencia artificial para su modelización y resolución."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105001028/2025-26/CE16> a ns1:Competency ;
    ns1:competencyCode "CE16" ;
    ns1:competencyDescription "Capacidad para describir las técnicas de percepción y robótica cognitiva y utilizarlas para desarrollar sistemas que puedan percibir su entorno y desempeñar tareas de manipulación, navegación y planificación de su comportamiento, con cierto grado de autonomía."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105001028/2025-26/CG01> a ns1:Competency ;
    ns1:competencyCode "CG01" ;
    ns1:competencyDescription "Capacidad de trabajo en equipo, en entornos interdisciplinares y complejos, negociando y resolviendo conflictos, diseñando soluciones eficientes, fiables, robustas y responsables."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105001028/2025-26/RA115> a ns1:LearningResult ;
    ns1:learningResultCode "RA115" ;
    ns1:learningResultDescription "Diseñar y construir sistemas informáticos capaces de resolver problemas para los que no se conoce solución."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105001028/2025-26/RA120> a ns1:LearningResult ;
    ns1:learningResultCode "RA120" ;
    ns1:learningResultDescription "Ser capaz de diseñar algoritmos que reconozcan objetos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105001028/2025-26/RA76> a ns1:LearningResult ;
    ns1:learningResultCode "RA76" ;
    ns1:learningResultDescription "Programar aplicaciones mediante librerías existentes de Análisis de Datos"@es .

