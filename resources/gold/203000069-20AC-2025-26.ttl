        <https://guia-kg.skai.etsisi.upm.es/resource/203000069/2025-26/RA28> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/203000069/2025-26/syllabus> ;
    ns1:inpersonHours "24 horas (59.3%)"@es ;
    ns1:numberOfCredits 1.5 ;
    ns1:otherInformation "El Máster en Producción y Sanidad Animal en un Máster Interuniversitario en el que participan la UPM y la UCM. La profesora coordinadora de esta asignatura es Rosa María Escudero, profesora de la Facultad de Veterinaria de la Universidad Complutense de Madrid. La asignatura se relaciona con el ODS12 y el ODS15."@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "24 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/203000069/2025-26/eventSchedule> ;
    schema:description """Concepto de marketing en el ámbito pecuario.
El plan de marketing.
Estrategias de marketing mix.
Concepto de calidad y su importancia.
Factores que influyen en la calidad."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/nora.formosorafferty%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/nora.formosorafferty%40upm.es> ;
    schema:name "Calidad y Marketing de Productos Ganaderos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000069/2025-26/CE07> a ns1:Competency ;
    ns1:competencyCode "CE07" ;
    ns1:competencyDescription "Plantear y desarrollar un trabajo de investigación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000069/2025-26/CE09> a ns1:Competency ;
    ns1:competencyCode "CE09" ;
    ns1:competencyDescription "Saber utilizar las herramientas y técnicas bioinformáticas más actuales a la investigación en producción animal y en sanidad animal."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000069/2025-26/CE14> a ns1:Competency ;
    ns1:competencyCode "CE14" ;
    ns1:competencyDescription "Aplicar conocimientos avanzados acerca de la gestión más adecuada en el ámbito de la calidad y del marketing, en el marco de la producción animal y de la sanidad animal, con el objetivo de buscar la optimización en las empresas pecuarias."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000069/2025-26/CE15> a ns1:Competency ;
    ns1:competencyCode "CE15" ;
    ns1:competencyDescription "Conocer la metodología de investigación a aplicar en el campo del marketing en los ámbitos de la producción animal y de la sanidad animal."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000069/2025-26/CE16> a ns1:Competency ;
    ns1:competencyCode "CE16" ;
    ns1:competencyDescription "Adquirir conocimientos adecuados para poder plantear soluciones y resolver problemáticas inherentes al sector ganadero en lo que se refiere a la calidad y al marketing de los productos ganaderos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000069/2025-26/CE17> a ns1:Competency ;
    ns1:competencyCode "CE17" ;
    ns1:competencyDescription "Evaluar adecuadamente el efecto del marketing sobre la imagen de los productos ganaderos y la valoración de la su calidad."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000069/2025-26/CE18> a ns1:Competency ;
    ns1:competencyCode "CE18" ;
    ns1:competencyDescription "Conocer los factores que influyen en el consumidor en su valoración de la calidad de los productos agropecuarios y los criterios en que fundamenta su estimación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000069/2025-26/CE19> a ns1:Competency ;
    ns1:competencyCode "CE19" ;
    ns1:competencyDescription "Saber aplicar las estrategias de marketing para mejorar la comercialización y la venta de los productos ganaderos."@es .

