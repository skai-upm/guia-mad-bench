    ns1:itemIndex 10 ;
    ns1:syllabusDescription "2.2. 2.2. Transmisión del calor y termodinámica aplicada"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000071/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "2.2.1. 2.2.1. Transmisión del calor (conducción, convección y radiación). Motores térmicos. Máquinas frigoríficas Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000071/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "2.3. 2.3. Cambios de fase y humedad"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000071/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "2.3.1. 2.3.1. Cambios de fase. Ecuación de Clapeyron. Índices de humedad Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000071/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.1.1. 1.1.1. Carga eléctrica. Ley de Coulomb Campo eléctrico. Líneas de campo eléctrico. Energía potencial eléctrica. Potencial eléctrico. Líneas equipotenciales. Teorema de Gauss Dipolo eléctrico. Condensadores. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000071/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "1.2. 1.2. Corriente continua"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000071/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "1.2.1. 1.2.1. Corriente eléctrica. Ley de Ohm Resistencia eléctrica. Asociaciones de resistencias. Ley de Joule. Potencias eléctricas y fuerzas electromotrices. Reglas de Kirchoff. Circuitos de corriente continua Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000071/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "1.3. 1.3. Magnetismo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000071/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "1.3.1. 1.3.1. Magnetismo. Campo magnético creado por partícula en movimiento. Ley de Biot-Savart. Espira en un campo magnético. Fuerza de Lorentz. Fuerzas magnéticas. Inducción electromagnética. Leyes de Faraday y Lenz Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000071/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "2. 2. Termodinámica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000071/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "2.1. 2.1. Principios de la Termodinámica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000071/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "2.1.1. 2.1.1. Sistemas termodinámicos. Calor, temperatura y energía interna. Primer principio y trabajo. Segundo principio y entropía. Ciclo de Carnot.Termodinámica de los gases perfectos Sin subniveles"@es .

