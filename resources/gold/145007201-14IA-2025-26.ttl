        <https://guia-kg.skai.etsisi.upm.es/resource/luis.sanchezdeleon%40upm.es> ;
    schema:name "Motores Cohete"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145007201/2025-26/CE29> a ns1:Competency ;
    ns1:competencyCode "CE29" ;
    ns1:competencyDescription "Conocimiento adecuado de: las instalaciones de los sistemas propulsivos; el control de instalaciones de los sistemas propulsivos; la ingeniería de los sistemas de propulsión; actuaciones de los motores de aviación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145007201/2025-26/CE34> a ns1:Competency ;
    ns1:competencyCode "CE34" ;
    ns1:competencyDescription "Conocimiento adecuado y aplicado a la Ingeniería de: los métodos de cálculo y de desarrollo de instalaciones de los sistemas propulsivos; la regulación y control de instalaciones de los sistemas propulsivos; el manejo de las técnicas experimentales, equipamiento e instrumentos de medida propios de la disciplina; los combustibles y lubricantes empleados en los motores de aviación y automoción; la simulación numérica de los procesos físico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145007201/2025-26/CE35> a ns1:Competency ;
    ns1:competencyCode "CE35" ;
    ns1:competencyDescription "Conocimiento aplicado de: aerodinámica interna; teoría de la propulsión; actuaciones de aviones y de aerorreactores; ingeniería de sistemas de propulsión; mecánica y termodinámica."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145007201/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Capacidad para identificar y resolver problemas aplicando, con creatividad, los conocimientos adquiridos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145007201/2025-26/CG9> a ns1:Competency ;
    ns1:competencyCode "CG9" ;
    ns1:competencyDescription "Razonamiento crítico y capacidad de asociación que posibiliten el aprendizaje continuo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145007201/2025-26/RA216> a ns1:LearningResult ;
    ns1:learningResultCode "RA216" ;
    ns1:learningResultDescription "Conocimiento y comprensión de las leyes que gobiernan el movimiento de vehículos propulsados con motores cohete; la generación de empuje y las variables de las que depende."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145007201/2025-26/RA217> a ns1:LearningResult ;
    ns1:learningResultCode "RA217" ;
    ns1:learningResultDescription "Conocimiento y comprensión del modelo ideal de los motores cohete de propulsión fluidodinámica y de la influencia de efectos reales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145007201/2025-26/RA218> a ns1:LearningResult ;
    ns1:learningResultCode "RA218" ;
    ns1:learningResultDescription "Conocimiento de los propulsantes y comprensión y del proceso de combustión de los motores cohete de propulsante sólido, líquido e híbridos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145007201/2025-26/RA219> a ns1:LearningResult ;
    ns1:learningResultCode "RA219" ;
    ns1:learningResultDescription "Conocimiento y comprensión del sistema de ionización y de aceleración de los motores cohete eléctricos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145007201/2025-26/RA220> a ns1:LearningResult ;
    ns1:learningResultCode "RA220" ;
    ns1:learningResultDescription "Conocimiento y comprensión de los sistemas de alimentación y refrigeración."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145007201/2025-26/RA304> a ns1:LearningResult ;
    ns1:learningResultCode "RA304" ;
    ns1:learningResultDescription "Capacidad para comprender y simular los procesos físico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145007201/2025-26/RA305> a ns1:LearningResult ;
    ns1:learningResultCode "RA305" ;
    ns1:learningResultDescription "Conocimiento, comprensión, aplicación y análisis de los sistemas de alimentación y refrigeración"@es .

