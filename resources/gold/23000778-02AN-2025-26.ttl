<https://guia-kg.skai.etsisi.upm.es/resource/23000778/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "2.1. Tema 1: Introducción a la Ecología: Conceptos básicos. Aspectos principales de la Ecología. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000778/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "2.2. Tema 2: El medio físico: Organismos generalistas y especialistas. Ejes de diversidad. Plantas C-S-R. Factores abióticos y climáticos. Zonas de rusticidad. Inversión térmica. Sequía orográfica. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000778/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "2.3. Tema 3: Tipos de comunidades vegetales según el tipo de suelo y según distintos parámetros ambientales. Halofilia, xerofilia, esclerofilia, hidrofilia, etc. Sin subniveles"@es .

