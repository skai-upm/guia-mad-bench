    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/133000151/2025-26/syllabus> ;
    ns1:inpersonHours "60 horas (46.2%)"@es ;
    ns1:numberOfCredits 5.0 ;
    ns1:otherInformation """LAS COMPETENCIAS Y LOS RESULTADOS DE APRENDIZAJE DE ESTA ASIGNATURA SON LOS ACORDES CON LA MEMORIA VERIFICA DEL TÍTULO
La asignatura se relaciona con el ODS 9 y 12"""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "76 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/133000151/2025-26/eventSchedule> ;
    schema:description "El objetivo de esta asignatura es introducir al alumno en el sector turístico y su economía, así como que adquiera los conocimientos básicos de financiación del turismo y de la gestión de la empresa turística."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/a.martinf%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/a.martinf%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/sigfredo.ortuno%40upm.es> ;
    schema:name "Recursos Económicos y Gestión Financiera de los Fondos."@es .

