    schema:name "Economic Resources And Financial Management Of Funds."@en,
        "Recursos Económicos y Gestión Financiera de los Fondos."@es ;
    schema:numberOfCredits 5.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/133000151/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/133000151/2025-26/CE01>,
