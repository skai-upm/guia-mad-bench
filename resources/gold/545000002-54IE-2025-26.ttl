        <https://guia-kg.skai.etsisi.upm.es/resource/ines.higuera%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/mercedes.valiente%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/pabloluis.mayor%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/rafaelvicente.lozano%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/sofia.herrero%40upm.es> ;
    schema:name "Dibujo Arquitectonico I"@es .

