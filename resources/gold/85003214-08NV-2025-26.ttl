        <https://guia-kg.skai.etsisi.upm.es/resource/monica.carboneras%40upm.es> ;
    schema:name "Ciencia y Tecnología de los Materiales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003214/2025-26/CB5> a ns1:Competency ;
    ns1:competencyCode "CB5" ;
    ns1:competencyDescription "Que los estudiantes hayan desarrollado aquellas habilidades de aprendizaje necesarias para emprender estudios posteriores con un alto grado de autonomía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003214/2025-26/CE%2020> a ns1:Competency ;
    ns1:competencyCode "CE 20" ;
    ns1:competencyDescription "Conocimiento de las características de los materiales estructurales navales y de los criterios para su selección"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003214/2025-26/CE%2022> a ns1:Competency ;
    ns1:competencyCode "CE 22" ;
    ns1:competencyDescription "Capacidad para el diseño y cálculo de estructuras navales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003214/2025-26/CE%208> a ns1:Competency ;
    ns1:competencyCode "CE 8" ;
    ns1:competencyDescription "Conocimiento de la ciencia y tecnología de materiales y capacidad para su selección y para la evaluación de su comportamiento."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003214/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Capacidad para el aprendizaje de nuevos métodos y teorías, y en la versatilidad para adaptarse a nuevas situaciones basándose en los conocimientos adquiridos en materias básicas y tecnológicas propias de la Arquitectura Naval."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003214/2025-26/RA57> a ns1:LearningResult ;
    ns1:learningResultCode "RA57" ;
    ns1:learningResultDescription "Manejando los conceptos de constituyente y fase."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003214/2025-26/RA58> a ns1:LearningResult ;
    ns1:learningResultCode "RA58" ;
    ns1:learningResultDescription "Conocer y comprender os diagramas de equilibrio binarios en particular el diagrama hierro"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003214/2025-26/RA59> a ns1:LearningResult ;
    ns1:learningResultCode "RA59" ;
    ns1:learningResultDescription "Conocer los ensayos a realizar para la caracterización de un material."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003214/2025-26/RA60> a ns1:LearningResult ;
    ns1:learningResultCode "RA60" ;
    ns1:learningResultDescription "Comprender la acción de los elementos aleantes y sus propiedades en los aceros."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003214/2025-26/RA61> a ns1:LearningResult ;
    ns1:learningResultCode "RA61" ;
    ns1:learningResultDescription "Conocer los tratamientos térmicos de los aceros."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003214/2025-26/RA62> a ns1:LearningResult ;
    ns1:learningResultCode "RA62" ;
    ns1:learningResultDescription "Manejar las cualidades de los aceros al carbono y los aceros especiales aleados"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003214/2025-26/RA63> a ns1:LearningResult ;
    ns1:learningResultCode "RA63" ;
    ns1:learningResultDescription "Conocer las fundiciones de acero."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003214/2025-26/RA64> a ns1:LearningResult ;
    ns1:learningResultCode "RA64" ;
    ns1:learningResultDescription "Conocer el aluminio y sus aleaciones, especialmente las de aplicación naval."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003214/2025-26/RA65> a ns1:LearningResult ;
    ns1:learningResultCode "RA65" ;
    ns1:learningResultDescription "Conocer los materiales cerámicos, los polímeros y los compuestos y sus aplicaciones características."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003214/2025-26/RA66> a ns1:LearningResult ;
    ns1:learningResultCode "RA66" ;
    ns1:learningResultDescription "Conocer los procedimientos de selección de materiales."@es .

