        <https://guia-kg.skai.etsisi.upm.es/resource/95000026/2025-26/syllabus/7>,
        <https://guia-kg.skai.etsisi.upm.es/resource/95000026/2025-26/syllabus/8>,
        <https://guia-kg.skai.etsisi.upm.es/resource/95000026/2025-26/syllabus/9> .

<https://guia-kg.skai.etsisi.upm.es/resource/95000026/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. El sistema microprocesador"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000026/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Elementos de un sistema microprocesador. El sistema microprocesador. Aplicaciones. Estructura funcional. La Unidad Central de Proceso. Ejecución de una instrucción. La memoria central. Periféricos. Las líneas de conexión. El mapa de memoria Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000026/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "3.1. Arquitectura del sistema. Diagrama de bloques. El núcleo. El módulo de integración del sistema (SIM). Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000026/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "3.2. Configuración del sistema de memoria. Configuración de los dispositivos internos. Acceso a dispositivos externos. Señales de selección de chip. Programación de un mapa de memoria. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000026/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "4. Excepciones en el sistema microprocesador"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000026/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "4.1. Excepciones. Definición y tipos de excepciones. Tabla de vectores de excepción. Configuración de la tabla de vectores. Prioridad entre excepciones. El procesamiento de excepciones. Subrutinas frente a excepciones. Reset, error de bus y parada del sistema Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000026/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "4.2. Interrupciones. Sondeo frente a interrupciones. Prioridades y enmascaramiento. Fuentes de interrupción y controlador de interrupciones. Configuración de interrupciones Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000026/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "5. Entrada/Salida en el sistema microprocesador"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000026/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "5.1. Interfaces y periféricos de E/S. Tipos de comunicación paralelo y serie. Control de un teclado matricial. Manejo de un visualizador LCD. Comunicación serie asíncrona y síncrona. Módulo UART simplificado Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000026/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "6. Módulos de temporización en el sistema microprocesador"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000026/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "6.1. Temporizadores programables. Elementos de un temporizador. Resolución y rango. La captura de entrada. La comparación de salida. Configuración de la captura de entrada y la comparación de salida. Combinación de captura de entrada y comparación de salida Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000026/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "6.2. Modulación por anchura de pulso. La modulación PWM. Diagrama de bloques de un modulador PWM. Configuración del módulo PWM. Aplicación al control de velocidad de un motor de continua Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000026/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. El mercado de los microprocesadores. Tipos de procesadores y memorias. Gamas de procesadores. El mercado de los semiconductores. El mercado de los microcontroladores Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000026/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "2. Programación en un sistema microprocesador"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000026/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "2.1. Programación en ensamblador. Componentes de un programa. Sintaxis del lenguaje ensamblador. Directivas del ensamblador. El proceso de ensamblado. Desarrollo y depuración de programas Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000026/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "2.2. El modelo de programación. Modos de ejecución. Organización en memoria. La pila. Modos de direccionamiento. Acceso a estructuras de datos Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000026/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "2.3. El juego de instrucciones I. Transferencia de datos. Manipulación de bits. Instrucciones lógincas. Instrucciones de desplazamiento. Instrucciones aritméticas. Instrucciones de comparación y test Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000026/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "2.4. El juego de instrucciones II. Control de programa. Saltos incondicionales. Subrutinas y paso de parámetros por la pila. Instrucciones condicionales Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000026/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "2.5. Programación en lenguaje C. Principales diferencias con lenguaje Java. Uso de punteros y arrays Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000026/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "3. Arquitectura hardware del microcontrolador"@es .

