        <https://guia-kg.skai.etsisi.upm.es/resource/95000026/2025-26/syllabus/12>,
        <https://guia-kg.skai.etsisi.upm.es/resource/95000026/2025-26/syllabus/13>,
        <https://guia-kg.skai.etsisi.upm.es/resource/95000026/2025-26/syllabus/14>,
        <https://guia-kg.skai.etsisi.upm.es/resource/95000026/2025-26/syllabus/15>,
        <https://guia-kg.skai.etsisi.upm.es/resource/95000026/2025-26/syllabus/16>,
        <https://guia-kg.skai.etsisi.upm.es/resource/95000026/2025-26/syllabus/17>,
        <https://guia-kg.skai.etsisi.upm.es/resource/95000026/2025-26/syllabus/18>,
        <https://guia-kg.skai.etsisi.upm.es/resource/95000026/2025-26/syllabus/19>,
