<https://guia-kg.skai.etsisi.upm.es/resource/145004002/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. PRESENTACIÓN DE LA ASIGNATURA. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145004002/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "2. INTRODUCCIÓN Y CINEMÁTICA."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145004002/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "3.5. Condiciones iniciales y de contorno. Flujo compresible e incompresible. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145004002/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "4. FLUIDOSTÁTICA."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145004002/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "4.1. Hidrostática. Fuerzas y momentos sobre superficies. Principio de Arquímedes. Columnas de líquido. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145004002/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "5. FLUJO UNIDIRECCIONAL"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145004002/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "5.1. Ecuaciones del flujo unidireccional. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145004002/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "5.2. Aplicación a las corrientes de Couette y Poiseuille. Caída de presión en un conducto laminar. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145004002/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "5.3. Regiones de adaptación. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145004002/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "6. ANÁLISIS DIMENSIONAL Y SEMEJANZA FÍSICA"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145004002/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "6.1. Análisis dimensional. Teorema Pi. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145004002/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "6.2. Semejanza física. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145004002/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "2.1. Definición de fluido. Hipótesis de medio continuo y equilibrio termodinámico. Magnitudes fluidas. Partícula fluida. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145004002/2025-26/syllabus/20> a ns1:SyllabusItem ;
    ns1:itemIndex 20 ;
    ns1:syllabusDescription "7. APLICACIÓN DE LA FORMULACIÓN INTEGRAL A LA TEORÍA DE TURBOMÁQUINAS. (Compresible e incompresible). Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145004002/2025-26/syllabus/21> a ns1:SyllabusItem ;
    ns1:itemIndex 21 ;
    ns1:syllabusDescription "8. FLUJO TURBULENTO."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145004002/2025-26/syllabus/22> a ns1:SyllabusItem ;
    ns1:itemIndex 22 ;
    ns1:syllabusDescription "8.1. Introducción a la turbulencia. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145004002/2025-26/syllabus/23> a ns1:SyllabusItem ;
    ns1:itemIndex 23 ;
    ns1:syllabusDescription "8.2. Flujo turbulento en tubos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145004002/2025-26/syllabus/24> a ns1:SyllabusItem ;
    ns1:itemIndex 24 ;
    ns1:syllabusDescription "9. FLUJOS A ALTOS NÚMEROS DE REYNOLDS."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145004002/2025-26/syllabus/25> a ns1:SyllabusItem ;
    ns1:itemIndex 25 ;
    ns1:syllabusDescription "9.1. Ecuaciones de Euler. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145004002/2025-26/syllabus/26> a ns1:SyllabusItem ;
    ns1:itemIndex 26 ;
    ns1:syllabusDescription "9.2. Escalado básico de capa límite. Capa límite viscosa. Resistencia de presión y de fricción. Capa límite térmica (Pr de orden unidad). Flujo de calor. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145004002/2025-26/syllabus/27> a ns1:SyllabusItem ;
    ns1:itemIndex 27 ;
    ns1:syllabusDescription "9.3. Velocidad del sonido. Número de Mach. Flujo subsónico y supersónico. Flujo isentrópico y homentrópico. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145004002/2025-26/syllabus/28> a ns1:SyllabusItem ;
    ns1:itemIndex 28 ;
    ns1:syllabusDescription "9.4. Ecuación de Bernoulli. Magnitudes de remanso. Magnitudes críticas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145004002/2025-26/syllabus/29> a ns1:SyllabusItem ;
    ns1:itemIndex 29 ;
    ns1:syllabusDescription "9.5. Flujo casi-unidireccional en toberas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145004002/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "2.2. Cinemática de fluidos. Descripción Lagrangiana y Euleriana. Trayectorias, sendas. Líneas, superficies y volúmenes fluidos. Líneas de traza y líneas de corriente. Puntos de remanso. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145004002/2025-26/syllabus/30> a ns1:SyllabusItem ;
    ns1:itemIndex 30 ;
    ns1:syllabusDescription "9.6. Carga y descarga de depósitos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145004002/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "2.3. Cinemática de fluidos. Derivada sustancial. Velocidad normal de avance. Flujo convectivo. Teorema del transporte de Reynolds. Vorticidad. Circulación. Potencial de la velocidad. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145004002/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "3. ECUACIONES GENERALES DE LA MECÁNICA DE FLUIDOS."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145004002/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "3.1. Ecuación de la conservación de la masa. Velocidad de dilatación cúbica unitaria. Función de corriente. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145004002/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "3.2. Fuerzas sobre fluidos. Ecuación de la cantidad de movimiento. Tensor de esfuerzos moleculares (presión y esfuerzo viscoso). Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145004002/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "3.3. Trabajo y calor. Ecuación de conservación de la energía. Ecuaciones de estado. Coeficientes de transporte, viscosidad, presión de vapor. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145004002/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "3.4. Ecuación de le energía mecánica. Formas alternativas de la ecuación de conservación de la energía. Sin subniveles"@es .

