<https://guia-kg.skai.etsisi.upm.es/resource/205000260/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. UT1. INTRODUCCIÓN A LA AGRICULTURA ECOLÓGICA Y LA AGENDA 2030"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000260/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. La agricultura ecológica en el Mundo y en España"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000260/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "2.1. TÉCNICAS REGULADAS POR LA AGRICULTURA ECOLÓGICA Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000260/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "2.2. CUADERNO DE NORMAS TÉCNICAS Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000260/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "2.3. LA AGRICULTURA ECOLÓGICA FUNCIONAL Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000260/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "2.4. Diseño de la explotación agrícola. Rotaciones y alternativas en la explotación Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000260/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "2.5. Las secuencias de cultivos en la parcela. Aplicaciones de la agricultura integrada y de la agroecología. Uso de agua y nutrientes. Suministro de nutrientes. Control de plagas y enfermedades; control de malas hierbas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000260/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "2.6. Importación y exportación de biomasa, energía, agua y nutrientes: impacto en la sostenibilidad de los sistemas PAE. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000260/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "2.7. Itinerario técnico de cultivo. Descripción del itinerario técnico en agricultura convencional Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000260/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "3. UT2.- Sistemas y técnicas de cultivos--Tema 3.- Técnicas de manejo de suelo en PAE"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000260/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "3.1. Sistemas de laboreo. Laboreo de conservación; siembra directa y trasplante. Control de la erosión. Control de malas hierbas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000260/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "3.2. Huella de carbono asociada al manejo de suelo. Energía y tiempo consumidos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000260/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.1.1. Historia de la agricultura ecológica Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000260/2025-26/syllabus/20> a ns1:SyllabusItem ;
    ns1:itemIndex 20 ;
    ns1:syllabusDescription "3.3. Maquinaria en los sistemas de producción ecológica. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000260/2025-26/syllabus/21> a ns1:SyllabusItem ;
    ns1:itemIndex 21 ;
    ns1:syllabusDescription "4. UT2.- Sistemas y técnicas de cultivos--Tema 4.- Fertilidad de suelo y suministro de nutrientes. Sostenibilidad de la capacidad productiva de los suelos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000260/2025-26/syllabus/22> a ns1:SyllabusItem ;
    ns1:itemIndex 22 ;
    ns1:syllabusDescription "4.1. Cálculo de la materia orgánica del suelo. Residuos orgánicos como fuente de humus y nutrientes. Producción y composición de residuos orgánicos. Compostaje. Manejo de abonos verdes. Acolchados. Equilibrio húmico. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000260/2025-26/syllabus/23> a ns1:SyllabusItem ;
    ns1:itemIndex 23 ;
    ns1:syllabusDescription "4.2. Cálculo de la fertilización nitrogenada. Fertilidad. Necesidades de nutrientes y empleo de biofertilizantes. Efectos ecotoxicológicos de los biofertilizantes. Fertilización fosfórica y potásica. Aporte de micronutrientes. Balances a nivel de sistema. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000260/2025-26/syllabus/24> a ns1:SyllabusItem ;
    ns1:itemIndex 24 ;
    ns1:syllabusDescription "4.3. Relación de superficie equivalente asociada a las fertilizaciones orgánicas. Huella hídrica. Huella de carbono. Costes de producción. Sin subniveles"@es .

