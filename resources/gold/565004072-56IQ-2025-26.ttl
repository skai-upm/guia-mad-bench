    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/565004072/2025-26/eventSchedule> ;
    schema:description "Organizations in the Knowledge Age, in Industry 4-0 need a new management model for generating, capturing, and leveraging intellectual capital assets in order to stay competitive. In this course, we review the fundamental elements required for developing a comprehensive system for creating and applying sustained levels of intellectual capital in this mellenium. A central question is how to measure this knowledge, this is Intellectual Capital."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/irene.mrubio%40upm.es> ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/irene.mrubio%40upm.es> ;
    schema:name "Intellectual Capital And Knowledge Management"@es .

