    ns1:otherInformation """Esta guía refleja los contenidos y normas aplicados en el curso 2024-2025 y anteriores. Durante el semestre
septiembre-enero se evaluarán los resultados y de esta evaluación podrían resultar propuestas de modificación
que quedarían reflejadas en una versión posterior."""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
