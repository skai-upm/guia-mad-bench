    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/55000007/2025-26/RA122>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55000007/2025-26/RA123>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55000007/2025-26/RA124>,
