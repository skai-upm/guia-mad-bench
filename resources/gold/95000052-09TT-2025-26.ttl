    ns1:inpersonHours "60 horas (38.5%)"@es ;
    ns1:numberOfCredits 6.0 ;
    ns1:otherInformation """La asignatura se relaciona con los ODS 4 y 9:
Subobjetivo 4.4: Aumentar considerablemente el número de jóvenes y adultos que tienen las competencias profesionales y técnicas necesarias para acceder al empleo y al emprendimiento.
Subobjetivo 9.1: Desarrollar infraestructuras fiables, sostenibles, resilientes y de calidad."""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "60 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/95000052/2025-26/eventSchedule> ;
    schema:description "La asignatura cubre los principios de las redes de comunicaciones móviles, incluyendo: arquitecturas de red, protocolos de comunicación, procedimientos de señalización, servicios, dimensionado e ingeniería de tráfico. El desarrollo del temario sigue un orden cronológico a través de las principales generaciones de redes de comunicaciones móviles: 2G (GSM/GPRS), 3G (UMTS/HSPA), 4G (LTE) y 5G."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/mario.sanz%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/enrique.vazquez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/joseignacio.moreno%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/julio.berrocal%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/manuel.alvarez-campana%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/mario.sanz%40upm.es> ;
    schema:name "Redes de Comunicaciones Moviles"@es .

