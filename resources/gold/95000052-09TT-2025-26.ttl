    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Introducción a las Redes de Comunicaciones Móviles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000052/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Principios de las Redes de Comunicaciones Móviles Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000052/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "2.1.5. GPRS. Servicios, arquitectura y procedimientos. Dimensionado. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000052/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "2.2. Redes de Comunicaciones Móviles 3G (UMTS Rel99)"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000052/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "2.2.1. Principios de la arquitectura UMTS Release 99. Evolución desde GSM/GPRS. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000052/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "2.2.2. Red de acceso UTRAN. Protocolos. Uso de ATM. Dimensionado. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000052/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "2.2.3. Núcleo de red. Protocolos. Servicios modo circuito y servicios modo paquete. Calidad de servicio. Dimensionado. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000052/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "3. Evolución de redes de Comunicaciones Móviles 3G (IMS y HSPA)"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000052/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "3.1. Evolución de UMTS en Releases 4, 5 y posteriores. Dominio CS basado en VoIP. Subsistema IP Multimedia (IMS). Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000052/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "3.2. Voz sobre IP. Codificación, empaquetado, calidad de servicio. Señalización para VoIP. Escenarios de aplicación. Dimensionado Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000052/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "3.3. Dominio CS basado en VoIP. Subsistema IP Multimedia (IMS). Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000052/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "3.4. Servicios de datos de alta velocidad (HSPA). Dimensionado. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000052/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Normalización de las Redes de Comunicaciones Móviles Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000052/2025-26/syllabus/20> a ns1:SyllabusItem ;
    ns1:itemIndex 20 ;
    ns1:syllabusDescription "4. Redes de Comunicaciones Móviles 4G (LTE)"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000052/2025-26/syllabus/21> a ns1:SyllabusItem ;
    ns1:itemIndex 21 ;
    ns1:syllabusDescription "4.1. Principios de la arquitectura LTE/EPS. Elementos e interfaces. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000052/2025-26/syllabus/22> a ns1:SyllabusItem ;
    ns1:itemIndex 22 ;
    ns1:syllabusDescription "4.2. Red de acceso E-UTRAN. Protocolos. Transporte sobre IP. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000052/2025-26/syllabus/23> a ns1:SyllabusItem ;
    ns1:itemIndex 23 ;
    ns1:syllabusDescription "4.3. Núcleo de red EPC. Protocolos. Portadoras EPS y calidad de servicio. Procedimientos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000052/2025-26/syllabus/24> a ns1:SyllabusItem ;
    ns1:itemIndex 24 ;
    ns1:syllabusDescription "4.4. Interfuncionamiento con otras redes (2G, 3G, WiFi, WIMAX). Escenarios de itinerancia. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000052/2025-26/syllabus/25> a ns1:SyllabusItem ;
    ns1:itemIndex 25 ;
    ns1:syllabusDescription "4.5. Soporte de servicios de voz. Solución con IMS (VoLTE). Solución transitoria con paso a circuitos (CS fallback). Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000052/2025-26/syllabus/26> a ns1:SyllabusItem ;
    ns1:itemIndex 26 ;
    ns1:syllabusDescription "5. Redes de Comunicaciones Móviles 5G"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000052/2025-26/syllabus/27> a ns1:SyllabusItem ;
    ns1:itemIndex 27 ;
    ns1:syllabusDescription "5.1. Principios de arquitectura de 5G. Casos de uso. Elementos e Interfaces. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000052/2025-26/syllabus/28> a ns1:SyllabusItem ;
    ns1:itemIndex 28 ;
    ns1:syllabusDescription "5.2. Redes de acceso NG-RAN. Protocolos. Alternativas de despliegue SA y NSA Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000052/2025-26/syllabus/29> a ns1:SyllabusItem ;
    ns1:itemIndex 29 ;
    ns1:syllabusDescription "5.3. Núcleo de red 5GC. Arquitectura SBA Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000052/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "1.3. Evolución de las Redes de Comunicaciones Móviles Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000052/2025-26/syllabus/30> a ns1:SyllabusItem ;
    ns1:itemIndex 30 ;
    ns1:syllabusDescription "5.4. Network Slicing (SDN y NFV). Computación en el borde (MEC) Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000052/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "2. Redes de Comunicaciones Móviles 2G y 3G (Rel 99)"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000052/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "2.1. Redes de comunicaciones móviles 2G (GSM y GPRS)"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000052/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "2.1.1. Introducción a las redes GSM. Operadores móviles. Servicios. Elementos. Interfaces. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000052/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "2.1.2. Red de acceso. Protocolos. Dimensionado Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000052/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "2.1.3. Núcleo de red. Procedimientos de control de movilidad y seguridad, control de llamadas, mensajes cortos. Sin subniveles"@es .

