    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/63000142/2025-26/eventSchedule> ;
    schema:description "La asignatura profundiza en el conocimiento de los aspectos claves de la Ingeniería de explosivos enfocados a la optimización de las operaciones de excavación por voladura, específicamente la aplicación de modelos de fragmentación de roca por voladura. El estudiante aprende a utilizar herramientas de diseño experto. Se estudian los elementos de seguridad de la explotación, las afecciones medioambientales y los aspectos económicos de la excavación por voladura en el contexto global ('mine-to-mill') de la operación minera. Se profundiza en conocimientos de fabricación, almacenamiento y transporte de explosivos."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/ja.sanchidrian%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/ja.sanchidrian%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/lina.lopez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/pablo.segarra%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/santiago.gomez%40upm.es> ;
    schema:name "Ingenieria de Explosivos: Diseño, Control y Optimizacion"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000142/2025-26/CE01> a ns1:Competency ;
    ns1:competencyCode "CE01" ;
    ns1:competencyDescription "Capacidad para abordar y resolver problemas matemáticos avanzados de ingeniería, desde el planteamiento del problema hasta el desarrollo de la formulación y su implementación en un programa de ordenador. En particular, capacidad para formular, programar y aplicar modelos analíticos y numéricos avanzados de cálculo, proyectos, planificación y gestión, así como capacidad para la interpretación de los resultados obtenidos, en el contexto de la ingeniería de minas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000142/2025-26/CE12> a ns1:Competency ;
    ns1:competencyCode "CE12" ;
    ns1:competencyDescription "Capacidad para proyectar, gestionar y dirigir la fabricación, transporte, almacenamiento, manipulación y uso de explosivos y pirotecnia"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000142/2025-26/RA151> a ns1:LearningResult ;
    ns1:learningResultCode "RA151" ;
    ns1:learningResultDescription "Aplicar los modelos de fragmentación de roca para el diseño de voladuras."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000142/2025-26/RA152> a ns1:LearningResult ;
    ns1:learningResultCode "RA152" ;
    ns1:learningResultDescription "Aplicar las tecnologías disponibles, incluyendo software y equipos de medida, al diseño y control de voladuras."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000142/2025-26/RA153> a ns1:LearningResult ;
    ns1:learningResultCode "RA153" ;
    ns1:learningResultDescription "Conocer el mecanismo de daño a la roca por voladura, su implicación en la estabilidad del macizo, y aplicar métodos para su medida, modelización, control y mitigación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000142/2025-26/RA154> a ns1:LearningResult ;
    ns1:learningResultCode "RA154" ;
    ns1:learningResultDescription "Aplicar los métodos de medida de las vibraciones y onda aérea, sus modelos y su control y mitigación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000142/2025-26/RA155> a ns1:LearningResult ;
    ns1:learningResultCode "RA155" ;
    ns1:learningResultDescription "Comprender los aspectos económicos de la voladura y su interrelación con el coste global de la operación para su gestión óptima."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000142/2025-26/RA156> a ns1:LearningResult ;
    ns1:learningResultCode "RA156" ;
    ns1:learningResultDescription "Comprender el ciclo de vida del explosivo y la huella de carbono de la voladura en el marco de la operación minera."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000142/2025-26/RA157> a ns1:LearningResult ;
    ns1:learningResultCode "RA157" ;
    ns1:learningResultDescription "Capacidad de abordar el diseño de cualquier tipo de voladuras."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000142/2025-26/didactic_resource/1> a ns1:DidacticResource ;
    ns1:bibliographyDescription """Persson PA, Holmberg R, Lee J. 1994. Rock blasting and explosives engineering. Boca Raton, FL: CRC Press.
Zhang, Z-X. 2016. Rock Fracture and Blasting. Theory and Applications. Butterworth-Heinemann / Elsevier."""@es ;
    ns1:bibliographyTitle "General"@es ;
    ns1:bibliographyType "Bibliografía"@es .

