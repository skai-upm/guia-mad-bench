    ns1:bibliographyDescription "Sanchidrián JA. 2025. Ingeniería de Explosivos. Capítulo 15 - Fragmentation by blasting prediction models"@es ;
    ns1:bibliographyTitle "Avanzado - fragmentación"@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000142/2025-26/didactic_resource/3> a ns1:DidacticResource ;
    ns1:bibliographyDescription "Hustrulid WA, McCarter MK, Van Zyl DJA. 2000. Slope stability in surface mining. Littleton, CO: Society for Mining, Metallurgy and Exploration."@es ;
    ns1:bibliographyTitle "Avanzado - talud"@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000142/2025-26/didactic_resource/4> a ns1:DidacticResource ;
    ns1:bibliographyDescription "Dowding CH. 2000. Construction vibrations. Cleveland, OH: International Society of Explosives Engineers"@es ;
    ns1:bibliographyTitle "Avanzado - vibraciones"@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000142/2025-26/didactic_resource/5> a ns1:DidacticResource ;
    ns1:bibliographyDescription "Proceedings, International Symposium on Rock Fragmentation by Blasting (FRAGBLAST). 2025, 2022, 2018, 2015, 2012, 2009, 2006, 2002, 1999, 1996, 1993, 1990, 1987, 1983"@es ;
    ns1:bibliographyTitle "Avanzado - de todo"@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000142/2025-26/didactic_resource/6> a ns1:DidacticResource ;
    ns1:bibliographyDescription """- 3D Laser profiler
- Borehole deviation probe
- Sismógrafos
- Medidor velocidad de detonación
- Vídeo alta velocidad"""@es ;
    ns1:bibliographyTitle "Equipos de medida y análisis de voladuras (I)"@es ;
    ns1:bibliographyType "Equipamiento"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000142/2025-26/didactic_resource/7> a ns1:DidacticResource ;
    ns1:bibliographyDescription """- Fotogrametría terrestre de banco Blastmetrix + Shapemetrix 3G
- Fotogrametría aérea de banco y subterránea UAV
- Acelerómetros
- Transductores de presión
- Equipos de registro multicanal a 10 MHz
- Televiewer (optical borehole logger)"""@es ;
    ns1:bibliographyTitle "Equipos de medida y análisis de voladuras (II)"@es ;
    ns1:bibliographyType "Equipamiento"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000142/2025-26/didactic_resource/8> a ns1:DidacticResource ;
    ns1:bibliographyDescription """- JK-Simblast
- i-Blast 6
- Face 3D
- Blastware
- Split
- Fragmenter
- Mine Plan Package: MP core, MP Blast Design, MP Blast Tie-in & Charge"""@es ;
    ns1:bibliographyTitle "Software"@es ;
    ns1:bibliographyType "Otros"@es .

