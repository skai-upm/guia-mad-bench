    ns1:otherInformation """In a normal situation the Evaluation Activities and classes will be done presentially.
In case the Chief of Studies says so, all the activities will be done telematically with no significant changes either in the contents or in the schedule."""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
