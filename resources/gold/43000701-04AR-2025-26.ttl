    ns1:inpersonHours "60 horas (51.3%)"@es ;
    ns1:numberOfCredits 4.5 ;
    ns1:otherInformation "La asignatura se relaciona con los siguientes Objetivos de Desarrollo Sostenible: 11 (Ciudades y comunidades sostenibles), 13 (Acción por el clima) y 14 (Vida submarina)."@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "60 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/43000701/2025-26/eventSchedule> ;
    schema:description "Esta asignatura es optativa dentro de la especialidad de Ingeniería Civil del Medio Ambiente. El contenido de la asignatura se centra en los efectos del cambio climático (subida del nivel de mar y eventos extraordinarios y su frencuencia) en el comportamiento hidráulico y estructural de las estructuras costeras tanto de protección de núcleos urbanos como de protección de instalaciones portuarias. Para ello, primero se realiza una revisión de la legislación y normativa,luego se analizan la intensidad y frecuencia de los eventos extremos (tormentas) y por último se analizan sus efectos en diferentes estructuras costeras."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/josesantos.lopez%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/josesantos.lopez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/mariadolores.esteban%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/pedro.fernandez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/vicente.negro%40upm.es> ;
    schema:name "Adaptación de las Obras Marítimas Al Cambio Climático"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000701/2025-26/CE1> a ns1:Competency ;
    ns1:competencyCode "CE1" ;
    ns1:competencyDescription "Realizar estudios de los aspectos medioambientales relacionados con infraestructuras civiles TIPO: Competencias."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000701/2025-26/CE2> a ns1:Competency ;
    ns1:competencyCode "CE2" ;
    ns1:competencyDescription "Abordar y resolver problemas matemáticos avanzados de ingeniería, desde el planteamiento del problema hasta el desarrollo de la formulación y su implementación en un programa de ordenador. En particular, capacidad para formular, programar y aplicar modelos analíticos y numéricos avanzados de cálculo, planificación y gestión, así como capacidad para la interpretación de los resultados obtenidos, en el contexto de la ingeniería civil hidráulica, energética o medioambiental TIPO: Competencias."@es .

