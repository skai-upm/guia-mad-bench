<https://guia-kg.skai.etsisi.upm.es/resource/25001205/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Introducción al estudio del Suelo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001205/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Concepto de Edafología y Suelo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001205/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "1.3. Morfología de suelos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001205/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "1.3.1. Estudio del suelo en campo y el perfil del suelo Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001205/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "1.3.2. Horizontes genéticos y su nomenclatura. Horizontes de diagnóstico Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001205/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "1.3.3. Metodología de muestreo, descripción de perfiles en campo y análisis de laboratorio. Elaboración de la hoja de campo Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001205/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "1.3.4. Propiedades observadas e inferidas Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001205/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "2. Componentes del suelo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001205/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "2.1. Fracciones del suelo: sólida, líquida y gaseosa. Organización y relaciones entre ellas Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001205/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "2.2. Componente mineral. Minerales primarios y secundarios. Importancia edáfica Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001205/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "2.3. Componente orgánico. Origen y formas de la materia orgánica. Balance de materia orgánica. Relación C/N. Complejos órgano-minerale Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001205/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "2.4. Aplicaciones de enmiendas orgánicas Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001205/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.1.1. Objeto de la Edafología Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001205/2025-26/syllabus/20> a ns1:SyllabusItem ;
    ns1:itemIndex 20 ;
    ns1:syllabusDescription "2.5. Componente biológico. Funciones de los organismos del suelo. Actividad biológica. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001205/2025-26/syllabus/21> a ns1:SyllabusItem ;
    ns1:itemIndex 21 ;
    ns1:syllabusDescription "3. Propiedades del suelo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001205/2025-26/syllabus/22> a ns1:SyllabusItem ;
    ns1:itemIndex 22 ;
    ns1:syllabusDescription "3.1. Propiedades físicas del suelo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001205/2025-26/syllabus/23> a ns1:SyllabusItem ;
    ns1:itemIndex 23 ;
    ns1:syllabusDescription "3.1.1. El color del suelo; atributos del color y medida. Implicaciones agronómicas Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001205/2025-26/syllabus/24> a ns1:SyllabusItem ;
    ns1:itemIndex 24 ;
    ns1:syllabusDescription "3.1.2. Textura del suelo: fracciones granulométricas, clases texturales y su relación con otras propiedades del suelo. Aplicación agroambiental Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001205/2025-26/syllabus/25> a ns1:SyllabusItem ;
    ns1:itemIndex 25 ;
    ns1:syllabusDescription "3.1.3. Estructura del suelo: concepto y formación de agregados. Clasificación morfológica de la estructura. Estabilidad estructural. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001205/2025-26/syllabus/26> a ns1:SyllabusItem ;
    ns1:itemIndex 26 ;
    ns1:syllabusDescription "3.1.4. Porosidad del suelo, densidad real y aparente. Determinación de la densidad. Compactación. Costras superficiales. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001205/2025-26/syllabus/27> a ns1:SyllabusItem ;
    ns1:itemIndex 27 ;
    ns1:syllabusDescription "3.2. El agua en el suelo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001205/2025-26/syllabus/28> a ns1:SyllabusItem ;
    ns1:itemIndex 28 ;
    ns1:syllabusDescription "3.2.1. El agua del suelo. Medida: humedad gravimétrica y volumétrica Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001205/2025-26/syllabus/29> a ns1:SyllabusItem ;
    ns1:itemIndex 29 ;
    ns1:syllabusDescription "3.2.2. Potencial del agua en el suelo. Curva característica de humedad y constantes de humedad (PM, CC). CRAD. Balance de humedad del suelo Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001205/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "1.1.2. El concepto y funiciones del suelo Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001205/2025-26/syllabus/30> a ns1:SyllabusItem ;
    ns1:itemIndex 30 ;
    ns1:syllabusDescription "3.2.3. Movimiento de agua en el suelo: infiltración y permeabilidad Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001205/2025-26/syllabus/31> a ns1:SyllabusItem ;
    ns1:itemIndex 31 ;
    ns1:syllabusDescription "3.3. Propiedades químicas y físico-químicas del suelo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001205/2025-26/syllabus/32> a ns1:SyllabusItem ;
    ns1:itemIndex 32 ;
    ns1:syllabusDescription "3.3.1. Superficie de los coloides. Carga y superficie específica. Carga permanente y carga variable. Doble capa difusa. Interacción entre partículas: floculación y dispersión de arcillas Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001205/2025-26/syllabus/33> a ns1:SyllabusItem ;
    ns1:itemIndex 33 ;
    ns1:syllabusDescription "3.3.2. Caracterización del complejo de intercambio: capacidad de intercambio catiónico, saturación por bases, acidez de cambio. Equilibrios de intercambio iónico. Ecuación de Gapón Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001205/2025-26/syllabus/34> a ns1:SyllabusItem ;
    ns1:itemIndex 34 ;
    ns1:syllabusDescription "3.3.3. El pH del suelo. Influencia sobre la disponibilidad de nutrientes. Poder amortiguador del suelo. Adaptación de los cultivos a distintos pH. Modificación del pH: encalado de suelos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001205/2025-26/syllabus/35> a ns1:SyllabusItem ;
    ns1:itemIndex 35 ;
    ns1:syllabusDescription "3.3.4. Química de los procesos redox en el suelo. Suelos hidromorfos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001205/2025-26/syllabus/36> a ns1:SyllabusItem ;
    ns1:itemIndex 36 ;
    ns1:syllabusDescription "3.3.5. Conductividad eléctrica y concentración de sales. Salinidad y sodicidad. Tolerancia de los cultivos a la salinidad. Calidad del agua de riego. Balance de sales. Recuperación de suelos salinos y sódicos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001205/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "1.1.3. El suelo como sistema complejo, dinámico y abierto Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001205/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "1.2. Génesis del suelo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001205/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "1.2.1. Factores formadores del suelo (causas). Factores activos (clima, seres vivos), factores pasivos (litología y geomorfología) y tiempo Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001205/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "1.2.2. Procesos formadores de suelos (efectos). Adiciones, pérdidas, transformaciones y translocaciones. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001205/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "1.2.3. Procesos predominantes en ambientes mediterráneos Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001205/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "1.2.4. Bases para la clasificación de suelos: Soil Taxonomy y WRB. Sin subniveles"@es .

