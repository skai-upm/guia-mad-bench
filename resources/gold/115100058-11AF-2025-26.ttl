    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/115100058/2025-26/eventSchedule> ;
    schema:description "Las actividades acuáticas contribuyen de forma esencial a la recuperación, mantenimiento y mejora de la condición física y de la salud, tanto en personas que hacen ejercicio físico como en las que no hacen ejercicio físico de forma regular. Dentro de los itinerarios profesionales que ofrece el Grado en Ciencias de la Actividad Física y del Deporte, esta asignatura ha de servir a los futuros graduados a adquirir una base en las diferentes modalidades acuáticas, desde un punto de vista saludable, atendiendo a las características especiales de los/as alumnos/as, usuarios/as y/o deportistas. Asimismo, al relacionarse con asignaturas como Actividad Física y Salud, Natación, etc., permitirá al graduado universitario disponer de recursos para el desarrollo de habilidades en cualquier tipo de persona."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/raquel.pedrero%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/ma.rojo%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/raquel.pedrero%40upm.es> ;
    schema:name "Actividades Acuáticas para la Salud"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100058/2025-26/CE14> a ns1:Competency ;
    ns1:competencyCode "CE14" ;
    ns1:competencyDescription "Evaluar la condición física y prescribir ejercicios físicos orientados hacia la salud. Nivel 2."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100058/2025-26/CE15> a ns1:Competency ;
    ns1:competencyCode "CE15" ;
    ns1:competencyDescription "Identificar y prevenir los riesgos que se derivan para la salud, de la práctica de actividades físicas inadecuadas, entre la población que realiza práctica física orientada a la salud. Nivel 3."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100058/2025-26/CG03> a ns1:Competency ;
    ns1:competencyCode "CG03" ;
    ns1:competencyDescription "Organizar y planificar propuestas de acción, programas y actividades propias de su campo profesional en sus diferentes ámbitos de aplicación y desarrollo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100058/2025-26/CG08> a ns1:Competency ;
    ns1:competencyCode "CG08" ;
    ns1:competencyDescription "Aplicar los conocimientos adquiridos en los procesos de formación en la práctica profesional, en diferentes contextos y situaciones."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100058/2025-26/RA33> a ns1:LearningResult ;
    ns1:learningResultCode "RA33" ;
    ns1:learningResultDescription "Conocer la terminología, el uso de símbolos y gráficos en la representación de las diferentes situaciones prácticas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100058/2025-26/RA59> a ns1:LearningResult ;
    ns1:learningResultCode "RA59" ;
    ns1:learningResultDescription "Conocer y contactar con las bases teóricas y concepto de salud. Importancia de las actividades acuáticas para la salud. Conocer las técnicas empleadas en el medio acuático para la prevención y tratamiento de las patologías más frecuentes y para el mantenimiento de la condición física."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100058/2025-26/RA60> a ns1:LearningResult ;
    ns1:learningResultCode "RA60" ;
    ns1:learningResultDescription "Conocer las características específicas de algunas poblaciones especiales (mayores y embarazadas) y elaborar programas de actividades acuáticas para estas poblaciones."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100058/2025-26/RA61> a ns1:LearningResult ;
    ns1:learningResultCode "RA61" ;
    ns1:learningResultDescription "Conocer las características de las alteraciones de columna, su prevención y compensación mediante la actividad física en el medio acuático."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100058/2025-26/RA62> a ns1:LearningResult ;
    ns1:learningResultCode "RA62" ;
    ns1:learningResultDescription "Conocer las bases teóricas de los procesos patológicos más frecuentes y la prescripción de los programas de ejercicios individualizados en el medio acuático."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100058/2025-26/RA63> a ns1:LearningResult ;
    ns1:learningResultCode "RA63" ;
    ns1:learningResultDescription "Conocer y saber aplicar diferentes modalidades acuáticas (aquagym, aquaerobic, etc), para el mantenimiento de la condición física"@es .

