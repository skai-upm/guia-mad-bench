    ns1:itemIndex 11 ;
    ns1:syllabusDescription "2.6. Práctica en el laboratorio de simulación, introductoria al análisis circuitos de microondas mediante el software comercial ADS. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000040/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "3. Líneas y medios de transmisión comunes"@es .

