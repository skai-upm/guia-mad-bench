    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/63000149/2025-26/syllabus> ;
    ns1:inpersonHours "36 horas (46.2%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation ""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "39 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/63000149/2025-26/eventSchedule> ;
    schema:description """Desarrollar una comprensión de los elementos de la teoría clásica de control aplicada al control de procesos industriales.
Comprender el concepto de realimentación y sus propiedades, el concepto de márgenes de estabilidad y robustez.

Utilizar las diferentes herramientas que se pueden usar para analizar las propiedades previas.

Obtener un conocimiento práctico de las técnicas básicas de diseño lineal, en particular las aplicadas a procesos
industriales simples.

Autómatas y controladores lógicos programables (PLC)"""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/miguel.jimenezcarrizosa%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/luisjavier.sanjose%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/miguel.jimenezcarrizosa%40upm.es> ;
    schema:name "Control Automatico de Procesos"@es .

