<https://guia-kg.skai.etsisi.upm.es/resource/305000102/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "3.2. Números enteros y racionales. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000102/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "3.3. Números reales y complejos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000102/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "3.4. Numerabilidad de conjuntos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000102/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "4. Aritmética."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000102/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "4.1. División entera, mcd y mcm, ecuaciones diofánticas lineales, primos, teorema fundamental de la aritmética y fracciones simples Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000102/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "4.2. Aritmética modular: congruencias en Z, aritmética en Zn, divisores de cero y elementos invertibles. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000102/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "4.3. Introducción a los grupos. Definición, subgrupo y grupos cíclicos. Ejemplos. Primer teorema de isomorfía. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000102/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "4.4. Teoremas de Euler, Fermat y Wilson. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000102/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "4.5. Ecuaciones lineales en congruencias. Teorema chino del residuo. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000102/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Demostración en matemáticas. Tipos de demostración; refutaciones y contraejemplos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000102/2025-26/syllabus/20> a ns1:SyllabusItem ;
    ns1:itemIndex 20 ;
    ns1:syllabusDescription "4.6. Polinomios: división entera y divisibilidad, raíces, factorización en los reales y los complejos; fracciones simples. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000102/2025-26/syllabus/21> a ns1:SyllabusItem ;
    ns1:itemIndex 21 ;
    ns1:syllabusDescription "5. Combinatoria."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000102/2025-26/syllabus/22> a ns1:SyllabusItem ;
    ns1:itemIndex 22 ;
    ns1:syllabusDescription "5.1. Principios básicos de recuento. Cajas, adición, multiplicación y complementario. Listas y selecciones. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000102/2025-26/syllabus/23> a ns1:SyllabusItem ;
    ns1:itemIndex 23 ;
    ns1:syllabusDescription "5.2. Algoritmos de enumeración, números combinatorios y multinómicos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000102/2025-26/syllabus/24> a ns1:SyllabusItem ;
    ns1:itemIndex 24 ;
    ns1:syllabusDescription "5.3. Principio de inclusión-exclusión, distribuciones de objetos en cajas distintas o iguales y particiones de conjuntos. Argumentos combinatorios. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000102/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "1.3. Escritura de demostraciones. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000102/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "2. Conjuntos y aplicaciones."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000102/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "2.1. Teoría elemental de conjuntos. Subconjuntos, potencia, unión, intersección y producto cartesiano. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000102/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "2.2. Relaciones de equivalencia, conjunto cociente, relaciones de orden, diagramas de Hasse, retículos y álgebra de Boole. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000102/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "2.3. Aplicaciones. Imagen, preimagen y composición. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000102/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "2.4. Aplicaciones inyectivas, inclusión canónica. Aplicaciones suprayectivas, proyección canónica. Aplicaciones biyectivas, aplicación inversa. Descomposición canónica. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000102/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "3. Números."@es .

