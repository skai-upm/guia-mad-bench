<https://guia-kg.skai.etsisi.upm.es/resource/45001418/2025-26/CM32.1> a ns1:Competency ;
    ns1:competencyCode "CM32.1" ;
    ns1:competencyDescription "Capacidad para la construcción y conservación de carreteras, así como para el dimensionamiento, el proyecto y los elementos que componen las dotaciones viarias básicas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001418/2025-26/CM32.2> a ns1:Competency ;
    ns1:competencyCode "CM32.2" ;
    ns1:competencyDescription "Comprensión y capacidad de cuantificación de las variables viarias y de tráfico que determinan la seguridad, la calidad y la sostenibilidad de las infraestructuras de transporte por carretera."@es .

