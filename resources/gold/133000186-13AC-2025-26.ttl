<https://guia-kg.skai.etsisi.upm.es/resource/133000186> a ns1:Course ;
    ns1:courseType "Obligatoria"@es ;
    ns1:courseYear 1 ;
    ns1:semester "Segundo semestre"@es ;
    schema:courseCode 133000186 ;
    schema:hasCourseInstance <https://guia-kg.skai.etsisi.upm.es/resource/133000186/2025-26> ;
    schema:name "Project Analysis And Environmental Investments"@en,
        "Analisis de Proyectos e Inversiones Ambientales"@es ;
    schema:numberOfCredits 3.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/133000186/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/133000186/2025-26/CB08>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000186/2025-26/CE03>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000186/2025-26/CE06>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000186/2025-26/CG01>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000186/2025-26/CG02>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000186/2025-26/CT05> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/133000186/2025-26/didactic_resource/1> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/133000186/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/133000186/2025-26/RA22>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000186/2025-26/RA23>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000186/2025-26/RA6>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000186/2025-26/RA8> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/133000186/2025-26/syllabus> ;
    ns1:inpersonHours "37 horas (47.4%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation "En la asignatura se trabajan los objetivos de desarrollo sostenible, resaltando la importancia de la economía circular, sus modelos de negocio y las posibilidades de su implantación en el P.I.B. de los diferentes países donde se lleva a cabo."@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "37 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/133000186/2025-26/eventSchedule> ;
    schema:description """En esta asignatura se plantea que los estudiantes adquieran los conocimientos fundamentales de cualquier proyecto económico, incluidos los proyectos e inversiones de índole ambiental y de economía circular.
El primer tema gira en torno a los conceptos básicos económicos del rendimiento o rentabilidad y el riesgo.
Los objetivos de la Economía Circular constituye el segundo apartado del temario.
Dentro del tercer tema están los modelos de negocio en economía circular y sus principales características.
En el bloque cuarto se contemplan los tipos de Economía colaborativa.
Para el quinto tema, se hace un estudio de como deben plantearse los análisis de viabilidad de proyectos y de inversiones, resolviendo ejercicios con inclusión de variables como la inflación y los impuestos.
En el sexto tema, se explican el "project Finance", muy importante para grandes proyectos de inversión."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/julian.alonso%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/julian.alonso%40upm.es> ;
    schema:name "Analisis de Proyectos e Inversiones Ambientales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000186/2025-26/CB08> a ns1:Competency ;
    ns1:competencyCode "CB08" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de integrar conocimientos y enfrentarse a la complejidad de formular juicios a partir de una información que, siendo incompleta o limitada, incluya reflexiones sobre las responsabilidades sociales y éticas vinculadas a la aplicación de sus conocimientos y juicios"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000186/2025-26/CE03> a ns1:Competency ;
    ns1:competencyCode "CE03" ;
    ns1:competencyDescription "El alumno podrá planificar proyectos de economía circular referidos a la interacción entre actividades e industrias."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000186/2025-26/CE06> a ns1:Competency ;
    ns1:competencyCode "CE06" ;
    ns1:competencyDescription "El alumno será capaz de analizar proyectos de inversión y realizar modelos de negocio en el ámbito de la economía circular."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000186/2025-26/CG01> a ns1:Competency ;
    ns1:competencyCode "CG01" ;
    ns1:competencyDescription "El alumno tendrá capacidad para analizar y evaluar las implicaciones de implantar un modelo de economía circular desde el punto de vista normativo, económico, industrial y tecnológico."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000186/2025-26/CG02> a ns1:Competency ;
    ns1:competencyCode "CG02" ;
    ns1:competencyDescription "El alumno podrá utilizar las herramientas necesarias para llevar a cabo los cambios en la empresa y en la sociedad para adoptar un modelo de economía circular."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000186/2025-26/CT05> a ns1:Competency ;
    ns1:competencyCode "CT05" ;
    ns1:competencyDescription "El alumno tendrá capacidad para planificar y organizar trabajos y proyectos, estableciendo los objetivos y la programación, asignando tareas y recursos y responsabilizándose de la correcta toma de decisiones."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000186/2025-26/RA22> a ns1:LearningResult ;
    ns1:learningResultCode "RA22" ;
    ns1:learningResultDescription "Desarrollar un modelo de negocio en una economía circular"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000186/2025-26/RA23> a ns1:LearningResult ;
    ns1:learningResultCode "RA23" ;
    ns1:learningResultDescription "Que los estudiantes conozcan los fundamentos financieros"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000186/2025-26/RA6> a ns1:LearningResult ;
    ns1:learningResultCode "RA6" ;
    ns1:learningResultDescription ""@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000186/2025-26/RA8> a ns1:LearningResult ;
    ns1:learningResultCode "RA8" ;
    ns1:learningResultDescription "Capacidad de detereminar el mejor modelo circular en insitituciones y empresas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000186/2025-26/didactic_resource/1> a ns1:DidacticResource ;
