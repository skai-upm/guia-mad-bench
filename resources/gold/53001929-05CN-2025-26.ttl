<https://guia-kg.skai.etsisi.upm.es/resource/53001929/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/53001929/2025-26/MUCTN.CB06>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001929/2025-26/MUCTN.CB08>,
