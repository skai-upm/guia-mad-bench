    ns1:learningResultCode "RA161" ;
    ns1:learningResultDescription "Conocimiento y comprensión de las técnicas básicas de Variable Compleja que son de aplicación en el ámbito de la Ingeniería Aeroespacial."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145003001/2025-26/RA162> a ns1:LearningResult ;
    ns1:learningResultCode "RA162" ;
    ns1:learningResultDescription "Comprensión de los modelos básicos que, en forma de ecuaciones diferenciales en derivadas parciales, son de aplicación en Ingeniería Aeroespacial."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145003001/2025-26/RA163> a ns1:LearningResult ;
    ns1:learningResultCode "RA163" ;
    ns1:learningResultDescription "Conocimiento y aplicación de los métodos de resolución básicos para este tipo de modelos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145003001/2025-26/RA593> a ns1:LearningResult ;
    ns1:learningResultCode "RA593" ;
    ns1:learningResultDescription "Comprensión de las técnicas básicas de análisis y solución de ecuaciones diferenciales ordinarias."@es .

