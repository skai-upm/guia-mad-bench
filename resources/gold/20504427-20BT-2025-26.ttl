<https://guia-kg.skai.etsisi.upm.es/resource/20504427/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/20504427/2025-26/CG03>,
        <https://guia-kg.skai.etsisi.upm.es/resource/20504427/2025-26/CG04>,
        <https://guia-kg.skai.etsisi.upm.es/resource/20504427/2025-26/CT04>,
        <https://guia-kg.skai.etsisi.upm.es/resource/20504427/2025-26/CT06>,
        <https://guia-kg.skai.etsisi.upm.es/resource/20504427/2025-26/CT07> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/20504427/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/20504427/2025-26/didactic_resource/2>,
