<https://guia-kg.skai.etsisi.upm.es/resource/145013002/2025-26/RA34> a ns1:LearningResult ;
    ns1:learningResultCode "RA34" ;
    ns1:learningResultDescription "Comprende los fundamentos teóricos de los sistemas e instrumentación meteorológica"@es .

