<https://guia-kg.skai.etsisi.upm.es/resource/145013002/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Introducción: Unidades utilizadas en meteorología, relación de la meteorología con la aviación y organización de los servicios meteorológicos nacionales e internacionales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145013002/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Termodinámica. Primer pincipio, calor. Gas ideal. Temperatura Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145013002/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "3.3. Nieblas. Formación y tipos de niebla. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145013002/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "3.4. Nubes. (Clasificación, descripción). Condiciones de vuelo correspondientes. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145013002/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "4. Estabilidad atmosférica. Gradiente térmico. Diagrama termodinámico de Stüve Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145013002/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "5. Viento (Gradiente horizontal de presión, efecto Coriolis y composición de fuerzas). Medida ."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145013002/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "5.1. Viento (Gradiente horizontal de presión Viento geostrófico, del gradiente, ciclostrófíco, ageostrófico, locales, brisas, orográfico, Foehn). Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145013002/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "5.2. Variación del viento con el rozamiento. Espiral de Ekman Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145013002/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "5.3. Circulación general de la atmósfera. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145013002/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "5.4. Corriente en chorro. Origen. Condiciones favorables para su existencia. Estructura general y fenómenos asociados. Clasificación. Reconocimiento del chorro y su aprovechamiento en la aeronáutica."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145013002/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "5.4.1. Chorro estratosférico. Condiciones estratósfericas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145013002/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "6. Turbulencia. Turbulencia orográfica y térmica. Onda de montaña. Turbulencia en aire claro. Condiciones para su formación. Cizalladura vertical y horizontal. Onda de gravedad cizalladura. Inversiones térmicas. Condiciones de vuelo. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145013002/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Relación de la meteorología con la aviación (anexo 3) y organización de los servicios meteorológicos nacionales e internacionales. Sistemas de Observación. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145013002/2025-26/syllabus/20> a ns1:SyllabusItem ;
    ns1:itemIndex 20 ;
    ns1:syllabusDescription "7. Precipitación. Definición. Efectos de las precipitaciones en el vuelo. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145013002/2025-26/syllabus/21> a ns1:SyllabusItem ;
    ns1:itemIndex 21 ;
    ns1:syllabusDescription "8. Engelamiento. Condiciones de vuelo Efectos orográficos. Características del avión Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145013002/2025-26/syllabus/22> a ns1:SyllabusItem ;
    ns1:itemIndex 22 ;
    ns1:syllabusDescription "9. Tormentas y tornados."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145013002/2025-26/syllabus/23> a ns1:SyllabusItem ;
    ns1:itemIndex 23 ;
    ns1:syllabusDescription "9.1. Tormentas y fenómenos asociados. Estructura. Microráfagas. Clasificación. Vuelo a través de tormentas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145013002/2025-26/syllabus/24> a ns1:SyllabusItem ;
    ns1:itemIndex 24 ;
    ns1:syllabusDescription "10. Visibilidad. Factores que afectan a la visibilidad. Procesos físicos de formación y disipación de la niebla. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145013002/2025-26/syllabus/25> a ns1:SyllabusItem ;
    ns1:itemIndex 25 ;
    ns1:syllabusDescription "11. Masas de aire. clasificación, condiciones y características. Frentes, clasificación, condiciones meteorológicas. Condiciones de vuelo en una borrasca frontal."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145013002/2025-26/syllabus/26> a ns1:SyllabusItem ;
    ns1:itemIndex 26 ;
    ns1:syllabusDescription "11.1. Depresiones no frontales: DANA, gota fría, borrasca térmica, borrasca orográfica, ciclón tropical. Ciclón tropical o huracán: definición, clasificación según Ness, frecuencia, denominación, Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145013002/2025-26/syllabus/27> a ns1:SyllabusItem ;
    ns1:itemIndex 27 ;
    ns1:syllabusDescription "12. Climatología. Definición. Zonas climáticas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145013002/2025-26/syllabus/28> a ns1:SyllabusItem ;
    ns1:itemIndex 28 ;
    ns1:syllabusDescription "12.1. Cambio climático y sus implicaciones en el transporte aéreo. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145013002/2025-26/syllabus/29> a ns1:SyllabusItem ;
    ns1:itemIndex 29 ;
    ns1:syllabusDescription "13. Clave METAR TREND/SPECI. Clave SNOWTAM. Clave METAR--#TAF. Clave SIGMET. Clave GAMET. Clave AIRMET/GAFOR. Mapas meteorológicos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145013002/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "2. La atmósfera y calor"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145013002/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "2.1. La atmósfera (Definición, composición, distribución térmica y físico químico). Variación de la presión con la altura. Temperatura. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145013002/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "2.2. Atmósfera Estándar Internacional. ISA. Altimetría. Anexo 3 Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145013002/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "2.3. Procesos adiabáticos. Transmisión del calor. Ley de Plank del cuerpo negro, ley de Kirchhoff de la radiación térmica .Equilibrio térmico. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145013002/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "3. Presión o tensión de saturación. Condensación y precipitación. Teoría de la coalescencia."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145013002/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "3.1. Termodinamoca: Cambios de estado. Ecuacion Clausius Clapeyron Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145013002/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "3.2. Humedad absoluta, específica, relativa y razón de mezcla. Tensión de saturación del vapor sobre agua e hielo. Agua en subfusión. Condensación y precipitación. Precipitación procedente de las nubes frías y calientes. Teoría de la coalescencia. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/14GY%20-%20Grado%20en%20Gesti%C3%B3n%20y%20Operaciones%20del%20Transporte%20A%C3%A9reo> a ns1:BachelorDegree ;
    ns1:degreeCode "14GY"@es ;
    ns1:hasCourse <https://guia-kg.skai.etsisi.upm.es/resource/145013002> ;
    schema:name "Grado en Gestión y Operaciones del Transporte Aéreo"@es .

