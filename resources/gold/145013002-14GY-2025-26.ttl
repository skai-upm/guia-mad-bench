    ns1:bibliographyDescription """Libro clásico que cubre casi toda la asignatura.
Algunas definiciones las tomaremos de otra bibliografía."""@es ;
    ns1:bibliographyTitle "Manuel Ledesma y Gabriel Baleriola:. Meteorología Aplicada a la Aviaciónmosférica."@es ;
    ns1:bibliographyType "Bibliografía"@es .

