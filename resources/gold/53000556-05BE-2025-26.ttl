    ns1:learningResultCode "RA50" ;
    ns1:learningResultDescription "Capacidad para diagnosticar máquinas eléctricas en caso de fallo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000556/2025-26/RA51> a ns1:LearningResult ;
    ns1:learningResultCode "RA51" ;
    ns1:learningResultDescription "Capacidad para la estimación del estado de una máquina eléctrica a través de la interpretación de los datos de un sistema de monitorización"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000556/2025-26/RA52> a ns1:LearningResult ;
