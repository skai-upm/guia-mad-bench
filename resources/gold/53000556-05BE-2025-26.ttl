<https://guia-kg.skai.etsisi.upm.es/resource/53000556/2025-26/CE09> a ns1:Competency ;
    ns1:competencyCode "CE09" ;
    ns1:competencyDescription "Aplicar los conocimientos adquiridos para establecer procedimientos de mantenimiento predictivo de máquinas y equipos eléctricos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000556/2025-26/CG02> a ns1:Competency ;
    ns1:competencyCode "CG02" ;
    ns1:competencyDescription "Ser capaces de aplicar sus conocimientos y su comprensión, así como sus habilidades para resolver problemas, en entornos nuevos o no familiares y en contextos amplios (multidisciplinarios) relativos a su campo de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000556/2025-26/CG03> a ns1:Competency ;
    ns1:competencyCode "CG03" ;
    ns1:competencyDescription "Tener habilidad de integrar conocimientos y de afrontar la complejidad y también de formular juicios a partir de información incompleta o limitada, pero que incluye reflexiones sobre las responsabilidades sociales y éticas ligadas a la aplicación de sus conocimientos y juicios"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000556/2025-26/CG05> a ns1:Competency ;
    ns1:competencyCode "CG05" ;
    ns1:competencyDescription "Haber desarrollado habilidades de aprendizaje que les permitan continuar los estudios de manera ampliamente autodirigida o autónoma"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000556/2025-26/CT01> a ns1:Competency ;
    ns1:competencyCode "CT01" ;
    ns1:competencyDescription "Uso de la lengua inglesa"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000556/2025-26/CT03> a ns1:Competency ;
