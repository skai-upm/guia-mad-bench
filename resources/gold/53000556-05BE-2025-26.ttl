<https://guia-kg.skai.etsisi.upm.es/resource/53000556/2025-26/RA53> a ns1:LearningResult ;
    ns1:learningResultCode "RA53" ;
    ns1:learningResultDescription "Capacidad para el diseño y utilización de sistemas de mantenimiento predictivo en máquinas eléctricas"@es .

