<https://guia-kg.skai.etsisi.upm.es/resource/55001014/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. El trabajo en el laboratorio. Normas de trabajo específicas. Normas de seguridad. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001014/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "2. Tratamiento estadístico de resultados. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001014/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "3. Trabajo en equipo Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001014/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "4. Medida de viscosidad de líquidos. Influencia de la temperatura. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001014/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "5. Determinación de pesos moleculares por viscosimetría. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001014/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "6. Solubilidad. Influencia de la fuerza iónica, la temperatura y el efecto del ion común. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001014/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "7. Determinación del pK de un indicador ácido-base. Proyecto. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001014/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "8. Cinética I: Determinación de los parámetros cinéticos de la decoloración de la fenolftaleina Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001014/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "9. Cinética II. Proyecto: Estudio del efecto de la naturaleza del disolvente y/o de la fuerza iónica en la cinética de la decoloración de la fenolftaleina Sin subniveles"@es .

