    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/45000229/2025-26/eventSchedule> ;
    schema:description "La enseñanza del proyecto y análisis de estructuras está configurada mediante un conjunto de asignaturas en las que se van introduciendo los conocimientos de forma organizada y progresiva, con uniformidad en la notación y coherencia en los planteamientos. En la asignatura de \"Cálculo de Estructuras\" se estudian las estructuras formadas por barras (estructuras articuladas y reticuladas), abordando su cálculo tanto por métodos elásticos como plásticos."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/miguel.fernandezruiz%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/antonio.carnerero%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/david.izquierdo%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/josemaria.arrieta%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/mariamercedes.madrid%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/miguel.fernandezruiz%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/nicola.tarque%40upm.es> ;
    schema:name "Calculo de Estructuras"@es .

