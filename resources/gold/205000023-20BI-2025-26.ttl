    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. UT1. Avicultura"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000023/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Tema 1: Introducción avicultura de carne y avicultura de puesta. Ciclos Productivos. Base animal de la avicultura intensiva. Estirpes. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000023/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "2. UT 2. Conejos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000023/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "2.1. Tema 8: Sistemas de producción de conejos. Situación del sector. Objetivos y Alimentación Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000023/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "3. UT3. Porcino"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000023/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "3.1. Tema 9: Estructura y porblemática del sector porcino Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000023/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "3.2. Tema 10: Manejo reproductivo Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000023/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "3.3. Tema 11: Manejo de la alimentación de ganado porcino reproductor Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000023/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "3.4. Tema 12: Mejora genética del ganado porcino Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000023/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "3.5. Tema 13: Producción internsiva de carne de cerdo Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000023/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "3.6. Tema 14: Calidad de la canal y de la carne Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000023/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "3.7. Tema 15: Dimensionamiento II. Dimensionamiento y planificación de explotaciones porcinas Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000023/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Tema 2: Reproductores pesados, semipesados y ligeros: crianza. Objetivos buscados. Alojamiento, instalaciones y condiciones de explotación. Control del crecimiento: manejo de la alimentación. Programas de iluminación Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000023/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "1.3. Tema 3: Reproductores pesados, semipesado y ligeros: puesta. Objetivos buscados. Alojamiento, instalaciones y condiciones deexplotación. Manejo de la alimentación. Programas de iluminación Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000023/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "1.4. Tema 4: El huevo incubable. Manejo del huevo incubable antes de la incubación. Incubadoras y nacedoras. El proceso de incubación y los nacimientos. Manejo del pollito recién nacido Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000023/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "1.5. Tema 5. Las ponedoras comerciales: crianza y puesta."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000023/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "1.5.1. Objetivos buscados. Alojamiento, instalaciones y condiciones de explotación. Manejo y programas de iluminación: edad a la madurez sexual Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000023/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "1.5.2. Objetivos buscados. Alojamiento, instalaciones y condiciones de explotación. Programas de iluminación. Muda forzada. Manejo del huevo para consumo. Calidad del huevo Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000023/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "1.6. Tema 6: El cebo del pollo de carne. Objetivos. Alojamiento, instalaciones y condiciones de explotación. Manejo para reducir los problemas derivados del potencial genético Sin subniveles"@es .

