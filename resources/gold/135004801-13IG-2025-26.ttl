    schema:name "Aprovechamientos y Certificacion Forestales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004801/2025-26/CB02> a ns1:Competency ;
    ns1:competencyCode "CB02" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar sus conocimientos a su trabajo o vocación de una forma profesional y posean las competencias que suelen demostrarse por medio de la elaboración y defensa de argumentos y la resolución de problemas dentro de su área de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004801/2025-26/CB05> a ns1:Competency ;
    ns1:competencyCode "CB05" ;
    ns1:competencyDescription "Que los estudiantes hayan desarrollado aquellas habilidades de aprendizaje necesarias para emprender estudios posteriores con un alto grado de autonomía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004801/2025-26/CE%202.13> a ns1:Competency ;
    ns1:competencyCode "CE 2.13" ;
    ns1:competencyDescription "Capacidad para conocer, comprender y utilizar los principios de: Aprovechamientos Forestales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004801/2025-26/CE%202.14> a ns1:Competency ;
    ns1:competencyCode "CE 2.14" ;
    ns1:competencyDescription "Capacidad para conocer, comprender y utilizar los principios de: Certificación Forestal."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004801/2025-26/CE%202.9> a ns1:Competency ;
    ns1:competencyCode "CE 2.9" ;
    ns1:competencyDescription "Capacidad para conocer, comprender y urilizar los principios de: Maquinaria y Mecanización Forestales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004801/2025-26/CG04> a ns1:Competency ;
    ns1:competencyCode "CG04" ;
    ns1:competencyDescription "Capacidad para evaluar y corregir el impacto ambiental, así como aplicar las técnicas de auditoria y gestión ambiental."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004801/2025-26/CG06> a ns1:Competency ;
    ns1:competencyCode "CG06" ;
    ns1:competencyDescription "Capacidad para medir, inventariar y evaluar los recursos forestales, aplicar y desarrollar las técnicas selvicolas y de manejo de todo tipo de sistemas forestales, parques y áreas recreativas, así como las técnicas de aprovechamiento de productos forestales maderables y no maderables."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004801/2025-26/CG10> a ns1:Competency ;
    ns1:competencyCode "CG10" ;
    ns1:competencyDescription "Capacidad para aplicar las técnicas de ordenación forestal y planificación del territorio, así como los criterios e indicadores de la gestión forestal sostenible en el marco de los procedimientos de certificación forestal."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004801/2025-26/CT9> a ns1:Competency ;
    ns1:competencyCode "CT9" ;
    ns1:competencyDescription "Utilización de TICs para el trabajo cooperativo y trabajo en equipo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004801/2025-26/RA289> a ns1:LearningResult ;
    ns1:learningResultCode "RA289" ;
    ns1:learningResultDescription "Decidir las operaciones de un aprovechamiento forestal, determinando materiales, equipos y técnicas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004801/2025-26/RA290> a ns1:LearningResult ;
    ns1:learningResultCode "RA290" ;
    ns1:learningResultDescription "Decidir las operaciones de un aprovechamiento forestal, determinando materiales, eUtilizar los recursos adecuados para la obtención y análisis de datos en un aprovechamiento forestal.quipos y técnicas."@es .

