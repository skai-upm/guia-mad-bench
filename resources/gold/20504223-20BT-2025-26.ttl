    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/20504223/2025-26/eventSchedule> ;
    schema:description """Unidad temática 1. Organización del trabajo en el laboratorio
Unidad temática 2. Preparación de muestras
Unidad temática 3. Separación por Centrifugación
Unidad temática 4. Separación por Electroforesis
Unidad temática 5. Separación por Cromatografía
Unidad temática 6. Detección mediante luminiscencia, radiactividad y uso de anticuerpos
Unidad temática 7. Detección mediante PCR y PCR cuantitativa. Secuenciación.
Unidad temática 8. Detección mediante Microscopía"""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/elena.caro%40upm.es> ;
