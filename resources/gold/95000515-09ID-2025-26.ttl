<https://guia-kg.skai.etsisi.upm.es/resource/95000515/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Estructura y organización de Internet."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000515/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Introducción. Conmutación de paquetes. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000515/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "4. Nivel de enlace: Metro y Carrier Ethernet."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000515/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "4.1. Ethernet clásica y conmutada. Redes locales virtuales. Redes Ethernet extensas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000515/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "5. Servicios y Calidad de servicio."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000515/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "5.1. Normalización y caracterización de servicios. Calidad de servicio (QoS). Acuerdos de nivel de servicio. QoS en redes Carrier Ethernet. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000515/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "6. Virtualización y Redes definidas por software."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000515/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "6.1. Virtualización de redes y conmutadores. SDN, redes definidas por software. NFV, introducción a la virtualización de funciones de red. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000515/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "7. Redes de distribución de contenidos (CDNs). Redes centradas en contenidos (ICN). Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000515/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "8. Prácticas de Laboratorio."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000515/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "8.1. Práctica 1.- Arquitectura y protocolos en Internet. Configuración de redes y equipos. Análisis de comportamiento y de prestaciones. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000515/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "8.2. Práctica 2.- Configuración de redes Ethernet. Redes de área local virtuales. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000515/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Qué es Internet. Estructura de Internet. Proveedores de servicios de Internet. Torres de protocolos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000515/2025-26/syllabus/20> a ns1:SyllabusItem ;
    ns1:itemIndex 20 ;
    ns1:syllabusDescription "8.3. Práctica 3.- Despliegue y prueba de aplicaciones basadas en red. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000515/2025-26/syllabus/21> a ns1:SyllabusItem ;
    ns1:itemIndex 21 ;
    ns1:syllabusDescription "8.4. Práctica 4.- Virtualización y redes definidas por software. Emulación del plano de datos. Configuración del plano de control. Aplicaciones de virtualización. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000515/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "1.3. Prestaciones en las redes de conmutación de paquetes. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000515/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "2. Nivel de aplicación e introducción al nivel de transporte."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000515/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "2.1. Principios de las aplicaciones en las redes. La Web y el protocolo HTTP. DNS, el servicio directorio en Internet. Distribución de ficheros entre pares. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000515/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "2.2. Servicios de nivel de transporte TCP y UDP. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000515/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "3. Nivel de red."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000515/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "3.1. Protocolo IP. Direccionamiento IP. Tablas de reenvío. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000515/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "3.2. Protocolo ICMP Sin subniveles"@es .

