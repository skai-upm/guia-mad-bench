<https://guia-kg.skai.etsisi.upm.es/resource/53001368/2025-26/RA1> a ns1:LearningResult ;
    ns1:learningResultCode "RA1" ;
    ns1:learningResultDescription "Conocimiento de los principios de la Biología, Bioquímica e Ingeniería Genética en su aplicación a la biotecnología"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001368/2025-26/RA3> a ns1:LearningResult ;
    ns1:learningResultCode "RA3" ;
    ns1:learningResultDescription "Conocimiento de los diferentes tipos de biorreactores celulares y de las ecuaciones que determinan su funcionamiento"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001368/2025-26/RA4> a ns1:LearningResult ;
