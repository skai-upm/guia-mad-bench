        <https://guia-kg.skai.etsisi.upm.es/resource/23000620/2025-26/didactic_resource/4>,
        <https://guia-kg.skai.etsisi.upm.es/resource/23000620/2025-26/didactic_resource/5>,
        <https://guia-kg.skai.etsisi.upm.es/resource/23000620/2025-26/didactic_resource/6> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/23000620/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/23000620/2025-26/RA38>,
        <https://guia-kg.skai.etsisi.upm.es/resource/23000620/2025-26/RA46>,
        <https://guia-kg.skai.etsisi.upm.es/resource/23000620/2025-26/RA8> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/23000620/2025-26/syllabus> ;
    ns1:inpersonHours "31 horas y 20 minutos (58%)"@es ;
    ns1:numberOfCredits 2.0 ;
    ns1:otherInformation """La asignatura está orientada a alumnos interesados en los estudios sobre asociacionismo: cooperativas, economía colaborativa y diversas asociaciones de caracter social.
Se considera importante el trabajo de grupo.
Al final de la asignatura, el estudiante podrá emitir juicios sobre implicaciones económicas y sociales; habrá adquirido capacidad para trabajar de forma efectiva como individuo, organizando y planificando su propio trabajo, de forma independiente o como miembro de un equipo y para trabajar en contextos internacionales. Lo que se corresponde con las competencias transersales, CT4, CT6 y CT7.
Durante la asignatura se suele realizar un viaje a una cooperativa
Esta asignatura se relaciona con varios Objetivos del Desarrollo Sostenible, en particular ODS3, ODS8, ODS12
Una parte de la asignatura podría convalidarse con créditos sujetos al proyecto de Innovación EELISA, en la Comunidad ESCE (Ethics, Social Commitment and Entrepeneurship)"""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "37 horas y 20 minutos"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/23000620/2025-26/eventSchedule> ;
    schema:description "Ante la importancia creciente de la Economía Social, el objetivo de esta asignatura es aportar los principios y fundamentos en los que se basa y lograr que los alumnos entiendan el funcionamiento de las diferentes entidades de la Economía Social, interpreten el contexto socioeconómico en el que desarrollan su actividad y el papel que actualmente desempeña la Economía Social en las políticas públicas y en la creación de empleo."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/ana.velasco%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/ana.velasco%40upm.es> ;
    schema:name "Economia Social"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000620/2025-26/CB6> a ns1:Competency ;
    ns1:competencyCode "CB6" ;
    ns1:competencyDescription "Poseer y comprender conocimientos que aporten una base u oportunidad de ser originales en el desarrollo y/o aplicación de ideas, a menudo en un contexto de investigación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000620/2025-26/CB7> a ns1:Competency ;
    ns1:competencyCode "CB7" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en entornos nuevos o poco conocidos dentro de contextos más amplios (o multidisciplinares) relacionados con su área de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000620/2025-26/CB8> a ns1:Competency ;
    ns1:competencyCode "CB8" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de integrar conocimientos y enfrentarse a la complejidad de formular juicios a partir de una información que, siendo incompleta o limitada, incluya reflexiones sobre las responsabilidades sociales y éticas vinculadas a la aplicación de sus conocimientos y juicios"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000620/2025-26/CB9> a ns1:Competency ;
    ns1:competencyCode "CB9" ;
    ns1:competencyDescription "Que los estudiantes sepan comunicar sus conclusiones y los conocimientos y razones últimas que las sustentan a públicos especializados y no especializados de un modo claro y sin ambigüedades"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000620/2025-26/CT4> a ns1:Competency ;
    ns1:competencyCode "CT4" ;
    ns1:competencyDescription "Capacidad para trabajar de forma efectiva como individuo, organizando y planificando su propio trabajo, de forma independiente o como miembro de un equipo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000620/2025-26/CT5> a ns1:Competency ;
    ns1:competencyCode "CT5" ;
    ns1:competencyDescription "Capacidad para gestionar la información, identificando las fuentes necesarias, los principales tipos de documentos técnicos y científicos, de una manera adecuada y eficiente"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000620/2025-26/CT6> a ns1:Competency ;
    ns1:competencyCode "CT6" ;
    ns1:competencyDescription "Capacidad para emitir juicios sobre implicaciones económicas, administrativas, sociales, éticas y medioambientales ligadas a la aplicación de sus conocimientos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000620/2025-26/RA38> a ns1:LearningResult ;
    ns1:learningResultCode "RA38" ;
    ns1:learningResultDescription "Entender funcionamiento y parámetros de desempeño de las diferentes entidades de la Economía Social, así como a interpretar adecuadamente el contexto socioeconómico en que estas entidades desarrollan su actividad."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000620/2025-26/RA46> a ns1:LearningResult ;
    ns1:learningResultCode "RA46" ;
    ns1:learningResultDescription "Interpretar y contextualizar el papel de la economía social en las políticas públicas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000620/2025-26/RA8> a ns1:LearningResult ;
    ns1:learningResultCode "RA8" ;
    ns1:learningResultDescription "Producir, comprender y utilizar estratégicamente información para la investigación social."@es .

