<https://guia-kg.skai.etsisi.upm.es/resource/23000620/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/23000620/2025-26/CB6>,
        <https://guia-kg.skai.etsisi.upm.es/resource/23000620/2025-26/CB7>,
        <https://guia-kg.skai.etsisi.upm.es/resource/23000620/2025-26/CB8>,
        <https://guia-kg.skai.etsisi.upm.es/resource/23000620/2025-26/CB9>,
        <https://guia-kg.skai.etsisi.upm.es/resource/23000620/2025-26/CT4>,
        <https://guia-kg.skai.etsisi.upm.es/resource/23000620/2025-26/CT5>,
        <https://guia-kg.skai.etsisi.upm.es/resource/23000620/2025-26/CT6> ;
