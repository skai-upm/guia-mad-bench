    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/143005021/2025-26/eventSchedule> ;
    schema:description """La asignatura tiene por objetivo instruir al alumno sobre la investigación de seguridad operacional, empezando por la investigación de accidentes e incidentes y los sistemas de notificación de sucesos, pero haciendo énfasis en los sistemas proactivos y predictivos de análisis de datos. Se describirán los principales métodos y herramientas de análisis de la información de seguridad operacional.
Se introducirá la capacidad de relacionar diferentes aspectos de la gestión ATM e interralacionar la operación de aeronaves con la seguridad operacional"""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/daniel.sanchez%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/daniel.sanchez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/josefelix.alonso%40upm.es> ;
    schema:name "Investigacion de Seguridad Operacional: Analisis de Sucesos e Informacion de Seguridad"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005021/2025-26/CE5> a ns1:Competency ;
    ns1:competencyCode "CE5" ;
    ns1:competencyDescription "Comprender principios, requisitos , criterios y métodos para la gestión de la seguridad operacional en el sistema del transporte aéreo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005021/2025-26/CE6> a ns1:Competency ;
    ns1:competencyCode "CE6" ;
    ns1:competencyDescription "Interpretar y valorar la normativa y de aplicación en el ámbito de la seguridad operacional"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005021/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Integrar conocimientos y enfrentarse a la complejidad de formular juicios a partir de una información que, siendo incompleta o limitada, incluya reflexiones sobre las responsabilidades sociales y éticas que puedan estar vinculadas a la aplicación de sus conocimientos y juicios en el marco correspondiente a los Sistemas del Transporte Aéreo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005021/2025-26/CG4> a ns1:Competency ;
    ns1:competencyCode "CG4" ;
    ns1:competencyDescription "Comunicar sus conclusiones y los conocimientos y razones últimas que las sustentan a públicos especializados, y no especializados de un modo claro y sin ambigüedades"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005021/2025-26/CG6> a ns1:Competency ;
    ns1:competencyCode "CG6" ;
    ns1:competencyDescription "Que los estudiantes posean las habilidades de aprendizaje que les permitan continuar estudiando de un modo que habrá de ser en gran medida autodirigido o autónomo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005021/2025-26/CT4> a ns1:Competency ;
    ns1:competencyCode "CT4" ;
    ns1:competencyDescription "Analizar implicaciones económicas, administrativas, sociales o medioambientales ligadas a la aplicación de nuevos conceptos y técnicas en el Sistema del Transporte Aéreo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005021/2025-26/RA129> a ns1:LearningResult ;
    ns1:learningResultCode "RA129" ;
    ns1:learningResultDescription "Mediante casos prácticos, el objetivo de la asignatura es que el alumno aprenda a aplicar los fundamentos y métodos cuantitativos del análisis de riesgos en el ámbito de la seguridad operacional"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005021/2025-26/RA20> a ns1:LearningResult ;
    ns1:learningResultCode "RA20" ;
    ns1:learningResultDescription "El alumno conoce las técnicas de toma de decisión con incertidumbre y riesgo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005021/2025-26/RA29> a ns1:LearningResult ;
    ns1:learningResultCode "RA29" ;
    ns1:learningResultDescription "Conocimiento y comprensión de la normativa aplicable en materia de seguridad y protección de la aviación civil"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005021/2025-26/RA30> a ns1:LearningResult ;
    ns1:learningResultCode "RA30" ;
    ns1:learningResultDescription "Conocimiento, comprensión y síntesis de la aplicación de los principios de diseño y aplicación de tecnologías y procedimientos para garantizar la seguridad del transporte aéreo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005021/2025-26/RA39> a ns1:LearningResult ;
    ns1:learningResultCode "RA39" ;
    ns1:learningResultDescription "Comprensión de la necesidad de la evolución del Sistema de Navegación Aérea"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005021/2025-26/RA44> a ns1:LearningResult ;
    ns1:learningResultCode "RA44" ;
    ns1:learningResultDescription "Identifica el sistema regulador básico en materia de Seguridad Operacional"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005021/2025-26/RA65> a ns1:LearningResult ;
    ns1:learningResultCode "RA65" ;
    ns1:learningResultDescription "El alumno conoce y comprende las metodologías para la realización de análisis de seguridad"@es .

