    schema:name "Fundamentos de Programacion"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000215/2025-26/CG04> a ns1:Competency ;
    ns1:competencyCode "CG04" ;
    ns1:competencyDescription "Conocimiento de los fundamentos del uso y programación de los computadores, los sistemas operativos, las bases de datos y, en general, los programas informáticos con aplicación en ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000215/2025-26/CT2> a ns1:Competency ;
    ns1:competencyCode "CT2" ;
    ns1:competencyDescription "Resolución de problemas: Identificar, analizar y definir los elementos significativos que constituyen un problema para resolverlo con criterio y de forma efectiva."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000215/2025-26/CT7> a ns1:Competency ;
    ns1:competencyCode "CT7" ;
    ns1:competencyDescription "Aprendizaje autónomo: El estudiante debe responsabilizarse de su propio aprendizaje, lo que le lleva a utilizar procesos cognitivos de forma estratégica y flexible, en función del objetivo de aprendizaje"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000215/2025-26/OB09> a ns1:Competency ;
    ns1:competencyCode "OB09" ;
    ns1:competencyDescription "Capacidad para resolver problemas con iniciativa, toma de decisiones, autonomía y creatividad. Capacidad para saber comunicar y transmitir los conocimientos, habilidades y destrezas de la profesión de Ingeniero Técnico en Informática."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000215/2025-26/RA23> a ns1:LearningResult ;
    ns1:learningResultCode "RA23" ;
    ns1:learningResultDescription "Resuelve problemas definiendo los elementos significativos que los constituyen, de manera razonada, expresando con precisión las argumentaciones necesarias y las conclusiones"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000215/2025-26/RA67> a ns1:LearningResult ;
    ns1:learningResultCode "RA67" ;
    ns1:learningResultDescription "Comprende los elementos de los lenguajes de programación de un paradigma estructurado"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000215/2025-26/RA68> a ns1:LearningResult ;
    ns1:learningResultCode "RA68" ;
    ns1:learningResultDescription "Modela y diseña soluciones atendiendo a los compromisos de eficiencia y modularidad"@es .

