<https://guia-kg.skai.etsisi.upm.es/resource/65005016/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/65005016/2025-26/C15>,
        <https://guia-kg.skai.etsisi.upm.es/resource/65005016/2025-26/CON13>,
