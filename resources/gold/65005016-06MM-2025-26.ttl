    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Definición de proyecto de ingeniería y sus partes. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65005016/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "2. Organización de un proyecto. Modelos de contratación de un proyecto. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65005016/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "3. Ingeniería básica y de detalle. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65005016/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "4. Gestión económica de un proyecto. Presupuestos y gestión de compras. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65005016/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "5. Gestión de proyectos de construcción y de montaje. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65005016/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "6. Etapas y ciclo de vida de un proyecto. La Dirección y los riesgos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65005016/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "7. Prácticas de diagramas de Gantt para control de proyectos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65005016/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "8. Prácticas de diagramas de redes de Pert. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65005016/2025-26/syllabus/8> a ns1:SyllabusItem ;
