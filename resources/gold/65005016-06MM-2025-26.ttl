        <https://guia-kg.skai.etsisi.upm.es/resource/65005016/2025-26/HAB9> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/65005016/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/65005016/2025-26/didactic_resource/2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/65005016/2025-26/didactic_resource/3> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/65005016/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/65005016/2025-26/RA139>,
        <https://guia-kg.skai.etsisi.upm.es/resource/65005016/2025-26/RA142>,
        <https://guia-kg.skai.etsisi.upm.es/resource/65005016/2025-26/RA147> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/65005016/2025-26/syllabus> ;
    ns1:inpersonHours "34 horas y 30 minutos (44.2%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation "La asignatura se relaciona con el ODS7 (Garantizar el acceso a una energía asequible, segura, sostenible y moderna), ODS8 (Promover el crecimiento económico inclusivo y sostenible, el empleo y el trabajo decente para todos) y ODS9 (Construir infraestructuras resilientes, promover la industrialización sostenible y fomentar la innovación)."@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "34 horas y 30 minutos"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/65005016/2025-26/eventSchedule> ;
    schema:description """La asignatura de ingeniería de proyectos te acerca y da conocer un proyecto de ingeniería. Conocerás los tipos de proyectos y sus modalidades de contratación. Reúne las técnicas de programación de un proyecto de ingeniería,
contemplando: los límites tiempo, coste y alcance técnico.
Adicionalmente, se contemplan las teorías de gestión y dirección técnica y económica de proyectos: contemplando la cultura, el liderazgo, los riesgos y la gestión económica y de personas.
Por último, se contemplan las técnicas prácticas de planificación temporal, diagramas habitualmente considerados Barras y Redes, así como, la práctica de la planificación financiera: costes e ingresos."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/juan.pous%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/juan.pous%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/maria.chiquito%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/marta.fernandezh%40upm.es> ;
    schema:name "Ingeniería de Proyectos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65005016/2025-26/C15> a ns1:Competency ;
    ns1:competencyCode "C15" ;
    ns1:competencyDescription "Capacidad para organizar y planificar en el ámbito de la empresa, y otras instituciones y organizaciones de proyectos y equipos humanos. TIPO: Competencias"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65005016/2025-26/CON13> a ns1:Competency ;
    ns1:competencyCode "CON13" ;
    ns1:competencyDescription "Conocer y comprender la metodología, gestión y organización de proyectos. TIPO: Conocimientos o contenidos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65005016/2025-26/HAB10> a ns1:Competency ;
    ns1:competencyCode "HAB10" ;
    ns1:competencyDescription "Poseer habilidades de aprendizaje que permitan continuar estudiando a lo largo de la vida para su adecuado desarrollo profesional. TIPO: Habilidades o destrezas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65005016/2025-26/HAB11> a ns1:Competency ;
    ns1:competencyCode "HAB11" ;
    ns1:competencyDescription "Utilizar la creatividad para resolver problemas de ingeniería. TIPO: Habilidades o destrezas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65005016/2025-26/HAB6> a ns1:Competency ;
    ns1:competencyCode "HAB6" ;
    ns1:competencyDescription "Capacidad para aplicar metodologías de estudios y evaluaciones de impacto ambiental y, en general, de tecnologías ambientales, sostenibilidad y tratamiento de residuos. TIPO: Habilidades o destrezas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65005016/2025-26/HAB7> a ns1:Competency ;
    ns1:competencyCode "HAB7" ;
    ns1:competencyDescription "Capacidad para la planificación y gestión integral de obras, mediciones, replanteos, control y seguimiento. TIPO: Habilidades o destrezas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65005016/2025-26/HAB9> a ns1:Competency ;
    ns1:competencyCode "HAB9" ;
    ns1:competencyDescription "Saber comunicar los conocimientos y conclusiones, tanto de forma oral, escrita y gráfica, a públicos especializados y no especializados de un modo claro y sin ambigüedades. TIPO: Habilidades o destrezas"@es .

