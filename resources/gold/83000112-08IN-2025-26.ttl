    ns1:learningResultDescription "Desarrollar un plan de Ingeniería de Sistemas para un proyecto realista"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/83000112/2025-26/RA41> a ns1:LearningResult ;
    ns1:learningResultCode "RA41" ;
    ns1:learningResultDescription "Aplicar algunos de los métodos y herramientas de Ingeniería de Sistemas a un proyecto realista"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/83000112/2025-26/RA42> a ns1:LearningResult ;
    ns1:learningResultCode "RA42" ;
    ns1:learningResultDescription "Juzgar la aplicabilidad de Ingeniería de Sistemas a proyectos navales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/83000112/2025-26/RA43> a ns1:LearningResult ;
