    ns1:learningResultCode "RA29" ;
    ns1:learningResultDescription "C: Capacidad de la aplicación de la Ingeniería de Sistemas a la definición de buques."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/83000112/2025-26/RA38> a ns1:LearningResult ;
    ns1:learningResultCode "RA38" ;
    ns1:learningResultDescription "Conocer en profundidad los conceptos básicos de Ingeniería de Sistemas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/83000112/2025-26/RA39> a ns1:LearningResult ;
    ns1:learningResultCode "RA39" ;
    ns1:learningResultDescription "Conocer las normas, documentos de buenas prácticas y enfoques de Ingeniería de Sistemas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/83000112/2025-26/RA40> a ns1:LearningResult ;
