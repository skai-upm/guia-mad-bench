    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/65001052/2025-26/eventSchedule> ;
    schema:description "La asignatura trata de los conocimientos básicos para el diseño de elementos de máquinas, incluyendo las transmisiones hidráulicas y los sistemas de engrase, y de las técnicas aplicadas al mantenimiento con especial atención a la medición y análisis de vibraciones."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/carlos.lopezj%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/carlos.lopezj%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/lauramaria.valle%40upm.es> ;
    schema:name "Tecnologia Mecanica y de Mantenimiento"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001052/2025-26/CG%201> a ns1:Competency ;
    ns1:competencyCode "CG 1" ;
    ns1:competencyDescription "Conocer y aplicar conocimientos de ciencias y tecnologías básicas a la práctica de la Tecnología Minera."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001052/2025-26/CG%202> a ns1:Competency ;
    ns1:competencyCode "CG 2" ;
    ns1:competencyDescription "Poseer capacidad para diseñar, analizar, calcular, proyectar, construir, mantener, conservar, explotar, desarrollar, implementar, gestionar y mejorar productos, sistemas y procesos en los distintos ámbitos de las Tecnologías Mineras, usando técnicas analíticas, computacionales o experimentales apropiadas, incluyendo la función de asesoría en estos campos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001052/2025-26/CG%203> a ns1:Competency ;
    ns1:competencyCode "CG 3" ;
    ns1:competencyDescription "Aplicar los conocimientos adquiridos para identificar, formular y resolver problemas dentro de contextos amplios y multidisciplinarios, siendo capaces de integrar conocimientos, trabajando en equipos multidisciplinares."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001052/2025-26/CG%206> a ns1:Competency ;
    ns1:competencyCode "CG 6" ;
    ns1:competencyDescription "Poseer habilidades de aprendizaje que permitan continuar estudiando a lo largo de la vida para su adecuado desarrollo profesional"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001052/2025-26/CG%207> a ns1:Competency ;
    ns1:competencyCode "CG 7" ;
    ns1:competencyDescription "Incorporar nuevas tecnologías y herramientas de la ingeniería en tecnología minera en sus actividades profesionales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001052/2025-26/CG%209> a ns1:Competency ;
    ns1:competencyCode "CG 9" ;
    ns1:competencyDescription "Organización y planificación en el ámbito de la empresa, y otras instituciones y organizaciones de proyectos y equipos humanos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001052/2025-26/F10> a ns1:Competency ;
    ns1:competencyCode "F10" ;
    ns1:competencyDescription "Comprensión y dominio de los conceptos básicos sobre las leyes generales de la mecánica y de la termodinámica y su aplicación para la resolución de los problemas propios de la ingeniería. Transferencia de calor y materia y máquinas térmicas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001052/2025-26/F11> a ns1:Competency ;
    ns1:competencyCode "F11" ;
    ns1:competencyDescription "Capacidad para conocer, comprender y utilizar los principios y tecnología de materiales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001052/2025-26/F32> a ns1:Competency ;
    ns1:competencyCode "F32" ;
    ns1:competencyDescription "Diseño, operación y mantenimiento de plantas de preparación y tratamiento de minerales, rocas industriales, rocas ornamentales y residuos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001052/2025-26/F4> a ns1:Competency ;
    ns1:competencyCode "F4" ;
    ns1:competencyDescription "Comprensión y dominio de los conceptos básicos sobre las leyes generales de la mecánica, termodinámica, campos y ondas y electromagnetismo y su aplicación para la resolución de problemas propios de la ingeniería"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001052/2025-26/RA254> a ns1:LearningResult ;
    ns1:learningResultCode "RA254" ;
    ns1:learningResultDescription "Conocimiento de resistencia de materiales y cálculo de elementos mecánicos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001052/2025-26/RA255> a ns1:LearningResult ;
    ns1:learningResultCode "RA255" ;
    ns1:learningResultDescription "Capacidad científico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001052/2025-26/RA256> a ns1:LearningResult ;
    ns1:learningResultCode "RA256" ;
    ns1:learningResultDescription "Capacidad para diseñar, redactar y planificar proyectos de instalaciones mecánicas con su mantenimiento."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001052/2025-26/RA257> a ns1:LearningResult ;
    ns1:learningResultCode "RA257" ;
    ns1:learningResultDescription "Capacidad para el mantenimiento, conservación y explotación de los proyectos, plantas e instalaciones."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001052/2025-26/RA258> a ns1:LearningResult ;
    ns1:learningResultCode "RA258" ;
    ns1:learningResultDescription "Conocer las exigencias básicas de diseño de elementos para el diagnóstico en los trabajos de mantenimiento."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001052/2025-26/RA259> a ns1:LearningResult ;
    ns1:learningResultCode "RA259" ;
    ns1:learningResultDescription "Calcular mecanismos y elementos de máquinas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001052/2025-26/RA260> a ns1:LearningResult ;
    ns1:learningResultCode "RA260" ;
    ns1:learningResultDescription "Comprender los sistemas hidráulicos y sus aplicaciones."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001052/2025-26/RA261> a ns1:LearningResult ;
    ns1:learningResultCode "RA261" ;
    ns1:learningResultDescription "Comprender los sistemas de engrase y sus aplicaciones."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001052/2025-26/RA262> a ns1:LearningResult ;
    ns1:learningResultCode "RA262" ;
    ns1:learningResultDescription "Comprender las técnicas de mantenimiento."@es .

