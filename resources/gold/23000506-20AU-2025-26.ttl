    ns1:learningResultDescription "RA79"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000506/2025-26/S4> a ns1:Competency ;
    ns1:competencyCode "S4" ;
    ns1:competencyDescription "Diseñar medidas de política agraria y de desarrollo rural analizando sus efectos.Tipo: Habilidades/ Designing agricultural policy measures and rural development strategies while analyzing their effects."@es .

