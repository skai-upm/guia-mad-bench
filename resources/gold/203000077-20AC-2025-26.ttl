    schema:numberOfCredits 8.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/203000077/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/203000077/2025-26/CE01>,
