        <https://guia-kg.skai.etsisi.upm.es/resource/203000077/2025-26/RA39> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/203000077/2025-26/syllabus> ;
    ns1:inpersonHours "112 horas (51.9%)"@es ;
    ns1:numberOfCredits 8.0 ;
    ns1:otherInformation "La asignatura se relaciona con el ODS13 (Acción por el Clima), dado que se estudian distintos sistemas de producción animal y su repercusión medioambiental, así como se diseñan programas de piensos y se formulan para alcanzar la máxima eficacia metabólica del animal, así como reducir la eliminación de nutrientes y compuestos contaminantes al medio ambiente."@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "112 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/203000077/2025-26/eventSchedule> ;
    schema:description """- Características propias en cuanto a alimentación, producción e higiene de las especies objeto de estudio.
- Interpretación de trabajos científicos, entendimiento de su importancia real y aplicación práctica.
- Resolución de problemas conceptuales relacionados con la producción y nutrición animal y aplicación de supuestos prácticos"""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/rosa.lazaro%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/david.menoyo%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/lourdes.camara%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/martina.perez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/nuria.nicodemus%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/rosa.lazaro%40upm.es> ;
    schema:name "Alimentación, Produción e Higiene en Aves y Conejos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000077/2025-26/CE01> a ns1:Competency ;
    ns1:competencyCode "CE01" ;
    ns1:competencyDescription "Adquirir unos conocimientos y unas destrezas adecuadas en producción y sanidad animal para poder plantear soluciones y resolver las problemáticas inherentes a las explotaciones ganaderas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000077/2025-26/CE02> a ns1:Competency ;
    ns1:competencyCode "CE02" ;
    ns1:competencyDescription "Aplicar conocimientos avanzados acerca de la gestión técnico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000077/2025-26/CE03> a ns1:Competency ;
    ns1:competencyCode "CE03" ;
    ns1:competencyDescription "Evaluar adecuadamente el efecto de los factores de producción y de las técnicas de manejo, sobre la productividad de los modelos y la calidad de los productos ganaderos generados."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000077/2025-26/CE04> a ns1:Competency ;
    ns1:competencyCode "CE04" ;
    ns1:competencyDescription "Diseñar nuevas estrategias para mejorar la productividad de los modelos ganaderos, optimizando la utilización de los factores de producción, afrontando adecuadamente la temática del bienestar animal y minimizando el impacto ambiental de los mencionados modelos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000077/2025-26/CE06> a ns1:Competency ;
    ns1:competencyCode "CE06" ;
    ns1:competencyDescription "Conocer toda la normativa inherente al bienestar y a la protección animal, que debe ser tenida en cuenta en los sistemas productivos, en los alojamientos ganaderos y en los estudios de investigación relacionados con la producción animal y con la sanidad animal."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000077/2025-26/RA37> a ns1:LearningResult ;
    ns1:learningResultCode "RA37" ;
    ns1:learningResultDescription "Introducir al alumno en las características propias en cuanto a alimentación, producción e higiene de las especies en estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000077/2025-26/RA39> a ns1:LearningResult ;
    ns1:learningResultCode "RA39" ;
    ns1:learningResultDescription "Desarrollar en el alumno la capacidad de razonamiento y su aplicación en la resolución de problemas con iniciativa, creatividad, metodología y razonamiento crítico, en el ámbito de la nutrición y la producción animal"@es .

