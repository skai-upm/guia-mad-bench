<https://guia-kg.skai.etsisi.upm.es/resource/55001097/2025-26/RA273> a ns1:LearningResult ;
    ns1:learningResultCode "RA273" ;
    ns1:learningResultDescription "Conocer los tratamientos más adecuados para cada aleación en función de las necesidades de servicio &#8722; Capacidad para interpretar metalográficamente estructuras de metales y aleaciones no férreas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001097/2025-26/RA278> a ns1:LearningResult ;
    ns1:learningResultCode "RA278" ;
    ns1:learningResultDescription "Será capaz de tratar térmicamente aceros al carbono e inoxidables para dotarles de propiedades diferentes."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001097/2025-26/RA284> a ns1:LearningResult ;
    ns1:learningResultCode "RA284" ;
    ns1:learningResultDescription "Capacidad de comprender y utilizar de forma práctica el efecto de las modificaciones microestructurales en las propiedades de los metales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001097/2025-26/RA285> a ns1:LearningResult ;
    ns1:learningResultCode "RA285" ;
    ns1:learningResultDescription "Capacidad de desarrollar tratamientos térmicos dentro y fuera del equilibrio termodinámico para obtener las propiedades deseadas en los metales, en función de modificaciones microestructurales diseñadas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001097/2025-26/RA290> a ns1:LearningResult ;
    ns1:learningResultCode "RA290" ;
    ns1:learningResultDescription "Posibilidades de mejorar sus propiedades de tenacidad."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001097/2025-26/RA297> a ns1:LearningResult ;
    ns1:learningResultCode "RA297" ;
    ns1:learningResultDescription "Sugerir el estado metalúrgico más conveniente para cada uso"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001097/2025-26/RA298> a ns1:LearningResult ;
