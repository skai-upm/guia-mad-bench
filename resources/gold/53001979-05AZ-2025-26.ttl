<https://guia-kg.skai.etsisi.upm.es/resource/53001979/2025-26/%28a%29> a ns1:Competency ;
    ns1:competencyCode "(a)" ;
    ns1:competencyDescription "APLICA. Habilidad para aplicar conocimientos científicos, matemáticos y tecnológicos en sistemas relacionados con la práctica de la ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001979/2025-26/%28b%29> a ns1:Competency ;
    ns1:competencyCode "(b)" ;
    ns1:competencyDescription "EXPERIMENTA. Habilidad para diseñar y realizar experimentos así como analizar e interpretar datos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001979/2025-26/%28c%29> a ns1:Competency ;
    ns1:competencyCode "(c)" ;
    ns1:competencyDescription "DISEÑA. Habilidad para diseñar un sistema, componente o proceso que alcance los requisitos deseados teniendo en cuenta restricciones realistas tales como las económicas, medioambientales, sociales, políticas, éticas, de salud y seguridad, de fabricación y de sostenibilidad."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001979/2025-26/%28d%29> a ns1:Competency ;
    ns1:competencyCode "(d)" ;
    ns1:competencyDescription "TRABAJA EN EQUIPO. Habilidad para trabajar en equipos multidisciplinares."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001979/2025-26/%28e%29> a ns1:Competency ;
    ns1:competencyCode "(e)" ;
    ns1:competencyDescription "RESUELVE. Habilidad para identificar, formular y resolver problemas de ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001979/2025-26/%28f%29> a ns1:Competency ;
    ns1:competencyCode "(f)" ;
    ns1:competencyDescription "ES RESPONSABLE. Comprensión de la responsabilidad ética y profesional."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001979/2025-26/%28g%29> a ns1:Competency ;
    ns1:competencyCode "(g)" ;
    ns1:competencyDescription "COMUNICA. Habilidad para comunicar eficazmente."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001979/2025-26/%28h%29> a ns1:Competency ;
    ns1:competencyCode "(h)" ;
    ns1:competencyDescription "ENTIENDE LOS IMPACTOS. Educación amplia necesaria para entender el impacto de las soluciones ingenieriles en un contexto social global."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001979/2025-26/%28i%29> a ns1:Competency ;
    ns1:competencyCode "(i)" ;
    ns1:competencyDescription "SE ACTUALIZA. Reconocimiento de la necesidad y la habilidad para comprometerse al aprendizaje continuo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001979/2025-26/%28j%29> a ns1:Competency ;
    ns1:competencyCode "(j)" ;
    ns1:competencyDescription "CONOCE. Conocimiento de los temas contemporáneos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001979/2025-26/%28k%29> a ns1:Competency ;
    ns1:competencyCode "(k)" ;
    ns1:competencyDescription "USA HERRAMIENTAS. Habilidad para usar las técnicas, destrezas y herramientas ingenieriles modernas necesarias para la práctica de la ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001979/2025-26/%28l%29> a ns1:Competency ;
    ns1:competencyCode "(l)" ;
    ns1:competencyDescription "ES BILINGÜE. Capacidad de trabajar en un entorno bilingüe (inglés/castellano)."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001979/2025-26/%28m%29> a ns1:Competency ;
    ns1:competencyCode "(m)" ;
    ns1:competencyDescription "PLANIFICA. Organización y planificación en el ámbito de la empresa, y otras instituciones y organizaciones de proyectos y equipos humanos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001979/2025-26/%28n%29> a ns1:Competency ;
    ns1:competencyCode "(n)" ;
    ns1:competencyDescription "IDEA. Creatividad"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001979/2025-26/CG01> a ns1:Competency ;
    ns1:competencyCode "CG01" ;
    ns1:competencyDescription "Tener conocimientos adecuados de los aspectos científicos y tecnológicos de: métodos matemáticos, analíticos y numéricos en la ingeniería, ingeniería eléctrica, ingeniería energética, ingeniería química, ingeniería mecánica, mecánica de medios continuos, electrónica industrial, automática, fabricación, materiales, métodos cuantitativos de gestión, informática industrial, urbanismo, infraestructuras, etc."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001979/2025-26/CG02> a ns1:Competency ;
    ns1:competencyCode "CG02" ;
    ns1:competencyDescription "Proyectar, calcular y diseñar productos, procesos, instalaciones y plantas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001979/2025-26/CG03> a ns1:Competency ;
    ns1:competencyCode "CG03" ;
    ns1:competencyDescription "Dirigir, planificar y supervisar equipos multidisciplinares."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001979/2025-26/CG04> a ns1:Competency ;
    ns1:competencyCode "CG04" ;
    ns1:competencyDescription "Realizar investigación, desarrollo e innovación en productos, procesos y métodos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001979/2025-26/CG05> a ns1:Competency ;
    ns1:competencyCode "CG05" ;
    ns1:competencyDescription "Realizar la planificación estratégica y aplicarla a sistemas tanto constructivos como de producción, de calidad y de gestión medioambiental."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001979/2025-26/CG06> a ns1:Competency ;
    ns1:competencyCode "CG06" ;
    ns1:competencyDescription "Gestionar técnica y económicamente proyectos, instalaciones, plantas, empresas y centros tecnológicos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001979/2025-26/CG07> a ns1:Competency ;
    ns1:competencyCode "CG07" ;
    ns1:competencyDescription "Poder ejercer funciones de dirección general, dirección técnica y dirección de proyectos I+D+i en plantas, empresas y centros tecnológicos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001979/2025-26/CG08> a ns1:Competency ;
    ns1:competencyCode "CG08" ;
    ns1:competencyDescription "Aplicar los conocimientos adquiridos y resolver problemas en entornos nuevos o poco conocidos dentro de contextos más amplios y multidisciplinares."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001979/2025-26/CG09> a ns1:Competency ;
    ns1:competencyCode "CG09" ;
    ns1:competencyDescription "Ser capaz de integrar conocimientos y enfrentarse a la complejidad de formular juicios a partir de una información que, siendo incompleta o limitada, incluya reflexiones sobre las responsabilidades sociales y éticas vinculadas a la aplicación de sus conocimientos y juicios."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001979/2025-26/CG10> a ns1:Competency ;
    ns1:competencyCode "CG10" ;
    ns1:competencyDescription "Saber comunicar las conclusiones ¿y los conocimientos y razones últimas que las sustentan ¿a públicos especializados y no especializados de un modo claro y sin ambigüedades."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001979/2025-26/CG11> a ns1:Competency ;
    ns1:competencyCode "CG11" ;
    ns1:competencyDescription "Poseer las habilidades de aprendizaje que permitan continuar estudiando de un modo autodirigido o autónomo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001979/2025-26/CG12> a ns1:Competency ;
    ns1:competencyCode "CG12" ;
    ns1:competencyDescription "Conocimiento, comprensión y capacidad para aplicar la legislación necesaria en el ejercicio de la profesión de Ingeniero Industrial."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001979/2025-26/RA116> a ns1:LearningResult ;
    ns1:learningResultCode "RA116" ;
    ns1:learningResultDescription "Identificar, analizar, e interpretar los datos del problema planteado por el profesor."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001979/2025-26/RA119> a ns1:LearningResult ;
    ns1:learningResultCode "RA119" ;
    ns1:learningResultDescription "Valoración y validación del resultado obtenido."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001979/2025-26/RA121> a ns1:LearningResult ;
    ns1:learningResultCode "RA121" ;
    ns1:learningResultDescription "Organiza la información."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001979/2025-26/RA124> a ns1:LearningResult ;
    ns1:learningResultCode "RA124" ;
    ns1:learningResultDescription "Gestiona el tiempo de la presentación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001979/2025-26/RA125> a ns1:LearningResult ;
    ns1:learningResultCode "RA125" ;
    ns1:learningResultDescription "Utiliza correctamente técnicas de comunicación oral."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001979/2025-26/RA126> a ns1:LearningResult ;
    ns1:learningResultCode "RA126" ;
    ns1:learningResultDescription "El alumno es capaz de valorar los efectos positivos y negativos de la solución a un problema de ingeniería que afectan a la sociedad, la economía y el medio ambiente."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001979/2025-26/RA127> a ns1:LearningResult ;
    ns1:learningResultCode "RA127" ;
    ns1:learningResultDescription "El alumno es capaz de organizar y dirigir su aprendizaje de forma autónoma para ampliar sus conocimientos en una materia."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001979/2025-26/RA128> a ns1:LearningResult ;
    ns1:learningResultCode "RA128" ;
    ns1:learningResultDescription "Emplean los programas o instrumentos adecuados a las necesidades sin necesidad de sugerencia por parte del profesor."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001979/2025-26/RA132> a ns1:LearningResult ;
    ns1:learningResultCode "RA132" ;
    ns1:learningResultDescription "Originalidad de los enfoques y soluciones propuestos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001979/2025-26/RA133> a ns1:LearningResult ;
    ns1:learningResultCode "RA133" ;
    ns1:learningResultDescription "Valor de los enfoques de acuerdo a su relevancia, viabilidad y efectividad"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001979/2025-26/RA225> a ns1:LearningResult ;
    ns1:learningResultCode "RA225" ;
    ns1:learningResultDescription "Conocer el contexto multidisciplinar de la ingeniería"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001979/2025-26/RA76> a ns1:LearningResult ;
    ns1:learningResultCode "RA76" ;
    ns1:learningResultDescription "diseño de un producto o servicio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001979/2025-26/RA77> a ns1:LearningResult ;
    ns1:learningResultCode "RA77" ;
    ns1:learningResultDescription "Desarrollo de múltiples soluciones a un problema"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001979/2025-26/RA78> a ns1:LearningResult ;
    ns1:learningResultCode "RA78" ;
    ns1:learningResultDescription "Empleo de herramientas informáticas específicas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001979/2025-26/RA79> a ns1:LearningResult ;
    ns1:learningResultCode "RA79" ;
    ns1:learningResultDescription "Capacidad para identificar, formular y resolver problemas de ingeniería de organización"@es .

