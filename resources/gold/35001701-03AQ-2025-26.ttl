<https://guia-kg.skai.etsisi.upm.es/resource/35001701/2025-26/syllabus> a ns1:Syllabus ;
    ns1:hasItem <https://guia-kg.skai.etsisi.upm.es/resource/35001701/2025-26/syllabus/0>,
        <https://guia-kg.skai.etsisi.upm.es/resource/35001701/2025-26/syllabus/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/35001701/2025-26/syllabus/2> .

<https://guia-kg.skai.etsisi.upm.es/resource/35001701/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Reforzar los aspectos ecológicos y energéticos, así como los relacionados con el acondicionamiento pasivo. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35001701/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "2. Sumar conocimientos constructivos y su aplicación a la arquitectura existente, a través del concepto de patrimonio. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35001701/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "3. Aplicar los conocimientos sobre la ciudad y entorno al desarrollo de proyectos de escala urbana y estudios medioambientales y sobre el paisaje. Sin subniveles"@es .

