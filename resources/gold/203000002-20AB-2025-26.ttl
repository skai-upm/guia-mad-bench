<https://guia-kg.skai.etsisi.upm.es/resource/203000002/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Tema 1. Concepto y método en economía ambiental. Externalidades ambientales y fallos de mercado. Caso práctico: Revisión de indicadores ambientales y análisis de tendencias. Hipótesis de Kuznets Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000002/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "2. Tema 2. Evaluación de políticas ambientales. Análisis coste beneficio. Caso práctico: Diseño, análisis y evaluación de programas agroambientales. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000002/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "3. Tema 3. El papel de los precios en la gestión ambiental. Caso práctico : El papel de los precios en la gestión del agua Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000002/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "4. Tema 4. Impactos económicos del cambio climático. Caso Práctico con SIG Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000002/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "5. Tema 5. Políticas de cambio climático: Adaptación. Caso Práctico Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000002/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "6. Tema 6. Políticas de cambio climático: Mitigación. Caso práctico: Curvas MACC Sin subniveles"@es .

