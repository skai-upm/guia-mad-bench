    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/203000002/2025-26/syllabus> ;
    ns1:inpersonHours "42 horas (51.9%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation "La asignatura se relaciona con los objetivos de desarrollo sostenible y, en particular, con los ODS 12, 13 y 15"@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "42 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/203000002/2025-26/eventSchedule> ;
    schema:description "La asignatura presenta y analiza las relaciones entre el medio ambiente, la economía y la sociedad. Primero se presentan las bases de la economía ambiental, se introduce el concepto de desarrollo sostenible y se realiza un análisis económico de los principales problemas ambientales. Seguidamente, se analiza como afrontar estas distintas problemáticas y se describen las principales políticas de regulación ambiental, ilustrándolas con casos de estudio relativos a los sistemas agroalimentarios. Finalmente, se analiza el impacto económico del cambio climático por ser uno de los temas medioambientales con mayores repercusiones en la actualidad y que forma parte de todas las políticas medioambientales globales.Se analizan las principales medidas de mitigación y adaptación al cambio climático."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/ana.iglesias%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/ana.iglesias%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/eva.iglesias%40upm.es> ;
    schema:name "Economía y Política Ambiental"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000002/2025-26/CB06> a ns1:Competency ;
    ns1:competencyCode "CB06" ;
    ns1:competencyDescription "Poseer y comprender conocimientos que aporten una base u oportunidad de ser originales en el desarrollo y/o aplicación de ideas, a menudo en un contexto de investigación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000002/2025-26/CB07> a ns1:Competency ;
    ns1:competencyCode "CB07" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en entornos nuevos o poco conocidos dentro de contextos más amplios (o multidisciplinares) relacionados con su área de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000002/2025-26/CB08> a ns1:Competency ;
    ns1:competencyCode "CB08" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de integrar conocimientos y enfrentarse a la complejidad de formular juicios a partir de una información que, siendo incompleta o limitada, incluya reflexiones sobre las responsabilidades sociales y éticas vinculadas a la aplicación de sus conocimientos y juicios"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000002/2025-26/CB09> a ns1:Competency ;
    ns1:competencyCode "CB09" ;
    ns1:competencyDescription "Que los estudiantes sepan comunicar sus conclusiones y los conocimientos y razones últimas que las sustentan a públicos especializados y no especializados de un modo claro y sin ambigüedades"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000002/2025-26/CB10> a ns1:Competency ;
    ns1:competencyCode "CB10" ;
    ns1:competencyDescription "Que los estudiantes posean las habilidades de aprendizaje que les permitan continuar estudiando de un modo que habrá de ser en gran medida autodirigido o autónomo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000002/2025-26/CE01> a ns1:Competency ;
    ns1:competencyCode "CE01" ;
    ns1:competencyDescription "Saber identificar la incidencia de los factores de producción y las técnicas de manejo sobre la sostenibilidad de los sistemas agrarios."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000002/2025-26/CE03> a ns1:Competency ;
    ns1:competencyCode "CE03" ;
    ns1:competencyDescription "Conocer y saber aplicar los principios económicos al diseño, análisis y evaluación de políticas ambientales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000002/2025-26/CG02> a ns1:Competency ;
    ns1:competencyCode "CG02" ;
    ns1:competencyDescription "Capacidad de integración de los resultados experimentales en modelos y herramientas de gestión."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000002/2025-26/CG03> a ns1:Competency ;
    ns1:competencyCode "CG03" ;
    ns1:competencyDescription "Capacidad para la resolución y toma de decisiones sobre la gestión sostenible de los recursos naturales en sistemas agroambientales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000002/2025-26/CG04> a ns1:Competency ;
    ns1:competencyCode "CG04" ;
    ns1:competencyDescription "Capacidad de selección y utilización de las metodologías disponibles para el estudio de sistemas agroambientales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000002/2025-26/CT01> a ns1:Competency ;
    ns1:competencyCode "CT01" ;
    ns1:competencyDescription "Capacidad para comprender los contenidos de clases magistrales, conferencias y seminarios en lengua inglesa."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000002/2025-26/CT02> a ns1:Competency ;
    ns1:competencyCode "CT02" ;
    ns1:competencyDescription "Capacidad para dinamizar y liderar equipos de trabajo multidisciplinares."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000002/2025-26/CT03> a ns1:Competency ;
    ns1:competencyCode "CT03" ;
    ns1:competencyDescription "Capacidad para adoptar soluciones creativas que satisfagan adecuadamente las diferentes necesidades planteadas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000002/2025-26/CT04> a ns1:Competency ;
    ns1:competencyCode "CT04" ;
    ns1:competencyDescription "Capacidad para trabajar de forma efectiva como individuo, organizando y planificando su propio trabajo, de forma independiente o como miembro de un equipo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000002/2025-26/CT05> a ns1:Competency ;
    ns1:competencyCode "CT05" ;
    ns1:competencyDescription "Capacidad para gestionar la información, identificando las fuentes necesarias, los principales tipos de documentos técnicos y científicos, de una manera adecuada y eficiente."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000002/2025-26/CT06> a ns1:Competency ;
    ns1:competencyCode "CT06" ;
    ns1:competencyDescription "Capacidad para emitir juicios sobre implicaciones económicas, administrativas, sociales, éticas y medioambientales ligadas a la aplicación de sus conocimientos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000002/2025-26/CT07> a ns1:Competency ;
    ns1:competencyCode "CT07" ;
    ns1:competencyDescription "Capacidad para trabajar en contextos internacionales"@es .

