<https://guia-kg.skai.etsisi.upm.es/resource/65001050/2025-26/CG%201> a ns1:Competency ;
    ns1:competencyCode "CG 1" ;
    ns1:competencyDescription "Conocer y aplicar conocimientos de ciencias y tecnologías básicas a la práctica de la Tecnología Minera."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001050/2025-26/CG%202> a ns1:Competency ;
    ns1:competencyCode "CG 2" ;
    ns1:competencyDescription "Poseer capacidad para diseñar, analizar, calcular, proyectar, construir, mantener, conservar, explotar, desarrollar, implementar, gestionar y mejorar productos, sistemas y procesos en los distintos ámbitos de las Tecnologías Mineras, usando técnicas analíticas, computacionales o experimentales apropiadas, incluyendo la función de asesoría en estos campos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001050/2025-26/CG%203> a ns1:Competency ;
    ns1:competencyCode "CG 3" ;
    ns1:competencyDescription "Aplicar los conocimientos adquiridos para identificar, formular y resolver problemas dentro de contextos amplios y multidisciplinarios, siendo capaces de integrar conocimientos, trabajando en equipos multidisciplinares."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001050/2025-26/CG%204> a ns1:Competency ;
    ns1:competencyCode "CG 4" ;
    ns1:competencyDescription "Comprender el impacto de la tecnología minera en el medio ambiente, el desarrollo sostenible de la sociedad. desarrollando la capacidad para la realización de estudios de ordenación del territorio y de los aspectos medioambientales relacionados con los proyectos, plantas e instalaciones, en su ámbito"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001050/2025-26/CG%206> a ns1:Competency ;
    ns1:competencyCode "CG 6" ;
    ns1:competencyDescription "Poseer habilidades de aprendizaje que permitan continuar estudiando a lo largo de la vida para su adecuado desarrollo profesional"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001050/2025-26/CG%207> a ns1:Competency ;
    ns1:competencyCode "CG 7" ;
    ns1:competencyDescription "Incorporar nuevas tecnologías y herramientas de la ingeniería en tecnología minera en sus actividades profesionales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001050/2025-26/F10> a ns1:Competency ;
    ns1:competencyCode "F10" ;
    ns1:competencyDescription "Comprensión y dominio de los conceptos básicos sobre las leyes generales de la mecánica y de la termodinámica y su aplicación para la resolución de los problemas propios de la ingeniería. Transferencia de calor y materia y máquinas térmicas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001050/2025-26/F37> a ns1:Competency ;
    ns1:competencyCode "F37" ;
    ns1:competencyDescription "Metalurgia y tratamiento de concentrados minerales, metales y aleaciones: Industria metalurgia férrea y no férrea, aleaciones especiales, ensayos metalotécnicos, etc"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001050/2025-26/RA221> a ns1:LearningResult ;
    ns1:learningResultCode "RA221" ;
    ns1:learningResultDescription "Capacidad para conocer, comprender y utilizar los principios de la ingeniería de materiales refractarios"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001050/2025-26/RA222> a ns1:LearningResult ;
    ns1:learningResultCode "RA222" ;
    ns1:learningResultDescription "Capacidad para el análisis y valoración de las propiedades de los materiales refractarios"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001050/2025-26/RA223> a ns1:LearningResult ;
    ns1:learningResultCode "RA223" ;
    ns1:learningResultDescription "Capacidad para diseñar y planificar proyectos de hornos y revestimientos refractarios en las principales aplicaciones metalúrgicas y siderúrgicas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001050/2025-26/RA224> a ns1:LearningResult ;
    ns1:learningResultCode "RA224" ;
    ns1:learningResultDescription "Aplicar los conocimientos económicos, de calidad y medioambientales en el diseño de hornos y revestimientos refractarios"@es .

