<https://guia-kg.skai.etsisi.upm.es/resource/145006105/2025-26/RA216> a ns1:LearningResult ;
    ns1:learningResultCode "RA216" ;
    ns1:learningResultDescription "Conocimiento y comprensión de las leyes que gobiernan el movimiento de vehículos propulsados con motores cohete; la generación de empuje y las variables de las que depende."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145006105/2025-26/RA217> a ns1:LearningResult ;
    ns1:learningResultCode "RA217" ;
    ns1:learningResultDescription "Conocimiento y comprensión del modelo ideal de los motores cohete de propulsión fluidodinámica y de la influencia de efectos reales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145006105/2025-26/RA218> a ns1:LearningResult ;
    ns1:learningResultCode "RA218" ;
    ns1:learningResultDescription "Conocimiento de los propulsantes y comprensión y del proceso de combustión de los motores cohete de propulsante sólido, líquido e híbridos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145006105/2025-26/RA219> a ns1:LearningResult ;
    ns1:learningResultCode "RA219" ;
    ns1:learningResultDescription "Conocimiento y comprensión del sistema de ionización y de aceleración de los motores cohete eléctricos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145006105/2025-26/RA220> a ns1:LearningResult ;
    ns1:learningResultCode "RA220" ;
    ns1:learningResultDescription "Conocimiento y comprensión de los sistemas de alimentación y refrigeración."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145006105/2025-26/RA221> a ns1:LearningResult ;
    ns1:learningResultCode "RA221" ;
    ns1:learningResultDescription "Capacidad de selección del motor cohete adecuado para los diferentes vehículos espaciales."@es .

