        "Mecánica de los Medios Continuos"@es ;
    schema:numberOfCredits 4.5 .

<https://guia-kg.skai.etsisi.upm.es/resource/55001086/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/55001086/2025-26/CG1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55001086/2025-26/CG5>,
