    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/615000234/2025-26/eventSchedule> ;
    schema:description """Asignatura que complementa a la de Fundamentos de Programación, reforzando el aprendizaje de ésta en base a prácticas de programación en el laboratorio y al desarrollo de un proyecto de programación con el apoyo de los profesores de la asignatura.
Los alumnos analizarán, diseñarán, codificarán, probarán y validarán el proyecto de programación propuesto."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/jorge.duenas.lerin%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/fernando.demingo%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/j.burguet%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/jorge.duenas.lerin%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/nuria.gomez.blas%40upm.es> ;
    schema:name "Taller de Programacion"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000234/2025-26/CB4> a ns1:Competency ;
    ns1:competencyCode "CB4" ;
    ns1:competencyDescription "Conocimiento de los fundamentos del uso y programación de los computadores, los sistemas operativos, las bases de datos y, en general, los programas informáticos con aplicación en ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000234/2025-26/CC7> a ns1:Competency ;
    ns1:competencyCode "CC7" ;
    ns1:competencyDescription "Conocimiento, diseño y utilización de forma eficiente los tipos y estructuras de datos más adecuados a la resolución de un problema"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000234/2025-26/CT2> a ns1:Competency ;
    ns1:competencyCode "CT2" ;
    ns1:competencyDescription "Resolución de problemas: Identificar, analizar y definir los elementos significativos que constituyen un problema para resolverlo con criterio y de forma efectiva"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000234/2025-26/RA23> a ns1:LearningResult ;
    ns1:learningResultCode "RA23" ;
    ns1:learningResultDescription "Resuelve problemas definiendo los elementos significativos que los constituyen, de manera razonada, expresando con precisión las argumentaciones necesarias y las conclusiones"@es .

