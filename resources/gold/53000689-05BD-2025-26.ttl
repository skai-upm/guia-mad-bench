    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/53000689/2025-26/eventSchedule> ;
    schema:description "This course, both at its contents and learning activities' level, is strongly linked with the EELISA community \"The Circular and Regenerative Campus\", with the Circular Campus UPM Innovation community, with the Madrid City Council's Center for Innovation in Circular Economy (CIEC Madrid) and with the UPM-Comunidad de Madrid Chair on Circular Economy. Some sessions or practical activities, such as hackatons or challenge-based sessions, could eventually take place at CIEC (C/Prat, 59; Vicálvaro, Metro San Cipriano, L9) or in other stakeholders facilities."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/ruth.carrasco%40upm.es> ;
    schema:inLanguage "Inglés/Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/ruth.carrasco%40upm.es> ;
    schema:name "Circular Supply Chains"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000689/2025-26/CB06> a ns1:Competency ;
    ns1:competencyCode "CB06" ;
    ns1:competencyDescription "Poseer y comprender conocimientos que aporten una base u oportunidad de ser originales en el desarrollo y/o aplicación de ideas, a menudo en un contexto de investigación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000689/2025-26/CE05> a ns1:Competency ;
    ns1:competencyCode "CE05" ;
    ns1:competencyDescription "Analizar y comprender las implicaciones estratégicas y el potencial disruptivo de las nuevas tecnologías digitales para las organizaciones y modelos de negocio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000689/2025-26/CE08> a ns1:Competency ;
    ns1:competencyCode "CE08" ;
    ns1:competencyDescription "Conocer y aplicar los conceptos y técnicas actuales para la gestión del área productiva y logística de las organizaciones"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000689/2025-26/CG04> a ns1:Competency ;
    ns1:competencyCode "CG04" ;
    ns1:competencyDescription "Comprender las relaciones entre la estrategia y el diseño de una organización, sus condiciones de funcionamiento y las características del entorno económico, político, normativo, social, tecnológico y medioambiental en que se desenvuelve"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000689/2025-26/CT08> a ns1:Competency ;
    ns1:competencyCode "CT08" ;
    ns1:competencyDescription "Entiende los impactos. Educación amplia necesaria para entender el impacto de las soluciones ingenieriles en un contexto social global"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000689/2025-26/CT12> a ns1:Competency ;
    ns1:competencyCode "CT12" ;
    ns1:competencyDescription "Es bilingüe. Capacidad de trabajar en un entorno bilingüe (inglés/español)"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000689/2025-26/CT14> a ns1:Competency ;
    ns1:competencyCode "CT14" ;
    ns1:competencyDescription "Idea. Creatividad"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000689/2025-26/RA22> a ns1:LearningResult ;
    ns1:learningResultCode "RA22" ;
    ns1:learningResultDescription "Diseñar y analizar la cadena de valor o red de suministro como un sistema complejo, no lineal y dinámico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000689/2025-26/RA23> a ns1:LearningResult ;
    ns1:learningResultCode "RA23" ;
    ns1:learningResultDescription "Modelar estructuras de redes de suministro complejas, identificando las actividades productivas y logísticas que la integran y las relaciones existentes entre las organizaciones"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000689/2025-26/RA24> a ns1:LearningResult ;
    ns1:learningResultCode "RA24" ;
    ns1:learningResultDescription "Identificar las alternativas estratégicas existentes para el diseño y posterior gestión de redes de suministro"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000689/2025-26/RA25> a ns1:LearningResult ;
    ns1:learningResultCode "RA25" ;
    ns1:learningResultDescription "Enumerar, seleccionar y aplicar herramientas orientadas a la gestión de riesgos en redes de suministro complejas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000689/2025-26/RA51> a ns1:LearningResult ;
    ns1:learningResultCode "RA51" ;
    ns1:learningResultDescription "Analizar y evaluar las políticas de Responsabilidad Social Corporativa desde el conocimiento de los aspectos fundamentales de la misma"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000689/2025-26/RA55> a ns1:LearningResult ;
    ns1:learningResultCode "RA55" ;
    ns1:learningResultDescription "Entender los aspectos claves del diseño de producto, su ciclo de vida, los programas de comunicación, la estrategia de precios y la promoción."@es .

