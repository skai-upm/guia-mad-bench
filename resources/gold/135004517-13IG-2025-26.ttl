<https://guia-kg.skai.etsisi.upm.es/resource/135004517/2025-26/didactic_resource/1> a ns1:DidacticResource ;
    ns1:bibliographyDescription "Se comienza la asignatura con recursos propios que progresivamente van siendo complementados por instrumentos modernos cedidos sin coste por empresas especializadas."@es ;
