<https://guia-kg.skai.etsisi.upm.es/resource/135004517> a ns1:Course ;
    ns1:courseType "Optativa"@es ;
    ns1:courseYear 4 ;
    ns1:semester "Octavo semestre"@es ;
    schema:courseCode 135004517 ;
    schema:hasCourseInstance <https://guia-kg.skai.etsisi.upm.es/resource/135004517/2025-26> ;
    schema:name "Advanced Geolocation And Mapping Equipment: Terrestrial Instruments And Drones"@en,
        "Equipos de Geolocalización y Cartográficos Avanzados: Instrumentos Terrestres y Drones"@es ;
    schema:numberOfCredits 6.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/135004517/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/135004517/2025-26/CB05> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/135004517/2025-26/didactic_resource/1> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/135004517/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/135004517/2025-26/RA520>,
        <https://guia-kg.skai.etsisi.upm.es/resource/135004517/2025-26/RA521>,
        <https://guia-kg.skai.etsisi.upm.es/resource/135004517/2025-26/RA522>,
        <https://guia-kg.skai.etsisi.upm.es/resource/135004517/2025-26/RA523>,
        <https://guia-kg.skai.etsisi.upm.es/resource/135004517/2025-26/RA524> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/135004517/2025-26/syllabus> ;
    ns1:inpersonHours "76 horas y 30 minutos (49%)"@es ;
    ns1:numberOfCredits 6.0 ;
    ns1:otherInformation """Se requiere la participación y colaboración activa de empresas externas a la Universidad presentan y permiten acceder a las últimas novedades de equipos e instrumentación topográfica que resultan una gran ayuda y complemento formativo para la impartición de la materia.
Se propone que el número mínimo de alumnos para impartir la asignatura se a de al menos 3.
Esta asignatura empieza su impartición en el séptimo semestre con un esquema bimodal definido.
Debido a que la disponibilidad de equipos por parte de las empresas puede ser modificado, se advertiría oportunamente de tal circunstancia.
En caso de un cambio en las condiciones sanitarias que obligara a un confinamiento total o parcial, habría que hacer una replanificación con las correspondientes adendas.
El numero de alumnos matriculados ha sido de dos inicialmente.
LAS COMPETENCIAS Y LOS RESULTADOS DE APRENDIZAJE DE ESTA ASIGNATURA SON CONFORMES CON LA MEMORIA VERIFICA DEL TÍTULO"""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "76 horas y 30 minutos"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/135004517/2025-26/eventSchedule> ;
    schema:description """Revisión, repaso y actualización de los elementos principales y manejo de Estaciones Totales. Material y equipamiento complementario
Tecnologías Desarrollos tecnológicos actuales en estaciones totales: Software,: sistemas de registro y tratamiento de la información. Mediciones en campo
Receptores GPS: Tipología, Clasificación , registro, tratamiento y procesado de datos de campo y manejo de equipos GNSS
Equialtímetros ; analógicos y digitales .Niveles Láser
Barredores Láser (Láser escáner): Clasificación , Registros en campo , tratamiento informático y resultados.
Drones: Normativa, condicionantes del vuelo, tipología y manejo."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/roberto.rodriguezsolano%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/alejandra.ezquerra%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/joseluis.peces%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/roberto.rodriguezsolano%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/rosario.contreras.alonso%40upm.es> ;
    schema:name "Equipos de Geolocalización y Cartográficos Avanzados: Instrumentos Terrestres y Drones"@es .

