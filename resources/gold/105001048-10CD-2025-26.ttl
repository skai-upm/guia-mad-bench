<https://guia-kg.skai.etsisi.upm.es/resource/105001048/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/105001048/2025-26/CB04>,
        <https://guia-kg.skai.etsisi.upm.es/resource/105001048/2025-26/CB05>,
