    schema:description "Esta asignatura trata de temas de Aseguramiento de la Calidad de proyectos software, Gobernanza de la TI, Seguridad de la Información y Auditoría Informática"@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/edmundo.tovar%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/edmundo.tovar%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/joseantonio.calvomanzano%40upm.es> ;
    schema:name "Evaluacion y Aseguramiento de Sistemas de Informacion"@es .

