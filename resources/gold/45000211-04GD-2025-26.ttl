    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/45000211/2025-26/eventSchedule> ;
    schema:description "El objetivo de la asignatura es introducir a los alumnos en los conceptos básicos de las finanzas en la empresa. Se estudiarán las bases en las que se sustenta la lógica de la valoración financiera y la metodología a seguir para el estudio y el análisis de cualquier operación financiera en general y de las operaciones a corto plazo y largo plazo en particular."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/samuel.carpintero%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/antoniolorenzo.lara%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/samuel.carpintero%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/vicente.alcarazc%40upm.es> ;
    schema:name "Introducción a las Finanzas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000211/2025-26/30AD.%20E10> a ns1:Competency ;
    ns1:competencyCode "30AD. E10" ;
    ns1:competencyDescription "Comprender los procesos para la gestión financiera de las empresas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000211/2025-26/30AD.%20E12> a ns1:Competency ;
    ns1:competencyCode "30AD. E12" ;
    ns1:competencyDescription "Comprender la operativa de las operaciones financieras."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000211/2025-26/30AD.%20G02> a ns1:Competency ;
    ns1:competencyCode "30AD. G02" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de planificar eficientemente los trabajos en el ámbito de la administración y dirección de empresas, priorizando las tareas a desempeñar y evaluando los recursos y el tiempo necesario para llevarlas a cabo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000211/2025-26/30AD.%20G03> a ns1:Competency ;
    ns1:competencyCode "30AD. G03" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de comunicar conocimientos y conclusiones del ámbito de la administración y dirección de empresas, tanto de forma oral como escrita, a públicos especializados y no especializados, expresándose de manera fluida y sin ambigüedades."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000211/2025-26/30AD.%20G06> a ns1:Competency ;
    ns1:competencyCode "30AD. G06" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de trabajar en equipos multidisciplinares, aplicando los conocimientos adquiridos en el ámbito de la administración y dirección de empresas, fomentando el espíritu de equipo y la coordinación en las tareas de los diversos miembros."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000211/2025-26/30AD.%20G10> a ns1:Competency ;
    ns1:competencyCode "30AD. G10" ;
    ns1:competencyDescription "Que los estudiantes adquieran un compromiso ético en su trabajo en el ámbito de la administración y dirección de empresas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000211/2025-26/RA19> a ns1:LearningResult ;
    ns1:learningResultCode "RA19" ;
    ns1:learningResultDescription "Comprender y resolver los problemas de asignación de recursos financieros que suceden en los mercados financieros"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000211/2025-26/RA226> a ns1:LearningResult ;
    ns1:learningResultCode "RA226" ;
    ns1:learningResultDescription "Ser capaz de manejar adecuadamente paquetes informáticos de gestión financiera de la empresa"@es .

