    ns1:itemIndex 32 ;
    ns1:syllabusDescription "7.1. Definición de Cónicas. Ecuaciones. Tipos de cónicas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125009005/2025-26/syllabus/33> a ns1:SyllabusItem ;
    ns1:itemIndex 33 ;
    ns1:syllabusDescription "7.2. Reducción de la ecuación general de una cónica. Invariantes de una cónica. Clasificación de las cónicas Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125009005/2025-26/syllabus/34> a ns1:SyllabusItem ;
    ns1:itemIndex 34 ;
    ns1:syllabusDescription "7.3. Cálculo de los coeficientes de la ecuación canónica de una cónica, excentricidad y parámetro de una cónica Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125009005/2025-26/syllabus/35> a ns1:SyllabusItem ;
    ns1:itemIndex 35 ;
    ns1:syllabusDescription "7.4. Determinación del centro y ejes de una cónica con centro. Determinación del vértice y eje de una parábola Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125009005/2025-26/syllabus/36> a ns1:SyllabusItem ;
    ns1:itemIndex 36 ;
    ns1:syllabusDescription "7.5. Determinación de las asíntotas de una hipérbola. Rectas tangente y normal a una cónica Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125009005/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "1.4. Coordenadas geográficas. Distancia esférica entre dos puntos Sin subniveles"@es .

