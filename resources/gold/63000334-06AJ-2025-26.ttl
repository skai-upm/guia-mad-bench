    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/63000334/2025-26/eventSchedule> ;
    schema:description """La ingeniería fluvial se convierte en una especialidad para el ingeniero geólogo muy interesante profesionalmente, muy pocos profesionales están debidamente capacitados para afrontar la actuación antrópica con el río de manera eficaz, eficiente y sostenible.
Esta asignatura te aportará todos los conocimientos necesarios para afrontar un estudio de una cuenca de un río, evaluar los efectos de las obras hidráulicas realizadas, proponer proyectos de mejora y restauración a realizar, así como sus consecuencias sobre el río.
El ingeniero fluvial participa en la elaboración de proyectos, en la construcción de los mismos, incluso en la evaluación de sus efectos y para terminar en el control y la inspección de la cuenca.
Las Confederaciones Hidrográficas de los ríos necesitan personal capacitado para sus actuaciones, control, evaluación de proyectos e inspección de cuencas. Las empresas proyectistas desean ingenieros capaces de realizar los mejores proyectos que sean admitidos y seleccionados por las administraciones licitantes. La empresas constructoras jefes de obra conocedores del medio y sus problemáticas. Por todo esto, esta asignatura es fundamental para este tipo de profesionales y le da capacidades muy útiles y diferenciadoras."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/juan.pous%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/juan.pous%40upm.es> ;
    schema:name "Hidráulica e Ingeniería Fluvial"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000334/2025-26/CB08> a ns1:Competency ;
    ns1:competencyCode "CB08" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de integrar conocimientos y enfrentarse a la complejidad de formular juicios a partir de una información que, siendo incompleta o limitada, incluya reflexiones sobre las responsabilidades sociales y éticas vinculadas a la aplicación de sus conocimientos y juicios"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000334/2025-26/CB09> a ns1:Competency ;
    ns1:competencyCode "CB09" ;
    ns1:competencyDescription "Que los estudiantes sepan comunicar sus conclusiones y los conocimientos y razones últimas que las sustentan a públicos especializados y no especializados de un modo claro y sin ambigüedades"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000334/2025-26/CB10> a ns1:Competency ;
    ns1:competencyCode "CB10" ;
    ns1:competencyDescription "Que los estudiantes posean las habilidades de aprendizaje que les permitan continuar estudiando de un modo que habrá de ser en gran medida autodirigido o autónomo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000334/2025-26/CE01> a ns1:Competency ;
    ns1:competencyCode "CE01" ;
    ns1:competencyDescription "Ser capaz de realizar la toma de datos, seleccionar los métodos geoestadísticos adecuados, interpretar y aplicar resultados, interactuando con expertos y personas ajenas a este campo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000334/2025-26/CE03> a ns1:Competency ;
    ns1:competencyCode "CE03" ;
    ns1:competencyDescription "Estar capacitado para el estudio de una cuenca hidrográfica/hidrogeológica compleja, como recurso renovable y en los agentes antrópicos que pudieran afectarlas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000334/2025-26/CE04> a ns1:Competency ;
    ns1:competencyCode "CE04" ;
    ns1:competencyDescription "Estar capacitado para realizar análisis de cuencas sedimentarias de acuerdo a la información geográfica, s.l. disponible realizando modelos de cuenca y, en su caso, analizando informes y transmitiendo conocimiento mediante diálogo con expertos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000334/2025-26/CE08> a ns1:Competency ;
    ns1:competencyCode "CE08" ;
    ns1:competencyDescription "Estar capacitado para realizar estudios desde un punto de vista de la ingeniería geológica, petrofísica, hidroquímica y recurso no renovable"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000334/2025-26/CE09> a ns1:Competency ;
    ns1:competencyCode "CE09" ;
    ns1:competencyDescription "Estar capacitado para estudiar una cuenca con objetivo de marcar directrices para la ordenación del territorio: usos y características"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000334/2025-26/CE11> a ns1:Competency ;
    ns1:competencyCode "CE11" ;
    ns1:competencyDescription "Comprender el nexo medio físico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000334/2025-26/CE12> a ns1:Competency ;
    ns1:competencyCode "CE12" ;
    ns1:competencyDescription "Capacidad de realizar un trabajo o proyecto integrando y relacionando las competencias adquiridas en las distintas asignaturas del máster, junto con la capacidad de defenderlo en público ante un grupo de personas expertas en el tema del trabajo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000334/2025-26/CG01> a ns1:Competency ;
    ns1:competencyCode "CG01" ;
    ns1:competencyDescription "Capacidad para aplicar los conocimientos teóricos y prácticos adquiridos a lo largo del Máster para resolver problemas concretos relacionados con la Ingeniería Geológica y la Geotecnia en cualquier tipo de proyectos, incluidos aquellos que presentan problemas nuevos o afectan a entornos o medios poco conocidos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000334/2025-26/CG02> a ns1:Competency ;
    ns1:competencyCode "CG02" ;
    ns1:competencyDescription "Capacidad para evaluar, diseñar, desarrollar, implementar, gestionar y mejorar productos, sistemas y procesos en los distintos ámbitos de la Ingeniería Geológica, en relación al medio físico usando técnicas analíticas, computacionales o experimentales avanzadas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000334/2025-26/CG03> a ns1:Competency ;
    ns1:competencyCode "CG03" ;
    ns1:competencyDescription "Capacidad para adquirir habilidades y predisposición para el aprendizaje autónomo o dirigido en Ingeniería Geológica que permitan la formación continua, ya sea en el ámbito de la investigación (Doctorado) o del perfeccionamiento profesional."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000334/2025-26/CG04> a ns1:Competency ;
    ns1:competencyCode "CG04" ;
    ns1:competencyDescription "Capacidad para plantear y dirigir el desarrollo de soluciones de ingeniería en entornos nuevos o poco conocidos, dentro de contextos más amplios o multidisciplinares, siendo capaces de integrar dichos conocimientos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000334/2025-26/CG05> a ns1:Competency ;
    ns1:competencyCode "CG05" ;
    ns1:competencyDescription "Capacidad para integrar conocimientos de ingeniería geológica y geotecnia y formular juicios, aún cuando la información sea limitada o incompleta."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000334/2025-26/CG06> a ns1:Competency ;
    ns1:competencyCode "CG06" ;
    ns1:competencyDescription "Capacidad técnica, de dirección y gestión de actividades y proyectos de I+D+i en el ámbito de la Ingeniería Geológica."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000334/2025-26/CT01> a ns1:Competency ;
    ns1:competencyCode "CT01" ;
    ns1:competencyDescription "Capacidad de uso de la lengua inglesa para el trabajo en contextos internacionales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000334/2025-26/CT02> a ns1:Competency ;
    ns1:competencyCode "CT02" ;
    ns1:competencyDescription "Capacidad para el trabajo en grupo y dirigir, organizar y supervisar equipos multidisciplinares"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000334/2025-26/CT03> a ns1:Competency ;
    ns1:competencyCode "CT03" ;
    ns1:competencyDescription "Creatividad, iniciativa y capacidad emprendedora."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000334/2025-26/CT04> a ns1:Competency ;
    ns1:competencyCode "CT04" ;
    ns1:competencyDescription "Capacidad para la elaboración, planificación, coordinación y gestión técnica y económica de proyectos siguiendo criterios éticos, de calidad y medioambientales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000334/2025-26/RA1> a ns1:LearningResult ;
    ns1:learningResultCode "RA1" ;
    ns1:learningResultDescription "Análisis de los conceptos aprovechamiento sostenible en la explotación de los recursos hidrogeológicos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000334/2025-26/RA10> a ns1:LearningResult ;
    ns1:learningResultCode "RA10" ;
    ns1:learningResultDescription "Conocer y aplicar las tipologías de cuencas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000334/2025-26/RA11> a ns1:LearningResult ;
