    ns1:courseType "Obligatoria"@es ;
    ns1:courseYear 3 ;
    ns1:semester "Quinto semestre"@es ;
    schema:courseCode 145005204 ;
    schema:hasCourseInstance <https://guia-kg.skai.etsisi.upm.es/resource/145005204/2025-26> ;
    schema:name "Fluid Mechanics II"@en,
        "Mecanica de Fluidos II"@es ;
    schema:numberOfCredits 6.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/145005204/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/145005204/2025-26/CE35>,
        <https://guia-kg.skai.etsisi.upm.es/resource/145005204/2025-26/CE37>,
        <https://guia-kg.skai.etsisi.upm.es/resource/145005204/2025-26/CG3>,
        <https://guia-kg.skai.etsisi.upm.es/resource/145005204/2025-26/CG9> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/145005204/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/145005204/2025-26/didactic_resource/2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/145005204/2025-26/didactic_resource/3>,
        <https://guia-kg.skai.etsisi.upm.es/resource/145005204/2025-26/didactic_resource/4>,
        <https://guia-kg.skai.etsisi.upm.es/resource/145005204/2025-26/didactic_resource/5>,
        <https://guia-kg.skai.etsisi.upm.es/resource/145005204/2025-26/didactic_resource/6> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/145005204/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/145005204/2025-26/RA186>,
        <https://guia-kg.skai.etsisi.upm.es/resource/145005204/2025-26/RA187> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/145005204/2025-26/syllabus> ;
    ns1:inpersonHours "65 horas (41.7%)"@es ;
    ns1:numberOfCredits 6.0 ;
    ns1:otherInformation """Toda la ordenación aquí recogida está supeditada al calendario laboral pendiente de publicación. También está supeditada al calendario escolar, disponibilidad de aulas, coordinación docente con otras asignaturas, etc., especialmente importante para fijar el calendario de exámenes. Los profesores y Jefatura de Estudios darán información durante el curso relativa al desarrollo del mismo y al calendario de exámenes. Dicha información prevalece y sustituye a la recogida en el presente documento. Es responsabilidad del alumno estar informado a través del profesorado, de la plataforma Moodle de la asignatura o de los órganos competentes.
En el Moodle de la asignatura se encuentran publicados los detalles pormenorizados sobre las pruebas de evaluación a realizar en la asignatura. ES RESPONSABILIDAD DEL ALUMNO LEERLOS Y ENTENDERLOS.
La asignatura se relaciona con el ODS4, ODS7 y ODS9 de los Objetivos de Desarrollo Sostenible (ODS) establecidos por Naciones Unidas."""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "65 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/145005204/2025-26/eventSchedule> ;
    schema:description "El objetivo de esta asignatura, impartida durante el primer cuatrimestre del tercer curso, es ampliar los conocimientos en mecánica de fluidos del alumno presentando temas más avanzados que los vistos durante la asignatura de \"Mecánica de Fluidos\" del segundo cuatrimestre del segundo curso. La asignatura impartida es la misma para las tres especialidades de CTA, PA y VA."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/miguel.hermanns%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/a.dominguezg%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/daniel.mruiz%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/josemiguel.perez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/miguel.hermanns%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/rafael.rebolo%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/victor.muntean%40upm.es> ;
    schema:name "Mecanica de Fluidos II"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005204/2025-26/CE35> a ns1:Competency ;
    ns1:competencyCode "CE35" ;
    ns1:competencyDescription "Conocimiento aplicado de: aerodinámica interna; teoría de la propulsión; actuaciones de aviones y de aerorreactores; ingeniería de sistemas de propulsión; mecánica y termodinámica."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005204/2025-26/CE37> a ns1:Competency ;
    ns1:competencyCode "CE37" ;
    ns1:competencyDescription "Conocimiento adecuado y aplicado a la Ingeniería de: Los fundamentos de la mecánica de fluidos que describen el flujo conducido y determinan las distribuciones de presiones y las fuerzas en la aerodinámica interna."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005204/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Capacidad para identificar y resolver problemas aplicando, con creatividad, los conocimientos adquiridos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005204/2025-26/CG9> a ns1:Competency ;
    ns1:competencyCode "CG9" ;
    ns1:competencyDescription "Razonamiento crítico y capacidad de asociación que posibiliten el aprendizaje continuo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005204/2025-26/RA186> a ns1:LearningResult ;
    ns1:learningResultCode "RA186" ;
    ns1:learningResultDescription "Capacidad para aplicarlos a las Ciencias de la Ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005204/2025-26/RA187> a ns1:LearningResult ;
    ns1:learningResultCode "RA187" ;
    ns1:learningResultDescription "Conocimiento y comprensión de los principales conceptos y técnicas de la Mecánica de Fluidos."@es .

