<https://guia-kg.skai.etsisi.upm.es/resource/203000039> a ns1:Course ;
    ns1:courseType "Obligatoria"@es ;
    ns1:courseYear 1 ;
    ns1:semester "Segundo semestre"@es ;
    schema:courseCode 203000039 ;
    schema:hasCourseInstance <https://guia-kg.skai.etsisi.upm.es/resource/203000039/2025-26> ;
    schema:name "Scientific Seminars"@en,
        "Seminarios Científicos"@es ;
    schema:numberOfCredits 3.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/203000039/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/203000039/2025-26/CE03>,
        <https://guia-kg.skai.etsisi.upm.es/resource/203000039/2025-26/CG04>,
        <https://guia-kg.skai.etsisi.upm.es/resource/203000039/2025-26/CG06>,
        <https://guia-kg.skai.etsisi.upm.es/resource/203000039/2025-26/CT08> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/203000039/2025-26/didactic_resource/1> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/203000039/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/203000039/2025-26/RA70>,
        <https://guia-kg.skai.etsisi.upm.es/resource/203000039/2025-26/RA71>,
        <https://guia-kg.skai.etsisi.upm.es/resource/203000039/2025-26/RA73>,
        <https://guia-kg.skai.etsisi.upm.es/resource/203000039/2025-26/RA74> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/203000039/2025-26/syllabus> ;
    ns1:inpersonHours "40 horas (51.3%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation "The seminar course will give a broad view about the potential applications of Computational Biology to improve human, animal and plant welfare. Because of the transversal nature of computational biology, seminars will include speakers who are experts in quite diverse areas of knowledge such as human health, crop production, ecosystem preservation, climate change, biotechnology o veterinary sciences. Thus, the content of the seminars will be related to ODS #1 (End of Poverty), #2 (Zero Hunger), #3 (Health and Welfare), #12 (Sustainable Production), #13 (Actions for climate), #14 (Marine Life), #15 (Life in Terrestrial Ecosystems)."@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "43 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/203000039/2025-26/eventSchedule> ;
    schema:description """The course aims at providing students with a general view of the areas of knowledge in which Computational Biology can be applied, both in the context of scientific research and for production of services and technological products. To achieve this goal, students will attend a series of seminars given by speakers invited by the course coordination. Speakers will be top professionals in their area of knowledge and will cover disciplines than span from medical applications of Computational Biology to bioinformatics technology applicable to the development of new marketable crop varieties.

The course contains a series of 10 seminars of 3 hours of duration. 2 hours will be devoted to the oral presentations of invites speakers and 1 hour will be for discussion of master students with the speaker."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/jesusisrael.pagan%40upm.es> ;
    schema:inLanguage "Inglés"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/jesusisrael.pagan%40upm.es> ;
    schema:name "Seminarios Científicos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000039/2025-26/CE03> a ns1:Competency ;
    ns1:competencyCode "CE03" ;
    ns1:competencyDescription "Analizar e interpretar bioinformáticamente los datos que se derivan de las tecnologías ómicas, y proponer soluciones bioinformáticas en relación a dichos datos/ Analyzing and interpreting bioinformatically data derived from ?omics technologies, and proposing bioinformatics solutions according to such data."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000039/2025-26/CG04> a ns1:Competency ;
    ns1:competencyCode "CG04" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de comunicar los fundamentos de sus líneas de trabajo en el area de la Biología Computacional, así como los resultados y conclusiones obtenidos, a públicos especializados y no especializados de un modo claro y sin ambigüedades/ Provide students with the capacity to communicate basic knowledge in the area of Computational Biology, and the results and conclusions derived from their work to specialized and general publics in an clear and unambiguous way."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000039/2025-26/CG06> a ns1:Competency ;
    ns1:competencyCode "CG06" ;
    ns1:competencyDescription "Que los estudiantes posean las habilidades de aprendizaje que les permitan continuar estudiando de un modo que habrá de ser en gran medida autodirigido o autónomo para adaptarse a la rápida evolución prevista en el área de la Biología Computacional/ Provide students with the learning abilities that allow them to study in a largely autodirected and autonomous manner so that they can adapt to the fast evolving nature of the Computational Biology field."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000039/2025-26/CT08> a ns1:Competency ;
    ns1:competencyCode "CT08" ;
    ns1:competencyDescription "Tener capacidad de análisis y síntesis para interpretar datos relevantes y abordar los problemas desde diferentes perspectivas/ To have capacity for analysis and synthesis to interpret relevant data and approach to problems from different perspectives."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000039/2025-26/RA70> a ns1:LearningResult ;
    ns1:learningResultCode "RA70" ;
    ns1:learningResultDescription "Ser capaz de comunicar a la comunidad cienti?fica, en los formatos adecuados, las hipo?tesis de trabajo y los resultados experimentales obtenidos durante el traba"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000039/2025-26/RA71> a ns1:LearningResult ;
    ns1:learningResultCode "RA71" ;
    ns1:learningResultDescription "Conocer las relaciones entre la ciencia y sus aplicaciones tecnológicas en el ámbito de la Biología Computacional"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000039/2025-26/RA73> a ns1:LearningResult ;
    ns1:learningResultCode "RA73" ;
    ns1:learningResultDescription "Conocer las principales áreas de investigación en el campo de la Biología Computacional a nivel nacional e internacional"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000039/2025-26/RA74> a ns1:LearningResult ;
    ns1:learningResultCode "RA74" ;
    ns1:learningResultDescription "Ser capaz de extraer, valorar y sintetizar la información procedente de comunicaciones científicas del campo de la Biología Computacional"@es .

