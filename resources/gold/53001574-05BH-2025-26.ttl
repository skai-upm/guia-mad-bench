    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/53001574/2025-26/eventSchedule> ;
    schema:description "El objetivo de la asignatura es dar al alumno una visión general de la disciplina de la Inteligencia Artificial, tanto histórica como en términos de las tecnologías disponibles. Se hará especial énfasis en tecnologías basadas en el conocimiento. El enfoque será práctico y centrado en los problemas y las necesidades de la automática y la robótica."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/ricardo.sanz%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/ricardo.sanz%40upm.es> ;
    schema:name "Inteligencia Artificial"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001574/2025-26/CB07> a ns1:Competency ;
    ns1:competencyCode "CB07" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en entornos nuevos o poco conocidos dentro de contextos más amplios (o multidisciplinares) relacionados con su área de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001574/2025-26/CE04> a ns1:Competency ;
    ns1:competencyCode "CE04" ;
    ns1:competencyDescription "Capacidad para aplicar técnicas de inteligencia artificial en automática"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001574/2025-26/CG03> a ns1:Competency ;
    ns1:competencyCode "CG03" ;
    ns1:competencyDescription "Aplicar los conocimientos adquiridos y resolver problemas en entornos nuevos o poco conocidos dentro de contextos más amplios y multidisciplinares"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001574/2025-26/CT04> a ns1:Competency ;
    ns1:competencyCode "CT04" ;
    ns1:competencyDescription "Trabaja en equipo. Habilidad para trabajar en equipos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001574/2025-26/CT11> a ns1:Competency ;
    ns1:competencyCode "CT11" ;
    ns1:competencyDescription "Usa herramientas. Habilidad para usar las técnicas, destrezas y herramientas ingenieriles modernas necesarias para la práctica de la ingeniería"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001574/2025-26/RA44> a ns1:LearningResult ;
    ns1:learningResultCode "RA44" ;
    ns1:learningResultDescription "El alumno debe conocer y comprender las técnicas clásicas de inteligencia artificial, de modo que pueda continuar con el aprendizaje de forma autónoma."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001574/2025-26/RA45> a ns1:LearningResult ;
    ns1:learningResultCode "RA45" ;
    ns1:learningResultDescription "El alumno debe ser capaz de realizar un planteamiento viable para la solución de un problema mediante técnicas de inteligencia artificial."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001574/2025-26/RA46> a ns1:LearningResult ;
    ns1:learningResultCode "RA46" ;
    ns1:learningResultDescription "El alumno debe ser capaz de establecer la correcta algorítmica para la solución de un problema de inteligencia artificial en el nivel de las técnicas presentadas"@es .

