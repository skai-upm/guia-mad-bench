    ns1:inpersonHours "86 horas (53.1%)"@es ;
    ns1:numberOfCredits 6.0 ;
    ns1:otherInformation """Las prácticas se realizan en dos grupos en días alternos
La semana del viaje de prácticas puede sufrir modificaciones cuando la Subdirección de Ordenación Académica cierre la programación de toda la titulación.
La comunicación con el profesorado se realizará a través del correo electrónico.
La asignatura se relaciona con los ODS 8, 9 y 12.
Las competencias y los resultados de aprendizaje de esta asignatura son conformes con la memoria Verifica del título"""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "86 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/133000220/2025-26/eventSchedule> ;
    schema:description "El objetivo de esta asignatura es proporcionar al alumno los conocimientos necesarios de la tecnología de fabricación de las diferentes industrias de primera y segunda transformación de la madera, así como los controles de producción y producto terminado de acuerdo a especificaciones reglamentarias y normativas para capacitarle para dimensionar instalaciones, y redactar, dirigir y ejecutar los correspondientes proyectos industriales."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/paloma.depalacios%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/francisco.garcia%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/luis.garcia%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/paloma.depalacios%40upm.es> ;
    schema:name "Tecnologia de las Industrias de Transformacion de la Madera"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000220/2025-26/CB06> a ns1:Competency ;
    ns1:competencyCode "CB06" ;
    ns1:competencyDescription "Poseer y comprender conocimientos que aporten una base u oportunidad de ser originales en el desarrollo y/o apl0icación de ideas, a menudo en un contexto de investigación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000220/2025-26/CB07> a ns1:Competency ;
    ns1:competencyCode "CB07" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en entornos nuevos o poco conocidos dentro de contextos más amplios (o multidisciplinares) relacionados con su área de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000220/2025-26/CB08> a ns1:Competency ;
    ns1:competencyCode "CB08" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de integrar conocimientos y enfrentarse a la complejidad de formular juicios a partir de una información que, siendo incompleta o limitada, incluya reflexiones sobre las responsabilidades sociales y éticas vinculadas a la aplicación de sus conocimientos y juicios"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000220/2025-26/CB10> a ns1:Competency ;
    ns1:competencyCode "CB10" ;
    ns1:competencyDescription "Que los estudiantes posean las habilidades de aprendizaje que les permitan continuar estudiando de un modo que habrá de ser en gran medida autodirigido o autónomo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000220/2025-26/CE%201.1> a ns1:Competency ;
    ns1:competencyCode "CE 1.1" ;
    ns1:competencyDescription "Capacidad para la redacción, dirección y ejecución de proyectos de industrias de desenrollo, aserrío y mueble y para el aprovechamiento de energías renovables"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000220/2025-26/CE%201.2> a ns1:Competency ;
    ns1:competencyCode "CE 1.2" ;
    ns1:competencyDescription "Capacidad para la redacción, dirección y ejecución de proyectos de industrias de celulosa y papel, industrias de tableros de fibras, partículas y contrachapado e industrias de destilación de la madera"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000220/2025-26/CE%201.3> a ns1:Competency ;
    ns1:competencyCode "CE 1.3" ;
    ns1:competencyDescription "Conocimientos adecuados y capacidad para proyectar y dimensionar instalaciones de industrias y productos forestales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000220/2025-26/CG%2003> a ns1:Competency ;
    ns1:competencyCode "CG 03" ;
    ns1:competencyDescription "Capacidad para proyectar, dirigir y gestionar industrias e instalaciones forestales de primera y sucesivas transformaciones."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000220/2025-26/CT01> a ns1:Competency ;
    ns1:competencyCode "CT01" ;
    ns1:competencyDescription "Habilidades de comunicación escrita y oral"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000220/2025-26/CT06> a ns1:Competency ;
    ns1:competencyCode "CT06" ;
    ns1:competencyDescription "Búsqueda bibliográfica, análisis de documentación y tratamiento de la información procedente de diversas fuentes y de su análisis y síntesis aplicándola a la resolución de problemas complejos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000220/2025-26/RA87> a ns1:LearningResult ;
    ns1:learningResultCode "RA87" ;
    ns1:learningResultDescription "Aplicar las especificaciones normativas y reglamentarias nacionales y comunitarias relativas a la aptitud del producto semielaborado y terminado."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000220/2025-26/RA88> a ns1:LearningResult ;
    ns1:learningResultCode "RA88" ;
    ns1:learningResultDescription "Diseñar y proyectar diferentes tipos industriales de aserraderos según el producto de entrada y la tecnología de fabricación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000220/2025-26/RA89> a ns1:LearningResult ;
    ns1:learningResultCode "RA89" ;
    ns1:learningResultDescription "Diseñar y proyectar la línea de fabricación para: madera laminada encolada, tableros alistonados y microlaminados (LVL), chapa por desenrollo y a la plana, tablero contrachapado, tableros de partículas, de fibras y de virutas orientadas (OSB), carpintería industrializada (puertas, ventanas y suelos de madera) y mobiliario (hogar, oficina, cocina)."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000220/2025-26/RA90> a ns1:LearningResult ;
    ns1:learningResultCode "RA90" ;
    ns1:learningResultDescription "Aplicar las redes neuronales artificiales (ANN) en la industria de la madera."@es .

