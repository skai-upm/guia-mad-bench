        <https://guia-kg.skai.etsisi.upm.es/resource/583000054/2025-26/CG%2007> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/583000054/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/583000054/2025-26/didactic_resource/2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/583000054/2025-26/didactic_resource/3> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/583000054/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/583000054/2025-26/RA24>,
        <https://guia-kg.skai.etsisi.upm.es/resource/583000054/2025-26/RA26>,
        <https://guia-kg.skai.etsisi.upm.es/resource/583000054/2025-26/RA28>,
        <https://guia-kg.skai.etsisi.upm.es/resource/583000054/2025-26/RA29>,
        <https://guia-kg.skai.etsisi.upm.es/resource/583000054/2025-26/RA31> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/583000054/2025-26/syllabus> ;
    ns1:inpersonHours "39 horas y 10 minutos (50.2%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation "La asignatura se relaciona con el ODS6, el ODS7, el ODS9, el ODS11, el ODS12, el ODS13, el ODS14 y el ODS15"@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "39 horas y 10 minutos"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/583000054/2025-26/eventSchedule> ;
    schema:description """Durante el segundo semestre académico (febrero - junio) se ofertarán una serie de seminarios, conferencias y ciclos de conferencias relacionados con la planificación y gestión de infraestructuras o con temas de formación transversales y útiles para la planficación y gestión de infraestructuras de una hora de duración
Los profesores impartirán los distintos bloques o seminarios en clase, empleando inicialmente el método expositivo. A continuación, se propondrá a los alumnos una serie de actividades relacionadas, para poner en práctica los conceptos aprendidos. Los alumnos deberán realizar las distintas actividades relacionadas con la asignatura, que servirán para su evaluación continua. En particular casos específicos para trabajar de forma individual por el estudiante, debatir y presentar en grupo, tendrán la siguiente programación:
Trabajo en aula. Entrega de documentación y presentación del Caso (90')
Trabajo del alumno en su casa o en grupo basándose en la documentación recibida y completándola con información propia."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/miriam.martinez%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/julio.soria-lara%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/manuel.romana%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/miriam.martinez%40upm.es> ;
    schema:name "Seminarios Especializados"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/583000054/2025-26/CB07> a ns1:Competency ;
    ns1:competencyCode "CB07" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en entornos nuevos o poco conocidos dentro de contextos más amplios (o multidisciplinares) relacionados con su área de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/583000054/2025-26/CB08> a ns1:Competency ;
    ns1:competencyCode "CB08" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de integrar conocimientos y enfrentarse a la complejidad de formular juicios a partir de una información que, siendo incompleta o limitada, incluya reflexiones sobre las responsabilidades sociales y éticas vinculadas a la aplicación de sus conocimientos y juicios"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/583000054/2025-26/CB09> a ns1:Competency ;
    ns1:competencyCode "CB09" ;
    ns1:competencyDescription "Que los estudiantes sepan comunicar sus conclusiones y los conocimientos y razones últimas que las sustentan a públicos especializados y no especializados de un modo claro y sin ambigüedades"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/583000054/2025-26/CE%2005> a ns1:Competency ;
    ns1:competencyCode "CE 05" ;
    ns1:competencyDescription "Capacidad para la gestión, dentro de equipos multidisciplinares, en lo relacionado a la planificación estratégica, siguiendo criterios de calidad y medioambientales, de aspectos relacionados con la dirección, coordinación y gestión técnica y económica de proyectos en todos los ámbitos de las infraestructuras"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/583000054/2025-26/CG%2001> a ns1:Competency ;
    ns1:competencyCode "CG 01" ;
    ns1:competencyDescription "Capacidad para dirigir, planificar y supervisar equipos multidisciplinares"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/583000054/2025-26/CG%2007> a ns1:Competency ;
    ns1:competencyCode "CG 07" ;
    ns1:competencyDescription "Capacidad para saber comunicar (de forma oral y escrita) las conclusiones y los conocimientos y las razones últimas que sustentan a públicos especializados y no especializados de un modo claro y sin ambigüedades"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/583000054/2025-26/RA24> a ns1:LearningResult ;
    ns1:learningResultCode "RA24" ;
    ns1:learningResultDescription "Poseer, con sentido crítico, los conocimientos de vanguardia de su especialidad"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/583000054/2025-26/RA26> a ns1:LearningResult ;
    ns1:learningResultCode "RA26" ;
    ns1:learningResultDescription "Proyectar y llevar a cabo investigaciones experimentales, interpretar datos con criterio y extraer conclusiones"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/583000054/2025-26/RA28> a ns1:LearningResult ;
    ns1:learningResultCode "RA28" ;
    ns1:learningResultDescription "Utilizar distintos métodos para comunicar sus conclusiones, de forma clara y sin ambigüedades, y el conocimiento y los fundamentos lógicos que las sustentan, a audiencias especializadas y no especializadas con el tema, en contextos nacionales e internacionales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/583000054/2025-26/RA29> a ns1:LearningResult ;
    ns1:learningResultCode "RA29" ;
    ns1:learningResultDescription "Integrar conocimientos y manejar conceptos complejos para formular juicios con información limitada o incompleta, que incluya reflexiones relativas a cuestiones técnicas y sociales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/583000054/2025-26/RA31> a ns1:LearningResult ;
    ns1:learningResultCode "RA31" ;
    ns1:learningResultDescription "Funcionar eficazmente en contextos nacionales e internacionales como miembro o líder de un equipo compuesto por miembros de distintas disciplinas y niveles, con posibilidad de utilizar herramientas de comunicación virtuales"@es .

