        <https://guia-kg.skai.etsisi.upm.es/resource/63000143/2025-26/didactic_resource/8> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/63000143/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/63000143/2025-26/RA119>,
        <https://guia-kg.skai.etsisi.upm.es/resource/63000143/2025-26/RA120>,
        <https://guia-kg.skai.etsisi.upm.es/resource/63000143/2025-26/RA149>,
        <https://guia-kg.skai.etsisi.upm.es/resource/63000143/2025-26/RA51>,
        <https://guia-kg.skai.etsisi.upm.es/resource/63000143/2025-26/RA52> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/63000143/2025-26/syllabus> ;
    ns1:inpersonHours "38 horas (48.7%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation """En esta asignatura se trabajan los siguientes Objetivos de Desarrollo Sostenible
ODS6: Garantizar la disponibilidad y la gestión sostenible del agua y el saneamiento para todos.
ODS9: Desarrollar infraestructuras resilientes, promover la industrialización inclusiva y sostenible, y fomentar la innovación.
ODS12: Garantizar las pautas de consumo y de producción sostenibles."""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "38 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/63000143/2025-26/eventSchedule> ;
    schema:description "La asignatura se compone de dos partes, una de fundamentos teóricos aplicables a la metalurgia que permita realizar balances de materia y energía y con ello la ejecución de diagramas de proceso y otra de aplicación más practica que permitirá al alumno diseñar y operar plantas metalúrgicas (hidrometalúrgicas, pirometalúrgicas y siderúrgicas)"@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/inigo.rbustinza%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/anamaria.mendez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/inigo.rbustinza%40upm.es> ;
    schema:name "Ingenieria Metalurgica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000143/2025-26/CE13> a ns1:Competency ;
    ns1:competencyCode "CE13" ;
    ns1:competencyDescription "Capacidad para planificar, diseñar y gestionar instalaciones de tratamientos de recursos minerales, plantas metalúrgicas, siderúrgicas e industrias de materiales de construcción, incluyendo materiales metálicos, cerámicos, sinterizados, refractarios y otros."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000143/2025-26/CG10> a ns1:Competency ;
    ns1:competencyCode "CG10" ;
    ns1:competencyDescription "Capacidad para planificar, diseñar y gestionar instalaciones de beneficio de recursos minerales y plantas metalúrgicas, siderúrgicas e industrias de materiales de construcción"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000143/2025-26/CG19> a ns1:Competency ;
    ns1:competencyCode "CG19" ;
    ns1:competencyDescription "Capacidad para planificar, diseñar y gestionar plantas de tratamiento de minerales metalúrgicos y siderúrgicos e instalaciones de procesado de materiales metálicos, cerámicos, sinterizados, refractarios y otros."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000143/2025-26/RA119> a ns1:LearningResult ;
    ns1:learningResultCode "RA119" ;
    ns1:learningResultDescription "Comprender la interrelación de las distintas etapas del proceso sidero"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000143/2025-26/RA120> a ns1:LearningResult ;
    ns1:learningResultCode "RA120" ;
    ns1:learningResultDescription "RA119"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000143/2025-26/RA149> a ns1:LearningResult ;
    ns1:learningResultCode "RA149" ;
    ns1:learningResultDescription "Capacidad para planificar la comercialización de productos minerales en los diferentes mercados, planificar calidades y estimar ingresos por ventas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000143/2025-26/RA51> a ns1:LearningResult ;
    ns1:learningResultCode "RA51" ;
    ns1:learningResultDescription "Comprender la interrelación de las distintas etapas del proceso siderometalúrgico en el diseño de plantas metalúrgicas y siderúrgicas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000143/2025-26/RA52> a ns1:LearningResult ;
    ns1:learningResultCode "RA52" ;
    ns1:learningResultDescription "Aplicar las técnicas de gestión alas plantas siderometalúrgicas"@es .

