    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/145001005/2025-26/eventSchedule> ;
    schema:description """Esta asignatura de carácter anual está dividida en dos partes bien diferenciadas. Temporalmente se corresponden con los dos semestres Septiembre-Enero y Febrero-Mayo. Desde un punto de vista del temario, en la primera parte el objetivo del alumnado debe ser adquirir los conocimientos fundamentales del lenguaje de programación de modo que sea capaz de implementar sus propios códigos.
La segunda parte está más enfocada en los fundamentos del cálculo numérico. Se abordaran una serie de problemas clásicos del cálculo numérico con un doble objetivo: por una parte conocer los fundamentos matemáticos de los problemas y los algoritmos de resolución empleados. Por otra parte se trabajará en la implementación de dichos algoritmos para profundizar desde un punto de vista práctico en los aspectos más relevantes de los problemas matemáticos."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/mario.zamecnik%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/mario.zamecnik%40upm.es> ;
    schema:name "Informatica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145001005/2025-26/CE03> a ns1:Competency ;
    ns1:competencyCode "CE03" ;
    ns1:competencyDescription "Conocimientos básicos sobre el uso y programación de los ordenadores, sistemas operativos, bases de datos y programas informáticos con aplicación en ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145001005/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Capacidad de Organización y de Planificación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145001005/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Capacidad para identificar y resolver problemas aplicando, con creatividad, los conocimientos adquiridos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145001005/2025-26/CG4> a ns1:Competency ;
    ns1:competencyCode "CG4" ;
    ns1:competencyDescription "Capacidad para integrarse y formar parte activa de equipos de trabajo. Trabajo en equipo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145001005/2025-26/CG6> a ns1:Competency ;
    ns1:competencyCode "CG6" ;
    ns1:competencyDescription "Uso de las Tecnologías de la Información y de las Comunicaciones"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145001005/2025-26/CG9> a ns1:Competency ;
    ns1:competencyCode "CG9" ;
    ns1:competencyDescription "Razonamiento crítico y capacidad de asociación que posibiliten el aprendizaje continuo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145001005/2025-26/RA39> a ns1:LearningResult ;
    ns1:learningResultCode "RA39" ;
    ns1:learningResultDescription "Conocimiento, comprensión, aplicación de las técnicas de programación básicas y de su uso en la resolución de los modelos numéricos de la Ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145001005/2025-26/RA40> a ns1:LearningResult ;
    ns1:learningResultCode "RA40" ;
    ns1:learningResultDescription "Conocimiento comprensión y aplicación sobre la metodología de la programación (datos y operaciones básicas, programación modular, operaciones de entrada"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145001005/2025-26/RA41> a ns1:LearningResult ;
    ns1:learningResultCode "RA41" ;
    ns1:learningResultDescription "Conocimiento básico sobre los sistemas operativos y los lenguajes de programación, orientados fundamentalmente a la formulación e implementación de métodos numéricos específicos en ingeniería."@es .

