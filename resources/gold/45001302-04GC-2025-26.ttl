    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/45001302/2025-26/eventSchedule> ;
    schema:description "La asignatura de Hidráulica e Hidrología tiene como objetivo que el alumno adquiera los conocimientos necesarios y conozca los aspectos técnicos más relevantes relativos a la hidrostática y flotación, el flujo en sistemas de conducciones en presión, el funcionamiento de las bombas hidráulicas, y el flujo en canales en lámina libre, dentro del campo de la Hidráulica. Dentro del campo de la Hidrología, la asignatura tiene como objetivo que el alumno conozca los métodos de la hidrología superficial de avenidas que son utilizados en la práctica profesional para la comprobación y dimensionamiento de las infraestructuras hidráulicas."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/luis.mediero%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/antonio.lastra%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/beatriz.delama%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/j.fernandez.fidalgo%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/jaime.garcia.palacios%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/luis.cueto%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/luis.mediero%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/sandro.andres%40upm.es> ;
    schema:name "Hidraulica e Hidrologia"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001302/2025-26/CM23.1> a ns1:Competency ;
    ns1:competencyCode "CM23.1" ;
    ns1:competencyDescription "Conocimiento de los conceptos y los aspectos técnicos vinculados a los sistemas de conducciones, tanto en presión como en lámina libre."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001302/2025-26/CM24.1> a ns1:Competency ;
    ns1:competencyCode "CM24.1" ;
    ns1:competencyDescription "Conocimiento de los conceptos básicos de hidrología superficial y subterránea"@es .

