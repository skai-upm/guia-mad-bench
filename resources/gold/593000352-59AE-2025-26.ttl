    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/593000352/2025-26/syllabus> ;
    ns1:inpersonHours "30 horas (38.5%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation ""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "45 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/593000352/2025-26/eventSchedule> ;
    schema:description """Los seminarios tienen como objetivo reforzar la adquisición de competencias y la capacidad profesional/investigadora de los estudiantes del programa
Se ofertarán diferentes seminarios, con una duración media de 10 horas lectivas, a lo largo de cada curso académico que serán impartidos por profesores del programa y por investigadores y profesionales de reconocido prestigio. Habrá dos tipos de seminarios
1.- Seminarios relacionados con las competencias generales de investigación: metodología científica, búsqueda de información, programas de financiación de la investigación, elaboración de publicaciones científicas.
2.- Seminarios más específicos, de contenido más tecnológico para dar a conocer a los estudiantes temas novedosos relacionados con la actividad profesional e investigadora del programa. Por la propia naturaleza de este tipo de seminarios, no pueden establecerse sus contenidos a priori, puesto que se modificarán curso a curso para incorporar el estado del arte en las tecnologías y líneas de investigación relacionadas con la Ingeniería Acústica."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/g.dearcas%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/g.dearcas%40upm.es> ;
    schema:name "Seminarios I"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/593000352/2025-26/CB06> a ns1:Competency ;
    ns1:competencyCode "CB06" ;
    ns1:competencyDescription "Poseer y comprender conocimientos que aporten una base u oportunidad de ser originales en el desarrollo y/o aplicación de ideas, a menudo en un contexto de investigación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/593000352/2025-26/CB07> a ns1:Competency ;
    ns1:competencyCode "CB07" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en entornos nuevos o poco conocidos dentro de contextos más amplios (o multidisciplinares) relacionados con su área de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/593000352/2025-26/CB08> a ns1:Competency ;
    ns1:competencyCode "CB08" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de integrar conocimientos y enfrentarse a la complejidad de formular juicios a partir de una información que, siendo incompleta o limitada, incluya reflexiones sobre las responsabilidades sociales y éticas vinculadas a la aplicación de sus conocimientos y juicios"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/593000352/2025-26/CB09> a ns1:Competency ;
    ns1:competencyCode "CB09" ;
    ns1:competencyDescription "Que los estudiantes sepan comunicar sus conclusiones y los conocimientos y razones últimas que las sustentan a públicos especializados y no especializados de un modo claro y sin ambigüedades"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/593000352/2025-26/CB10> a ns1:Competency ;
    ns1:competencyCode "CB10" ;
    ns1:competencyDescription "Que los estudiantes posean las habilidades de aprendizaje que les permitan continuar estudiando de un modo que habrá de ser en gran medida autodirigido o autónomo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/593000352/2025-26/CE08> a ns1:Competency ;
    ns1:competencyCode "CE08" ;
    ns1:competencyDescription "Conocimiento adecuado del concepto de empresa con actividades de I+D+i, así como organización y gestión, en el campo científico tecnológico."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/593000352/2025-26/CG01> a ns1:Competency ;
    ns1:competencyCode "CG01" ;
    ns1:competencyDescription "Conocer y aplicar conocimientos y soluciones de ingeniería acústica a los campos de la industria, la edificación, el transporte y el medio ambiente, entre otros."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/593000352/2025-26/CG02> a ns1:Competency ;
    ns1:competencyCode "CG02" ;
    ns1:competencyDescription "Analizar, evaluar y sintetizar algunas ideas nuevas y complejas de una manera crítica en la rama de la ingeniería acústica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/593000352/2025-26/CG03> a ns1:Competency ;
    ns1:competencyCode "CG03" ;
    ns1:competencyDescription "Fomentar el trabajo en entorno científico y/o tecnológico multilingüe y multidisciplinar"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/593000352/2025-26/CG05> a ns1:Competency ;
    ns1:competencyCode "CG05" ;
    ns1:competencyDescription "Preparar al alumno para la toma de decisiones y la emisión de juicios ante el estudio de casos reales presentados por el profesorado en la forma práctica, científica y profesional."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/593000352/2025-26/CG06> a ns1:Competency ;
    ns1:competencyCode "CG06" ;
    ns1:competencyDescription "Comunicar correcta y adecuadamente las conclusiones obtenidas mediante la exposición del análisis de casos prácticos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/593000352/2025-26/RA129> a ns1:LearningResult ;
    ns1:learningResultCode "RA129" ;
    ns1:learningResultDescription "Saber manejar las herramientas comumente utilizadas para buscar documentación científica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/593000352/2025-26/RA130> a ns1:LearningResult ;
    ns1:learningResultCode "RA130" ;
    ns1:learningResultDescription "Conocer los diferentes programas de investigación nacionales e internacionales así como las principales convocatorias para financiación de este tipod e actividades"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/593000352/2025-26/RA131> a ns1:LearningResult ;
    ns1:learningResultCode "RA131" ;
    ns1:learningResultDescription "Redactar publicaciones científicas e identificar posibles opciones para su publicación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/593000352/2025-26/RA132> a ns1:LearningResult ;
    ns1:learningResultCode "RA132" ;
    ns1:learningResultDescription "Concoer nuevas aplicaciones o últimas tendencias en temas relacionados con la temática del programa"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/593000352/2025-26/didactic_resource/1> a ns1:DidacticResource ;
    ns1:bibliographyDescription "En cada seminario se proporcionarán los recursos didácticos correspondientes a la temática del mismo"@es ;
    ns1:bibliographyTitle "Bibliografía"@es ;
    ns1:bibliographyType "Bibliografía"@es .

