    schema:courseCode 615000720 ;
    schema:hasCourseInstance <https://guia-kg.skai.etsisi.upm.es/resource/615000720/2025-26> ;
    schema:name "Concurrent And Advanced Programming"@en,
        "Programacion Concurrente y Avanzada"@es ;
    schema:numberOfCredits 6.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/615000720/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/615000720/2025-26/CC14>,
        <https://guia-kg.skai.etsisi.upm.es/resource/615000720/2025-26/CT07> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/615000720/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/615000720/2025-26/didactic_resource/2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/615000720/2025-26/didactic_resource/3> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/615000720/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/615000720/2025-26/RA73>,
        <https://guia-kg.skai.etsisi.upm.es/resource/615000720/2025-26/RA77> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/615000720/2025-26/syllabus> ;
    ns1:inpersonHours "73 horas (46.8%)"@es ;
    ns1:numberOfCredits 6.0 ;
    ns1:otherInformation """FORMACIÓN Y EVALUACIÓN DE LA COMPETENCIA TRANSVERSAL
Esta asignatura tiene asignada la competencia de aprendizaje autónomo. Dado que una parte importante del proceso de aprendizaje se realizará de forma autónoma (aula invertida), la susodicha competencia transversal se entiende subsumida en el actual proceso de enseñanza-aprendizaje. Por tanto, aquellos estudiantes que superen la asignatura durante la evaluación progresiva verán incrementada su calificación final en 0,5 puntos al entender que el proceso de aprendizaje autónomo ha dado sus frutos y estos estudiantes han adquirido el nivel de desempeño suficiente en la indicada competencia transversal.
Se utilizará la plataforma Moodle como repositorio compartido de información.
Con respecto a los objetivos de desarrollo sostenible de la ONU (https://bit.ly//2qk9f28) esta asignatura utiliza plataformas y lenguajes de acceso gratuito que promueven la consecución del objetivo 10. Reducción de la brecha digital."""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "73 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/615000720/2025-26/eventSchedule> ;
    schema:description "Se puede definir un \"programa concurrente\" como un conjunto de programas secuenciales que pueden ser ejecutados en paralelo. Este conjunto de programas secuenciales (o procesos) puede ser ejecutados en varios procesadores (paralelismo real) o en un solo procesador (pseudo paralelismo). En cualquiera de los dos casos, en el momento en que exista una cooperación entre dos o más procesos o existan recursos compartidos aparece la necesidad de sincronizar adecuadamente dichos procesos concurrentes para conseguir los resultados esperados. Esta asignatura se centra en la programación de sistemas, con un conocimiento amplio y profundo de mecanismos de comunicación y sincronización."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/jorgeenrique.perez%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/c.castilla%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/jorgeenrique.perez%40upm.es> ;
    schema:name "Programacion Concurrente y Avanzada"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000720/2025-26/CC14> a ns1:Competency ;
    ns1:competencyCode "CC14" ;
    ns1:competencyDescription "Conocimiento y aplicación de los principios fundamentales y técnicas básicas de la programación paralela, concurrente, distribuida y de tiempo real."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000720/2025-26/CT07> a ns1:Competency ;
    ns1:competencyCode "CT07" ;
    ns1:competencyDescription "Aprendizaje autónomo: El estudiante debe responsabilizarse de su propio aprendizaje, lo que le lleva a utilizar procesos cognitivos de forma estratégica y flexible, en función del objetivo de aprendizaje."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000720/2025-26/RA73> a ns1:LearningResult ;
    ns1:learningResultCode "RA73" ;
    ns1:learningResultDescription "Utiliza entornos y herramientas de desarrollo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000720/2025-26/RA77> a ns1:LearningResult ;
    ns1:learningResultCode "RA77" ;
    ns1:learningResultDescription "Comprende los elementos de lenguajes de programación de distintos paradigmas"@es .

