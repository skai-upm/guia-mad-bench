<https://guia-kg.skai.etsisi.upm.es/resource/305000109/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Integrales curvilíneas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000109/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Curva parametrizada. Curva rectificable: longitud de arco. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000109/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "3.2. Superficie con borde. Teorema de Stokes. Significado geométrico del operador rotacional. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000109/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "3.3. El símbolo de Levi-Civita. Fórmulas de derivación. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000109/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "3.4. Campos solenoidales, potencial vector y dominios estrellados. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000109/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "4. Integración de formas diferenciales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000109/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "4.1. Variedades parametrizadas de dimensión k en R^n. Volumen de un k-paralelepípedo en R^n. Integración de funciones escalares. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000109/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "4.2. Formas diferenciables en R^n. Derivada exterior y producto exterior. Propiedades. Acción de una aplicación diferenciable. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000109/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "4.3. Integración de formas en variedades parametrizadas de R^n. Variedades parametrizadas con borde. Orientación y orientación inducida. Teorema generalizado de Stokes. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000109/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "4.4. Homotopía y dominios simplemente conexos. Formas cerradas y exactas. Espacios contractibles. Lema de Poincaré Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000109/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Integral de campos escalares y vectoriales a lo largo de una curva. Trabajo. Campos conservativos y campos de gradientes. Potencial escalar. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000109/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "1.3. Teorema de Green. Dominios planos simplemente conexos. Existencia de potencial escalar global. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000109/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "2. Integrales de superficie."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000109/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "2.1. Superficie parametrizada. Ecuaciones implícitas de una superficie. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000109/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "2.2. El problema del área. Integral de campos escalares sobre una superficie. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000109/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "2.3. Superficie orientable. Integral de campos vectoriales sobre una superficie: flujo. Significado geométrico del operador laplaciano. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000109/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "3. Teoremas integrales clásicos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000109/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "3.1. Teorema de Gauss. Significado geométrico del operador divergencia. Sin subniveles"@es .

