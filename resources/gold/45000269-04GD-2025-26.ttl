    ns1:inpersonHours "39 horas y 45 minutos (51%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation "Por otra parte en esta asignatura se intenta trabajar el objetivo número 8 de la lista de Objetivos de crecimiento sostenible de Naciones Unidas, relativo al trabajo decente y al crecimiento económico. Para ello la asignatura trabaja el concepto de imagen fiel de la empresa y la necesidad de aportar información contable transparente y fiable que contribuya a la creación de relaciones comerciales de confianza y que contribuya a la mejor gestión de la responsabilidad social corporativa de la empresa."@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "39 horas y 45 minutos"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/45000269/2025-26/eventSchedule> ;
    schema:description "Esta asignatura \"Análisis de los estados financieros\" proporciona los conceptos y herramientas necesarios para analizar la información que emiten las empresas, a través de los estados financieros, con el fin de valorar su situación económica-financiera y su previsible evolución."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/mariabelen.munoz%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/mariabelen.munoz%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/mario.araus%40upm.es> ;
    schema:name "Análisis de Estados Financieros"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000269/2025-26/30AD.%20E01> a ns1:Competency ;
    ns1:competencyCode "30AD. E01" ;
    ns1:competencyDescription "Conocer la técnica contable en relación con la situación y los resultados de la empresa, y los flujos habidos en un período."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000269/2025-26/30AD.%20E02> a ns1:Competency ;
    ns1:competencyCode "30AD. E02" ;
    ns1:competencyDescription "Comprender el impacto de las operaciones económicas que desarrollan las empresas en su patrimonio empresarial."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000269/2025-26/30AD.%20E04> a ns1:Competency ;
    ns1:competencyCode "30AD. E04" ;
    ns1:competencyDescription "Aplicar las herramientas de análisis de la información contable."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000269/2025-26/30AD.%20E05> a ns1:Competency ;
    ns1:competencyCode "30AD. E05" ;
    ns1:competencyDescription "Comprender los métodos de consolidación contable, la contabilidad de los grupos y las operaciones de fusión, escisión y absorción."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000269/2025-26/30AD.%20E10> a ns1:Competency ;
    ns1:competencyCode "30AD. E10" ;
    ns1:competencyDescription "Comprender los procesos para la gestión financiera de las empresas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000269/2025-26/30AD.%20E12> a ns1:Competency ;
    ns1:competencyCode "30AD. E12" ;
    ns1:competencyDescription "Comprender la operativa de las operaciones financieras."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000269/2025-26/30AD.%20G01> a ns1:Competency ;
    ns1:competencyCode "30AD. G01" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de comprender, interpretar, sintetizar y evaluar de forma crítica información proveniente de fuentes diversas en el ámbito de la administración y dirección de empresas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000269/2025-26/30AD.%20G02> a ns1:Competency ;
    ns1:competencyCode "30AD. G02" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de planificar eficientemente los trabajos en el ámbito de la administración y dirección de empresas, priorizando las tareas a desempeñar y evaluando los recursos y el tiempo necesario para llevarlas a cabo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000269/2025-26/30AD.%20G05> a ns1:Competency ;
    ns1:competencyCode "30AD. G05" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de aportar soluciones creativas en la resolución de problemas en el ámbito de la administración y dirección de empresas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000269/2025-26/30AD.%20G10> a ns1:Competency ;
    ns1:competencyCode "30AD. G10" ;
    ns1:competencyDescription "Que los estudiantes adquieran un compromiso ético en su trabajo en el ámbito de la administración y dirección de empresas."@es .

