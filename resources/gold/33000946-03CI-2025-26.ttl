    ns1:otherInformation "El curso estará especialmente informado, además de por el profesorado, por los diversos industriales invitados. Esta información será de gran valor, junto con las visitas a las fábricas y a las obras que se realicen durante el curso."@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
