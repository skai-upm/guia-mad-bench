<https://guia-kg.skai.etsisi.upm.es/resource/105000156/2025-26/Ce%2022> a ns1:Competency ;
    ns1:competencyCode "Ce 22" ;
    ns1:competencyDescription "Capacidad de aplicar sus conocimientos e intuición para diseñar el hardware/software que cumple unos requisitos especificados."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000156/2025-26/Ce%2025> a ns1:Competency ;
    ns1:competencyCode "Ce 25" ;
    ns1:competencyDescription "Concebir y diseñar la arquitectura de un sistema software."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000156/2025-26/Ce%2026/27> a ns1:Competency ;
    ns1:competencyCode "Ce 26/27" ;
    ns1:competencyDescription "Definir, evaluar y seleccionar plataformas hardware y software, incluyendo el sistema operativo, y concebir, llevar a cabo, instalar y mantener arquitecturas informáticas centralizadas o distribuidas integrando hardware, software y redes."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000156/2025-26/Ce%207> a ns1:Competency ;
    ns1:competencyCode "Ce 7" ;
    ns1:competencyDescription "Entender el soporte físico (hardware) de los ordenadores desde el punto de vista del soporte lógico (software), por ejemplo, el uso del procesador, de la memoria, de los discos, del monitor, etc."@es .

