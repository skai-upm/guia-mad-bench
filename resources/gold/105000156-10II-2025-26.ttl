    ns1:learningResultCode "RA308" ;
    ns1:learningResultDescription "Realizar el diseño arquitectónico de aplicaciones utilizando eficientemente los servicios de un sistema operativo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000156/2025-26/RA309> a ns1:LearningResult ;
