<https://guia-kg.skai.etsisi.upm.es/resource/105000106/2025-26/C1> a ns1:Competency ;
    ns1:competencyCode "C1" ;
    ns1:competencyDescription "Capacidad de resolución de problemas aplicando conocimientos de matemáticas, ciencias e ingeniería. TIPO: Competencias."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000106/2025-26/C13> a ns1:Competency ;
    ns1:competencyCode "C13" ;
    ns1:competencyDescription "Capacidad de elegir y usar los métodos analíticos y de modelización relevantes, y de describir una solución de forma abstracta. TIPO: Competencias."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000106/2025-26/C3> a ns1:Competency ;
    ns1:competencyCode "C3" ;
    ns1:competencyDescription "Saber trabajar en situaciones carentes de información y bajo presión, teniendo nuevas ideas, siendo creativo. TIPO: Competencias."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000106/2025-26/C5> a ns1:Competency ;
    ns1:competencyCode "C5" ;
    ns1:competencyDescription "Capacidad de abstracción, análisis y síntesis. TIPO: Competencias."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000106/2025-26/K1> a ns1:Competency ;
    ns1:competencyCode "K1" ;
    ns1:competencyDescription "Comprender y utilizar el lenguaje matemático. Conocer demostraciones de teoremas clásicos. Comprender las definiciones de objetos matemáticos. TIPO: Conocimientos o contenidos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000106/2025-26/RA138> a ns1:LearningResult ;
    ns1:learningResultCode "RA138" ;
    ns1:learningResultDescription "Conocer la topología usual de Rn, hallar límites de funciones y sumas de series de funciones y series de potencias. Estudiar la convergencia de series de potencias y desarrollar funciones en series de potencias."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000106/2025-26/RA139> a ns1:LearningResult ;
    ns1:learningResultCode "RA139" ;
    ns1:learningResultDescription "Saber calcular derivadas parciales y direccionales, y entender el concepto de diferencial y sus implicaciones, así como las condiciones suficientes de diferenciabilidad. Aplicar los conceptos anteriores al cálculo de direcciones de máximo crecimiento, cálculo de errores, optimización, multiplicadores de Lagrange, etc., y utilizar estos métodos en problemas aplicados."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000106/2025-26/RA140> a ns1:LearningResult ;
    ns1:learningResultCode "RA140" ;
    ns1:learningResultDescription "Estudiar funciones de varias variables, calcular su dominio, representarlas gráficamente a través de curvas de nivel y calcular límites, conociendo sus peculiaridades dependiendo de las direcciones de aproximación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000106/2025-26/RA19> a ns1:LearningResult ;
    ns1:learningResultCode "RA19" ;
    ns1:learningResultDescription "Modelizar matemáticamente problemas reales y conocer las técnicas para resolverlos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000106/2025-26/RA202> a ns1:LearningResult ;
    ns1:learningResultCode "RA202" ;
    ns1:learningResultDescription "Los resultados del aprendizaje correspondientes a esta asignatura han quedado definidos en el apartado de competencias de este documento, señalando los que corresponden a conocimientos, habilidades y competencias propiamente dichas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000106/2025-26/RA47> a ns1:LearningResult ;
    ns1:learningResultCode "RA47" ;
    ns1:learningResultDescription "Ser capaz de demostrar teoremas mediante lógica matemática."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000106/2025-26/S1> a ns1:Competency ;
    ns1:competencyCode "S1" ;
    ns1:competencyDescription "Plantear nuevas definiciones. Poder enunciar resultados y construir demostraciones, detectar errores en ellas o encontrar contraejemplos. TIPO: Habilidades o destrezas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000106/2025-26/S2> a ns1:Competency ;
    ns1:competencyCode "S2" ;
    ns1:competencyDescription "Ser capaz de extraer de un objeto matemático aquellas propiedades fundamentales que lo caracterizan, distinguiéndolas de aquellas otras ocasionales compartidas con otros objetos matemáticos. TIPO: Habilidades o destrezas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000106/2025-26/S3> a ns1:Competency ;
    ns1:competencyCode "S3" ;
    ns1:competencyDescription "Ser capaz de plantear modelos matemáticos para problemas reales, utilizando para resolverlos las herramientas necesarias, interpretando la solución en los mismos términos en que estaba planteado el problema. TIPO: Habilidades o destrezas."@es .

