    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/135003056/2025-26/syllabus> ;
    ns1:inpersonHours "51 horas y 30 minutos (49.5%)"@es ;
    ns1:numberOfCredits 4.0 ;
    ns1:otherInformation """LAS COMPETENCIAS Y LOS RESULTADOS DE APRENDIZAJE DE ESTA ASIGNATURA SON CONFORMES CON LA MEMORIA VERIFICA DEL TÍTULO
Esta asignatura está relacionada con Objetivo 15 de Desarrollo sostenible (ODS15): Gestionar sosteniblemente los bosques, luchar contra la desertificación, detener e invertir la degradación de las tierras, detener la pérdida de biodiversidad"""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "51 horas y 30 minutos"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/135003056/2025-26/eventSchedule> ;
    schema:description "La asignatura busca proporcionar a los alumnos capacidades que le permitan evaluar el riesgo de incendios de un territorio, conocer las técnicas de prevención y lucha contra incendios forestales para poder determinar las medidas preventivas mas adecuadas a ese territorio. El alumno también tiene que desarrollar capacidades para la determinación de la inversión optima, que minimice los daños provocados por los incendios forestales con los gastos de prevención y extinción."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/javier.gonzalezr%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/javier.gonzalezr%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/javier.madrigal%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/ruben.laina%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/yolanda.ambrosio%40upm.es> ;
    schema:name "Incendios Forestales"@es .

