    schema:name "Advanced Methods In Biomedical Images"@en,
        "Temas Avanzados de Imágenes Biomédicas-Ii"@es ;
    schema:numberOfCredits 3.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/93000977/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/93000977/2025-26/CB07>,
