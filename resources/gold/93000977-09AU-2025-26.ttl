        <https://guia-kg.skai.etsisi.upm.es/resource/93000977/2025-26/didactic_resource/4> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/93000977/2025-26/evaluation> ;
