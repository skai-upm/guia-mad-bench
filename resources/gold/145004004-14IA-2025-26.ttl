    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/145004004/2025-26/eventSchedule> ;
    schema:description """En esta asignatura se introducen conceptos relacionados con los siguientes campos del transporte aéreo:
- Estructura y los elementos que conforman el actual sistema de transporte mundial.
- Inserción del modo aéreo en el sistema de transporte y las distintas formas de cooperación y competencia intermodales.
- Beneficios económicos y sociales del transporte aéreo.
- Marco legal del transporte aéreo y sistema regulatorio internacional.
- Elementos que integran el sistema de transportes: compañías aéreas, fabricantes, aeropuertos, proveedores de servicios de navegación aérea.
- Situación del transporte aéreo en la actualidad, tanto en España como en el resto del mundo."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/j.cubas%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/elena.roibas%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/francisco.fernandezb%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/gustavo.alonso%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/j.cubas%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/jm.herrero.borrell%40upm.es> ;
    schema:name "Transporte Aereo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145004004/2025-26/CE14> a ns1:Competency ;
    ns1:competencyCode "CE14" ;
    ns1:competencyDescription "Comprender el sistema de transporte aéreo y la coordinación con otros modos de transporte"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145004004/2025-26/CE19> a ns1:Competency ;
    ns1:competencyCode "CE19" ;
    ns1:competencyDescription "Conocimiento aplicado de: la ciencia y tecnología de los materiales; mecánica y termodinámica; mecánica de fluidos; aerodinámica y mecánica del vuelo; sistemas de navegación y circulación aérea; tecnología aeroespacial; teoría de estructuras; transporte aéreo; economía y producción; proyectos; impacto ambiental."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145004004/2025-26/CG8> a ns1:Competency ;
    ns1:competencyCode "CG8" ;
    ns1:competencyDescription "Capacidad de integrar el respeto al medio ambiente en el desarrollo de sus actividades"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145004004/2025-26/RA128> a ns1:LearningResult ;
    ns1:learningResultCode "RA128" ;
    ns1:learningResultDescription "Conocimiento de la estructura y los elementos que conforman el actual sistema de transporte mundial."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145004004/2025-26/RA129> a ns1:LearningResult ;
    ns1:learningResultCode "RA129" ;
    ns1:learningResultDescription "Conocimiento de la manera en la que el modo aéreo se inserta en el sistema de transporte y las distintas formas de cooperación y competencia intermodales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145004004/2025-26/RA130> a ns1:LearningResult ;
    ns1:learningResultCode "RA130" ;
    ns1:learningResultDescription "Conocimiento los beneficios económicos y sociales del transporte aéreo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145004004/2025-26/RA131> a ns1:LearningResult ;
    ns1:learningResultCode "RA131" ;
    ns1:learningResultDescription "Comprensión de las características legales del transporte aéreo y conocimiento del sistema regulatorio internacional de este modo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145004004/2025-26/RA132> a ns1:LearningResult ;
    ns1:learningResultCode "RA132" ;
    ns1:learningResultDescription "Conocimiento de los diferentes elementos que integran el sistema de transportes: compañías aéreas, fabricantes, aeropuertos, proveedores de servicios de navegación aérea."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145004004/2025-26/RA133> a ns1:LearningResult ;
    ns1:learningResultCode "RA133" ;
    ns1:learningResultDescription "Comprender los aspectos más importantes de la situación del transporte aéreo en la actualidad, tanto en España como en el resto del mundo."@es .

