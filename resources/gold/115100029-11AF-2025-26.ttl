    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/115100029/2025-26/eventSchedule> ;
    schema:description """Tiene como objetivo principal proporcionar al alumnado un conjunto sólido de conocimientos y competencias esenciales para mejorar la labor profesional en el ámbito del entrenamiento deportivo y el acondicionamiento físico.
Los estudiantes aprenderán las bases, técnicas y estrategias de entrenamiento adaptadas a diversas necesidades y contextos. Se fomentará una perspectiva integradora y aplicada que permita a los estudiantes desarrollar competencias, asegurando que puedan implementar prácticas de entrenamiento efectivas y basadas en evidencia. Asimismo, se proporcionará una visión crítica que capacitará a los alumnos para seleccionar y adaptar metodologías específicas, con el fin de maximizar los resultados en los distintos ámbitos de actuación."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/daniel.mon%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/c.gsanchez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/daniel.mon%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/jesus.olivan%40upm.es> ;
    schema:name "Metodología del Entrenamiento Deportivo y Acondicionamiento Físico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100029/2025-26/CE07> a ns1:Competency ;
    ns1:competencyCode "CE07" ;
    ns1:competencyDescription "Planificar, desarrollar y evaluar la realización de programas y procesos de entrenamiento deportivo en sus distintos niveles. Nivel 3."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100029/2025-26/CE09> a ns1:Competency ;
    ns1:competencyCode "CE09" ;
    ns1:competencyDescription "Identificar y prevenir los riesgos que se derivan para la salud de los deportistas por la práctica de actividades físicas inadecuadas, en el contexto del entrenamiento deportivo. Nivel 2."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100029/2025-26/CG02> a ns1:Competency ;
    ns1:competencyCode "CG02" ;
    ns1:competencyDescription "Desarrollar habilidades y estrategias que incidan en la capacidad para trabajar en forma autónoma."@es .

