    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/203000064/2025-26/syllabus> ;
    ns1:inpersonHours "18 horas (46.2%)"@es ;
    ns1:numberOfCredits 1.5 ;
    ns1:otherInformation "La asignatura está relacionada con el ODS2 (hambre cero) y ODS 3 (salud y bienestar) ya que en ella se plantea la metodología de investigación tanto en experimentos de producción ganadera como en sanidad."@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "21 horas y 10 minutos"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/203000064/2025-26/eventSchedule> ;
    schema:description "La asignatura trata de dar una visión general de la metodología usada en trabajos de investigación en producción y sanidad animal. Se les propone a los estudiantes un acercamiento al método científico a través del análisis de artículos científicos y de la estructura de los TFM. Los estudiantes de la especialidad investigadora, previsiblemente crearán ciencia, y los de la especialidad profesional utilizarán la información científica para solventar los problemas a los que se enfrenten en su trabajo en una empresa o institución. Se dedica también un tema a la ética en investigación y bioética porque creemos que es vital su compromiso como profesionales en este tema."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/mariajesus.villamide%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/mariajesus.villamide%40upm.es> ;
    schema:name "Introducción a la Investigación en Producción y Sanidad Animal"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000064/2025-26/CE05> a ns1:Competency ;
    ns1:competencyCode "CE05" ;
    ns1:competencyDescription "Dominar los aspectos éticos, legales, medioambientales y los protocolos de bioseguridad, que deben cumplir las empresas pecuarias y los trabajos experimentales realizados en producción animal y en sanidad animal."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000064/2025-26/CE07> a ns1:Competency ;
    ns1:competencyCode "CE07" ;
    ns1:competencyDescription "Plantear y desarrollar un trabajo de investigación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000064/2025-26/CE08> a ns1:Competency ;
    ns1:competencyCode "CE08" ;
    ns1:competencyDescription "Conocer las metodologías de investigación disponibles en la producción animal y en la sanidad animal."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000064/2025-26/CE09> a ns1:Competency ;
    ns1:competencyCode "CE09" ;
    ns1:competencyDescription "Saber utilizar las herramientas y técnicas bioinformáticas más actuales a la investigación en producción animal y en sanidad animal."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000064/2025-26/CG02> a ns1:Competency ;
    ns1:competencyCode "CG02" ;
    ns1:competencyDescription "Ampliar y aprender, de forma autónoma e interdisciplinar, conceptos avanzados y nuevos conceptos, además de métodos, relacionados con la producción animal y con la sanidad animal."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000064/2025-26/CG05> a ns1:Competency ;
    ns1:competencyCode "CG05" ;
    ns1:competencyDescription "Capacidad de concebir, diseñar o crear, poner en práctica y adoptar un proceso sustancial de investigación o creación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000064/2025-26/CT01> a ns1:Competency ;
    ns1:competencyCode "CT01" ;
    ns1:competencyDescription "Analizar y sintetizar la información disponible y/o los resultados obtenidos, en un trabajo de investigación, en el ámbito que aquí compete."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000064/2025-26/CT02> a ns1:Competency ;
    ns1:competencyCode "CT02" ;
    ns1:competencyDescription "Adoptar el proceso marcado por el método científico en el planteamiento y en la realización de trabajos de investigación y/o profesionales diversos, fomentando el espíritu crítico."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000064/2025-26/CT03> a ns1:Competency ;
    ns1:competencyCode "CT03" ;
    ns1:competencyDescription "Observar y generar hipótesis, para plantear diseños de investigación adecuados."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000064/2025-26/CT05> a ns1:Competency ;
    ns1:competencyCode "CT05" ;
    ns1:competencyDescription "Capacidad para utilizar, con fluidez, un buen lenguaje técnico y científico, tanto oral como escrito, en el ámbito de la sanidad y de la producción animal, siendo riguroso en las explicaciones de cualquier proceso y/o en la divulgación de los resultados de la investigación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000064/2025-26/CT06> a ns1:Competency ;
    ns1:competencyCode "CT06" ;
    ns1:competencyDescription "Seleccionar y manejar adecuadamente la bibliografía y la búsqueda de referencias en el área de la producción y la sanidad animal."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000064/2025-26/RA10> a ns1:LearningResult ;
