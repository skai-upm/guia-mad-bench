<https://guia-kg.skai.etsisi.upm.es/resource/203000064/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. UT 1 Introducción a la investigación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000064/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Tema 1: Objetivos de la asignatura. Estructura de los artículos científicos y de los TFM Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000064/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "2.2.2. Estudios de eficacia y seguridad: desarrollo de vacunas Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000064/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "3. UT 3 Etica en investigación y profesional"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000064/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "3.1. Tema 6: Ética en investigación. Derechos y responsabilidades del investigador y becarios. Autoría. Conflicto de intereses Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000064/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "3.2. Tema 7: Bioética en investigación. La responsabilidad del investigador. Prevención del dolor y sufrimiento. Manipulación genética, problema ético Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000064/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Tema 2: Recursos de la información. Fuentes, clasificación, tipos y soportes. Bases de datos y gestores informáticos. Implicaciones en la evaluación de la calidad científica. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000064/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "1.3. Tema 3: Planteamiento de hipótesis. Objetivos de la investigación. Estudio de los antecedentes. Revisión bibliográfica Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000064/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "2. UT 2 Metodología en experimentación animal"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000064/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "2.1. Tema 4: Metodología de experimentación en Producción Animal."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000064/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "2.1.1. Diseño de pruebas experimentales en trabajos de investigación. Rendimientos productivos y digestibilidad Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000064/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "2.1.2. Pruebas de Registro en la UE y pruebas de campo. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000064/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "2.2. Tema 5: Metodología de experimentación en sanidad animal."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000064/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "2.2.1. Diseños experimentales para estudios de patogenia Sin subniveles"@es .

