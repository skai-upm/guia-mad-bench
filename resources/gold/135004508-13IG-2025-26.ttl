    ns1:inpersonHours "62 horas y 30 minutos (48.1%)"@es ;
    ns1:numberOfCredits 5.0 ;
    ns1:otherInformation """Sólo se publicarán las soluciones de los ejercicios de cálculo de los exámenes parciales y no las cuestiones de teoría y razonamiento.
Las competencias y los resultados de aprendizaje de esta asignatura son conformes con la memoria verifica del título"""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "62 horas y 30 minutos"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/135004508/2025-26/eventSchedule> ;
    schema:description """Para un titulado de Grado de Ingeniería Forestal de la especialidad de Industrias, los objetivos de esta asignatura son:
1. Estimar las pérdidas por transmisión de calor en un recinto industrial
2.- Calcular y pre-dimensionar algunos componentes de las instalaciones de producción de calor, calefacción y secado
3.- Calcular y pre-dimensionar algunos componentes de las instalaciones de refrigeración industrial
4.- Calcular y pre-dimensionar el sistema de captación solar de instalaciones de energía solar térmica de baja temperatura"""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/c.pascual%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/c.pascual%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/francisco.marcos%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/m.quintanilla%40upm.es> ;
    schema:name "Instalaciones Termicas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004508/2025-26/CE%202.9> a ns1:Competency ;
    ns1:competencyCode "CE 2.9" ;
    ns1:competencyDescription "Capacidad para conocer, comprender y urilizar los principios de: Maquinaria y Mecanización Forestales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004508/2025-26/CG09> a ns1:Competency ;
    ns1:competencyCode "CG09" ;
    ns1:competencyDescription "Conocimientos de hidráulica, construcción, electrificación, caminos forestales, maquinaria y mecanización necesarios tanto para la gestión de los sistemas forestales como para su conservación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004508/2025-26/CT4> a ns1:Competency ;
    ns1:competencyCode "CT4" ;
    ns1:competencyDescription "Análisis y Síntesis. Esta capacidad permite afrontar y conocer más profundamente realidades complejas, simplificar su descripción, descubrir relaciones aparentemente ocultas y construir nuevos conocimientos a partir de otros que ya se posean."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004508/2025-26/CT8> a ns1:Competency ;
    ns1:competencyCode "CT8" ;
    ns1:competencyDescription "Creatividad y capacidad de observación, generación de hipótesis y planteamiento de problemas experimentales."@es .

