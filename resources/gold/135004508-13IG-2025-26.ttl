<https://guia-kg.skai.etsisi.upm.es/resource/135004508/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Conducción y convección de calor"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004508/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Concepto. Ley de Fourier. El coeficiente de conductividad térmica k: propiedades y unidades Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004508/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "4. Centrales térmicas de vapor."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004508/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "4.1. Ciclo de Rankine. Ciclos con recalentamiento y sobrecalentamiento. Ciclos con intercambiador abierto y cerrado. Turbinas. Potencia. Rendimientos. Gasto de combustible Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004508/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "5. Calderas y Chimeneas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004508/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "5.1. Componentes principales de las calderas. Clasificación. Combustión. Calderas de biomasa. Balance térmico y rendimiento de una caldera. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004508/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "5.2. Ventilación. Chimeneas de tipo natural y forzado Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004508/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "6. Intercambiadores de calor."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004508/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "6.1. Tipos. Coeficiente de transferencia de calor total. Factor de incrustación. Análisis de los intercambiadores de calor. Método de la diferencia de temperatura media logarítmica Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004508/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "6.2. Intercambiadores a contracorriente. Intercambiadores de pasos múltiples y de flujo cruzado. Método de la efectividad. Selección de los intercambiadores de calor Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004508/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "7. Instalaciones de producción de frío"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004508/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "7.1. Máquina frigorífica. Ciclo inverso de Rankine. Bomba de calor. Diagramas. Instalaciones ideales y reales. Ciclos frigoríficos de compresión mecánica. Simple. Múltiple directa. Múltiple indirecta. Rendimientos Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004508/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Modelo matricial de transmisión de calor. Ecuación general de transmisión de calor para sólidos isotrópicos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004508/2025-26/syllabus/20> a ns1:SyllabusItem ;
    ns1:itemIndex 20 ;
    ns1:syllabusDescription "7.2. Cálculo de la carga frigorífica. Cálculo de las dimensiones principales del compresor. Cálculo del Condensador. Cálculo del evaporador. Válvula de expansión. Tipos y clasificación de los fluidos frigoríficos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004508/2025-26/syllabus/21> a ns1:SyllabusItem ;
    ns1:itemIndex 21 ;
    ns1:syllabusDescription "8. Energía solar"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004508/2025-26/syllabus/22> a ns1:SyllabusItem ;
    ns1:itemIndex 22 ;
    ns1:syllabusDescription "8.1. Energía solar térmica: tipos. La radiación solar. Cálculo de la radiación solar incidente en una superficie inclinada Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004508/2025-26/syllabus/23> a ns1:SyllabusItem ;
    ns1:itemIndex 23 ;
    ns1:syllabusDescription "8.2. Colectores solares. Concepto. Tipos de colectores solares. Colectores solares planos. Colectores solares concentradores Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004508/2025-26/syllabus/24> a ns1:SyllabusItem ;
    ns1:itemIndex 24 ;
    ns1:syllabusDescription "8.3. Energía solar termoeléctrica. Concepto. Tipos. Centrales solares con colectores cilindroparabólicos. Concepto. Descripción. Uso. Centrales solares de torre. Concepto. Descripción. Uso. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004508/2025-26/syllabus/25> a ns1:SyllabusItem ;
    ns1:itemIndex 25 ;
    ns1:syllabusDescription "8.4. Dimensionamiento del sistema de captación de una instalación de energía solar térmica Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004508/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "1.3. Problemas de conducción de calor. Caso del muro múltiple. Caso de los materiales porosos. Caso del tubo circular. Caso del tubo prismático. Caso de la esfera. El coeficiente k de los productos leñosos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004508/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "1.4. Convección de calor. Concepto. Tipos de convección. Ley de desplazamiento de Newton. Números adimensionales utilizados en convección de calor para obtener el coeficiente h Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004508/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "2. Radiación de calor"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004508/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "2.1. Concepto. Comparación con conducción y convección. Ley de Planck. Ley de Stefan Boltzmann . Ley de desplazamiento de Wien. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004508/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "2.2. Conceptos de reflectancia, tramitancia y absortancia. El efecto invernadero Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004508/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "3. - Propiedades de las sustancias puras"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004508/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "3.1. Superficies p-v-T para sustancias puras. Zona de vapor húmedo. Título y volumen específico. Entropía y entalpía específicas. Calor de transformación. Tablas y diagramas. Sin subniveles"@es .

