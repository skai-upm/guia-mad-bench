        <https://guia-kg.skai.etsisi.upm.es/resource/53001361/2025-26/RA23>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001361/2025-26/RA24>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001361/2025-26/RA25> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/53001361/2025-26/syllabus> ;
    ns1:inpersonHours "42 horas (35.9%)"@es ;
    ns1:numberOfCredits 4.5 ;
    ns1:otherInformation "La asignatura se relaciona con el ODS3, el ODS9 y el ODS12"@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "42 horas"@es ;
    schema:activitiesWorkload "110%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/53001361/2025-26/eventSchedule> ;
    schema:description """Objetivo
El objetivo es tener los conocimientos básicos en las áreas de Seguridad de procesos así como en Higiene y Salud laboral.
Breve descripción del contenido
La asignatura tiene dos partes diferenciadas, la parte de seguridad de procesos incluye mecanismos de protección, análisis de riesgos, técnicas de reducción de riesgos, capas de protección, etc. La parte de higiene y salud laboral incluye manejo, almacenamiento y riesgos de sustancias peligrosas, prevención de riesgos y condiciones laborales seguras."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/manuel.rodriguezh%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/manuel.rodriguezh%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/vm.perdices%40upm.es> ;
    schema:name "Seguridad de Procesos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001361/2025-26/CG2> a ns1:Competency ;
    ns1:competencyCode "CG2" ;
    ns1:competencyDescription "Concebir, proyectar, calcular, y diseñar procesos, equipos, instalaciones industriales y servicios, en el ámbito de la ingeniería química y sectores industriales relacionados, en términos de calidad, seguridad, economía, uso racional y eficiente de los recursos naturales y conservación del medio ambiente."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001361/2025-26/CG6> a ns1:Competency ;
    ns1:competencyCode "CG6" ;
    ns1:competencyDescription "Tener capacidad de análisis y síntesis para el progreso continuo de productos, procesos, sistemas y servicios utilizando criterios de seguridad, viabilidad económica, calidad y gestión medioambiental"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001361/2025-26/RA22> a ns1:LearningResult ;
    ns1:learningResultCode "RA22" ;
    ns1:learningResultDescription "Conocimiento de sustancias peligrosas, transporte y almacenamiento."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001361/2025-26/RA23> a ns1:LearningResult ;
    ns1:learningResultCode "RA23" ;
    ns1:learningResultDescription "Conocimiento de las estrategias de seguridad en plantas de proceso."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001361/2025-26/RA24> a ns1:LearningResult ;
    ns1:learningResultCode "RA24" ;
    ns1:learningResultDescription "Realización de análisis de riesgos en plantas químicas y estimación de las consecuencias de accidentes."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001361/2025-26/RA25> a ns1:LearningResult ;
    ns1:learningResultCode "RA25" ;
    ns1:learningResultDescription "Capacidad de analizar accidentes"@es .

