    ns1:otherInformation "El curso 25/26 es el primero año en que se imparte esta asignatura. El cronograma y las indicaciones que figuran en esta guía son orientativas y pueden ser modificadas por el profesorado durante el curso en función de las necesidades docentes y de las necesidades de cada actividad de evaluación."@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
