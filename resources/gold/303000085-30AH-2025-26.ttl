    ns1:bibliographyTitle "Programas en Python"@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000085/2025-26/didactic_resource/4> a ns1:DidacticResource ;
