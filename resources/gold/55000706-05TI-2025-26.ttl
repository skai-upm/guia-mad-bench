<https://guia-kg.skai.etsisi.upm.es/resource/55000706> a ns1:Course ;
    ns1:courseType "Optativa"@es ;
    ns1:courseYear 4 ;
    ns1:semester "Séptimo semestre"@es ;
    schema:courseCode 55000706 ;
    schema:hasCourseInstance <https://guia-kg.skai.etsisi.upm.es/resource/55000706/2025-26> ;
    schema:name "Chemical Processes Fundamentals"@en,
        "Principios de los Procesos Quimicos"@es ;
    schema:numberOfCredits 3.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/55000706/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/55000706/2025-26/CE21G>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55000706/2025-26/CG1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55000706/2025-26/CG3>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55000706/2025-26/CG4>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55000706/2025-26/CG7> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/55000706/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55000706/2025-26/didactic_resource/2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55000706/2025-26/didactic_resource/3> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/55000706/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/55000706/2025-26/RA382>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55000706/2025-26/RA383> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/55000706/2025-26/syllabus> ;
    ns1:inpersonHours "30 horas (38.5%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation """A lo largo de esta asignatura se potenciarán las competencias y capacidades de los Ingenieros Químicos relacionadas con el diseño de procesos químicos que permitan una producción y consumo de materias primas y energía responsable.
En concreto, la asignatura se relaciona con el ODS 9 "Industria, innovación e infraestructuras" y el ODS 12 "Producción y consumo responsables"."""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "34 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/55000706/2025-26/eventSchedule> ;
    schema:description ""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/salvador.leon%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/salvador.leon%40upm.es> ;
    schema:name "Principios de los Procesos Quimicos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000706/2025-26/CE21G> a ns1:Competency ;
    ns1:competencyCode "CE21G" ;
    ns1:competencyDescription "Conocimientos sobre balances de materia y energía, biotecnología, transferencia de materia, operaciones de separación, ingeniería de la reacción química, diseño de reactores, y valoración y transformación de materias primas y recursos energéticos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000706/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Conocer y aplicar conocimientos de ciencias y tecnologías básicas a la práctica de la Ingeniería Industrial."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000706/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Aplicar los conocimientos adquiridos para identificar, formular y resolver problemas dentro de contextos amplios y multidisciplinarios, siendo capaces de integrar conocimientos, trabajando en equipos multidisciplinares."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000706/2025-26/CG4> a ns1:Competency ;
    ns1:competencyCode "CG4" ;
    ns1:competencyDescription "Comprender el impacto de la ingeniería industrial en el medio ambiente, el desarrollo sostenible de la sociedad y la importancia de trabajar en un entorno profesional y responsable."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000706/2025-26/CG7> a ns1:Competency ;
    ns1:competencyCode "CG7" ;
    ns1:competencyDescription "Incorporar nuevas tecnologías y herramientas de la Ingeniería Industrial en sus actividades profesionales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000706/2025-26/RA382> a ns1:LearningResult ;
    ns1:learningResultCode "RA382" ;
    ns1:learningResultDescription "Análisis integral de procesos químicos y sus eficiencias globales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000706/2025-26/RA383> a ns1:LearningResult ;
    ns1:learningResultCode "RA383" ;
    ns1:learningResultDescription "Información de balances de materia y energía para el diseño básico de operaciones básicas en una planta química."@es .

