        "Geomatica Minera"@es ;
    schema:numberOfCredits 3.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/65001048/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/65001048/2025-26/CG%201>,
        <https://guia-kg.skai.etsisi.upm.es/resource/65001048/2025-26/CG%202>,
        <https://guia-kg.skai.etsisi.upm.es/resource/65001048/2025-26/CG%203>,
        <https://guia-kg.skai.etsisi.upm.es/resource/65001048/2025-26/CG%204>,
        <https://guia-kg.skai.etsisi.upm.es/resource/65001048/2025-26/CG%205>,
        <https://guia-kg.skai.etsisi.upm.es/resource/65001048/2025-26/CG%206>,
        <https://guia-kg.skai.etsisi.upm.es/resource/65001048/2025-26/CG%207>,
        <https://guia-kg.skai.etsisi.upm.es/resource/65001048/2025-26/CG%209> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/65001048/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/65001048/2025-26/didactic_resource/2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/65001048/2025-26/didactic_resource/3> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/65001048/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/65001048/2025-26/RA243>,
        <https://guia-kg.skai.etsisi.upm.es/resource/65001048/2025-26/RA244>,
        <https://guia-kg.skai.etsisi.upm.es/resource/65001048/2025-26/RA245>,
        <https://guia-kg.skai.etsisi.upm.es/resource/65001048/2025-26/RA246> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/65001048/2025-26/syllabus> ;
    ns1:inpersonHours "35 horas (44.9%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation """La asignatura es eminentemente práctica. En el caso de que las circunstancias lo permitan, el desarrollo de la misma tiene lugar en una explotación minera, realizando distintas operaciones de captura y análisis de información topográfica, cartográfica y fotogramétrica necesaria en las distintas labores a realizar dentro de la mina.
Toda la planificación prevista en la presente guía puede ser susceptible de modificación debida a motivos normativos o circunstanciales ajenos a los agentes que intervienen en la docencia, tales como medidas tomadas por las autoridades sanitarias, imprevistos en la planificación docente de asignaturas concurrentes con esta, condiciones meteorológicas que impidan el desarrollo de las actividades planificadas en campo, o cualquier otra imprevisto."""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "35 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/65001048/2025-26/eventSchedule> ;
    schema:description """1.- Introducción a la Geomática Minera
2.- Instrumentos topográficos utilizados en minería
3.- Métodos topográficos utilizados en minería
4.- Fotogrametría - SfM"""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/luis.iglesias%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/luis.iglesias%40upm.es> ;
    schema:name "Geomatica Minera"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001048/2025-26/CG%201> a ns1:Competency ;
    ns1:competencyCode "CG 1" ;
    ns1:competencyDescription "Conocer y aplicar conocimientos de ciencias y tecnologías básicas a la práctica de la Tecnología Minera."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001048/2025-26/CG%202> a ns1:Competency ;
    ns1:competencyCode "CG 2" ;
    ns1:competencyDescription "Poseer capacidad para diseñar, analizar, calcular, proyectar, construir, mantener, conservar, explotar, desarrollar, implementar, gestionar y mejorar productos, sistemas y procesos en los distintos ámbitos de las Tecnologías Mineras, usando técnicas analíticas, computacionales o experimentales apropiadas, incluyendo la función de asesoría en estos campos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001048/2025-26/CG%203> a ns1:Competency ;
    ns1:competencyCode "CG 3" ;
    ns1:competencyDescription "Aplicar los conocimientos adquiridos para identificar, formular y resolver problemas dentro de contextos amplios y multidisciplinarios, siendo capaces de integrar conocimientos, trabajando en equipos multidisciplinares."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001048/2025-26/CG%204> a ns1:Competency ;
    ns1:competencyCode "CG 4" ;
    ns1:competencyDescription "Comprender el impacto de la tecnología minera en el medio ambiente, el desarrollo sostenible de la sociedad. desarrollando la capacidad para la realización de estudios de ordenación del territorio y de los aspectos medioambientales relacionados con los proyectos, plantas e instalaciones, en su ámbito"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001048/2025-26/CG%205> a ns1:Competency ;
    ns1:competencyCode "CG 5" ;
    ns1:competencyDescription "Saber comunicar los conocimientos y conclusiones, tanto de forma oral, escrita y gráfica, a públicos especializados y no especializados de un modo claro y sin ambigüedades."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001048/2025-26/CG%206> a ns1:Competency ;
    ns1:competencyCode "CG 6" ;
    ns1:competencyDescription "Poseer habilidades de aprendizaje que permitan continuar estudiando a lo largo de la vida para su adecuado desarrollo profesional"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001048/2025-26/CG%207> a ns1:Competency ;
    ns1:competencyCode "CG 7" ;
    ns1:competencyDescription "Incorporar nuevas tecnologías y herramientas de la ingeniería en tecnología minera en sus actividades profesionales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001048/2025-26/CG%209> a ns1:Competency ;
    ns1:competencyCode "CG 9" ;
    ns1:competencyDescription "Organización y planificación en el ámbito de la empresa, y otras instituciones y organizaciones de proyectos y equipos humanos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001048/2025-26/RA243> a ns1:LearningResult ;
    ns1:learningResultCode "RA243" ;
    ns1:learningResultDescription "Adquirir los conocimientos teóricos y prácticos sobre topografía subterránea."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001048/2025-26/RA244> a ns1:LearningResult ;
    ns1:learningResultCode "RA244" ;
    ns1:learningResultDescription "Conocer e interpretar los planos que se utilizan en los planes de labores y en el desarrollo de la explotación minera."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001048/2025-26/RA245> a ns1:LearningResult ;
    ns1:learningResultCode "RA245" ;
    ns1:learningResultDescription "Conocer como se realizan los deslindes de permisos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001048/2025-26/RA246> a ns1:LearningResult ;
    ns1:learningResultCode "RA246" ;
    ns1:learningResultDescription "Conocer los métodos de seguimiento y cubicación de labores mineras."@es .

