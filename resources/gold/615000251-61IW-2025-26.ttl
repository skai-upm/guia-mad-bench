    ns1:inpersonHours "58 horas y 40 minutos (37.6%)"@es ;
    ns1:numberOfCredits 6.0 ;
    ns1:otherInformation "Esta asignatura contribuye al Objetivo de Desarrollo Sostenible 4 (ODS 4) de Educación de Calidad que consiste en \"garantizar una educación inclusiva, equitativa y de calidad y promover las oportunidades de aprendizaje durante toda la vida para todos\" promoviendo la educación pública como universidad en general y la educación inclusiva y equitativa promoviendo el trabajo en equipo y realizando prácticas en la que se promueve la calidad del desarrollo y los proyectos y por ende del aprendizaje de los estudiantes."@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "58 horas y 40 minutos"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/615000251/2025-26/eventSchedule> ;
    schema:description "La asignatura tiene como objetivo global dotar al estudiante de los conocimientos fundamentales, teóricos y prácticos de procesos de desarrollo software para la construcción de software. Además, la asignatura tiene como objetivo que el estudiante sea capaz de poner en práctica alguno de los procesos de desarrollo software más representativos, empleando de técnicas y herramientas avanzadas para el desarrollo software."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/jenifer.perez%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/gema.borgaz%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/jenifer.perez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/mariasoledad.delgado%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/vanessa.rodriguez.horcajo%40upm.es> ;
    schema:name "Ingenieria del Proceso Software y Construccion"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000251/2025-26/CC16> a ns1:Competency ;
    ns1:competencyCode "CC16" ;
    ns1:competencyDescription "Conocimiento y aplicación de los principios, metodologías y ciclos de vida de la ingeniería de software"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000251/2025-26/CC8> a ns1:Competency ;
    ns1:competencyCode "CC8" ;
    ns1:competencyDescription "Capacidad para analizar, diseñar, construir y mantener aplicaciones de forma robusta, segura y eficiente, eligiendo el paradigma y los lenguajes de programación más adecuados."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000251/2025-26/CE1> a ns1:Competency ;
    ns1:competencyCode "CE1" ;
    ns1:competencyDescription "Capacidad para desarrollar, mantener y evaluar servicios y sistemas software que satisfagan todos los requisitos del usuario y se comporten de forma fiable y eficiente, sean asequibles de desarrollar y mantener y cumplan normas de calidad, aplicando las teorías, principios, métodos prácticas de la Ingeniería del Software."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000251/2025-26/CE4> a ns1:Competency ;
    ns1:competencyCode "CE4" ;
    ns1:competencyDescription "Capacidad de identificar y analizar problemas y diseñar, desarrollar, implementar, verificar y documentar soluciones software sobre la base de un conocimiento adecuado de las teorías, modelos y técnicas actuales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000251/2025-26/CT11> a ns1:Competency ;
    ns1:competencyCode "CT11" ;
    ns1:competencyDescription "Liderazgo: Cualidades, actitudes, conocimientos y destrezas que posee un individuo, desenvolviéndose de modo que logra inspirar, generar confianza y credibilidad en un grupo de colaboradores, además del compromiso para el logro de la visión corporativa a través de sinergias, motivaciones y compromisos, y no de manera coercitiva e individualista."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000251/2025-26/CT8> a ns1:Competency ;
    ns1:competencyCode "CT8" ;
    ns1:competencyDescription "Trabajo en equipo: Ser capaz de trabajar como miembro de un equipo interdisciplinar con la finalidad de contribuir a desarrollar proyectos con pragmatismo y sentido de la responsabilidad, asumiendo compromisos teniendo en cuenta los recursos disponibles."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000251/2025-26/RA105> a ns1:LearningResult ;
    ns1:learningResultCode "RA105" ;
    ns1:learningResultDescription "Identifica y analiza problemas para solventar soluciones software sobre la base de un conocimiento adecuado de teorías, modelos y técnicas actuales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000251/2025-26/RA106> a ns1:LearningResult ;
    ns1:learningResultCode "RA106" ;
    ns1:learningResultDescription "Conoce y aplica las teorías, modelos y técnicas actuales para la identificación de los problemas, el análisis, el diseño del software, el desarrollo, la implementación, la verificación y la documentación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000251/2025-26/RA118> a ns1:LearningResult ;
    ns1:learningResultCode "RA118" ;
    ns1:learningResultDescription "Es capaz de trabajar como miembro de un equipo con la finalidad de contribuir a desarrollar proyectos con pragmatismo y sentido de la responsabilidad, asumiendo compromisos y teniendo en cuenta los recursos disponibles. Se desenvuelve de modo que logra generar confianza y credibilidad en un grupo de colaboradores, además del compromiso para el logro de la visión corporativa a través de negociaciones y motivaciones, y no de manera coercitiva e individualista."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000251/2025-26/RA39> a ns1:LearningResult ;
    ns1:learningResultCode "RA39" ;
    ns1:learningResultDescription "Modela y Diseña soluciones atendiendo a los compromisos de eficiencia, modularidad"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000251/2025-26/RA69> a ns1:LearningResult ;
    ns1:learningResultCode "RA69" ;
    ns1:learningResultDescription "Utiliza entornos y herramientas de desarrollo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000251/2025-26/RA99> a ns1:LearningResult ;
    ns1:learningResultCode "RA99" ;
    ns1:learningResultDescription "Utiliza tecnologías, estrategias y estándares para solucionar problemas de integración"@es .

