<https://guia-kg.skai.etsisi.upm.es/resource/135005503/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Introducción."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005503/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Definiciones. Diseño de infraestructuras. Construcción de infraestructuras. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005503/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "4. Construcción. Materiales de construcción."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005503/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "4.1. Definicion de construcción, materiales y estructura. Normas. Código técnico de la edificación. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005503/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "4.2. Propiedades físicas y mecánicas Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005503/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "4.3. Clasificación de los materiales según su origen. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005503/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "4.4. Ejemplos de construcción. Áreas recreativas: mobiliario, cartelería, talanqueras, vallas. Comederos para aves, pasos para fauna, observatorios, miradores, torretas de vigilancia, pasarelas y paseos, parques de aventuras en los árboles, ... Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005503/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "5. Piedra"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005503/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "5.1. Definiciones y clasificación geológica. Estructura y propiedades. Tipos de rocas. Rocas más usadas Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005503/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "5.2. Extracción, transformación y acabado superficial. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005503/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "5.3. Aplicación constructiva. durabilidad, tipos de deterioros. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005503/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "6. Cemento y Hormigón"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005503/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Tipos de infraestructuras: puntuales, lineales, ramificadas Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005503/2025-26/syllabus/20> a ns1:SyllabusItem ;
    ns1:itemIndex 20 ;
    ns1:syllabusDescription "6.1. Definiciones. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005503/2025-26/syllabus/21> a ns1:SyllabusItem ;
    ns1:itemIndex 21 ;
    ns1:syllabusDescription "6.2. Tipos de cemento. Propiedades del cemento. Conglomerante hidráulico: cemento. Clasificación y designación de cementos. Fabricación del cemento (fases). Aplicaciones del cemento. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005503/2025-26/syllabus/22> a ns1:SyllabusItem ;
    ns1:itemIndex 22 ;
    ns1:syllabusDescription "6.3. Definición y principales características del hormigón. Ingredientes. Propiedades del hormigón fresco y endurecido. Ensayos. Dosificación, fabricación, transporte y puesta en obra. Fraguado, endurecimiento y curado. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005503/2025-26/syllabus/23> a ns1:SyllabusItem ;
    ns1:itemIndex 23 ;
    ns1:syllabusDescription "6.4. Tipos de hormigón. Hormigón armado. Ensayos. Adherencia hormigón-acero. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005503/2025-26/syllabus/24> a ns1:SyllabusItem ;
    ns1:itemIndex 24 ;
    ns1:syllabusDescription "7. Acero"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005503/2025-26/syllabus/25> a ns1:SyllabusItem ;
    ns1:itemIndex 25 ;
    ns1:syllabusDescription "7.1. Estructuras metálicas. Fabricación, tratamientos, tipos y propiedades. Ensayos. Uniones. Durabilidad. Sistemas de celosía. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005503/2025-26/syllabus/26> a ns1:SyllabusItem ;
    ns1:itemIndex 26 ;
    ns1:syllabusDescription "8. Madera"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005503/2025-26/syllabus/27> a ns1:SyllabusItem ;
    ns1:itemIndex 27 ;
    ns1:syllabusDescription "8.1. Anatomía. Propiedades físicas: anisotropía, heterogeneidad, contenido en humedad, higroscopicidad, densidad. Propiedades mecánicas. Apeo y transformación. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005503/2025-26/syllabus/28> a ns1:SyllabusItem ;
    ns1:itemIndex 28 ;
    ns1:syllabusDescription "8.2. Madera en rollo, aserrada y laminada encolada. Clasificación estructural. Durabilidad, resistencia, sostenibilidad y eficiencia energética. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005503/2025-26/syllabus/29> a ns1:SyllabusItem ;
    ns1:itemIndex 29 ;
    ns1:syllabusDescription "9. Maquinaria a emplear en el medio natural. Esquema de división de la maquinaria elegida. El tractor. Maquinaria de movimiento de tierras"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005503/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "2. Clasificación del terreno"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005503/2025-26/syllabus/30> a ns1:SyllabusItem ;
    ns1:itemIndex 30 ;
    ns1:syllabusDescription "9.1. Maquinaria de movimiento de tierras: Excavadora, retroexcavadora, explanadora, traílla, motoniveladora, Camión basculante, dumper. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005503/2025-26/syllabus/31> a ns1:SyllabusItem ;
    ns1:itemIndex 31 ;
    ns1:syllabusDescription "10. Maquinaria de compactación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005503/2025-26/syllabus/32> a ns1:SyllabusItem ;
    ns1:itemIndex 32 ;
    ns1:syllabusDescription "10.1. Apisonadoras, rodillos, compactador de neumáticos, pisones automáticos, rodillos vibratorios. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005503/2025-26/syllabus/33> a ns1:SyllabusItem ;
    ns1:itemIndex 33 ;
    ns1:syllabusDescription "11. Maquinaria agraria, de jardinería y restauración paisajística. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005503/2025-26/syllabus/34> a ns1:SyllabusItem ;
    ns1:itemIndex 34 ;
    ns1:syllabusDescription "12. Maquinaria para la poda, desbroce y arrastre."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005503/2025-26/syllabus/35> a ns1:SyllabusItem ;
    ns1:itemIndex 35 ;
    ns1:syllabusDescription "12.1. Motosierra, skidder, autocargador, cosechadora, cortadora y apiladoras. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005503/2025-26/syllabus/36> a ns1:SyllabusItem ;
    ns1:itemIndex 36 ;
    ns1:syllabusDescription "13. Definición de infraestructura. Infraestructura lineal, definición de camino o vía rural o forestal. Clasificación de caminos. Características del tráfico. Los vehículos. El entorno rural. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005503/2025-26/syllabus/37> a ns1:SyllabusItem ;
    ns1:itemIndex 37 ;
    ns1:syllabusDescription "14. Diseño geométrico de una infraestructura lineal viária. Trazado en planta. Trazado en alzado. Secciones transversales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005503/2025-26/syllabus/38> a ns1:SyllabusItem ;
    ns1:itemIndex 38 ;
    ns1:syllabusDescription "14.1. Trazado en planta. Factores que determinan el trazado en planta. Velocidad específica o de cálculo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005503/2025-26/syllabus/39> a ns1:SyllabusItem ;
    ns1:itemIndex 39 ;
    ns1:syllabusDescription "14.1.1. Visibilidad: distancia de visibilidad de parada. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005503/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "2.1. Naturaleza del terreno. Clasificación del terreno. Rocas y suelos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005503/2025-26/syllabus/40> a ns1:SyllabusItem ;
    ns1:itemIndex 40 ;
    ns1:syllabusDescription "14.1.2. Estabilidad: coeficiente de rozamiento transversal por rotación. Movimiento de los vehículos en las curvas circulares. Peligro de deslizamiento. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005503/2025-26/syllabus/41> a ns1:SyllabusItem ;
    ns1:itemIndex 41 ;
    ns1:syllabusDescription "14.1.3. Maniobrabilidad: sobreancho de las curvas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005503/2025-26/syllabus/42> a ns1:SyllabusItem ;
    ns1:itemIndex 42 ;
    ns1:syllabusDescription "14.2. Trazado en alzado."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005503/2025-26/syllabus/43> a ns1:SyllabusItem ;
    ns1:itemIndex 43 ;
    ns1:syllabusDescription "14.2.1. Factores que determinan el trazado en alzado. Influencia económica de la pendiente sobre la velocidad y de la capacidad de la vía. Criterios para la elección de las pendientes mínima y máximas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005503/2025-26/syllabus/44> a ns1:SyllabusItem ;
    ns1:itemIndex 44 ;
    ns1:syllabusDescription "14.2.2. Curva de acuerdo vertical: radio mínimo y curva más conveniente. Radios mínimos de las curvas verticales convexas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005503/2025-26/syllabus/45> a ns1:SyllabusItem ;
    ns1:itemIndex 45 ;
    ns1:syllabusDescription "14.3. Secciones transversales: tipos y cálculo de sus áreas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005503/2025-26/syllabus/46> a ns1:SyllabusItem ;
    ns1:itemIndex 46 ;
    ns1:syllabusDescription "15. Movimiento de tierras."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005503/2025-26/syllabus/47> a ns1:SyllabusItem ;
    ns1:itemIndex 47 ;
    ns1:syllabusDescription "15.1. Ancho y superficie de zona ocupada. Áreas de los taludes. Cajeo en planta. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005503/2025-26/syllabus/48> a ns1:SyllabusItem ;
    ns1:itemIndex 48 ;
    ns1:syllabusDescription "15.2. Cálculo del volumen de tierras a mover. fórmula de la media de las secciones extremas. Casos particulares. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005503/2025-26/syllabus/49> a ns1:SyllabusItem ;
    ns1:itemIndex 49 ;
    ns1:syllabusDescription "15.3. Modelos digitales del terreno. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005503/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "2.2. Clasificación de suelos. ¿Qué necesitamos conocer para clasificar un suelo?. Análisis granulométrico. Consistencia de los suelos. Plasticidad. Límites de Atterberg. Límite líquido y plástico. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005503/2025-26/syllabus/50> a ns1:SyllabusItem ;
    ns1:itemIndex 50 ;
    ns1:syllabusDescription "16. Distribución de tierras."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005503/2025-26/syllabus/51> a ns1:SyllabusItem ;
    ns1:itemIndex 51 ;
    ns1:syllabusDescription "16.1. Curva de áreas.. Correcciones. compensación transversal de tierras Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005503/2025-26/syllabus/52> a ns1:SyllabusItem ;
    ns1:itemIndex 52 ;
    ns1:syllabusDescription "16.2. Coste del transporte. Distancia media de transporte. Préstamos y caballeros. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005503/2025-26/syllabus/53> a ns1:SyllabusItem ;
    ns1:itemIndex 53 ;
    ns1:syllabusDescription "16.3. Compensación longitudinal de tierras. Curva de volúmenes. Cantera de compensación. Horizontal de coste mínimo. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005503/2025-26/syllabus/54> a ns1:SyllabusItem ;
    ns1:itemIndex 54 ;
    ns1:syllabusDescription "17. La construcción de la explanación. Tareas a realizar. Maquinaria a emplear. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005503/2025-26/syllabus/55> a ns1:SyllabusItem ;
    ns1:itemIndex 55 ;
    ns1:syllabusDescription "18. Drenaje en infraestructuras viarias."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005503/2025-26/syllabus/56> a ns1:SyllabusItem ;
    ns1:itemIndex 56 ;
    ns1:syllabusDescription "18.1. La vía y la red de drenaje. Interferencias. Drenaje longitudinal y transversal. Tipos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005503/2025-26/syllabus/57> a ns1:SyllabusItem ;
    ns1:itemIndex 57 ;
    ns1:syllabusDescription "18.2. Cuencas vertientes y agua que drena desde ladera. Calculo de estimación de caudales. Dimensionado de obras de drenaje transversal y longitudinal. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005503/2025-26/syllabus/58> a ns1:SyllabusItem ;
    ns1:itemIndex 58 ;
    ns1:syllabusDescription "19. La superestructura del camino. Importancia del firme en caminos en el medio natural. Tipos de firmes. Estructuras y capas que lo componen. Firmes flexibles. Capas: subbase, base y capa de rodadura. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005503/2025-26/syllabus/59> a ns1:SyllabusItem ;
    ns1:itemIndex 59 ;
    ns1:syllabusDescription "20. Infraestructuras hidráulicas para la defensa contra incendios forestales (IHDIF)"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005503/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "2.3. Clasificación de suelos según la AASHTO (HRB), clasificación unificada de suelos o casagrande, según USDA. Equivalente de arena. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005503/2025-26/syllabus/60> a ns1:SyllabusItem ;
    ns1:itemIndex 60 ;
    ns1:syllabusDescription "20.1. Objetivos generales y específicos de este tipo de infraestructuras. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005503/2025-26/syllabus/61> a ns1:SyllabusItem ;
    ns1:itemIndex 61 ;
    ns1:syllabusDescription "20.2. Esquema general de una instalación tipo. Análisis de cada componente: conducción, almacenamiento, otras funcionalidades, carga a presión (hidrantes), carga por aspiración, accesos. Trabajos complementarios. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005503/2025-26/syllabus/62> a ns1:SyllabusItem ;
    ns1:itemIndex 62 ;
    ns1:syllabusDescription "20.3. Discusión de casos reales. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005503/2025-26/syllabus/63> a ns1:SyllabusItem ;
    ns1:itemIndex 63 ;
    ns1:syllabusDescription "21. Diseño y cálculo de IHDIF"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005503/2025-26/syllabus/64> a ns1:SyllabusItem ;
    ns1:itemIndex 64 ;
    ns1:syllabusDescription "21.1. Requisitos de funcionamiento. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005503/2025-26/syllabus/65> a ns1:SyllabusItem ;
    ns1:itemIndex 65 ;
    ns1:syllabusDescription "21.2. Diseño de la conducción: elección del material, elección de diámetros, elección del timbraje. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005503/2025-26/syllabus/66> a ns1:SyllabusItem ;
    ns1:itemIndex 66 ;
    ns1:syllabusDescription "21.3. Comprobación de requisitos de funcionamiento. Prácticas de dimensionado. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005503/2025-26/syllabus/67> a ns1:SyllabusItem ;
    ns1:itemIndex 67 ;
    ns1:syllabusDescription "22. Otras infraestructuras. Sendas: Introducción. Definición y objetivos. Características de un sendero. Tipos de senderos homologados. Las señales. Mantenimiento de senderos. Reglamento de senderos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005503/2025-26/syllabus/68> a ns1:SyllabusItem ;
    ns1:itemIndex 68 ;
    ns1:syllabusDescription "23. Deslindes y amojonamientos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005503/2025-26/syllabus/69> a ns1:SyllabusItem ;
    ns1:itemIndex 69 ;
    ns1:syllabusDescription "23.1. Definición y objetivos. Tipos de deslindes. Estudio documental/histórico. Levantamiento topográfico georreferenciado. Expediente de deslinde de fincas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005503/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "3. Teoría de la compactación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005503/2025-26/syllabus/70> a ns1:SyllabusItem ;
    ns1:itemIndex 70 ;
    ns1:syllabusDescription "23.2. Acta de deslinde. Amojonamiento. Requisitos del amojonamiento. Supuestos del amojonamiento (primera implantación, desaparición de mojones, modificación de elementos físicos naturales) Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005503/2025-26/syllabus/71> a ns1:SyllabusItem ;
    ns1:itemIndex 71 ;
    ns1:syllabusDescription "24. Práctica de la asignatura: Anteproyecto de construcción de vía tipo tierra."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005503/2025-26/syllabus/72> a ns1:SyllabusItem ;
    ns1:itemIndex 72 ;
    ns1:syllabusDescription "24.1. Práctica 0 y 1. Objetivos y contenido del anteproyecto. Señalización puntos origen, intermedio y final. Estudio trazado en planta. Poligonal base. Eje definitivo. Estado de alineaciones. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005503/2025-26/syllabus/73> a ns1:SyllabusItem ;
    ns1:itemIndex 73 ;
    ns1:syllabusDescription "24.2. Práctica 2. Perfil longitudinal. Trazado de rasante. Determinación de los perfiles transversales. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005503/2025-26/syllabus/74> a ns1:SyllabusItem ;
    ns1:itemIndex 74 ;
    ns1:syllabusDescription "24.3. Práctica 3. Perfil transversal tipo. Perfiles transversales. Cálculo del área de los perfiles transversales. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005503/2025-26/syllabus/75> a ns1:SyllabusItem ;
    ns1:itemIndex 75 ;
    ns1:syllabusDescription "24.4. Práctica 4. Cajeo en planta. Cálculo de la superficie ocupada por la vía. Cubicación de las obras de tierra. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005503/2025-26/syllabus/76> a ns1:SyllabusItem ;
    ns1:itemIndex 76 ;
    ns1:syllabusDescription "24.5. Práctica 5. Distribución de tierras: Registro. Curva de volúmenes Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005503/2025-26/syllabus/77> a ns1:SyllabusItem ;
    ns1:itemIndex 77 ;
    ns1:syllabusDescription "24.6. Práctica 6. Obras de fábrica. Mediciones y presupuestos. Memoria. Finalización y entrega de Anteproyecto. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005503/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "3.1. Introducción. Ensayos de compactación. Ensayo proctor y proctor modificado. Ensayo CBR. Ensayo de resistencia a la fragmentación \"Los Ángeles\". Presentación de resultados. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005503/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "3.2. Tipos de compactación. Compactación por presión estática, compactación por vibración. Teoría de la distribución de presiones. Sin subniveles"@es .

