    schema:hasCourseInstance <https://guia-kg.skai.etsisi.upm.es/resource/113000037/2025-26> ;
    schema:name "Equality Of Opportunities Between Men An Women In The Physical Activity And The Sport"@en,
        "Igualdad de Oportunidades Entre Hombres y Mujeres en la Actividad Fisica y el Deporte"@es ;
    schema:numberOfCredits 3.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/113000037/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/113000037/2025-26/CE5>,
        <https://guia-kg.skai.etsisi.upm.es/resource/113000037/2025-26/CE7>,
        <https://guia-kg.skai.etsisi.upm.es/resource/113000037/2025-26/CG1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/113000037/2025-26/CG3>,
        <https://guia-kg.skai.etsisi.upm.es/resource/113000037/2025-26/CG4> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/113000037/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/113000037/2025-26/didactic_resource/2> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/113000037/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/113000037/2025-26/RA61>,
        <https://guia-kg.skai.etsisi.upm.es/resource/113000037/2025-26/RA62>,
        <https://guia-kg.skai.etsisi.upm.es/resource/113000037/2025-26/RA63> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/113000037/2025-26/syllabus> ;
    ns1:inpersonHours "32 horas y 10 minutos (41.2%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation "Esta asignatura se alinea con los Objetivos de Desarrollo Sostenible ODS5-Igualdad de género, principalmente, así como el ODS3-Salud y bienestar, ODS4-Educación de calidad y ODS10-Reducción de las desigualdades."@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "32 horas y 10 minutos"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/113000037/2025-26/eventSchedule> ;
    schema:description "La asignatura tiene como objetivo proporcionar las competencias necesarias para introducir al alumnado en el ámbito de la investigación social sobre la igualdad de oportunidades entre mujeres y hombres en la actividad física y el deporte, así como incorporar transversalmente la perspectiva de género en la investigación científica sobre la actividad física y el deporte. Esta asignatura se alinea con los Objetivos de Desarrollo Sostenible ODS5-Igualdad de género, principalmente, así como el ODS3-Salud y bienestar, ODS4-Educación de calidad y ODS10-Reducción de las desigualdades."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/maria.martin%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/maria.martin%40upm.es> ;
    schema:name "Igualdad de Oportunidades Entre Hombres y Mujeres en la Actividad Fisica y el Deporte"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000037/2025-26/CE5> a ns1:Competency ;
    ns1:competencyCode "CE5" ;
    ns1:competencyDescription "Capacidad para encontrar nuevas formas de utilización de la Actividad física y el Deporte en la solución de los grandes problemas de la sociedad de nuestros días (igualdad de oportunidades, salud, marginación, cooperación, desarrollo)."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000037/2025-26/CE7> a ns1:Competency ;
    ns1:competencyCode "CE7" ;
    ns1:competencyDescription "Iniciarse de forma concreta en un campo de investigación determinado."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000037/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Capacidad abierta y reflexiva para conocer y asumir valores y compromisos inherentes al desarrollo humano, tales como la igualdad de oportunidades entre hombres y mujeres, facilidad de acceso a las personas con discapacidad, promoción de la cultura de la paz, y así manejarse adecuadamente en el ámbito de la investigación científica."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000037/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Capacidad para aplicar los conocimientos adquiridos y para resolver problemas en diferentes entornos relacionados con el ámbito de la actividad física y los deportes."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000037/2025-26/CG4> a ns1:Competency ;
    ns1:competencyCode "CG4" ;
    ns1:competencyDescription "Capacidad para integrar conocimientos y enfrentarse a la complejidad de formular juicios a partir de información que, siendo compleja o limitada, incluya reflexiones sobre las responsabilidades sociales y éticas vinculadas al ámbito de la actividad física y los deportes."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000037/2025-26/RA61> a ns1:LearningResult ;
    ns1:learningResultCode "RA61" ;
    ns1:learningResultDescription "Conocer y analizar la situación actual de igualdad de oportunidades entre mujeres y hombres en la actividad física y el deporte"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000037/2025-26/RA62> a ns1:LearningResult ;
    ns1:learningResultCode "RA62" ;
    ns1:learningResultDescription "Conocer y analizar los estudios científicos, programas nacionales e internacionales orientados a mejorar la igualdad de oportunidades entre hombres y mujeres en el ámbito de la actividad física y el deporte, así como las estrategias de intervención"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000037/2025-26/RA63> a ns1:LearningResult ;
    ns1:learningResultCode "RA63" ;
    ns1:learningResultDescription "Capacitar para incorporar la perspectiva de género en la investigación científica relacionada con la actividad física y el deporte"@es .

