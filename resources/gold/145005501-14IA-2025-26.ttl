    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/145005501/2025-26/eventSchedule> ;
    schema:description """Este curso,es un curso introductorio a la variable compleja y sus aplicaciones. La aplicaciones que se considerará a lo largo del curso son las transformdas de Fourier y de Laplace y
las ecuaciones diferenciales ordinarias lineales de coeficientes analíticos."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/fj.mancebo%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
