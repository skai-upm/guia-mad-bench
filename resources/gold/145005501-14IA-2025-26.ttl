        <https://guia-kg.skai.etsisi.upm.es/resource/mariola.gomez%40upm.es> ;
    schema:name "Ampliacion de Matematicas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005501/2025-26/CE51> a ns1:Competency ;
    ns1:competencyCode "CE51" ;
    ns1:competencyDescription "Capacidad para relacionar fenómenos físicos distintos a través de un modelo matemático, aplicar las técnicas apropiadas para obtener información del mismo e interpretar los resultados"@es .

