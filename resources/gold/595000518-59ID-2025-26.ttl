    ns1:learningResultDescription "Analizar, diseñar y gestionar sistemas empotrados distribuidos para adquisición de datos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000518/2025-26/RA043> a ns1:LearningResult ;
