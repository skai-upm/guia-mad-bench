<https://guia-kg.skai.etsisi.upm.es/resource/205000012/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. UNIDAD DIDÁCTICA 1. TIEMPO GEOLÓGICO y MINERALOGÍA"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000012/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Introducción. Concepto de geología. Sistemática de la geología. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000012/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "2. UNIDAD DIDÁCTICA 2. PETROLOGÍA y GEOMORFOLOGÍA"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000012/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "2.1. Ciclo de las rocas. Ambientes genéticos formadores de las rocas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000012/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "2.2. Origen de los magmas: factores de control de la fusión de rocas. Ámbitos geodinámicos de la fusión de rocas. Evolución de los magmas: diferenciación, asimilación, mezcla de magmas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000012/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "2.3. Rocas endógenas ígneas. Rocas plutónicas. Intrusión magmática. Clasificación y propiedades. Rocas filonianas o subvolcánicas. Clasificación y propiedades."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000012/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "2.3.1. Enfriamiento y cristalización de magmas. Relación con composición y texturas de rocas ígneas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000012/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "2.4. Rocas volcánicas y vulcanismo. Factores que controlan las erupciones volcánicas. Estructuras asociadas a las erupciones volcánicas. Clasificación, propiedades y aplicaciones. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000012/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "2.5. Rocas endógenas metamórficas. Factores del metamorfismo (presión y temperatura). Procesos metamórficos. Tipos de metamorfismo. Rocas metamórficas. Clasificación y propiedades. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000012/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "2.6. Meteorización. Procesos de meteorización física. Procesos de meteorización química. Reacciones y productos de la alteración. Erosión"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000012/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "2.6.1. Factores formadores de los suelos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000012/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "2.7. Procesos generadores de rocas sedimentarias I: Procesos de erosión y transporte. Estructuras sedimentarias. Sedimentación continental. Sedimentación marina. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000012/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. El Tiempo geológico. Datación relativa y absoluta. Principios de datación relativa. Datación absoluta. La Escala del tiempo Geológico. Geocronología. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000012/2025-26/syllabus/20> a ns1:SyllabusItem ;
    ns1:itemIndex 20 ;
    ns1:syllabusDescription "2.8. Procesos generadores de rocas sedimentarias II. Procesos postsedimentarios. Procesos diagenéticos. Rocas exógenas detríticas. Componentes. Génesis, clasificación, propiedades. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000012/2025-26/syllabus/21> a ns1:SyllabusItem ;
    ns1:itemIndex 21 ;
    ns1:syllabusDescription "2.9. Rocas exógenas de precipitación química. Rocas carbonatadas. Mecanismos de precipitación /disolución. Rocas evaporíticas. Ambientes geológicos de sedimentación. Rocas silíceas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000012/2025-26/syllabus/22> a ns1:SyllabusItem ;
    ns1:itemIndex 22 ;
    ns1:syllabusDescription "2.10. El Ciclo hidrológico. Formas erosivas y depósitos resultantes. Abanicos aluviales, conos de deyección, glacis, llanura de inundación y terrazas fluviales. Hidrogeología. Acuíferos libres. Acuíferos confinados. Explotación. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000012/2025-26/syllabus/23> a ns1:SyllabusItem ;
    ns1:itemIndex 23 ;
    ns1:syllabusDescription "2.11. Riesgos Geológicos. Concepto, tipos, análisis de riesgos: peligrosidad, exposición, vulnerabilidad. Prevención. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000012/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "1.3. Geomorfología global y Dinámica Global. Eventos bióticos globales y cambios paleoambientales a lo largo de la historia de la Tierra. Cambios climáticos durante el Cuaternario."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000012/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "1.3.1. Geología de España. Contexto en la dinámica global. Principales Unidades Geológicas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000012/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "1.4. Concepto de mineral. Clasificación de los minerales. Estructura de los silicatos. Bases de la estabilidad de los minerales frente a la alteración. Polimerización. Tipos de enlace. Sustituciones isomórficas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000012/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "1.5. Nesosilicatos, Sorosilicatos, Ciclosilicatos e Inosilicatos. Estructura. Propiedades y aplicaciones. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000012/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "1.6. Filosilicatos. Estructura. Propiedades y aplicaciones. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000012/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "1.7. Arcillas de sedimentos y suelos. Estructuras, propiedades y aplicaciones Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000012/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "1.8. Tectosilicatos. Minerales no silicatados de interés agronómico. Estructura. Propiedades y aplicaciones. Sin subniveles"@es .

