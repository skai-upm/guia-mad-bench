    ns1:inpersonHours "1 horas (1.3%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation ""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "2 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/43000459/2025-26/eventSchedule> ;
    schema:description "Seminario de introducción al Trabajo Fin de Máster (siTFM) se introduce loas aspectos metodológicos generales para la elaboración de proyectos e investigaciones en el área de estructuras, cimentaciones y materiales. Para matricularse el estudiante deberá contar con un tema de trabajo trabajo fin de máster y un tutor asignado. Una parte del seminario estará dedicada a aspectos metodológicos generales a aplicar en la elaboración del TFM, con especial énfasis en las cuestiones deontológicas y de elaboración de documentos técnicos escritos (artículos científicos, TFM, Posters) y presentaciones orales efectivas. La otra parte, impartida por el tutor, se dedicará a los aspectos específicos del tema a desarrollar por cada estudiante. El resultado final será una exploración bibliográfica del estado del arte del tema elegido para el TFM, una justificación escrita y una presentación oral junto a un plan de trabajo del TFM, que servirá al coordinador y al tutor para evaluar la asignatura."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/d.manzanal%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/d.manzanal%40upm.es> ;
    schema:name "Seminario de Introducción Al Trabajo Fin de Máster"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000459/2025-26/CB9> a ns1:Competency ;
    ns1:competencyCode "CB9" ;
    ns1:competencyDescription "Que los estudiantes sepan comunicar sus conclusiones y los conocimientos y razones últimas que las sustentan a públicos especializados y no especializados de un modo claro y sin ambigüedades"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000459/2025-26/CG2> a ns1:Competency ;
    ns1:competencyCode "CG2" ;
    ns1:competencyDescription "Capacidad de ejercer las funciones de proyecto, construcción, conservación y evaluación técnica mediante el uso de normativa europea e internacional."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000459/2025-26/CT1> a ns1:Competency ;
    ns1:competencyCode "CT1" ;
    ns1:competencyDescription "Capacidad de preparar y presentar comunicaciones orales, escritas y gráficas, estructurada y argumentadamente."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000459/2025-26/CT2> a ns1:Competency ;
    ns1:competencyCode "CT2" ;
    ns1:competencyDescription "Capacidad de organizar y dirigir los esfuerzos de un equipo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000459/2025-26/CT3> a ns1:Competency ;
    ns1:competencyCode "CT3" ;
    ns1:competencyDescription "Compromiso y capacidad de aplicación de los estándares de deontología en investigación y ejercicio profesional avanzado"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000459/2025-26/RA10> a ns1:LearningResult ;
    ns1:learningResultCode "RA10" ;
    ns1:learningResultDescription "Interioriza los principios y técnicas de organización y dirección de equipos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000459/2025-26/RA11> a ns1:LearningResult ;
    ns1:learningResultCode "RA11" ;
    ns1:learningResultDescription "Realiza una exploración bibliográfica y un plan de trabajo justificado del TFM haciendo uso en particular del conocimiento adquirido sobre normativa europea e internacional de ingeniería estructural, geotécnica y de materiales estructurales para proyecto, construcción, conservación y evaluación técnica Interioriza los principios y técnicas de organización y dirección de equipos Interioriza los principios de deontología profesional de ingeniería civil"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000459/2025-26/RA2> a ns1:LearningResult ;
    ns1:learningResultCode "RA2" ;
    ns1:learningResultDescription "Presenta comunicaciones orales, escritas y gráficas, estructurada y argumentadamente, en lengua española e inglesa"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000459/2025-26/RA3> a ns1:LearningResult ;
    ns1:learningResultCode "RA3" ;
    ns1:learningResultDescription "Interioriza los principios de deontología profesional para actividades de I+D+i"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000459/2025-26/RA4> a ns1:LearningResult ;
