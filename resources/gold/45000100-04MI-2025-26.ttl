<https://guia-kg.skai.etsisi.upm.es/resource/45000100/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Sistemas de vectores deslizantes. Eje central. Equivalencia y reducción Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000100/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "2. Cinemática del punto material. Velocidad. Aceleración. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000100/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "11. Teorema de la energía. Teorema del momento. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000100/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "12. Percusiones y vibraciones. Choque excéntrico. Vibraciones libres del S. Rígido Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000100/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "13. Estática del sólido rígido. Reacciones.Ligaduras. Rozamiento seco. Tornillos. Cuñas. Rozamiento en correas Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000100/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "14. Introducción a la Elasticidad. Tensiones y deformaciones. Ley de Hooke. Energía elástica. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000100/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "3. Dinámica del punto material. Leyes de Newton. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000100/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "4. Teorema de la energía. Fuerzas conservativas. Rozamiento. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000100/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "5. Momento lineal y angular. Fuerzas centrales. Choques. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000100/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "6. Sistemas no inerciales. Principio de D?Alambert. Aceleración de Coriolis. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000100/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "7. Sistemas de partículas. Teoremas generales. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000100/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "8. Geometría de masas. Centros de masas.Momentos de inercia. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000100/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "9. Cinemática del sólido rígido. Movimiento plano. Rotación. Rodadura. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000100/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "10. Dinámica del sólido rígido. Movimiento plano. Sin subniveles"@es .

