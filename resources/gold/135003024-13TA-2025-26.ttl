    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/135003024/2025-26/RA178>,
        <https://guia-kg.skai.etsisi.upm.es/resource/135003024/2025-26/RA179>,
        <https://guia-kg.skai.etsisi.upm.es/resource/135003024/2025-26/RA235>,
        <https://guia-kg.skai.etsisi.upm.es/resource/135003024/2025-26/RA59>,
