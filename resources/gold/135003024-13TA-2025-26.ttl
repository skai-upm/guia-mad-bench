<https://guia-kg.skai.etsisi.upm.es/resource/135003024/2025-26/RA63> a ns1:LearningResult ;
    ns1:learningResultCode "RA63" ;
    ns1:learningResultDescription "Conocer las tecnologías de reciclado de materiales no metálicos como: papel, plástico, cristal, fibra, equipos de construcción, asfalto, neumáticos, aceites, y lubricantes, residuos sólidos urbanos, lodos, y de materiales metálicos"@es .

