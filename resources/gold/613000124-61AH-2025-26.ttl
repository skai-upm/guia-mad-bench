    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/613000124/2025-26/eventSchedule> ;
    schema:description "Este es un curso completo de Visión por Computador centrado en modelos actuales de Deep Learning. Las clases teóricas incluyen la explicación de los conceptos y el seguimiento detallado de códigos fuente que implementan versiones simplificadas (académicas) de cada uno de los apartados descritos en el temario. Los alumnos harán uso de esos programas, como base, para completar los créditos ECTS de la asignatura. El resultado esperado es la capacidad por parte de los alumnos de proponer variaciones, mejoras, diseños alternativos o nuevos enfoques a los modelos que forman el estado del arte en la materia, así como ser capaces de iniciar una linea de investigación en visión por computador."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/jesus.bobadilla%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/abraham.gutierrez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/jesus.bobadilla%40upm.es> ;
    schema:name "Deep Learning para Visión Computacional"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000124/2025-26/CB10> a ns1:Competency ;
    ns1:competencyCode "CB10" ;
    ns1:competencyDescription "Que los estudiantes posean las habilidades de aprendizaje que les permitan continuar estudiando de un modo que habrá de ser en gran medida autodirigido o autónomo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000124/2025-26/CB6> a ns1:Competency ;
    ns1:competencyCode "CB6" ;
    ns1:competencyDescription "Poseer y comprender conocimientos que aporten una base u oportunidad de ser originales en el desarrollo y/o aplicación de ideas, a menudo en un contexto de investigación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000124/2025-26/CB7> a ns1:Competency ;
    ns1:competencyCode "CB7" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en entornos nuevos o poco conocidos dentro de contextos más amplios (o multidisciplinares) relacionados con su área de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000124/2025-26/CB8> a ns1:Competency ;
    ns1:competencyCode "CB8" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de integrar conocimientos y enfrentarse a la complejidad de formular juicios a partir de una información que, siendo incompleta o limitada, incluya reflexiones sobre las responsabilidades sociales y éticas vinculadas a la aplicación de sus conocimientos y juicios"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000124/2025-26/CB9> a ns1:Competency ;
    ns1:competencyCode "CB9" ;
    ns1:competencyDescription "Que los estudiantes sepan comunicar sus conclusiones y los conocimientos y razones últimas que las sustentan a públicos especializados y no especializados de un modo claro y sin ambigüedades"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000124/2025-26/CE03> a ns1:Competency ;
    ns1:competencyCode "CE03" ;
    ns1:competencyDescription "Diseñar y aplicar técnicas avanzadas de aprendizaje profundo para la resolución de problemas relacionados con el análisis y tratamiento de datos masivos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000124/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Capacidad para aplicar el método científico y saber organizar y planificar experimentos con rigor metodológico en el ámbito del aprendizaje automático y los datos masivos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000124/2025-26/CG2> a ns1:Competency ;
    ns1:competencyCode "CG2" ;
    ns1:competencyDescription "Participar en la aplicación de mecanismos de descripción, cuantificación, análisis, interpretación y evaluación de resultados experimentales del ámbito de los datos masivos y el aprendizaje automático"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000124/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Capacidad para reunir e interpretar datos masivos relevantes para emitir juicios que incluyan una reflexión sobre temas importantes de índole científico, social o ético en el ámbito del aprendizaje automático y los datos masivos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000124/2025-26/CG4> a ns1:Competency ;
    ns1:competencyCode "CG4" ;
    ns1:competencyDescription "Capacidad de aplicar iniciativa, integración, colaboración y potenciación de la discusión crítica en el ámbito del trabajo en equipo dentro del ámbito del aprendizaje automático y datos masivos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000124/2025-26/CG5> a ns1:Competency ;
    ns1:competencyCode "CG5" ;
    ns1:competencyDescription "Participar en la transmisión de la información generada, las ideas, los problemas y las soluciones de forma oral y escrita para un público tanto especializado como no especializado"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000124/2025-26/CT1> a ns1:Competency ;
    ns1:competencyCode "CT1" ;
    ns1:competencyDescription "Creatividad"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000124/2025-26/CT2> a ns1:Competency ;
    ns1:competencyCode "CT2" ;
    ns1:competencyDescription "Organización y planificación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000124/2025-26/CT3> a ns1:Competency ;
    ns1:competencyCode "CT3" ;
    ns1:competencyDescription "Gestión de la información"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000124/2025-26/CT4> a ns1:Competency ;
    ns1:competencyCode "CT4" ;
    ns1:competencyDescription "Liderazgo de equipos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000124/2025-26/CT5> a ns1:Competency ;
    ns1:competencyCode "CT5" ;
    ns1:competencyDescription "Trabajo en contextos internacionales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000124/2025-26/K01> a ns1:Competency ;
    ns1:competencyCode "K01" ;
    ns1:competencyDescription "El alumno clasifica y explica los algoritmos y técnicas de aprendizaje automático, tanto supervisado como no supervisado"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000124/2025-26/K02> a ns1:Competency ;
    ns1:competencyCode "K02" ;
    ns1:competencyDescription "El alumno explica los modelos de aprendizaje profundo y generativos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000124/2025-26/RA6> a ns1:LearningResult ;
    ns1:learningResultCode "RA6" ;
    ns1:learningResultDescription "Conocer y explicar técnicas avanzadas de visión por computador aplicadas a la solución de problemas complejos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000124/2025-26/RA7> a ns1:LearningResult ;
    ns1:learningResultCode "RA7" ;
    ns1:learningResultDescription "· Plantear soluciones plausibles a problemas que impliquen clasificación de imágenes, así como la identificación y el reconocimiento de objetos en entornos variables"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000124/2025-26/RA8> a ns1:LearningResult ;
    ns1:learningResultCode "RA8" ;
    ns1:learningResultDescription "· Conocer y aplicar técnicas de transferencia de estilo artístico para que las imágenes adopten el estilo visual de otras."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000124/2025-26/S03> a ns1:Competency ;
    ns1:competencyCode "S03" ;
    ns1:competencyDescription "El alumno experimenta con modelos de aprendizaje automático para la obtención de conocimiento a partir de conjuntos de datos masivos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000124/2025-26/S04> a ns1:Competency ;
    ns1:competencyCode "S04" ;
    ns1:competencyDescription "El alumno crea nuevos modelos de aprendizaje automático y ejecuta experimentos para demostrar su viabilidad y mejora de rendimiento con respecto al estado del arte"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000124/2025-26/S05> a ns1:Competency ;
    ns1:competencyCode "S05" ;
    ns1:competencyDescription "El alumno compone y ejecuta el flujo de trabajo necesario para la resolución de un problema de aprendizaje automático"@es .

