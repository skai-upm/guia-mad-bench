<https://guia-kg.skai.etsisi.upm.es/resource/133000272> a ns1:Course ;
    ns1:courseType "Optativa"@es ;
    ns1:courseYear 1 ;
    ns1:semester "Segundo semestre"@es ;
    schema:courseCode 133000272 ;
    schema:hasCourseInstance <https://guia-kg.skai.etsisi.upm.es/resource/133000272/2025-26> ;
    schema:name "Forest Products Carbon Footprint And Lca"@en,
        "Huella de Carbono y Acv en Productos Forestales"@es ;
    schema:numberOfCredits 3.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/133000272/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/133000272/2025-26/CE%202.7>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000272/2025-26/CE%203.2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000272/2025-26/CE%206.2> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/133000272/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000272/2025-26/didactic_resource/2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000272/2025-26/didactic_resource/3>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000272/2025-26/didactic_resource/4>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000272/2025-26/didactic_resource/5> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/133000272/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/133000272/2025-26/RA198>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000272/2025-26/RA200> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/133000272/2025-26/syllabus> ;
    ns1:inpersonHours "32 horas (41%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation "LAS COMPETENCIAS Y LOS RESULTADOS DE APRENDIZAJE DE ESTA ASIGNATURA SON CONFORMES CON LA MEMORIA VERIFICA DEL TÍTULO"@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "32 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/133000272/2025-26/eventSchedule> ;
    schema:description """El objetivo de la asignatura es introducir al alumno en el ámbito de la valoración de la sostenibilidad de los productos fabricados a partir de materias primas de origen forestal y también de los servicios forestales, como pueda ser una repoblación o cualquier otra obra de la ingeniería de montes.
Se abordará el estudio de los tres principales conceptos en este ámbito: Análisis de Ciclo de Vida, Huella de Carbono y Balance de Carbono. La asignatura tiene un enfoque aplicado, centrándose en las metodologías de cálculo y en el estudio de casos concretos."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/victor.gonzalez%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/alejandra.ezquerra%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/sigfredo.ortuno%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/victor.gonzalez%40upm.es> ;
    schema:name "Huella de Carbono y Acv en Productos Forestales"@es .

