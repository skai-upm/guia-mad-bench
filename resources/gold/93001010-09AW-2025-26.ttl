    ns1:competencyDescription "Trabajo en equipo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93001010/2025-26/CT09> a ns1:Competency ;
    ns1:competencyCode "CT09" ;
    ns1:competencyDescription "Capacidad de análisis y síntesis"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93001010/2025-26/CT11> a ns1:Competency ;
