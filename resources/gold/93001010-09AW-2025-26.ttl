    ns1:competencyDescription "Razonamiento crítico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93001010/2025-26/CT12> a ns1:Competency ;
    ns1:competencyCode "CT12" ;
    ns1:competencyDescription "Aprendizaje autónomo, adaptación a nuevas situaciones y motivación por el desarrollo profesional permanente"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93001010/2025-26/RA15> a ns1:LearningResult ;
    ns1:learningResultCode "RA15" ;
    ns1:learningResultDescription "Reconocer, analizar y saber neutralizar los diferentes tipos de malware"@es .

