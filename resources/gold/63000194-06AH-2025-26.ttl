    ns1:competencyDescription "Adquirir nuevos conocimientos y capacidade relacionados con el ámbito profesional del máster"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000194/2025-26/CG06> a ns1:Competency ;
    ns1:competencyCode "CG06" ;
    ns1:competencyDescription "Dar respuesta eficaz y eficiente a situaciones y problemas de caracter profesional propios de la temática del máster."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000194/2025-26/CG20> a ns1:Competency ;
    ns1:competencyCode "CG20" ;
    ns1:competencyDescription "Capacidad de innovación para identificar formular y resolver problemas de eficiencia energética dentro de los contextos multidisciplinares de la Ingeniería Energética"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000194/2025-26/CG21> a ns1:Competency ;
    ns1:competencyCode "CG21" ;
    ns1:competencyDescription "Capacidad de autoaprendizaje y formación continua en el ámbito de la aplicación de criterios de eficiencia energética"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000194/2025-26/CG22> a ns1:Competency ;
