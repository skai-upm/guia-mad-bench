<https://guia-kg.skai.etsisi.upm.es/resource/305000113/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Grupos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000113/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Definición y ejemplos de grupos. Subgrupos. Grupos cíclicos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000113/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "2.4. Anillos de polinomios. Factorización de polinomios e irreducibilidad. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000113/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "2.5. Dominios Euclídeos. Dominios de ideales principales. Dominios de Factorización única. Concepto de m.c.d. y m.c.m. Polinomios primitivos. Lema de Gauss e implicaciones. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000113/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "2.6. Resultante de polinomios univariados. Aplicaciones:Implicitación de curvas racionales. Intersección de curvas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000113/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "2.7. Cuerpos finitos y aplicaciones a las teorías de la información y comunicaciones. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000113/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "3. Módulos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000113/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "3.1. Módulo, submódulo y homomorfismo. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000113/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "3.2. Módulos libres. Espacios vectoriales sobre cuerpos arbitrarios. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000113/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "3.3. Representaciones de grupos como módulos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000113/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Grupos simétricos y diédricos. Homomorfismos y Teorema de Cayley. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000113/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "1.3. Teorema de Lagrange. Grupo cociente. Teoremas de isomorfía Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000113/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "1.4. Productos directos. Teorema Fundamental de Grupos Finitos Abelianos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000113/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "1.5. 5. Aplicaciones (a la teoría de códigos, criptografía, genética o circuitos eléctricos). Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000113/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "2. Anillos y Cuerpos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000113/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "2.1. Anillos, dominios y cuerpos. Característica de un anillo. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000113/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "2.2. Ideales. Anillo cociente. Ideales primos y maximales. Cuerpo de fracciones. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000113/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "2.3. Homomorfismos de anillos. Sin subniveles"@es .

