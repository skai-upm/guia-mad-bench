    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/305000113/2025-26/eventSchedule> ;
    schema:description """El objetivo principal de esta asignatura es la comprensión de los conceptos básicos de la Teoría de Grupos y Anillos. Se inicia además el estudio de las extensiones de cuerpos y del concepto de módulo. Desde un punto de vista computacional y orientado a las aplicaciones se manejarán modelos concretos que son necesarios para abordar asignaturas posteriores de álgebra: grupos finitos de orden pequeño, grupos simétricos y diédricos, tipos de dominios, propiedades de la factorización, anillos de polinomios y sus propiedades.
En asignaturas cursadas con anterioridad los alumnos habrán estudiado las definiciones y primeros ejemplos de grupos, anillos y cuerpos. En esta asignatura se integrarán todos estos conceptos dentro de una teoría algebraica que influirá transversalmente en prácticamente todas las asignaturas del grado. Junto con la asignatura de Ecuaciones Algebraicas del 6º semestre, esta asignatura proveerá al alumno de una formación inicial en álgebra que podrá ampliarse con la elección de optativas de 4º curso."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/sonialuisa.rueda%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/sonialuisa.rueda%40upm.es> ;
    schema:name "Estructuras Algebraicas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000113/2025-26/CE1> a ns1:Competency ;
    ns1:competencyCode "CE1" ;
    ns1:competencyDescription "Comprender y utilizar el lenguaje matemático. Adquirir la capacidad para enunciar propiedades en distintos campos de la Matemática, para construir argumentaciones, elaborar cálculos y para transmitir los conocimientos matemáticos adquiridos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000113/2025-26/CE2> a ns1:Competency ;
    ns1:competencyCode "CE2" ;
    ns1:competencyDescription "Conocer y comprender demostraciones rigurosas de los principales teoremas de cada área de la Matemática y extraer de ellos corolarios mediante la particularización a casos concretos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000113/2025-26/CE3> a ns1:Competency ;
    ns1:competencyCode "CE3" ;
    ns1:competencyDescription "Asimilar la definición de un nuevo objeto matemático, en términos de otros ya conocidos, y ser capaz de utilizar este objeto en diferentes contextos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000113/2025-26/CE4> a ns1:Competency ;
    ns1:competencyCode "CE4" ;
    ns1:competencyDescription "Abstraer las propiedades estructurales de objetos matemáticos, de la realidad observada o de otros ámbitos distinguiéndolas de aquellas puramente ocasionales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000113/2025-26/CE5> a ns1:Competency ;
    ns1:competencyCode "CE5" ;
    ns1:competencyDescription "Comprobar con demostraciones hipótesis sobre un objeto matemático o refutarlas con contraejemplos, así como identificar errores en razonamientos incorrectos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000113/2025-26/CE7> a ns1:Competency ;
    ns1:competencyCode "CE7" ;
    ns1:competencyDescription "Resolver problemas de Matemáticas, mediante habilidades de cálculo básico y tecnologías de computación, planificando su resolución en función de las herramientas de que se disponga y de las restricciones de tiempo y recursos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000113/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Identificar la naturaleza, métodos y fines de los distintos campos de la Matemática y asociarlos con cierta perspectiva histórica de su desarrollo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000113/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Utilizar las capacidades analíticas y de abstracción, la intuición y el pensamiento lógico y riguroso desarrolladas a través del estudio de la Matemática en contextos tanto matemáticos como no matemáticos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000113/2025-26/CG4> a ns1:Competency ;
    ns1:competencyCode "CG4" ;
    ns1:competencyDescription "Utilizar los conocimientos teóricos y prácticos adquiridos en la definición y planteamiento de problemas y en la búsqueda de sus soluciones tanto en contextos académicos como profesionales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000113/2025-26/CG5> a ns1:Competency ;
    ns1:competencyCode "CG5" ;
    ns1:competencyDescription "Sintetizar conocimientos y habilidades adquiridas en el campo de la matemática en diferentes materias del plan de estudios para enfocarlas en posteriores estudios especializados, tanto en una disciplina matemática como en cualquiera de las ciencias que requieran buenos fundamentos matemáticos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000113/2025-26/RA89> a ns1:LearningResult ;
    ns1:learningResultCode "RA89" ;
    ns1:learningResultDescription "Identificar estructuras algebraicas subyacentes a diversos conjuntos de números, polinomios, matrices y transformaciones, equipados con determinadas operaciones."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000113/2025-26/RA90> a ns1:LearningResult ;
    ns1:learningResultCode "RA90" ;
    ns1:learningResultDescription "Utilizar con soltura las propiedades de grupos, anillos y cuerpos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000113/2025-26/RA91> a ns1:LearningResult ;
    ns1:learningResultCode "RA91" ;
    ns1:learningResultDescription "Interpretar el estudio de las formas canónicas de los endomorfismos lineales y las representaciones lineales de grupos en términos de módulos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000113/2025-26/RA92> a ns1:LearningResult ;
    ns1:learningResultCode "RA92" ;
    ns1:learningResultDescription "Identificar propiedades invariantes por la acción de un grupo y calcular el grupo de automorfismos de una estructura como grupo de invariancia."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000113/2025-26/RA93> a ns1:LearningResult ;
    ns1:learningResultCode "RA93" ;
    ns1:learningResultDescription "Conectar el concepto de invariancia por un grupo con las geometrías clásicas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000113/2025-26/RA94> a ns1:LearningResult ;
    ns1:learningResultCode "RA94" ;
    ns1:learningResultDescription "Aplicar la teoría de grupos, anillos y cuerpos para resolver problemas prácticos de áreas como la criptografía y la teoría de códigos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000113/2025-26/RA95> a ns1:LearningResult ;
    ns1:learningResultCode "RA95" ;
    ns1:learningResultDescription "Utilizar herramientas computacionales en problemas sobre estructuras algebraicas."@es .

