<https://guia-kg.skai.etsisi.upm.es/resource/63000201/2025-26/CB07> a ns1:Competency ;
    ns1:competencyCode "CB07" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en entornos nuevos o poco conocidos dentro de contextos más amplios (o multidisciplinares) relacionados con su área de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000201/2025-26/CB08> a ns1:Competency ;
    ns1:competencyCode "CB08" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de integrar conocimientos y enfrentarse a la complejidad de formular juicios a partir de una información que, siendo incompleta o limitada, incluya reflexiones sobre las responsabilidades sociales y éticas vinculadas a la aplicación de sus conocimientos y juicios"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000201/2025-26/CB09> a ns1:Competency ;
    ns1:competencyCode "CB09" ;
    ns1:competencyDescription "Que los estudiantes sepan comunicar sus conclusiones ¿y los conocimientos y razones últimas que las sustentan¿ a públicos especializados y no especializados de un modo claro y sin ambigüedades"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000201/2025-26/CB10> a ns1:Competency ;
    ns1:competencyCode "CB10" ;
    ns1:competencyDescription "Que los estudiantes posean las habilidades de aprendizaje que les permitan continuar estudiando de un modo que habrá de ser en gran medida autodirigido o autónomo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000201/2025-26/CG03> a ns1:Competency ;
    ns1:competencyCode "CG03" ;
    ns1:competencyDescription "Desarrollo de la creatividad."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000201/2025-26/CG13> a ns1:Competency ;
    ns1:competencyCode "CG13" ;
    ns1:competencyDescription "Capacidad de análisis, crítica, sisntesis, de discusióny conclusión científica."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000201/2025-26/CG16> a ns1:Competency ;
    ns1:competencyCode "CG16" ;
    ns1:competencyDescription "Manejo de documentación y capacidad de procesar información procedente de diferentes fuentes para su posterior utilización en el estudio y análisis."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000201/2025-26/CG17> a ns1:Competency ;
    ns1:competencyCode "CG17" ;
    ns1:competencyDescription "Capacidad para trabajar en equipo, tanto en relación directa (equipo propio) como indirecta (otros equipos), y en un contexto internacional. Siendo capaces de organizar y planificar el trabajo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000201/2025-26/RA151> a ns1:LearningResult ;
    ns1:learningResultCode "RA151" ;
    ns1:learningResultDescription "Manejo de documentación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000201/2025-26/RA26> a ns1:LearningResult ;
    ns1:learningResultCode "RA26" ;
    ns1:learningResultDescription "Comprender los factores culturales, sociales y ambientales asociados a la sostenibilidad y la responsabilidad social en la industria energética."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000201/2025-26/RA27> a ns1:LearningResult ;
    ns1:learningResultCode "RA27" ;
    ns1:learningResultDescription "Aplicar las principales herramientas y técnicas de análisis, control y gestión medioambiental."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000201/2025-26/RA88> a ns1:LearningResult ;
    ns1:learningResultCode "RA88" ;
    ns1:learningResultDescription "Comprender y aplicar los conceptos estratégicos de sostenibilidad y eficiencia en la industria para su diagnóstico."@es .

