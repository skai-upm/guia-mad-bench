<https://guia-kg.skai.etsisi.upm.es/resource/85004412/2025-26/CB3> a ns1:Competency ;
    ns1:competencyCode "CB3" ;
    ns1:competencyDescription "Que los estudiantes tengan la capacidad de reunir e interpretar datos relevantes (normalmente dentro de su área de estudio) para emitir juicios que incluyan una reflexión sobre temas relevantes de índole social, científica o ética"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85004412/2025-26/CB4> a ns1:Competency ;
    ns1:competencyCode "CB4" ;
    ns1:competencyDescription "Que los estudiantes puedan transmitir información, ideas, problemas y soluciones a un público tanto especializado como no especializado"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85004412/2025-26/CB5> a ns1:Competency ;
    ns1:competencyCode "CB5" ;
    ns1:competencyDescription "Que los estudiantes hayan desarrollado aquellas habilidades de aprendizaje necesarias para emprender estudios posteriores con un alto grado de autonomía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85004412/2025-26/CE15> a ns1:Competency ;
    ns1:competencyCode "CE15" ;
    ns1:competencyDescription "Conocimiento de las características de los sistemas de propulsión naval"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85004412/2025-26/CE19> a ns1:Competency ;
    ns1:competencyCode "CE19" ;
    ns1:competencyDescription "Conocimiento de los motores diesel marinos, turbinas de gas y plantas de vapor"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85004412/2025-26/CE23> a ns1:Competency ;
    ns1:competencyCode "CE23" ;
    ns1:competencyDescription "Conocimiento de los métodos de proyecto de los sistemas de propulsión naval"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85004412/2025-26/CE24> a ns1:Competency ;
    ns1:competencyCode "CE24" ;
    ns1:competencyDescription "Conocimiento de los métodos de proyecto de los sistemas auxiliares de los buques y artefactos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85004412/2025-26/CE26> a ns1:Competency ;
    ns1:competencyCode "CE26" ;
    ns1:competencyDescription "Conocimiento de los procesos de montaje a bordo de máquinas equipos y sistemas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85004412/2025-26/CE8> a ns1:Competency ;
    ns1:competencyCode "CE8" ;
    ns1:competencyDescription "Conocimiento de la ciencia y tecnología de materiales y capacidad para su selección y para la evaluación de su comportamiento."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85004412/2025-26/CG5> a ns1:Competency ;
    ns1:competencyCode "CG5" ;
    ns1:competencyDescription "Capacidad para la realización de mediciones, cálculos, valoraciones, tasaciones, peritaciones, estudios, informes, planos de labores y otros trabajos análogos en el ámbito de la Ingeniería Marítima."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85004412/2025-26/RA130> a ns1:LearningResult ;
    ns1:learningResultCode "RA130" ;
    ns1:learningResultDescription "Conocer y comprender los sistemas de generación de energía a bordo y su aplicación a la producción eléctrica y a la propulsión del buque o artefacto marino"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85004412/2025-26/RA131> a ns1:LearningResult ;
    ns1:learningResultCode "RA131" ;
    ns1:learningResultDescription "Analizar y aplicar el funcionamiento y diseño del motor Diésel, la turbina de gas y la planta de vapor"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85004412/2025-26/RA132> a ns1:LearningResult ;
    ns1:learningResultCode "RA132" ;
    ns1:learningResultDescription "Conocer la combinación de todos los tipos de generadores entre sí para gestionar la potencia generada"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85004412/2025-26/RA133> a ns1:LearningResult ;
    ns1:learningResultCode "RA133" ;
    ns1:learningResultDescription "Conocer las características y diseño de la propulsión del buque"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85004412/2025-26/RA134> a ns1:LearningResult ;
    ns1:learningResultCode "RA134" ;
    ns1:learningResultDescription "Determinar las emisiones de contaminantes debidas a la generación de potencia a bordo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85004412/2025-26/RA135> a ns1:LearningResult ;
    ns1:learningResultCode "RA135" ;
    ns1:learningResultDescription "Conocer las aplicaciones de los sistemas térmicos para su aplicación auxiliar a bordo resultando en un aumento de la eficiencia energética del buque o artefacto"@es .

