    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/115100130/2025-26/eventSchedule> ;
    schema:description "Los contenidos de la asignatura se localizan en 11 temas donde el alumno afianza la base de conocimiento adquirida en el curso anterior. En Aplicación Deportiva I se pretende asimilar las particularidades de un deporte de características artísticas muy definidas y en el que se empieza a entrenar muy temprano. Para ello se profundiza en las características técnicas, físicas y psicológicas de las modalidades que conforman la GR y se adquieren conocimientos específicos relacionados con el sistema de competición. Por otro lado, se continua con la técnica de base de los aparatos cuerda, aro y pelota profundizando en las dificultades de aparato (AD), se desarrollan las bases de los aparatos cinta y mazas así como los de la modalidad de conjunto, que se completará en Aplicación Deportiva II."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/monica.hontoria%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/monica.hontoria%40upm.es> ;
    schema:name "Aplicación Deportiva I: Gimnasia Rítmica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100130/2025-26/CE01> a ns1:Competency ;
    ns1:competencyCode "CE01" ;
    ns1:competencyDescription "Diseñar, desarrollar y evaluar los procesos de enseñanza¿aprendizaje relativos a la actividad física y el deporte con atención a las características individuales y contextuales de las personas. Nivel 3."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100130/2025-26/CE08> a ns1:Competency ;
    ns1:competencyCode "CE08" ;
    ns1:competencyDescription "Aplicar de manera fundamentada y argumentada los principios fisiológicos, biomecánicos, comportamentales y sociales, durante la dirección del entrenamiento deportivo. Nivel 3."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100130/2025-26/CE09> a ns1:Competency ;
    ns1:competencyCode "CE09" ;
    ns1:competencyDescription "Identificar y prevenir los riesgos que se derivan para la salud de los deportistas por la práctica de actividades físicas inadecuadas, en el contexto del entrenamiento deportivo. Nivel 2."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100130/2025-26/CE26> a ns1:Competency ;
    ns1:competencyCode "CE26" ;
    ns1:competencyDescription "Presentar de forma oral y escrita, información clara y detallada de una amplia serie de temas relacionados con la especialidad del alumno, utilizando el lenguaje específico de cada campo académico y profesional."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100130/2025-26/CG01> a ns1:Competency ;
    ns1:competencyCode "CG01" ;
    ns1:competencyDescription "Desarrollar y mostrar en su aplicación una alta capacidad de análisis y de síntesis de la información relativa al campo de conocimiento y profesional."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100130/2025-26/CG03> a ns1:Competency ;
    ns1:competencyCode "CG03" ;
    ns1:competencyDescription "Organizar y planificar propuestas de acción, programas y actividades propias de su campo profesional en sus diferentes ámbitos de aplicación y desarrollo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100130/2025-26/CG04> a ns1:Competency ;
    ns1:competencyCode "CG04" ;
    ns1:competencyDescription "Mostrar disposición y habilidad para el trabajo y el liderazgo en equipo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100130/2025-26/CG08> a ns1:Competency ;
    ns1:competencyCode "CG08" ;
    ns1:competencyDescription "Aplicar los conocimientos adquiridos en los procesos de formación en la práctica profesional, en diferentes contextos y situaciones."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100130/2025-26/CG09> a ns1:Competency ;
    ns1:competencyCode "CG09" ;
    ns1:competencyDescription "Resolver con eficacia, creatividad y eficiencia problemas inherentes a su campo de conocimiento y profesional utilizando estrategias y técnicas adecuadas y, si procede, innovadoras."@es .

