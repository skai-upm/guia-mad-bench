    ns1:otherInformation """CODIGO FIG según Ciclo Olimpico.
Actualización de la bibliografía durante el curso / Fuentes WEB
Análisis videos diferentes campeonatos Nacionales e internacionales.
Visita al CAR para observar sesiones con el Equipo Nacional de GR."""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
