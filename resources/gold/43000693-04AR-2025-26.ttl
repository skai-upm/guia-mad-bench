<https://guia-kg.skai.etsisi.upm.es/resource/43000693/2025-26/CG5> a ns1:Competency ;
    ns1:competencyCode "CG5" ;
    ns1:competencyDescription "Buscar bibliografía, analizar la información procedente de diversas fuentes y de su análisis y síntesis aplicarla a la resolución de problemas complejos, en el campo de la ingeniería hidráulica, energética o medioambiental TIPO: Competencias."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000693/2025-26/K2> a ns1:Competency ;
    ns1:competencyCode "K2" ;
    ns1:competencyDescription "Conocer y comprender el efecto de los factores ambientales en las infraestructuras civiles hidráulicas y energéticas TIPO: Conocimientos o contenidos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000693/2025-26/K3> a ns1:Competency ;
    ns1:competencyCode "K3" ;
    ns1:competencyDescription "Conocer los aspectos científicos y tecnológicos de métodos matemáticos, analíticos y numéricos de la ingeniería, mecánica de fluidos, ingeniería marítima, y obras y Aprovechamientos hidráulicos y energéticos TIPO: Conocimientos o contenidos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000693/2025-26/K4> a ns1:Competency ;
    ns1:competencyCode "K4" ;
    ns1:competencyDescription "Conocer y comprender los fenómenos dinámicos del medio océano"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000693/2025-26/RA12> a ns1:LearningResult ;
    ns1:learningResultCode "RA12" ;
    ns1:learningResultDescription "Conocer los aspectos cientificos y tecnologicos de metodos matemáticos, analiticos y numericos de la ingenieria, aprovechamientos hidraulicos y energeticos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000693/2025-26/RA13> a ns1:LearningResult ;
    ns1:learningResultCode "RA13" ;
    ns1:learningResultDescription "Aplica las capacidades tecnicas y gestoras en actividades de I+D+i dentro del ambito de la ingenieria civil hidraulica, energetica o medioambiental"@es .

