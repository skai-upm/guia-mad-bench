    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/20504225/2025-26/eventSchedule> ;
    schema:description """El objetivo de esta asignatura es que el alumno conozca en profundidad la base molecular de la herencia, el DNA como molécula portadora de la información genética, comprenda y domine los distintos procesos en que participa, y las consecuencias biológicas de cada uno de ellos.
En la segunda parte de la asignatura se hará especial énfasis en la regulación de la expresión génica, tanto en procariotas como en eucariotas, y se abordará su estudio en procesos biológicos complejos como es el desarrollo de organismos pluricelulares.
Durante toda la asignatura se tratará de fomentar la capacidad de razonamiento del alumno mediante preguntas intercaladas con la explicación de la materia y la realización de ejercicios, resolución de problemas y la discusión de los mismos."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/luis.onate%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/luis.onate%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/mariaestela.gimenez%40upm.es> ;
    schema:name "Genética Molecular y Regulación de la Expresión Génica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504225/2025-26/CB02> a ns1:Competency ;
    ns1:competencyCode "CB02" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar sus conocimientos a su trabajo o vocación de una forma profesional y posean las competencias que suelen demostrarse por medio de la elaboración y defensa de argumentos y la resolución de problemas dentro de su área de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504225/2025-26/CE19> a ns1:Competency ;
    ns1:competencyCode "CE19" ;
    ns1:competencyDescription "Capacidad de conocer las bases moleculares de la manipulación de la información genética en microorganismos, animales y plantas y diseñar y ejecutar estrategias para la obtención de organismos modificados genéticamente."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504225/2025-26/CE28> a ns1:Competency ;
    ns1:competencyCode "CE28" ;
    ns1:competencyDescription "Conocimientos adecuados de los mecanismos de control de la expresión génica, y los métodos de estudio para integrarlos en sus aplicaciones en la biotecnología."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504225/2025-26/CG02> a ns1:Competency ;
    ns1:competencyCode "CG02" ;
    ns1:competencyDescription "Familiarizarse con el trabajo en el laboratorio, la instrumentación y los métodos experimentales. Además, ser capaz de realizar experimentos y/o diseñar aplicaciones de forma independiente y describir, cuantificar, analizar y evaluar críticamente los resultados obtenidos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504225/2025-26/CG04> a ns1:Competency ;
    ns1:competencyCode "CG04" ;
    ns1:competencyDescription "Adquirir la formación y habilidades para el desarrollo de la investigación biotecnológica (tecnologías y estrategias frontera), de cara a su posterior aplicación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504225/2025-26/CG10> a ns1:Competency ;
    ns1:competencyCode "CG10" ;
    ns1:competencyDescription "Fomentar la implicación en el trabajo de laboratorio seguro y propiciar el conocimiento de los aspectos éticos y bioéticos del área."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504225/2025-26/CT06> a ns1:Competency ;
    ns1:competencyCode "CT06" ;
    ns1:competencyDescription "Capacidad para organizar y planificar proyectos, experimentos y, en general, trabajos de índole profesional."@es .

