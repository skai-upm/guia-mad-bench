    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/20504113/2025-26/eventSchedule> ;
    schema:description "La asignatura pretende ampliar los conocimientos que el alumno adquirió en Bachillerato en relación el enlace químico y cinética química además de introducir conocimientos básicos de la química orgánica como herramienta indispensable para entender algunos procesos de síntesis. Los temas de enlace se centran fundamentalmente en los sistemas moleculares, profundizando en enlace covalente y fuerzas intermoleculares. En cinética química se profundiza en los conceptos de ordenes de reacción y mecanismos de reacción, incorporando aplicaciones de interés para la Biotecnología. La química orgánica pretende ampliar los conocimientos en la estereoquímica de compuestos orgánicos, y en las reacciones más importantes de los grupos funcionales de interés biotecnológico. En la parte práctica en laboratorio, el alumno complementará la formación que se da en teoría, mediante ejercicios prácticos (preparación de disoluciones, utilización del material más importante, trabajo ordenado en el laboratorio...)."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/laura.sanchez%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/antonio.vallejo%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/laura.sanchez%40upm.es> ;
    schema:name "Química"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504113/2025-26/CB01> a ns1:Competency ;
    ns1:competencyCode "CB01" ;
    ns1:competencyDescription "Que los estudiantes hayan demostrado poseer y comprender conocimientos en un área de estudio que parte de la base de la educación secundaria general, y se suele encontrar a un nivel que, si bien se apoya en libros de texto avanzados, incluye también algunos aspectos que implican conocimientos procedentes de la vanguardia de su campo de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504113/2025-26/CB05> a ns1:Competency ;
    ns1:competencyCode "CB05" ;
    ns1:competencyDescription "Que los estudiantes hayan desarrollado aquellas habilidades de aprendizaje necesarias para emprender estudios posteriores con un alto grado de autonomía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504113/2025-26/CE01> a ns1:Competency ;
    ns1:competencyCode "CE01" ;
    ns1:competencyDescription "Capacidad para conocer las propiedades de la materia, los principios termodinámicos y sus aplicaciones prácticas, así como las características comunes de los procesos físicoquímicos de interés biotecnológico a escala de laboratorio e industrial."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504113/2025-26/CE02> a ns1:Competency ;
    ns1:competencyCode "CE02" ;
    ns1:competencyDescription "Conocimientos básicos de la química inorgánica y los principales grupos funcionales orgánicos, las reacciones de síntesis, los tipos de isomerías y las técnicas de separación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504113/2025-26/CG01> a ns1:Competency ;
    ns1:competencyCode "CG01" ;
    ns1:competencyDescription "Ser capaz de evaluar y discernir los diferentes mecanismos moleculares y celulares responsables de las transformaciones que llevan a cabo los seres vivos, así como poder desarrollar soluciones alternativas y novedosas frente a problemas biológicos conocidos y/o emergentes."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504113/2025-26/CG02> a ns1:Competency ;
    ns1:competencyCode "CG02" ;
    ns1:competencyDescription "Familiarizarse con el trabajo en el laboratorio, la instrumentación y los métodos experimentales. Además, ser capaz de realizar experimentos y/o diseñar aplicaciones de forma independiente y describir, cuantificar, analizar y evaluar críticamente los resultados obtenidos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504113/2025-26/CT05> a ns1:Competency ;
    ns1:competencyCode "CT05" ;
    ns1:competencyDescription "Habilidad de aprendizaje para emprender actividades o estudios posteriores de forma autónoma."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504113/2025-26/RA1> a ns1:LearningResult ;
    ns1:learningResultCode "RA1" ;
    ns1:learningResultDescription "Saber realizar ajustes estequiométricos de reacciones químicas y manejar con soltura herramientas básicas de la química como el concepto de mol y peso molecular."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504113/2025-26/RA10> a ns1:LearningResult ;
    ns1:learningResultCode "RA10" ;
    ns1:learningResultDescription "Saber predecir las propiedades químicas básicas y la reactividad de compuestos inorgánicos y orgánicos relevantes en biología a partir de la estructura atómica, molecular y la naturaleza de los enlaces."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504113/2025-26/RA11> a ns1:LearningResult ;
    ns1:learningResultCode "RA11" ;
    ns1:learningResultDescription "Saber utilizar una constante de velocidad y predecir cómo afectará a la velocidad de una reacción química las condiciones de operación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504113/2025-26/RA12> a ns1:LearningResult ;
    ns1:learningResultCode "RA12" ;
    ns1:learningResultDescription "Saber distinguir entre la eficacia de un proceso químico desde el punto de vista termodinámico y desde el punto de vista cinético"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504113/2025-26/RA14> a ns1:LearningResult ;
    ns1:learningResultCode "RA14" ;
    ns1:learningResultDescription "Saber proponer procedimientos básicos de síntesis de moléculas orgánicas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504113/2025-26/RA15> a ns1:LearningResult ;
    ns1:learningResultCode "RA15" ;
    ns1:learningResultDescription "Aplicar los conceptos de estereoquímica y quiralidad a biomoléculas simples"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504113/2025-26/RA16> a ns1:LearningResult ;
    ns1:learningResultCode "RA16" ;
    ns1:learningResultDescription "Disponer de una base que permita comprender los fundamentos fisicoquímicos que gobiernan la estructura molecular de biomoléculas y de sus principales reacciones en condiciones fisiológicas o de interés en procesos biotecnológicos"@es .

