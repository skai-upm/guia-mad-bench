    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Cinética Química ."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504113/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Velocidad de reacción: factores de los que depende. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504113/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "2.2. Catálisis homogénea y heterogénea. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504113/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "2.3. Catálisis enzimática. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504113/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "2.4. Sesion de laboratorio 2. . Determinación de parámetros cinéticos químicos característicos en una catálisis homogénea de interés en Biotecnología Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504113/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "3. Enlace químico en sistemas moleculares."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504113/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "3.1. Teoría de enlace de valencia. Geometría molecular. Resonancia.Polaridad de enlace. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504113/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "3.2. Uniones intermoleculares y su influencia en sistemas moleculares. Estados de agregación de los sistemas moleculares. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504113/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "4. Química del carbono y estereoisomería de compuestos orgánicos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504113/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "4.1. Grupos funcionales. Nomenclatura. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504113/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "4.2. Estereoquimica de compuestos orgánicos. Isomería optica. Importancia de los estereoisomeros Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504113/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "4.3. Isomería conformacional. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504113/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Ecuaciones integradas de velocidad. Orden de reacción. Reacciones de orden cero, primer orden, segundo orden. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504113/2025-26/syllabus/20> a ns1:SyllabusItem ;
    ns1:itemIndex 20 ;
    ns1:syllabusDescription "5. Mecanismos en las reacciones orgánicas (Parte I)"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504113/2025-26/syllabus/21> a ns1:SyllabusItem ;
    ns1:itemIndex 21 ;
    ns1:syllabusDescription "5.1. Reacciones de sustitución radicálica, nucleófila y electrófila Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504113/2025-26/syllabus/22> a ns1:SyllabusItem ;
    ns1:itemIndex 22 ;
    ns1:syllabusDescription "5.2. Reacciones de eliminación Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504113/2025-26/syllabus/23> a ns1:SyllabusItem ;
    ns1:itemIndex 23 ;
    ns1:syllabusDescription "5.3. Sesión de laboratorio 3: Determinación de la pureza de una biomolécula mediante polarimetría. Aislamiento y purificación de biomoléculas en sistemas complejos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504113/2025-26/syllabus/24> a ns1:SyllabusItem ;
    ns1:itemIndex 24 ;
    ns1:syllabusDescription "6. Mecanismos en las reacciones orgánicas (Parte II)"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504113/2025-26/syllabus/25> a ns1:SyllabusItem ;
    ns1:itemIndex 25 ;
    ns1:syllabusDescription "6.1. Reacciones de adición nucleófila y electrófila Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504113/2025-26/syllabus/26> a ns1:SyllabusItem ;
    ns1:itemIndex 26 ;
    ns1:syllabusDescription "6.2. Reacciones de oxidación y reducción Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504113/2025-26/syllabus/27> a ns1:SyllabusItem ;
    ns1:itemIndex 27 ;
    ns1:syllabusDescription "7. Principales reacciones orgánicas aplicadas a la Biotecnología"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504113/2025-26/syllabus/28> a ns1:SyllabusItem ;
    ns1:itemIndex 28 ;
    ns1:syllabusDescription "7.1. Reacciones de Alcoholes Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504113/2025-26/syllabus/29> a ns1:SyllabusItem ;
    ns1:itemIndex 29 ;
    ns1:syllabusDescription "7.2. Reacciones de compuestos carbonílicos y carboxilicos Sin subniveles"@es .

