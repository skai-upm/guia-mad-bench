    ns1:itemIndex 31 ;
    ns1:syllabusDescription "7.4. Sesión de laboratorio 4: Identificación de grupos funcionales y de moléculas orgánicas de interés biotecnológico Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504113/2025-26/syllabus/32> a ns1:SyllabusItem ;
    ns1:itemIndex 32 ;
    ns1:syllabusDescription "8. Síntesis de moléculas orgánicas de interés en Biotecnología"@es .

