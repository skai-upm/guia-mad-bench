    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/583000043/2025-26/RA32>,
        <https://guia-kg.skai.etsisi.upm.es/resource/583000043/2025-26/RA62>,
        <https://guia-kg.skai.etsisi.upm.es/resource/583000043/2025-26/RA67>,
        <https://guia-kg.skai.etsisi.upm.es/resource/583000043/2025-26/RA68>,
        <https://guia-kg.skai.etsisi.upm.es/resource/583000043/2025-26/RA69>,
        <https://guia-kg.skai.etsisi.upm.es/resource/583000043/2025-26/RA70>,
        <https://guia-kg.skai.etsisi.upm.es/resource/583000043/2025-26/RA71>,
        <https://guia-kg.skai.etsisi.upm.es/resource/583000043/2025-26/RA72> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/583000043/2025-26/syllabus> ;
    ns1:inpersonHours "41 horas y 45 minutos (51.5%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation """La asignatura se relaciona con los ODS4, ODS9 y ODS11.
Los alumnos que deseen realizar su Trabajo Fin de Máster relacionado con la asignatura deberán ponerse en contacto con el coordinador durante el mes de septiembre. Aunque el TFM corresponde al segundo semestre, la asignatura se imparte en el primer semestre y debe comenzarse su preparación a la vez que la asignatura."""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "41 horas y 45 minutos"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/583000043/2025-26/eventSchedule> ;
    schema:description """La asignatura aborda el funcionamiento y la aplicación de los diferentes sistemas inteligentes de transporte y su aplicación en el ámbito de la explotación de infraestructuras de transporte y logística.
El temario se plantea abarcando todos los sistemas existentes en el ámbito del transporte, ilustrando los conceptos teóricos con experiencias reales.
La asignatura se impartirá a través lecciones magistrales por parte de los profesores orientadas especialmente a casos prácticos y de aplicación. Al finalizar cada sesión se realizará una breve prueba de control escrita (test, preguntas cortas o pequeños ejercicio) con el fin de evaluar el nivel de comprensión de los conocimientos impartidos, y como parte importante del sistema de evaluación continua progresiva. Como parte práctica, tras los temas teóricos, se incluyen dos visitas a instalaciones de ITS en Madrid. Las instalaciones a visitar y las fechas concretas se confirmarán durante el semestre.
Los alumnos deberán realizar un trabajo de investigación individual sobre sistemas inteligentes de transporte, que una vez corregido deberán exponer y defender en clase."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/rafael.enriquez%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/carlos.romeromorales%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/david.delvillar%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/j.vaca%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/josemanuel.vassallo%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/jr.ballesteros%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/manuel.romana%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/mariaamor.ariza%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/natalia.sobrino%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/rafael.enriquez%40upm.es> ;
    schema:name "Sistemas Inteligentes de Transporte"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/583000043/2025-26/CE%2002> a ns1:Competency ;
    ns1:competencyCode "CE 02" ;
    ns1:competencyDescription "Capacidad para la gestión, dentro de equipos multidisciplinares, de aspectos relacionados con la planificación, ejecución o explotación de infraestructuras"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/583000043/2025-26/CE%2005> a ns1:Competency ;
    ns1:competencyCode "CE 05" ;
    ns1:competencyDescription "Capacidad para la gestión, dentro de equipos multidisciplinares, en lo relacionado a la planificación estratégica, siguiendo criterios de calidad y medioambientales, de aspectos relacionados con la dirección, coordinación y gestión técnica y económica de proyectos en todos los ámbitos de las infraestructuras"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/583000043/2025-26/CE%2009> a ns1:Competency ;
    ns1:competencyCode "CE 09" ;
    ns1:competencyDescription "Capacidad para la formación continuada en relación a los diferentes tipos de infraestructuras, proporcionando una formación avanzada y competencias en la aplicación tecnológica y de ingeniería en el ámbito de las infraestructuras Terrestres."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/583000043/2025-26/CG%2004> a ns1:Competency ;
    ns1:competencyCode "CG 04" ;
    ns1:competencyDescription "Capacidad para el análisis y la toma de decisiones relacionada con la dirección general, dirección técnica y dirección de proyectos, desarrollo e innovación, en empresas y centros tecnológicos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/583000043/2025-26/CG%2005> a ns1:Competency ;
    ns1:competencyCode "CG 05" ;
    ns1:competencyDescription "Capacidad para la puesta en marcha, dirección y gestión de planificación y gestión de infraestructuras, etc., en el ámbito de la ingeniería civil y de infraestructuras con garantía de seguridad para las personas y bienes, con calidad final de las infraestructuras"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/583000043/2025-26/RA32> a ns1:LearningResult ;
    ns1:learningResultCode "RA32" ;
    ns1:learningResultDescription "Examinar los Sistemas Inteligentes de Transporte, su funcionamiento y aplicación en la gestión de infraestructuras de transporte."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/583000043/2025-26/RA62> a ns1:LearningResult ;
    ns1:learningResultCode "RA62" ;
    ns1:learningResultDescription "Identificar, formular y resolver problemas complejos con aplicación de soluciones en áreas nuevas y emergentes como los sistemas inteligentes de transporte"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/583000043/2025-26/RA67> a ns1:LearningResult ;
    ns1:learningResultCode "RA67" ;
    ns1:learningResultDescription "Conocimiento y comprensión de los sistemas inteligentes de transporte en relación con la planificación y la gestión de infraestructuras."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/583000043/2025-26/RA68> a ns1:LearningResult ;
    ns1:learningResultCode "RA68" ;
    ns1:learningResultDescription "Poseer, con sentido crítico, los conocimientos de vanguardia sobre los sistemas inteligentes de transporte."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/583000043/2025-26/RA69> a ns1:LearningResult ;
    ns1:learningResultCode "RA69" ;
    ns1:learningResultDescription "Conceptualizar productos, procesos y sistemas de ingeniería utilizados en la planificación y la gestión de infraestructuras mediante los sistemas inteligentes de transporte."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/583000043/2025-26/RA70> a ns1:LearningResult ;
    ns1:learningResultCode "RA70" ;
    ns1:learningResultDescription "Capacidad para investigar sobre la aplicación de las tecnologías emergentes relacionadas con los sistemas inteligentes de transporte."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/583000043/2025-26/RA71> a ns1:LearningResult ;
    ns1:learningResultCode "RA71" ;
    ns1:learningResultDescription "Comprensión global de las técnicas y métodos de análisis, diseño e investigación sobre los sistemas inteligentes de transporte aplicados a la planificación y la gestión de infraestructuras, así como sus limitaciones."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/583000043/2025-26/RA72> a ns1:LearningResult ;
    ns1:learningResultCode "RA72" ;
    ns1:learningResultDescription "Comprensión global de los materiales, equipamiento, herramientas, tecnologías y procesos de ingeniería sobre los sistemas inteligentes de transporte aplicados a la planificación y la gestión de infraestructuras, así como sus limitaciones."@es .

