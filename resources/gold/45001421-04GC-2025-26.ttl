<https://guia-kg.skai.etsisi.upm.es/resource/45001421/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/45001421/2025-26/CM32.1>,
