    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. UT1. Geoinformación aplicada a la Agricultura"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000199/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Datos geoespaciales en un SIG. Geoportales, Visores e IDEs Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000199/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "3. UT3. Observación del Territorio. Teledetección"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000199/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "3.1. Evolución de los Sistemas de Teledetección en Agricultura Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000199/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "3.2. Procesado de datos provenientes de Sistemas de Observación de la Tierra Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000199/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "3.3. Índices de vegetación. Cálculo, análisis y seguimiento de los cambios en los cultivos Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000199/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "3.4. Aplicación de Machine Learning (ML) en el procesado de datos provenientes de Sistemas de Observación de la Tierra Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000199/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Análisis de la información espacial Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000199/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "1.3. Visualización de datos Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000199/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "1.4. Geotrazabilidad. Algunas aplicaciones y desarrollos. Cuadernos digitales de campo Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000199/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "2. UT2. Modelos de datos tridimensionales con tecnologías geoespaciales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000199/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "2.1. Equipos y Sistemas geomáticos como base de la información del Modelado Tridimensional. Sistemas fotogramétricos y técnica LÍDAR. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000199/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "2.2. Modelado Tridimensional en Sistemas Agroforestal Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000199/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "2.3. Geovisualización. Realidad Aumentada, Virtual Inmersiva y Mixta Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000199/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "2.4. Aplicaciones de técnicas LIDAR en el ámbito agroforestal. Integración de Sistemas y procesamiento combinado Sin subniveles"@es .

