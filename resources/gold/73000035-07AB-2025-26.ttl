    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/73000035/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/73000035/2025-26/RA30>,
        <https://guia-kg.skai.etsisi.upm.es/resource/73000035/2025-26/RA31>,
        <https://guia-kg.skai.etsisi.upm.es/resource/73000035/2025-26/RA32>,
        <https://guia-kg.skai.etsisi.upm.es/resource/73000035/2025-26/RA33>,
        <https://guia-kg.skai.etsisi.upm.es/resource/73000035/2025-26/RA36>,
        <https://guia-kg.skai.etsisi.upm.es/resource/73000035/2025-26/RA37> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/73000035/2025-26/syllabus> ;
    ns1:inpersonHours "28 horas (35.9%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation """Las competencias y resultados de aprendizaje correspondientes a la memoria Verifica actual del título https://blogs.upm.es/incendios/wp-content/uploads/sites/1107/2024/02/MemoriaIncendios2023.pdf


La asignatura es online. Esta asignatura está relacionada con Objetivo 15 de Desarrollo sostenible (ODS15): Gestionar sosteniblemente los bosques, luchar contra la desertificación, detener e invertir la degradación de las tierras, detener la pérdida de biodiversidad"""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "30 horas y 30 minutos"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/73000035/2025-26/eventSchedule> ;
    schema:description """El objetivo de esta asignatura es que el alumno adquiera una comprensión profunda del comportamiento del fuego en entornos forestales incluyendo:
Los principios básicos de la combustión y la propagación del fuego forestal
Tipologías de incendios forestales
Los factores que influyen en su desarrollo, como la meteorología, la topografía y los tipos de combustible vegetal
Uso de simuladores de comportamiento y manejo del fuego, incluyendo quemas prescritas."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/javier.gonzalezr%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/javier.gonzalezr%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/javier.madrigal%40upm.es> ;
    schema:name "Comportamiento del Fuego"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/73000035/2025-26/CE%201.1> a ns1:Competency ;
    ns1:competencyCode "CE 1.1" ;
    ns1:competencyDescription "Capacidad para la identificación y descripción cualitativa de los impactos ambientales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/73000035/2025-26/CE%201.3> a ns1:Competency ;
    ns1:competencyCode "CE 1.3" ;
    ns1:competencyDescription "Capacidad para identificar y valorar cualitativamente los riesgos naturales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/73000035/2025-26/CE%203.1> a ns1:Competency ;
    ns1:competencyCode "CE 3.1" ;
    ns1:competencyDescription "Capacidad para diseñar y analizar modelos matemáticos, estadísticos y espaciales que simulen fenómenos naturales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/73000035/2025-26/CG%203> a ns1:Competency ;
    ns1:competencyCode "CG 3" ;
    ns1:competencyDescription "Capacidad crítica para el análisis, la síntesis y el aprendizaje mediante el intercambio de opiniones, presentando argumentos sólidos y estructurados"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/73000035/2025-26/CG%207> a ns1:Competency ;
    ns1:competencyCode "CG 7" ;
    ns1:competencyDescription "Utilización de las TICs para el trabajo cooperativo y el trabajo en equipo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/73000035/2025-26/RA30> a ns1:LearningResult ;
    ns1:learningResultCode "RA30" ;
    ns1:learningResultDescription "Capacidad para la redacción, dirección y ejecución de proyectos de investigación aplicados al medio forestal"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/73000035/2025-26/RA31> a ns1:LearningResult ;
    ns1:learningResultCode "RA31" ;
    ns1:learningResultDescription "Que los estudiantes hayan demostrado poseer y comprender conocimientos para la interpretación crítica de textos científicos especializados (tanto en español como en inglés)"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/73000035/2025-26/RA32> a ns1:LearningResult ;
    ns1:learningResultCode "RA32" ;
    ns1:learningResultDescription "Que los estudiantes sepan aplicar sus conocimientos a su trabajo de una forma profesional por medio de la elaboración y defensa de argumentos y la resolución de problemas dentro del área."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/73000035/2025-26/RA33> a ns1:LearningResult ;
    ns1:learningResultCode "RA33" ;
    ns1:learningResultDescription "Que los estudiantes tengan la capacidad de reunir e interpretar datos relevantes dentro del área de estudio, para emitir juicios relevantes de índole social, científica o ética"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/73000035/2025-26/RA36> a ns1:LearningResult ;
    ns1:learningResultCode "RA36" ;
    ns1:learningResultDescription "· Conocimientos amplios sobre las variables que determinan la ignición de un incendio y la propagacion del mismo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/73000035/2025-26/RA37> a ns1:LearningResult ;
    ns1:learningResultCode "RA37" ;
    ns1:learningResultDescription "Capacidad para valorar el riesgo de incendio de acuerdo a las variables que lo determinan"@es .

