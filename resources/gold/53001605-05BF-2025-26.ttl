<https://guia-kg.skai.etsisi.upm.es/resource/53001605/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. MÓDULO I INTRODUCCIÓN Y CONCEPTOS BÁSICOS"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001605/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Los principios fundamentales de la seguridad nuclear y su aplicación. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001605/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "4. MÓDULO IV: INTRODUCCIÓN A LOS ACCIDENTES EN CC.NN."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001605/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "4.1. Accidentes en centrales nucleares. Clasificación. Metodologías de análisis determinista y probabilista. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001605/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "4.2. Accidentes en reactores tipo PWR:"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001605/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "4.2.1. Accidentes con pérdida de refrigerante (Loss of Coolant Accident, LOCA). Grandes y pequeñas roturas. Roturas de tubos del Generador de Vapor (Steam Generator Tube Rupture, SGTR). Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001605/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "4.2.2. Otros accidentes en PWR: Pérdida total de agua de alimentación. Transitorios de reactividad. Pérdida total de suministro eléctrico (Station Black Out, SBO) Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001605/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "4.3. Introduccción a los accidentes severos en reactores de agua ligera Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001605/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "4.4. Accidentes históricos en centrales nucleares: TMI-2; Chernóbil; Fukushima Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001605/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. El concepto de riesgo y la cuantificación de la seguridad Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001605/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "2. MÓDULO II ACUMULACIÓN Y LIBERACIÓN DE RADIACTIVIDAD EN LAS CC.NN."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001605/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "2.1. La acumulación de productos radiactivos en el reactor nuclear Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001605/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "2.2. El balance de radiactividad en el refrigerante de una central nuclear Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001605/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "2.3. La descarga de radiactividad al medio ambiente Sin subniveles"@es .

