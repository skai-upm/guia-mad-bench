    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. INTRODUCCIÓN A LA AEROELASTICIDAD"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145007506/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Triangulo de Collar Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145007506/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "3.4. Aeroservoelasticidad. Sistemas de control con realimentación. Bucle abierto y bucle cerrado. Criterios de estabilidad. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145007506/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "4. AEROELASTICIDAD EXPERIMENTAL"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145007506/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "4.1. Introducción Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145007506/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "4.2. Ensayos en tierra Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145007506/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "4.3. Ensayos en vuelo Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145007506/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Velocidades críticas Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145007506/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "2. AEROELASTICIDAD ESTÁTICA DEL PERFIL"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145007506/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "2.1. Fenómenos aeroelásticos estáticos Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145007506/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "2.2. Ala bidimensional. Divergencia torsional. Inversión y efectividad del mando Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145007506/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "3. AEROELASTICIDAD DINÁMICA DEL PERFIL"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145007506/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "3.1. Aeroelasticidad dinámica. Flameo. Sistemas de tres grados de libertad. Métodos de obtención de la velocidad y frecuencia de flameo. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145007506/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "3.2. Teoría del perfil oscilante en una corriente incompresible. Ecuaciones generales. Función de Theodorsen. Aerodinámica cuasi-estacionaria. Cálculo de flameo. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145007506/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "3.3. Aeroelasticidad dinámica. Ráfagas. Respuesta dinámica de un perfil a una ráfaga discreta. Función de Wagner. Función de Küssner. Función de Sears. Bataneo de una superficie sustentadora. Sin subniveles"@es .

