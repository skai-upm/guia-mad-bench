<https://guia-kg.skai.etsisi.upm.es/resource/305000111/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Algoritmos, problemas y su complejidad."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000111/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Algoritmos: definición y descripción. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000111/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "3.1. Conceptos básicos. Familias más importantes. Representación de grafos. Resultados básicos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000111/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "3.2. Grafos eulerianos. Propiedades, caracterización y algoritmos de construcción de recorridos eulerianos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000111/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "3.3. Grafos hamiltonianos. El problema del cartero. Propiedades de grafos hamiltonianos. El problema del viajante. Algoritmos aproximados. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000111/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "4. Árboles."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000111/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "4.1. Algoritmos de búsqueda y árboles generadores. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000111/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "4.2. Distancias y algoritmos de caminos mínimos. Conectividad por vértices y aristas. Orientabilidad. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000111/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "5. Aplicaciones en grafos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000111/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "5.1. Flujos en redes. Emparejamientos. Capacidad de una red. Teorema de Ford- Fulkerson. Algoritmo de etiquetado. Conectividad y flujos. Emparejamientos en grafos bipartitos. Teorema de Hall. Estabilidad. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000111/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "5.2. Planaridad y coloración de grafos. Grafos planos. Fórmula de Euler. Caracterizaciones de la planaridad. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000111/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Complejidad de algoritmos. Complejidad en tiempo y espacio. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000111/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "1.3. Algoritmos y problemas. Complejidad de problemas. Clases de complejidad: problemas P y NP. Problemas tipo de la clase NP. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000111/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "2. Recurrencias y complejidad."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000111/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "2.1. Ecuaciones en recurrencias. Clasificación. Relación con los algoritmos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000111/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "2.2. Resolución de recurrencias lineales homogéneas y no homogéneas con coeficientes constantes. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000111/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "2.3. Recurrencias no lineales. Algoritmos recursivos y su complejidad. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000111/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "2.4. Funciones generatrices. Aplicación a la resolución de recurrencias y al análisis de complejidad de algoritmos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000111/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "3. Grafos."@es .

