    ns1:itemIndex 15 ;
    ns1:syllabusDescription "4.3. Metales de transición. Obtención y propiedades. Estabilidad relativa de los diferentes estados de oxidación Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000446/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "4.4. Compuestos de coordinación. Nomenclatura. Isomería. Teorías de enlace. Aplicaciones más importantes Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000446/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "5. ESTRUCTURA DE LAS MOLÉCULAS ORGÁNICAS E ISOMERÍA"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000446/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "5.1. Hibridación del átoimo de carbono. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000446/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "5.2. Nomenclatura de los compuestos orgánicos Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000446/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Enlace químico. Geometría molecular. Momentos dipolares. Fuerzas intermoleculares. Enlace de hidrógeno. Estado líquido. Estructura y propiedades de los sólidos. Sin subniveles"@es .

