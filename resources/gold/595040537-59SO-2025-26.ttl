<https://guia-kg.skai.etsisi.upm.es/resource/595040537/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Introduction to quantum physics and quantum computing"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595040537/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. From the bit to the qbit Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595040537/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "3.1. Introduction to Quantum Gates. Unitary operation over qubit states Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595040537/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "3.2. 1-qubit quantum gate: Pauli gate Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595040537/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "3.3. 2-qubits quantum gates: Hadamard and CNOT Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595040537/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "3.4. 3-qubits quantum gate: Toffoli gate Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595040537/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "4. Quantum circuits"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595040537/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "4.1. Introduction to quantum gate notation and basic quantum circuits Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595040537/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "4.2. Usage of Quirk (Quantum Circuit Simulator) Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595040537/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "4.3. Construction of a Toffoli gate by means of CNOT gates Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595040537/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "4.4. Simple quantum circuits for increasing and decreasing Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595040537/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "4.5. A very basic introduction to the ?de-facto? standard (Python) qiskit framework Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595040537/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Kroneker (or tensor) product Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595040537/2025-26/syllabus/20> a ns1:SyllabusItem ;
    ns1:itemIndex 20 ;
    ns1:syllabusDescription "4.6. Some quantum gate based algorithms: Quantum teleportation, Schorr?s algorithm and Grover?s search algorithm Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595040537/2025-26/syllabus/21> a ns1:SyllabusItem ;
    ns1:itemIndex 21 ;
    ns1:syllabusDescription "5. Quantum annealing"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595040537/2025-26/syllabus/22> a ns1:SyllabusItem ;
    ns1:itemIndex 22 ;
    ns1:syllabusDescription "5.1. Introduction to the concept of quantum annealing Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595040537/2025-26/syllabus/23> a ns1:SyllabusItem ;
    ns1:itemIndex 23 ;
    ns1:syllabusDescription "5.2. Introduction to the Satisfiability Problem Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595040537/2025-26/syllabus/24> a ns1:SyllabusItem ;
    ns1:itemIndex 24 ;
    ns1:syllabusDescription "5.3. Choice of Hamiltonians and interpolation functions to solve a SAT problem via quantum annealing Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595040537/2025-26/syllabus/25> a ns1:SyllabusItem ;
    ns1:itemIndex 25 ;
    ns1:syllabusDescription "5.4. Simulation of simple quantum annealing in qiskit Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595040537/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "1.3. The computational basis Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595040537/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "2. Quantum states"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595040537/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "2.1. Quantum states, entanglement Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595040537/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "2.2. The spin 1/2 system. The Bloch sphere Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595040537/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "2.3. Hermitian operators and observables. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595040537/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "2.4. Measurement Sin subniveles"@es .

