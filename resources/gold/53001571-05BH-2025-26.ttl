    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/53001571/2025-26/eventSchedule> ;
    schema:description """La asignatura se centra en la adquisición de conocimientos y habilidades para la implementación de tecnologías y aplicaciones domóticas, de forma principalmente práctica.
Como metodología docente, los profesores desarrollarán parte de los temas de forma descriptiva y los alumnos realizarán ejemplos, utilizando los equipos necesarios, para aplicar lo aprendido.
Se considera fundamental la asistencia a clase. Salvo causa de fuerza mayor justificada, será obligatorio acudir a las presentaciones de trabajos de otros grupos."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/paloma.delapuente%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/alberto.brunete%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/paloma.delapuente%40upm.es> ;
    schema:name "Domótica. Entornos Inteligentes"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001571/2025-26/CB07> a ns1:Competency ;
    ns1:competencyCode "CB07" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en entornos nuevos o poco conocidos dentro de contextos más amplios (o multidisciplinares) relacionados con su área de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001571/2025-26/CE06> a ns1:Competency ;
    ns1:competencyCode "CE06" ;
    ns1:competencyDescription "Capacidad para aplicar técnicas de automatización en sistemas industriales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001571/2025-26/CG03> a ns1:Competency ;
    ns1:competencyCode "CG03" ;
    ns1:competencyDescription "Aplicar los conocimientos adquiridos y resolver problemas en entornos nuevos o poco conocidos dentro de contextos más amplios y multidisciplinares"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001571/2025-26/CT01> a ns1:Competency ;
    ns1:competencyCode "CT01" ;
    ns1:competencyDescription "Aplica. Habilidad para aplicar conocimientos científicos, matemáticos y tecnológicos en sistemas relacionados con la práctica de la ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001571/2025-26/CT08> a ns1:Competency ;
    ns1:competencyCode "CT08" ;
    ns1:competencyDescription "Entiende los impactos. Educación amplia necesaria para entender el impacto de las soluciones ingenieriles en un contexto social global"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001571/2025-26/RA33> a ns1:LearningResult ;
    ns1:learningResultCode "RA33" ;
    ns1:learningResultDescription "El alumno debe disponer de conocimientos amplios sobre tecnologías aplicables en el entorno de la domótica, tanto en sensórica como en dispositivos de actuación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001571/2025-26/RA34> a ns1:LearningResult ;
    ns1:learningResultCode "RA34" ;
    ns1:learningResultDescription "El alumno debe ser capaz de plantear soluciones plausibles a problemas de creación de entornos inteligentes en diferentes situaciones ambientales"@es .

