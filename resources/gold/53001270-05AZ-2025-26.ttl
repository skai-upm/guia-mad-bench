    ns1:competencyCode "(l)" ;
    ns1:competencyDescription "ES BILINGÜE. Capacidad de trabajar en un entorno bilingüe (inglés/castellano)."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001270/2025-26/%28m%29> a ns1:Competency ;
