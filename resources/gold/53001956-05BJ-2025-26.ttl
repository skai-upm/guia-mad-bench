    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/53001956/2025-26/eventSchedule> ;
    schema:description "La asignatura expone las herramientas de diseño conceptual que permiten discriminar desde el principio del ciclo de vida del producto y del proceso (etapa de diseño preliminar) qué diseños de ingeniería pueden al mismo tiempo minimizar los costes de diseño, aumentar la prestaciones y asegurar los beneficios y el posicionamiento estratégico de la empresa de un modo sostenible a largo plazo. La asignatura está confeccionada de modo que las teorías de decisión se construyan de un modo crítico, desde unos fundamentos básicos hasta unos principios prácticos que permitan hacer juicios de valor sobre productos y procesos. La asignatura hará hincapié en el Diseño Axiomático y en el Métrico."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/efren.moreno%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/angel.mendez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/efren.moreno%40upm.es> ;
    schema:name "Diseño y Producción Sostenible"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001956/2025-26/CB07> a ns1:Competency ;
    ns1:competencyCode "CB07" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en entornos nuevos o poco conocidos dentro de contextos más amplios (o multidisciplinares) relacionados con su área de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001956/2025-26/CB08> a ns1:Competency ;
    ns1:competencyCode "CB08" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de integrar conocimientos y enfrentarse a la complejidad de formular juicios a partir de una información que, siendo incompleta o limitada, incluya reflexiones sobre las responsabilidades sociales y éticas vinculadas a la aplicación de sus conocimientos y juicios"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001956/2025-26/CE06> a ns1:Competency ;
    ns1:competencyCode "CE06" ;
    ns1:competencyDescription "Capacidad para aplicar las teorías de diseño sostenible a los procesos de diseño de productos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001956/2025-26/CE07> a ns1:Competency ;
    ns1:competencyCode "CE07" ;
    ns1:competencyDescription "Habilidad para profundizar en el conocimiento del aprovechamiento de los recursos energéticos y sus implicaciones."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001956/2025-26/CE08> a ns1:Competency ;
    ns1:competencyCode "CE08" ;
    ns1:competencyDescription "Capacidad de comprensión y dominio de la legislación y normativa nacional e internacional y su aplicación para la resolución de problemas propios de la ingeniería ambiental."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001956/2025-26/CG01> a ns1:Competency ;
    ns1:competencyCode "CG01" ;
    ns1:competencyDescription "Capacidad de analizar, evaluar y sintetizar algunas ideas nuevas y complejas de una manera crítica en la rama de la ingeniería ambiental."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001956/2025-26/CG03> a ns1:Competency ;
    ns1:competencyCode "CG03" ;
    ns1:competencyDescription "Capacidad para concebir, diseñar y analizar situaciones complejas en esta rama de la ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001956/2025-26/CG04> a ns1:Competency ;
    ns1:competencyCode "CG04" ;
    ns1:competencyDescription "Capacidad para la toma de decisiones y la emisión de juicios ante el estudio de casos reales presentados por el profesorado en la forma práctica, científica y profesional."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001956/2025-26/CG05> a ns1:Competency ;
    ns1:competencyCode "CG05" ;
    ns1:competencyDescription "Capacidad para comunicar correcta y adecuadamente las conclusiones obtenidas mediante la exposición del análisis de casos prácticos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001956/2025-26/CT01> a ns1:Competency ;
    ns1:competencyCode "CT01" ;
    ns1:competencyDescription "Aplica. Habilidad para aplicar conocimientos científicos, matemáticos y tecnológicos en sistemas relacionados con la práctica de la ingeniería ambiental."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001956/2025-26/CT03> a ns1:Competency ;
    ns1:competencyCode "CT03" ;
    ns1:competencyDescription "Diseña. Habilidad para diseñar un sistema, componente o proceso que alcance los requisitos deseados teniendo en cuenta restricciones realistas tales como las económicas, medioambientales, sociales, políticas, éticas, de salud y seguridad, de fabricación y de sostenibilidad."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001956/2025-26/CT04> a ns1:Competency ;
    ns1:competencyCode "CT04" ;
    ns1:competencyDescription "Trabaja en equipo. Habilidad para trabajar en equipos multidisciplinares."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001956/2025-26/CT05> a ns1:Competency ;
    ns1:competencyCode "CT05" ;
    ns1:competencyDescription "Resuelve. Habilidad para identificar, formular y resolver problemas de ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001956/2025-26/CT07> a ns1:Competency ;
    ns1:competencyCode "CT07" ;
    ns1:competencyDescription "Comunica. Habilidad para comunicar eficazmente."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001956/2025-26/RA18> a ns1:LearningResult ;
    ns1:learningResultCode "RA18" ;
    ns1:learningResultDescription "Preparar la toma de decisiones fomentando su capacidad para realizar juicios holísticos que incrementen el desarrollo sostenible en los diseños realizados"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001956/2025-26/RA19> a ns1:LearningResult ;
    ns1:learningResultCode "RA19" ;
    ns1:learningResultDescription "Conocer teorías universales para el diseño conceptual sostenible tanto en procesos como en productos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001956/2025-26/RA20> a ns1:LearningResult ;
    ns1:learningResultCode "RA20" ;
    ns1:learningResultDescription "Desarrollar habilidades y aptitudes para evaluar críticamente soluciones estratégicas durante el diseño conceptual"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001956/2025-26/didactic_resource/1> a ns1:DidacticResource ;
    ns1:bibliographyTitle "Advanced Engineering Design: an integrated approach"@es ;
    ns1:bibliographyType "Bibliografía"@es .

