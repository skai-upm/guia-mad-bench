<https://guia-kg.skai.etsisi.upm.es/resource/53001593/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/53001593/2025-26/CB07>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001593/2025-26/CE01>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001593/2025-26/CE02>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001593/2025-26/CG02>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001593/2025-26/CG03>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001593/2025-26/CT01>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001593/2025-26/CT04>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001593/2025-26/CT11> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/53001593/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001593/2025-26/didactic_resource/2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001593/2025-26/didactic_resource/3>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001593/2025-26/didactic_resource/4> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/53001593/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/53001593/2025-26/RA32>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001593/2025-26/RA33>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001593/2025-26/RA34> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/53001593/2025-26/syllabus> ;
    ns1:inpersonHours "31 horas y 40 minutos (40.6%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation "La asignatura se relaciona con el ODS7, ODS9 y ODS13"@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "31 horas y 40 minutos"@es ;
    schema:activitiesWorkload "187%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/53001593/2025-26/eventSchedule> ;
    schema:description "Se presentan métodos numéricos, y el correspondiente software que implementan estos métodos, para el estudio de materia con atas densidades de energía (HEDP) e intermedias (WDM). La primera parte de la asignatura trata de diferentes leyes de conservación: las ecuaciones de fluidodinámica y las ecuaciones de Maxwell. Finalmente se explican los fundamentos básficos de la teoría del funcional de densidad, con especial énfasis en paquetes de software que se utilizan actualmente para distintas aplicaciones desdeel estudio de catalizadores, fármacos, optimización de reacciones químicas y propiedades de plasmas característicos de WDM."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/pedro.velarde%40upm.es> ;
    schema:inLanguage "Inglés"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/eduardo.oliva%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/manuel.cotelo%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/pedro.velarde%40upm.es> ;
    schema:name "Métodos Numéricos Avanzados"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001593/2025-26/CB07> a ns1:Competency ;
    ns1:competencyCode "CB07" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en entornos nuevos o poco conocidos dentro de contextos más amplios (o multidisciplinares) relacionados con su área de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001593/2025-26/CE01> a ns1:Competency ;
    ns1:competencyCode "CE01" ;
    ns1:competencyDescription "Entiende a fondo las leyes básicas y avanzadas de la física atómica y nuclear y las ciencias de la ingeniería pertinentes aplicables a la tecnología de las plantas de energía nuclear de fisión y/o fusión"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001593/2025-26/CE02> a ns1:Competency ;
    ns1:competencyCode "CE02" ;
    ns1:competencyDescription "Es capaz de realizar análisis matemático avanzado y simulación numérica de los diferentes procesos y sistemas de la física y de la ingeniería de los reactores de energía nuclear de fisión y/o fusión"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001593/2025-26/CG02> a ns1:Competency ;
    ns1:competencyCode "CG02" ;
    ns1:competencyDescription "Realizar investigación, desarrollo e innovación en procesos y métodos aplicables a los sistemas de fisión o fusión nuclear"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001593/2025-26/CG03> a ns1:Competency ;
    ns1:competencyCode "CG03" ;
    ns1:competencyDescription "Aplicar los conocimientos adquiridos y resolver problemas en entornos nuevos o poco conocidos dentro de contextos más amplios y multidisciplinares"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001593/2025-26/CT01> a ns1:Competency ;
    ns1:competencyCode "CT01" ;
    ns1:competencyDescription "Aplica. Habilidad para aplicar conocimientos científicos, matemáticos y tecnológicos en sistemas relacionados con la práctica de la ingeniería"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001593/2025-26/CT04> a ns1:Competency ;
    ns1:competencyCode "CT04" ;
    ns1:competencyDescription "Trabaja en equipo. Habilidad para trabajar en equipos multidisciplinares"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001593/2025-26/CT11> a ns1:Competency ;
    ns1:competencyCode "CT11" ;
    ns1:competencyDescription "Usa herramientas. Habilidad para usar las técnicas, destrezas y herramientas ingenieriles modernas necesarias para la práctica de la ingeniería"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001593/2025-26/RA32> a ns1:LearningResult ;
    ns1:learningResultCode "RA32" ;
    ns1:learningResultDescription "Conocimiento de los diferentes procesos físicos involucrados en fenómenos de alta densidad de energía."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001593/2025-26/RA33> a ns1:LearningResult ;
    ns1:learningResultCode "RA33" ;
    ns1:learningResultDescription "Conocimiento tanto de los métodos numéricos como del software utilizado para modelizar sistemas de alta densidad de energía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001593/2025-26/RA34> a ns1:LearningResult ;
    ns1:learningResultCode "RA34" ;
    ns1:learningResultDescription "Estudio de sistemas de alta densidad de energía con aplicaciones ingenieriles (Fusión Nuclear por Confinamiento Inercial, interacción de láseres intensos con plasmas, haces intensos de rayos X) con códigos actuales e interpretación de los resultados de dichos códigos."@es .

