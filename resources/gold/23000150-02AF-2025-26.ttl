    ns1:inpersonHours "36 horas (46.2%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation "Esta asignatura se dirige en gran medida a conocer todo el proceso conducente a la definición de la Agenda 2030 y los 17 ODS."@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "46 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/23000150/2025-26/eventSchedule> ;
    schema:description """La búsqueda de una teoría general de desarrollo ha atraído la atención de los economistas durante dos siglos. Hasta hace menos de dos décadas por desarrollo se entendía desarrollo económico. Las teorías de desarrollo se han preocupado de estudiar las potenciales fuentes de crecimiento y como pueden ser integradas en un proceso de transformación que produzca mejoras continuadas en el nivel de vida. En los años 90 en los debates sobre políticas y desarrollo económico se reconoce que el desarrollo es algo más que el crecimiento material y que debe tener objetivos más amplios relativos al bienestar humano. El desarrollo ya no se adjetiva económico y surge el concepto de desarrollo humano. El seminario profundizará en la idea del proyecto de desarrollo basado en el territorio como un proceso de desarrollo con personas, que por lo tanto exige unos modelos de planificación y unas técnicas de evaluación particulares. El enfoque es de seminario de investigación, por lo tanto se espera que sea fundamentalmente el alumno forme parte activa de su aprendizaje a través de las diferentes actividades que se plantearán en torno a cada concepto o tema.
En el 2015, la Asamblea General de las Naciones Unidas adoptó una serie de objetivos para la transformación de Nuestro Mundo: la Agenda 2030 para el Desarrollo Sostenible. La primera parte del Seminario revisará la situación actual de la Agenda de desarrollo y los conceptos y corrientes que de ellas se derivan, así como los principales organismos y mecanismos de obtención y difusión de la información como los Informes de Desarrollo Humano y sus indicadores.
Asimismo se completará el temario abordando el enfoque de proyectos de cooperación como procesos de desarrollo, y sus implicaciones para gestionar y evaluar su sostenibilidad. También una introducción al análisis de redes sociales como instrumento de análisis para la gobernanza.
La segunda parte del Seminario se orienta a experimentar diferentes estrategias de aprendizaje (conferencias, debates, elaboración de reseñas, ...) para profundizar los desafíos del Desarrollo Humano para el siglo XXI:. cambio climático, biodiversidad, nutrición, bosques, agua y océanos, revolución agrícola, migración y ciudades."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/joseluis.yague%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/joseluis.yague%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/manuel.aparicio%40upm.es> ;
    schema:name "Desarrollo Humano"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000150/2025-26/CE42> a ns1:Competency ;
    ns1:competencyCode "CE42" ;
    ns1:competencyDescription "Conocimiento de los conceptos relacionados con el desarrollo humano y de la evaluación y tendencias, con capacidad para analizar e interpretar los indicadores de desarrollo sus potencialidades y carencias desde una perspectiva crítica, y proponer nuevos sistemas de análisis y evaluación del desarrollo humano"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000150/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Habilidades de comunicación escrita y oral: Concluir aportaciones por escrito, desarrollando la capacidad de síntesis y presentación de las ideas propias en un grupo de trabajo y en exposición pública."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000150/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Fortalecer conocimiento oral y escrito de idioma inglés"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000150/2025-26/CG4> a ns1:Competency ;
    ns1:competencyCode "CG4" ;
    ns1:competencyDescription "Capacidad crítica para el análisis, síntesis y aprendizaje mediante el intercambio de opiniones, presentando argumentos sólidos y estructurados"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000150/2025-26/CG5> a ns1:Competency ;
    ns1:competencyCode "CG5" ;
    ns1:competencyDescription "Búsqueda bibliográfica y análisis de documentación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000150/2025-26/CG6> a ns1:Competency ;
    ns1:competencyCode "CG6" ;
    ns1:competencyDescription "Capacidad de gestión de la información procedente de diversas fuentes y de su análisis y síntesis aplicándola a la resolución de problemas complejos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000150/2025-26/CG7> a ns1:Competency ;
    ns1:competencyCode "CG7" ;
    ns1:competencyDescription "Capacidad de trabajo en equipo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000150/2025-26/RA28> a ns1:LearningResult ;
    ns1:learningResultCode "RA28" ;
    ns1:learningResultDescription "Conocer el proceso en la toma de decisiones y los acuerdos alcanzados por los organismos internacionales para el logro de objetivos de Desarrollo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000150/2025-26/RA29> a ns1:LearningResult ;
    ns1:learningResultCode "RA29" ;
    ns1:learningResultDescription "Conocer las pautas para la redacción de reseñas de publicaciones o informes sobre desarrollo humano"@es .

