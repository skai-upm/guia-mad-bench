    schema:name "Programación para Aplicaciones Geoespaciales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/123000723/2025-26/CB10> a ns1:Competency ;
    ns1:competencyCode "CB10" ;
    ns1:competencyDescription "Que los estudiantes posean las habilidades de aprendizaje que les permitan continuar estudiando de un modo que habrá de ser en gran medida autodirigido o autónomo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/123000723/2025-26/CB6> a ns1:Competency ;
    ns1:competencyCode "CB6" ;
    ns1:competencyDescription "Poseer y comprender conocimientos que aporten una base u oportunidad de ser originales en el desarrollo y/o aplicación de ideas, a menudo en un contexto de investigación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/123000723/2025-26/CB7> a ns1:Competency ;
    ns1:competencyCode "CB7" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en entornos nuevos o poco conocidos dentro de contextos más amplios (o multidisciplinares) relacionados con su área de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/123000723/2025-26/CB9> a ns1:Competency ;
    ns1:competencyCode "CB9" ;
    ns1:competencyDescription "Que los estudiantes sepan comunicar sus conclusiones y los conocimientos y razones últimas que las sustentan a públicos especializados y no especializados de un modo claro y sin ambigüedades"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/123000723/2025-26/CE7> a ns1:Competency ;
    ns1:competencyCode "CE7" ;
    ns1:competencyDescription "Analizar, diseñar, construir y mantener algoritmos, bases de datos y sistemas de información eligiendo los procedimientos algorítmicos, modelos de datos y lenguajes de programación más adecuados para resolver problemas del ámbito de la Geomática, considerando robustez, seguridad, complejidad y eficiencia."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/123000723/2025-26/CE9> a ns1:Competency ;
    ns1:competencyCode "CE9" ;
    ns1:competencyDescription "Diseñar y evaluar interfaces persona"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/123000723/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Aplicar conocimientos de ciencias de la Tierra y tecnologías de la información geoespacial en Ingeniería y Arquitectura."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/123000723/2025-26/CT3> a ns1:Competency ;
    ns1:competencyCode "CT3" ;
    ns1:competencyDescription "Ser capaz de resolver de forma nueva y original situaciones o problemas en el ámbito de la Ingeniería (Creatividad)."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/123000723/2025-26/RA12> a ns1:LearningResult ;
    ns1:learningResultCode "RA12" ;
    ns1:learningResultDescription "Conocer los modelos de datos y los procedimientos de tratamiento de imágenes ópticas para extraer información de la superficie terrestre."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/123000723/2025-26/RA13> a ns1:LearningResult ;
    ns1:learningResultCode "RA13" ;
    ns1:learningResultDescription "Conocer los modelos de datos y los procedimientos de tratamiento de imágenes radar para extraer información de la superficie terrestre."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/123000723/2025-26/RA14> a ns1:LearningResult ;
    ns1:learningResultCode "RA14" ;
    ns1:learningResultDescription "Conocer las distintas funciones estadísticas, intervalos de confianza y test de hipótesis"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/123000723/2025-26/RA15> a ns1:LearningResult ;
    ns1:learningResultCode "RA15" ;
    ns1:learningResultDescription "Conocer la propagación de varianzas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/123000723/2025-26/RA19> a ns1:LearningResult ;
    ns1:learningResultCode "RA19" ;
    ns1:learningResultDescription "Aplicar las diferentes técnicas de ajuste en distintos problemas relacionados con el tratamiento de la información geomática"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/123000723/2025-26/RA24> a ns1:LearningResult ;
    ns1:learningResultCode "RA24" ;
    ns1:learningResultDescription "Aprender a modelizar flujos cartográficos para el análisis espacial"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/123000723/2025-26/RA3> a ns1:LearningResult ;
    ns1:learningResultCode "RA3" ;
    ns1:learningResultDescription "Comprender el paradigma de la programación basada en eventos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/123000723/2025-26/RA30> a ns1:LearningResult ;
    ns1:learningResultCode "RA30" ;
    ns1:learningResultDescription "Ser capaz de realizar modelos de datos tridimensionales basados en la utilización de sensores geoespaciales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/123000723/2025-26/RA33> a ns1:LearningResult ;
    ns1:learningResultCode "RA33" ;
    ns1:learningResultDescription "Aplicación de las técnicas de orientación externa de sensores fotogramétricos en el ámbito de la fotogrametría."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/123000723/2025-26/RA38> a ns1:LearningResult ;
    ns1:learningResultCode "RA38" ;
    ns1:learningResultDescription "Conocimiento del sistema LiDAR y de las técnicas de clasificación de los ficheros LAS para la obtención directa de la orografía del terreno."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/123000723/2025-26/RA7> a ns1:LearningResult ;
    ns1:learningResultCode "RA7" ;
    ns1:learningResultDescription "Utilizar adecuadamente los entornos de desarrollo con herramientas de libre distribución"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/123000723/2025-26/RA8> a ns1:LearningResult ;
    ns1:learningResultCode "RA8" ;
    ns1:learningResultDescription "Utilizar servidores de software libre para publicar y consumir datos espaciales usando estándares abiertos"@es .

