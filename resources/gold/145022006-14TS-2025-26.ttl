<https://guia-kg.skai.etsisi.upm.es/resource/145022006/2025-26/RA51> a ns1:LearningResult ;
    ns1:learningResultCode "RA51" ;
    ns1:learningResultDescription "Conocimiento general de los distintos materiales no metálicos utilizados en la ingeniería, como son los materiales poliméricos, los materiales termoplásticos, los materiales compuestos,etc"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145022006/2025-26/RA52> a ns1:LearningResult ;
    ns1:learningResultCode "RA52" ;
    ns1:learningResultDescription "Habilidades: Analizar las propiedades, transformaciones y tratamientos de los materiales y su aplicación en ingeniería especialmente en el ámbito aeroespacial,incluyendo los aspectos experimentales en tratamiento de materiales"@es .

