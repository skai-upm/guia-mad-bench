    ns1:bibliographyTitle "Deep learning for Vision Systems, Mohamed Elgendy, Ed. Manning"@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615001039/2025-26/didactic_resource/4> a ns1:DidacticResource ;
