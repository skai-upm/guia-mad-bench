    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/615001039/2025-26/eventSchedule> ;
    schema:description "En esta asignatura se guía a los alumnos en la creación de sus propios proyectos de ciencia de datos, de forma individual y/o en grupo. Se espera una aportación propia y original por parte de cada alumno, que vaya más allá de lo aprendido a lo largo del grado. A modo de ejemplo, esta aportación original se puede realizar ampliando aplicaciones vistas en el grado, abordando temas no vistos anteriormente, creando aplicaciones de interés social o académico, o iniciándose en el proceso de investigación."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/jesus.bobadilla%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/abraham.gutierrez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/jesus.bobadilla%40upm.es> ;
    schema:name "Proyecto de Ciencia de Datos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615001039/2025-26/CB05> a ns1:Competency ;
    ns1:competencyCode "CB05" ;
    ns1:competencyDescription "Que los estudiantes hayan desarrollado aquellas habilidades de aprendizaje necesarias para emprender estudios posteriores con un alto grado de autonomía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615001039/2025-26/CE10> a ns1:Competency ;
    ns1:competencyCode "CE10" ;
    ns1:competencyDescription "Capacidad para aplicar las metodologías y las técnicas adecuadas de análisis y explotación de datos sobre datos disponibles, incluidos los poco estructurados o de estructura compleja (como los que contienen series temporales, los provenientes de redes sociales, etc.), para descubrir nuevas relaciones y proporcionar conocimiento y una comprensión intuitiva precisa y profunda sobre problemas científicos o procesos organizacionales reales y así respaldar la toma de decisiones."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615001039/2025-26/CE11> a ns1:Competency ;
    ns1:competencyCode "CE11" ;
    ns1:competencyDescription "Capacidad para aplicar métodos generales de ciencia de datos e inteligencia artificial para desarrollar software que explote los datos de un dominio concreto científico o de negocio."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615001039/2025-26/CE12> a ns1:Competency ;
    ns1:competencyCode "CE12" ;
    ns1:competencyDescription "Capacidad de comunicar de forma efectiva el proceso de análisis a partir de los datos y la interpretación de los resultados del mismo, seleccionando y utilizando para ello las técnicas y herramientas de visualización de datos más adecuadas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615001039/2025-26/CG01> a ns1:Competency ;
    ns1:competencyCode "CG01" ;
    ns1:competencyDescription "Capacidad de trabajo en equipo, en entornos interdisciplinares y complejos, negociando y resolviendo conflictos, diseñando soluciones eficientes, fiables, robustas y responsables."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615001039/2025-26/RA102> a ns1:LearningResult ;
    ns1:learningResultCode "RA102" ;
    ns1:learningResultDescription "Conocer y aplicar técnicas de preprocesamiento de datos y reducción de dimensionalidad de variables discriminantes"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615001039/2025-26/RA106> a ns1:LearningResult ;
    ns1:learningResultCode "RA106" ;
    ns1:learningResultDescription "Plantea el diseño de sistemas robóticos específicos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615001039/2025-26/RA11> a ns1:LearningResult ;
    ns1:learningResultCode "RA11" ;
    ns1:learningResultDescription "Conocer, comprender y aplicar los conceptos, técnicas y algoritmos básicos de la teoría de grafos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615001039/2025-26/RA114> a ns1:LearningResult ;
    ns1:learningResultCode "RA114" ;
    ns1:learningResultDescription "Modelizar, resolver y analizar la sensibilidad de problemas de programación lineal continua"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615001039/2025-26/RA118> a ns1:LearningResult ;
    ns1:learningResultCode "RA118" ;
    ns1:learningResultDescription "Conocer y aplicar métodos de aprendizaje automático probabilísticos y no probabilísticos, y su combinación mediante ensembles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615001039/2025-26/RA12> a ns1:LearningResult ;
    ns1:learningResultCode "RA12" ;
    ns1:learningResultDescription "Comprender las nociones de complejidad de un algoritmo y de complejidad de un problema y analizar la complejidad de los algoritmos en grafos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615001039/2025-26/RA120> a ns1:LearningResult ;
    ns1:learningResultCode "RA120" ;
    ns1:learningResultDescription "RA96"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615001039/2025-26/RA124> a ns1:LearningResult ;
    ns1:learningResultCode "RA124" ;
    ns1:learningResultDescription "Dado un problema real elegir la tecnología de ciencia de datos o de inteligencia artificial existente en el mercado más apropiada para su solución y diseñar su desarrollo e integración analizando la viabilidad de su solución, lo que se puede y no se puede conseguir a través del estado actual de desarrollo de la tecnología usada, y lo que se espera que avance en el futuro"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615001039/2025-26/RA169> a ns1:LearningResult ;
    ns1:learningResultCode "RA169" ;
    ns1:learningResultDescription "Analizar problemas reales con datos de estructura compleja o poco estructurados (como los que contienen series temporales, los provenientes de redes sociales, etc.)"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615001039/2025-26/RA171> a ns1:LearningResult ;
    ns1:learningResultCode "RA171" ;
    ns1:learningResultDescription "Ser capaz de planificar, gestionar y desarrollar un proyecto de ciencia de datos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615001039/2025-26/RA172> a ns1:LearningResult ;
    ns1:learningResultCode "RA172" ;
    ns1:learningResultDescription "Ser capaz de evaluar y validar los resultados de un proyecto de ciencia de datos y decidir sobre su implantación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615001039/2025-26/didactic_resource/1> a ns1:DidacticResource ;
    ns1:bibliographyTitle "Deep Learning with Python, second edition, F. Chollet, Manning, 2021"@es ;
    ns1:bibliographyType "Bibliografía"@es .

