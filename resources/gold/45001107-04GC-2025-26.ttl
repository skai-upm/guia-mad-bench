    ns1:learningResultCode "RA206" ;
    ns1:learningResultDescription "RA1 Resuelve problemas monográficos de estadística y optimización acordes con el papel de estas disciplinas en ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001107/2025-26/RA207> a ns1:LearningResult ;
    ns1:learningResultCode "RA207" ;
    ns1:learningResultDescription "Selecciona recursos y resuelve problemas combinados de estadística y optimización acordes con el papel de estas disciplinas en ingeniería civil."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001107/2025-26/RA208> a ns1:LearningResult ;
    ns1:learningResultCode "RA208" ;
    ns1:learningResultDescription "Resuelve problemas monográficos de estadística y optimización acordes con el papel de estas disciplinas en ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001107/2025-26/RA209> a ns1:LearningResult ;
    ns1:learningResultCode "RA209" ;
    ns1:learningResultDescription "Argumenta la resolución de problemas mediante la lógica científica y la metodología científica de las disciplinas empleadas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001107/2025-26/didactic_resource/1> a ns1:DidacticResource ;
    ns1:bibliographyDescription "Este libro desarrolla el temario de la asignatura con un gran número de ejemplos, ejercicios resueltos y ejercicios propuestos."@es ;
    ns1:bibliographyTitle "Muruzábal, J.J. y Pérez, D. Estadística y probabilidad en la ingeniería. Ed. Garceta, 2022"@es ;
    ns1:bibliographyType "Bibliografía"@es .

