    schema:hasCourseInstance <https://guia-kg.skai.etsisi.upm.es/resource/105001043/2025-26> ;
    schema:name "Programming For Mobile Devices"@en,
        "Programación para Dispositivos Móviles"@es ;
    schema:numberOfCredits 3.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/105001043/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/105001043/2025-26/CG>,
        <https://guia-kg.skai.etsisi.upm.es/resource/105001043/2025-26/Ce%2044> ;
