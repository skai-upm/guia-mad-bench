<https://guia-kg.skai.etsisi.upm.es/resource/205000001/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Cálculo Diferencial e Integral"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000001/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Funciones: modelos matemáticos. Funciones elementales. Parametrizaciones. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000001/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. La Derivada: razón de cambio. Regla de la cadena. Derivación implícita. Optimización. Aproximación de funciones. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000001/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "1.3. Integración: la integral de Riemann. Teorema Fundamental del Cálculo. Aplicaciones de la integral. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000001/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "2. Álgebra Lineal"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000001/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "2.1. Espacios vectoriales. Subespacios. Generadores e independencia lineal. Bases y dimensión. Coordenadas y cambio de base. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000001/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "2.2. Aplicaciones lineales. Núcleo, imagen matriz asociada. Composición y aplicación inversa. Diagonalización. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000001/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "2.3. Modelos matriciales. Sin subniveles"@es .

