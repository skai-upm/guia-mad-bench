    schema:description "La asignatura consta, por una parte, del Cálculo Diferencial e Integral y sus aplicaciones en diferentes contextos de la realidad y, por otra, de Álgebra Lineal con aplicaciones a modelos matriciales en sistemas evolutivos, que se aplican en Biología, Ecología y otros ámbitos."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/carlos.garciagutierrez%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/carlos.garciagutierrez%40upm.es> ;
    schema:name "Matemáticas I"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000001/2025-26/CB02> a ns1:Competency ;
    ns1:competencyCode "CB02" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar sus conocimientos a su trabajo o vocación de una forma profesional y posean las competencias que suelen demostrarse por medio de la elaboración y defensa de argumentos y la resolución de problemas dentro de su área de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000001/2025-26/CE02> a ns1:Competency ;
    ns1:competencyCode "CE02" ;
    ns1:competencyDescription "Conocer y aplicar los conocimientos sobre el Álgebra lineal y el Cálculo diferencial e integral para la resolución de los problemas matemáticos que puedan plantearse en el ámbito de las Ciencias Agrarias."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000001/2025-26/CG01> a ns1:Competency ;
    ns1:competencyCode "CG01" ;
    ns1:competencyDescription "Conocimiento en materias básicas, científicas y tecnológicas que permitan un aprendizaje continuo, así como una capacidad de adaptación a nuevas situaciones o entornos cambiantes."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000001/2025-26/CT02> a ns1:Competency ;
    ns1:competencyCode "CT02" ;
    ns1:competencyDescription "Capacidad para aplicar el método científico para la resolución de problemas de forma efectiva y creativa."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000001/2025-26/RA1> a ns1:LearningResult ;
    ns1:learningResultCode "RA1" ;
    ns1:learningResultDescription "Establecer relaciones funcionales entre dos variables en el contexto de los biosistemas agrarios y la bioeconomía."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000001/2025-26/RA10> a ns1:LearningResult ;
    ns1:learningResultCode "RA10" ;
    ns1:learningResultDescription "Usar herramientas informáticas de computación a nivel básico para visualizar información, calcular simbólicamente y obtener soluciones numéricas en el planteamiento y análisis de problemas prácticos relacionados con los anteriores resultados de aprendizaje."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000001/2025-26/RA2> a ns1:LearningResult ;
    ns1:learningResultCode "RA2" ;
    ns1:learningResultDescription "Analizar los aspectos relevantes de la dependencia funcional (orden de crecimiento, optimización,¿.) mediante las herramientas del cálculo diferencial."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000001/2025-26/RA3> a ns1:LearningResult ;
    ns1:learningResultCode "RA3" ;
    ns1:learningResultDescription "Utilizar el cálculo integral en problemas reales para obtener magnitudes y cuantificadores en el ámbito de los biosistemas agrarios y la bioeconomía."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000001/2025-26/RA4> a ns1:LearningResult ;
    ns1:learningResultCode "RA4" ;
    ns1:learningResultDescription "Codificar y manejar la información mediante el lenguaje matricial."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000001/2025-26/RA5> a ns1:LearningResult ;
    ns1:learningResultCode "RA5" ;
    ns1:learningResultDescription "Utilizar las técnicas del álgebra lineal en la resolución de problemas geométricos, así como en la estadística y análisis de datos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000001/2025-26/RA6> a ns1:LearningResult ;
    ns1:learningResultCode "RA6" ;
    ns1:learningResultDescription "Identificar y describir en contextos reales leyes de evolución lineales mediante el uso del lenguaje matricial en una o varias dimensiones."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000001/2025-26/RA7> a ns1:LearningResult ;
    ns1:learningResultCode "RA7" ;
    ns1:learningResultDescription "Resolver modelos lineales de evolución (en tiempo discreto o continuo) mediante técnicas del álgebra lineal."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000001/2025-26/RA8> a ns1:LearningResult ;
    ns1:learningResultCode "RA8" ;
    ns1:learningResultDescription "Describir el comportamiento a largo plazo de los modelos lineales anteriormente descritos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000001/2025-26/RA9> a ns1:LearningResult ;
    ns1:learningResultCode "RA9" ;
    ns1:learningResultDescription "Obtener las consecuencias que pudieran derivar en cada contexto (sostenibilidad de sistemas agroambientales, políticas socioeconómicas, etc.)."@es .

