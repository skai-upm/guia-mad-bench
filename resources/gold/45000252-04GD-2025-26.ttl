<https://guia-kg.skai.etsisi.upm.es/resource/45000252/2025-26/04GC.%20CM33.1> a ns1:Competency ;
    ns1:competencyCode "04GC. CM33.1" ;
    ns1:competencyDescription "Capacidad para la construcción y conservación de las líneas de ferrocarriles con conocimiento para aplicar la normativa técnica específica y diferenciando las características del material móvil."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000252/2025-26/04GC.%20CM33.2> a ns1:Competency ;
    ns1:competencyCode "04GC. CM33.2" ;
    ns1:competencyDescription "Comprensión de los modelos teóricos que explican el comportamiento mecánico de la vía, la interacción de la vía y el tren, y su influencia sobre las especificaciones de diseño."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000252/2025-26/04GC.%20CT2> a ns1:Competency ;
    ns1:competencyCode "04GC. CT2" ;
    ns1:competencyDescription "Capacidad de organizar y dirigir los esfuerzos de un grupo humano reducido y homogéneo. Desarrolla la competencia transversal 8ª de la normativa UPM."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000252/2025-26/04GC.%20CT3> a ns1:Competency ;
    ns1:competencyCode "04GC. CT3" ;
    ns1:competencyDescription "Capacidad de actuar con efectividad como miembro de equipos interdisciplinares. Desarrolla la competencia transversal 5ª de la normativa UPM."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000252/2025-26/04GC.%20CT4> a ns1:Competency ;
    ns1:competencyCode "04GC. CT4" ;
    ns1:competencyDescription "Capacidad de preparar y presentar con efectividad comunicaciones orales, escritas y gráficas. Completa el desarrollo de la competencia transversal 4ª del real decreto y desarrolla la competencia transversal 2ª de la normativa UPM."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000252/2025-26/04GC.%20CT6> a ns1:Competency ;
    ns1:competencyCode "04GC. CT6" ;
    ns1:competencyDescription "Compromiso y capacidad de aplicación de los estándares de deontología profesional."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000252/2025-26/RA137> a ns1:LearningResult ;
    ns1:learningResultCode "RA137" ;
    ns1:learningResultDescription "Interioriza los principios de deontología profesional de ingeniería civil."@es .

