    schema:description "La asignatura Ferrocarriles para la especialidad de Transportes y Servicios proporciona los conocimientos básicos del sistema ferroviario, tanto infraestructura como material rodante y operación."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/juan.gomez.sanchez%40upm.es> ;
