    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/145016302/2025-26/eventSchedule> ;
    schema:description "Conocer los aspectos constructivos y operacionales de los sistemas de avión y componentes principales que integran las aeronaves, tal como la Célula y la Planta de Potencia."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/javier.crespo%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/javier.crespo%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/rafael.bardera%40upm.es> ;
    schema:name "Conocimiento de Aeronaves para Atc"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145016302/2025-26/CG02> a ns1:Competency ;
    ns1:competencyCode "CG02" ;
    ns1:competencyDescription "Conocimiento en materias básicas, científicas y tecnológicas que permitan un aprendizaje continuo, así como una capacidad de adaptación a nuevas situaciones o entornos cambiantes"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145016302/2025-26/CT02> a ns1:Competency ;
    ns1:competencyCode "CT02" ;
    ns1:competencyDescription "Capacidad para el uso de la lengua inglesa"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145016302/2025-26/CT06> a ns1:Competency ;
    ns1:competencyCode "CT06" ;
    ns1:competencyDescription "Capacidad para utilizar las Tecnologías de la Información y de las Comunicaciones"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145016302/2025-26/RA20> a ns1:LearningResult ;
    ns1:learningResultCode "RA20" ;
    ns1:learningResultDescription "Es capaz de analizar la necesidad de instalación de equipos de control en función del tipo de aeronave."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145016302/2025-26/RA21> a ns1:LearningResult ;
    ns1:learningResultCode "RA21" ;
    ns1:learningResultDescription "Interpreta las particularidades operativas en los servicios ATS en función de las características de las aeronaves."@es .

