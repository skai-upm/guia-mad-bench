    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/105001039/2025-26/eventSchedule> ;
    schema:description """En este curso nos centramos en la realizacion de un proyecto de ciencia de datos desde su planificación hasta su desarollo
Se analizan las fases de desarrollo, y se genera de manera práctica con un caso de estudio como aplicar y desarrollar el proyecto.
A lo largo del curso se analizarán los siguientes aspectos:
Metodologías de gestión de proyectos de ciencia de datos
Desarrollo de proyectos de ciencia de datos
Aplicación de técnicas de aprendizaje automático en proyectos de ciencias de datos
Decisión sobre las técnicas a aplicar en cada fase del proyecto de ciencia de datos"""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/ernestina.menasalvas%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/alejandro.rg%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/antoniojesus.diaz%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/ernestina.menasalvas%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/lucia.prieto.santamaria%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/luis.mengual%40upm.es> ;
    schema:name "Proyecto de Ciencia de Datos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105001039/2025-26/CB05> a ns1:Competency ;
    ns1:competencyCode "CB05" ;
    ns1:competencyDescription "Que los estudiantes hayan desarrollado aquellas habilidades de aprendizaje necesarias para emprender estudios posteriores con un alto grado de autonomía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105001039/2025-26/CE10> a ns1:Competency ;
    ns1:competencyCode "CE10" ;
    ns1:competencyDescription "Capacidad para aplicar las metodologías y las técnicas adecuadas de análisis y explotación de datos sobre datos disponibles, incluidos los poco estructurados o de estructura compleja (como los que contienen series temporales, los provenientes de redes sociales, etc.), para descubrir nuevas relaciones y proporcionar conocimiento y una comprensión intuitiva precisa y profunda sobre problemas científicos o procesos organizacionales reales y así respaldar la toma de decisiones."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105001039/2025-26/CE11> a ns1:Competency ;
    ns1:competencyCode "CE11" ;
    ns1:competencyDescription "Capacidad para aplicar métodos generales de ciencia de datos e inteligencia artificial para desarrollar software que explote los datos de un dominio concreto científico o de negocio."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105001039/2025-26/CE12> a ns1:Competency ;
    ns1:competencyCode "CE12" ;
    ns1:competencyDescription "Capacidad de comunicar de forma efectiva el proceso de análisis a partir de los datos y la interpretación de los resultados del mismo, seleccionando y utilizando para ello las técnicas y herramientas de visualización de datos más adecuadas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105001039/2025-26/CG01> a ns1:Competency ;
    ns1:competencyCode "CG01" ;
    ns1:competencyDescription "Capacidad de trabajo en equipo, en entornos interdisciplinares y complejos, negociando y resolviendo conflictos, diseñando soluciones eficientes, fiables, robustas y responsables."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105001039/2025-26/RA110> a ns1:LearningResult ;
    ns1:learningResultCode "RA110" ;
    ns1:learningResultDescription "RA"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105001039/2025-26/RA116> a ns1:LearningResult ;
    ns1:learningResultCode "RA116" ;
    ns1:learningResultDescription "Dado un problema real elegir la tecnología de ciencia de datos o de inteligencia artificial existente en el mercado más apropiada para su solución y diseñar su desarrollo e integración analizando la viabilidad de su solución, lo que se puede y no se puede conseguir a través del estado actual de desarrollo de la tecnología usada, y lo que se espera que avance en el futuro"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105001039/2025-26/RA132> a ns1:LearningResult ;
    ns1:learningResultCode "RA132" ;
    ns1:learningResultDescription "Ser capaz de entender un dominio de datos complejos, establecer objetivos concretos de análisis de datos, aplicar técnicas relevantes y evaluar los resultados obtenidos"@es .

