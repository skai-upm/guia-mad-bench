    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/203000075/2025-26/syllabus> ;
    ns1:inpersonHours "78 horas (37.5%)"@es ;
    ns1:numberOfCredits 8.0 ;
    ns1:otherInformation "El Máster en Producción y Sanidad Animal en un Máster Interuniversitario en el que participan la UPM y la UCM. El profesor coordinador de esta asignatura es Clemente José López Bote, profesor de la Facultad de Veterinaria de la Universidad Complutense de Madrid. Por parte de la UPM, la profesora coordinadora de la asignatura es Martina Pérez Serrano, profesora de la ETSIAAB."@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "86 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/203000075/2025-26/eventSchedule> ;
    schema:description """- Características propias en cuanto a alimentación, producción e higiene del ganado porcino.
- Interpretación de trabajos científicos y entendimiento de su importancia real.
- Resolución de problemas conceptuales relacionados con la producción y nutrición animal y aplicación de supuestos prácticos."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/martina.perez%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/antonio.callejo%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/david.menoyo%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/lourdes.camara%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/martina.perez%40upm.es> ;
    schema:name "Alimentación, Produción e Higiene en Porcino"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000075/2025-26/CE01> a ns1:Competency ;
    ns1:competencyCode "CE01" ;
    ns1:competencyDescription "Adquirir unos conocimientos y unas destrezas adecuadas en producción y sanidad animal para poder plantear soluciones y resolver las problemáticas inherentes a las explotaciones ganaderas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000075/2025-26/CE02> a ns1:Competency ;
    ns1:competencyCode "CE02" ;
    ns1:competencyDescription "Aplicar conocimientos avanzados acerca de la gestión técnico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000075/2025-26/CE03> a ns1:Competency ;
    ns1:competencyCode "CE03" ;
    ns1:competencyDescription "Evaluar adecuadamente el efecto de los factores de producción y de las técnicas de manejo, sobre la productividad de los modelos y la calidad de los productos ganaderos generados."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000075/2025-26/CE04> a ns1:Competency ;
    ns1:competencyCode "CE04" ;
    ns1:competencyDescription "Diseñar nuevas estrategias para mejorar la productividad de los modelos ganaderos, optimizando la utilización de los factores de producción, afrontando adecuadamente la temática del bienestar animal y minimizando el impacto ambiental de los mencionados modelos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000075/2025-26/CE06> a ns1:Competency ;
    ns1:competencyCode "CE06" ;
    ns1:competencyDescription "Conocer toda la normativa inherente al bienestar y a la protección animal, que debe ser tenida en cuenta en los sistemas productivos, en los alojamientos ganaderos y en los estudios de investigación relacionados con la producción animal y con la sanidad animal."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000075/2025-26/RA10> a ns1:LearningResult ;
    ns1:learningResultCode "RA10" ;
    ns1:learningResultDescription "RA52"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000075/2025-26/RA34> a ns1:LearningResult ;
    ns1:learningResultCode "RA34" ;
    ns1:learningResultDescription "Desarrollar en el alumno la capacidad de resolución de problemas con creatividad, iniciativa, metodología y razonamiento crítico, en el ámbito de la nutrición y la producción animal"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000075/2025-26/RA37> a ns1:LearningResult ;
    ns1:learningResultCode "RA37" ;
    ns1:learningResultDescription "Introducir al alumno en las características propias en cuanto a alimentación, producción e higiene de las especies en estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000075/2025-26/RA40> a ns1:LearningResult ;
    ns1:learningResultCode "RA40" ;
    ns1:learningResultDescription "Aprender en la búsqueda de trabajos científicos actuales en relación a la alimentación, producción e higiene de la especie en estudio"@es .

