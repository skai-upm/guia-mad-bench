    schema:name "Visión por Computador"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001572/2025-26/CB06> a ns1:Competency ;
    ns1:competencyCode "CB06" ;
    ns1:competencyDescription "Poseer y comprender conocimientos que aporten una base u oportunidad de ser originales en el desarrollo y/o aplicación de ideas, a menudo en un contexto de investigación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001572/2025-26/CB09> a ns1:Competency ;
    ns1:competencyCode "CB09" ;
    ns1:competencyDescription "Que los estudiantes sepan comunicar sus conclusiones y los conocimientos y razones últimas que las sustentan a públicos especializados y no especializados de un modo claro y sin ambigüedades"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001572/2025-26/CE03> a ns1:Competency ;
    ns1:competencyCode "CE03" ;
    ns1:competencyDescription "Capacidad para realizar un diseño integral de un proyecto básico de visión por computador."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001572/2025-26/CG01> a ns1:Competency ;
    ns1:competencyCode "CG01" ;
    ns1:competencyDescription "Tener conocimientos adecuados de los aspectos científicos y tecnológicos de la automática y la robótica."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001572/2025-26/CG05> a ns1:Competency ;
    ns1:competencyCode "CG05" ;
    ns1:competencyDescription "Saber comunicar las conclusiones"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001572/2025-26/CT01> a ns1:Competency ;
    ns1:competencyCode "CT01" ;
    ns1:competencyDescription "Aplica. Habilidad para aplicar conocimientos científicos, matemáticos y tecnológicos en sistemas relacionados con la práctica de la ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001572/2025-26/CT05> a ns1:Competency ;
    ns1:competencyCode "CT05" ;
    ns1:competencyDescription "Resuelve. Habilidad para identificar, formular y resolver problemas de ingeniería"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001572/2025-26/CT07> a ns1:Competency ;
    ns1:competencyCode "CT07" ;
    ns1:competencyDescription "Comunica. Habilidad para comunicar eficazmente"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001572/2025-26/CT12> a ns1:Competency ;
    ns1:competencyCode "CT12" ;
    ns1:competencyDescription "Es bilingüe. Capacidad de trabajar en un entorno bilingüe (inglés/castellano)"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001572/2025-26/RA38> a ns1:LearningResult ;
    ns1:learningResultCode "RA38" ;
    ns1:learningResultDescription "El alumno debe disponer de un amplio conocimiento de las ténicas de visión por computador, así como de los diferentes principios que las inspiran."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001572/2025-26/RA39> a ns1:LearningResult ;
    ns1:learningResultCode "RA39" ;
    ns1:learningResultDescription "El alumno debe ser capaz de adquirir nuevos conocimientos de forma autónoma como extensión de las técnicas presentadas en la asignatura"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001572/2025-26/RA40> a ns1:LearningResult ;
    ns1:learningResultCode "RA40" ;
    ns1:learningResultDescription "El alumno debe ser capaz de aplicar los conocimientos adquiridos al planteamiento de soluciones plausibles a problemas industriales en el ámbito de la visión por computador"@es .

