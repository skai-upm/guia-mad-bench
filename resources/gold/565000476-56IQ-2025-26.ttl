<https://guia-kg.skai.etsisi.upm.es/resource/565000476/2025-26/CE%2016> a ns1:Competency ;
    ns1:competencyCode "CE 16" ;
    ns1:competencyDescription "Conocimientos básicos y aplicación de tecnologías medioambientales y sostenibilidad."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000476/2025-26/CE%2019> a ns1:Competency ;
    ns1:competencyCode "CE 19" ;
    ns1:competencyDescription "Conocimientos sobre balances de materia y energía, biotecnología, transferencia de materia, operaciones de separación, ingeniería de la reacción química, diseño de reactores, y valoración y transformación de materias primas y recursos energéticos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000476/2025-26/CE%2021> a ns1:Competency ;
    ns1:competencyCode "CE 21" ;
    ns1:competencyDescription "Capacidad para el diseño y gestión de procedimientos de experimentación aplicada, especialmente para la determinación de propiedades termodinámicas y de transporte, y modelado de fenómenos y sistemas en el ámbito de la ingeniería química, sistemas con flujo de fluidos, transmisión de calor, operaciones de transferencia de materia, cinética de las reacciones químicas y reactores."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000476/2025-26/CG%203> a ns1:Competency ;
    ns1:competencyCode "CG 3" ;
    ns1:competencyDescription "Aplicar los conocimientos adquiridos para identificar, formular y resolver problemas en contextos amplios, siendo capaces de integrar los trabajando en equipos multidisciplinares"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000476/2025-26/CG%204> a ns1:Competency ;
    ns1:competencyCode "CG 4" ;
    ns1:competencyDescription "Comprender el impacto de la ingeniería en el medio ambiente, el desarrollo sostenible de la sociedad y la importancia de trabajar en un entorno profesional y responsable"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000476/2025-26/CG%205> a ns1:Competency ;
    ns1:competencyCode "CG 5" ;
    ns1:competencyDescription "Comunicar conocimientos y conclusiones, tanto de forma oral como escrita, a públicos especializados y no especializados de modo claro y sin ambigüedades"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000476/2025-26/CG%206> a ns1:Competency ;
    ns1:competencyCode "CG 6" ;
    ns1:competencyDescription "Poseer las habilidades de aprendizaje que permitan continuar estudiando a lo largo de toda la vida para un desarrollo profesional adecuado"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000476/2025-26/RA226> a ns1:LearningResult ;
    ns1:learningResultCode "RA226" ;
    ns1:learningResultDescription "Conocimiento de las metodologías más importantes para abordar los problemas de la contaminación atmosférica."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000476/2025-26/RA227> a ns1:LearningResult ;
    ns1:learningResultCode "RA227" ;
    ns1:learningResultDescription "Capacidad para comparar y seleccionar diferentes métodos para detectar episodios de contaminación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000476/2025-26/RA228> a ns1:LearningResult ;
    ns1:learningResultCode "RA228" ;
    ns1:learningResultDescription "Conocer la importancia del sector trasporte como una de las fuentes principales de contaminación y poder seleccionar las diferentes alternativas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000476/2025-26/RA229> a ns1:LearningResult ;
    ns1:learningResultCode "RA229" ;
    ns1:learningResultDescription "Poder conocer las causas que dan lugar a la contaminación con criterios de sostenibilidad."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000476/2025-26/RA6> a ns1:LearningResult ;
    ns1:learningResultCode "RA6" ;
    ns1:learningResultDescription "Conocimientos básicos y aplicación de tecnologías medioambientales y sostenibilidad. Comparar y seleccionar alternativas técnicas."@es .

