<https://guia-kg.skai.etsisi.upm.es/resource/65003028/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Introducción a la Geoquímica Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65003028/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "2. Los elementos químicos: Origen y abundancias relativas. Nucleosíntesis y evolución estelar Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65003028/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "3. Composición química de la Tierra: Diferenciación. Distribución y clasificación de los elementos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65003028/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "4. Geoquímica isotópica Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65003028/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "5. Fundamentos de geoquímica orgánica Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65003028/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "6. La corteza terrestre: Abundancia, disponibilidad, movilidad, especiación, biodisponibilidad y toxicidad Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65003028/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "7. Diagramas de existencia, de concentración y de predominancia"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65003028/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "7.1. Reacciones sólido-gas. Cálculo de los dominios de existencia de los óxidos, carbonatos y sulfuros. Paragénesis minerales Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65003028/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "7.2. Predicción de las reacciones en disolución. Sistemas químicos y reacciones. Fuerza de un sistema Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65003028/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "7.3. Aplicación de los diagramas Eh-pH al estudio del medio natural y de los procesos industriales. Sin subniveles"@es .

