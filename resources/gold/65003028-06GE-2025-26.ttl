    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/65003028/2025-26/eventSchedule> ;
    schema:description """La asignatura está orientada a proporcionar a los alumnos la capacidad de aplicar las herramientas geoquímicas en la resolución de problemas geológicos, mineros y medioambientales.
Consta de una primera parte en la que se analiza el comportamiento y la abundancia relativa de los elementos en la Tierra para pasar después a la aplicación de herramientas para el estudio de los sistemas sólido-gas, líquido-líquido y sólido-líquido en condiciones de la corteza terrestre. También se analiza la aplicación de los isotopos estables y radiactivos a la resolución de problemas y se aplican ideas fundamentales de la geoquímica orgánica a la caracterización de yacimientos."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/eduardo.demiguel%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/eduardo.demiguel%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/joseeugenio.ortiz%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/lucia.arevalo%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/miguel.izquierdo%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/yolanda.sanchezpalencia%40upm.es> ;
    schema:name "Geoquimica Aplicada"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65003028/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Conocer y aplicar conocimientos de ciencias y tecnologías básicas a la práctica de la Ingeniería Geológica."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65003028/2025-26/CG2> a ns1:Competency ;
    ns1:competencyCode "CG2" ;
    ns1:competencyDescription "Poseer capacidad para diseñar, desarrollar, implementar, gestionar y mejorar productos, sistemas y procesos en los distintos ámbitos geológicos, usando técnicas analíticas, computacionales o experimentales apropiadas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65003028/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Aplicar los conocimientos adquiridos para identificar, formular y resolver problemas dentro de contextos amplios y multidisciplinarios, siendo capaces de integrar conocimientos, trabajando en equipos multidisciplinares."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65003028/2025-26/CG5> a ns1:Competency ;
    ns1:competencyCode "CG5" ;
    ns1:competencyDescription "Saber comunicar los conocimientos y conclusiones, tanto de forma oral, escrita y gráfica, a públicos especializados y no especializados de un modo claro y sin ambigüedades."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65003028/2025-26/CG6> a ns1:Competency ;
    ns1:competencyCode "CG6" ;
    ns1:competencyDescription "Poseer habilidades de aprendizaje que permitan continuar estudiando a lo largo de la vida para su adecuado desarrollo profesional."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65003028/2025-26/CG7> a ns1:Competency ;
    ns1:competencyCode "CG7" ;
    ns1:competencyDescription "Incorporar nuevas tecnologías y herramientas de la Ingeniería Geológica en sus actividades profesionales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65003028/2025-26/F22> a ns1:Competency ;
    ns1:competencyCode "F22" ;
    ns1:competencyDescription "Prospección Geofísica y Geoquímica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65003028/2025-26/F23> a ns1:Competency ;
    ns1:competencyCode "F23" ;
    ns1:competencyDescription "Diseño, planificación y ejecución para prospección y extracción de minerales, rocas, combustibles fósiles y nucleares, aguas subterráneas y geotécnicos. Ídem para inyección de fluidos en estructuras subterráneas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65003028/2025-26/F25> a ns1:Competency ;
    ns1:competencyCode "F25" ;
    ns1:competencyDescription "Ensayos mineralógicos, petrográficos y geotécnicos. Técnicas de muestreo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65003028/2025-26/F34> a ns1:Competency ;
    ns1:competencyCode "F34" ;
    ns1:competencyDescription "Ecología y ordenación del territorio. Planificación y gestión territorial y urbanística"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65003028/2025-26/RA149> a ns1:LearningResult ;
    ns1:learningResultCode "RA149" ;
    ns1:learningResultDescription "Conocer y comprender la composición química de la Tierra y la abundancia relativa de los elementos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65003028/2025-26/RA150> a ns1:LearningResult ;
    ns1:learningResultCode "RA150" ;
    ns1:learningResultDescription "Conocer los principales ciclos biogeoquímicos y comprender la interacción entre la corteza, la hidrosfera, la atmosfera y la biosfera."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65003028/2025-26/RA151> a ns1:LearningResult ;
    ns1:learningResultCode "RA151" ;
    ns1:learningResultDescription "Conocer y comprender las principales aplicaciones de los isotopos estables y radiactivos en el estudio de los procesos naturales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65003028/2025-26/RA152> a ns1:LearningResult ;
    ns1:learningResultCode "RA152" ;
    ns1:learningResultDescription "Aplicar herramientas geoquímicas en la caracterización de los sistemas hidrogeológicos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65003028/2025-26/RA153> a ns1:LearningResult ;
    ns1:learningResultCode "RA153" ;
    ns1:learningResultDescription "Aplicar herramientas geoquímicas en la detección y caracterización de yacimientos minerales y de hidrocarburos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65003028/2025-26/RA154> a ns1:LearningResult ;
    ns1:learningResultCode "RA154" ;
    ns1:learningResultDescription "Aplicar herramientas geoquímicas al análisis del comportamiento de contaminantes orgánicos e inorgánicos en el medio natural."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65003028/2025-26/RA155> a ns1:LearningResult ;
    ns1:learningResultCode "RA155" ;
    ns1:learningResultDescription "Aplicar modelos geoquímicos al estudio de sistemas naturales complejos."@es .

