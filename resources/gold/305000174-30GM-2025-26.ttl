    ns1:numberOfCredits 6.0 ;
    ns1:otherInformation """El trabajo final puede ser en grupo o individual. El trabajo final puede ser teórico o puede ser aplicado con un
enfoque sobre modelización y/o simulación. Podría servir para preparación para la realización de un trabajo fin de
grado sobre diversos temas del análisis."""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "81 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/305000174/2025-26/eventSchedule> ;
    schema:description """Una introducción al análisis de Fourier y sus aplicaciones. Se estudiarán series de Fourier, la trasformada de
Fourier en R, la trasformada de Fourier en R^d, la trasformada de Fourier discreto y en grupos abelianos finitos y
sus usos como herramientas matemáticas en contextos teóricos y en aplicaciones en ámbitos diversos, desde la
resolución de ecuaciones en derivadas parciales, la trasformada de Radon, la probabilidad, el procesamiento de
señales y otros.

La asignatura concluirá con la realización de un proyecto con presentación escrita y oral en que cada estudiante
desarrolla en detalle uno de estos usos/aplicaciones."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/daniel.fox%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/daniel.fox%40upm.es> ;
    schema:name "Ampliación de Análisis"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000174/2025-26/CE1> a ns1:Competency ;
    ns1:competencyCode "CE1" ;
    ns1:competencyDescription "Comprender y utilizar el lenguaje matemático. Adquirir la capacidad para enunciar propiedades en distintos campos de la Matemática, para construir argumentaciones, elaborar cálculos y para transmitir los conocimientos matemáticos adquiridos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000174/2025-26/CE10> a ns1:Competency ;
    ns1:competencyCode "CE10" ;
    ns1:competencyDescription "Utilizar herramientas de búsqueda de recursos bibliográficos en Matemáticas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000174/2025-26/CE11> a ns1:Competency ;
    ns1:competencyCode "CE11" ;
    ns1:competencyDescription "Realizar individualmente y presentar y defender ante un tribunal universitario un proyecto en el ámbito de las Matemáticas, en el que se sinteticen e integren las competencias adquiridas en las enseñanzas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000174/2025-26/CE2> a ns1:Competency ;
    ns1:competencyCode "CE2" ;
    ns1:competencyDescription "Conocer y comprender demostraciones rigurosas de los principales teoremas de cada área de la Matemática y extraer de ellos corolarios mediante la particularización a casos concretos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000174/2025-26/CE3> a ns1:Competency ;
    ns1:competencyCode "CE3" ;
    ns1:competencyDescription "Asimilar la definición de un nuevo objeto matemático, en términos de otros ya conocidos, y ser capaz de utilizar este objeto en diferentes contextos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000174/2025-26/CE4> a ns1:Competency ;
    ns1:competencyCode "CE4" ;
    ns1:competencyDescription "Abstraer las propiedades estructurales de objetos matemáticos, de la realidad observada o de otros ámbitos distinguiéndolas de aquellas puramente ocasionales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000174/2025-26/CE5> a ns1:Competency ;
    ns1:competencyCode "CE5" ;
    ns1:competencyDescription "Comprobar con demostraciones hipótesis sobre un objeto matemático o refutarlas con contraejemplos, así como identificar errores en razonamientos incorrectos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000174/2025-26/CE6> a ns1:Competency ;
    ns1:competencyCode "CE6" ;
    ns1:competencyDescription "Proponer, analizar, validar e interpretar modelos matemáticos de sistemas reales, utilizando las herramientas matemáticas más adecuadas a los fines que se persigan, explicitando las características del sistema recogidas en el modelo y las no consideradas en el mismo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000174/2025-26/CE7> a ns1:Competency ;
    ns1:competencyCode "CE7" ;
    ns1:competencyDescription "Resolver problemas de Matemáticas, mediante habilidades de cálculo básico y tecnologías de computación, planificando su resolución en función de las herramientas de que se disponga y de las restricciones de tiempo y recursos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000174/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Utilizar las capacidades analíticas y de abstracción, la intuición y el pensamiento lógico y riguroso desarrolladas a través del estudio de la Matemática en contextos tanto matemáticos como no matemáticos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000174/2025-26/CG5> a ns1:Competency ;
    ns1:competencyCode "CG5" ;
    ns1:competencyDescription "Sintetizar conocimientos y habilidades adquiridas en el campo de la matemática en diferentes materias del plan de estudios para enfocarlas en posteriores estudios especializados, tanto en una disciplina matemática como en cualquiera de las ciencias que requieran buenos fundamentos matemáticos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000174/2025-26/CT8> a ns1:Competency ;
    ns1:competencyCode "CT8" ;
    ns1:competencyDescription "Mostrar capacidad para comunicar ideas, problemas y soluciones, tanto a público especializado como no especializado, de manera oral y escrita."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000174/2025-26/RA117> a ns1:LearningResult ;
    ns1:learningResultCode "RA117" ;
    ns1:learningResultDescription "Producir un modelo matemático de un fenómeno real. Identificar todos los compo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000174/2025-26/RA118> a ns1:LearningResult ;
    ns1:learningResultCode "RA118" ;
    ns1:learningResultDescription "Utilizar el análisis de las series numéricas para resolver diversidad de problemas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000174/2025-26/RA120> a ns1:LearningResult ;
    ns1:learningResultCode "RA120" ;
    ns1:learningResultDescription "Conocer y manejar el concepto de integral de Lebesgue y sus aplicaciones"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000174/2025-26/RA123> a ns1:LearningResult ;
    ns1:learningResultCode "RA123" ;
    ns1:learningResultDescription "Conocer los conceptos y propiedades fundamentales de los espacios de Banach y espacios de Hilbert"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000174/2025-26/RA136> a ns1:LearningResult ;
    ns1:learningResultCode "RA136" ;
    ns1:learningResultDescription "Calcular la transformada de Fourier de una función y relacionar su regularidad y decaimiento con el decaimiento y la regularidad de su transformada"@es .

