<https://guia-kg.skai.etsisi.upm.es/resource/135004303/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Tema 01 Introducción. La anatomía vegetal. Estructura Celular"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004303/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Niveles de organización de los vegetales: protófitos, talófitos y cormófitos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004303/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "3.2. Tejidos conductores Xilema: Tipos celulares, elementos conductores, de sostén. Protoxilema, metaxilema y xilema secundario. Floema: Tipos celulares. Protofloema, metafloema y floema secundario. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004303/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "3.3. Tejidos de recubrimiento. Epidermis: células ordinarias, células de guarda y estomas, tricomas, tricoblastos. Peridermis. Lenticelas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004303/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "4. Tema 04 El crecimiento primario"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004303/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "4.1. Meristemas apicales. Estructura: túnica y corpus. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004303/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "4.2. Desarrollo del crecimiento primario en el tallo. Yemas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004303/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "4.3. Desarrollo del crecimiento primario en la raíz. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004303/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "4.4. Conexión tallo-raíz Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004303/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "4.5. Diferencias entre tallo y raíz Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004303/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "5. Tema 05 Estructura de las plantas leñosas. El cuerpo secundario"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004303/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "5.1. Meristemas laterales. Cambium vascular y cambium suberoso. Divisiones del cambium. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004303/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. La célula vegetal. Membranas celulares. Núcleo. Ribosomas. Vacuolas. Plastidios: Cloroplastos. Mitrocondria. Retículo endoplasmático. Aparato de Golgi. Citoesqueleto. Sustancias ergásticas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004303/2025-26/syllabus/20> a ns1:SyllabusItem ;
    ns1:itemIndex 20 ;
    ns1:syllabusDescription "5.2. Desarrollo del crecimiento secundario en el tallo. Respuesta a heridas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004303/2025-26/syllabus/21> a ns1:SyllabusItem ;
    ns1:itemIndex 21 ;
    ns1:syllabusDescription "5.3. Desarrollo del crecimiento secundario en la raíz. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004303/2025-26/syllabus/22> a ns1:SyllabusItem ;
    ns1:itemIndex 22 ;
    ns1:syllabusDescription "6. Tema 06 La hoja"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004303/2025-26/syllabus/23> a ns1:SyllabusItem ;
    ns1:itemIndex 23 ;
    ns1:syllabusDescription "6.1. Tipos y funciones de las hojas. Limbo y peciolo. Estructura del limbo: epidermis, mesófilo, sistema vascular. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004303/2025-26/syllabus/24> a ns1:SyllabusItem ;
    ns1:itemIndex 24 ;
    ns1:syllabusDescription "6.2. La acícula de gimnospermas. La hoja de las monocotiledóneas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004303/2025-26/syllabus/25> a ns1:SyllabusItem ;
    ns1:itemIndex 25 ;
    ns1:syllabusDescription "6.3. Características anatómicas vinculadas a metabolismos especiales (C4 y CAM). Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004303/2025-26/syllabus/26> a ns1:SyllabusItem ;
    ns1:itemIndex 26 ;
    ns1:syllabusDescription "7. Tema 07 Células y tejidos secretores"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004303/2025-26/syllabus/27> a ns1:SyllabusItem ;
    ns1:itemIndex 27 ;
    ns1:syllabusDescription "7.1. Hidatodos. Glándulas de sal. Nectarios. Osmóforos. Glándulas digestivas. Células adhesivas. Pelos urticantes. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004303/2025-26/syllabus/28> a ns1:SyllabusItem ;
    ns1:itemIndex 28 ;
    ns1:syllabusDescription "7.2. Mucílagos. Aceites. Gomas. Taninos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004303/2025-26/syllabus/29> a ns1:SyllabusItem ;
    ns1:itemIndex 29 ;
    ns1:syllabusDescription "7.3. Laticíferos. Canales resiníferos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004303/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "2. Tema 02 La pared celular vegetal"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004303/2025-26/syllabus/30> a ns1:SyllabusItem ;
    ns1:itemIndex 30 ;
    ns1:syllabusDescription "8. Tema 08 La reproducción"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004303/2025-26/syllabus/31> a ns1:SyllabusItem ;
    ns1:itemIndex 31 ;
    ns1:syllabusDescription "8.1. Conceptos generales. Alternancia de generaciones. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004303/2025-26/syllabus/32> a ns1:SyllabusItem ;
    ns1:itemIndex 32 ;
    ns1:syllabusDescription "8.2. El ciclo reproductivo de las Gimnospermas. Estróbilos. Megagametófito. Microgametófito. Embriogénesis y formación de la semilla. Diseminación. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004303/2025-26/syllabus/33> a ns1:SyllabusItem ;
    ns1:itemIndex 33 ;
    ns1:syllabusDescription "8.3. El ciclo reproductivo de las Angiospermas. Flores. Androceo y Gineceo. Megagametófito. Microgametófito. Doble fecundación y formación del endosperma. Embriogénesis. Apomixis. Formación de semilla y fruto. Diseminación. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004303/2025-26/syllabus/34> a ns1:SyllabusItem ;
    ns1:itemIndex 34 ;
    ns1:syllabusDescription "9. Tema 09 El agua en las plantas. Relaciones hídricas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004303/2025-26/syllabus/35> a ns1:SyllabusItem ;
    ns1:itemIndex 35 ;
    ns1:syllabusDescription "9.1. Introducción. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004303/2025-26/syllabus/36> a ns1:SyllabusItem ;
    ns1:itemIndex 36 ;
    ns1:syllabusDescription "9.2. Cuantificación del estado hídrico: contenido hídrico relativo y potencial hídrico. Medición del potencial hídrico y sus componentes. Movimiento del agua en las plantas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004303/2025-26/syllabus/37> a ns1:SyllabusItem ;
    ns1:itemIndex 37 ;
    ns1:syllabusDescription "10. Tema 10 Absorción y transporte del agua en las plantas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004303/2025-26/syllabus/38> a ns1:SyllabusItem ;
    ns1:itemIndex 38 ;
    ns1:syllabusDescription "10.1. Factores que modifican el agua disponible en el suelo. Rizodeposición. Señales isotópicas. Redistribución hidráulica. Mecanismos de absorción. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004303/2025-26/syllabus/39> a ns1:SyllabusItem ;
    ns1:itemIndex 39 ;
    ns1:syllabusDescription "10.2. El ascenso de la savia en el xilema. Teoría de la cohesión-tensión. Estructura hidráulica del árbol. Cavitación. Embolismo. Vulnerabilidad. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004303/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "2.1. Componentes de la pared vegetal. Celulosas, hemicelulosas, matriz glicoproteica, ligninas, deposiciones lipídicas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004303/2025-26/syllabus/40> a ns1:SyllabusItem ;
    ns1:itemIndex 40 ;
    ns1:syllabusDescription "11. Tema 11 Nutrición mineral."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004303/2025-26/syllabus/41> a ns1:SyllabusItem ;
    ns1:itemIndex 41 ;
    ns1:syllabusDescription "11.1. Transporte a través de membranas. Potencial químico, transporte activo y pasivo. Potencial de membrana. Difusión facilitada: transportadores, canales, bombas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004303/2025-26/syllabus/42> a ns1:SyllabusItem ;
    ns1:itemIndex 42 ;
