<https://guia-kg.skai.etsisi.upm.es/resource/595040074/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/595040074/2025-26/CG%2002>,
        <https://guia-kg.skai.etsisi.upm.es/resource/595040074/2025-26/CG%2006> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/595040074/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/595040074/2025-26/didactic_resource/2>,
