    ns1:itemIndex 11 ;
    ns1:syllabusDescription "2.2.3. Práctica 1. Extracción y separación de mezclas complejas de proteínas de tejidos animales Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000307/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "2.3. Estructura tridimensional de las Proteínas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000307/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "2.3.1. Fuerzas que estabilizan la estructura tridimensional Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000307/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "2.4. Enzimas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000307/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "2.4.1. Concepto, funciones y clasificación Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000307/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "2.4.2. Seminario 2. Problemas de Cinética enzimática Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000307/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "2.4.3. Práctica 2. Cinética enzimática Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000307/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "3. Carbohidratos y ácidos nucleícos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000307/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "3.1. Carbohidratos y Glucobiología"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000307/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.1.1. Definición de Bioquímica.Características de los seres vivos y composición química. Jeraraquía y organización de los seres vivos. Biomoléculas: propiedades. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000307/2025-26/syllabus/20> a ns1:SyllabusItem ;
    ns1:itemIndex 20 ;
    ns1:syllabusDescription "3.1.1. Funciones biológicas Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000307/2025-26/syllabus/21> a ns1:SyllabusItem ;
    ns1:itemIndex 21 ;
    ns1:syllabusDescription "3.1.2. Seminario 3 Problemas de Biomoléculas Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000307/2025-26/syllabus/22> a ns1:SyllabusItem ;
    ns1:itemIndex 22 ;
    ns1:syllabusDescription "3.2. Nucleótidos y ácidos nucléicos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000307/2025-26/syllabus/23> a ns1:SyllabusItem ;
    ns1:itemIndex 23 ;
    ns1:syllabusDescription "3.2.1. Propiedades,composición y función de nucleósidos y nucleótidos. Ácidos nucléicos: composición, propiedades (desnaturalización/renaturalización e hibridación). Ácidos ribonucléicos: tipos, estructura y función. estructura del ADN. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000307/2025-26/syllabus/24> a ns1:SyllabusItem ;
    ns1:itemIndex 24 ;
    ns1:syllabusDescription "3.2.2. Practica 3: Purificación y análisis de ácidos nucleícos mediante PCR y electroforesis en gel de agarosa Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000307/2025-26/syllabus/25> a ns1:SyllabusItem ;
    ns1:itemIndex 25 ;
    ns1:syllabusDescription "4. UNIDAD II. Bioseñalización"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000307/2025-26/syllabus/26> a ns1:SyllabusItem ;
    ns1:itemIndex 26 ;
    ns1:syllabusDescription "4.1. Lípidos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000307/2025-26/syllabus/27> a ns1:SyllabusItem ;
    ns1:itemIndex 27 ;
    ns1:syllabusDescription "4.1.1. Definición, función y características generales. Lípidos de almacenamiento. Lípidos estructurales. lípidos con actividades biológicas específicas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000307/2025-26/syllabus/28> a ns1:SyllabusItem ;
    ns1:itemIndex 28 ;
    ns1:syllabusDescription "4.2. Membranas biológicas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000307/2025-26/syllabus/29> a ns1:SyllabusItem ;
    ns1:itemIndex 29 ;
    ns1:syllabusDescription "4.2.1. Constituyentes de las membranas biológicas. Modelo del mosaico fluido. Estructura tridimensional de las proteínas de membrana. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000307/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "1.2. El agua y el PH"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000307/2025-26/syllabus/30> a ns1:SyllabusItem ;
    ns1:itemIndex 30 ;
    ns1:syllabusDescription "4.3. Bioseñalización"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000307/2025-26/syllabus/31> a ns1:SyllabusItem ;
    ns1:itemIndex 31 ;
    ns1:syllabusDescription "4.3.1. Características generales. Receptores y segundos mensajeros. Señalización mediada por hormonas esteroideas Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000307/2025-26/syllabus/32> a ns1:SyllabusItem ;
    ns1:itemIndex 32 ;
    ns1:syllabusDescription "5. UNIDAD III: Genética Molecular e introducción a la biómica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000307/2025-26/syllabus/33> a ns1:SyllabusItem ;
    ns1:itemIndex 33 ;
    ns1:syllabusDescription "5.1. Transferencia de la información genética"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000307/2025-26/syllabus/34> a ns1:SyllabusItem ;
    ns1:itemIndex 34 ;
    ns1:syllabusDescription "5.1.1. Dogma central de la genética molecular. Mecanismo de replicación del ADN. ADN polimerasas. Mecanismo de transcripción. Transcripción inversa. Replicación del ARN. Mecanismo de traducción. Código genético. Hipótesis del balanceo Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000307/2025-26/syllabus/35> a ns1:SyllabusItem ;
    ns1:itemIndex 35 ;
    ns1:syllabusDescription "5.2. Tecnologías del ADN recombinante"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000307/2025-26/syllabus/36> a ns1:SyllabusItem ;
    ns1:itemIndex 36 ;
    ns1:syllabusDescription "5.2.1. Enzimas de restricción. Vectores de clonación. Técnicas para la obtención de organismos modificados genéticamente. Técnicas de editado genético. CRISPR-Cas9 Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000307/2025-26/syllabus/37> a ns1:SyllabusItem ;
    ns1:itemIndex 37 ;
    ns1:syllabusDescription "5.3. Introducción a la biómica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000307/2025-26/syllabus/38> a ns1:SyllabusItem ;
    ns1:itemIndex 38 ;
    ns1:syllabusDescription "5.3.1. Concepto de genoma, transcriptoma, proteoma y metaboloma. Avances tecnológicos en el análisi global de biomoléculas. Metaanálisis y bioinformática. Análisis de clusterización y ontología génica Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000307/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "1.2.1. Estructura y propiedades del agua y los equilibrios iónicos. Ionización del agua, ácidos y bases débiles. Sistemas tampón. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000307/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "2. UNIDAD I. Bioquímica Estructural"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000307/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "2.1. Aminoácidos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000307/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "2.1.1. Estructura, propiedades y clasificación de los aminoácidos. Estereoisomería de aminoácidos. Modificaciones postraduccionales de aminoácidos y aminoácidos no estandar. Propiedades ácido-básicas y curvas de valoración. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000307/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "2.2. Proteínas: Estructura primaria"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000307/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "2.2.1. Enlace péptidico. Diversidad de funciones biológicas. Niveles de organización estructural. Estrauctura primaria. Secuencia de aminoácidos: obtencón e información que proporciona. Sin subniveles"@es .

