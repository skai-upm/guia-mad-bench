    ns1:itemIndex 31 ;
    ns1:syllabusDescription "2.1. Aplicaciones o trabajos del tractor. Tipos de tractores Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000101/2025-26/syllabus/32> a ns1:SyllabusItem ;
    ns1:itemIndex 32 ;
    ns1:syllabusDescription "2.2. Transmisiones mecánicas"@es .

