<https://guia-kg.skai.etsisi.upm.es/resource/205000101/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. MOTOR"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000101/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Tipos de motores atendiendo a la fuente de energía Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000101/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "1.4.1. Ciclos teóricos Otto y Diesel. Ciclos cuasi-teóricos y ciclos indicados. Proceso de escape. Ciclo Miller Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000101/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "1.4.2. Presión media efectiva. Potencia indicada. Par y potencia efectiva o al freno. Potencia absorbida por las resistencias pasivas. Rendimiento mecánico. Rendimiento efectivo o económico. Consumo específico Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000101/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "1.5. Renovación de la carga"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000101/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "1.5.1. Rendimiento volumétrico. Trabajo de bombeo. Flujo en válvulas. Sobrealimentación. Determinación del caudal másico de aire de un compresor. Selección del compresor y de la turbina. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000101/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "1.6. Cinemática y dinámica del motor alternativo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000101/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "1.6.1. Cinemática del mecanismo biela-manivela. Fuerzas en el pistón. Par instantáneo. Orden de encendido. Volante de inercia. Equilibrado del cigüeñal Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000101/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "1.7. Ensayos del motor: curvas características"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000101/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "1.7.1. Medida de la potencia al freno dinamométrico. Potencias al volante sin y con auxiliares del motor. Potencia a la TdF. Curvas características del motor. Reserva de par y elasticidad. Curvas de isoconsumo Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000101/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "1.8. Sistemas de alimentación de combustible en motores diésel"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000101/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "1.8.1. Bomba de inyección de émbolos en línea. Regulador de velocidad centrífugo. Bomba de inyección rotativa. Inyector-bomba. Inyección electrónica 'common-rail' Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000101/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Combustibles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000101/2025-26/syllabus/20> a ns1:SyllabusItem ;
    ns1:itemIndex 20 ;
    ns1:syllabusDescription "1.9. Lubricantes y sistema de lubricación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000101/2025-26/syllabus/21> a ns1:SyllabusItem ;
    ns1:itemIndex 21 ;
    ns1:syllabusDescription "1.9.1. Composición y propiedades de los lubricantes. Aditivos. Sistema de lubricación Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000101/2025-26/syllabus/22> a ns1:SyllabusItem ;
    ns1:itemIndex 22 ;
    ns1:syllabusDescription "1.10. Sistema de refrigeración por agua"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000101/2025-26/syllabus/23> a ns1:SyllabusItem ;
    ns1:itemIndex 23 ;
