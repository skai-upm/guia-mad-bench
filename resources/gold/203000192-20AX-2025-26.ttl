<https://guia-kg.skai.etsisi.upm.es/resource/203000192/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/203000192/2025-26/CG3>,
        <https://guia-kg.skai.etsisi.upm.es/resource/203000192/2025-26/CG4>,
