    ns1:otherInformation """La asignatura se relaciona con todos los ODS porque es aplicable a cualquier reto, pero especialmente con el ODS 17.
El nombre de la asignatura debería tener un subtítulo: Liderazgo adaptativo."""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
