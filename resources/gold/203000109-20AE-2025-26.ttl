    ns1:competencyDescription "Organización y planificación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000109/2025-26/CT05> a ns1:Competency ;
    ns1:competencyCode "CT05" ;
    ns1:competencyDescription "Gestión de la información."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000109/2025-26/CT06> a ns1:Competency ;
