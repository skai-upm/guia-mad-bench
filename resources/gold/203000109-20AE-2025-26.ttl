    ns1:competencyDescription "Capacidad de trabajo en equipo o su liderazgo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000109/2025-26/CT03> a ns1:Competency ;
    ns1:competencyCode "CT03" ;
    ns1:competencyDescription "Creatividad."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000109/2025-26/CT04> a ns1:Competency ;
