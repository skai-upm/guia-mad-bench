<https://guia-kg.skai.etsisi.upm.es/resource/205000052/2025-26/syllabus> a ns1:Syllabus ;
    ns1:hasItem <https://guia-kg.skai.etsisi.upm.es/resource/205000052/2025-26/syllabus/0>,
        <https://guia-kg.skai.etsisi.upm.es/resource/205000052/2025-26/syllabus/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/205000052/2025-26/syllabus/10>,
        <https://guia-kg.skai.etsisi.upm.es/resource/205000052/2025-26/syllabus/11>,
        <https://guia-kg.skai.etsisi.upm.es/resource/205000052/2025-26/syllabus/12>,
        <https://guia-kg.skai.etsisi.upm.es/resource/205000052/2025-26/syllabus/13>,
        <https://guia-kg.skai.etsisi.upm.es/resource/205000052/2025-26/syllabus/2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/205000052/2025-26/syllabus/3>,
