        <https://guia-kg.skai.etsisi.upm.es/resource/205000052/2025-26/syllabus/5>,
        <https://guia-kg.skai.etsisi.upm.es/resource/205000052/2025-26/syllabus/6>,
        <https://guia-kg.skai.etsisi.upm.es/resource/205000052/2025-26/syllabus/7>,
        <https://guia-kg.skai.etsisi.upm.es/resource/205000052/2025-26/syllabus/8>,
        <https://guia-kg.skai.etsisi.upm.es/resource/205000052/2025-26/syllabus/9> .

<https://guia-kg.skai.etsisi.upm.es/resource/205000052/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. UT 1. CARACTERIZACIÓN Y APROVECHAMIENTO DIGESTIVO DE LOS PRINCIPIOS INMEDIATOS Y UTILIZACIÓN METABÓLICA DE LOS NUTRIENTES"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000052/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Tema 1. Importancia de la nutrición animal en la producción animal: influencia en los rendimientos productivos, salud de los animales, calidad de los productos animales y emisiones contaminantes. Alimentos y nutrientes. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000052/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "2.3. Tema 9. Ingestión de los alimentos. Regulación de la ingestión en los animales monogástricos y rumiantes. Factores que afectan a la ingestión. Unidades lastre. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000052/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "3. UT 3. NECESIDADES NUTRITIVAS."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000052/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "3.1. Tema 10. Necesidades nutritivas de rumiantes Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000052/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "3.2. Tema 11. Necesidades nutritivas de monogástricos Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000052/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Tema 2. Análisis de los principios inmediatos de los alimentos Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000052/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "1.3. Tema 3. Medida de la eficacia digestiva Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000052/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "1.4. Tema 4. Factores que afectan a la digestión: monogástricos y rumiantes Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000052/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "1.5. Tema 5. Otros nutrientes. Agua: funciones en el organismo. Minerales: funciones en el organismo, necesidades y deficiencia. Vitaminas. funciones en el organismo, necesidades y deficiencia. Aditivos: clasificación y normativa legal. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000052/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "1.6. Tema 6. Metabolismo de nutrientes Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000052/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "2. UT 2. VALORACIÓN NUTRITIVA DE LOS ALIMENTOS: CONCEPTOS, UNIDADES Y DEFINICIÓN DE LAS NECESIDADES NUTRICIONALES DE LOS ANIMALES"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000052/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "2.1. Tema 7. Alimentación energética. Energía bruta, digestible, metabolizable y neta. Pérdidas de energía en heces, orina, gases y en forma de calor. Unidades de medida en las diferentes especies animales. Unidades de medida en los sistemas NRC, INRA y AFRC. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000052/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "2.2. Tema 8. Alimentación nitrogenada Sin subniveles"@es .

