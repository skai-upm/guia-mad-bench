<https://guia-kg.skai.etsisi.upm.es/resource/143005024/2025-26/CE5> a ns1:Competency ;
    ns1:competencyCode "CE5" ;
    ns1:competencyDescription "Comprender principios, requisitos , criterios y métodos para la gestión de la seguridad operacional en el sistema del transporte aéreo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005024/2025-26/CG2> a ns1:Competency ;
    ns1:competencyCode "CG2" ;
    ns1:competencyDescription "Aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en los entornos de evolución previstos en los Sistemas de Transporte Aéreo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005024/2025-26/CG4> a ns1:Competency ;
    ns1:competencyCode "CG4" ;
    ns1:competencyDescription "Comunicar sus conclusiones y los conocimientos y razones últimas que las sustentan a públicos especializados, y no especializados de un modo claro y sin ambigüedades"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005024/2025-26/CG6> a ns1:Competency ;
    ns1:competencyCode "CG6" ;
    ns1:competencyDescription "Que los estudiantes posean las habilidades de aprendizaje que les permitan continuar estudiando de un modo que habrá de ser en gran medida autodirigido o autónomo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005024/2025-26/CT3> a ns1:Competency ;
    ns1:competencyCode "CT3" ;
    ns1:competencyDescription "Gestionar la información, identificando las fuentes necesarias, los principales tipos de documentos técnicos y científicos que son de aplicación en el entorno de los Sistemas del Transporte Aéreo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005024/2025-26/RA30> a ns1:LearningResult ;
    ns1:learningResultCode "RA30" ;
    ns1:learningResultDescription "Conocimiento, comprensión y síntesis de la aplicación de los principios de diseño y aplicación de tecnologías y procedimientos para garantizar la seguridad del transporte aéreo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005024/2025-26/RA33> a ns1:LearningResult ;
    ns1:learningResultCode "RA33" ;
    ns1:learningResultDescription "Conocer, comprender, analizar y valorar la Organización Aeronáutica nacional e internacional y del funcionamiento de los distintos modos del sistema mundial de transportes, con especial énfasis en el transporte aéreo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005024/2025-26/RA39> a ns1:LearningResult ;
    ns1:learningResultCode "RA39" ;
    ns1:learningResultDescription "Comprensión de la necesidad de la evolución del Sistema de Navegación Aérea"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005024/2025-26/RA40> a ns1:LearningResult ;
    ns1:learningResultCode "RA40" ;
    ns1:learningResultDescription "Mejorar sus capacidades de análisis a lo largo del semestre, en presentaciones escritas y desarrollos de resolución de ejercicios, planteamiento, resultados y unidades, entre otros."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005024/2025-26/RA73> a ns1:LearningResult ;
    ns1:learningResultCode "RA73" ;
    ns1:learningResultDescription "El alumno domina el concepto de modelización de riesgo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005024/2025-26/RA81> a ns1:LearningResult ;
    ns1:learningResultCode "RA81" ;
    ns1:learningResultDescription "El alumno comprende el concepto de separación en términos ATM"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005024/2025-26/RA82> a ns1:LearningResult ;
    ns1:learningResultCode "RA82" ;
    ns1:learningResultDescription "El alumno comprende las capas de la gestión de conflictos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005024/2025-26/RA83> a ns1:LearningResult ;
    ns1:learningResultCode "RA83" ;
    ns1:learningResultDescription "El alumno comprende los sistemas y conceptos operacionales que se aplican en la gestión de la separación"@es .

