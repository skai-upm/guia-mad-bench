<https://guia-kg.skai.etsisi.upm.es/resource/145001004/2025-26/CE09> a ns1:Competency ;
    ns1:competencyCode "CE09" ;
    ns1:competencyDescription "Comprender la globalidad del sistema de navegación aérea y la complejidad del tráfico aéreo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145001004/2025-26/CE10> a ns1:Competency ;
    ns1:competencyCode "CE10" ;
    ns1:competencyDescription "Comprender cómo las fuerzas aerodinámicas determinan la dinámica del vuelo y el papel de las distintas variables involucradas en el fenómeno del vuelo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145001004/2025-26/CE13> a ns1:Competency ;
    ns1:competencyCode "CE13" ;
    ns1:competencyDescription "Comprender la singularidad de las infraestructuras, edificaciones y funcionamiento de los aeropuertos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145001004/2025-26/CE17> a ns1:Competency ;
    ns1:competencyCode "CE17" ;
    ns1:competencyDescription "Conocimiento adecuado y aplicado a la ingeniería de: Los elementos fundamentales de los diversos tipos de aeronaves; los elementos funcionales del sistema de navegación aérea y las instalaciones eléctricas y electrónicas asociadas; los fundamentos del diseño y construcción de aeropuertos y sus diversos elementos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145001004/2025-26/CE18> a ns1:Competency ;
    ns1:competencyCode "CE18" ;
    ns1:competencyDescription "Conocimiento adecuado y aplicado a la Ingeniería de: Los fundamentos de la mecánica de fluidos; los principios básicos del control y la automatización del vuelo; las principales características y propiedades físicas y mecánicas de los materiales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145001004/2025-26/CE19> a ns1:Competency ;
    ns1:competencyCode "CE19" ;
    ns1:competencyDescription "Conocimiento aplicado de: la ciencia y tecnología de los materiales; mecánica y termodinámica; mecánica de fluidos; aerodinámica y mecánica del vuelo; sistemas de navegación y circulación aérea; tecnología aeroespacial; teoría de estructuras; transporte aéreo; economía y producción; proyectos; impacto ambiental."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145001004/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Capacidad para identificar y resolver problemas aplicando, con creatividad, los conocimientos adquiridos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145001004/2025-26/CG4> a ns1:Competency ;
    ns1:competencyCode "CG4" ;
    ns1:competencyDescription "Capacidad para integrarse y formar parte activa de equipos de trabajo. Trabajo en equipo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145001004/2025-26/CG6> a ns1:Competency ;
    ns1:competencyCode "CG6" ;
    ns1:competencyDescription "Uso de las Tecnologías de la Información y de las Comunicaciones"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145001004/2025-26/CG7> a ns1:Competency ;
    ns1:competencyCode "CG7" ;
    ns1:competencyDescription "Comunicación oral y escrita"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145001004/2025-26/CG9> a ns1:Competency ;
    ns1:competencyCode "CG9" ;
    ns1:competencyDescription "Razonamiento crítico y capacidad de asociación que posibiliten el aprendizaje continuo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145001004/2025-26/RA42> a ns1:LearningResult ;
    ns1:learningResultCode "RA42" ;
    ns1:learningResultDescription "Conocimiento general de los distintos sistemas propulsivos de los vehículos aeroespaciales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145001004/2025-26/RA43> a ns1:LearningResult ;
    ns1:learningResultCode "RA43" ;
    ns1:learningResultDescription "Conocimiento general de la tecnología aeroespacial."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145001004/2025-26/RA44> a ns1:LearningResult ;
    ns1:learningResultCode "RA44" ;
    ns1:learningResultDescription "Conocimiento, comprensión y aplicación de los fundamentos del vuelo atmosférico de las aeronaves, incluyendo los lanzadores y misiles."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145001004/2025-26/RA45> a ns1:LearningResult ;
    ns1:learningResultCode "RA45" ;
    ns1:learningResultDescription "Conocimiento, comprensión y aplicación de los fundamentos del vuelo orbital de los vehículos espaciales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145001004/2025-26/RA46> a ns1:LearningResult ;
    ns1:learningResultCode "RA46" ;
    ns1:learningResultDescription "Conocimiento, comprensión y aplicación de las distintas infraestructuras aeroportuarias y la navegación aérea."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145001004/2025-26/didactic_resource/1> a ns1:DidacticResource ;
    ns1:bibliographyDescription "La finalidad de este texto es proporcionar una introducción a los fundamentos de la ingeniería aeroespacial, centrando el contenido en aquellos aspectos que rigen el movimiento de los vehículos aeroespaciales."@es ;
    ns1:bibliographyTitle "FRANCHINI, S Y LÓPEZ GARCÍA, O. \"Introducción a la Ingeniería Aeroespacial\". Ed. Garceta, 2ºedición, Madrid, 2011."@es ;
    ns1:bibliographyType "Bibliografía"@es .

