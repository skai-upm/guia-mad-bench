    ns1:bibliographyTitle "F.J. SÁEZ NIETO, L PÉREZ SANZ Y V.F. GÓMEZ COMENDADOR. \"La navegación aérea y el aeropuerto\". Fundación AENA, Madrid, 2002."@es ;
    ns1:bibliographyType "Bibliografía"@es .

