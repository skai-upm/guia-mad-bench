<https://guia-kg.skai.etsisi.upm.es/resource/145001004/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. ACTIVIDADES AEROESPACIALES"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145001004/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. La industria aeroespacial. 1.2. Infraestructuras aeroespaciales. 1.3. Las compañías aéreas. 1.4. Las organizaciones aeronáuticas y espaciales. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145001004/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "6. ECUACIÓN DE CONSERVACIÓN DE LA MASA."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145001004/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "6.1. Definición de gasto másico. 6.2. Flujo compresible e incompresible. 6.3. Definición de caudal. 6.4. Aplicación de la conservación de la masa al caso incompresible. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145001004/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "7. ECUACIÓN DE LA CANTIDAD DE MOVIMIENTO."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145001004/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "7.1. Fuerzas sobre un fluido (volumen y superficie). 7.2. Ecuación de Euler. 7.3. Ecuación de Bernoulli. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145001004/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "8. ASPECTOS CUALITATIVOS DEL FLUJO VISCOSO."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145001004/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "8.1. Flujo con viscosidad. 8.2. Definición de capa límite. 8.3. Definición de esfuerzos viscosos. 8.4. Flujos laminar y turbulento. 8.5. Número de Reynolds. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145001004/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "9. ASPECTOS CUALITATIVOS DEL FLUJO COMPRESIBLE."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145001004/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "9.1. Velocidad del sonido. 9.2. Número de Mach. 9.3. Ondas de Mach, choque y de expansión. 9.4. Movimiento subsónico y supersónico en flujo interno: difusores y toberas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145001004/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "10. AERODINÁMICA DE PERFILES."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145001004/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "10.1. Geometría y nomenclatura de perfiles. 10.2. Fueras aerodinámicas. 10.3. Curvas características. Coeficientes adimensionales. 10.4. Entrada en pérdida. 10.5. Componentes de la resistencia aerodinámica. 10.6. Efectos de compresibilidad. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145001004/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "2. CLASIFICACIÓN DE LOS VEHÍCULOS AEROESPACIALES"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145001004/2025-26/syllabus/20> a ns1:SyllabusItem ;
    ns1:itemIndex 20 ;
    ns1:syllabusDescription "11. AERODINÁMICA DE ALAS."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145001004/2025-26/syllabus/21> a ns1:SyllabusItem ;
    ns1:itemIndex 21 ;
    ns1:syllabusDescription "11.1. Geometría y nomenclatura de alas. 11.2. Flujo sobre un ala de envergadura finita. 11.3. Sustentación en alas (diferencias con perfiles). 11.4. Resistencia inducida. 11.5. Curvas características de las alas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145001004/2025-26/syllabus/22> a ns1:SyllabusItem ;
    ns1:itemIndex 22 ;
    ns1:syllabusDescription "12. DISPOSITIVOS HIPERSUSTENTADORES. CURVAS CARACTERÍSTICAS DEL AVIÓN."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145001004/2025-26/syllabus/23> a ns1:SyllabusItem ;
    ns1:itemIndex 23 ;
    ns1:syllabusDescription "12.1. Dispositivos hipersustentadores. 12.2. Aerodinámica de alas en régimen compresible y supersónico. 12.3. Curvas características del avión (sustentación y polar). Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145001004/2025-26/syllabus/24> a ns1:SyllabusItem ;
    ns1:itemIndex 24 ;
    ns1:syllabusDescription "13. INTRODUCCIÓN A LOS SISTEMAS DE PROPULSIÓN."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145001004/2025-26/syllabus/25> a ns1:SyllabusItem ;
    ns1:itemIndex 25 ;
    ns1:syllabusDescription "13.1. Sistema motopropulsor: motivación y fundamentos. 13.2. Creación de empuje. 13.3. Clasificación de los sistemas de propulsión. 13.4. Envolvente operacional de los distintos sistemas. 13.5. Aspectos medioambientales. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145001004/2025-26/syllabus/26> a ns1:SyllabusItem ;
    ns1:itemIndex 26 ;
    ns1:syllabusDescription "14. SISTEMA DE PROPULSIÓN POR HÉLICE."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145001004/2025-26/syllabus/27> a ns1:SyllabusItem ;
    ns1:itemIndex 27 ;
    ns1:syllabusDescription "14.1. Geometría y nomenclatura. 14.2. Cinemática de la hélice. 14.3. Teoría de cantidad de movimiento. 14.4. Rendimiento propulsivo. Curvas características. 14.5. Regímenes de funcionamiento. 14.6. Sistema de propulsión basado en el motor alternativo. Sin subniveles"@es .

