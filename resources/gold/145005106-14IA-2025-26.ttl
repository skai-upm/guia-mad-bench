        <https://guia-kg.skai.etsisi.upm.es/resource/s.avila%40upm.es> ;
    schema:name "Diseño Grafico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005106/2025-26/CE27> a ns1:Competency ;
    ns1:competencyCode "CE27" ;
    ns1:competencyDescription "Conocimiento adecuado y aplicado a la Ingeniería de: los métodos de cálculo de diseño y proyecto aeronáutico; el uso de la experimentación aerodinámica y de los parámetros más significativos en la aplicación teórica; el manejo de las técnicas experimentales, equipamiento e instrumentos de medida propios de la disciplina; la simulación, diseño, análisis e interpretación de experimentación y operaciones en vuelo; los sistemas de mantenimiento y certificación de aeronaves"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005106/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Capacidad para identificar y resolver problemas aplicando, con creatividad, los conocimientos adquiridos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005106/2025-26/CG6> a ns1:Competency ;
    ns1:competencyCode "CG6" ;
    ns1:competencyDescription "Uso de las Tecnologías de la Información y de las Comunicaciones"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005106/2025-26/CG9> a ns1:Competency ;
    ns1:competencyCode "CG9" ;
    ns1:competencyDescription "Razonamiento crítico y capacidad de asociación que posibiliten el aprendizaje continuo"@es .

