<https://guia-kg.skai.etsisi.upm.es/resource/63000260> a ns1:Course ;
    ns1:courseType "Optativa"@es ;
    ns1:courseYear 1 ;
    ns1:semester "Segundo semestre"@es ;
    schema:courseCode 63000260 ;
    schema:hasCourseInstance <https://guia-kg.skai.etsisi.upm.es/resource/63000260/2025-26> ;
    schema:name "Multivariate Data Analysis"@en,
        "Análisis de Datos Multivariantes"@es ;
    schema:numberOfCredits 4.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/63000260/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/63000260/2025-26/CB09>,
        <https://guia-kg.skai.etsisi.upm.es/resource/63000260/2025-26/CE01>,
        <https://guia-kg.skai.etsisi.upm.es/resource/63000260/2025-26/CT07> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/63000260/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/63000260/2025-26/didactic_resource/2> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/63000260/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/63000260/2025-26/RA7> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/63000260/2025-26/syllabus> ;
    ns1:inpersonHours "42 horas (40.4%)"@es ;
    ns1:numberOfCredits 4.0 ;
    ns1:otherInformation "?La asignatura se relaciona con el ODS3 y el ODS6?"@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "42 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/63000260/2025-26/eventSchedule> ;
    schema:description """La asignatura pretende dar una visión general de los métodos estadísticos multivariantes desde los más clásicos ( regresión y modelos de diseño de experimentos, análisis factorial, cluster, discriminante, correlaciones canónicas, etc. ), hasta los más actuales relacionados con la Inteligencia Artificial como son las redes neuronales (artificial neural networks) y algoritmos de "machine learning". En todos los casos enfocados a aplicaciones relacionadas con la temática del master.
Tema 1: Introducción: al Análisis de Datos Multivariante y Modelos Lineales.
Tema 2: Modelo Lineal General.
Tema 3: Métodos descriptivos multivariantes
Tema 4: Inferencia: Análisis Factorial
Tema 5: Análisis Discriminante y Correlaciones Canónicas
Tema 6: Métodos de Big Data e Inteligencia Artificial."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/esperanza.ayuga%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/concepcion.gonzalez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/esperanza.ayuga%40upm.es> ;
    schema:name "Análisis de Datos Multivariantes"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000260/2025-26/CB09> a ns1:Competency ;
    ns1:competencyCode "CB09" ;
    ns1:competencyDescription "Que los estudiantes sepan comunicar sus conclusiones y los conocimientos y razones últimas que las sustentan a públicos especializados y no especializados de un modo claro y sin ambigüedades / Students are capable of clearly and unambiguously communicating their conclusions, and the underlying knowledge and rationale to specialist and non"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000260/2025-26/CE01> a ns1:Competency ;
    ns1:competencyCode "CE01" ;
    ns1:competencyDescription "Aplicar herramientas de análisis de datos a la interpretación de la información procedente de una campaña de investigación de suelos y aguas subterráneas / Apply data analysis tools to the interpretation of information from soil and groundwater research campaigns"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000260/2025-26/CT07> a ns1:Competency ;
    ns1:competencyCode "CT07" ;
    ns1:competencyDescription "Redactar memorias, informes y artículos científicos y técnicos / Writing reports and scientific and technical articles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000260/2025-26/RA7> a ns1:LearningResult ;
    ns1:learningResultCode "RA7" ;
    ns1:learningResultDescription "Analizar y tratar datos multivariantes mediante el empleo de software especializado."@es .

