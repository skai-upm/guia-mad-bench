    ns1:learningResultCode "RA140" ;
    ns1:learningResultDescription "Conocer los fundamentos de la logística y la distribución."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000148/2025-26/RA141> a ns1:LearningResult ;
