<https://guia-kg.skai.etsisi.upm.es/resource/93000985/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/93000985/2025-26/CB06>,
        <https://guia-kg.skai.etsisi.upm.es/resource/93000985/2025-26/CB07>,
        <https://guia-kg.skai.etsisi.upm.es/resource/93000985/2025-26/CG> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/93000985/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/93000985/2025-26/didactic_resource/2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/93000985/2025-26/didactic_resource/3>,
        <https://guia-kg.skai.etsisi.upm.es/resource/93000985/2025-26/didactic_resource/4> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/93000985/2025-26/evaluation> ;
