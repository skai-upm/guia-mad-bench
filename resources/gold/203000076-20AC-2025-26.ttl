        <https://guia-kg.skai.etsisi.upm.es/resource/203000076/2025-26/CE09> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/203000076/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/203000076/2025-26/didactic_resource/2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/203000076/2025-26/didactic_resource/3>,
        <https://guia-kg.skai.etsisi.upm.es/resource/203000076/2025-26/didactic_resource/4>,
        <https://guia-kg.skai.etsisi.upm.es/resource/203000076/2025-26/didactic_resource/5>,
        <https://guia-kg.skai.etsisi.upm.es/resource/203000076/2025-26/didactic_resource/6>,
        <https://guia-kg.skai.etsisi.upm.es/resource/203000076/2025-26/didactic_resource/7> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/203000076/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/203000076/2025-26/RA16>,
        <https://guia-kg.skai.etsisi.upm.es/resource/203000076/2025-26/RA17>,
        <https://guia-kg.skai.etsisi.upm.es/resource/203000076/2025-26/RA18>,
        <https://guia-kg.skai.etsisi.upm.es/resource/203000076/2025-26/RA19>,
        <https://guia-kg.skai.etsisi.upm.es/resource/203000076/2025-26/RA20> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/203000076/2025-26/syllabus> ;
    ns1:inpersonHours "97 horas (46.6%)"@es ;
    ns1:numberOfCredits 8.0 ;
    ns1:otherInformation """La asignatura aborda la alimentación, producción e higiene en los animales rumiantes, por lo que se tratarán aspectos relacionados con varios ODS. Los rumiantes generan productos de alto valor nutritivo, lo que estaría relacionado con los ODS 2 (hambre cero), especialmente en pasíses en vías de desarrollo y zonas desfavorecidas, y ODS 3 (salud y bienestar). También se tratará el efecto de la ganadería de rumiantes en la generación de gases de efecto invernadero debido a su producción de metano, aspecto que está muy relacionado con el ODS 13 (acción por el clima).
La asignatura también contribuye a obtener varias competencias transversales del Máster.
No es un requisito indispensable, pero es recomendable disponer de una bata para las prácticas de laboratorio."""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "98 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/203000076/2025-26/eventSchedule> ;
    schema:description """La asignatura abordará los siguientes aspoectos:
- Particularidades de la digestión y metabolismo de los rumiantes.
- Valoración de alimentos para rumiantes. Tablas de valor nutritivo de ingredientes para piensos y forrajes.
- Estimación de necesidades nutritivas y de la capacidad de ingestión para diferentes estados fisiológicos.
- Efecto de la alimentación sobre la salud animal, la calidad de los productos y el impacto ambiental.
- Programas de alimentación y formulación de raciones completas y piensos compuestos.
- Sistemas de producción en el ganado bovino de leche y carne.
- Sistemas de producción de pequeños rumiantes.
- Alojamientos e higiene de rumiantes."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/mariadolores.carro%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/antonio.callejo%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/josemaria.arroyo.martinez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/mariadolores.carro%40upm.es> ;
    schema:name "Alimentación, Produción e Higiene en Rumiantes"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000076/2025-26/CE01> a ns1:Competency ;
    ns1:competencyCode "CE01" ;
    ns1:competencyDescription "Adquirir unos conocimientos y unas destrezas adecuadas en producción y sanidad animal para poder plantear soluciones y resolver las problemáticas inherentes a las explotaciones ganaderas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000076/2025-26/CE02> a ns1:Competency ;
    ns1:competencyCode "CE02" ;
    ns1:competencyDescription "Aplicar conocimientos avanzados acerca de la gestión técnico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000076/2025-26/CE03> a ns1:Competency ;
    ns1:competencyCode "CE03" ;
    ns1:competencyDescription "Evaluar adecuadamente el efecto de los factores de producción y de las técnicas de manejo, sobre la productividad de los modelos y la calidad de los productos ganaderos generados."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000076/2025-26/CE04> a ns1:Competency ;
    ns1:competencyCode "CE04" ;
    ns1:competencyDescription "Diseñar nuevas estrategias para mejorar la productividad de los modelos ganaderos, optimizando la utilización de los factores de producción, afrontando adecuadamente la temática del bienestar animal y minimizando el impacto ambiental de los mencionados modelos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000076/2025-26/CE09> a ns1:Competency ;
    ns1:competencyCode "CE09" ;
    ns1:competencyDescription "Saber utilizar las herramientas y técnicas bioinformáticas más actuales a la investigación en producción animal y en sanidad animal."@es .

