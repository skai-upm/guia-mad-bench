<https://guia-kg.skai.etsisi.upm.es/resource/203000076/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/203000076/2025-26/CE01>,
        <https://guia-kg.skai.etsisi.upm.es/resource/203000076/2025-26/CE02>,
