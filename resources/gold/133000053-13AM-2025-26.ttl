    schema:hasCourseInstance <https://guia-kg.skai.etsisi.upm.es/resource/133000053/2025-26> ;
    schema:name "Infrastructures For Fish Passage."@en,
        "Infraestructuras de Paso para Peces"@es ;
    schema:numberOfCredits 3.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/133000053/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/133000053/2025-26/CB10>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000053/2025-26/CB6>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000053/2025-26/CE14>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000053/2025-26/CT7> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/133000053/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000053/2025-26/didactic_resource/2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000053/2025-26/didactic_resource/3>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000053/2025-26/didactic_resource/4>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000053/2025-26/didactic_resource/5> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/133000053/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/133000053/2025-26/RA50> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/133000053/2025-26/syllabus> ;
    ns1:inpersonHours "35 horas y 30 minutos (45.5%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation "Las competencias y los resultados de aprendizaje de esta asignatura son conformes a la memoria verifica del título"@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "35 horas y 30 minutos"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/133000053/2025-26/eventSchedule> ;
    schema:description """Esta asignatura tiene por objetivo capacitar tecnicamente a los alumnos para:
Identificar y caracterizar barreras para la transitabilidad de la ictiofauna.
Definir prioridades de actuación y establecer especies objetivo
Discriminar la solución óptima de transitabilidad en función de los condicionantes técnicos y naturales
Identificar los condicionantes del proyecto en:
o Ubicación
o Comportamiento hidráulico
o Disipación de energía
o Capacidad natatoria
o Peculiaridades de la entrada y la salida
o Otras funcionalidades
Diseñar pasos artificiales
Establecer protocolos de mantenimiento y seguimiento"""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/carolina.martinez%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/carolina.martinez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/fernando.magdaleno%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/ricardo.garcia%40upm.es> ;
    schema:name "Infraestructuras de Paso para Peces"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000053/2025-26/CB10> a ns1:Competency ;
    ns1:competencyCode "CB10" ;
    ns1:competencyDescription "Que los estudiantes posean las habilidades de aprendizaje que les permitan continuar estudiando de un modo que habrá de ser en gran medida autodirigido o autónomo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000053/2025-26/CB6> a ns1:Competency ;
    ns1:competencyCode "CB6" ;
    ns1:competencyDescription "Poseer y comprender conocimientos que aporten una base u oportunidad de ser originales en el desarrollo y/o aplicación de ideas, a menudo en un contexto de investigación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000053/2025-26/CE14> a ns1:Competency ;
    ns1:competencyCode "CE14" ;
    ns1:competencyDescription "Aplicar e integrar conocimientos innovadores de ingeniería y gestión aplicados al uso sostenible de masas de agua y a la planificación de recursos hídricos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000053/2025-26/CT7> a ns1:Competency ;
    ns1:competencyCode "CT7" ;
    ns1:competencyDescription "Utilizar la lengua inglesa para la comunicación oral y escrita a nivel avanzado en entornos académicos y profesionales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000053/2025-26/RA50> a ns1:LearningResult ;
    ns1:learningResultCode "RA50" ;
    ns1:learningResultDescription "Complementar los conocimientos, destrezas y habilidades en ámbitos eminentemente prácticos vinculados con el uso y gestión de los ecosistemas acuáticos y los biomas a ellos vinculados"@es .

