    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/563000129/2025-26/syllabus> ;
    ns1:inpersonHours "40 horas (38.5%)"@es ;
    ns1:numberOfCredits 4.0 ;
    ns1:otherInformation ""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "40 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/563000129/2025-26/eventSchedule> ;
    schema:description "Esta asignatura es una introducción al procesamiento digital de las imágenes. Se analizará la adquisición de las imágenes, el procesamiento tanto lineal como no lineal, la segmentación y la extracción de características de alto nivel desde las imágenes. También se contempla la implementación de algoritmos para el análisis de las imágenes mediante Matlab. El enfoque es teórico-práctico, con múltiples aplicaciones en el ámbito industrial."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/carlos.platero%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/carlos.platero%40upm.es> ;
    schema:name "Visión Artificial"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000129/2025-26/CB06> a ns1:Competency ;
    ns1:competencyCode "CB06" ;
    ns1:competencyDescription "Poseer y comprender conocimientos que aporten una base u oportunidad de ser originales en el desarrollo y/o aplicación de ideas, a menudo en un contexto de investigación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000129/2025-26/CG02> a ns1:Competency ;
    ns1:competencyCode "CG02" ;
    ns1:competencyDescription "Capacidad de integrar conocimientos y enfrentarse a la complejidad de formular juicios a partir de una información que, siendo incompleta o limitada, incluya reflexiones sobre las responsabilidades sociales y éticas vinculadas a la aplicación de sus conocimientos y juicios."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000129/2025-26/CG05> a ns1:Competency ;
    ns1:competencyCode "CG05" ;
    ns1:competencyDescription "Capacidad para la puesta en marcha, dirección y gestión de diseño y desarrollo de productos, procesos de producción, etc., en el ámbito de la ingeniería de producción, con garantía de la seguridad para las personas y bienes, la c0alidad final de los productos y su homologación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000129/2025-26/CG06> a ns1:Competency ;
    ns1:competencyCode "CG06" ;
    ns1:competencyDescription "Capacidad para la aplicación de los conocimientos adquiridos y resolver problemas en entornos nuevos o poco conocidos dentro de contextos más amplios y multidisciplinares, siendo capaces de integrar conocimientos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000129/2025-26/CG07> a ns1:Competency ;
    ns1:competencyCode "CG07" ;
    ns1:competencyDescription "Capacidad para saber comunicar (de forma oral y escrita) las conclusiones y los conocimientos y razones últimas que lo sustentan a públicos especializados y no especializados de un modo claro y sin ambigüedades."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000129/2025-26/CG08> a ns1:Competency ;
    ns1:competencyCode "CG08" ;
    ns1:competencyDescription "Poseer habilidades para el aprendizaje continuado, autodirigido y autónomo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000129/2025-26/RA36> a ns1:LearningResult ;
    ns1:learningResultCode "RA36" ;
    ns1:learningResultDescription "Diseñar y construir un sistemas de inspección de productos mediante técnicas de Visión Artificial"@es .

