    schema:name "Artificial Vision"@en,
        "Visión Artificial"@es ;
    schema:numberOfCredits 4.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/563000129/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/563000129/2025-26/CB06>,
        <https://guia-kg.skai.etsisi.upm.es/resource/563000129/2025-26/CG02>,
