<https://guia-kg.skai.etsisi.upm.es/resource/43000654> a ns1:Course ;
    ns1:courseType "Obligatoria"@es ;
    ns1:courseYear 1 ;
    ns1:semester "Primer semestre"@es ;
    schema:courseCode 43000654 ;
    schema:hasCourseInstance <https://guia-kg.skai.etsisi.upm.es/resource/43000654/2025-26> ;
    schema:name "Advanced Programming"@en,
        "Programación Avanzada"@es ;
    schema:numberOfCredits 1.5 .

<https://guia-kg.skai.etsisi.upm.es/resource/43000654/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/43000654/2025-26/C6>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000654/2025-26/C7>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000654/2025-26/K3>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000654/2025-26/Sk4> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/43000654/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/43000654/2025-26/RA47> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/43000654/2025-26/syllabus> ;
    ns1:inpersonHours "25 horas (61.7%)"@es ;
    ns1:numberOfCredits 1.5 ;
    ns1:otherInformation ""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "25 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/43000654/2025-26/eventSchedule> ;
    schema:description """La asignatura de Programación Avanzada se centra en el diseño y aplicación de algoritmos informáticos necesarios para la gestión y mantenimiento de infraestructuras.
Bajo esta premisa, la asignatura abarca los aspectos fundamentales de la programación y de la programación orientada a objetos. Una vez proporcionadas las bases, se procederá a la enseñanza de las diferentes librerías útiles para el análisis de datos y representación de resultados."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/marcos.garcia%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/marcos.garcia%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/ruben.mpavon%40upm.es> ;
    schema:name "Programación Avanzada"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000654/2025-26/C6> a ns1:Competency ;
    ns1:competencyCode "C6" ;
    ns1:competencyDescription "[Proviene de la competencia CG3]: Capacidad para la participación en actividades de I+D+i mediante la utilización de recursos experimentales mediante técnicas de instrumentación y uso de sensores TIPO: Competencias"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000654/2025-26/C7> a ns1:Competency ;
    ns1:competencyCode "C7" ;
    ns1:competencyDescription "[Proviene de la competencia CG2]: Capacidad para la participación en actividades de I+D+i mediante la utilización de recursos de modelización predictiva mediante el uso de técnicas de programación informática TIPO: Competencias"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000654/2025-26/K3> a ns1:Competency ;
    ns1:competencyCode "K3" ;
    ns1:competencyDescription "[Proviene de la competencia CG3]: Identifica y explica los aspectos determinantes para diseñar, analizar e interpretar experimentos relevantes, así como usar varios lenguajes de computación, programas de análisis y simulación, y modelos avanzados en ingeniería estructural, geotécnica y de materiales estructurales. TIPO: Conocimientos o contenidos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000654/2025-26/RA47> a ns1:LearningResult ;
    ns1:learningResultCode "RA47" ;
    ns1:learningResultDescription "Los resultados del aprendizaje correspondientes a esta asignatura han quedado definidos en el apartado de competencias de este documento, señalando los que corresponden a conocimientos, habilidades y competencias propiamente dichas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000654/2025-26/Sk4> a ns1:Competency ;
    ns1:competencyCode "Sk4" ;
    ns1:competencyDescription "[Proviene de la competencia CB10]: Demuestra que puede adquirir conocimientos complejos y continuar estudiando de un modo que habrá de ser en gran medida auto"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000654/2025-26/evaluation> a ns1:EvaluationSystem ;
    ns1:evaluationDescription """Los criterios de calificación de la materia serán los siguientes:
Convocatoria Ordinaria (evaluación continua)
Prácticas de clase (30%) . Práctias teórico-prácticas y en algún caso telemáticas que se irán realizando durante el transcurso de la clase.
Examen final ordinario de la materia (70%). Examen final de 2 horas. El 40% de dicho examen se obtendrá a partir de tipo Test. El 60% restante se obtendrá a partir de un ejercicio teórico-práctico.
La nota final por convocatoria Ordinaria será siempre la mayor de entre la obtenida por evaluación continua y la obtenida por evaluación final.
Convocatoria Ordinaria (evaluación final)
Examen final ordinario de la materia (100%). Examen final de 2 horas. El 40% de dicho examen se obtendrá a partir de tipo Test. El 60% restante se obtendrá a partir de un ejercicio teórico-práctico.
La nota final por convocatoria Ordinaria será siempre la mayor de entre la obtenida por evaluación continua y la obtenida por evaluación final.
Convocatoria Extraordinaria (únicamente evaluación final)
Examen final extraordinario de la materia (100%). Examen final de 2 horas. El 40% de dicho examen se obtendrá a partir de tipo Test. El 60% restante se obtendrá a partir de un ejercicio teórico-práctico."""@es ;
    ns1:hasEvaluationTrial <https://guia-kg.skai.etsisi.upm.es/resource/43000654/2025-26/evaluation/trial1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000654/2025-26/evaluation/trial2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000654/2025-26/evaluation/trial3>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000654/2025-26/evaluation/trial4>,
