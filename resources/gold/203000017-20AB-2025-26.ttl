    ns1:numberOfCredits 4.0 ;
    ns1:otherInformation "Se tendrán en cuenta los Objetivos y Metas de Desarrollo Sostenible (ODS) de Naciones Unidas en la docencia de la asignatura, especialmente en su aplicación."@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
