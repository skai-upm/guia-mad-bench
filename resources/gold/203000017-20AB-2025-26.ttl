    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/203000017/2025-26/eventSchedule> ;
    schema:description """La asignatura introduce los fundamentos teóricos del Diseño de Experimentos, el Análisis Multivariante y el Análisis de Series de Tiempo, y prepara al alumno para su aplicación en el ámbito de la Agricultura, el medio ambiente y los recursos naturales con especial énfasis en la sostenibilidad de la Agricultura, en la cuantificación y verificación de relaciones, y en la estimación de modelos dinámicos de predicción. Se tendrán en cuenta los Objetivos y Metas de Desarrollo Sostenible (ODS) de Naciones Unidas en la docencia de la asignatura, especialmente en su aplicación.
Los alumnos adquirirán experiencia en el manejo de software estadístico para la aplicación de estos métodos."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/javier.litago%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/javier.litago%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/laura.recuero%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/miguel.ibanez%40upm.es> ;
    schema:name "Diseño de Experimentos y Análisis de Datos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000017/2025-26/CB06> a ns1:Competency ;
    ns1:competencyCode "CB06" ;
    ns1:competencyDescription "Poseer y comprender conocimientos que aporten una base u oportunidad de ser originales en el desarrollo y/o aplicación de ideas, a menudo en un contexto de investigación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000017/2025-26/CB07> a ns1:Competency ;
    ns1:competencyCode "CB07" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en entornos nuevos o poco conocidos dentro de contextos más amplios (o multidisciplinares) relacionados con su área de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000017/2025-26/CB08> a ns1:Competency ;
    ns1:competencyCode "CB08" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de integrar conocimientos y enfrentarse a la complejidad de formular juicios a partir de una información que, siendo incompleta o limitada, incluya reflexiones sobre las responsabilidades sociales y éticas vinculadas a la aplicación de sus conocimientos y juicios"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000017/2025-26/CB09> a ns1:Competency ;
    ns1:competencyCode "CB09" ;
    ns1:competencyDescription "Que los estudiantes sepan comunicar sus conclusiones y los conocimientos y razones últimas que las sustentan a públicos especializados y no especializados de un modo claro y sin ambigüedades"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000017/2025-26/CB10> a ns1:Competency ;
    ns1:competencyCode "CB10" ;
    ns1:competencyDescription "Que los estudiantes posean las habilidades de aprendizaje que les permitan continuar estudiando de un modo que habrá de ser en gran medida autodirigido o autónomo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000017/2025-26/CG01> a ns1:Competency ;
    ns1:competencyCode "CG01" ;
    ns1:competencyDescription "Capacidad de análisis y síntesis de la información disponible o de los datos extraídos de un sistema agroambiental"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000017/2025-26/CG02> a ns1:Competency ;
    ns1:competencyCode "CG02" ;
    ns1:competencyDescription "Capacidad de integración de los resultados experimentales en modelos y herramientas de gestión."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000017/2025-26/CT01> a ns1:Competency ;
    ns1:competencyCode "CT01" ;
    ns1:competencyDescription "Capacidad para comprender los contenidos de clases magistrales, conferencias y seminarios en lengua inglesa."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000017/2025-26/CT02> a ns1:Competency ;
