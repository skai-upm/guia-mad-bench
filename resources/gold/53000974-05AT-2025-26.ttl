    schema:name "Acustica Aplicada"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000974/2025-26/CE1> a ns1:Competency ;
    ns1:competencyCode "CE1" ;
    ns1:competencyDescription "Utilizar las ventajas que aportan las herramientas de diseño y cálculos asistidos por computador (?M"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000974/2025-26/CE2> a ns1:Competency ;
    ns1:competencyCode "CE2" ;
    ns1:competencyDescription "Realizar actividades de análisis, diseño, fabricación, ensayo y mantenimiento de máquinas, productos y dispositivos, aplicando metodologías estructuradas, considerando el ciclo de vida global."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000974/2025-26/CE3> a ns1:Competency ;
    ns1:competencyCode "CE3" ;
    ns1:competencyDescription "Utilizar conocimientos multidisciplinarios de mecánica, electrotecnia, control, medios continuos y materiales para el desarrollo de procesos, utillajes y máquinas de fabricación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000974/2025-26/CE4> a ns1:Competency ;
    ns1:competencyCode "CE4" ;
    ns1:competencyDescription "Analizar, diseñar, planificar técnicas de optimización de procesos y modelado de información e instrumentación para la mejora del ciclo de vida del producto."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000974/2025-26/CE5> a ns1:Competency ;
    ns1:competencyCode "CE5" ;
    ns1:competencyDescription "Relacionar las diferentes aéreas de simulación afines a la ingeniería mecánica."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000974/2025-26/CE6> a ns1:Competency ;
    ns1:competencyCode "CE6" ;
    ns1:competencyDescription "Analizar, diseñar y modelar los distintos componentes de un sistema en base al dominio físico al que pertenezcan, aplicando distintas técnicas de simulación a modelos realistas y multidominio dentro del área de ingeniería mecánica."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000974/2025-26/CE7> a ns1:Competency ;
    ns1:competencyCode "CE7" ;
    ns1:competencyDescription "Analizar y diseñar vehículos y sistemas vehiculares e interpretar los comportamientos de los principales sistemas vehiculares para su aplicación al diseño y evaluación de sus comportamientos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000974/2025-26/CE8> a ns1:Competency ;
    ns1:competencyCode "CE8" ;
    ns1:competencyDescription "Aplicar modelos estadísticos avanzados para la investigación y análisis de ensayos y procesos, la medida e inspección en producción y técnicas de reconstrucción dinámica de sistemas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000974/2025-26/CE9> a ns1:Competency ;
    ns1:competencyCode "CE9" ;
    ns1:competencyDescription "Redactar de documentación técnica y no especializada dentro del ámbito de la ingeniería mecánica. Búsqueda de fuentes y uso de Bases de datos. Difusión de resultados."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000974/2025-26/CG%201> a ns1:Competency ;
    ns1:competencyCode "CG 1" ;
    ns1:competencyDescription "Aplicar conocimientos de ciencias y tecnologías avanzadas a la práctica de la Ingeniería Mecánica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000974/2025-26/CG%202> a ns1:Competency ;
    ns1:competencyCode "CG 2" ;
    ns1:competencyDescription "Diseñar, desarrollar, implementar, gestionar y mejorar productos, sistemas y procesos en los distintos ámbitos de la ingeniería mecánica, usando técnicas analíticas, computacionales o experimentales apropiadas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000974/2025-26/CG%203> a ns1:Competency ;
    ns1:competencyCode "CG 3" ;
    ns1:competencyDescription "Aplicar los conocimientos adquiridos para identificar, formular y resolver problemas dentro de contextos amplios y multidisciplinarios, siendo capaces de integrar conocimientos, trabajando en equipos multidisciplinares y desarrollando actividades de I+D."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000974/2025-26/CG%204> a ns1:Competency ;
    ns1:competencyCode "CG 4" ;
    ns1:competencyDescription "Valorar el impacto de la ingeniería mecánica en el medio ambiente, el desarrollo sostenible de la sociedad y la importancia de trabajar en un entorno profesional y responsable"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000974/2025-26/CG%205> a ns1:Competency ;
    ns1:competencyCode "CG 5" ;
    ns1:competencyDescription "Comunicar los conocimientos y conclusiones, tanto de forma oral, escrita y gráfica, a públicos especializados y no especializados de un modo claro y sin ambigüedades."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000974/2025-26/CG%206> a ns1:Competency ;
    ns1:competencyCode "CG 6" ;
    ns1:competencyDescription "Preparar para el aprendizaje continuo a lo largo de la vida para su adecuado desarrollo profesional y para la innovación, investigación y desarrollo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000974/2025-26/CG%207> a ns1:Competency ;
    ns1:competencyCode "CG 7" ;
    ns1:competencyDescription "Aplicar nuevas tecnologías y herramientas de la Ingeniería Mecánica en sus actividades profesionales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000974/2025-26/CG%208> a ns1:Competency ;
    ns1:competencyCode "CG 8" ;
    ns1:competencyDescription "Operar en un entorno bilingüe (inglés"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000974/2025-26/CG%209> a ns1:Competency ;
    ns1:competencyCode "CG 9" ;
    ns1:competencyDescription "Crear nuevas ideas (Creatividad)."@es .

