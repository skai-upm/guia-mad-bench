    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/53001637/2025-26/syllabus> ;
    ns1:inpersonHours "16 horas (41%)"@es ;
    ns1:numberOfCredits 1.5 ;
    ns1:otherInformation ""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
