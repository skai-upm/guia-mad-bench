<https://guia-kg.skai.etsisi.upm.es/resource/105000023/2025-26/Ce%202> a ns1:Competency ;
    ns1:competencyCode "Ce 2" ;
    ns1:competencyDescription "Formalización y especificación de problemas reales cuya solución requiere el uso de la informática."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000023/2025-26/Ce%2021> a ns1:Competency ;
    ns1:competencyCode "Ce 21" ;
    ns1:competencyDescription "Educir, analizar y especificar las necesidades de los clientes (empresas o usuarios individuales), plazos, medios disponibles y posibles condicionantes que pudieran afectar al sistema a desarrollar."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000023/2025-26/Ce%2022> a ns1:Competency ;
    ns1:competencyCode "Ce 22" ;
    ns1:competencyDescription "Capacidad de aplicar sus conocimientos e intuición para diseñar el hardware/software que cumple unos requisitos especificados."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000023/2025-26/Ce%2025> a ns1:Competency ;
    ns1:competencyCode "Ce 25" ;
    ns1:competencyDescription "Concebir y diseñar la arquitectura de un sistema software."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000023/2025-26/Ce%2032> a ns1:Competency ;
    ns1:competencyCode "Ce 32" ;
    ns1:competencyDescription "Comprender el concepto de ciclo de vida, que abarca el significado de sus fases (planificación, desarrollo, instalación y evolución), las consecuencias para el desarrollo de todos los aspectos de los sistemas informáticos (el software, el hardware, y el interfaz humano"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000023/2025-26/Ce%2039> a ns1:Competency ;
    ns1:competencyCode "Ce 39" ;
    ns1:competencyDescription "Conocer y aplicar los principios de la ingeniería del software y de sus tecnologías para garantizar que las implementaciones de software sean robustas, fiables y apropiadas para la audiencia a la que van destinadas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000023/2025-26/Ce%2041> a ns1:Competency ;
    ns1:competencyCode "Ce 41" ;
    ns1:competencyDescription "Elegir y usar modelos de proceso y entornos de programación apropiados para proyectos que implican aplicaciones tradicionales, así como áreas de aplicación emergentes."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000023/2025-26/Ce%209> a ns1:Competency ;
    ns1:competencyCode "Ce 9" ;
    ns1:competencyDescription "Poseer las destrezas que se requieren para diseñar e implementar unidades estructurales mayores que utilizan los algoritmos y las estructuras de datos, así como las interfaces por las que se comunican estas unidades."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000023/2025-26/RA247> a ns1:LearningResult ;
    ns1:learningResultCode "RA247" ;
    ns1:learningResultDescription "Diseñar y construir sistemas informáticos capaces de resolver problemas para los que no se conoce solución."@es .

