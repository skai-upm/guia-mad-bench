<https://guia-kg.skai.etsisi.upm.es/resource/103000845/2025-26/CG03> a ns1:Competency ;
    ns1:competencyCode "CG03" ;
    ns1:competencyDescription "La capacidad de usar la lengua inglesa de manera competente, es decir, con capacitación para tareas complejas de trabajo y estudio/ The ability to use the English language in a competent way, i.e., with training for work and study complex tasks."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000845/2025-26/CG04> a ns1:Competency ;
    ns1:competencyCode "CG04" ;
    ns1:competencyDescription "La capacidad de toma de decisiones y liderazgo de equipos, basada en una comprensión holística de las contribuciones de la educación superior, la investigación y las empresas para la creación de valor, en equipos y contextos de tamaño limitado /The ability of decision"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000845/2025-26/CG07> a ns1:Competency ;
    ns1:competencyCode "CG07" ;
    ns1:competencyDescription "Capacidad de trabajar y comunicarse también en contextos internacionales/ To be able to communicate and work in international contexts."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000845/2025-26/CG08> a ns1:Competency ;
    ns1:competencyCode "CG08" ;
    ns1:competencyDescription "La capacidad de traducir innovaciones en soluciones comerciales factibles/ To be able to translate innovations into feasible business solutions."@es .

