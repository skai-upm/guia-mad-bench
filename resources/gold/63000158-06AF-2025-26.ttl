<https://guia-kg.skai.etsisi.upm.es/resource/63000158/2025-26/CE01> a ns1:Competency ;
    ns1:competencyCode "CE01" ;
    ns1:competencyDescription "Capacidad para abordar y resolver problemas matemáticos avanzados de ingeniería, desde el planteamiento del problema hasta el desarrollo de la formulación y su implementación en un programa de ordenador. En particular, capacidad para formular, programar y aplicar modelos analíticos y numéricos avanzados de cálculo, proyectos, planificación y gestión, así como capacidad para la interpretación de los resultados obtenidos, en el contexto de la ingeniería de minas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000158/2025-26/CE02> a ns1:Competency ;
    ns1:competencyCode "CE02" ;
    ns1:competencyDescription "Conocimiento adecuado de aspectos científicos y tecnológicos de mecánica de fluidos, mecánica de medios continuos, cálculo de estructuras, geotecnia, carboquímica y petroquímica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000158/2025-26/CG01> a ns1:Competency ;
    ns1:competencyCode "CG01" ;
    ns1:competencyDescription "Capacitación científico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000158/2025-26/CG02> a ns1:Competency ;
    ns1:competencyCode "CG02" ;
    ns1:competencyDescription "Comprensión de los múltiples condicionamientos de carácter técnicos, legal y de la propiedad que se plantean en el proyectos de una planta o instalación, y capacidad para establecer diferentes alternativas válidas, elegir la óptima y plasmarla adecuadamente, previendo los problemas de su desarrollo, y empleando los métodos y tecnologías más adecuadas, tanto tradicionales como innovadores, con la finalidad de conseguir la mayor eficacia y favorecer el progreso y un desarrollo de la sociedad sostenible y respetuoso con el medio ambiente"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000158/2025-26/CG04> a ns1:Competency ;
    ns1:competencyCode "CG04" ;
    ns1:competencyDescription "Conocimiento de la profesión de Ingeniero de Minas y de las actividades que se puedan realizar en el ámbito de la misma"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000158/2025-26/CG05> a ns1:Competency ;
    ns1:competencyCode "CG05" ;
    ns1:competencyDescription "Conocimiento para aplicar las capacidades técnicas y gestoras de actividades de I+D+i dentro de su ámbito"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000158/2025-26/CG13> a ns1:Competency ;
    ns1:competencyCode "CG13" ;
    ns1:competencyDescription "Capacidad para evaluar y gestionar ambientalmente proyectos, plantas o instalaciones"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000158/2025-26/CG18> a ns1:Competency ;
    ns1:competencyCode "CG18" ;
    ns1:competencyDescription "Conocimientos adecuados de los aspectos científicos y tecnológicos de métodos matemáticos, analíticos y numéricos de la ingeniería, mecánica de fluidos, mecánica de medios continuos, cálculo de estructuras, carboquímica, petroquímica y geotecnia"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000158/2025-26/CT03> a ns1:Competency ;
    ns1:competencyCode "CT03" ;
    ns1:competencyDescription "Capacidad para adoptar soluciones creativas que satisfagan adecuadamente las diferentes necesidades planteadas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000158/2025-26/CT04> a ns1:Competency ;
    ns1:competencyCode "CT04" ;
    ns1:competencyDescription "Capacidad para trabajar de forma efectiva como individuo, organizando y planificando su propio trabajo, de forma independiente o como miembro de un equipo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000158/2025-26/CT05> a ns1:Competency ;
    ns1:competencyCode "CT05" ;
    ns1:competencyDescription "Capacidad para gestionar la información, identificando las fuentes necesarias, los principales tipos de documentos técnicos y científicos, de una manera adecuada y eficiente"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000158/2025-26/RA103> a ns1:LearningResult ;
    ns1:learningResultCode "RA103" ;
    ns1:learningResultDescription "Comprender las vibraciones de sistemas mecánicos complejos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000158/2025-26/RA104> a ns1:LearningResult ;
    ns1:learningResultCode "RA104" ;
    ns1:learningResultDescription "Aplicar el análisis en frecuencia al mantenimiento predictivo"@es .

