<https://guia-kg.skai.etsisi.upm.es/resource/53000551/2025-26/RA12> a ns1:LearningResult ;
    ns1:learningResultCode "RA12" ;
    ns1:learningResultDescription "Capacidad para el análisis y diseño de sistemas eléctricos en situaciones nuevas debidas a: generación distribuida, ferrocarriles para trenes de alta velocidad, etc"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000551/2025-26/RA6> a ns1:LearningResult ;
    ns1:learningResultCode "RA6" ;
    ns1:learningResultDescription "Capacidad para determinar el valor de la intensidad del campo eléctrico en configuraciones electródicas sencillas. Capacidad para entender el funcionamiento de los programas comerciales de cálculo de campos eléctricos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000551/2025-26/RA7> a ns1:LearningResult ;
