<https://guia-kg.skai.etsisi.upm.es/resource/33000872/2025-26/C2> a ns1:Competency ;
    ns1:competencyCode "C2" ;
    ns1:competencyDescription "Elaborar, redactar y ejecutar estudios de ámbito territorial en aplicación de los juicios y conclusiones deducidos de los análisis realizados, controlando las distintas fases, técnicas y herramientas de gestión TIPO: Competencias."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000872/2025-26/K5> a ns1:Competency ;
    ns1:competencyCode "K5" ;
    ns1:competencyDescription "Gestionar presupuestos y tiempos TIPO: Conocimientos o contenidos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000872/2025-26/K6> a ns1:Competency ;
    ns1:competencyCode "K6" ;
    ns1:competencyDescription "Conocer herramientas que permitan el desarrollo y/o aplicación de ideas estratégicas y teóricas en el contexto del proyecto arquitectónico TIPO: Conocimientos o contenidos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000872/2025-26/K7> a ns1:Competency ;
    ns1:competencyCode "K7" ;
    ns1:competencyDescription "Señalar posibles soluciones arquitectónicas a problemas localizados en nuevos entornos (o contemporáneos) relacionados con el proyecto arquitectónico TIPO: Conocimientos o contenidos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000872/2025-26/RA12> a ns1:LearningResult ;
