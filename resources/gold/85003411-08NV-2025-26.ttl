<https://guia-kg.skai.etsisi.upm.es/resource/85003411/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Entorno de la asignatura y planteamientos 1.1. Partes de la teoría del buque 1.2. . Contenidos y planteamientos. 1.3. Actividades prácticas 1.4. Conocimientos requeridos Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003411/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "2. Conceptos elementales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003411/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "2.2.3. Fuerzas hidrostáticas. Flotabilidad y estabilidad. Principio de Arquímedes. Distribución de presiones en movimiento como sólido rígido Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003411/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "3. Cinemática."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003411/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "3.1. Cinemática de los Fluidos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003411/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "3.1.1. Sistemas de referencia de Lagrange y Euler. Movimiento estacionario. Velocidad, vorticidad y aceleración. Sendas y trayectorias. Trazas, líneas fluidas y líneas de corriente. Derivada sustancial. Rotacional. Campos rotacionales. Circulación. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003411/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "4. Ecuaciones generales de la Mecánica de Fluidos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003411/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "4.1. Fenómenos de transporte. 4.1.1. Fenómenos de transporte y Teorema de Transporte de Reynolds Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003411/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "4.2. Relaciones integrales para un volumen de control. 4.2.1. Conservación masa. Conservación Cantidad de Movimiento. Teorema del momento cinético. Ecuación de la energía. Flujos sin fricción: La ecuación de Bernouilli Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003411/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "4.3. Relaciones diferenciales para una partícula fluida. 4.3.1. Continuidad. Cantidad de movimiento. Soluciones de referencia (Couette y Pouiseuille plano). Ecaución de Bernouilli. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003411/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "5. Análisis dimensional y semejanza física."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003411/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "5.1. Análisis dimensional y semejanza física. 5.1.1. Introducción. El principio de homegeneidad dimensional.Adimensionalización de las ecuaciones básicas. El teorema de \"pi\" Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003411/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "2.1. Características de los fluidos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003411/2025-26/syllabus/20> a ns1:SyllabusItem ;
    ns1:itemIndex 20 ;
    ns1:syllabusDescription "6. Fluidos ideales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003411/2025-26/syllabus/21> a ns1:SyllabusItem ;
    ns1:itemIndex 21 ;
    ns1:syllabusDescription "6.1. Flujos ideales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003411/2025-26/syllabus/22> a ns1:SyllabusItem ;
    ns1:itemIndex 22 ;
    ns1:syllabusDescription "6.1.1. Flujos ideales. Ecuaciones del movimiento irrotacional para líquidos. Coordenadas polares. Ecuación de Laplace. Condiciones de contorno. Función de corriente. Concepto de circulación. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003411/2025-26/syllabus/23> a ns1:SyllabusItem ;
    ns1:itemIndex 23 ;
    ns1:syllabusDescription "6.1.2. Superposición de soluciones. Soluciones del movimiento potencial: movimiento cerca del punto de remanso, fuentes y sumideros, movimiento uniforme, dipolos. Movimiento alrededor de cuerpos: semi-óvalo de Rankine, óvalo de Rankine, esfera Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003411/2025-26/syllabus/24> a ns1:SyllabusItem ;
    ns1:itemIndex 24 ;
    ns1:syllabusDescription "6.2. Movimiento plano"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003411/2025-26/syllabus/25> a ns1:SyllabusItem ;
    ns1:itemIndex 25 ;
    ns1:syllabusDescription "6.2.1. Resolución de la ecuación de Laplace en 2D. Dibujo de líneas de corriente y equipotenciales de velocidad. Superposición de soluciones. Cálculo de campos de velocidades y presiones. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003411/2025-26/syllabus/26> a ns1:SyllabusItem ;
    ns1:itemIndex 26 ;
    ns1:syllabusDescription "6.2.2. Movimiento alrededor de cuerpos planos: cilindro circular. Movimiento potencial plano con circulación. Cálculo de fuerzas de resistencia y sustentación. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003411/2025-26/syllabus/27> a ns1:SyllabusItem ;
    ns1:itemIndex 27 ;
    ns1:syllabusDescription "7. Fluidos viscosos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003411/2025-26/syllabus/28> a ns1:SyllabusItem ;
    ns1:itemIndex 28 ;
    ns1:syllabusDescription "7.1. Fluidos viscosos en conductos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003411/2025-26/syllabus/29> a ns1:SyllabusItem ;
    ns1:itemIndex 29 ;
    ns1:syllabusDescription "7.1.1. Concepto de capa límite. Regímenes del número de Reynolds. Flujos viscosos internos frente a los externos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003411/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "2.1.1. Planteamiento de la primera parte del curso.El concepto de fluido. Gases y líquidos. La hipótesis del medio continuo. Dimensiones y unidades Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003411/2025-26/syllabus/30> a ns1:SyllabusItem ;
    ns1:itemIndex 30 ;
    ns1:syllabusDescription "7.1.2. Movimiento unidireccional laminar. Flujo laminar desarrollado en conductos circulares. Simplificaciones de las ecuaciones de Navier-Stokes. Corrientes de Couette y Poiseuille 2D y de Pouseuille en cilíndricas. Superposición de soluciones. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003411/2025-26/syllabus/31> a ns1:SyllabusItem ;
    ns1:itemIndex 31 ;
    ns1:syllabusDescription "7.1.3. Movimiento unidireccional en régimen turbulento."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003411/2025-26/syllabus/32> a ns1:SyllabusItem ;
    ns1:itemIndex 32 ;
    ns1:syllabusDescription "7.1.3.1. Media temporal de Reynolds. Pérdida de carga: primarias y secundarias. Ley de la pared. Ley de la capa logarítmica. Ley defecto de velocidad. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003411/2025-26/syllabus/33> a ns1:SyllabusItem ;
    ns1:itemIndex 33 ;
    ns1:syllabusDescription "7.1.3.2. Flujo turbulento en conductos circulares. Efectos de la rugosidad. La carta de Moody. Modelización de la turbulencia. Circuitos hidraúlicos resolución con ordenador. Bombas y turbinas. Región de entrada a un conducto. Medidores de velocidad y caudal. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003411/2025-26/syllabus/34> a ns1:SyllabusItem ;
    ns1:itemIndex 34 ;
    ns1:syllabusDescription "7.2. Flujo alrededor de cuerpos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003411/2025-26/syllabus/35> a ns1:SyllabusItem ;
    ns1:itemIndex 35 ;
    ns1:syllabusDescription "7.2.1. Efectos geométricos y del número de Reynolds. Modelo integral en la teoría de la capa límite. Análisis de Karman para la placa plana. Las ecuaciones de la capa límite. Capa límite sobre una placa plana. Flujo laminar. ecuación de Blasius. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003411/2025-26/syllabus/36> a ns1:SyllabusItem ;
    ns1:itemIndex 36 ;
    ns1:syllabusDescription "7.2.2. Transición a la turbulencia. Flujo turbulento. Capa límite con gradiente de presión. Separación de flujo. Modelo de Thwaites Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003411/2025-26/syllabus/37> a ns1:SyllabusItem ;
    ns1:itemIndex 37 ;
    ns1:syllabusDescription "7.2.3. Introducción a los cuerpos con sustentación Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003411/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "2.1.2. Descripción macroscópicas y microscópicas de los fluidos. Densidad, velocidad, temperatura y presión Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003411/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "2.1.3. Viscosidad y otras propiedades secundarias. Fluidos Newtonianos y no Newtonianos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003411/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "2.1.4. Propiedades termodinámicas del fluido. Historia y visión global de la Mecálica de Fluidos Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003411/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "2.2. Fuerzas en el seno de un fluido"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003411/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "2.2.1. Fuerzas en el seno de un fluido considerado como un continuo. Fuerzas volumétricas, másicas y de superficie Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003411/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "2.2.2. Tensor de esfuerzos. Presión y gradiente de presión. Equilibrio de una partícula fluida. Distribución de presiones en hidrostática Sin subniveles"@es .

