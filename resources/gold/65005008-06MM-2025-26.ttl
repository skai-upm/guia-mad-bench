<https://guia-kg.skai.etsisi.upm.es/resource/65005008/2025-26/C10> a ns1:Competency ;
    ns1:competencyCode "C10" ;
    ns1:competencyDescription "Comprender y aplicar los ensayos y control de calidad de materiales metálicos y no metálicos, materiales cerámicos y plásticos. TIPO: Competencias"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65005008/2025-26/CON14> a ns1:Competency ;
    ns1:competencyCode "CON14" ;
    ns1:competencyDescription "Capacidad para conocer, comprender y utilizar los principios de la ingeniería mineralúrgica, metalúrgica y de la Tecnología de Materiales.TIPO: Conocimientos o contenidos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65005008/2025-26/CON4> a ns1:Competency ;
