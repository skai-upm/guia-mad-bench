        <https://guia-kg.skai.etsisi.upm.es/resource/205000030/2025-26/RA438>,
        <https://guia-kg.skai.etsisi.upm.es/resource/205000030/2025-26/RA439>,
        <https://guia-kg.skai.etsisi.upm.es/resource/205000030/2025-26/RA440>,
        <https://guia-kg.skai.etsisi.upm.es/resource/205000030/2025-26/RA441> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/205000030/2025-26/syllabus> ;
    ns1:inpersonHours "51 horas y 40 minutos (49.7%)"@es ;
    ns1:numberOfCredits 4.0 ;
    ns1:otherInformation """La asignatura se relaciona con el ODS13 y el ODS15.
La Comisión de Calidad del Centro en su reunión de 29 de mayo de 2023 acordó aprobar la propuesta de reasignación de competencias transversales en las asignaturas de los Grados en Biotecnología, Ingeniería Alimentaria, Ingeniería Agrícola, Ingeniería Agroambiental, Ciencias Agrarias y Bioeconomía, y en el Máster Universitario de Ingeniería Agronómica. En virtud de dicho acuerdo esta asignatura ha sido designada como Asignatura NO Punto Control. Esto significa que si bien puede seguir trabajando una o varias competencias transversales que se abordan en distintos puntos y aspectos de la asignatura, dicha formación y evaluación no será objeto de recopilación de evidencias por los sistemas de acreditación de la calidad del Centro."""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "51 horas y 40 minutos"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/205000030/2025-26/eventSchedule> ;
    schema:description """La asignatura proporciona a los alumnos los conocimientos necesarios para clasificar, caracterizar y cuantificar los residuos o subproductos agrícolas y ganaderos en el marco normativo actual, aplicar distintas estrategias y tecnologías para su gestión, tratamiento y valorización (compostaje), así como conocer los criterios técnicos para optimizar el empleo de estiércoles y compost como fertilizantes en cultivos. Para el tratamiento de los subproductos se plantean las características de cada uno de los materiales orgánicos y las alternativas posibles de tratamiento, los criterios de mezclas, y los aspectos microbiológicos y técnicos para el control del proceso de compostaje. La valorización agrícola de estiércoles y compost minimizando los potenciales efectos contaminantes sobre distintos ecosistemas será la finalidad principal de uso de los residuos, centrándose en este caso en analizar las prácticas agrícolas más adecuadas y la tecnología más moderna para adaptar la liberación de nutrientes en el suelo con las necesidades de la planta, y reducir con ello las pérdidas de N reactivo. Se abordará además el análisis del ciclo de vida asociado a la fertilización.
La asignatura se desarrollará en tres bloques:
Bloque I: Producción, caracterización y sistemas de gestión de residuos agrícolas y ganaderos (1,5 ECTS)
Bloque II: Tratamientos y valorización de los residuos (compostaje) (1,5 ECTS)
Bloque III: Valorización agronómica de estiércoles y compost como fertilizante orgánico (1 ECTS)"""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/paloma.grebollar%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/eduardo.vazquez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/paloma.grebollar%40upm.es> ;
    schema:name "Valorización y Gestión de Residuos Agroganaderos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000030/2025-26/CE16> a ns1:Competency ;
    ns1:competencyCode "CE16" ;
    ns1:competencyDescription "Conocer los efectos ambientales de la actividad agraria sobre el suelo, los recursos hídricos y la atmósfera, así como las principales técnicas para su mitigación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000030/2025-26/CE24> a ns1:Competency ;
    ns1:competencyCode "CE24" ;
    ns1:competencyDescription "Capacidad de proponer estrategias de optimización del proceso productivo en términos de un uso sostenible agronómico y ambiental."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000030/2025-26/CG07> a ns1:Competency ;
    ns1:competencyCode "CG07" ;
    ns1:competencyDescription "Adquirir la formación profesional necesaria para desarrollar estrategias sostenibles de producción vegetal y animal de forma eficiente y acorde a los recursos disponibles."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000030/2025-26/CT03> a ns1:Competency ;
    ns1:competencyCode "CT03" ;
    ns1:competencyDescription "Tener compromiso ético y profesional y respeto por el medio ambiente"@es .

