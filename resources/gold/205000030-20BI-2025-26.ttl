<https://guia-kg.skai.etsisi.upm.es/resource/205000030/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Bloque I. Gestión de residuos agroganaderos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000030/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Tema 1.1 Introducción. Definición y cuantificación de residuos y subproductos. Marco normativo. Tipos de residuos y caracterización. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000030/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "2.4. Bases del proceso de vermicompostaje. Optimización del proceso para una mayor calidad del producto final Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000030/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "3. Bloque III. Valorización agronómica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000030/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "3.1. Tema 3.1. Valoración agronómica del purín, estiércol sólido y compost como fertilizante orgánico."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000030/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "3.1.1. Mineralización de abonos orgánicos. Disponibilidad de nutrientes a partir de estiércoles. Ejercicios prácticos Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000030/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "3.2. Tema 3.2. Problemas ambientales asociados a la utilización de estiércoles y compost en el cultivo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000030/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "3.2.1. Emisiones de amoniaco y mitigación. Emisiones de N2O y NOx y mitigación. Lavado de nitrato. Manejo de estiércoles en zonas vulnerables. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000030/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "3.3. Tema 3.3. Análisis de ciclo de vida asociado a la fertilización con estiércoles y buenas prácticas agrícolas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000030/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Tema 1.2 Sistemas de gestión, tratamientos y valorización de subproductos vegetales, agroindustriales y SANDACH Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000030/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "1.3. Tema 1.3 Deyecciones ganaderas. Balances de N y P en los sistemas de producción animal Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000030/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "1.4. Tema 1.4 Manejo y gestión de las deyecciones en granjas. Cálculo de pérdidas de su valor fertilizante Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000030/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "1.5. Tema 1.5 MTD para reducir la contaminación ambiental y mejorar el valor fertilizante de las deyecciones Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000030/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "2. Bloque II. Tratamientos y valorización de residuos agrarios"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000030/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "2.1. Tema 2.1 Gestión de subproductos orgánicos agrarios: Del residuo al recurso. Importancia del reciclaje de nutrientes en un contexto de cambio global Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000030/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "2.2. Tipos de tratamientos para la valorización de residuos agrarios. Compostaje, Vermicompostaje y biometanización. Ejemplos prácticos Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000030/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "2.3. Bases del proceso de compostaje. Optimización del proceso y evaluación de la calidad del compost Sin subniveles"@es .

