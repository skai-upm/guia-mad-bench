    ns1:itemIndex 15 ;
    ns1:syllabusDescription "4.2. Extremos relativos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145002001/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "4.3. Extremos relativos condicionados. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145002001/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "5. INTEGRALES MÚLTIPLES"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145002001/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "5.1. Funciones integrables. Sin subniveles"@es .

