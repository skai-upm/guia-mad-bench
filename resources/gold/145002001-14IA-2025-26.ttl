    ns1:itemIndex 11 ;
    ns1:syllabusDescription "3.3. Derivadas y diferenciales de orden superior. Desarrollo limitado de Taylor. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145002001/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "3.4. Derivadas y diferencial de las funciones compuestas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145002001/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "4. APLICACIONES DEL CÁLCULO DIFERENCIAL"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145002001/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "4.1. Funciones implícita e inversa Sin subniveles"@es .

