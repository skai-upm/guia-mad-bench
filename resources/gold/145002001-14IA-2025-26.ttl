    ns1:itemIndex 33 ;
    ns1:syllabusDescription "6.7.1. Campos gradiente. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145002001/2025-26/syllabus/34> a ns1:SyllabusItem ;
    ns1:itemIndex 34 ;
    ns1:syllabusDescription "6.7.2. Dominios simplemente conexos en el plano y en el espacio. Sin subniveles"@es .

