    ns1:itemIndex 19 ;
    ns1:syllabusDescription "5.2. Integración en intervalos de Rn. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145002001/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Conjuntos abiertos y cerrados. Conjuntos compactos Sin subniveles"@es .

