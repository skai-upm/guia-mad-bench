    ns1:itemIndex 24 ;
    ns1:syllabusDescription "6.2. Integrales de línea. Integrales de campos escalares y vectoriales sobre curvas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145002001/2025-26/syllabus/25> a ns1:SyllabusItem ;
    ns1:itemIndex 25 ;
    ns1:syllabusDescription "6.3. Superficies. Representación paramétrica. Superficies simples y regulares. Vector normal y plano tangente a una superficie."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145002001/2025-26/syllabus/26> a ns1:SyllabusItem ;
    ns1:itemIndex 26 ;
    ns1:syllabusDescription "6.3.1. Superficies de revolución, de traslación y regladas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145002001/2025-26/syllabus/27> a ns1:SyllabusItem ;
    ns1:itemIndex 27 ;
    ns1:syllabusDescription "6.4. Integrales de superficie. Integrales de campos escalares y vectoriales sobre superficies. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145002001/2025-26/syllabus/28> a ns1:SyllabusItem ;
    ns1:itemIndex 28 ;
    ns1:syllabusDescription "6.5. Gradiente y laplaciana de un campo escalar. Divergencia y rotacional de un campo vectorial. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145002001/2025-26/syllabus/29> a ns1:SyllabusItem ;
    ns1:itemIndex 29 ;
    ns1:syllabusDescription "6.6. Teoremas de integración del cálculo vectorial"@es .

