    ns1:itemIndex 20 ;
    ns1:syllabusDescription "5.3. Integración en conjuntos acotados de Rn. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145002001/2025-26/syllabus/21> a ns1:SyllabusItem ;
    ns1:itemIndex 21 ;
    ns1:syllabusDescription "6. INTEGRACIÓN DE CAMPOS ESCALARES Y VECTORIALES SOBRE CURVAS Y SUPERFICIES"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145002001/2025-26/syllabus/22> a ns1:SyllabusItem ;
    ns1:itemIndex 22 ;
    ns1:syllabusDescription "6.1. Curvas planas y curvas en el espacio. Representación paramétrica e implícita."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145002001/2025-26/syllabus/23> a ns1:SyllabusItem ;
    ns1:itemIndex 23 ;
    ns1:syllabusDescription "6.1.1. Triedro intrínseco. Curvaturas a flexión y a torsión. Fórmulas de Frenet. Sin subniveles"@es .

