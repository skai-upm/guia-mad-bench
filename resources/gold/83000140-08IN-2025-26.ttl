    ns1:competencyCode "CE14" ;
    ns1:competencyDescription "(K9)"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/83000140/2025-26/CE15> a ns1:Competency ;
    ns1:competencyCode "CE15" ;
    ns1:competencyDescription "(K10)"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/83000140/2025-26/CE5> a ns1:Competency ;
