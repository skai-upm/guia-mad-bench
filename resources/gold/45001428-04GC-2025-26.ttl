    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/45001428/2025-26/eventSchedule> ;
    schema:description "En la asignatura de Ingeniería Estructural se amplían los conocimientos vistos en la asignatura de Cálculo de Estructuras. Para ello se introducen diferentes conceptos sobre el cálculo matricial aplicado a ingeniería sísmica así como las placas, abordando su cálculo tanto en régimen elástico como en régimen plástico. Finalmente se presentan los fundamentos de la fiabilidad estructural y los formatos de seguridad, que permiten aplicar los conocimientos anteriores al proyecto de estructuras."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/miguel.fernandezruiz%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/antonio.carnerero%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/david.izquierdo%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/josemaria.arrieta%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/mariamercedes.madrid%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/miguel.fernandezruiz%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/nicola.tarque%40upm.es> ;
    schema:name "Ingenieria Estructural"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001428/2025-26/CM29.1> a ns1:Competency ;
    ns1:competencyCode "CM29.1" ;
    ns1:competencyDescription "Conocimiento de la tipología y las bases de cálculo de los elementos prefabricados y su aplicación en los procesos de fabricación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001428/2025-26/CM30.1> a ns1:Competency ;
    ns1:competencyCode "CM30.1" ;
    ns1:competencyDescription "Conocimiento sobre el proyecto, cálculo, construcción y mantenimiento de las obras de edificación en cuanto a la estructura, los acabados, las instalaciones y los equipos propios."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001428/2025-26/CT2> a ns1:Competency ;
    ns1:competencyCode "CT2" ;
    ns1:competencyDescription "Capacidad de organizar y dirigir los esfuerzos de un grupo humano reducido y homogéneo. Desarrolla la competencia transversal 8ª de la normativa UPM."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001428/2025-26/CT3> a ns1:Competency ;
    ns1:competencyCode "CT3" ;
    ns1:competencyDescription "Capacidad de actuar con efectividad como miembro de equipos interdisciplinares. Desarrolla la competencia transversal 5ª de la normativa UPM."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001428/2025-26/RA169> a ns1:LearningResult ;
    ns1:learningResultCode "RA169" ;
    ns1:learningResultDescription "Asume los principios de incertidumbre y riesgo en el cálculo de estructuras"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001428/2025-26/RA170> a ns1:LearningResult ;
    ns1:learningResultCode "RA170" ;
    ns1:learningResultDescription "Calcula estructuras con mecanismos resistentes interactivos, mediante modelos analíticos y computacionales refrendados por la normativa comunitaria"@es .

