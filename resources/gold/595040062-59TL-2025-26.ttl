<https://guia-kg.skai.etsisi.upm.es/resource/595040062/2025-26/CE%20TEL09> a ns1:Competency ;
    ns1:competencyCode "CE TEL09" ;
    ns1:competencyDescription "Capacidad para comprender los mecanismos de propagación y transmisión de ondas electromagnéticas y acústicas, y sus correspondientes dispositivos emisores y receptores."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595040062/2025-26/CE%20TEL16> a ns1:Competency ;
    ns1:competencyCode "CE TEL16" ;
    ns1:competencyDescription "Conocimiento de la normativa y la regulación de las telecomunicaciones en los ámbitos nacional, europeo e internacional."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595040062/2025-26/CE%20TL01> a ns1:Competency ;
    ns1:competencyCode "CE TL01" ;
    ns1:competencyDescription "Capacidad de construir, explotar y gestionar las redes, servicios, procesos y aplicaciones de telecomunicaciones, entendidas éstas como sistemas de captación, transporte, representación, procesado, almacenamiento, gestión y presentación de información multimedia, desde el punto de vista de los servicios telemáticos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595040062/2025-26/CE%20TL04> a ns1:Competency ;
    ns1:competencyCode "CE TL04" ;
    ns1:competencyDescription "Capacidad de describir, programar, validar y optimizar protocolos e interfaces de comunicación en los diferentes niveles de una arquitectura de redes."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595040062/2025-26/CE%20TL05> a ns1:Competency ;
    ns1:competencyCode "CE TL05" ;
    ns1:competencyDescription "Capacidad de seguir el progreso tecnológico de transmisión, conmutación y proceso para mejorar las redes y servicios Telemáticos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595040062/2025-26/CG%2002> a ns1:Competency ;
    ns1:competencyCode "CG 02" ;
    ns1:competencyDescription "Capacidad de búsqueda y selección de información, de razonamiento crítico y de elaboración y defensa de argumentos dentro del área."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595040062/2025-26/CG%2005> a ns1:Competency ;
    ns1:competencyCode "CG 05" ;
    ns1:competencyDescription "Capacidad de trabajo en equipo y en entornos multidisciplinares."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595040062/2025-26/CG%2007> a ns1:Competency ;
