    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/55000031/2025-26/eventSchedule> ;
    schema:description "En la primera parte de la asignatura se introducen las herramientas y métodos necesarios para trabajar con materiales avanzados según su estructura y morfología. En la segunda parte se desarrolla la capacidad para realizar diseños y aplicaciones avanzadas de materiales no metálicos, así como la habilidad para diseñar racionalmente nuevos materiales."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/k.foteinopoulou%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/daniel.martinez.fernandez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/k.foteinopoulou%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/manuel.laso%40upm.es> ;
    schema:name "Estructura y Propiedades de Materiales No Metálicos"@es .

