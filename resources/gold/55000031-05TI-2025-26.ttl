<https://guia-kg.skai.etsisi.upm.es/resource/55000031/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/55000031/2025-26/CE27C>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55000031/2025-26/CG1> ;
