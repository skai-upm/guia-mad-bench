    schema:hasCourseInstance <https://guia-kg.skai.etsisi.upm.es/resource/55001072/2025-26> ;
    schema:name "Solid Mechanics And Materials"@en,
        "Mecánica de Solidos y Materiales"@es ;
    schema:numberOfCredits 4.5 .

<https://guia-kg.skai.etsisi.upm.es/resource/55001072/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/55001072/2025-26/CE23D>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55001072/2025-26/CG1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55001072/2025-26/CG5> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/55001072/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55001072/2025-26/didactic_resource/2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55001072/2025-26/didactic_resource/3> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/55001072/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/55001072/2025-26/RA162>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55001072/2025-26/RA256>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55001072/2025-26/RA287>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55001072/2025-26/RA52> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/55001072/2025-26/syllabus> ;
    ns1:inpersonHours "48 horas (41%)"@es ;
    ns1:numberOfCredits 4.5 ;
    ns1:otherInformation ""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "48 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/55001072/2025-26/eventSchedule> ;
    schema:description "La asignatura de Mecánica de Sólidos y Materiales proporciona la base teórica para comprender el comportamiento termo-mecánico de los sólidos deformables. Partiendo del estudio de la cinemática y el equilibrio de los medios continuos, el curso se centra en el análisis de sólidos deformables sometidos a fuerzas exteriores y solicitaciones térmicas. En él, se presentarán los principios básicos que se pueden aplicar a todos los cuerpos y después se estudiarán los principales modelos consitutivos dentro del contexto de pequeñas deformaciones. Estos son los modelos de la elasticidad, la visco-elasticidad, la plasticidad, la fractura y la fatiga. Con estos ingredientes el alumno podrá, al final del curso, comprender el dimensionamiento de piezas y la selección de materiales para asegurar el funcionamiento correcto de piezas y estructuras, evitando sus fallos."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/david.portillo%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/david.portillo%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/ignacio.romero%40upm.es> ;
    schema:name "Mecánica de Solidos y Materiales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001072/2025-26/CE23D> a ns1:Competency ;
    ns1:competencyCode "CE23D" ;
    ns1:competencyDescription "Capacidad de comprender y utilizar en la práctica las metodologías de la mecánica de los medios continuos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001072/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Conocer y aplicar conocimientos de ciencias y tecnologías básicas a la práctica de la Ingeniería Industrial."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001072/2025-26/CG5> a ns1:Competency ;
    ns1:competencyCode "CG5" ;
    ns1:competencyDescription "Saber comunicar los conocimientos y conclusiones, de forma oral, escrita y gráfica, a públicos especializados y no especializados de un modo claro y sin ambigüedades."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001072/2025-26/RA162> a ns1:LearningResult ;
    ns1:learningResultCode "RA162" ;
    ns1:learningResultDescription "Selección de Materiales para la Construcción de Máquinas. Aplicación de Normativa para la Construcción de Máquinas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001072/2025-26/RA256> a ns1:LearningResult ;
    ns1:learningResultCode "RA256" ;
    ns1:learningResultDescription "Plantear en términos matemáticos problemas físicos y de ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001072/2025-26/RA287> a ns1:LearningResult ;
    ns1:learningResultCode "RA287" ;
    ns1:learningResultDescription "Capacidad de elegir y seleccionar un material determinado que cumpla los requisitos de calidad especificados para unas condiciones de servicio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001072/2025-26/RA52> a ns1:LearningResult ;
    ns1:learningResultCode "RA52" ;
    ns1:learningResultDescription "Optimizar los diseños mecánicos y evaluar de forma precisa los márgenes de seguridad frente a las distintas modalidades de fallo."@es .

