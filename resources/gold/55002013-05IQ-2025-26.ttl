<https://guia-kg.skai.etsisi.upm.es/resource/55002013/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. 1. Módulo I: SÓLIDO RÍGIDO TALLER 1: Cálculo CDG TALLER 2: CALCULO DE REACCIONES Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55002013/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "2. 2. MODULO II: SÓLIDO RÍGIDO SOBRE APOYOS FLEXIBLES EN ESTÁTICA Taller 3: Muelles en serie y en paralelo Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55002013/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "3. 3. MODULO III: Sólido rígido con apoyos flexibles en dinámica. Respuesta en el tiempo: derivadas e integrales transformada de Fourier. Taller 4: Respuesta del sistema de 1gdl en tiempo Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55002013/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "4. 4. MODULO IV: Sólido rígido con apoyos flexibles en dinámica. Respuesta en frecuencia: Ajuste del modelo Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55002013/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "5. 5. MODULO V: PROGRAMACION LINEAL Sin subniveles"@es .

