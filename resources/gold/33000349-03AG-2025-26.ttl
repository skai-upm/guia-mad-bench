    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/33000349/2025-26/eventSchedule> ;
    schema:description "En esta asignatura se busca poner en práctica los conocimientos teóricos por medio de visitas a obras e intervenciones relevantes, de conferencias sobre intervenciones ya realizadas en edificios históricos y/o de patrimonio impartidas por los arquitectos que las han llevado a cabo y de participación en congresos y workshops sobre patrimonio."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/mer.gonzalez%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/javier.gmosteiro%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/mer.gonzalez%40upm.es> ;
    schema:name "Practicas Externas I"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000349/2025-26/CE%201.1> a ns1:Competency ;
    ns1:competencyCode "CE 1.1" ;
    ns1:competencyDescription "Conocimiento de las principales tipologías arquitectónicas en edificios históricos"@es .

