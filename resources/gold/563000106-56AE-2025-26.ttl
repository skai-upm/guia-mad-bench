<https://guia-kg.skai.etsisi.upm.es/resource/563000106/2025-26/CB07> a ns1:Competency ;
    ns1:competencyCode "CB07" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en entornos nuevos o poco conocidos dentro de contextos más amplios (o multidisciplinares) relacionados con su área de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000106/2025-26/CB10> a ns1:Competency ;
    ns1:competencyCode "CB10" ;
    ns1:competencyDescription "Que los estudiantes posean las habilidades de aprendizaje que les permitan continuar estudiando de un modo que habrá de ser en gran medida autodirigido o autónomo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000106/2025-26/CEC03> a ns1:Competency ;
    ns1:competencyCode "CEC03" ;
    ns1:competencyDescription "Desarrollar habilidades de aprendizaje que les permitan fomentar, en contextos académicos y profesionales, el avance tecnológico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000106/2025-26/CEC04> a ns1:Competency ;
    ns1:competencyCode "CEC04" ;
    ns1:competencyDescription "Desarrollar la capacidad para su implicación en actividades relacionadas con la innovación científica y tecnológica."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000106/2025-26/CG05> a ns1:Competency ;
    ns1:competencyCode "CG05" ;
    ns1:competencyDescription "Capacidad para la aplicación de los conocimientos adquiridos y resolver problemas en entornos nuevos o poco conocidos dentro de contextos más amplios y multidisciplinares, siendo capaces de integrar conocimientos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000106/2025-26/CG06> a ns1:Competency ;
    ns1:competencyCode "CG06" ;
    ns1:competencyDescription "Capacidad para saber comunicar (de forma oral y escrita) las conclusiones y los conocimientos, y razones últimas que lo sustentan, a públicos especializados y no especializados de un modo claro y sin ambigüedades."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000106/2025-26/RA60> a ns1:LearningResult ;
    ns1:learningResultCode "RA60" ;
    ns1:learningResultDescription "Conocer los procesos de cálculo de elementos y estructuras con comportamiento dinámico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000106/2025-26/RA61> a ns1:LearningResult ;
    ns1:learningResultCode "RA61" ;
    ns1:learningResultDescription "Profundizar en el estudio de los conceptos avanzados de elasticidad"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000106/2025-26/RA62> a ns1:LearningResult ;
    ns1:learningResultCode "RA62" ;
    ns1:learningResultDescription "Conocer los métodos de cálculo de tensiones y deformaciones de elementos y estructuras electromecánicas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000106/2025-26/RA63> a ns1:LearningResult ;
    ns1:learningResultCode "RA63" ;
    ns1:learningResultDescription "Aprender el comportamiento de uniones y conocer su procedimiento de cálculo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000106/2025-26/RA64> a ns1:LearningResult ;
    ns1:learningResultCode "RA64" ;
    ns1:learningResultDescription "Conocer la evolución de los materiales hasta su fractura, analizar los mecanismos de fatiga de elementos y los procesos de cálculo de elementos y estructuras con comportamiento dinámico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000106/2025-26/RA65> a ns1:LearningResult ;
    ns1:learningResultCode "RA65" ;
    ns1:learningResultDescription "Conocer la evolución de los materiales hasta su fractura"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000106/2025-26/RA66> a ns1:LearningResult ;
    ns1:learningResultCode "RA66" ;
    ns1:learningResultDescription "Analizar los mecanismos de fatiga de elementos"@es .

