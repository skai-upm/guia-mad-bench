<https://guia-kg.skai.etsisi.upm.es/resource/55001029/2025-26/CE%209> a ns1:Competency ;
    ns1:competencyCode "CE 9" ;
    ns1:competencyDescription "Conocimientos de los fundamentos de ciencia, tecnología y química de materiales. Comprender la relación entre la microestructura, la síntesis o procesado y las propiedades de los materiales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001029/2025-26/CG%201> a ns1:Competency ;
    ns1:competencyCode "CG 1" ;
    ns1:competencyDescription "Conocer y aplicar los conocimientos de ciencias y tecnologías básicas a la práctica de la Ingeniería Industria"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001029/2025-26/CG%202> a ns1:Competency ;
    ns1:competencyCode "CG 2" ;
    ns1:competencyDescription "Poseer la capacidad para diseñar, desarrollar, implementar, gestionar y mejorar productos, sistemas y procesos en los distintos ámbitos industriales, usando técnicas analíticas, computacionales o experimentales apropiadas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001029/2025-26/CG%203> a ns1:Competency ;
    ns1:competencyCode "CG 3" ;
    ns1:competencyDescription "Aplicar los conocimientos adquiridos para identificar, formular y resolver problemas en contextos amplios, siendo capaces de integrar los trabajando en equipos multidisciplinares"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001029/2025-26/CG%206> a ns1:Competency ;
    ns1:competencyCode "CG 6" ;
    ns1:competencyDescription "Poseer las habilidades de aprendizaje que permitan continuar estudiando a lo largo de toda la vida para un desarrollo profesional adecuado"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001029/2025-26/RA324> a ns1:LearningResult ;
    ns1:learningResultCode "RA324" ;
    ns1:learningResultDescription "Leer con provecho literatura técnica sobre Ciencia de Materiales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001029/2025-26/RA325> a ns1:LearningResult ;
    ns1:learningResultCode "RA325" ;
    ns1:learningResultDescription "Aplicación de distintos métodos y técnicas para tomar las decisiones de diseño, tácticas y operativas que aparecen en la producción y logística"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001029/2025-26/RA326> a ns1:LearningResult ;
    ns1:learningResultCode "RA326" ;
    ns1:learningResultDescription "Conocer las estructuras de los distintos materiales y su relación con las propiedades"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001029/2025-26/RA92> a ns1:LearningResult ;
