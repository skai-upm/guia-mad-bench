<https://guia-kg.skai.etsisi.upm.es/resource/615001022/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/615001022/2025-26/CB01>,
        <https://guia-kg.skai.etsisi.upm.es/resource/615001022/2025-26/CB02>,
        <https://guia-kg.skai.etsisi.upm.es/resource/615001022/2025-26/CB03>,
        <https://guia-kg.skai.etsisi.upm.es/resource/615001022/2025-26/CB04>,
        <https://guia-kg.skai.etsisi.upm.es/resource/615001022/2025-26/CB05>,
        <https://guia-kg.skai.etsisi.upm.es/resource/615001022/2025-26/CE13>,
        <https://guia-kg.skai.etsisi.upm.es/resource/615001022/2025-26/CE20>,
        <https://guia-kg.skai.etsisi.upm.es/resource/615001022/2025-26/CG01>,
