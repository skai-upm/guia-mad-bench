    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/615001022/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/615001022/2025-26/RA74>,
        <https://guia-kg.skai.etsisi.upm.es/resource/615001022/2025-26/RA88>,
        <https://guia-kg.skai.etsisi.upm.es/resource/615001022/2025-26/RA91> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/615001022/2025-26/syllabus> ;
    ns1:inpersonHours "38 horas y 30 minutos (49.4%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation """La asignatura se desarrollará de forma colaborativa: a partir de la elección de un caso de estudio, los alumnos/as abordarán las diferentes áreas de contenido (problemas éticos, protección de datos, propiedad intelectual, aspectos sociales de la IA).
Los resultados de los Proyectos se expondrán públicamente, y esta exposición formará parte de la evaluación del alumno; y, eventualmente, se buscará su publicación o divulgación virtual.
La orientación será eminentemente práctica, orientada a la resolución de problemas reales de la Inteligencia Artificial que tengan implicaciones sociales, éticas o jurídicas.
Se prevé, como en anteriores ediciones, la invitación de profesionales del ámbito empresarial, investigador, o instituciones públicas (Agencia europea de IA con sede en Estrasburgo) que ayuden al alumnado a aterrizar los contenidos.

OBJETIVOS DE DESARROLLO SOSTENIBLE
Esta asignatura contribuye al ODS 8, que a su vez contiene varias metas e indicadores orientados a conseguir "trabajo decente y crecimiento económico". En la misma se abordan temas relacionados con la economía digital o el comercio electrónico o el uso de las TIC y de la Inteligencia Artificial tanto por las empresas como por Organismos Públicos, con las implicaciones sociales, éticas y legales del uso de estas tecnologías.
Además, se trabajan temas relacionados con el ODS10, relacionado con la reducción de desigualdades (los aspectos de brecha digital y sesgos, por ejemplo, están íntimamente relacionados con este objetivo).
Finalmente, los contenidos están alineados con el ODS 16 dirigido a conseguir "paz, justicia e instituciones sólidas". El uso de los datos (personales o no) es una de las preocupaciones más importantes a nivel mundial, especialmente vinculado al uso y desarrollo de la Inteligencia Artificial."""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "38 horas y 30 minutos"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/615001022/2025-26/eventSchedule> ;
    schema:description "Esta asignatura proporciona las herramientas téoricas y prácticas para afrontar los retos éticos, legales y sociales que plantean los recientes avances de la ciencia de datos y la inteligencia artificial. Durante el curso se impartirán metodologías para realizar el análisis del impacto ético y social de proyectos de innovación, con aplicación en casos de uso reales. También se impartirán nociones básicas del marco jurídico europeo para el procesamiento de datos de carácter personal y para la protección de la propiedad intelectual y se estudiará la posición europea en el ámbito de sistemas autónomos y de inteligencia artificial."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/aureamaria.angueradesojo%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/aureamaria.angueradesojo%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/mariacelia.fernandez%40upm.es> ;
    schema:name "Aspectos Sociales, éticos y Legales de los Datos y la Inteligencia Artificial"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615001022/2025-26/CB01> a ns1:Competency ;
    ns1:competencyCode "CB01" ;
    ns1:competencyDescription "Que los estudiantes hayan demostrado poseer y comprender conocimientos en un área de estudio que parte de la base de la educación secundaria general, y se suele encontrar a un nivel que, si bien se apoya en libros de texto avanzados, incluye también algunos aspectos que implican conocimientos procedentes de la vanguardia de su campo de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615001022/2025-26/CB02> a ns1:Competency ;
    ns1:competencyCode "CB02" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar sus conocimientos a su trabajo o vocación de una forma profesional y posean las competencias que suelen demostrarse por medio de la elaboración y defensa de argumentos y la resolución de problemas dentro de su área de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615001022/2025-26/CB03> a ns1:Competency ;
    ns1:competencyCode "CB03" ;
    ns1:competencyDescription "Que los estudiantes tengan la capacidad de reunir e interpretar datos relevantes (normalmente dentro de su área de estudio) para emitir juicios que incluyan una reflexión sobre temas relevantes de índole social, científica o ética"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615001022/2025-26/CB04> a ns1:Competency ;
    ns1:competencyCode "CB04" ;
    ns1:competencyDescription "Que los estudiantes puedan transmitir información, ideas, problemas y soluciones a un público tanto especializado como no especializado"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615001022/2025-26/CB05> a ns1:Competency ;
    ns1:competencyCode "CB05" ;
    ns1:competencyDescription "Que los estudiantes hayan desarrollado aquellas habilidades de aprendizaje necesarias para emprender estudios posteriores con un alto grado de autonomía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615001022/2025-26/CE13> a ns1:Competency ;
    ns1:competencyCode "CE13" ;
    ns1:competencyDescription "Capacidad para conocer y diseñar entidades y sistemas inteligentes que incorporen capacidades como la autonomía, la situación en su entorno, la reactividad y proactividad, el aprendizaje, y habilidades sociales y organizativas, entre otras."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615001022/2025-26/CE20> a ns1:Competency ;
    ns1:competencyCode "CE20" ;
    ns1:competencyDescription "Poseer las destrezas para aplicar de manera socialmente responsable los aspectos éticos, legales y normativos relacionados con el tratamiento de los datos, el uso de las técnicas de la inteligencia artificial y la explotación del conocimiento obtenido."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615001022/2025-26/CG01> a ns1:Competency ;
    ns1:competencyCode "CG01" ;
    ns1:competencyDescription "Capacidad de trabajo en equipo, en entornos interdisciplinares y complejos, negociando y resolviendo conflictos, diseñando soluciones eficientes, fiables, robustas y responsables."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615001022/2025-26/CG07> a ns1:Competency ;
    ns1:competencyCode "CG07" ;
    ns1:competencyDescription "Capacidad para integrar aspectos sociales, ambientales, económicos y éticos inherentes a la ingeniería, analizando sus impactos, y comprometiéndose con la búsqueda de soluciones a retos del desarrollo sostenible."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615001022/2025-26/RA74> a ns1:LearningResult ;
    ns1:learningResultCode "RA74" ;
    ns1:learningResultDescription "Demostrar una base formativa suficiente para comprender el impacto de las soluciones de ingeniería en un contexto global, económico, medioambiental y social."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615001022/2025-26/RA88> a ns1:LearningResult ;
    ns1:learningResultCode "RA88" ;
    ns1:learningResultDescription "Seguridad de los Datos de carácter Personal"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615001022/2025-26/RA91> a ns1:LearningResult ;
    ns1:learningResultCode "RA91" ;
    ns1:learningResultDescription "Capacidad para producir informes sobre el impacto social, legal y ético de proyectos de ciencia de datos e inteligencia artificial"@es .

