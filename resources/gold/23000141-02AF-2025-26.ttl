        <https://guia-kg.skai.etsisi.upm.es/resource/23000141/2025-26/RA23>,
        <https://guia-kg.skai.etsisi.upm.es/resource/23000141/2025-26/RA25> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/23000141/2025-26/syllabus> ;
    ns1:inpersonHours "25 horas (48.1%)"@es ;
    ns1:numberOfCredits 2.0 ;
    ns1:otherInformation """En Blog Project Management GESPLAN se encontrarán algunas de las actividades de docencia e investigación y que se llevan a cabo desde GESPLAN en colaboración con empresas, organismos e impulsores del Área de conocimiento de Proyectos de Ingeniería y fundadores de la Asociación Española de Dirección e Ingeniería de Proyectos (AEIPRO).
Desde la asignatura se animará a participar en la edición anual el Campeonato Internacional de Dirección de Proyectos iPMC. El objetivo del IPMC es promover el interés por la dirección de proyectos facilitando el diálogo y el intercambio de conocimientos entre jóvenes de distintos países. Como cada año, en colaboración con AEIPRO Joven se organiza una Jornada para informar sobre el proceso para definir el equipo que podrá participar.
Se verán casos de estudio desde la dirección de proyectos realizados en el contexto internacional de la Metauniversidad para un desarrollo sostenible https://principiosirametauniversidad.com/
Se analizarán las competencias desde relaciones con otras universidades, empresas, cooperativas, gobiernos y la FAO"""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "35 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/23000141/2025-26/eventSchedule> ;
    schema:description "En el curso se abordan casos prácticos reales de proyectos para tratar los aspectos relacionados con los procesos y los posibles pasos a emprender para mejorar los elementos de competencia en dirección de Proyectos. Se relacionan un conjunto de acciones y actividades interrelacionadas que se pueden llevar a cabo para alcanzar una serie de resultados concretos en relación a una investigación aplicada en torno a los proyectos de desarrollo. Estos grupos de procesos tienen dependencias claras con otros que se mencionan en otras asignaturas del Máster."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/ignacio.delosrios%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/ignacio.delosrios%40upm.es> ;
    schema:name "Bases para la Competencia en Direccion de Proyectos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000141/2025-26/CE12> a ns1:Competency ;
    ns1:competencyCode "CE12" ;
    ns1:competencyDescription "Conocer las metodologías participativas en la formulación, ejecución seguimiento y evaluación de un programa o proyecto de desarrollo y su multidimensionalidad (humana, territorial, ambiental)."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000141/2025-26/CE13> a ns1:Competency ;
    ns1:competencyCode "CE13" ;
    ns1:competencyDescription "Conocimiento análisis y aplicación de metodologías de evaluación participativa encaminadas al aprendizaje interno de las organizaciones susceptibles de ser aplicadas a los programas y proyectos de desarrollo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000141/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Habilidades de comunicación escrita y oral: Concluir aportaciones por escrito, desarrollando la capacidad de síntesis y presentación de las ideas propias en un grupo de trabajo y en exposición pública."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000141/2025-26/CG10> a ns1:Competency ;
    ns1:competencyCode "CG10" ;
    ns1:competencyDescription "Valores humanos positivos para la investigación: Respeto a los derechos humanos fundamentales; los principios de igualdad de oportunidades, accesibilidad universal y no discriminación; y los valores propios de una cultura de paz y de valores democráticos. Compromiso con estos derechos, principios y valores, motivación, actitud positiva y entusiasta; ética, integridad y honestidad investigadora"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000141/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Fortalecer conocimiento oral y escrito de idioma inglés"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000141/2025-26/CG4> a ns1:Competency ;
    ns1:competencyCode "CG4" ;
    ns1:competencyDescription "Capacidad crítica para el análisis, síntesis y aprendizaje mediante el intercambio de opiniones, presentando argumentos sólidos y estructurados"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000141/2025-26/CG7> a ns1:Competency ;
    ns1:competencyCode "CG7" ;
    ns1:competencyDescription "Capacidad de trabajo en equipo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000141/2025-26/CG8> a ns1:Competency ;
    ns1:competencyCode "CG8" ;
    ns1:competencyDescription "Capacidad de observación, generación de hipótesis y planteamiento de problemas experimentales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000141/2025-26/CG9> a ns1:Competency ;
    ns1:competencyCode "CG9" ;
    ns1:competencyDescription "Utilización de TIC para el trabajo cooperativo y trabajo en equipo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000141/2025-26/RA22> a ns1:LearningResult ;
    ns1:learningResultCode "RA22" ;
    ns1:learningResultDescription "Identificar e implicar a los distintos grupos sociales y las partes interesadas en proyectos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000141/2025-26/RA23> a ns1:LearningResult ;
    ns1:learningResultCode "RA23" ;
    ns1:learningResultDescription "Identificar y analizar problemas, necesidades, oportunidades y amenazas en los proyectos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000141/2025-26/RA25> a ns1:LearningResult ;
