        <https://guia-kg.skai.etsisi.upm.es/resource/33000883/2025-26/didactic_resource/4> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/33000883/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/33000883/2025-26/RA3>,
        <https://guia-kg.skai.etsisi.upm.es/resource/33000883/2025-26/RA4>,
