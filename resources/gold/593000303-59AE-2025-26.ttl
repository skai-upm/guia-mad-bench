    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/593000303/2025-26/eventSchedule> ;
    schema:description """La asignatura aborda el estudio del aislamiento acústico desde diferentes puntos de vista.
La primera parte, formada por los Temas 1, 2, 3 y 4, estudia los mecanismos físicos que condicionan la propagación de la energía vibratoria a través de las estructuras y la radiación sonora de elementos y estructuras vibrantes. Estos mecanismos se particularizan para las dos formas de aislamiento acústico que se dan en las edificaciones: el aislamiento a ruido aéreo y el aislamiento a impactos.
La segunda parte (Tema 5) profundiza en los métodos de cálculo que permiten predecir el comportamiento acústico de los edificios a partir de las características acústicas de los elementos constructivos que los componen.
Finalmente, la asignatura estudia los procedimientos de medición del aislamiento acústico (Tema 6), haciendo especial hincapié en el análisis de la normativa en vigor y la validez meteorológica de los resultados de los ensayos."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/antonio.pedrero%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/antonio.pedrero%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/josedavid.oses%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/r.fraile%40upm.es> ;
    schema:name "Aislamiento Acustico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/593000303/2025-26/CB10> a ns1:Competency ;
    ns1:competencyCode "CB10" ;
    ns1:competencyDescription "Que los estudiantes posean las habilidades de aprendizaje que les permitan continuar estudiando de un modo que habrá de ser en gran medida autodirigido o autónomo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/593000303/2025-26/CE02> a ns1:Competency ;
    ns1:competencyCode "CE02" ;
    ns1:competencyDescription "Comprensión y dominio de la legislación y normativa nacional e internacional y su aplicación para la resolución de problemas propios de la ingeniería acústica."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/593000303/2025-26/CE05> a ns1:Competency ;
    ns1:competencyCode "CE05" ;
    ns1:competencyDescription "Capacidad para comprender y utilizar los principios de acústica aplicada para el diseño industrial, ambiental y/o arquitectónico de equipos, instalaciones y/o recintos y su aplicación para la resolución de los problemas propios de la ingeniería acústica."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/593000303/2025-26/CG01> a ns1:Competency ;
    ns1:competencyCode "CG01" ;
    ns1:competencyDescription "Conocer y aplicar conocimientos y soluciones de ingeniería acústica a los campos de la industria, la edificación, el transporte y el medio ambiente, entre otros."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/593000303/2025-26/CG06> a ns1:Competency ;
    ns1:competencyCode "CG06" ;
    ns1:competencyDescription "Comunicar correcta y adecuadamente las conclusiones obtenidas mediante la exposición del análisis de casos prácticos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/593000303/2025-26/RA56> a ns1:LearningResult ;
    ns1:learningResultCode "RA56" ;
    ns1:learningResultDescription "Comprensión de los principios físicos básicos que gobiernan el aislamiento acústico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/593000303/2025-26/RA57> a ns1:LearningResult ;
    ns1:learningResultCode "RA57" ;
    ns1:learningResultDescription "Conocimiento y utilización de las diferentes magnitudes que describen el aislamiento acústico."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/593000303/2025-26/RA58> a ns1:LearningResult ;
    ns1:learningResultCode "RA58" ;
    ns1:learningResultDescription "Conocimiento de los fundamentos de la transmisión acústica de los sistemas .constructivos y su ámbito de aplicación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/593000303/2025-26/RA59> a ns1:LearningResult ;
    ns1:learningResultCode "RA59" ;
    ns1:learningResultDescription "Conocimiento de las características de aislamiento acústico a ruido aéreo de diferentes elementos: divisorios verticales y horizontales, puertas, ventanas, fachadas, etc"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/593000303/2025-26/RA60> a ns1:LearningResult ;
    ns1:learningResultCode "RA60" ;
    ns1:learningResultDescription "Conocimiento de los fundamentos de la transmisión estructural de los sistemas constructivos y su ámbito de aplicación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/593000303/2025-26/RA61> a ns1:LearningResult ;
    ns1:learningResultCode "RA61" ;
    ns1:learningResultDescription "Conocimiento de las características de aislamiento acústico a ruido de impactos de diferentes elementos: forjados, cubiertas, etc"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/593000303/2025-26/RA62> a ns1:LearningResult ;
    ns1:learningResultCode "RA62" ;
    ns1:learningResultDescription "Conocimiento y aplicación de normativa internacional y nacional de predicción de aislamiento acústico a ruido aéreo y de impacto. Norma UNEEN 12354 y DB"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/593000303/2025-26/RA63> a ns1:LearningResult ;
    ns1:learningResultCode "RA63" ;
    ns1:learningResultDescription "Conocimiento y aplicación de normativa internacional de medida de aislamiento acústico a ruido aéreo y de impacto. Normas ISO 140 e ISO 10140."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/593000303/2025-26/RA64> a ns1:LearningResult ;
    ns1:learningResultCode "RA64" ;
    ns1:learningResultDescription "Conocimiento de nuevas técnicas de medición del aislamiento acústico."@es .

