    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/95000575/2025-26/eventSchedule> ;
    schema:description """La solución numérica de problemas es uno de los objetivos básicos de la ingeniería y de cualquier ciencia cuantitativa (economía, arquitectura, química, biología, etc.). La confluencia actual de computadoras de enorme potencia con programas de cálculo de gran versatilidad y fácil uso permiten resolver con presteza todo tipo de problemas numéricos y visualizar de forma apropiada los resultados.
Esta asignatura es una introducción a la computación y visualización de datos utilizando el programa MATLAB®, estándar de facto en la práctica de la ingeniería. Los alumnos empiezan a usar MATLAB® como una calculadora científica de gran funcionalidad y a continuación se familiarizan con sus capacidades de programación y visualización lo que les permite adquirir dos competencias básicas: introducción a la resolución de problemas numéricos e introducción a la visualización de datos. Además, tienen la oportunidad de seguir reforzando sus competencias en lenguajes de programación.
El desarrollo de las actividades es eminentemente práctico y el trabajo de los alumnos se organiza por parejas. La dinámica de las clases es de tipo taller: el profesor expone ideas básicas de cada tema y a continuación los alumnos resuelven ejercicios prácticos para afianzar los conceptos explicados.
MATLAB® se usa extensivamente en esta Universidad en laboratorios docentes, para la elaboración de trabajos Fin de Titulación y en actividades de investigación. La adquisición de solvencia en el manejo de este programa facilitará el trabajo de los profesores y alumnos en numerosas asignaturas del currículo académico del Graduado en Ingeniería de Tecnologías y Servicios de Telecomunicación. Además, se trata de una herramienta de amplio uso profesional en la industria."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/jose.parera%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/jd.martinezderioja%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/jose.parera%40upm.es> ;
    schema:name "Herramientas para la Computación y Visualización"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000575/2025-26/CB01> a ns1:Competency ;
    ns1:competencyCode "CB01" ;
    ns1:competencyDescription "Que los estudiantes hayan demostrado poseer y comprender conocimientos en un área de estudio que parte de la base de la educación secundaria general, y se suele encontrar a un nivel que, si bien se apoya en libros de texto avanzados, incluye también algunos aspectos que implican conocimientos procedentes de la vanguardia de su campo de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000575/2025-26/CB02> a ns1:Competency ;
    ns1:competencyCode "CB02" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar sus conocimientos a su trabajo o vocación de una forma profesional y posean las competencias que suelen demostrarse por medio de la elaboración y defensa de argumentos y la resolución de problemas dentro de su área de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000575/2025-26/CB03> a ns1:Competency ;
    ns1:competencyCode "CB03" ;
    ns1:competencyDescription "Que los estudiantes tengan la capacidad de reunir e interpretar datos relevantes (normalmente dentro de su área de estudio) para emitir juicios que incluyan una reflexión sobre temas relevantes de índole social, científica o ética"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000575/2025-26/CB05> a ns1:Competency ;
    ns1:competencyCode "CB05" ;
    ns1:competencyDescription "Que los estudiantes hayan desarrollado aquellas habilidades de aprendizaje necesarias para emprender estudios posteriores con un alto grado de autonomía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000575/2025-26/CE01> a ns1:Competency ;
    ns1:competencyCode "CE01" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de aplicar los conceptos y las herramientas fundamentales de la matemática a la formalización y resolución de los problemas en el ámbito de la titulación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000575/2025-26/CE13> a ns1:Competency ;
    ns1:competencyCode "CE13" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de aplicar sus conocimientos sobre los fundamentos de las técnicas de aprendizaje automático y de visualización de datos a la ingeniería de datos y sistemas en el ámbito de la ingeniería de telecomunicación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000575/2025-26/CE17> a ns1:Competency ;
    ns1:competencyCode "CE17" ;
    ns1:competencyDescription "Que los estudiantes tengan la capacidad de utilizar los fundamentos de la programación, sistemas operativos, bases de datos, tecnología web y las redes y servicios de telecomunicación en proyectos de ingeniería de datos y sistemas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000575/2025-26/CG01> a ns1:Competency ;
    ns1:competencyCode "CG01" ;
    ns1:competencyDescription "Tener capacidad de trabajar en entornos internacionales y multidisciplinares, haciendo uso de la lengua inglesa en forma oral y escrita."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000575/2025-26/CG02> a ns1:Competency ;
    ns1:competencyCode "CG02" ;
    ns1:competencyDescription "Desarrollar la capacidad de trabajar en equipo empleando metodologías ágiles para diseñar soluciones eficientes, fiables y robustas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000575/2025-26/CG04> a ns1:Competency ;
    ns1:competencyCode "CG04" ;
    ns1:competencyDescription "Saber identificar y utilizar las herramientas de las Tecnologías de la Información y de las Comunicaciones más adecuadas para plantear y construir soluciones a problemas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000575/2025-26/RA170> a ns1:LearningResult ;
    ns1:learningResultCode "RA170" ;
    ns1:learningResultDescription "Conocer los elementos básicos de un sistema de computación: unidad de proceso, memoria y periféricos de entrada/salida. Conocer los entornos de computación y visualización de datos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000575/2025-26/RA171> a ns1:LearningResult ;
    ns1:learningResultCode "RA171" ;
    ns1:learningResultDescription "Conocer el manejo básico de MATLAB empleando su interfaz gráfica, y de manera especial la ventana de comandos. Conocer los tipos de datos básicos, los operadores aritméticos y lógicos y las funciones predefinidas de entrada/salida."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000575/2025-26/RA172> a ns1:LearningResult ;
    ns1:learningResultCode "RA172" ;
    ns1:learningResultDescription "Conocer las técnicas básicas de entrada y salida de datos. Aprender técnicas de presentación de resultados."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000575/2025-26/RA173> a ns1:LearningResult ;
    ns1:learningResultCode "RA173" ;
    ns1:learningResultDescription "Aprender a programar y depurar algoritmos empleando el lenguaje de programación de MATLAB."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000575/2025-26/RA174> a ns1:LearningResult ;
    ns1:learningResultCode "RA174" ;
    ns1:learningResultDescription "Conocer las características básicas de los problemas y los algoritmos. Conocer las implicaciones de la aritmética finita sobre las prestaciones de los algoritmos. Saber estudiar la complejidad computacional de los algoritmos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000575/2025-26/didactic_resource/1> a ns1:DidacticResource ;
    ns1:bibliographyDescription "Libro de texto"@es ;
    ns1:bibliographyTitle "H. Moore, MATLAB for engineers, 3rd ed. Boston: Pearson Prentice Hall, 2012."@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000575/2025-26/didactic_resource/2> a ns1:DidacticResource ;
    ns1:bibliographyDescription "Libro auxiliar"@es ;
    ns1:bibliographyTitle "T. Siauw y A. M. Bayen, An introduction to MATLAB programming and numerical methods for engineers. Amsterdam: Academic Press, an imprint of Elsevier, 2015."@es ;
    ns1:bibliographyType "Bibliografía"@es .

