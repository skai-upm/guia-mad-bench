    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/45000150/2025-26/CE%202.> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/45000150/2025-26/didactic_resource/1>,
