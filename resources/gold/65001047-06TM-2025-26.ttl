        "Fundamentos de Metalurgia"@es ;
    schema:numberOfCredits 3.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/65001047/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/65001047/2025-26/CG%201>,
        <https://guia-kg.skai.etsisi.upm.es/resource/65001047/2025-26/CG%202>,
