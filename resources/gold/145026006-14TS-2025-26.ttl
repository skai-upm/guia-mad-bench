    ns1:itemIndex 15 ;
    ns1:syllabusDescription "8.1. 8.1. Selección de materiales para aplicaciones a alta temperatura. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145026006/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "2.1. 2.1. Diseño de aleaciones para trabajar en fluencia. 2.2. Comportamiento a fatiga. Interacción fluencia-fatiga. 2.3. Oxidación y corrosión a alta temperatura. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145026006/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "3. Tema 3. SUPERALEACIONES BASE NÍQUEL."@es .

