    ns1:itemIndex 4 ;
    ns1:syllabusDescription "3.1. 3.1. Mecanismos de refuerzo en aleaciones para alta temperatura. 3.2. Microestructura y propiedades de las superaleaciones base níquel. 3.3. Tratamientos térmicos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145026006/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "3.2. 3.4. Superaleaciones base Ni policristalinas y monocristalinas. 3.5. Superaleaciones base Ni-Fe. 3.6. Aplicaciones. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145026006/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "4. Tema 4. SUPERALEACIONES BASE COBALTO."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145026006/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "4.1. 4.1. Microestructura y propiedades de las superaleaciones base cobalto. 4.2 Ventajas e inconvenientes. 4.3. Aplicaciones de las superaleaciones base cobalto. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145026006/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "5. Tema 5. RECUBRIMIENTOS PROTECTORES."@es .

