    ns1:itemIndex 1 ;
    ns1:syllabusDescription "2. Tema 2. COMPORTAMIENTO EN SERVICIO A ALTA TEMPERATURA."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145026006/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "6. Tema 6. METALES REFRACTARIOS."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145026006/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "6.1. 6.1. Molibdeno, wolframio, niobio, tántalo y renio. 6.2. Características y principales aplicaciones de los metales refractarios Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145026006/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "7. Tema 7. MATERIALES CERÁMICOS."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145026006/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "7.1. 7.1. Propiedades físicas y mecánicas. 7.2. Tipos de cerámicos para alta temperatura. 7.3. Aplicaciones de los materiales cerámicos para alta temperatura Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145026006/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "8. Tema 8. SELECCIÓN DE MATERIALES."@es .

