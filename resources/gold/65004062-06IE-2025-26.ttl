<https://guia-kg.skai.etsisi.upm.es/resource/65004062/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Fundamentos en el acondicionamiento electrónico de la energía eléctrica. Ejemplos de aplicación. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004062/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "2. Repaso a los fundamentos de teoría de circuitos. Corriente continua. Corriente alterna. Regimen permanente. Regimen transitorio Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004062/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "3. Interruptores electrónicos de potencia. Diodos de potencia. SCRs. MOSFETs e IGBTs. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004062/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "4. Conversión continua-continua. Convertidor reductor (buck). Convertidor elevador (boost). Convertidor reductor-elevador (buck-boost) Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004062/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "5. Conversión alterna-continua. Convertidores monofásicos no controlados y controlados, de media onda y de onda completa. Convertidores trifásicos Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004062/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "6. Convertidores continua-alterna. Inversores monofásicos. Modulación PWM Sin subniveles"@es .

