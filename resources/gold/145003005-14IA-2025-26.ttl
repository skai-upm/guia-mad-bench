    ns1:learningResultCode "RA171" ;
    ns1:learningResultDescription "Conocimiento, comprensión y aplicación de la estática y de la evolución dinámica de sistemas de partículas y sólidos rígidos en el ámbito de la Mecánica Clásica."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145003005/2025-26/RA172> a ns1:LearningResult ;
    ns1:learningResultCode "RA172" ;
    ns1:learningResultDescription "Conocimiento, comprensión y aplicación de los métodos de análisis cinemático y dinámico empleados en este contexto."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145003005/2025-26/RA173> a ns1:LearningResult ;
    ns1:learningResultCode "RA173" ;
    ns1:learningResultDescription "Conocimiento, comprensión y aplicación de aspectos más concretos de la Mecánica Clásica como, por ejemplo, la teoría de percusiones."@es .

