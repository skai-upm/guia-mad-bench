    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/613000103/2025-26/eventSchedule> ;
    schema:description "En esta asignatura se abordará la gestión de proyectos de desarrollo software para la web desde dos enfoques diferentes: pesado/tradicional y ligero/ágil. En ambos casos se presentarán las técnicas específicas de cada metodología para la captura de requisitos, el análisis, el diseño y las pruebas. Los conocimientos teóricos se reforzarán con la realización de casos prácticos."@es ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/luis.fernandezm%40upm.es> ;
    schema:name "Metodologías de Desarrollo Web"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000103/2025-26/CE01> a ns1:Competency ;
    ns1:competencyCode "CE01" ;
    ns1:competencyDescription "Requisitar, analizar y diseñar en un desarrollo Web bajo las metodologías vigentes en el entorno profesional."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000103/2025-26/CE02> a ns1:Competency ;
    ns1:competencyCode "CE02" ;
    ns1:competencyDescription "Programar y probar en un desarrollo Web con los lenguajes y técnicas vigentes en el entorno profesional."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000103/2025-26/CE04> a ns1:Competency ;
    ns1:competencyCode "CE04" ;
    ns1:competencyDescription "Configurar herramientas y entornos de desarrollo Web vigentes en el entorno profesional."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000103/2025-26/CE06> a ns1:Competency ;
    ns1:competencyCode "CE06" ;
    ns1:competencyDescription "Incorporar seguridad, calidad, usabilidad y persistencia al desarrollo Web vigentes en el entorno profesional."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000103/2025-26/CE07> a ns1:Competency ;
    ns1:competencyCode "CE07" ;
    ns1:competencyDescription "Organizar, coordinar y supervisar al equipo de desarrollo Web con técnicas vigentes en el entorno profesional"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000103/2025-26/CE08> a ns1:Competency ;
    ns1:competencyCode "CE08" ;
    ns1:competencyDescription "Estimar costes tiempos/recuros para un desarrollo Web con metodologías vigentes en el entorno profesional."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000103/2025-26/CE09> a ns1:Competency ;
    ns1:competencyCode "CE09" ;
    ns1:competencyDescription "Respetar los marcos legal, social y económico de los desarrollos vigentes en el entorno profesional."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000103/2025-26/RA55> a ns1:LearningResult ;
    ns1:learningResultCode "RA55" ;
    ns1:learningResultDescription "Conoce, comprende, aplica y analiza técnicas de captura de requisitos basadas en casos de uso e historias de usuario."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000103/2025-26/RA56> a ns1:LearningResult ;
    ns1:learningResultCode "RA56" ;
    ns1:learningResultDescription "Conoce, comprende, aplica y analiza técnicas de diseño y pruebas con Modelo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000103/2025-26/RA57> a ns1:LearningResult ;
    ns1:learningResultCode "RA57" ;
    ns1:learningResultDescription "Conoce, comprende, aplica y analiza técnicas de gestión de proyectos con enfoques ágil y pesado."@es .

