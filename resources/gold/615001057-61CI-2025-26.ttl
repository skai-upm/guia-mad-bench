<https://guia-kg.skai.etsisi.upm.es/resource/615001057/2025-26/CT12> a ns1:Competency ;
    ns1:competencyCode "CT12" ;
    ns1:competencyDescription "Uso de tecnologías de la información y las comunicaciones : Usar las tecnologías de la información y las comunicaciones en el ámbito de la ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615001057/2025-26/OB08> a ns1:Competency ;
    ns1:competencyCode "OB08" ;
    ns1:competencyDescription "Conocimiento de las materias básicas y tecnológicas, que capaciten para el aprendizaje y desarrollo de nuevos métodos y tecnologías, así como las que les doten de una gran versatilidad para adaptarse a las nuevas situaciones."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615001057/2025-26/OB09> a ns1:Competency ;
    ns1:competencyCode "OB09" ;
    ns1:competencyDescription "Capacidad para resolver problemas con iniciativa, toma de decisiones, autonomía y creatividad. Capacidad para saber comunicar y transmitir los conocimientos, habilidades y destrezas de la profesión de Ingeniero Técnico en Informática."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615001057/2025-26/RA37> a ns1:LearningResult ;
    ns1:learningResultCode "RA37" ;
    ns1:learningResultDescription "Utiliza adecuadamente software matemático en la resolución de problemas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615001057/2025-26/RA389> a ns1:LearningResult ;
    ns1:learningResultCode "RA389" ;
    ns1:learningResultDescription "Utiliza adecuadamente la transformada de Fourier para el análisis de señales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615001057/2025-26/RA390> a ns1:LearningResult ;
    ns1:learningResultCode "RA390" ;
    ns1:learningResultDescription "Maneja el algoritmo de transformada rápida para el cálculo eficiente de transformadas discretas de Fourier y convoluciones."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615001057/2025-26/RA391> a ns1:LearningResult ;
    ns1:learningResultCode "RA391" ;
    ns1:learningResultDescription "Calcula y aplica transformadas z para el análisisi y control de sistemas lineales en tiempo discreto."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615001057/2025-26/RA403> a ns1:LearningResult ;
    ns1:learningResultCode "RA403" ;
    ns1:learningResultDescription "Maneja los elementos básicos del tratamiento de señales discretas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615001057/2025-26/RA489> a ns1:LearningResult ;
    ns1:learningResultCode "RA489" ;
    ns1:learningResultDescription "Representa y analiza la voz en dominios de tiempo y frecuencia"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615001057/2025-26/RA490> a ns1:LearningResult ;
    ns1:learningResultCode "RA490" ;
    ns1:learningResultDescription "Diseña y evalua algoritmos para el procesado de la voz"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615001057/2025-26/RA491> a ns1:LearningResult ;
    ns1:learningResultCode "RA491" ;
    ns1:learningResultDescription "Aplica métodos de DataScience en analisis de patrones temporales"@es .

