    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/203000063/2025-26/eventSchedule> ;
    schema:description """Estadística básica
Diseño de experimentos
Regresión
Modelos lineales complejos.
Análisis de datos de estudios observacionales: tipos de diseños, medidas del impacto de la asociación, estimación de riesgos en presencia de confusión e interacción."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/javier.garcia%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/javier.garcia%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/nuria.nicodemus%40upm.es> ;
    schema:name "Diseño Experimental y Análisis de Datos en Producción y Sanidad Animal"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000063/2025-26/CE03> a ns1:Competency ;
    ns1:competencyCode "CE03" ;
    ns1:competencyDescription "Evaluar adecuadamente el efecto de los factores de producción y de las técnicas de manejo, sobre la productividad de los modelos y la calidad de los productos ganaderos generados."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000063/2025-26/CE07> a ns1:Competency ;
    ns1:competencyCode "CE07" ;
    ns1:competencyDescription "Plantear y desarrollar un trabajo de investigación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000063/2025-26/CE08> a ns1:Competency ;
    ns1:competencyCode "CE08" ;
    ns1:competencyDescription "Conocer las metodologías de investigación disponibles en la producción animal y en la sanidad animal."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000063/2025-26/CE09> a ns1:Competency ;
    ns1:competencyCode "CE09" ;
    ns1:competencyDescription "Saber utilizar las herramientas y técnicas bioinformáticas más actuales a la investigación en producción animal y en sanidad animal."@es .

