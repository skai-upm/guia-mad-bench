<https://guia-kg.skai.etsisi.upm.es/resource/205000053/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. UT 1. ALIMENTOS CONCENTRADOS PARA LA FABRICACIÓN DE PIENSOS (36 h)"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000053/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Tema 1. Balance alimentario de la ganadería española. Importancia de la fabricación de piensos por especies animales en España. Consumo y dependencia de materias primas para la alimentación animal. (2 h) Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000053/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "2.2. Tema 9. Forrajes conservados. Henificación. Deshidratación. Ensilado.(2 h) Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000053/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "2.3. Tema 10. Subproductos húmedos de origen vegetal y animal. (4 h) Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000053/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "3. UT 3. FABRICACIÓN DE PIENSOS COMPUESTOS (14 h)"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000053/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "3.1. Tema 11. Proceso de fabricación de piensos compuestos. Mezclas unifeed (10 h) Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000053/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "3.2. Tema 12. Puntos críticos del control de calidad en la fabricación (4 h) Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000053/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Tema 2. Fuentes de energía (almidón): Cereales grano. Frutos, raíces y tubérculos (10 h) Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000053/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "1.3. Tema 3. Subproductos de cereales de la industria alimentaria y de los biocarburantes (8 h) Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000053/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "1.4. Tema 4. Fuentes de proteína vegetal: leguminosas grano, semillas y harinas de oleaginosas (8 h) Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000053/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "1.5. Tema 5. Fuentes de proteína animal. Productos lácteos (4 h) Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000053/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "1.6. Tema 6. Grasas y aceites vegetales (4 h) Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000053/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "1.7. Tema 7. Minerales y Vitaminas. Aditivos: clasificación y modos de acción (2 h) Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000053/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "2. UT 2. FORRAJES Y SUBPRODUCTOS HÚMEDOS. METODOS DE CONSERVACIÓN (10 h)"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000053/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "2.1. Tema 8. Conceptos generales. Forrajes verdes. (4 h) Sin subniveles"@es .

