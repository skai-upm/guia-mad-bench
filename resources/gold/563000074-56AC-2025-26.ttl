<https://guia-kg.skai.etsisi.upm.es/resource/563000074/2025-26/CB10> a ns1:Competency ;
    ns1:competencyCode "CB10" ;
    ns1:competencyDescription "Que los estudiantes posean las habilidades de aprendizaje que les permitan continuar estudiando de un modo que habrá de ser en gran medida autodirigido o autónomo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000074/2025-26/CB6> a ns1:Competency ;
    ns1:competencyCode "CB6" ;
    ns1:competencyDescription "Poseer y comprender conocimientos que aporten una base u oportunidad de ser originales en el desarrollo y/o aplicación de ideas, a menudo en un contexto de investigación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000074/2025-26/CB7> a ns1:Competency ;
    ns1:competencyCode "CB7" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en entornos nuevos o poco conocidos dentro de contextos más amplios (o multidisciplinares) relacionados con su área de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000074/2025-26/CB9> a ns1:Competency ;
    ns1:competencyCode "CB9" ;
    ns1:competencyDescription "Que los estudiantes sepan comunicar sus conclusiones y los conocimientos y razones últimas que las sustentan a públicos especializados y no especializados de un modo claro y sin ambigüedades"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000074/2025-26/CE3> a ns1:Competency ;
    ns1:competencyCode "CE3" ;
    ns1:competencyDescription "Capacidad de aplicar los conceptos innovadores de las nuevas tendencias en los diseños de producto"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000074/2025-26/CE4> a ns1:Competency ;
    ns1:competencyCode "CE4" ;
    ns1:competencyDescription "Capacidad de manejar e integrar las herramientas de representación, simulación y cálculo CAD"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000074/2025-26/CE8> a ns1:Competency ;
    ns1:competencyCode "CE8" ;
    ns1:competencyDescription "Capacidad para aplicar herramientas de visualización y generación virtual de productos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000074/2025-26/CG10> a ns1:Competency ;
    ns1:competencyCode "CG10" ;
    ns1:competencyDescription "Capacidad de integrarse en el ámbito empresarial a través del diseño y la innovación o a través de proyectos de diseño operativo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000074/2025-26/CG2> a ns1:Competency ;
    ns1:competencyCode "CG2" ;
    ns1:competencyDescription "Capacidad para integrar aspectos estéticos en los productos de diseño sin perder la funcionalidad"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000074/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Conocimiento de las herramientas de visualización y generación de productos de diseño"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000074/2025-26/CG4> a ns1:Competency ;
    ns1:competencyCode "CG4" ;
    ns1:competencyDescription "Conocimiento de los procesos industriales para ser capaz de decidir sobre los criterios adecuados en la fabricación de productos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000074/2025-26/CG5> a ns1:Competency ;
    ns1:competencyCode "CG5" ;
    ns1:competencyDescription "Capacidad de integrar herramientas de representación en los procesos de fabricación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000074/2025-26/CG7> a ns1:Competency ;
    ns1:competencyCode "CG7" ;
    ns1:competencyDescription "Capacidad de integrar metodologías, tecnologías, procesos y herramientas en el campo de la ingeniería y el diseño industrial"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000074/2025-26/CT1> a ns1:Competency ;
    ns1:competencyCode "CT1" ;
    ns1:competencyDescription "Capacidad para comunicarse con profesionales de su ámbito, con la comunidad académica en su conjunto y con la sociedad en general acerca de sus áreas de conocimiento"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000074/2025-26/CT2> a ns1:Competency ;
    ns1:competencyCode "CT2" ;
    ns1:competencyDescription "Ser capaz de negociar y trabajar en equipo así como de manera autónoma en un contexto internacional, multidisciplinar y multicultura"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000074/2025-26/CT5> a ns1:Competency ;
    ns1:competencyCode "CT5" ;
    ns1:competencyDescription "Capacidad para desarrollar y ejercitar la creatividad"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000074/2025-26/RA10> a ns1:LearningResult ;
    ns1:learningResultCode "RA10" ;
    ns1:learningResultDescription "Aplicar con criterio las técnicas y herramientas descritas en la asignatura."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000074/2025-26/RA12> a ns1:LearningResult ;
    ns1:learningResultCode "RA12" ;
    ns1:learningResultDescription "Redactar y comunicar utilizando un lenguaje claro y preciso."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000074/2025-26/RA13> a ns1:LearningResult ;
    ns1:learningResultCode "RA13" ;
    ns1:learningResultDescription "Aprender por sí mismos otros conocimientos relacionados con la asignatura."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000074/2025-26/RA48> a ns1:LearningResult ;
    ns1:learningResultCode "RA48" ;
    ns1:learningResultDescription "Motivar la búsqueda y producción de soluciones, tanto formales como técnicas, basadas en la experiencia proporcionada por el diseño rápido de prototipos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000074/2025-26/RA8> a ns1:LearningResult ;
    ns1:learningResultCode "RA8" ;
    ns1:learningResultDescription "Conocer, interpretar y aplicar los conocimientos de la asignatura."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000074/2025-26/RA9> a ns1:LearningResult ;
    ns1:learningResultCode "RA9" ;
    ns1:learningResultDescription "Criticar y analizar la información inicial previa a la realización del diseño."@es .

