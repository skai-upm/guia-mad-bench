<https://guia-kg.skai.etsisi.upm.es/resource/133000045/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/133000045/2025-26/CB6>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000045/2025-26/CE8>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000045/2025-26/CE9>,
