<https://guia-kg.skai.etsisi.upm.es/resource/95000536/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Gestión y protección de datos personales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000536/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Privacidad y normativa de protección de datos personales. Reglamento general de protección de datos, Ley Orgánica de Protección de Datos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000536/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "3. Propiedad intelectual e industrial en el ámbito de la ingeniería de datos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000536/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "3.1. Propiedad intelectual e industrial del dato Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000536/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "3.2. Propiedad intelectual e industrial de los algoritmos y los sistemas de ingeniería de datos Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000536/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Roles profesionales. El Director de Datos (Chief Data Officer, CDO) y el Delegado de Protección de Datos (Data Protection Officer, DPO). Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000536/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "1.3. Gobierno del dato. Tratamientos, clasificación de la información y ciclo de vida. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000536/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "2. Gestión ética en la ingeniería de datos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000536/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "2.1. Concepto de ética en la ingeniería de datos y la inteligencia artificial Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000536/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "2.2. Confianza e ingeniería de datos e inteligencia artificial: privacidad, transparencia, sesgos, equidad y rendición de cuentas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000536/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "2.3. Supervisión y gobernanza de sistemas de ingeniería de datos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000536/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "2.4. Códigos éticos en la ingeniería de datos y la inteligencia artificial. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000536/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "2.5. Factores ASG (Ambientales, Sociales y Gobernanza) en la práctica empresarial en la ética de los datos. Sin subniveles"@es .

