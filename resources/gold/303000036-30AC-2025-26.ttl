        <https://guia-kg.skai.etsisi.upm.es/resource/303000036/2025-26/RA144>,
        <https://guia-kg.skai.etsisi.upm.es/resource/303000036/2025-26/RA145>,
        <https://guia-kg.skai.etsisi.upm.es/resource/303000036/2025-26/RA146> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/303000036/2025-26/syllabus> ;
    ns1:inpersonHours "48 horas y 45 minutos (60.2%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation "La asignatura se relaciona con el ODS4 (enseñanza de calidad)."@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "48 horas y 45 minutos"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/303000036/2025-26/eventSchedule> ;
    schema:description """Descripción de la asignatura.-
Conocer, comprender y practicar los métodos de enseñanza teórico-prácticos de la enseñanza del Dibujo a Mano Alzada y Croquización, aspectos didácticos de la organización de la docencia y de la evaluación. Conocer y aplicar la acotación en el dibujo a mano alzada como medio de enseñanza de la Croquización, empleando la herramienta del método lógico geométrico. Conocer y aplicar las reglas fundamentales de la Croquización: distribución, proporción, finalidad y técnica. Conocer y aplicar la Croquización como medio de representación de la geometría que determina la estructura espacial de los objetos, haciendo uso adecuado de los Sistemas de Representación. Aplicación de recursos pedagógicos a partir de objetos domésticos y a través del razonamiento que facilitan el aprendizaje y previenen del empleo de procesos insustanciales o meramente memorísticos por el alumno."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/josejaime.rua%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/josejaime.rua%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/mercedes.valiente%40upm.es> ;
    schema:name "Dibujo a Mano Alzada y Croquizacion"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000036/2025-26/CON16.CE20.> a ns1:Competency ;
    ns1:competencyCode "CON16.CE20." ;
    ns1:competencyDescription "Adquirir criterios de selección y elaboración de materiales educativos. TIPO: Conocimientos o contenidos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000036/2025-26/CON18.CE24.> a ns1:Competency ;
    ns1:competencyCode "CON18.CE24." ;
    ns1:competencyDescription "Conocer y aplicar propuestas docentes innovadoras en el ámbito de la especialización cursada. TIPO: Conocimientos o contenidos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000036/2025-26/RA140> a ns1:LearningResult ;
    ns1:learningResultCode "RA140" ;
    ns1:learningResultDescription "Conocer y dominar los métodos de enseñanza de la representación del dibujo a mano alzada, y los elementos básicos de representación del Croquis"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000036/2025-26/RA141> a ns1:LearningResult ;
    ns1:learningResultCode "RA141" ;
    ns1:learningResultDescription "Conocer cómo enseñar a definir y utilizar los elementos básicos de representación del Croquis"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000036/2025-26/RA142> a ns1:LearningResult ;
    ns1:learningResultCode "RA142" ;
    ns1:learningResultDescription "Aprender a desarrollar la capacidad de análisis e interpretación gráfica de planos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000036/2025-26/RA143> a ns1:LearningResult ;
    ns1:learningResultCode "RA143" ;
    ns1:learningResultDescription "Conocer diferentes formas de enseñanza de las herramientas de Representación de los elementos de proyecto arquitectónico y de ingeniería: plantas alzados y secciones."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000036/2025-26/RA144> a ns1:LearningResult ;
    ns1:learningResultCode "RA144" ;
    ns1:learningResultDescription "Enseñar métodos docentes de impartición de las teorías de Levantamiento de planos de elementos en distintos ámbitos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000036/2025-26/RA145> a ns1:LearningResult ;
    ns1:learningResultCode "RA145" ;
    ns1:learningResultDescription "Enseñar métodos de Interpretación de los documentos del proyecto de diversa índole."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000036/2025-26/RA146> a ns1:LearningResult ;
    ns1:learningResultCode "RA146" ;
    ns1:learningResultDescription "Capacitar para hacer frente a los procesos creativos del diseño conceptual y para comunicar los resultados de su actividad"@es .

