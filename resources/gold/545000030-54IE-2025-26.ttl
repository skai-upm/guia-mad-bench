    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation """Para el cálculo de los valores totales del CRONOGRAMA, se estima que por cada crédito ECTS el alumno dedicará dependiendo del plan de estudios, entre 26 y 27 horas de trabajo presencial y no presencial.
Está previsto inicialmente en el calendario de Grado en Edificación y Doble grado, que las clases del 2º semestre del curso (semestres pares) se desarrollen entre enero y final de mayo. Pero esto puede ser variado antes del inicio del curso. El cronograma se adaptará a dicho calendario de clases y a los horarios y aulas fijados por la ETSEM.
* El cronograma sigue una planificación teórica de la asignatura y puede sufrir modificaciones durante el curso."""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "42 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/545000030/2025-26/eventSchedule> ;
    schema:description "La asignatura está orientada a introducir a los alumnos en la metodología, organización y gestión de los proyectos técnicos de obras y construcciones, tanto de urbanización como de edificación, así como a la aplicación de herramientas avanzadas para el análisis, resolución y desarrollo de las diferentes partes y de los documentos que, en base a la legislación y normativa técnica española, son necesarios para su ejecución, en el marco de las atribuciones profesionales del ámbito de la titulación."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/ma.florez%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/a.picazo%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/ma.florez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/manuel.alvarezd%40upm.es> ;
    schema:name "Proyectos Tecnicos I"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000030/2025-26/CE35> a ns1:Competency ;
    ns1:competencyCode "CE35" ;
    ns1:competencyDescription "Capacidad para aplicar las herramientas avanzadas necesarias para la resolución de las partes que comporta el proyecto técnico y su gestión"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000030/2025-26/CE36> a ns1:Competency ;
    ns1:competencyCode "CE36" ;
    ns1:competencyDescription "Aptitud para redactar proyectos técnicos de obras y construcciones, que no requieran proyecto arquitectónico, así como proyectos de demolición y decoración"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000030/2025-26/CE37> a ns1:Competency ;
    ns1:competencyCode "CE37" ;
    ns1:competencyDescription "Aptitud para redactar documentos que forman parte de proyectos de ejecución elaborados en forma multidisciplinar"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000030/2025-26/CE38> a ns1:Competency ;
    ns1:competencyCode "CE38" ;
    ns1:competencyDescription "Capacidad de análisis de los proyectos de ejecución y su traslación a la ejecución de las obras."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000030/2025-26/CE39> a ns1:Competency ;
    ns1:competencyCode "CE39" ;
    ns1:competencyDescription "Conocimiento de las funciones y responsabilidades de los agentes que intervienen en la edificación y de su organización profesional o empresarial. Los procedimientos administrativos, de gestión y tramitación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000030/2025-26/CE40> a ns1:Competency ;
    ns1:competencyCode "CE40" ;
    ns1:competencyDescription "Conocimiento de la organización profesional y las tramitaciones básicas en el campo de la edificación y la promoción"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000030/2025-26/CG01> a ns1:Competency ;
    ns1:competencyCode "CG01" ;
    ns1:competencyDescription "Dirigir la ejecución material de las obras de edificación, de sus instalaciones y elementos, llevando a cabo el control cualitativo y cuantitativo de lo construido mediante el establecimiento y gestión de los planes de control de materiales, sistemas y ejecución de obra, elaborando los correspondientes registros para su incorporación al Libro del Edificio."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000030/2025-26/CG02> a ns1:Competency ;
    ns1:competencyCode "CG02" ;
    ns1:competencyDescription "Llevar el control económico de la obra elaborando las certificaciones y la liquidación de la obra ejecutada"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000030/2025-26/CG03> a ns1:Competency ;
    ns1:competencyCode "CG03" ;
    ns1:competencyDescription "Redactar estudios y planes de seguridad y salud laboral y coordinar la actividad de las empresas en materia de seguridad y salud laboral en obras de construcción, tanto en fase de proyecto como de ejecución."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000030/2025-26/CG04> a ns1:Competency ;
    ns1:competencyCode "CG04" ;
    ns1:competencyDescription "Llevar a cabo actividades técnicas de cálculo, mediciones, valoraciones, tasaciones y estudios de viabilidad económica; realizar peritaciones, inspecciones, análisis de patología y otros análogos y redactar los informes, dictámenes y documentos técnicos correspondientes; efectuar levantamientos de planos en solares y edificios."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000030/2025-26/CG05> a ns1:Competency ;
    ns1:competencyCode "CG05" ;
    ns1:competencyDescription "Elaborar los proyectos técnicos y desempeñar la dirección de obras de edificación en el ámbito de su habilitación legal."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000030/2025-26/CG06> a ns1:Competency ;
    ns1:competencyCode "CG06" ;
    ns1:competencyDescription "Gestionar las nuevas tecnologías edificatorias y participar en los procesos de gestión de la calidad en la edificación; realizar análisis, evaluaciones y certificaciones de eficiencia energética así como estudios de sostenibilidad en los edificios."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000030/2025-26/CG07> a ns1:Competency ;
    ns1:competencyCode "CG07" ;
    ns1:competencyDescription "Dirigir y gestionar el uso, conservación y mantenimiento de los edificios, redactando los documentos técnicos necesarios."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000030/2025-26/CG11> a ns1:Competency ;
    ns1:competencyCode "CG11" ;
    ns1:competencyDescription "Gestionar el proceso inmobiliario en su conjunto."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000030/2025-26/CG12> a ns1:Competency ;
    ns1:competencyCode "CG12" ;
    ns1:competencyDescription "Ostentar la representación técnica de las empresas constructoras en las obras de edificación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000030/2025-26/CT07> a ns1:Competency ;
    ns1:competencyCode "CT07" ;
    ns1:competencyDescription "Capacidad de búsqueda, análisis y selección de información"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000030/2025-26/CT12> a ns1:Competency ;
    ns1:competencyCode "CT12" ;
    ns1:competencyDescription "Negociaciones, Reuniones."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000030/2025-26/CT13> a ns1:Competency ;
    ns1:competencyCode "CT13" ;
    ns1:competencyDescription "Ética y Deontología"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000030/2025-26/CT16> a ns1:Competency ;
    ns1:competencyCode "CT16" ;
    ns1:competencyDescription "Resolución de problemas. Conflictos y crisis. Toma de decisiones"@es .

