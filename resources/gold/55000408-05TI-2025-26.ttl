    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/55000408/2025-26/eventSchedule> ;
    schema:description "La asignatura de Ferrocarriles tiene como objetivo dotar a los alumnos de conocimientos generales sobre el sistema de transporte por ferrocarril: el camino de rodadura, el contacto rueda-carril, la suspensión, la tracción y el frenado, los subsistemas asociados a la infraestructura y al material móvil, la seguridad ferroviaria, las tecnologías para la electrificación, así como algunos aspectos generales relacionados con la explotación de este modo de transporte."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/franciscojavier.paez%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/franciscojavier.paez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/juandedios.sanz%40upm.es> ;
    schema:name "Ferrocarriles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000408/2025-26/CE29C> a ns1:Competency ;
    ns1:competencyCode "CE29C" ;
    ns1:competencyDescription "Conocimiento y capacidades para la aplicación de la ingeniería de los ferrocarriles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000408/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Conocer y aplicar conocimientos de ciencias y tecnologías básicas a la práctica de la Ingeniería Industrial."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000408/2025-26/CG4> a ns1:Competency ;
    ns1:competencyCode "CG4" ;
    ns1:competencyDescription "Comprender el impacto de la ingeniería industrial en el medio ambiente, el desarrollo sostenible de la sociedad y la importancia de trabajar en un entorno profesional y responsable."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000408/2025-26/CG6> a ns1:Competency ;
    ns1:competencyCode "CG6" ;
    ns1:competencyDescription "Poseer habilidades de aprendizaje que permitan continuar estudiando a lo largo de la vida para su adecuado desarrollo profesional."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000408/2025-26/RA189> a ns1:LearningResult ;
    ns1:learningResultCode "RA189" ;
    ns1:learningResultDescription "Identificar las áreas tecnológicas del ferrocarril."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000408/2025-26/RA190> a ns1:LearningResult ;
    ns1:learningResultCode "RA190" ;
    ns1:learningResultDescription "Determinar las características básicas de la geometría y dinámica ferroviaria."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000408/2025-26/RA191> a ns1:LearningResult ;
    ns1:learningResultCode "RA191" ;
    ns1:learningResultDescription "Determinar el estado del material rodante ferroviario."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000408/2025-26/RA192> a ns1:LearningResult ;
    ns1:learningResultCode "RA192" ;
    ns1:learningResultDescription "Identificar las instalaciones de tracción eléctrica (subestaciones y línea aérea de contacto."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000408/2025-26/RA193> a ns1:LearningResult ;
    ns1:learningResultCode "RA193" ;
    ns1:learningResultDescription "Funciones básicas y avanzadas del control de trenes, como seguridad en la circulación, y de la gestión y planificación de la explotación ferroviaria."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000408/2025-26/RA194> a ns1:LearningResult ;
    ns1:learningResultCode "RA194" ;
    ns1:learningResultDescription "Determinar las características específicas de la alta velocidad ferroviaria"@es .

