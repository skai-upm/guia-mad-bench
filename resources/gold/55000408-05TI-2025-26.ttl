    schema:courseCode 55000408 ;
    schema:hasCourseInstance <https://guia-kg.skai.etsisi.upm.es/resource/55000408/2025-26> ;
    schema:name "Railway Engineering"@en,
        "Ferrocarriles"@es ;
    schema:numberOfCredits 6.0 .

