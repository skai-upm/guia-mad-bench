    ns1:inpersonHours "29 horas (53.7%)"@es ;
    ns1:numberOfCredits 2.0 ;
    ns1:otherInformation "En esta asignatura se trabajará y relacionará con la ODS 11. Las ciudades y las áreas metropolitanas son centros neurálgicos del crecimiento económico, ya que contribuyen al 60 % aproximadamente del PIB mundial. Sin embargo, también representan alrededor del 70 % de las emisiones de carbono mundiales y más del 60 % del uso de recursos. Por medo de la jardinería en las ciudades también se trabajará el ODS 3 ( Garantizar una vida sana y promover el bienestar para todos en todas las edades) tal como indica OMS sobre la calidad de viada de las ciudades en función de las zonas ajardinadas"@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "30 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/23000393/2025-26/eventSchedule> ;
    schema:description "El estudio de las instalaciones de riego en zonas verdes está organizado en dos asignaturas, \"Instalaciones de riego I\" e \"Instalaciones de riego II\", que en conjunto, tratan del conocimiento de las características, tipos, peculiaridades, cálculo, aplicaciones y evaluación de las instalaciones de riego en jardines, parques y espacios verdes de todo tipo."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/ruben.moratiel%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/ruben.moratiel%40upm.es> ;
    schema:name "Instalaciones de Riego II"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000393/2025-26/C2> a ns1:Competency ;
    ns1:competencyCode "C2" ;
    ns1:competencyDescription "Capacidad para describir, organizar y analizar los elementos constitutivos de un problema de jardinería y paisajismo y diseñar estrategias que permitan alcanzar una solución técnica, ambiental y económicamente viable. TIPO: Competencias."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000393/2025-26/C5> a ns1:Competency ;
    ns1:competencyCode "C5" ;
    ns1:competencyDescription "Capacidad de diseñar, calcular y ejecutar todo tipo de instalaciones de riego, iluminación, movimiento de tierras, drenaje y desagüe, en todo tipo de actuaciones paisajísticas y áreas verdes, así como de llevar a cabo su mantenimiento, aplicando incluso las técnicas más complejas y avanzadas. TIPO: Competencias."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000393/2025-26/K6> a ns1:Competency ;
    ns1:competencyCode "K6" ;
    ns1:competencyDescription "Conocer las características y peculiaridades de las empresas y entidades vinculadas a las actividades de jardinería y paisajismo, y cómo organizar el trabajo en equipo y participar en las actuaciones ejecutivas y directivas. TIPO: Conocimientos o contenidos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000393/2025-26/RA107> a ns1:LearningResult ;
    ns1:learningResultCode "RA107" ;
    ns1:learningResultDescription "K6"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000393/2025-26/RA109> a ns1:LearningResult ;
    ns1:learningResultCode "RA109" ;
    ns1:learningResultDescription "S4"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000393/2025-26/S4> a ns1:Competency ;
    ns1:competencyCode "S4" ;
    ns1:competencyDescription "Habilidad de reconocer los principios éticos para la toma de decisiones en el ámbito de la jardinería y el paisajismo, conociendo y aplicando la normativa, con criterios de calidad y considerando las implicaciones sociales, de salud y seguridad, ambientales y económicas. TIPO: Habilidades o destrezas"@es .

