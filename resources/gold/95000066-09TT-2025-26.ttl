<https://guia-kg.skai.etsisi.upm.es/resource/95000066/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/95000066/2025-26/CE>,
        <https://guia-kg.skai.etsisi.upm.es/resource/95000066/2025-26/CG10>,
