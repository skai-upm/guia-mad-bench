<https://guia-kg.skai.etsisi.upm.es/resource/93000967/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. 0. Introduction to the different acquisition techniques of medical images Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000967/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "2. 1. Physical principles of radiology and nuclear medicine and their influence on the design of imaging systems. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000967/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "3. 2. Radiology Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000967/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "4. 3. Nuclear Medicine: scintigraphy, design factors, image quality factors, SPECT and its clinical applications; Positron Emission Tomography (PET): design parameters, new applications, hybrid PET-CT, PET-RM system Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000967/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "5. 4. Magnetic resonance imaging: image parameters, pulse sequences, imaging methods, quality factors and main applications in neuroimaging and cardiology. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000967/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "6. . Ultrasound imaging: advanced ultrasound techniques and new clinical applications Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000967/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "7. 6. DICOM standard Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000967/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "8. Advanced processing methods: intensification, enhancement and segmentation of biomedical images. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000967/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "9. 8. Practical work on image processing Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000967/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "10. 9. Computed tomography: design of CT systems, image quality, reconstruction and new applications. Sin subniveles"@es .

