        <https://guia-kg.skai.etsisi.upm.es/resource/enriquejavier.gomez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/mariaelena.hernando%40upm.es> ;
    schema:name "Imágenes Médicas"@es .

