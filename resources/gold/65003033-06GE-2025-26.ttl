    ns1:inpersonHours "67 horas (55.1%)"@es ;
    ns1:numberOfCredits 4.5 ;
    ns1:otherInformation """ODS12 "Consumo y producción responsables" --- Las técnicas de prospección geofísica favorecen el uso eficiente de los recursos naturales desde la exploración tanto de recursos no explotados, como de escombreras u otros medios asociados a recursos explotados o empleados en una primera vida útil.
ODS6 "Agua limpia y saneamiento" y 15 ?Vida de ecosistemas terrestres?: Las técnicas de prospección geofísica son herramientas fundamentales en el control de los procesos de contaminación y degradación de los suelos y las aguas."""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "70 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/65003033/2025-26/eventSchedule> ;
    schema:description "La asignatura pretende dar una visión global y aplicada de las herramientas más habituales y actuales en prospección geofísica. Los contenidos se dividen en un bloque de introducción y otros cinco bloques sobre las distintas técnicas de prospección. En el primer bloque se define y contextualiza la prospección geofísica, se presentan diferentes clasificaciones de los métodos de prospección, y se tratan aspectos básicos y comunes a todos ellos. En los cinco bloques siguientes se desarrollan tanto las técnicas clásicas de prospección como otras más recientes, todas ellas ampliamente utilizadas en el ámbito profesional. Los aspectos que se trataran en cada una serán: los principios teóricos, instrumentación y mediciones, interpretación y sus campos de aplicación."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/barbara.biosca%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/barbara.biosca%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/j.diazcuriel%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/lucia.arevalo%40upm.es> ;
    schema:name "Prospeccion Geofisica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65003033/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Conocer y aplicar conocimientos de ciencias y tecnologías básicas a la práctica de la Ingeniería Geológica."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65003033/2025-26/CG2> a ns1:Competency ;
    ns1:competencyCode "CG2" ;
    ns1:competencyDescription "Poseer capacidad para diseñar, desarrollar, implementar, gestionar y mejorar productos, sistemas y procesos en los distintos ámbitos geológicos, usando técnicas analíticas, computacionales o experimentales apropiadas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65003033/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Aplicar los conocimientos adquiridos para identificar, formular y resolver problemas dentro de contextos amplios y multidisciplinarios, siendo capaces de integrar conocimientos, trabajando en equipos multidisciplinares."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65003033/2025-26/CG5> a ns1:Competency ;
    ns1:competencyCode "CG5" ;
    ns1:competencyDescription "Saber comunicar los conocimientos y conclusiones, tanto de forma oral, escrita y gráfica, a públicos especializados y no especializados de un modo claro y sin ambigüedades."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65003033/2025-26/CG6> a ns1:Competency ;
    ns1:competencyCode "CG6" ;
    ns1:competencyDescription "Poseer habilidades de aprendizaje que permitan continuar estudiando a lo largo de la vida para su adecuado desarrollo profesional."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65003033/2025-26/CG7> a ns1:Competency ;
    ns1:competencyCode "CG7" ;
    ns1:competencyDescription "Incorporar nuevas tecnologías y herramientas de la Ingeniería Geológica en sus actividades profesionales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65003033/2025-26/F22> a ns1:Competency ;
    ns1:competencyCode "F22" ;
    ns1:competencyDescription "Prospección Geofísica y Geoquímica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65003033/2025-26/F23> a ns1:Competency ;
    ns1:competencyCode "F23" ;
    ns1:competencyDescription "Diseño, planificación y ejecución para prospección y extracción de minerales, rocas, combustibles fósiles y nucleares, aguas subterráneas y geotécnicos. Ídem para inyección de fluidos en estructuras subterráneas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65003033/2025-26/F28> a ns1:Competency ;
    ns1:competencyCode "F28" ;
    ns1:competencyDescription "Estudios hidrológicos, hidrogeológicos, estratigráficos y paleontológicos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65003033/2025-26/RA175> a ns1:LearningResult ;
    ns1:learningResultCode "RA175" ;
    ns1:learningResultDescription "Conocer y aplicar la terminología geofísica."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65003033/2025-26/RA176> a ns1:LearningResult ;
    ns1:learningResultCode "RA176" ;
    ns1:learningResultDescription "Conocer los principios generales de los métodos de prospección geofísica."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65003033/2025-26/RA177> a ns1:LearningResult ;
    ns1:learningResultCode "RA177" ;
    ns1:learningResultDescription "Conocer la forma en que se llevan a cabo las prospecciones geofísicas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65003033/2025-26/RA178> a ns1:LearningResult ;
    ns1:learningResultCode "RA178" ;
    ns1:learningResultDescription "Conocer el proceso de datos y las bases de su interpretación cualitativa y cuantitativa"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65003033/2025-26/RA179> a ns1:LearningResult ;
    ns1:learningResultCode "RA179" ;
    ns1:learningResultDescription "Conocer los campos de aplicación de la Geofísica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65003033/2025-26/RA268> a ns1:LearningResult ;
    ns1:learningResultCode "RA268" ;
    ns1:learningResultDescription "Conocer los criterios para seleccionar el método de prospección geofísica para localización y/o caracterización en función de las propiedades del objetivo y de su entorno"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65003033/2025-26/RA269> a ns1:LearningResult ;
    ns1:learningResultCode "RA269" ;
    ns1:learningResultDescription "Conocer las aplicaciones de la prospección geofísica en problemas hidrogeológicos, geotécnicos, mineros y medioambientales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65003033/2025-26/RA270> a ns1:LearningResult ;
    ns1:learningResultCode "RA270" ;
    ns1:learningResultDescription "Conocer la metodología y división de los métodos de prospección geofísica."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65003033/2025-26/RA271> a ns1:LearningResult ;
    ns1:learningResultCode "RA271" ;
    ns1:learningResultDescription "Conocer las principales características físicas (densidad, velocidad, resistividad,?) de diferentes rocas y suelos que se utilizan en la prospección geofísica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65003033/2025-26/RA272> a ns1:LearningResult ;
    ns1:learningResultCode "RA272" ;
    ns1:learningResultDescription "Conocer los métodos gravimétricos, magnéticos, eléctricos y sísmicos de prospección."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65003033/2025-26/RA273> a ns1:LearningResult ;
    ns1:learningResultCode "RA273" ;
    ns1:learningResultDescription "Conocer los métodos de prospección eléctrica avanzados y los métodos electromagnéticos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65003033/2025-26/RA274> a ns1:LearningResult ;
    ns1:learningResultCode "RA274" ;
    ns1:learningResultDescription "Alcanzar capacidad para la utilización de sondeos eléctricos verticales y perfiles de sísmica de refracción."@es .

