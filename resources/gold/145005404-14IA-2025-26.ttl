    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Tipología estructural en el entorno aeropoturario. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005404/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "2.6. Ecuaciones de equilibrio. Ensamblaje. Resolución. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005404/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "2.7. Ligaduras. Tipos. Tratamiento. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005404/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "2.8. Efectos térmicos. Asientos. Retracción del hormigón. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005404/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "2.9. Diagramas de momentos y fuerzas. Esfuerzos en secciones. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005404/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "2.10. Ejercicios de análisis estructural. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005404/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "3. ANÁLISIS PLÁSTICO DE ESTRUCTURAS."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005404/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "3.1. Introducción al cálculo plástico de estructuras. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005404/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "3.2. Flexión plástica de vigas. Rótula plástica. Factor de forma. Determinación de la carga última. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005404/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "3.3. Teoremas fundamentales del análisis límite. Método estático. Método de los mecanismos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005404/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "3.4. Vigas continuas. Pórticos simples. Método de superposición de mecanismos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005404/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Acciones sobre edificios. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005404/2025-26/syllabus/20> a ns1:SyllabusItem ;
    ns1:itemIndex 20 ;
    ns1:syllabusDescription "3.5. Ejercicios de análisis plástico. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005404/2025-26/syllabus/21> a ns1:SyllabusItem ;
    ns1:itemIndex 21 ;
    ns1:syllabusDescription "3.6. Análisis plástico de losas. Método de las líneas de rotura. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005404/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "1.3. Normativa. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005404/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "2. ANÁLISIS DE ESTRUCTURAS."@es .

