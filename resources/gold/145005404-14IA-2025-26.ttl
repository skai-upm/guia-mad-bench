    ns1:itemIndex 5 ;
    ns1:syllabusDescription "2.1. Métodos analítiicos de resolución de estructuras articuladas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005404/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "2.2. Métodos numéricos. Métodos de los desplazamientos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005404/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "2.3. Matrices de rigidez y de cargas de elementos estructurales. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005404/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "2.4. Vector de cargas nodales equivalentes. Sin subniveles"@es .

