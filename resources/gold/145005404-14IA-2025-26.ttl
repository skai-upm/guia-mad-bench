        <https://guia-kg.skai.etsisi.upm.es/resource/145005404/2025-26/RA624> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/145005404/2025-26/syllabus> ;
    ns1:inpersonHours "48 horas y 30 minutos (59.9%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation ""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "48 horas y 30 minutos"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/145005404/2025-26/eventSchedule> ;
    schema:description """La asignatura de Estructuras para la especialidad de Aeropuertos y Transporte Aéreo, describe, en un primer lugar, la tipología estructural en el entorno aeroportuario desde el punto de vista del cálculo estructural: hangares, pistas, terminales.
Posteriormente, en el tema II, se centra en una profundización de los métodos de cálculo clásicos y, sobre todo, del cálculo matricial de estructuras.
Por último, en el tema III, se desarrolla el análisis plástico de estructuras aplicable tanto en estructuras continuas de hormigón y acero como en el cálculo de losas."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/khanhnguyen.gia%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/jorge.llamazares%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/joseluis.hernando%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/khanhnguyen.gia%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/roman.torres%40upm.es> ;
    schema:name "Estructuras"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005404/2025-26/CE61> a ns1:Competency ;
    ns1:competencyCode "CE61" ;
    ns1:competencyDescription "Conocimiento adecuado y aplicado a la Ingeniería de: La mecánica de fractura del medio continuo y los planteamientos dinámicos, de fatiga y de inestabilidad estructural."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005404/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Capacidad para identificar y resolver problemas aplicando, con creatividad, los conocimientos adquiridos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005404/2025-26/RA239> a ns1:LearningResult ;
    ns1:learningResultCode "RA239" ;
    ns1:learningResultDescription "Conocimiento, comprensión, aplicación, análisis y síntesis de la teoría de estructuras en edificaciones de aeropuertos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005404/2025-26/RA240> a ns1:LearningResult ;
    ns1:learningResultCode "RA240" ;
    ns1:learningResultDescription "Conocimiento general de los tipos de estructuras utilizadas en la construcción de edificios aeroportuarios."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005404/2025-26/RA241> a ns1:LearningResult ;
    ns1:learningResultCode "RA241" ;
    ns1:learningResultDescription "Conocimiento, comprensión, aplicación, análisis y síntesis del cálculo matricial de estructuras civiles, así como de los diferentes tipos de pandeo de elementos estructurales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005404/2025-26/RA624> a ns1:LearningResult ;
    ns1:learningResultCode "RA624" ;
    ns1:learningResultDescription "RA239"@es .

