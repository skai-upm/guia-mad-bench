    ns1:numberOfCredits 4.0 ;
    ns1:otherInformation "Aunque es el primer año que se celebrará la matería y no esta claro como reaccionarán los alumnos al trabajo autónomo en la innovación. Se indicará que el Trabajo de Innovación deberá dar respuesta en algún aspecto, a alguno de los ODS."@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
