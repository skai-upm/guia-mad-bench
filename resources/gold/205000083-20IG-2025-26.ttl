<https://guia-kg.skai.etsisi.upm.es/resource/205000083/2025-26/CT05> a ns1:Competency ;
    ns1:competencyCode "CT05" ;
    ns1:competencyDescription "Respeto al medio ambiente: capacidad para ofrecer soluciones compatibles con la conservaciÃ³n del entorno de forma responsable y sostenible, con el fin de evitar o disminuir los efectos negativos producidos por las prÃ¡cticas inadecuadas ocasionadas por la actividad humana y potenciar los beneficios que pueda generar la actividad profesional de la ingenierÃ­a, en el Ã¡mbito medioambiental. (EUR"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000083/2025-26/RA100> a ns1:LearningResult ;
    ns1:learningResultCode "RA100" ;
    ns1:learningResultDescription "Describir los horizontes de un perfil de un suelo y evaluar la influencia de los factores formadores"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000083/2025-26/RA101> a ns1:LearningResult ;
    ns1:learningResultCode "RA101" ;
    ns1:learningResultDescription "Describir, analizar e interpretar los datos edafológicos de campo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000083/2025-26/RA102> a ns1:LearningResult ;
    ns1:learningResultCode "RA102" ;
    ns1:learningResultDescription "Identificar y describir el componente mineral y orgánico del suelo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000083/2025-26/RA103> a ns1:LearningResult ;
    ns1:learningResultCode "RA103" ;
    ns1:learningResultDescription "Identificar la actividad biológica del suelo y su importancia en los ciclos biogeoquímicos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000083/2025-26/RA104> a ns1:LearningResult ;
    ns1:learningResultCode "RA104" ;
    ns1:learningResultDescription "Analizar e interpretar datos de laboratorio y relacionarlos con las propiedades del suelo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000083/2025-26/RA105> a ns1:LearningResult ;
    ns1:learningResultCode "RA105" ;
    ns1:learningResultDescription "Evaluar el suelo como recurso, describir sus propiedades y proponer técnicas de conservación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000083/2025-26/RA106> a ns1:LearningResult ;
    ns1:learningResultCode "RA106" ;
    ns1:learningResultDescription "Analizar el estado del agua en el suelo y su relación con la planta y manejo."@es .

