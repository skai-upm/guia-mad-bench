    ns1:itemIndex 45 ;
    ns1:syllabusDescription "9.2. Métodos de evaluación de suelos Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000083/2025-26/syllabus/46> a ns1:SyllabusItem ;
    ns1:itemIndex 46 ;
    ns1:syllabusDescription "9.3. Casos particulares de aplicación agronómica y medioambiental Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000083/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "2. Génesis y formación del suelo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000083/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "2.1. Factores de formación (causas). Factores activos (clima y seres vivos), factores pasivos (litología y geomorfología) y tiempo Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000083/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "2.2. Procesos de formación (efectos): adiciones, traslocaciones, transformaciones y eliminaciones Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000083/2025-26/syllabus/8> a ns1:SyllabusItem ;
