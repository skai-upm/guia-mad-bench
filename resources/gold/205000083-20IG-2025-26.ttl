    ns1:bibliographyType "Otros"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000083/2025-26/didactic_resource/3> a ns1:DidacticResource ;
    ns1:bibliographyDescription """La realización de las prácticas de laboratorio permitirá afianzar y
mejorar la comprensión de los aspectos teóricos."""@es ;
    ns1:bibliographyTitle "Prácticas de laboratorio"@es ;
    ns1:bibliographyType "Equipamiento"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000083/2025-26/didactic_resource/4> a ns1:DidacticResource ;
