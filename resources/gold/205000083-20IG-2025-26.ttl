    ns1:syllabusDescription "2.3. Secuencia de horizontes (resultado). El perfil Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000083/2025-26/syllabus/9> a ns1:SyllabusItem ;
