    ns1:inpersonHours "67 horas (51.5%)"@es ;
    ns1:numberOfCredits 5.0 ;
    ns1:otherInformation """Los alumnos que realicen prácticas de laboratorio deberán obligatoriamente disponer de bata de laboratorio para su realización, no pudiendo realizar las prácticas sin ella. Se considerará como no asistencia, siendo necesaria la asistencia a 4 de las 5 prácticas programadas para la aprobación de la asignatura.
La asignatura trabaja algunos aspectos de los Objetivos de Desarrollo Sostenible (ODS) establecidos por Naciones Unidas. La asignatura se relaciona con ODS15.
En cuanto al ODS15 mediante ejercicios y temario específico se analizan ciertos aspectos relacionados con la degradación de las tierras."""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "79 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/205000083/2025-26/eventSchedule> ;
    schema:description "La asignatura se ubica en el primer semestre del segundo curso de la titulación. En ella se introducen los conocimientos básicos sobre la Edafología, la formación, propiedades y manejo de los suelos dentro de la Ingeniería Agrícola en un contexto sostenible."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/marta.benito%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/marta.benito%40upm.es> ;
    schema:name "Edafología"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000083/2025-26/CB03> a ns1:Competency ;
    ns1:competencyCode "CB03" ;
    ns1:competencyDescription "Que los estudiantes tengan la capacidad de reunir e interpretar datos relevantes (normalmente dentro de su área de estudio) para emitir juicios que incluyan una reflexión sobre temas relevantes de índole social, científica o ética"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000083/2025-26/CB04> a ns1:Competency ;
    ns1:competencyCode "CB04" ;
    ns1:competencyDescription "Que los estudiantes puedan transmitir información, ideas, problemas y soluciones a un público tanto especializado como no especializado"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000083/2025-26/CE10> a ns1:Competency ;
    ns1:competencyCode "CE10" ;
    ns1:competencyDescription "Capacidad para conocer, comprender y utilizar las bases de la producción vegetal, los sistemas de producción, de protección y de explotación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000083/2025-26/CG02> a ns1:Competency ;
    ns1:competencyCode "CG02" ;
    ns1:competencyDescription "Conocimiento adecuado de los problemas físicos, las tecnologías, maquinaria y sistemas de suministro hídrico y energético, los límites impuestos por factores presupuestarios y normativa constructiva, y las relaciones entre las instalaciones o edificaciones y explotaciones agrarias, las industrias agroalimentarias y los espacios relacionados con la jardinería y el paisajismo con su entorno social y ambiental, así como la necesidad de relacionar aquellos y ese entorno con las necesidades humanas y de preservación del medio ambiente."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000083/2025-26/CG05> a ns1:Competency ;
    ns1:competencyCode "CG05" ;
    ns1:competencyDescription "Capacidad para la redacción y firma de estudios de desarrollo rural, de impacto ambiental y de gestión de residuos de las industrias agroalimentarias explotaciones agrícolas y ganaderas, y espacios relacionados con la jardinería y el paisajismo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000083/2025-26/CG06> a ns1:Competency ;
    ns1:competencyCode "CG06" ;
    ns1:competencyDescription "Capacidad para la dirección y gestión de toda clase de industrias agroalimentarias, explotaciones agrícolas y ganaderas, espacios verdes urbanos y/o rurales, y áreas deportivas públicas o privadas, con conocimiento de las nuevas tecnologías, los procesos de calidad, trazabilidad y certificación y las técnicas de marketing y comercialización de productos alimentarios y plantas cultivadas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000083/2025-26/CG11> a ns1:Competency ;
    ns1:competencyCode "CG11" ;
    ns1:competencyDescription "Capacidad para desarrollar sus actividades, asumiendo un compromiso social, ético y ambiental en sintonía con la realidad del entorno humano y natural."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000083/2025-26/CT01> a ns1:Competency ;
