    ns1:bibliographyDescription "El profesorado desarrollará el temario de teoría propuesto. En la plataforma se incluirán presentaciones, documentos de trabajo y los enlaces a la bibliografía recomendada para seguir la materia."@es ;
    ns1:bibliographyTitle "Clases teóricas"@es ;
