    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/95000027/2025-26/eventSchedule> ;
    schema:description "En esta asignatura se presentan conceptos fundamentales para analizar la eficiencia y fiabilidad de la transmisión de datos sobre canales discretos. Se aborda el concepto de información y fuente de información, se estudian los límites de compresión sin pérdidas y de la capacidad de transmisión de un canal discreto (Teoremas Fundamentales de Shannon en el caso discreto). Se estudian los conceptos básicos de protección de la información frente a errores del canal, presentando los códigos fundamentales. Por último, se realiza un análisis ideal de prestaciones en la aplicación estos códigos en mecanismos de transmisión al uso: corrección de errores y detección y solicitud de reenvío."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/gabriel.huecas%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/gabriel.huecas%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/juanantonio.saras%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/sonia.solera%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/victor.villagra%40upm.es> ;
    schema:name "Teoria de la Informacion"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000027/2025-26/CECT1> a ns1:Competency ;
    ns1:competencyCode "CECT1" ;
    ns1:competencyDescription "Capacidad para aprender de manera autónoma nuevos conocimientos y técnicas adecuados para la concepción, el desarrollo o la explotación de sistemas y servicios de telecomunicación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000027/2025-26/CECT4> a ns1:Competency ;
    ns1:competencyCode "CECT4" ;
    ns1:competencyDescription "Capacidad de analizar y especificar los parámetros fundamentales de un sistema de comunicaciones"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000027/2025-26/RA53> a ns1:LearningResult ;
    ns1:learningResultCode "RA53" ;
    ns1:learningResultDescription "Comprensión y dominio de caracterización y descripción de las señales deterministas y aleatorias y su aplicación a la codificación de voz, datos, audio y vídeo y a la caracterización de las perturbaciones y del ruido."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000027/2025-26/RA55> a ns1:LearningResult ;
    ns1:learningResultCode "RA55" ;
    ns1:learningResultDescription "Comprensión y dominio de las técnicas de codificación de fuente, codificación de canal y cifrado de señales."@es .

