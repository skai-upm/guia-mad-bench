<https://guia-kg.skai.etsisi.upm.es/resource/615000356/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/615000356/2025-26/CC1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/615000356/2025-26/CC18>,
        <https://guia-kg.skai.etsisi.upm.es/resource/615000356/2025-26/CT6>,
        <https://guia-kg.skai.etsisi.upm.es/resource/615000356/2025-26/CT9> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/615000356/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/615000356/2025-26/didactic_resource/2>,
