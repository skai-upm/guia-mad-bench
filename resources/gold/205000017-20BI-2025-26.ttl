    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/205000017/2025-26/eventSchedule> ;
    schema:description """El objetivo de la asignatura es introducir al alumno en los conceptos necesarios de programación y análisis estadístico de datos. Para ello se utilizará el lenguaje de programación R. La asignatura está dividida en dos unidades temáticas. La primera es programación, donde desarrollaremos los conceptos básicos de programación y como se utilizan en R.
En la segunda unidad temática desarrollamos los conceptos estadísticos y utilizamos R, y lo aprendido en la primera unidad temática, para entender los conceptos estadísticos desarrollados y su aplicación al análisis de datos."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/miguel.ibanez%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/miguel.ibanez%40upm.es> ;
    schema:name "Programación para Estadística"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000017/2025-26/CE03> a ns1:Competency ;
    ns1:competencyCode "CE03" ;
    ns1:competencyDescription "Capacidad para realizar análisis bioestadístico, así como utilizar herramientas informáticas para la resolución de problemas matemáticos y estadísticos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000017/2025-26/CG03> a ns1:Competency ;
    ns1:competencyCode "CG03" ;
    ns1:competencyDescription "Familiarizarse con el trabajo y los métodos experimentales en condiciones reales, adquiriendo la capacidad de realizar experimentos y/o diseñar aplicaciones de forma independiente y describir, cuantificar, analizar y evaluar críticamente los resultados obtenidos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000017/2025-26/CT08> a ns1:Competency ;
    ns1:competencyCode "CT08" ;
    ns1:competencyDescription "Ser capaz de manejar las tecnologías de la información y comunicación en un contexto profesional."@es .

