<https://guia-kg.skai.etsisi.upm.es/resource/55000021/2025-26/syllabus> a ns1:Syllabus ;
    ns1:hasItem <https://guia-kg.skai.etsisi.upm.es/resource/55000021/2025-26/syllabus/0>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55000021/2025-26/syllabus/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55000021/2025-26/syllabus/10>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55000021/2025-26/syllabus/11>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55000021/2025-26/syllabus/12>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55000021/2025-26/syllabus/13>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55000021/2025-26/syllabus/14>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55000021/2025-26/syllabus/2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55000021/2025-26/syllabus/3>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55000021/2025-26/syllabus/4>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55000021/2025-26/syllabus/5>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55000021/2025-26/syllabus/6>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55000021/2025-26/syllabus/7>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55000021/2025-26/syllabus/8>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55000021/2025-26/syllabus/9> .

<https://guia-kg.skai.etsisi.upm.es/resource/55000021/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Integrales sobre curvas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000021/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Ecuaciones implícitas y paramétricas de una curva. Curvas de clase C1 a trozos. Longitud de una curva. Integración de un campo escalar a lo largo de una curva. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000021/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "3.2. Superficies con borde. Teorema de Stokes. Significado geométrico del operador rotacional. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000021/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "4. Teoría de campos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000021/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "4.1. Campos irrotacionales y campos de gradientes. Dominios simplemente conexos en el espacio. Condición suficiente para que un campo sea conservativo. Potencial escalar de un campo conservativo. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000021/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "4.2. Campos solenoidales y campos de rotores. Potencial vector. Dominios estrellados: condición suficiente para que un campo solenoidal admita potencial vector. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000021/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "4.3. Teoremas de Helmholtz. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000021/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Circulación de un campo vectorial sobre una curva. Trabajo que ejerce un campo vectorial. Independencia del camino: campos conservativos y campos de gradientes. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000021/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "1.3. Teorema de Green. Dominios simplemente conexos en en plano. Condición suficiente para que un campo sea conservativo en el plano. Potencial escalar de un campo conservativo. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000021/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "2. Integrales de superficie."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000021/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "2.1. Ecuaciones implícitas y paramétricas de una superficie de clase C1. Plano tangente y vector normal a una superficie. Superficies de revolución. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000021/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "2.2. Área de una superficie. Integral de un campo escalar sobre una superficie. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000021/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "2.3. Superficies orientables. Flujo de un campo vectorial a través de una superficie. Significado geométrico del operador laplaciano. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000021/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "3. Teoremas Integrales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000021/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "3.1. Teorema de la divergencia o de Gauss. Significado geométrico del operador divergencia. Sin subniveles"@es .

