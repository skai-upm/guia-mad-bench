        <https://guia-kg.skai.etsisi.upm.es/resource/133000225/2025-26/syllabus/8>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000225/2025-26/syllabus/9> .

<https://guia-kg.skai.etsisi.upm.es/resource/133000225/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. TEMA 1.ORDENACIÓN DEL TERRITORIO. Concepto y objetivos. Aproximación al origen de la ordenación del territorio Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000225/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "2. TEMA 2. INSTRUMENTOS LEGALES DE LA ORDENACIÓN DEL TERRITORIO. Antecedentes. Marco estatal. Legislación en las Comunidades Autónomas. Otras legislaciones no específicas con incidencia territorial. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000225/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "11. TEMA 11. DEGRADACIÓN Y ORDENACIÓN DE LA FRANJA COSTERA. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000225/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "12. TEMA 12. EL MAR ABIERTO Y EL RELIEVE SUBMARINO. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000225/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "3. TEMA 3. METODOLOGÍA GENERAL PARA LA ELABORACIÓN DE UN PLAN DE ORDENACIÓN DEL TERRITORIO. El ámbito espacial del plan. Análisis y diagnóstico del sistema territorial. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000225/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "4. TEMA 4. PLANIFICACIÓN SECTORIAL. Planes territoriales y su influencia territorial. Papel de la planificación forestal en la ordenación territorial. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000225/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "5. TEMA 5. EL PLANEAMIENTO DEL USO URBANO. LA ESCALA LOCAL. Tipos de planes urbanísticos, influencia del urbanismo sobre el territorio y efectos ambientales. Relación del urbanismo con la política y planes forestales. Directrices para la toma de decisiones. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000225/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "6. TEMA 6. LA EVALUACIÓN AMBIENTAL DE PLANES Y PROGRAMAS. Principios y procedimientos de la Evaluación Ambiental Estratégica. Medidas de mejora ambiental en planes y programas con incidencia territorial. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000225/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "7. TEMA 7. GEOGRAFÍA Y DINÁMICA LITORAL. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000225/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "8. TEMA 8. GEOGRAFÍA LITORAL ESPAÑOLA. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000225/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "9. TEMA 9. MODIFICACIÓN Y ESTABILIZACIÓN DE LA LÍNEA DE COSTA POR ACTIVIDADES ANTRÓPICAS. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000225/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "10. TEMA 10. EL SISTEMA TIERRA - MAR Y EL BENTOS. Sin subniveles"@es .

