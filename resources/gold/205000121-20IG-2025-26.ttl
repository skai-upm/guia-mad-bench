    schema:description "La asignatura 'Instalaciones Ganaderas' aborda los alojamientos y equipos necesarios para la explotación de las distintas especies ganaderas, con un enfoque que busca tanto la necesaria profundidad como la aplicabilidad para el diseño de dichas instalaciones."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/antonio.callejo%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
