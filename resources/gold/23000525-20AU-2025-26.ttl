<https://guia-kg.skai.etsisi.upm.es/resource/23000525/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Fundamentos de bioenergía Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000525/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "2. Productividad vegetal. La bioenergía como fuente de energía renovable: conversión de energía solar a energía química Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000525/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "11. IB&MP: Biocombustibles avanzados. Biorrefinerías. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000525/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "3. La diversidad vegetal, base para la utilización de la bioenergía. Composición, caracterización y tipos de biomasa Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000525/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "4. Sostenibilidad de la bioenergía, marco regulatorio y balances Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000525/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "5. Herramientas de evaluación y recursos de biomasa Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000525/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "6. Industrias de la bioenergía y sus materias primas (IB&MP). Normalización y producción de biocombustibles sólidos Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000525/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "7. IB&MP: Usos térmicos de los biocombustibles sólidos Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000525/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "8. IB&MP: Biocarburantes. Biodiesel. HVO. Bioetanol Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000525/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "9. IIB&MP: Biogás y biometano. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000525/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "10. IB&MP: Generación eléctrica. bioelectricidad. Sin subniveles"@es .

