<https://guia-kg.skai.etsisi.upm.es/resource/563000123/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/563000123/2025-26/CB10>,
        <https://guia-kg.skai.etsisi.upm.es/resource/563000123/2025-26/CEC04>,
