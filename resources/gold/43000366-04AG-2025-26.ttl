    ns1:learningResultDescription "Conoce y comprende las ecuaciones que describen el movimiento de fluidos en el medio natural, incluyendo transporte de partículas y contaminantes"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000366/2025-26/RA109> a ns1:LearningResult ;
    ns1:learningResultCode "RA109" ;
    ns1:learningResultDescription "Aplica los principios de la hidráulica técnica al diseño, cálculo y explotación de obras y aprovechamientos hidráulicos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000366/2025-26/RA3> a ns1:LearningResult ;
