<https://guia-kg.skai.etsisi.upm.es/resource/43000366/2025-26/RA105> a ns1:LearningResult ;
    ns1:learningResultCode "RA105" ;
    ns1:learningResultDescription "Comprende y domina los principios y las ecuaciones fundamentales de la mecánica de fluidos"@es .

