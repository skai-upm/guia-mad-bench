    ns1:competencyCode "CE43" ;
    ns1:competencyDescription "Aplicar los principios de la ingeniería nuclear y de la protección radiológica."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004021/2025-26/CE45> a ns1:Competency ;
    ns1:competencyCode "CE45" ;
    ns1:competencyDescription "Aplicación de conocimientos de ingeniería al diseño, implantación y puesta en operación de plantas energéticas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004021/2025-26/CE53> a ns1:Competency ;
    ns1:competencyCode "CE53" ;
    ns1:competencyDescription "Aplicar los principios de la tecnología ambiental a la evaluación de impactos, al tratamiento de residuos y a la sostenibilidad."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004021/2025-26/CE58> a ns1:Competency ;
    ns1:competencyCode "CE58" ;
    ns1:competencyDescription "Aplicar los fundamentos de la prevención de riesgos laborales en los proyectos e instalaciones energéticos."@es .

