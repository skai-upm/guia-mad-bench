    schema:name "Mantenimiento"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000045/2025-26/CE17> a ns1:Competency ;
    ns1:competencyCode "CE17" ;
    ns1:competencyDescription "Capacidad para dictaminar sobre las causas y manifestaciones de las lesiones en los edificios, proponer soluciones para evitar o subsanar las patologías, y analizar el ciclo de vida útil de los elementos y sistemas constructivos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000045/2025-26/CE18> a ns1:Competency ;
    ns1:competencyCode "CE18" ;
    ns1:competencyDescription "Aptitud para intervenir en la rehabilitación de edificios y en la restauración y conservación del patrimonio construido"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000045/2025-26/CE19> a ns1:Competency ;
    ns1:competencyCode "CE19" ;
    ns1:competencyDescription "Capacidad para elaborar manuales y planes de mantenimiento y gestionar su implantación en el edificio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000045/2025-26/CG04> a ns1:Competency ;
    ns1:competencyCode "CG04" ;
    ns1:competencyDescription "Llevar a cabo actividades técnicas de cálculo, mediciones, valoraciones, tasaciones y estudios de viabilidad económica; realizar peritaciones, inspecciones, análisis de patología y otros análogos y redactar los informes, dictámenes y documentos técnicos correspondientes; efectuar levantamientos de planos en solares y edificios."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000045/2025-26/CG07> a ns1:Competency ;
    ns1:competencyCode "CG07" ;
    ns1:competencyDescription "Dirigir y gestionar el uso, conservación y mantenimiento de los edificios, redactando los documentos técnicos necesarios."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000045/2025-26/CT01> a ns1:Competency ;
    ns1:competencyCode "CT01" ;
    ns1:competencyDescription "Trabajo en equipo. Equipos interdisciplinares"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000045/2025-26/CT02> a ns1:Competency ;
    ns1:competencyCode "CT02" ;
    ns1:competencyDescription "Comunicación oral y escrita. Capacidad de análisis y síntesis y de discusión de ideas propias. Capacidad de comunicación a través de la palabra y la imagen."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000045/2025-26/CT07> a ns1:Competency ;
    ns1:competencyCode "CT07" ;
    ns1:competencyDescription "Capacidad de búsqueda, análisis y selección de información"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000045/2025-26/CT16> a ns1:Competency ;
    ns1:competencyCode "CT16" ;
    ns1:competencyDescription "Resolución de problemas. Conflictos y crisis. Toma de decisiones"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000045/2025-26/CT17> a ns1:Competency ;
    ns1:competencyCode "CT17" ;
    ns1:competencyDescription "Habilidades en las relaciones interpersonales"@es .

