    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/65001009/2025-26/eventSchedule> ;
    schema:description """Gestión de empresas consta de dos bloques:
El bloque 1 trata de la empresa, concepto, tipos y estructuras. También de la estrategia empresarial, el comportamiento humano en la organización y la gestión de los recursos humanos.
El bloque 2 trata de los estados financieros de la empresa y los indicadores que analizan dichos estados financieros. También se estudian los métodos de selección de inversiones y el coste de capital."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/juan.pous%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/juan.pous%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/maria.scanales%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/marta.fernandezh%40upm.es> ;
    schema:name "Gestion de Empresas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001009/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Conocer y aplicar conocimientos de ciencias y tecnologías básicas a la práctica de la Ingeniería de los Recursos Energéticos, Combustibles y Explosivos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001009/2025-26/CG2> a ns1:Competency ;
    ns1:competencyCode "CG2" ;
    ns1:competencyDescription "Poseer capacidad para diseñar, analizar, calcular, proyectar, construir, mantener, conservar, explotar, desarrollar, implementar, gestionar y mejorar productos, sistemas y procesos en los distintos ámbitos de las Tecnologías Mineras, usando técnicas analíticas, computacionales o experimentales apropiadas, incluyendo la función de asesoría en estos campos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001009/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Aplicar los conocimientos adquiridos para identificar, formular y resolver problemas dentro de contextos amplios y multidisciplinarios, siendo capaces de integrar conocimientos, trabajando en equipos multidisciplinares."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001009/2025-26/CG5> a ns1:Competency ;
    ns1:competencyCode "CG5" ;
    ns1:competencyDescription "Saber comunicar los conocimientos y conclusiones, tanto de forma oral, escrita y gráfica, a públicos especializados y no especializados de un modo claro y sin ambigüedades."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001009/2025-26/CG6> a ns1:Competency ;
    ns1:competencyCode "CG6" ;
    ns1:competencyDescription "Poseer habilidades de aprendizaje que permitan continuar estudiando a lo largo de la vida para su adecuado desarrollo profesional."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001009/2025-26/CG9> a ns1:Competency ;
    ns1:competencyCode "CG9" ;
    ns1:competencyDescription "Organización y planificación en el ámbito de la empresa, y otras instituciones y organizaciones de proyectos y equipos humanos."@es .

