    ns1:inpersonHours "32 horas (41%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation """El desarrollo de los contenidos de la asignatura incluye el traslado de alumnado a las instalaciones hospitalarias, por lo cual es necesario contar con un seguro de cobertura del citado traslado para los estudiantes.
Por otra parte se recuerda que la participación de los docentes extranjeros, está condicionada a la existencia de recursos económicos.
El desarrollo de la asignatura permite una relación de ciertos contenidos con algunos de los Objetivos de Desarrollo Sostenible (ODS), en concreto con los ODS 3 y 5.
Los/as estudiante tendrán la posibilidad de participar en un Seminario Científico relativa a la temática de la asignatura en fecha a definir."""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "32 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/113000048/2025-26/eventSchedule> ;
    schema:description """La asignatura está destinada a que el/la estudiante conozca las bases científicas que rigen la relación entre el ejercicio físico y el embarazo, y se introduzca en un nuevo e interesante ámbito de la investigación científica, y al mismo tiempo sea capaz de recuperar, manejar y producir información científica en este tema.
Por las propias características y naturaleza de la asignatura, ésta tiene un desarrollo cíclico, es decir que no existe un proceso ordinal de los contenidos previstos, sino que pueden adelantarse o superponerse si un estricto orden establecido."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/rubenomar.barakat%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/rubenomar.barakat%40upm.es> ;
    schema:name "Actividad Fisica y Gestacion"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000048/2025-26/CB10> a ns1:Competency ;
    ns1:competencyCode "CB10" ;
    ns1:competencyDescription "Que los estudiantes posean las habilidades de aprendizaje que les permitan continuar estudiando de un modo que habrá de ser en gran medida autodirigido o autónomo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000048/2025-26/CB6> a ns1:Competency ;
    ns1:competencyCode "CB6" ;
    ns1:competencyDescription "Poseer y comprender conocimientos que aporten una base u oportunidad de ser originales en el desarrollo y/o aplicación de ideas, a menudo en un contexto de investigación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000048/2025-26/CB7> a ns1:Competency ;
    ns1:competencyCode "CB7" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en entornos nuevos o poco conocidos dentro de contextos más amplios (o multidisciplinares) relacionados con su área de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000048/2025-26/CE1> a ns1:Competency ;
    ns1:competencyCode "CE1" ;
    ns1:competencyDescription "Conocimiento de los aspectos más relevantes del conocimiento científico y su relación con las CC de la Actividad Física y del Deporte."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000048/2025-26/CE2> a ns1:Competency ;
    ns1:competencyCode "CE2" ;
    ns1:competencyDescription "Identificar los distintos tipos de investigación y su aplicación en las Ciencias de la Actividad física y del Deporte."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000048/2025-26/CE5> a ns1:Competency ;
    ns1:competencyCode "CE5" ;
    ns1:competencyDescription "Capacidad para encontrar nuevas formas de utilización de la Actividad física y el Deporte en la solución de los grandes problemas de la sociedad de nuestros días (igualdad de oportunidades, salud, marginación, cooperación, desarrollo)."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000048/2025-26/CE6> a ns1:Competency ;
    ns1:competencyCode "CE6" ;
    ns1:competencyDescription "Conocer las diferentes posibilidades de investigación de manera específica en cada uno de los diferentes ámbitos de las Ciencias de la Actividad Física y del Deporte."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000048/2025-26/CE7> a ns1:Competency ;
    ns1:competencyCode "CE7" ;
    ns1:competencyDescription "Iniciarse de forma concreta en un campo de investigación determinado."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000048/2025-26/CG6> a ns1:Competency ;
    ns1:competencyCode "CG6" ;
    ns1:competencyDescription "Capacidad para comunicarse y relacionarse en un ámbito científico en la lengua inglesa."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000048/2025-26/RA1> a ns1:LearningResult ;
    ns1:learningResultCode "RA1" ;
    ns1:learningResultDescription "Conocer los aspectos más relevantes del conocimiento científico y las bases de la investigación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000048/2025-26/RA2> a ns1:LearningResult ;
