    ns1:learningResultDescription "Conocer en profundidad las bases científicas que rigen el proceso de embarazo y parto."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000048/2025-26/RA45> a ns1:LearningResult ;
    ns1:learningResultCode "RA45" ;
    ns1:learningResultDescription "Conocer y manejar adecuadamente las diferentes posibilidades de investigación acerca de la influencia del ejercicio físico sobre el proceso de embarazo y parto."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000048/2025-26/RA46> a ns1:LearningResult ;
