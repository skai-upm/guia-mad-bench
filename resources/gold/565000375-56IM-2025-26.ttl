    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Tema 1: Generalidades. Acoplamientos. Tipos. Aplicaciones. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000375/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "4.2. Tema 7.- Cadenas. Introducción. Tipos. Cadena Galle. Ruedas para la cadena Galle Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000375/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "5. CAPÍTULO VI : PROYECTO DE MÁQUINAS"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000375/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "5.1. Tema 8: Proyecto de diseño de máquinas. Introducción. Objetivos y alcance. Planificación y programación. Metodologías avanzadas. Aplicación. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000375/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Tema 2: Embragues y frenos. Tipos. Embragues y frenos de tambor, de cinta, de disco, cónicos. Otros tipos de embragues y frenos. Elevación de la temperatura. Materiales de fricción. Aplicaciones. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000375/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "2. CAPÍTULO II : RESORTES"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000375/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "2.1. Tema 3: Resortes. Consideraciones generales. Materiales. Resortes helicoidales. Resortes cónicos. Resortes de torsión o espiral. Ballestas. Aplicaciones. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000375/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "3. CAPÍTULO III COJINETES DE FRICCIÓN"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000375/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "3.1. Tema 4: Lubricación hidrodinámica. Viscosidad. Ley de Newton. Tipos de lubricación. Ley de Petroff. Lubricación estable ó de película gruesa. Teoría de lubricación hidrodinámica. Aplicaciones. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000375/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "3.2. Tema 5: Diseño de cojinetes de fricción. Tipos. Lubricación al límite. Diseño de cojinetes de fricción. Gráficos de Raimondi y Boid. Temperatura media de funcionamiento del lubricante. Optimización. Cojinetes a presión. Cojinetes autosuficientes. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000375/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "4. CAPÍTULO IV: TRANSMISIONES FLEXIBLES"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000375/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "4.1. Tema 6.- Correas de transmisión. Correas y poleas. Estudio cinemático. Tensiones en los ramales. Cálculo de las correas. Correas trapeciales Sin subniveles"@es .

