    schema:name "Industria e Ingeniería de los Explosivos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65002036/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Conocer y aplicar conocimientos de ciencias y tecnologías básicas a la práctica de la Ingeniería de los Recursos Energéticos, Combustibles y Explosivos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65002036/2025-26/CG2> a ns1:Competency ;
    ns1:competencyCode "CG2" ;
    ns1:competencyDescription "Poseer capacidad para diseñar, analizar, calcular, proyectar, construir, mantener, conservar, explotar, desarrollar, implementar, gestionar y mejorar productos, sistemas y procesos en los distintos ámbitos de las Tecnologías Mineras, usando técnicas analíticas, computacionales o experimentales apropiadas, incluyendo la función de asesoría en estos campos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65002036/2025-26/CG4> a ns1:Competency ;
    ns1:competencyCode "CG4" ;
    ns1:competencyDescription "Comprender el impacto de la Ingeniería de los Recursos Energéticos, Combustibles y Explosivos en el medio ambiente, el desarrollo sostenible de la sociedad . desarrollando la capacidad para la realización de estudios de ordenación del territorio y de los aspectos medioambientales relacionados con los proyectos, plantas e instalaciones, en su ámbito."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65002036/2025-26/CG5> a ns1:Competency ;
    ns1:competencyCode "CG5" ;
    ns1:competencyDescription "Saber comunicar los conocimientos y conclusiones, tanto de forma oral, escrita y gráfica, a públicos especializados y no especializados de un modo claro y sin ambigüedades."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65002036/2025-26/F30> a ns1:Competency ;
    ns1:competencyCode "F30" ;
    ns1:competencyDescription "Fabricación, manejo y utilización de explosivos industriales y pirotécnicos. Ensayos de caracterización de sustancias explosivas. Transporte y distribución de explosivos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65002036/2025-26/F31> a ns1:Competency ;
    ns1:competencyCode "F31" ;
    ns1:competencyDescription "Control de la calidad de los materiales empleados."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65002036/2025-26/RA169> a ns1:LearningResult ;
    ns1:learningResultCode "RA169" ;
    ns1:learningResultDescription "Conocer los explosivos, sus mecanismos de reacción y propiedades generales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65002036/2025-26/RA170> a ns1:LearningResult ;
    ns1:learningResultCode "RA170" ;
    ns1:learningResultDescription "Conocer de forma elemental la composición, los procesos de fabricación, y las propiedades de los explosivos, mezclas explosivas y mezclas pirotécnicas más importantes."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65002036/2025-26/RA171> a ns1:LearningResult ;
    ns1:learningResultCode "RA171" ;
    ns1:learningResultDescription "Aplicar los criterios para la más adecuada selección de los explosivos para las distintas aplicaciones."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65002036/2025-26/RA172> a ns1:LearningResult ;
    ns1:learningResultCode "RA172" ;
    ns1:learningResultDescription "Aplicar los métodos de ejecución de las voladuras en banco y en túnel."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65002036/2025-26/RA173> a ns1:LearningResult ;
    ns1:learningResultCode "RA173" ;
    ns1:learningResultDescription "Conocer las normas de seguridad que deben tenerse en cuenta en la correcta utilización de los explosivos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65002036/2025-26/RA174> a ns1:LearningResult ;
    ns1:learningResultCode "RA174" ;
    ns1:learningResultDescription "Conocer los efectos medioambientales de la utilización de los explosivos y su control."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65002036/2025-26/RA175> a ns1:LearningResult ;
    ns1:learningResultCode "RA175" ;
    ns1:learningResultDescription "Capacidad para conocer, comprender y utilizar los principios de: Fabricación, manejo y utilización de explosivos industriales y pirotécnicos. Ensayos de caracterización de sustancias explosivas. Transporte y distribución de explosivos."@es .

