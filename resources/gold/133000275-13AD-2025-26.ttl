<https://guia-kg.skai.etsisi.upm.es/resource/133000275> a ns1:Course ;
    ns1:courseType "Optativa"@es ;
    ns1:courseYear 1 ;
    ns1:semester "Segundo semestre"@es ;
    schema:courseCode 133000275 ;
    schema:hasCourseInstance <https://guia-kg.skai.etsisi.upm.es/resource/133000275/2025-26> ;
    schema:name "Geospatial Technologies Applied To Forestry Production"@en,
        "Tecnologías Geoespaciales Aplicadas a la Producción Forestal"@es ;
    schema:numberOfCredits 3.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/133000275/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/133000275/2025-26/CB07>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000275/2025-26/CT01>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000275/2025-26/CT02>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000275/2025-26/CT06> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/133000275/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000275/2025-26/didactic_resource/2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000275/2025-26/didactic_resource/3> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/133000275/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/133000275/2025-26/RA168>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000275/2025-26/RA176>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000275/2025-26/RA198>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000275/2025-26/RA80> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/133000275/2025-26/syllabus> ;
    ns1:inpersonHours "64 horas (79%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation """La asignatura se relaciona con el ODS 15:Proteger, restablecer y promover el uso sostenible de los ecosistemas terrestres, gestionar los bosques de forma sostenible, luchar contra la desertificación, detener e invertir la degradación de las tierras y poner freno a la pérdida de la diversidad biológica
LAS COMPETENCIAS Y LOS RESULTADOS DE APRENDIZAJE DE ESTA ASIGNATURA SON LOS ACORDES CON LA MEMORIA VERIFICA DEL TÍTULO."""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "66 horas y 30 minutos"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/133000275/2025-26/eventSchedule> ;
    schema:description """El objetivo de esta asignatura es proporcionar a los estudiantes conocimientos y habilidades en el uso de tecnologías geoespaciales aplicadas a la producción forestal, con un enfoque práctico en el uso de Sistemas de Información Geográfica (SIG), teledetección, análisis de imágenes con ERDAS y aplicación de drones para la gestión y planificación forestal.
Al finalizar el curso, los estudiantes serán capaces de:
Aplicar SIG y teledetección en la producción y gestión forestal.
Manejar software para procesar imágenes satelitales y datos de drones.
Utilizar datos obtenidos con drones utilizando diferentes sensores cámara térmica, cámara multiespectral, y datos de inventario con GNSS.
Implementar modelos de simulación y predicción de recursos y producción forestal basados en datos geoespaciales."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/alejandra.ezquerra%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/alejandra.ezquerra%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/enrique.perez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/rosario.contreras.alonso%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/tomas.herrero.tejedor%40upm.es> ;
    schema:name "Tecnologías Geoespaciales Aplicadas a la Producción Forestal"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000275/2025-26/CB07> a ns1:Competency ;
    ns1:competencyCode "CB07" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en entornos nuevos o poco conocidos dentro de contextos más amplios (o multidisciplinares) relacionados con su área de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000275/2025-26/CT01> a ns1:Competency ;
    ns1:competencyCode "CT01" ;
    ns1:competencyDescription "Habilidades de comunicación escrita y oral"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000275/2025-26/CT02> a ns1:Competency ;
    ns1:competencyCode "CT02" ;
    ns1:competencyDescription "Integrar los conocimientos previos (propios de grado) de manera crítica y relacionada de forma que se puedan aplicar al estudio de situaciones reales y a la propuesta de alternativas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000275/2025-26/CT06> a ns1:Competency ;
    ns1:competencyCode "CT06" ;
    ns1:competencyDescription "Búsqueda bibliográfica, análisis de documentación y tratamiento de la información procedente de diversas fuentes y de su análisis y síntesis aplicándola a la resolución de problemas complejos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000275/2025-26/RA168> a ns1:LearningResult ;
    ns1:learningResultCode "RA168" ;
    ns1:learningResultDescription "Saber cono aplicar los conocimientos adquiridos a situaciones diferentes"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000275/2025-26/RA176> a ns1:LearningResult ;
    ns1:learningResultCode "RA176" ;
    ns1:learningResultDescription "Ser capaz de manejar con destreza herramientas de teledetección para obtener cartografía útil para la planificación territorial, el paisajismo, la ordenación de montes, la ordenación hidrologíco"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000275/2025-26/RA198> a ns1:LearningResult ;
    ns1:learningResultCode "RA198" ;
    ns1:learningResultDescription "Calcular la huella de carbono de los productos y servicios forestales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000275/2025-26/RA80> a ns1:LearningResult ;
    ns1:learningResultCode "RA80" ;
    ns1:learningResultDescription "Tener la capacidad de reunir e interpretar datos del medio físico de los sistemas forestales que son condicionantes de las actividades propias de la ingeniería de montes"@es .

