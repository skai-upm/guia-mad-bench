    ns1:numberOfCredits 2.0 ;
    ns1:otherInformation "La docencia de esta asignatura esta concentrada en 8 sesiones de 2.5 horas. Para la mejora de la calidad de la docencia impartida se ha optado por no impartir 2 sesiones juntas por un mismo profesor y una misma temática."@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
