    ns1:numberOfCredits 6.0 ;
    ns1:otherInformation """En actividades prácticas el profesor podrá incluir clases prácticas usando el paquete estadístico informático
STATGRAPHICS, clases de resolución de problemas en grupo y clases de ejercicios individuales.
LAS COMPETENCIAS Y LOS RESULTADOS DE APRENDIZAJE DE ESTA ASIGNATURA SON CONFORMES CON LA MEMORIA VERIFICA DEL TÍTULO"""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "71 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/135005203/2025-26/eventSchedule> ;
    schema:description "Esta asignatura pretende enseñar a los alumnos los fundamentos de la estadística y del cálculo de probabilidades, tanto desde un punto de vista teórico como práctico. Se enseñará a los alumnos a extraer información de un conjunto de datos desde un punto de vista estadístico, por lo que les servirá para sacar conclusiones de los datos obtenidos en experimentos estudiados.."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/ana.martinez%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/ana.martinez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/angel.castellanos%40upm.es> ;
    schema:name "Estadistica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005203/2025-26/CB01> a ns1:Competency ;
    ns1:competencyCode "CB01" ;
    ns1:competencyDescription "Que los estudiantes hayan demostrado poseer y comprender conocimientos en un área de estudio que parte de la base de la educación secundaria general, y se suele encontrar a un nivel que, si bien se apoya en libros de texto avanzados, incluye también algunos aspectos que implican conocimientos procedentes de la vanguardia de su campo de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005203/2025-26/CE%201.05> a ns1:Competency ;
    ns1:competencyCode "CE 1.05" ;
    ns1:competencyDescription "Profundizar en el conocimiento de las herramientas matemáticas necesarias para la adecuada comprensión y modelización de los fenómenos que tienen lugar en la naturaleza, así como para el desarrollo de las técnicas necesarias para la gestión del Medio Natural."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005203/2025-26/CE%201.06> a ns1:Competency ;
    ns1:competencyCode "CE 1.06" ;
    ns1:competencyDescription "Aplicar y validar modelos estadísticos que resuelvan los problemas que se plantean en la gestión técnica del Medio Natural."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005203/2025-26/CE%201.07> a ns1:Competency ;
    ns1:competencyCode "CE 1.07" ;
    ns1:competencyDescription "Ser capaz de diseñar y realizar experimentos apropiados, interpretar los datos y extraer conclusiones."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005203/2025-26/CE%201.24> a ns1:Competency ;
    ns1:competencyCode "CE 1.24" ;
    ns1:competencyDescription "Saber utilizar programas informáticos en el almacenamiento y procesamiento de datos que permita la modelización de las complejas estructuras y procesos existentes en el Medio Natural, de manera que se facilite su gestión."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005203/2025-26/CE%201.32> a ns1:Competency ;
    ns1:competencyCode "CE 1.32" ;
    ns1:competencyDescription "Ser capaz de aclarar la relevancia y utilidad de la teoría y las habilidades aprendidas en el contexto académico sobre los acontecimientos del mundo real."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005203/2025-26/CT04> a ns1:Competency ;
    ns1:competencyCode "CT04" ;
    ns1:competencyDescription "Aplicar los conocimientos tecnológicos necesarios para desenvolverse adecuadamente y afrontar los retos que la sociedad impone en el quehacer profesional, empleando la informática."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005203/2025-26/RA29> a ns1:LearningResult ;
    ns1:learningResultCode "RA29" ;
    ns1:learningResultDescription "Manejar la información estadística de forma tabular, numérica y graficamente, para sintetizarla"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005203/2025-26/RA30> a ns1:LearningResult ;
    ns1:learningResultCode "RA30" ;
    ns1:learningResultDescription "Plantear y validar modelos estadísticos que resuelvan problemas que puedan plantearse en la ingeniería"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005203/2025-26/RA31> a ns1:LearningResult ;
    ns1:learningResultCode "RA31" ;
    ns1:learningResultDescription "Conocer como tomar una muestra representativa de una población y a partir de ellla predecir parámetros de toda la población"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005203/2025-26/RA32> a ns1:LearningResult ;
    ns1:learningResultCode "RA32" ;
    ns1:learningResultDescription "Aplicar las técnicas estadísticas elementales en la resolución de problemas prácticos concretos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005203/2025-26/RA33> a ns1:LearningResult ;
    ns1:learningResultCode "RA33" ;
    ns1:learningResultDescription "Manejar el paquete STATGRAPHICS y una hoja de cálculo para resolver problemas planteados."@es .

