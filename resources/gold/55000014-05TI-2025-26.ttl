<https://guia-kg.skai.etsisi.upm.es/resource/55000014/2025-26/RA115> a ns1:LearningResult ;
    ns1:learningResultCode "RA115" ;
    ns1:learningResultDescription "Relacionar velocidades, aceleraciones y trayectorias de sistemas en movimiento."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000014/2025-26/RA116> a ns1:LearningResult ;
    ns1:learningResultCode "RA116" ;
    ns1:learningResultDescription "Obtener las expresiones de la energía cinética, cantidad de movimiento, momento cinético y otras magnitudes similares en función de las rotaciones y velocidades de algunos puntos de un sistema."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000014/2025-26/RA117> a ns1:LearningResult ;
    ns1:learningResultCode "RA117" ;
    ns1:learningResultDescription "Aplicar las condiciones de la Estática para obtener las posiciones de equilibrio de un sistema y las fuerzas de reacción en el mismo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000014/2025-26/RA118> a ns1:LearningResult ;
    ns1:learningResultCode "RA118" ;
    ns1:learningResultDescription "Deducir las ecuaciones que ligan la evolución de un sistema con los conjuntos de fuerzas aplicadas sobre el mismo por un lado y con las de ligadura por el otro."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000014/2025-26/RA119> a ns1:LearningResult ;
    ns1:learningResultCode "RA119" ;
    ns1:learningResultDescription "Determinar las transformaciones que siguen los conjuntos de fuerzas (multiplicación, conversión de pares a fuerzas, etc.) cuando se aplican a un sistema."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000014/2025-26/RA120> a ns1:LearningResult ;
    ns1:learningResultCode "RA120" ;
    ns1:learningResultDescription "Incluir motores en los sistemas mecánicos, trabajando con sus curvas de par"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000014/2025-26/RA121> a ns1:LearningResult ;
    ns1:learningResultCode "RA121" ;
    ns1:learningResultDescription "Formular las relaciones entre fuerzas aplicadas y el movimiento de un sistema desde las perspectivas vectorial, lagrangiana y hamiltoniana."@es .

