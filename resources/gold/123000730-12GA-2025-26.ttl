    schema:numberOfCredits 4.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/123000730/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/123000730/2025-26/CE10>,
