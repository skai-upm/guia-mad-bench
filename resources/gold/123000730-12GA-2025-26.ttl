    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/123000730/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/123000730/2025-26/RA1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/123000730/2025-26/RA2> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/123000730/2025-26/syllabus> ;
    ns1:inpersonHours "91 horas (84.3%)"@es ;
    ns1:numberOfCredits 4.0 ;
    ns1:otherInformation """La asignatura se relaciona con los ODS 3, 4, 9, y 11.
En las clases se comenta a los estudiantes la posibilidad de participar en alguna protocomunidad o comunidad EELISA, e incluso desarrollar su TFM en este ámbito."""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "91 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/123000730/2025-26/eventSchedule> ;
    schema:description "En esta asignatura se trata el control metrológico dimensional de instrumental geomático a través de su calibración mediante procedimientos técnicos y en condiciones que cumplan los requisitos técnicos y de gestión de un laboratorio acreditado."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/enrique.priego%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/emma.barrio%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/enrique.priego%40upm.es> ;
    schema:name "Control Metrológico Dimensional"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/123000730/2025-26/CE10> a ns1:Competency ;
    ns1:competencyCode "CE10" ;
    ns1:competencyDescription "Aplicar los métodos existentes de diseño de control de infraestructuras de ingeniería civil y arquitectura, así como su desarrollo con equipos multidisciplinares."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/123000730/2025-26/CG4> a ns1:Competency ;
    ns1:competencyCode "CG4" ;
    ns1:competencyDescription "Analizar, evaluar y sintetizar, de manera crítica, ideas nuevas y complejas a partir de datos geoespaciales, generando informes técnicos y/o de investigación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/123000730/2025-26/CT4> a ns1:Competency ;
    ns1:competencyCode "CT4" ;
    ns1:competencyDescription "Ser capaz de definir el curso de acción y los procedimientos requeridos para alcanzar los objetivos y metas, estableciendo lo que hay que hacer para llegar al estado final deseado (Organización y planificación)."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/123000730/2025-26/CT6> a ns1:Competency ;
    ns1:competencyCode "CT6" ;
    ns1:competencyDescription "Ser capaz de organizar y desarrollar una planificación de las actividades profesionales o de investigación considerando los recursos humanos, materiales y económicos y los condicionantes temporales (Gestión económica y administrativa)."@es .

