    schema:hasCourseInstance <https://guia-kg.skai.etsisi.upm.es/resource/133000185/2025-26> ;
    schema:name "Industry 40"@en,
        "Industria 40"@es ;
    schema:numberOfCredits 2.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/133000185/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/133000185/2025-26/CE04>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000185/2025-26/CG04> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/133000185/2025-26/didactic_resource/1> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/133000185/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/133000185/2025-26/RA9> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/133000185/2025-26/syllabus> ;
    ns1:inpersonHours "20 horas (38.5%)"@es ;
    ns1:numberOfCredits 2.0 ;
    ns1:otherInformation ""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "35 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/133000185/2025-26/eventSchedule> ;
    schema:description "Esta asignatura está orientada a contextualizar las Tecnologías de la Industria 4.0 en el marco de la Economia Circular, en principio se realizará un pequeño recorrido descriptivo por las citadas tecnología, comentando las diferencias de enfoque con las tecnologías preexistentes, y destacando la oportunidad de su aplicación en el contexto del ciclo de vida de los productos y de los sistemas productivos. Se realizarán dos ejercicios prácticos con programas informáticos disponibles en el portfolio de UPM que permitirá a los alumnos identificar las mejoras de productividad que pueden derivarse de su uso y su adecuación en dos etapas diferentes del ciclo de vida."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/juandejuanes.marquez%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/juandejuanes.marquez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/luisa.mtzmuneta%40upm.es> ;
    schema:name "Industria 40"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000185/2025-26/CE04> a ns1:Competency ;
    ns1:competencyCode "CE04" ;
    ns1:competencyDescription "El alumno conocerá las nuevas tecnologías de la industria 4.0 y desarrollará mejoras en el diseño de los productos industriales.en el marco de la economía circular"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000185/2025-26/CG04> a ns1:Competency ;
    ns1:competencyCode "CG04" ;
    ns1:competencyDescription "El alumno podrá aplicar los principios de economía circular al ciclo de vida de los productos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000185/2025-26/RA9> a ns1:LearningResult ;
    ns1:learningResultCode "RA9" ;
    ns1:learningResultDescription "Adquirir visión integradora de las tecnologías de la industria 4.0 para mejorar la eficiencia de los procesos"@es .

