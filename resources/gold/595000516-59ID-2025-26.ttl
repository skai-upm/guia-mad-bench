    schema:name "Fundamentos de Gestión Empresarial"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000516/2025-26/CB02> a ns1:Competency ;
    ns1:competencyCode "CB02" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar sus conocimientos a su trabajo o vocación de una forma profesional y posean las competencias que suelen demostrarse por medio de la elaboración y defensa de argumentos y la resolución de problemas dentro de su área de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000516/2025-26/CB03> a ns1:Competency ;
    ns1:competencyCode "CB03" ;
    ns1:competencyDescription "Que los estudiantes tengan la capacidad de reunir e interpretar datos relevantes (normalmente dentro de su área de estudio) para emitir juicios que incluyan una reflexión sobre temas relevantes de índole social, científica o ética"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000516/2025-26/CB04> a ns1:Competency ;
    ns1:competencyCode "CB04" ;
    ns1:competencyDescription "Que los estudiantes puedan transmitir información, ideas, problemas y soluciones a un público tanto especializado como no especializado"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000516/2025-26/CE03> a ns1:Competency ;
    ns1:competencyCode "CE03" ;
    ns1:competencyDescription "Que los estudiantes comprendan la estructura y funcionamiento de organizaciones empresariales y de emprendimiento a un nivel que les permita desarrollar nuevos modelos de negocio basados en la economía de los datos, teniendo en cuenta aspectos de toma de decisiones y negociación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000516/2025-26/CG03> a ns1:Competency ;
    ns1:competencyCode "CG03" ;
    ns1:competencyDescription "Ser capaz de explicar de forma oral o escrita las soluciones planteadas para la resolución de un problema."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000516/2025-26/RA029> a ns1:LearningResult ;
    ns1:learningResultCode "RA029" ;
    ns1:learningResultDescription "Comprender el concepto de empresa y su entorno económico en distintos sectores de actividad (eHealth, business intelligence, smart cities, etc.)."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000516/2025-26/RA030> a ns1:LearningResult ;
    ns1:learningResultCode "RA030" ;
    ns1:learningResultDescription "Conocer los términos, herramientas y procesos de decisión asociados a la dirección de la empresa y a la gestión de sus principales áreas funcionales: económico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000516/2025-26/RA031> a ns1:LearningResult ;
    ns1:learningResultCode "RA031" ;
    ns1:learningResultDescription "Comprender el impacto de la tecnología y los procesos de transformación digital en la dirección y gestión de las empresas."@es .

