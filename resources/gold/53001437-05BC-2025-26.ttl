    ns1:learningResultCode "RA170" ;
    ns1:learningResultDescription "Entender las implicaciones ambientales, económicas y sociales de los sistemas energéticos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001437/2025-26/RA38> a ns1:LearningResult ;
    ns1:learningResultCode "RA38" ;
    ns1:learningResultDescription "Seleccionar los analizadores adecuados para el control de un proceso químico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001437/2025-26/RA60> a ns1:LearningResult ;
    ns1:learningResultCode "RA60" ;
    ns1:learningResultDescription "El alumno será capaz de realizar un diseño preliminar de un proceso químico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001437/2025-26/RA67> a ns1:LearningResult ;
    ns1:learningResultCode "RA67" ;
    ns1:learningResultDescription "Ser capaz de realizar la integración energética de un proceso químico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001437/2025-26/RA89> a ns1:LearningResult ;
    ns1:learningResultCode "RA89" ;
    ns1:learningResultDescription "El alumno es capaz de valorar los efectos positivos y negativos de la solución a un problema de ingeniería que afectan a la sociedad, la economía y el medio ambiente."@es .

