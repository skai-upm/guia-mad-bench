    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Objetivos, normas y conocimientos fundamentales del Dibujo Industrial"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000005/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. El Dibujo Industrial como lenguaje de comunicación preciso, claro y universal de la información técnica para representar una pieza. Sin subniveles"@es .

