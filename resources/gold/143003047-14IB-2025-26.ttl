    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/143003047/2025-26/syllabus> ;
    ns1:inpersonHours "60 horas (46.2%)"@es ;
    ns1:numberOfCredits 5.0 ;
    ns1:otherInformation ""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "60 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/143003047/2025-26/eventSchedule> ;
    schema:description """La asignatura se centra en el análisis de los sistemas realimentados y en el diseño de los algoritmos de control cuando se ejecutan en un microprocesador.
Discretizado el modelo lineal del sistema a controlar, se fijan los requisitos de comportamiento del sistema realimentado, y se comprueba su cumplimiento.
En el caso de que no se cumplan los requisitos, se diseña un compensador o controlador discreto que obligue a que el sistema realimentado se comporte, en el dominio del tiempo y en el dominio de la frecuencia, adecuadamente."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/mariano.asensio%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/mariano.asensio%40upm.es> ;
    schema:name "Sistemas de Control en Tiempo Discreto"@es .

