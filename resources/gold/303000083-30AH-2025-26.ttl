    schema:activitiesWorkload "120%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/303000083/2025-26/eventSchedule> ;
    schema:description """Description: this course aims to provide the student with the necessary tools to analyse and describe the behaviour of the solutions of ordinary differential equations that arise from modelling and applications. The tools are analytic, on one part, but also numeric.

Previous knowledge: the student is supposed to be familiar with the theory of ODEs as well as the qualitative behaviour of dynamical systems. Those students that come from the degree in mathematics (Grado en Matemáticas) will have acquired this in Ecuaciones Diferenciales Ordinarias I and II. Also a minimum familiarity with numerical tools will be expected. Again, those students from the degree in mathematics will have acquired this knowledge in Cálculo Numérico I and, especially, II.

Links to other master courses: this course will provide in a sense a complementary practical or applied vision of the dynamical systems theory and topics that correspond to ?Sistemas dinámicos avanzados S1-I?. The fact that both will be taught on the first semestrer may enhance a combined complementarity."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/s.jimenez%40upm.es> ;
    schema:inLanguage "Inglés"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/s.jimenez%40upm.es> ;
    schema:name "Ordinary Differential Equations And Applications"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000083/2025-26/CO1> a ns1:Competency ;
    ns1:competencyCode "CO1" ;
    ns1:competencyDescription "Conocer los principales métodos y teorías matemáticas, próximos a la frontera del conocimiento, que permitan tener una amplia perspectiva en al menos tres de las siguientes áreas: Análisis Matemático, Métodos Numéricos, Ecuaciones Diferenciales, Estadística y Ciencia de Datos, Álgebra, Geometría y Topología. TIPO: Conocimientos o contenidos./ To know the main mathematical methods and theories, close to the frontier of knowledge, that provide a broad perspective in at least three of the following areas: Mathematical Analysis, Numerical Methods, Differential Equations, Statistics and Data Science, Algebra, Geometry, and Topology.Type: Knowledge"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000083/2025-26/CO2> a ns1:Competency ;
    ns1:competencyCode "CO2" ;
    ns1:competencyDescription "Conocer demostraciones matemáticas avanzadas que permitan relacionar de una manera rigurosa las hipótesis con las conclusiones en al menos tres de las áreas relacionadas en el CO1.TIPO: Conocimientos o contenidos/ To understand advanced mathematical proofs that rigorously relate hypotheses to conclusions in at least three of the areas mentioned in CO1.Type:Knowledge"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000083/2025-26/CO3> a ns1:Competency ;
    ns1:competencyCode "CO3" ;
    ns1:competencyDescription "Conocer diversas aplicaciones de las teorías matemáticas y su modelización en otros entornos o disciplinas que permitan adaptar los conocimientos matemáticos a nuevos problemas.TIPO: Conocimientos o contenidos/ To understand various applications of mathematical theories and their modeling in different contexts or disciplines, allowing the adaptation of mathematical knowledge to new problems. Type: Knowledge"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000083/2025-26/CP1> a ns1:Competency ;
    ns1:competencyCode "CP1" ;
    ns1:competencyDescription "Utilizar programas informáticos especializados como laboratorio para diseñar, construir o validar hipótesis científicas en.alguno de los ámbitos de las matemáticas. TIPO: Competencias."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000083/2025-26/CP2> a ns1:Competency ;
    ns1:competencyCode "CP2" ;
    ns1:competencyDescription "Ser capaz de trabajar en equipos multidisciplinares que involucren conocimientos matemáticos avanzados en áreas teóricas o aplicadas.TIPO: Competencias."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000083/2025-26/CP3> a ns1:Competency ;
    ns1:competencyCode "CP3" ;
    ns1:competencyDescription "Seleccionar y comprender la bibliografía científica sobre un tema concreto, extrayendo la información relevante. TIPO:Competencias."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000083/2025-26/CP4> a ns1:Competency ;
    ns1:competencyCode "CP4" ;
    ns1:competencyDescription "Comunicar de forma oral y escrita conocimientos y conclusiones científicas, valorando diferentes interpretaciones en públicos especializados y no especializados de una manera clara y rigurosa. TIPO: Competencias"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000083/2025-26/CP5> a ns1:Competency ;
    ns1:competencyCode "CP5" ;
    ns1:competencyDescription "Complementar la formación matemática de manera autónoma en avances específicos de las Matemáticas, seleccionando la bibliografía adecuada y planteando cuestiones de interés. TIPO: Competencias"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000083/2025-26/HA1> a ns1:Competency ;
    ns1:competencyCode "HA1" ;
    ns1:competencyDescription "Aplicar los conocimientos matemáticos adquiridos a la resolución de problemas nuevos de una manera crítica, generando hipótesis de trabajo claras, definiciones precisas, nuevos enfoques con fundamento matemático y soluciones originales. TIPO: Habilidades o destrezas/ To apply acquired mathematical knowledge to solving new problems critically, generating clear working hypotheses, precise definitions, new mathematically grounded approaches, and original solutions.Type: Skills"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000083/2025-26/HA2> a ns1:Competency ;
    ns1:competencyCode "HA2" ;
    ns1:competencyDescription "Ser capaz de abstraer y detectar las dificultades relevantes ante problemas complejos para poder plantearlos correctamente y resolverlos con técnicas matemáticas avanzadas. TIPO: Habilidades o destrezas/ To be able to abstract and identify relevant difficulties in complex problems in order to correctly formulate and solve them using advanced mathematical techniques. Type: Skills"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000083/2025-26/HA3> a ns1:Competency ;
    ns1:competencyCode "HA3" ;
    ns1:competencyDescription "Dominar el rigor matemático en las técnicas de demostración aprendidas para su posterior uso en el enunciado y demostraciones de nuevos teoremas. TIPO: Habilidades o destrezas/ To master mathematical rigor in the learned proof techniques for their later use in formulating and proving new theorems.Type: Skills"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000083/2025-26/HA4> a ns1:Competency ;
    ns1:competencyCode "HA4" ;
    ns1:competencyDescription "Poseer destreza para proponer, validar e interpretar modelos matemáticos de diferente dificultad en situaciones reales complejas, utilizando las herramientas matemáticas más adecuadas a los fines que se persigan, y valorando las hipótesis y conclusiones asociadas a cada nivel de dificultad del modelo. TIPO: Habilidades o destrezas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000083/2025-26/HA5> a ns1:Competency ;
    ns1:competencyCode "HA5" ;
    ns1:competencyDescription "Adaptar teorías y técnicas matemáticas avanzadas al estudio de problemas en otros ámbitos con criterio científico para valorar su repercusión y formular las hipótesis adecuadas. TIPO: Habilidades o destrezas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000083/2025-26/HA6> a ns1:Competency ;
    ns1:competencyCode "HA6" ;
    ns1:competencyDescription "Interpretar adecuadamente la relevancia de nuevos resultados en Matemáticas, su aplicabilidad en situaciones particulares donde pudieran suponer nuevos avances y su relación con los resultados existentes. TIPO: Habilidades o destrezas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000083/2025-26/RA21> a ns1:LearningResult ;
    ns1:learningResultCode "RA21" ;
    ns1:learningResultDescription "Entender el análisis de estabilidad para modelos dinámicos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000083/2025-26/RA22> a ns1:LearningResult ;
    ns1:learningResultCode "RA22" ;
    ns1:learningResultDescription "to be able to analyse and describe the behaviour of the solutions of ordinary differential equations that arise from modelling and applications, using both analytical and computational tools"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000083/2025-26/RA5> a ns1:LearningResult ;
    ns1:learningResultCode "RA5" ;
    ns1:learningResultDescription "Desarrollar trabajos autónomos o en grupo, integrando bibliografía científica y, en su caso, métodos computacionales para profundizar en los contenidos de la asignatura o abordar problemas complejos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000083/2025-26/didactic_resource/1> a ns1:DidacticResource ;
    ns1:bibliographyDescription "A general book to cover most of the course"@es ;
    ns1:bibliographyTitle "M. W. Hirsch, S. Smale and R. L. Devaney. Differential Equations, Dynamical Systems, and an Introduction to Chaos. Third edition, Elsevier, 2013, https://doi.org/10.1016/B978-0-12- 382010-5.00057-9."@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000083/2025-26/didactic_resource/10> a ns1:DidacticResource ;
    ns1:bibliographyDescription "A very good reference for bifurcations."@es ;
    ns1:bibliographyTitle "D.K. Arrowsmith, C.M. PLace. An introduction to dynamical systems. Cambridge University Press, 1994."@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000083/2025-26/didactic_resource/11> a ns1:DidacticResource ;
    ns1:bibliographyDescription """This book is a classic on bifurcations. Although the programs that come with it are nowadays obsolete it remains
a very interesting text."""@es ;
    ns1:bibliographyTitle "J. Hale, H. Koçak. Dynamics and Bifurcations. Springer, 1991, https://doi.org/10.1007/978- 1-4612-4426-4."@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000083/2025-26/didactic_resource/12> a ns1:DidacticResource ;
    ns1:bibliographyDescription "A general book that may also be used for the whole course. Especially interesting for the applications it presents."@es ;
    ns1:bibliographyTitle "E. Ott. Chaos in Dynamical Systems. Cambridge University Press, 2002, https://doi.org/10.1017/CBO9780511803260."@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000083/2025-26/didactic_resource/13> a ns1:DidacticResource ;
    ns1:bibliographyDescription "Same as the previous one (Ott), especially interesting for all the applications it presents."@es ;
    ns1:bibliographyTitle "S. Strogatz. Nonlinear Dynamics and Chaos: With Applications to Physics, Biology, Chemistry and Engineering. Second edition, Westview Press, 2015, https://doi.org/10.1201/9780429492563 ."@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000083/2025-26/didactic_resource/14> a ns1:DidacticResource ;
    ns1:bibliographyDescription "This book provides ready tools to help the analysis of the properties of the equations, using the symbolic programme Maple."@es ;
    ns1:bibliographyTitle "S. Lynch, Dynamical Systems with Applications using Maple. Second Edition, Birkhäuser 2010, https://doi.org/10.1007/978-0-8176-4605-9."@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000083/2025-26/didactic_resource/15> a ns1:DidacticResource ;
    ns1:bibliographyDescription "Since this is not a numerical methods course, supporting material such as programs to analyse or simulate will either be provided by the teacher or be of free distribution. Languages: C, Matlab, Maple and Python."@es ;
    ns1:bibliographyTitle "Other material provided by the teacher"@es ;
    ns1:bibliographyType "Otros"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000083/2025-26/didactic_resource/16> a ns1:DidacticResource ;
    ns1:bibliographyDescription "Presentation notes and slides by the teacher."@es ;
    ns1:bibliographyTitle "Salvador Jiménez"@es ;
    ns1:bibliographyType "Otros"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000083/2025-26/didactic_resource/17> a ns1:DidacticResource ;
    ns1:bibliographyDescription "Some research papers, by different authors and on specific topics, provided by the teacher."@es ;
    ns1:bibliographyTitle "Research papers"@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000083/2025-26/didactic_resource/2> a ns1:DidacticResource ;
    ns1:bibliographyDescription """A general book and a very good
reference for all students to follow."""@es ;
    ns1:bibliographyTitle "C. Chicone. Ordinary Differential Equations with Applications. Texts in Applied Mathematics, vol 34. Springer, 2024, https://doi.org/10.1007/978-3-031-51652-8."@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000083/2025-26/didactic_resource/3> a ns1:DidacticResource ;
    ns1:bibliographyDescription "Covers all numerical methods with the exception of stiff equation."@es ;
    ns1:bibliographyTitle "E. Hairer, G. Wanner, S. P. Nørsett. Solving Ordinary Differential Equations I. Springer 1993, https://doi.org/10.1007/978-3-540-78862-1."@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000083/2025-26/didactic_resource/4> a ns1:DidacticResource ;
    ns1:bibliographyDescription "numerical methods, specific to stiff problems."@es ;
    ns1:bibliographyTitle "E. Hairer, G. Wanner. Solving Ordinary Differential Equations II. Springer, 1996, https://doi.org/10.1007/978-3-642-05221-7."@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000083/2025-26/didactic_resource/5> a ns1:DidacticResource ;
    ns1:bibliographyDescription "A perfect reference book for symplectic or geometric numerical methods for problems with symmetries and conservation laws. Especially relevant for Hamiltonian systems."@es ;
    ns1:bibliographyTitle "E. Hairer, G. Wanner, Ch. Lubich. Geometric Numerical Integration. Springer, 2006 , https:// doi.org/10.1007/3-540-30666-8."@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000083/2025-26/didactic_resource/6> a ns1:DidacticResource ;
    ns1:bibliographyDescription "A basic and complete book to simulate dynamical systems and their evolution equations."@es ;
    ns1:bibliographyTitle "A. Stuart, A.R. Humphries, Dynamical systems and numerical analysis, Cambridge, 1996."@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000083/2025-26/didactic_resource/7> a ns1:DidacticResource ;
    ns1:bibliographyDescription """A basic book that presents conservative numerical methods and its generalizations. Although it is in
Spanish it can be used by non-Spanish readers with the help of the teacher."""@es ;
    ns1:bibliographyTitle "L. Vázquez, S. Jiménez, C. Aguirre, P.J. Pascual. Métodos numéricos para la Física y la Ingeniería. McGrawHill, 2009."@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000083/2025-26/didactic_resource/8> a ns1:DidacticResource ;
    ns1:bibliographyDescription "Very complete book. Also, a very good reference for the structure of the phase space and the analysis of the stable, unstable and center manifolds. Topics 2 and 3 of the course."@es ;
    ns1:bibliographyTitle "L. Perko. Differential Equations and Dynamical Systems. Third edition. Springer, 2001, https://doi.org/10.1007/978-1-4613-0003-8."@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000083/2025-26/didactic_resource/9> a ns1:DidacticResource ;
    ns1:bibliographyDescription "Similar to the previous one (Perko) but perhaps a more demanding level."@es ;
    ns1:bibliographyTitle "S. Wiggins. Introduction to Applied Nonlinear Dynamical Systems and Chaos. Second edition. Springer, 2003, https://doi.org/10.1007/b97481."@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000083/2025-26/evaluation> a ns1:EvaluationSystem ;
    ns1:evaluationDescription """The evaluation will be graded according to the following criteria:
- the originality of the work,
- the good execution, exposition, reasoned achievement and completeness of the requested demonstrations or analyses,
- the proper use of the computational tools,
- the proper presentation of the results,
- the adequacy of the work to the specifications given in the statements."""@es ;
