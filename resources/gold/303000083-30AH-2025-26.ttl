<https://guia-kg.skai.etsisi.upm.es/resource/303000083/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Introduction and fundamentals"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000083/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Review of basic properties of ODE and IVP. Existence, unicity and regularity. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000083/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "2.4. Invariant manifolds. Attraction domains. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000083/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "3. Bifurcations and chaos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000083/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "3.1. Structural stability and bifurcations. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000083/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "3.2. Characterisation of chaos. Lyapunov exponents, Lagrangian descriptors, Melnikov method. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000083/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "3.3. Chaotic models. Intermittency and the onset of chaos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000083/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "4. Applications"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000083/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "4.1. Introduction to control of nonlinear systems. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000083/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "4.2. Coupled oscillators. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000083/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "4.3. Growth models in biology Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000083/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "4.4. Particle trapping. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000083/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Review of linear autonomous systems. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000083/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "1.3. Periodic linear systems. Floquet theory. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000083/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "1.4. Singular perturbative problems and multiple-time expansion. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000083/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "1.5. Review of numerical methods. Stiff equations. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000083/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "2. Nonlinear systems"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000083/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "2.1. Trayectories. Phase diagrams. Poincaré and stroboscopic maps. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000083/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "2.2. Critical points and Lyapunov stability. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000083/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "2.3. Periodic orbits and limit cycles. Stability. Sin subniveles"@es .

