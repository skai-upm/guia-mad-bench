        <https://guia-kg.skai.etsisi.upm.es/resource/203000005/2025-26/RA25>,
        <https://guia-kg.skai.etsisi.upm.es/resource/203000005/2025-26/RA26>,
        <https://guia-kg.skai.etsisi.upm.es/resource/203000005/2025-26/RA27>,
