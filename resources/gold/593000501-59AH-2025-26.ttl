    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/593000501/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/593000501/2025-26/RA21>,
        <https://guia-kg.skai.etsisi.upm.es/resource/593000501/2025-26/RA22>,
