        <https://guia-kg.skai.etsisi.upm.es/resource/593000501/2025-26/RA24> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/593000501/2025-26/syllabus> ;
    ns1:inpersonHours "46 horas y 30 minutos (39.7%)"@es ;
    ns1:numberOfCredits 4.5 ;
    ns1:otherInformation """The subject is related to Sustainable Development Goals number 9 and 12.
The deployment of IoT applications directly impacts the development of new industrial applications, improving the quality of life to minimise the environmental impact. In this course, we focus on developing IoT embedded systems that minimised the use of resources and energy consumption.
Due to the deprecation of Mbed OS in July 2026, the course will now introduce the use of Zephyr OS supported by the Linux Foundation as a broadly adopted alternative to the aforementioned operating system."""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "47 horas y 30 minutos"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/593000501/2025-26/eventSchedule> ;
    schema:description """Brief Description of the Course
The main goal of this course is to introduce the hardware and software architectures frequently used in hardware embedded platforms for IoT applications. More specifically, the description of the essential hardware resources, architecture details and sensor and actuator interfaces are covered. In addition, the integration, development and debugging of software IoT applications are studied in detail."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/g.azuara%40upm.es> ;
    schema:inLanguage "Inglés"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/eduardo.juarez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/g.azuara%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/miguel.chavarrias%40upm.es> ;
    schema:name "Embedded Platforms And Communications For Iot"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/593000501/2025-26/CB06> a ns1:Competency ;
    ns1:competencyCode "CB06" ;
    ns1:competencyDescription "Poseer y comprender conocimientos que aporten una base u oportunidad de ser originales en el desarrollo y/o aplicación de ideas, a menudo en un contexto de investigación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/593000501/2025-26/CB10> a ns1:Competency ;
    ns1:competencyCode "CB10" ;
    ns1:competencyDescription "Que los estudiantes posean las habilidades de aprendizaje que les permitan continuar estudiando de un modo que habrá de ser en gran medida autodirigido o autónomo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/593000501/2025-26/CE.01> a ns1:Competency ;
    ns1:competencyCode "CE.01" ;
    ns1:competencyDescription "Evaluar las arquitecturas HW/SW existentes y diseñar plataformas embebidas para desarrollar soluciones IoT integrando diversas capas SW que manejen sensores, actuadores y dispositivos de comunicación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/593000501/2025-26/CE.02> a ns1:Competency ;
    ns1:competencyCode "CE.02" ;
    ns1:competencyDescription "Diseñar y desarrollar redes de sensores integrando nodos heterogéneos con diferentes sistemas de comunicación inalámbricas para desarrollar aplicaciones IoT"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/593000501/2025-26/CG01> a ns1:Competency ;
    ns1:competencyCode "CG01" ;
    ns1:competencyDescription "Los alumnos demostrarán tener una visión del estado actual, las necesidades y los problemas que se plantean en el mundo de la IoT, así como de las arquitecturas y estándares más utilizados"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/593000501/2025-26/CG02> a ns1:Competency ;
    ns1:competencyCode "CG02" ;
    ns1:competencyDescription "Los alumnos serán capaces de aplicar métodos y tecnologías avanzadas que les permitan abordar necesidades y problemas en aplicaciones IoT"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/593000501/2025-26/CT.01> a ns1:Competency ;
    ns1:competencyCode "CT.01" ;
    ns1:competencyDescription "Capacidad de uso de la lengua inglesa para el trabajo en contextos internacionales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/593000501/2025-26/RA21> a ns1:LearningResult ;
    ns1:learningResultCode "RA21" ;
    ns1:learningResultDescription "To establish the building or selection criteria of embedded hardware platforms for the integration of a specific IoT application"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/593000501/2025-26/RA22> a ns1:LearningResult ;
    ns1:learningResultCode "RA22" ;
    ns1:learningResultDescription "To combine the development tools for the integration of all software elements required to use a hardware platform in an IoT solution"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/593000501/2025-26/RA23> a ns1:LearningResult ;
    ns1:learningResultCode "RA23" ;
    ns1:learningResultDescription "To use the interfaces for the connection of sensors, actuators and communication modules in a hardware/software platform supporting IoT applications"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/593000501/2025-26/RA24> a ns1:LearningResult ;
    ns1:learningResultCode "RA24" ;
    ns1:learningResultDescription "To integrate a wireless technology and the communication protocols for a hardware platform in an IoT specific application"@es .

