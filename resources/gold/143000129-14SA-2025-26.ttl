    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/143000129/2025-26/eventSchedule> ;
    schema:description "En la actividad docente que se propone es la asignatura \"Dinámica orbital y control de actitud\" del Master. Se presentan los aspectos más relevantes de la dinámica orbital necesarios para la compresión de la funcionalidad del subsistema de control de actitud en un vehículo espacial. El subsistema de navegación y control mide y controla la posición en el espacio, la orientación y la velocidad de desplazamiento del vehículo espacial."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/j.cubas%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/angel.porras.hermoso%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/j.cubas%40upm.es> ;
    schema:name "Dinámica Orbital y Control de Actitud"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000129/2025-26/E02> a ns1:Competency ;
    ns1:competencyCode "E02" ;
    ns1:competencyDescription "Aplicar los métodos de análisis propios de un determinado subsistema, para verificar la adecuación del diseño del mismo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000129/2025-26/E03> a ns1:Competency ;
    ns1:competencyCode "E03" ;
    ns1:competencyDescription "Conocer y comprender el entorno espacial y planetario, y su efecto en la operación de los vehículos aeroespaciales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000129/2025-26/E12> a ns1:Competency ;
    ns1:competencyCode "E12" ;
    ns1:competencyDescription "Desarrollar los diferentes subsistemas específicos que conforman un vehículo espacial."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000129/2025-26/E13> a ns1:Competency ;
    ns1:competencyCode "E13" ;
    ns1:competencyDescription "Analizar los subsistemas específicos que conforman un vehículo espacial."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000129/2025-26/E24> a ns1:Competency ;
    ns1:competencyCode "E24" ;
    ns1:competencyDescription "Evaluar la bondad de un determinado diseño para satisfacer los requisitos de misión"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000129/2025-26/RA15> a ns1:LearningResult ;
    ns1:learningResultCode "RA15" ;
    ns1:learningResultDescription "Con esta asignatura se pretende que el estudiante comprenda y conozca la necesidad de implementar un subsistema de control de actitud en un vehículo espacial, así como las funciones que debe asumir y la arquitectura de este subsistema, poniendo de relieve aquellos aspectos más relevantes que influyen en el diseño del mismo. El subsistema de guiado, navegación y control mide y controla la posición en el espacio, la orientación y la veloci"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000129/2025-26/RA16> a ns1:LearningResult ;
    ns1:learningResultCode "RA16" ;
    ns1:learningResultDescription "Comprende la relevancia de las ciencias básicas y su aplicación en la ingeniería"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000129/2025-26/RA17> a ns1:LearningResult ;
    ns1:learningResultCode "RA17" ;
    ns1:learningResultDescription "Utiliza herramientas analíticas y numéricas que son objeto de otras asignaturas del plan de estudios."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000129/2025-26/RA18> a ns1:LearningResult ;
    ns1:learningResultCode "RA18" ;
    ns1:learningResultDescription "Identifica y resuelve problemas aplicando los conocimientos adquiridos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000129/2025-26/RA19> a ns1:LearningResult ;
    ns1:learningResultCode "RA19" ;
    ns1:learningResultDescription "Se integra y forma parte activa de equipos de trabajo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000129/2025-26/RA20> a ns1:LearningResult ;
