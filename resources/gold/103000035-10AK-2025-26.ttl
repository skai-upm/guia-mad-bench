    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/103000035/2025-26/syllabus> ;
    ns1:inpersonHours "40 horas (38.5%)"@es ;
    ns1:numberOfCredits 4.0 ;
    ns1:otherInformation "Nota: Ante cualquier inconsistencia que pudiera surgir entre esta guía y el material equivalente publicado en el Moodle de la asignatura, prevalecerán las intrucciones en Moodle."@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "40 horas"@es ;
    schema:activitiesWorkload "200%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/103000035/2025-26/eventSchedule> ;
    schema:description "Las técnicas numéricas vistas se centran en métodos de optimización, que se ven desde una perspectiva esencialmente práctica. Se presentan métodos clásicos para problemas con restricciones y sin restricciones, métodos estocásticos como el annealing simulado y derivados y otros basados en sistemas biológicos como la computación evolutiva o los basados en sistemas inmunes artificiales, estrategias de forrajeo y de bandada. Finalmente, se estudian los métodos MonteCarlo."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/vicente.martin%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/esther.dopazo%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/juanpedro.brito%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/vicente.martin%40upm.es> ;
    schema:name "Computacion Numerica Avanzada"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000035/2025-26/CEM7> a ns1:Competency ;
    ns1:competencyCode "CEM7" ;
    ns1:competencyDescription "Evaluar y aplicar las diversas teorías matemáticas y estadísticas, y los procesos, métodos y técnicas disponibles para la extracción y descubrimiento de conocimiento a partir de grandes volúmenes de datos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000035/2025-26/CEM8> a ns1:Competency ;
    ns1:competencyCode "CEM8" ;
    ns1:competencyDescription "Aplicar los fundamentos teóricos y matemáticos adecuados al procesamiento y análisis de funciones y datos de diversa    naturaleza, y evaluar y diseñar los métodos relacionados para su aplicación en dominios prácticos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000035/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en entornos nuevos o poco conocidos dentro de contextos más amplios (o multidisciplinares) relacionados con su área de estudio."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000035/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Que los estudiantes sepan comunicar sus conclusiones y los conocimientos y razones últimas que las sustentan a públicos especializados y no especializados de un modo claro y sin ambigüedades."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000035/2025-26/CG4> a ns1:Competency ;
    ns1:competencyCode "CG4" ;
    ns1:competencyDescription "Que los estudiantes posean las habilidades de aprendizaje que les permitan continuar estudiando de un modo que habrá de ser en gran medida autodirigido o autónomo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000035/2025-26/CG7> a ns1:Competency ;
    ns1:competencyCode "CG7" ;
    ns1:competencyDescription "Especificación y realización de tareas informáticas complejas, poco definidas o no familiares"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000035/2025-26/CG8> a ns1:Competency ;
    ns1:competencyCode "CG8" ;
    ns1:competencyDescription "Planteamiento y resolución de problemas también en áreas nuevas y emergentes de su disciplina"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000035/2025-26/CG9> a ns1:Competency ;
    ns1:competencyCode "CG9" ;
    ns1:competencyDescription "Aplicación de los métodos de resolución de problemas más recientes o innovadores y que puedan implicar el uso de otras disciplinas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000035/2025-26/CGI20> a ns1:Competency ;
    ns1:competencyCode "CGI20" ;
    ns1:competencyDescription "Adquirir conocimientos científicos avanzados del campo de la informática que le permitan generar nuevas ideas dentro de una línea de investigación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000035/2025-26/CGI23> a ns1:Competency ;
    ns1:competencyCode "CGI23" ;
    ns1:competencyDescription "Capacidad de leer y comprender publicaciones dentro de su ámbito de estudio/investigación, así como su catalogación y valor científico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000035/2025-26/RA1> a ns1:LearningResult ;
    ns1:learningResultCode "RA1" ;
    ns1:learningResultDescription "Conocer ejemplos de aplicaciones reales y tendencias y líneas de investigación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000035/2025-26/RA103> a ns1:LearningResult ;
    ns1:learningResultCode "RA103" ;
    ns1:learningResultDescription "Conocer la aplicación de los métodos de optimización en gestión de producción"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000035/2025-26/RA12> a ns1:LearningResult ;
    ns1:learningResultCode "RA12" ;
    ns1:learningResultDescription "Be familiar with examples of real applications and research trends and lines"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000035/2025-26/RA13> a ns1:LearningResult ;
    ns1:learningResultCode "RA13" ;
    ns1:learningResultDescription "Select and apply optimization methods to specific problems"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000035/2025-26/RA2> a ns1:LearningResult ;
    ns1:learningResultCode "RA2" ;
    ns1:learningResultDescription "Seleccionar y aplicar métodos de optimización a problemas concretos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000035/2025-26/RA3> a ns1:LearningResult ;
    ns1:learningResultCode "RA3" ;
    ns1:learningResultDescription "Conocer la teoría de métodos de optimización clásicos y heurísticos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000035/2025-26/RA7> a ns1:LearningResult ;
    ns1:learningResultCode "RA7" ;
    ns1:learningResultDescription "Conocer, aplicar y criticar la bibliografía referente a un tema de investigación con objeto de utilizarla como impulso o cimiento de una idea nueva y de su proceso de investigación asociado."@es .

