    ns1:competencyDescription "Comprender la operativa de las operaciones financieras."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000157/2025-26/CE53> a ns1:Competency ;
    ns1:competencyCode "CE53" ;
    ns1:competencyDescription "Aplicar la metodología de valoración y análisis de proyectos y decisiones de inversión."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000157/2025-26/CE55> a ns1:Competency ;
    ns1:competencyCode "CE55" ;
    ns1:competencyDescription "Comprender las principales operaciones integradas en el ámbito de las finanzas corporativas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000157/2025-26/CG15> a ns1:Competency ;
    ns1:competencyCode "CG15" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de planificar eficientemente los trabajos en el ámbito de la administración y dirección de empresas, priorizando las tareas a desempeñar y evaluando los recursos y el tiempo necesario para llevarlas a cabo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000157/2025-26/CG18> a ns1:Competency ;
    ns1:competencyCode "CG18" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de aportar soluciones creativas en la resolución de problemas en el ámbito de la administración y dirección de empresas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000157/2025-26/CG21> a ns1:Competency ;
    ns1:competencyCode "CG21" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de aprender de forma autónoma, fijándose unos objetivos, identificando los procedimientos y recursos con los que cuentan y evaluando sus propios procesos de aprendizaje en el ámbito de la administración y dirección de empresas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000157/2025-26/RA129> a ns1:LearningResult ;
    ns1:learningResultCode "RA129" ;
    ns1:learningResultDescription "Conocer el intercambio de recursos económicos a lo largo del tiempo entre los individuos, empresas e instituciones financieras, lo que implica el análisis de las decisiones de inversiones y financiación en la empresa, la teoría de carteras, la valoración de activos y el funcionamiento de los mercados financieros."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000157/2025-26/RA130> a ns1:LearningResult ;
    ns1:learningResultCode "RA130" ;
    ns1:learningResultDescription "Aplicar el análisis cuantitativo de la empresa y su entorno."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000157/2025-26/RA132> a ns1:LearningResult ;
    ns1:learningResultCode "RA132" ;
    ns1:learningResultDescription "Aplicar las teorías y enfoques de análisis económico para explicar el comportamiento de los agentes económicos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000157/2025-26/RA93> a ns1:LearningResult ;
    ns1:learningResultCode "RA93" ;
    ns1:learningResultDescription "Escuchar, negociar, persuadir y defender argumentos oralmente o por escrito."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000157/2025-26/RA94> a ns1:LearningResult ;
