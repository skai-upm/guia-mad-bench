    ns1:bibliographyTitle "Corres, H. (1980) Dimensionamiento de soportes esbeltos de sección constante de hormigón armado en estado límite de agotamiento o inestabilidad. Método de las curvaturas de referencia. Tesis Doctoral."@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000441/2025-26/didactic_resource/6> a ns1:DidacticResource ;
