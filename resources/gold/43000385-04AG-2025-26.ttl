    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/43000385/2025-26/eventSchedule> ;
    schema:description "La asignatura que se propone, Comportamiento No Lineal de Estructuras, supone una continuidad con las anteriores asignaturas estructurales y en ella se estudian los efectos que, sobre el comportamiento de las estructuras, tiene la asunción realista de la falta de proporcionalidad entre las acciones y sus efectos en la estructura, debido a que los materiales no son ideales o a que los movimientos no son lo suficientemente pequeños. Se analizan los distintos tipos de no linealidad (geométrica, material, sustentación) y se desarrollan modelos continuos (vigas, placas, cables) y discretos (Cálculo Matricial y Elementos Finitos), centrándonos fundamentalmente en la no linealidad geométrica y aplicándolo a numerosos ejemplos. Además se aborda el tratamiento de los efectos dinámicos, los métodos numéricos de resolución y el formato de seguridad para este tipo de problemas. Aplicaciones típicas son los elementos comprimidos esbeltos, las estructuras colgadas o atirantadas, y cualquier tipo de estructura con estados de carga elevados."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/josemaria.arrieta%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/antonio.carnerero%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/david.izquierdo%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/josemaria.arrieta%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/mariamercedes.madrid%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/miguel.fernandezruiz%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/nicola.tarque%40upm.es> ;
    schema:name "Comportamiento No Lineal de Estructuras"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000385/2025-26/CE22> a ns1:Competency ;
    ns1:competencyCode "CE22" ;
    ns1:competencyDescription "Conocimiento y capacidad para el análisis estructural mediante la aplicación de los métodos y programas de diseño y cálculo avanzado de estructuras, a partir del conocimiento y comprensión de las solicitaciones y su aplicación a las tipologías estructurales de la ingeniería civil. Capacidad para realizar evaluaciones de integridad estructural."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000385/2025-26/CE23> a ns1:Competency ;
    ns1:competencyCode "CE23" ;
    ns1:competencyDescription "Conocimiento de todo tipo de estructuras y sus materiales, y capacidad para diseñar, proyectar, ejecutar y mantener las estructuras y edificaciones de obra civil."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000385/2025-26/CE38> a ns1:Competency ;
    ns1:competencyCode "CE38" ;
    ns1:competencyDescription "Capacidad para integrar y aplicar los conocimientos técnicos en asesoría, análisis, diseño y modelización físico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000385/2025-26/CE39> a ns1:Competency ;
    ns1:competencyCode "CE39" ;
    ns1:competencyDescription "Capacidad predictiva para optimización de soluciones en ingeniería estructural."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000385/2025-26/CGP01> a ns1:Competency ;
    ns1:competencyCode "CGP01" ;
    ns1:competencyDescription "Capacitación científico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000385/2025-26/CGP06> a ns1:Competency ;
    ns1:competencyCode "CGP06" ;
    ns1:competencyDescription "Conocimiento para aplicar las capacidades técnicas y gestoras en actividades de I+D+i dentro del ámbito de la ingeniería civil. Incorpora las competencias CB6, CB7 y CB8."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000385/2025-26/CGP11> a ns1:Competency ;
    ns1:competencyCode "CGP11" ;
    ns1:competencyDescription "Capacidad para el proyecto, ejecución e inspección de estructuras (puentes, edificaciones, etc.), de obras de cimentación y de obras subterráneas de uso civil (túneles, aparcamientos), y el diagnóstico sobre su integridad. Incorpora las competencias CB6, CB7 y CB8."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000385/2025-26/CGP12> a ns1:Competency ;
    ns1:competencyCode "CGP12" ;
    ns1:competencyDescription "Capacidad para planificar, diseñar y gestionar infraestructuras, así como su mantenimiento, conservación y explotación. Incorpora las competencias CB6, CB7 y CB8."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000385/2025-26/CGP18> a ns1:Competency ;
    ns1:competencyCode "CGP18" ;
    ns1:competencyDescription "Conocimientos adecuados de los aspectos científicos y tecnológicos de métodos matemáticos, analíticos y numéricos de la ingeniería, mecánica de fluidos, mecánica de medios continuos, cálculo de estructuras, ingeniería del terreno, ingeniería marítima, obras y aprovechamientos hidráulicos y obras lineales. Incorpora las competencias CB6, CB7 y CB8."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000385/2025-26/CT2> a ns1:Competency ;
    ns1:competencyCode "CT2" ;
    ns1:competencyDescription "Polivalencia y capacidad de aprendizaje autónomo. Desarrolla la competencia transversal 5ª del Real Decreto."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000385/2025-26/CT8> a ns1:Competency ;
    ns1:competencyCode "CT8" ;
    ns1:competencyDescription "Capacidad de diseñar, analizar e interpretar experimentos relevantes en ingeniería civil."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000385/2025-26/RA116> a ns1:LearningResult ;
    ns1:learningResultCode "RA116" ;
    ns1:learningResultDescription "Conoce las causas de no linealidad geométrica en estructuras y los métodos de cálculo en los distintos niveles."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000385/2025-26/RA119> a ns1:LearningResult ;
    ns1:learningResultCode "RA119" ;
    ns1:learningResultDescription "Conoce las causas de no linealidad debida al material en estructuras, sus leyes constitutivas y los métodos de cálculo estructural aplicables."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000385/2025-26/RA120> a ns1:LearningResult ;
    ns1:learningResultCode "RA120" ;
    ns1:learningResultDescription "Conoce la influencia de las diversas causas de no linealidad en el análisis dinámico de estructuras y los métodos de cálculo aplicables."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000385/2025-26/RA121> a ns1:LearningResult ;
    ns1:learningResultCode "RA121" ;
    ns1:learningResultDescription "Conoce los métodos numéricos para resolver los cálculos estructurales no lineales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000385/2025-26/RA122> a ns1:LearningResult ;
    ns1:learningResultCode "RA122" ;
    ns1:learningResultDescription "Conoce el formato de seguridad necesario para poder realizar comprobaciones estructurales mediante cálculos no lineales en estructuras reales."@es .

