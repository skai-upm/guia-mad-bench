        <https://guia-kg.skai.etsisi.upm.es/resource/63000277/2025-26/didactic_resource/2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/63000277/2025-26/didactic_resource/3>,
        <https://guia-kg.skai.etsisi.upm.es/resource/63000277/2025-26/didactic_resource/4> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/63000277/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/63000277/2025-26/RA39>,
        <https://guia-kg.skai.etsisi.upm.es/resource/63000277/2025-26/RA40>,
        <https://guia-kg.skai.etsisi.upm.es/resource/63000277/2025-26/RA41>,
        <https://guia-kg.skai.etsisi.upm.es/resource/63000277/2025-26/RA42>,
        <https://guia-kg.skai.etsisi.upm.es/resource/63000277/2025-26/RA43>,
        <https://guia-kg.skai.etsisi.upm.es/resource/63000277/2025-26/RA45> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/63000277/2025-26/syllabus> ;
    ns1:inpersonHours "48 horas (46.2%)"@es ;
    ns1:numberOfCredits 4.0 ;
    ns1:otherInformation "La asignatura se relaciona con el ODS9 y el ODS12"@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "48 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/63000277/2025-26/eventSchedule> ;
    schema:description """Esta asignatura se basa en definir el proceso mineralúrgico más adecuado para la concentración de un mineral. Para ello se parte del estudio de prospección geológica del yacimiento minero, donde se analiza la geología y las características de la mineralización, con objeto de realizar un muestreo en mina representativo y con garantías de calidad para su representatividad. De estas muestras seleccionadas del yacimiento se procede a la búsqueda del proceso de tratamiento mineralúrgico más adecuado para la recuperación de la especie valiosa.
Se analizan las diferentes unidades operacionales que se necesitan para conseguir la concentración del mineral, o bien, su adecuación a las condiciones de mercado. Desde el proceso de liberación de las especies minerales (fragmentación), a los posibles métodos de concentración de las especies de interés, para finalmente conseguir el acondicionamiento de productos de planta de tratamiento. Todo ello realizado en condiciones de sostenibilidad, teniendo en cuenta los aspectos aplicables de seguridad laboral, medioambiental, calidad de producto y eficiencia energética."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/carlos.grima%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/carlos.grima%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/dulce.gomezlimon%40upm.es> ;
    schema:name "Diseño Conceptual de Instalaciones Mineralúrgicas - Mtd"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000277/2025-26/CB10> a ns1:Competency ;
    ns1:competencyCode "CB10" ;
    ns1:competencyDescription "Que los estudiantes posean las habilidades de aprendizaje que les permitan continuar estudiando de un modo que habrá de ser en gran medida autodirigido o autónomo/ Students have the learning skills that they require to pursue their studies in a largely self"@es .

