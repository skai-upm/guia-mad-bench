    ns1:inpersonHours "36 horas (46.2%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation """La asignatura se relaciona con los ODS:

ODS 13, Acción por el clima (especialmente 13.2: Incorporar medidas relativas al cambio climático en las políticas, estrategias y planes nacionales).
ODS4 -- Educación de Calidad.
ODS11 -- Ciudades y comunidades sostenibles"""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "38 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/135005835/2025-26/eventSchedule> ;
    schema:description "La asignatura tiene como objetivo que los estudiantes adquieran los conocimientos necesarios para evaluar las causas, evolución prevista e impactos del cambio climático y para ser capaces de hacer diagnósticos y propuestas de actuación que incorporen las medidas más pertinentes para la mitigación y adaptación al cambio climático en diferentes contextos y sectores, en el marco de la políticas, legislación y acuerdos para la acción climática a escala nacional e internacional."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/aitor.gaston%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/aitor.gaston%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/santiago.saura%40upm.es> ;
    schema:name "Mitigacion y Adaptacion Al Cambio Climatico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005835/2025-26/CB04> a ns1:Competency ;
    ns1:competencyCode "CB04" ;
    ns1:competencyDescription "Que los estudiantes puedan transmitir información, ideas, problemas y soluciones a un público tanto especializado como no especializado"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005835/2025-26/CB05> a ns1:Competency ;
    ns1:competencyCode "CB05" ;
    ns1:competencyDescription "Que los estudiantes hayan desarrollado aquellas habilidades de aprendizaje necesarias para emprender estudios posteriores con un alto grado de autonomía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005835/2025-26/CE%202.19> a ns1:Competency ;
    ns1:competencyCode "CE 2.19" ;
    ns1:competencyDescription "Conocer las causas antrópicas del cambio climático y sus escenarios de evolución, las estrategias para su mitigación y el papel de los ecosistemas como sumideros de Carbono."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005835/2025-26/CG03> a ns1:Competency ;
    ns1:competencyCode "CG03" ;
    ns1:competencyDescription "Ejercer su actiividad profesional en el ámbito de la gestión del Medio Natural, con responsabilidad social, ética, profesional y civil, en el marco de una sociedad altamente sensibilizada por la protección, conservación y restauración de los sistemas naturales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005835/2025-26/CT02> a ns1:Competency ;
    ns1:competencyCode "CT02" ;
    ns1:competencyDescription "Aplicar las principales técnicas de análisis y síntesis para la gestión de la información procedente de distintas fuentes, extrayendo las conclusiones pertinentes e integrándolas con los conocimientos previos y los objetivos perseguidos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005835/2025-26/RA141> a ns1:LearningResult ;
    ns1:learningResultCode "RA141" ;
    ns1:learningResultDescription "Conocer y aplicar los fundamentos de la gestión adaptativa."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005835/2025-26/RA164> a ns1:LearningResult ;
    ns1:learningResultCode "RA164" ;
    ns1:learningResultDescription "RA533"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005835/2025-26/RA211> a ns1:LearningResult ;
    ns1:learningResultCode "RA211" ;
    ns1:learningResultDescription "Conocer los fundamentos ideológicos de las principales corrientes socioambientales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005835/2025-26/RA233> a ns1:LearningResult ;
    ns1:learningResultCode "RA233" ;
    ns1:learningResultDescription "Familiarizarse con el manejo de técnicas interpretativas y expositivas aplicadas al medio natural"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005835/2025-26/RA72> a ns1:LearningResult ;
    ns1:learningResultCode "RA72" ;
    ns1:learningResultDescription "RA 37 Reconocer y analizar problemas ambientales y planificar estrategias para la mejora de la calidad ambiental"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005835/2025-26/RA81> a ns1:LearningResult ;
    ns1:learningResultCode "RA81" ;
    ns1:learningResultDescription "Definir soluciones basadas en la naturaleza en empresas del sector"@es .

