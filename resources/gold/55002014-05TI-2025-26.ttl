<https://guia-kg.skai.etsisi.upm.es/resource/55002014> a ns1:Course ;
    ns1:courseType "Optativa"@es ;
    ns1:courseYear 4 ;
    ns1:semester "Octavo semestre"@es ;
    schema:courseCode 55002014 ;
    schema:hasCourseInstance <https://guia-kg.skai.etsisi.upm.es/resource/55002014/2025-26> ;
    schema:name "Engineering Design Event Of a Formula Student Racecar"@en,
        "Competición de Ingeniería de Diseño de un Monoplaza Tipo Fórmula Student"@es ;
    schema:numberOfCredits 3.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/55002014/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/55002014/2025-26/CB03>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55002014/2025-26/CB04>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55002014/2025-26/CB05>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55002014/2025-26/CG7>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55002014/2025-26/CG8> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/55002014/2025-26/didactic_resource/1> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/55002014/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/55002014/2025-26/RA159>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55002014/2025-26/RA203>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55002014/2025-26/RA208>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55002014/2025-26/RA209>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55002014/2025-26/RA264>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55002014/2025-26/RA316> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/55002014/2025-26/syllabus> ;
    ns1:inpersonHours "32 horas y 30 minutos (41.7%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation """La planificación temporal de temas impartidos se puede ver alterada.
La asignatura se relaciona con el ODS7 y el ODS11"""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "32 horas y 30 minutos"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/55002014/2025-26/eventSchedule> ;
    schema:description """En esta asignatura se pretende realizar una primera aproximación a algunos de los aspectos tecnológicos más relevantes de los vehículos monoplaza tipo Formula Student.
Se realizarán estudios comparativos de los equipos de otras Universidades.
Se analizará el vehículo del equipo @UPMRacing
Se comprarán los resultados en las diferentes competiciones
Se generará una herramienta en la que se enlacen los conocimientos adquiridos por sistema
Así, mediante un enfoque de trabajo en equipo, se pretende la búsqueda y comparación de soluciones en diferentes ámbitos como sistemas vehiculares o conducción autónoma, así como su defensa oral."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/enrique.alcala%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/enrique.alcala%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/felipe.jimenez%40upm.es> ;
    schema:name "Competición de Ingeniería de Diseño de un Monoplaza Tipo Fórmula Student"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55002014/2025-26/CB03> a ns1:Competency ;
    ns1:competencyCode "CB03" ;
    ns1:competencyDescription "Que los estudiantes tengan la capacidad de reunir e interpretar datos relevantes (normalmente dentro de su área de estudio) para emitir juicios que incluyan una reflexión sobre temas relevantes de índole social, científica o ética"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55002014/2025-26/CB04> a ns1:Competency ;
    ns1:competencyCode "CB04" ;
    ns1:competencyDescription "Que los estudiantes puedan transmitir información, ideas, problemas y soluciones a un público tanto especializado como no especializado"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55002014/2025-26/CB05> a ns1:Competency ;
    ns1:competencyCode "CB05" ;
    ns1:competencyDescription "Que los estudiantes hayan desarrollado aquellas habilidades de aprendizaje necesarias para emprender estudios posteriores con un alto grado de autonomía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55002014/2025-26/CG7> a ns1:Competency ;
    ns1:competencyCode "CG7" ;
    ns1:competencyDescription "Incorporar nuevas tecnologías y herramientas de la Ingeniería Industrial en sus actividades profesionales."@es .

