<https://guia-kg.skai.etsisi.upm.es/resource/55000006/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/55000006/2025-26/CE2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55000006/2025-26/CG1>,
