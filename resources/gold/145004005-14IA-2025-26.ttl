    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/145004005/2025-26/eventSchedule> ;
    schema:description """La asignatura de Resistencia de materiales y Elasticidad tiene como objetivo dotar al alumno de la capacidad de generar un razonamiento crítico, ingenieril y cuantitativo sobre la relación existente entre las cargas aplicadas en una estructura y el estado de esfuerzos y deformaciones que se produce en los sistemas deformables. El alumno tendrá capacidad para formular, aplicar e implementar las ecuaciones de la elasticidad lineal,
las hipótesis de la Resistencia de materiales y las técnicas básicas del análisis estructural."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/roman.torres%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/alberto.badias%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/i.binsenser%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/joseluis.hernando%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/khanhnguyen.gia%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/lucia.lopezdeabajo%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/luis.saucedo%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/roman.torres%40upm.es> ;
    schema:name "Resistencia de Materiales y Elasticidad"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145004005/2025-26/CE07> a ns1:Competency ;
    ns1:competencyCode "CE07" ;
    ns1:competencyDescription "Comprender el comportamiento de las estructuras ante las solicitaciones en condiciones de servicio y situaciones límite."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145004005/2025-26/CE15> a ns1:Competency ;
    ns1:competencyCode "CE15" ;
    ns1:competencyDescription "Conocimiento adecuado y aplicado a la Ingeniería de: Los principios de la mecánica del medio continuo y las técnicas de cálculo de su respuesta."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145004005/2025-26/CE18> a ns1:Competency ;
    ns1:competencyCode "CE18" ;
    ns1:competencyDescription "Conocimiento adecuado y aplicado a la Ingeniería de: Los fundamentos de la mecánica de fluidos; los principios básicos del control y la automatización del vuelo; las principales características y propiedades físicas y mecánicas de los materiales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145004005/2025-26/CE19> a ns1:Competency ;
    ns1:competencyCode "CE19" ;
    ns1:competencyDescription "Conocimiento aplicado de: la ciencia y tecnología de los materiales; mecánica y termodinámica; mecánica de fluidos; aerodinámica y mecánica del vuelo; sistemas de navegación y circulación aérea; tecnología aeroespacial; teoría de estructuras; transporte aéreo; economía y producción; proyectos; impacto ambiental."@es .

