    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/43000656/2025-26/eventSchedule> ;
    schema:description """Riesgos e incertidumbres: Toma de decisiones bajo incertidumbre. Variables aleatorias en la determinación de la resistencia y de la acción. Tipos de incertidumbre (aleatoria vs. epistémica). Caracterización de incertidumbres.
Modelos estadísticos: Teoría de probabilidad, hipótesis estadísticas y momentos, determinación del coeficiente de fiabilidad y factores de influencia
Funciones de distribución: Probability Density Function para acciones y resistencia y Joint Probability Density Function para análisis de fiabilidad.
Análisis de fiabilidad: Método de los momentos, FOSM, FORM y Monte Carlo. Formulación y ámbito de aplicación. Coeficientes parciales de seguridad
Métodos de fiabilidad:
Nivel de Aproximación 0: Métodos deterministas, coeficiente global
Nivel de Aproximación I: Métodos semi-probabilistas, coeficientes parciales de seguridad
Nivel de Aproximación II: Fiabilidad de primer orden (FOSM, FORM)
Nivel de Aproximación III: Métodos probabilistas (Monte Carlo)
Combinación de acciones: Líneas de influencia, envolventes y análisis plástico
Aplicaciones a diseño: Ejemplos teóricos y prácticos, tanto estructurales como geotécnicos"""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/miguel.fernandezruiz%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/david.izquierdo%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/josemaria.arrieta%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/manueljesus.bueno%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/miguel.fernandezruiz%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/rafael.jimenez%40upm.es> ;
    schema:name "Seguridad y Fiabilidad"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000656/2025-26/C1> a ns1:Competency ;
    ns1:competencyCode "C1" ;
    ns1:competencyDescription "[Proviene de las competencias CE1 y CE6]: Capacidad para la resolución de problemas ligados a diseño, construcción, conservación y evaluación técnica de estructuras de ingeniería civil y edificación que involucren el comportamiento lineal y no lineal de las estructuras TIPO: Competencias"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000656/2025-26/C2> a ns1:Competency ;
    ns1:competencyCode "C2" ;
    ns1:competencyDescription "[Proviene de las competencias CE2 y CE7]: Capacidad para la resolución de problemas ligados al diseño, construcción, conservación y evaluación técnica de cimentaciones de estructuras de ingeniería civil y edificación, obras subterráneas y trabajos geotécnicos, aprovechando los conocimientos de la mecánica de suelos y rocas TIPO: Competencias"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000656/2025-26/C4> a ns1:Competency ;
    ns1:competencyCode "C4" ;
    ns1:competencyDescription "[Proviene de las competencias CE1 y CE4]: Capacidad para el análisis del comportamiento mecánico y la durabilidad de estructuras de ingeniería civil y edificación, sus materiales y sus cimentaciones TIPO: Competencias"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000656/2025-26/K2> a ns1:Competency ;
    ns1:competencyCode "K2" ;
    ns1:competencyDescription "[Proviene de la competencia CG2]: Identifica los componentes determinantes para ejercer las funciones de diseño, construcción, conservación y evaluación técnica de estructuras, cimentaciones y materiales, mediante el uso de normativa y documentación científica nacional e internacional. TIPO: Conocimientos o contenidos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000656/2025-26/RA47> a ns1:LearningResult ;
    ns1:learningResultCode "RA47" ;
    ns1:learningResultDescription "Los resultados del aprendizaje correspondientes a esta asignatura han quedado definidos en el apartado de competencias de este documento, señalando los que corresponden a conocimientos, habilidades y competencias propiamente dichas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000656/2025-26/Sk2> a ns1:Competency ;
    ns1:competencyCode "Sk2" ;
    ns1:competencyDescription "[Proviene de la competencia CB7]: Utiliza los conocimientos técnicos adquiridos para la resolución de problemas nuevos o poco conocidos dentro de contextos más amplios (o multidisciplinares) relacionados con el diseño de estructuras, cimentaciones y materiales en ingeniería civil y edificación. TIPO: Habilidades o destrezas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000656/2025-26/Sk7> a ns1:Competency ;
    ns1:competencyCode "Sk7" ;
    ns1:competencyDescription "[Proviene de las competencias CB9 y CT1]: Prepara y presenta comunicaciones orales, escritas y gráficas, estructurada y argumentadamente, y es capaz de discutirlas con otras personas. TIPO: Habilidades o destrezas"@es .

