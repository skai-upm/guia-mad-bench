    ns1:itemIndex 4 ;
    ns1:syllabusDescription "5. Formatos de seguridad Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000656/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "6. Métodos de Fiabilidad de Primer Orden (FORM) Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000656/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "7. Evaluación de valores de diseño mediante el método Monte Carlo Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000656/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "8. Acciones y combinación de acciones Sin subniveles"@es .

