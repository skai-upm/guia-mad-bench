    ns1:itemIndex 1 ;
    ns1:syllabusDescription "2. Toma de decisiones bajo incertidumbre. Variables aleatorias en la determinación de la resistencia y de la acción Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000656/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "3. Tipos de incertidumbre (aleatoria vs. epistémica). Caracterización de incertidumbres Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000656/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "4. Fiabilidad. Determinación del índice de fiabilidad para diseño de nuevas estructuras y evaluación de estructuras existentes Sin subniveles"@es .

