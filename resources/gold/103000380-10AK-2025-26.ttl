        <https://guia-kg.skai.etsisi.upm.es/resource/joseantonio.calvomanzano%40upm.es> ;
    schema:name "Estrategias de Gestion y Desarrollo de Proyectos con Metodologias No Clasicas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000380/2025-26/CEM3> a ns1:Competency ;
    ns1:competencyCode "CEM3" ;
    ns1:competencyDescription "Aplicar métodos de investigación relevantes a problemas abiertos en el área de la Ingeniería del Software, relacionados tanto con las características peculiares del producto software como con la gestión del desarrollo del mismo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000380/2025-26/CEM4> a ns1:Competency ;
    ns1:competencyCode "CEM4" ;
    ns1:competencyDescription "Analizar y evaluar los diferentes paradigmas y enfoques de ingeniería de construcción y gestión de sistemas basados en software."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000380/2025-26/CG12> a ns1:Competency ;
    ns1:competencyCode "CG12" ;
    ns1:competencyDescription "Comprensión amplia de las técnicas y métodos aplicables en una especialización concreta, así como de sus límites"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000380/2025-26/CG13> a ns1:Competency ;
    ns1:competencyCode "CG13" ;
    ns1:competencyDescription "Apreciación de los límites del conocimiento actual y de la aplicación práctica de la tecnología más reciente."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000380/2025-26/CG14> a ns1:Competency ;
    ns1:competencyCode "CG14" ;
    ns1:competencyDescription "Conocimiento y comprensión de la informática necesaria para la creación de modelos de información, y de los sistemas y procesos complejos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000380/2025-26/CG17> a ns1:Competency ;
    ns1:competencyCode "CG17" ;
    ns1:competencyDescription "Habilidades de gestión y capacidad de liderar un equipo que puede estar integrado por disciplinas y niveles distintos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000380/2025-26/CG4> a ns1:Competency ;
    ns1:competencyCode "CG4" ;
    ns1:competencyDescription "Que los estudiantes posean las habilidades de aprendizaje que les permitan continuar estudiando de un modo que habrá de ser en gran medida autodirigido o autónomo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000380/2025-26/CG7> a ns1:Competency ;
    ns1:competencyCode "CG7" ;
    ns1:competencyDescription "Especificación y realización de tareas informáticas complejas, poco definidas o no familiares"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000380/2025-26/CG8> a ns1:Competency ;
    ns1:competencyCode "CG8" ;
    ns1:competencyDescription "Planteamiento y resolución de problemas también en áreas nuevas y emergentes de su disciplina"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000380/2025-26/CG9> a ns1:Competency ;
    ns1:competencyCode "CG9" ;
    ns1:competencyDescription "Aplicación de los métodos de resolución de problemas más recientes o innovadores y que puedan implicar el uso de otras disciplinas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000380/2025-26/CGI20> a ns1:Competency ;
    ns1:competencyCode "CGI20" ;
    ns1:competencyDescription "Adquirir conocimientos científicos avanzados del campo de la informática que le permitan generar nuevas ideas dentro de una línea de investigación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000380/2025-26/CGI23> a ns1:Competency ;
    ns1:competencyCode "CGI23" ;
    ns1:competencyDescription "Capacidad de leer y comprender publicaciones dentro de su ámbito de estudio/investigación, así como su catalogación y valor científico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000380/2025-26/RA27> a ns1:LearningResult ;
    ns1:learningResultCode "RA27" ;
    ns1:learningResultDescription "Identificar debilidades en las actividades de estimación y planificación de proyectos llevados a cabo con metodologías no clásicas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000380/2025-26/RA28> a ns1:LearningResult ;
    ns1:learningResultCode "RA28" ;
    ns1:learningResultDescription "Analizar investigaciones pioneras que pretendan cubrir debilidades en las actividades de estimación y planificación de proyectos llevados a cabo con metodologías no clásicas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000380/2025-26/RA29> a ns1:LearningResult ;
    ns1:learningResultCode "RA29" ;
    ns1:learningResultDescription "Identificar debilidades en las actividades de análisis y diseño de proyectos llevados a cabo con metodologías no clásicas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000380/2025-26/RA30> a ns1:LearningResult ;
    ns1:learningResultCode "RA30" ;
    ns1:learningResultDescription "Analizar investigaciones pioneras que pretendan cubrir debilidades en las actividades de requisitos y diseño de proyectos llevados a cabo con metodologías no clásicas"@es .

