        <https://guia-kg.skai.etsisi.upm.es/resource/53000941/2025-26/RA32>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53000941/2025-26/RA33>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53000941/2025-26/RA41>,
