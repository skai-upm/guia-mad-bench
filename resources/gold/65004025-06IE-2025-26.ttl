    ns1:inpersonHours "70 horas (44.9%)"@es ;
    ns1:numberOfCredits 6.0 ;
    ns1:otherInformation "Esta asignatura esta relacionada con el ODS 7"@es ;
    ns1:periodEndingMonth "Enero"@es ;
