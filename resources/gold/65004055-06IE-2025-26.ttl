    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/65004055/2025-26/eventSchedule> ;
    schema:description "La asignatura pretende mostrar a los alumnos las aplicaciones de las energías renovables de mayor presencia en la actualidad: Biomasa, Energía eólica y Energía solar, planteando las ventajas e inconvenientes de su aprovechamiento en relación con las instalaciones más convencionales (centrales térmicas y nucleares). Así, se explican las tecnologías y las técnicas disponibles para la obtención de energía tanto térmica como eléctrica utilizando como energía primaria estos tres tipos de energías renovables, de modo que sean capaces, no sólo de elegir la tecnología más adecuada, sino de planificar y diseñar instalaciones apropiadas según los recursos disponibles, el emplazamiento de la instalación y el criterio de diseño existente."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/josemanuel.buron%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/emilio.migoya%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/josemanuel.buron%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/lf.gonzalez%40upm.es> ;
    schema:name "Tecnicas de Aprovechamiento de Energias Renovables"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004055/2025-26/CE20> a ns1:Competency ;
    ns1:competencyCode "CE20" ;
    ns1:competencyDescription "Comprender los conceptos de la termodinámica y aplicarlos en la Ingeniería de la Energía."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004055/2025-26/CE23> a ns1:Competency ;
    ns1:competencyCode "CE23" ;
    ns1:competencyDescription "Aplicar los conceptos básicos de la transferencia de calor y materia en la Ingeniería de la Energía."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004055/2025-26/CE44> a ns1:Competency ;
    ns1:competencyCode "CE44" ;
    ns1:competencyDescription "Aplicar los principios del aprovechamiento de las energías alternativas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004055/2025-26/CE48> a ns1:Competency ;
    ns1:competencyCode "CE48" ;
    ns1:competencyDescription "Comprender el aprovechamiento, transformación y gestión de los recursos energéticos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004055/2025-26/CE51> a ns1:Competency ;
    ns1:competencyCode "CE51" ;
    ns1:competencyDescription "Conocer y aplicar las técnicas de utilización de Energía Solar, Eólica, Biomasa en la generación de Energía Eléctrica y Térmica."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004055/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Conocer y aplicar conocimientos de ciencias y tecnologías básicas a la práctica de la Ingeniería de la Energía."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004055/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Aplicar los conocimientos adquiridos para identificar, formular y resolver problemas dentro de contextos amplios y multidisciplinarios, siendo capaces de integrar conocimientos, trabajando en equipos multidisciplinares."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004055/2025-26/CG4> a ns1:Competency ;
    ns1:competencyCode "CG4" ;
    ns1:competencyDescription "Comprender el impacto de la ingeniería energética en el medio ambiente, el desarrollo sostenible de la sociedad y la importancia de trabajar en un entorno profesional y responsable."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004055/2025-26/CG5> a ns1:Competency ;
    ns1:competencyCode "CG5" ;
    ns1:competencyDescription "Saber comunicar los conocimientos y conclusiones, tanto de forma oral, escrita y gráfica, a públicos especializados y no especializados de un modo claro y sin ambigüedades."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004055/2025-26/RA226> a ns1:LearningResult ;
    ns1:learningResultCode "RA226" ;
    ns1:learningResultDescription "Comprender los principios de funcionamiento de sistemas energéticos basados en energías renovables y su integración con otras energías."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004055/2025-26/RA227> a ns1:LearningResult ;
    ns1:learningResultCode "RA227" ;
    ns1:learningResultDescription "Acometer trabajos de ingeniería relativos al aprovechamiento y aplicación de las energías solar, eólica y de la biomasa para generación de energías eléctricas, térmicas, etc. ,"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004055/2025-26/RA228> a ns1:LearningResult ;
