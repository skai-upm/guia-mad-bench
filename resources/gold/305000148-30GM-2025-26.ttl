<https://guia-kg.skai.etsisi.upm.es/resource/305000148/2025-26/CB1> a ns1:Competency ;
    ns1:competencyCode "CB1" ;
    ns1:competencyDescription "Que los estudiantes hayan demostrado poseer y comprender conocimientos en un área de estudio que parte de la base de la educación secundaria general, y se suele encontrar a un nivel que, si bien se apoya en libros de texto avanzados, incluye también algunos aspectos que implican conocimientos procedentes de la vanguardia de su campo de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000148/2025-26/CB2> a ns1:Competency ;
    ns1:competencyCode "CB2" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar sus conocimientos a su trabajo o vocación de una forma profesional y posean las competencias que suelen demostrarse por medio de la elaboración y defensa de argumentos y la resolución de problemas dentro de su área de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000148/2025-26/CB3> a ns1:Competency ;
    ns1:competencyCode "CB3" ;
    ns1:competencyDescription "Que los estudiantes tengan la capacidad de reunir e interpretar datos relevantes (normalmente dentro de su área de estudio) para emitir juicios que incluyan una reflexión sobre temas relevantes de índole social, científica o ética"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000148/2025-26/CB4> a ns1:Competency ;
    ns1:competencyCode "CB4" ;
    ns1:competencyDescription "Que los estudiantes puedan transmitir información, ideas, problemas y soluciones a un público tanto especializado como no especializado"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000148/2025-26/CB5> a ns1:Competency ;
    ns1:competencyCode "CB5" ;
    ns1:competencyDescription "Que los estudiantes hayan desarrollado aquellas habilidades de aprendizaje necesarias para emprender estudios posteriores con un alto grado de autonomía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000148/2025-26/CE1> a ns1:Competency ;
    ns1:competencyCode "CE1" ;
    ns1:competencyDescription "Comprender y utilizar el lenguaje matemático. Adquirir la capacidad para enunciar propiedades en distintos campos de la Matemática, para construir argumentaciones, elaborar cálculos y para transmitir los conocimientos matemáticos adquiridos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000148/2025-26/CE2> a ns1:Competency ;
    ns1:competencyCode "CE2" ;
    ns1:competencyDescription "Conocer y comprender demostraciones rigurosas de los principales teoremas de cada área de la Matemática y extraer de ellos corolarios mediante la particularización a casos concretos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000148/2025-26/CE3> a ns1:Competency ;
    ns1:competencyCode "CE3" ;
    ns1:competencyDescription "Asimilar la definición de un nuevo objeto matemático, en términos de otros ya conocidos, y ser capaz de utilizar este objeto en diferentes contextos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000148/2025-26/CE4> a ns1:Competency ;
    ns1:competencyCode "CE4" ;
    ns1:competencyDescription "Abstraer las propiedades estructurales de objetos matemáticos, de la realidad observada o de otros ámbitos distinguiéndolas de aquellas puramente ocasionales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000148/2025-26/CE5> a ns1:Competency ;
    ns1:competencyCode "CE5" ;
    ns1:competencyDescription "Comprobar con demostraciones hipótesis sobre un objeto matemático o refutarlas con contraejemplos, así como identificar errores en razonamientos incorrectos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000148/2025-26/CE6> a ns1:Competency ;
    ns1:competencyCode "CE6" ;
    ns1:competencyDescription "Proponer, analizar, validar e interpretar modelos matemáticos de sistemas reales, utilizando las herramientas matemáticas más adecuadas a los fines que se persigan, explicitando las características del sistema recogidas en el modelo y las no consideradas en el mismo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000148/2025-26/CE7> a ns1:Competency ;
    ns1:competencyCode "CE7" ;
    ns1:competencyDescription "Resolver problemas de Matemáticas, mediante habilidades de cálculo básico y tecnologías de computación, planificando su resolución en función de las herramientas de que se disponga y de las restricciones de tiempo y recursos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000148/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Identificar la naturaleza, métodos y fines de los distintos campos de la Matemática y asociarlos con cierta perspectiva histórica de su desarrollo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000148/2025-26/CG2> a ns1:Competency ;
    ns1:competencyCode "CG2" ;
    ns1:competencyDescription "Reconocer la presencia de la Matemática subyacente en la Naturaleza, en la Ciencia, en la Tecnología y en el Arte. Reconocer a la Matemática como parte integrante de la Educación y la Cultura."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000148/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Utilizar las capacidades analíticas y de abstracción, la intuición y el pensamiento lógico y riguroso desarrolladas a través del estudio de la Matemática en contextos tanto matemáticos como no matemáticos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000148/2025-26/RA103> a ns1:LearningResult ;
    ns1:learningResultCode "RA103" ;
    ns1:learningResultDescription "Identificar, en sistemas mecánicos, las magnitudes que permiten determinar su es"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000148/2025-26/RA104> a ns1:LearningResult ;
    ns1:learningResultCode "RA104" ;
    ns1:learningResultDescription "Calcular las magnitudes trabajo y energía y aplicar los principios de conservación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000148/2025-26/RA105> a ns1:LearningResult ;
    ns1:learningResultCode "RA105" ;
    ns1:learningResultDescription "Describir la Teoría de la Gravitación Universal de Newton y la ley de Coulomb."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000148/2025-26/RA106> a ns1:LearningResult ;
    ns1:learningResultCode "RA106" ;
    ns1:learningResultDescription "Plantear y resolver problemas básicos del movimiento de un sistema de partículaso cargas sometidas a fuerzas conocidas, con énfasis en los campos de fuerza gravi"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000148/2025-26/RA107> a ns1:LearningResult ;
    ns1:learningResultCode "RA107" ;
    ns1:learningResultDescription "Calcular la trayectoria de una partícula sometida a un potencial central."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000148/2025-26/RA108> a ns1:LearningResult ;
    ns1:learningResultCode "RA108" ;
    ns1:learningResultDescription "Discernir las propiedades que diferencian el movimiento de partículas del movi"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000148/2025-26/RA109> a ns1:LearningResult ;
    ns1:learningResultCode "RA109" ;
    ns1:learningResultDescription "Identificar y analizar los procesos de interferencia y las ondas estacionarias."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000148/2025-26/RA137> a ns1:LearningResult ;
    ns1:learningResultCode "RA137" ;
    ns1:learningResultDescription "Describir el movimiento de un sólido rígido"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000148/2025-26/RA138> a ns1:LearningResult ;
    ns1:learningResultCode "RA138" ;
    ns1:learningResultDescription "Construir modelos matemáticos mediante ecuaciones diferenciales ordinarias"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000148/2025-26/RA139> a ns1:LearningResult ;
    ns1:learningResultCode "RA139" ;
    ns1:learningResultDescription "Conocer y seleccionar adecuadamente las herramientas matemáticas necesarias para formular, analizar y simular modelos matemáticos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000148/2025-26/RA140> a ns1:LearningResult ;
    ns1:learningResultCode "RA140" ;
    ns1:learningResultDescription "Plantear, resolver e interpretar modelos matemáticos de problemas aplicados"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000148/2025-26/RA142> a ns1:LearningResult ;
    ns1:learningResultCode "RA142" ;
    ns1:learningResultDescription "Reconocer las hipótesis planteadas y los límites de aplicación de los modelos utilizados."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000148/2025-26/RA144> a ns1:LearningResult ;
    ns1:learningResultCode "RA144" ;
    ns1:learningResultDescription "Analizar la sensibilidad de los modelos utilizados respecto a sus parámetros."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000148/2025-26/RA149> a ns1:LearningResult ;
    ns1:learningResultCode "RA149" ;
    ns1:learningResultDescription "Representar mediante modelos matemáticos problemas reales de optimización con restricciones."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000148/2025-26/RA187> a ns1:LearningResult ;
    ns1:learningResultCode "RA187" ;
    ns1:learningResultDescription "Aplicar las herramientas del cálculo diferencial al estudio de la geometría de curvas y superficies en el espacio tridimensional."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000148/2025-26/RA188> a ns1:LearningResult ;
    ns1:learningResultCode "RA188" ;
    ns1:learningResultDescription "Manejar los invariantes locales de curvas y superficies."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000148/2025-26/RA26> a ns1:LearningResult ;
    ns1:learningResultCode "RA26" ;
    ns1:learningResultDescription "Identificar, formular y probar resultados relativos al concepto de derivada e integral."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000148/2025-26/RA27> a ns1:LearningResult ;
    ns1:learningResultCode "RA27" ;
    ns1:learningResultDescription "Calcular derivadas e integrales y utilizarlas en problemas aplicados."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000148/2025-26/RA282> a ns1:LearningResult ;
    ns1:learningResultCode "RA282" ;
    ns1:learningResultDescription "RA81"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000148/2025-26/RA86> a ns1:LearningResult ;
    ns1:learningResultCode "RA86" ;
    ns1:learningResultDescription "Resolver ecuaciones diferenciales ordinarias con valores iniciales mediante distintos métodos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000148/2025-26/RA88> a ns1:LearningResult ;
    ns1:learningResultCode "RA88" ;
    ns1:learningResultDescription "Resolver sistemas de ecuaciones diferenciales lineales de primer orden"@es .

