    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/583000044/2025-26/RA18>,
        <https://guia-kg.skai.etsisi.upm.es/resource/583000044/2025-26/RA3>,
        <https://guia-kg.skai.etsisi.upm.es/resource/583000044/2025-26/RA34>,
        <https://guia-kg.skai.etsisi.upm.es/resource/583000044/2025-26/RA48>,
        <https://guia-kg.skai.etsisi.upm.es/resource/583000044/2025-26/RA55> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/583000044/2025-26/syllabus> ;
    ns1:inpersonHours "38 horas (48.7%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation """La asignatura se relaciona con los siguientes Objetivos de Desarrollo Sostenible (ODS):
ODS nº8: Trabajo decente y crecimiento económico.
ODS nº9: Industria, Innovación e Infraestructura.
ODS nº10: Reducción de las desigualdades
ODS nº11: Ciudades y comunidades sostenibles"""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "39 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/583000044/2025-26/eventSchedule> ;
    schema:description "La asignatura desarrolla los conceptos necesarios para llevar a cabo el proceso de internacionalización por parte de las empresas de infraestructuras. Para ello, se profundiza en el estudio de aspectos de estrategia, finanzas internacionales, comercio internacional de infraestructuras, y otros como la gestión de riesgos específicos de la internacionalización y de los diferentes mercados internacionales de infraestructurales. También se estudian los diferentes organismos multilaterales de desarrollo y sus funciones, así como los procesos de licitaciones internacionales y tipos de contratación internacional."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/mariabelen.munoz%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/c.ursua%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/l.garrido%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/mariabelen.munoz%40upm.es> ;
    schema:name "La Internacionalización del Mercado de Infraestructuras"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/583000044/2025-26/CE%2005> a ns1:Competency ;
    ns1:competencyCode "CE 05" ;
    ns1:competencyDescription "Capacidad para la gestión, dentro de equipos multidisciplinares, en lo relacionado a la planificación estratégica, siguiendo criterios de calidad y medioambientales, de aspectos relacionados con la dirección, coordinación y gestión técnica y económica de proyectos en todos los ámbitos de las infraestructuras"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/583000044/2025-26/CE%2006> a ns1:Competency ;
    ns1:competencyCode "CE 06" ;
    ns1:competencyDescription "Capacidad para comprender la responsabilidad ética y la deontología profesional en el ámbito de las infraestructuras"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/583000044/2025-26/CE%2007> a ns1:Competency ;
    ns1:competencyCode "CE 07" ;
    ns1:competencyDescription "Capacidad para aplicar los principios de la economía y de la gestión de recursos humanos y proyectos, así como la legislación, regulación y normalización en los ámbitos de las infraestructuras"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/583000044/2025-26/CG%2001> a ns1:Competency ;
    ns1:competencyCode "CG 01" ;
    ns1:competencyDescription "Capacidad para dirigir, planificar y supervisar equipos multidisciplinares"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/583000044/2025-26/CG%2004> a ns1:Competency ;
    ns1:competencyCode "CG 04" ;
    ns1:competencyDescription "Capacidad para el análisis y la toma de decisiones relacionada con la dirección general, dirección técnica y dirección de proyectos, desarrollo e innovación, en empresas y centros tecnológicos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/583000044/2025-26/RA18> a ns1:LearningResult ;
    ns1:learningResultCode "RA18" ;
    ns1:learningResultDescription "Utilizar bases de datos nacionales e internacionales, repositorios y buscadores científico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/583000044/2025-26/RA3> a ns1:LearningResult ;
    ns1:learningResultCode "RA3" ;
    ns1:learningResultDescription "Adquisicion de herramientas y destrezas necesarias para la evaluacion de inversiones en infraestructuras"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/583000044/2025-26/RA34> a ns1:LearningResult ;
    ns1:learningResultCode "RA34" ;
    ns1:learningResultDescription "Conocimiento con sentido crítico del amplio contexto multidisciplinar de la ingeniería y de la interrelación que existe entre los conocimientos de los distintos campos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/583000044/2025-26/RA48> a ns1:LearningResult ;
    ns1:learningResultCode "RA48" ;
    ns1:learningResultDescription "Desmostrar capacidad para identificar, formular y resolver problemas de ingeniería en áreas emergentes de la sostenibilidad de infraestructuras"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/583000044/2025-26/RA55> a ns1:LearningResult ;
    ns1:learningResultCode "RA55" ;
    ns1:learningResultDescription "Desmostrar conocimiento y comprensión de las implicaciones sociales, de salud y seguridad, ambientales, económicas e industriales de la práctica de la ingeniería."@es .

