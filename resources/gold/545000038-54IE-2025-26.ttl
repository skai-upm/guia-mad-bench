    ns1:learningResultDescription "Diagnosticar problemas de patología en estructuras de hormigón estructural."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000038/2025-26/RA308> a ns1:LearningResult ;
    ns1:learningResultCode "RA308" ;
    ns1:learningResultDescription "Diseñar y dimensionar refuerzos estructurales para estructuras de hormigón estructural."@es .

