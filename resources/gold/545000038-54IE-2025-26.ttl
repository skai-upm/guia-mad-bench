    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/545000038/2025-26/syllabus> ;
    ns1:inpersonHours "74 horas (47.4%)"@es ;
    ns1:numberOfCredits 6.0 ;
    ns1:otherInformation """Se realizarán durante el curso dos seminarios sobre "Hormigones Innovadores" y "Refuerzo de Estructuras", que acercarán al alumno a la realidad de las obra y serán impartidas por empresas relevantes del sector. Además de organizará el XIII Ciclo de Conferencias en "Innovación Tecnológica en Estructuras" con empresas relevantes en el ámbito del hormigón estructural.
Se trabajará con los alumnos herramientas de IA, como parte de un proyecto de innovación educativa. Además, la asignatura se relacionará con el ODS12 y el ODS13.
Distribución de carga de profesorado: Hosokawa Menéndez, Kenzo Jorge (50%); Prieto Barrio, María Isabel (50%)"""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "74 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/545000038/2025-26/eventSchedule> ;
    schema:description "Se pretende impartir una enseñanza teórico-práctica que adiestre a los alumnos en el diseño, cálculo, comprobación y construcción de las estructuras realizadas con hormigón estructural, apoyándose en el Código Estructural 2021."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/mariaisabel.prieto%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/k.hosokawa%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/mariaisabel.prieto%40upm.es> ;
    schema:name "Hormigon Estructural"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000038/2025-26/CE21> a ns1:Competency ;
    ns1:competencyCode "CE21" ;
    ns1:competencyDescription "Capacidad para aplicar la normativa técnica al proceso de la edificación, y generar documentos de especificación técnica de los procedimientos y métodos constructivos de edificios"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000038/2025-26/CE23> a ns1:Competency ;
    ns1:competencyCode "CE23" ;
    ns1:competencyDescription "Aptitud para el predimensionado, diseño, cálculo y comprobación de estructuras y para dirigir su ejecución material"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000038/2025-26/CG01> a ns1:Competency ;
    ns1:competencyCode "CG01" ;
    ns1:competencyDescription "Dirigir la ejecución material de las obras de edificación, de sus instalaciones y elementos, llevando a cabo el control cualitativo y cuantitativo de lo construido mediante el establecimiento y gestión de los planes de control de materiales, sistemas y ejecución de obra, elaborando los correspondientes registros para su incorporación al Libro del Edificio."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000038/2025-26/CG04> a ns1:Competency ;
    ns1:competencyCode "CG04" ;
    ns1:competencyDescription "Llevar a cabo actividades técnicas de cálculo, mediciones, valoraciones, tasaciones y estudios de viabilidad económica; realizar peritaciones, inspecciones, análisis de patología y otros análogos y redactar los informes, dictámenes y documentos técnicos correspondientes; efectuar levantamientos de planos en solares y edificios."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000038/2025-26/CG05> a ns1:Competency ;
    ns1:competencyCode "CG05" ;
    ns1:competencyDescription "Elaborar los proyectos técnicos y desempeñar la dirección de obras de edificación en el ámbito de su habilitación legal."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000038/2025-26/CG10> a ns1:Competency ;
    ns1:competencyCode "CG10" ;
    ns1:competencyDescription "Asesorar técnicamente en los procesos de fabricación de materiales y elementos utilizados en la construcción de edificios."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000038/2025-26/CT01> a ns1:Competency ;
    ns1:competencyCode "CT01" ;
    ns1:competencyDescription "Trabajo en equipo. Equipos interdisciplinares"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000038/2025-26/CT09> a ns1:Competency ;
    ns1:competencyCode "CT09" ;
    ns1:competencyDescription "Organización y Planificación. Aprendizaje autónomo. Hábito de estudio y método de trabajo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000038/2025-26/RA305> a ns1:LearningResult ;
    ns1:learningResultCode "RA305" ;
    ns1:learningResultDescription "Calcular estructuras de nueva planta de hormigón estructural."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000038/2025-26/RA306> a ns1:LearningResult ;
