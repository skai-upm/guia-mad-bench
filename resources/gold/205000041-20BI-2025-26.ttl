<https://guia-kg.skai.etsisi.upm.es/resource/205000041> a ns1:Course ;
    ns1:courseType "Optativa"@es ;
    ns1:courseYear 3 ;
    ns1:semester "Sexto semestre"@es ;
    schema:courseCode 205000041 ;
    schema:hasCourseInstance <https://guia-kg.skai.etsisi.upm.es/resource/205000041/2025-26> ;
    schema:name "Agricultural Biotechnology"@en,
        "Biotecnología Agrícola"@es ;
    schema:numberOfCredits 3.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/205000041/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/205000041/2025-26/CB02>,
        <https://guia-kg.skai.etsisi.upm.es/resource/205000041/2025-26/CG09>,
        <https://guia-kg.skai.etsisi.upm.es/resource/205000041/2025-26/CT01> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/205000041/2025-26/didactic_resource/1> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/205000041/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/205000041/2025-26/RA109>,
        <https://guia-kg.skai.etsisi.upm.es/resource/205000041/2025-26/RA120>,
        <https://guia-kg.skai.etsisi.upm.es/resource/205000041/2025-26/RA121>,
        <https://guia-kg.skai.etsisi.upm.es/resource/205000041/2025-26/RA122>,
        <https://guia-kg.skai.etsisi.upm.es/resource/205000041/2025-26/RA173>,
        <https://guia-kg.skai.etsisi.upm.es/resource/205000041/2025-26/RA237> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/205000041/2025-26/syllabus> ;
    ns1:inpersonHours "45 horas (55.6%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation """Esta asignatura está vinculada a los Objetivos de Desarrollo Sostenible de Naciones Unidas y a varios retos planteados en su agenda 2030. Las aplicaciones de la Biotecnología tienen gran impacto en los sigueientes retos:
Reto 2 (Hambre 0): el sector alimentario y el sector agricola están intimamnete ligados a la aplicación de la Biotecnología en cuanto a la produccion, rendimientos y calidad de los productos agricolas y sus derivados.
Reto 3 (Salud y Bienestar): produccion de nuevos farmacos, vacunas y productos sanitarios, asi com ode productos derivados de la industria agroalimentaria como aditivos alimentarios generados como alternativa a los de sintesis quimica.
Reto 6 (Aguas limpias): limpieza de aguas y suelos debido mediante control biologico y a la eliminacion de contaminantes del suelo (biorremediación)
Reto 7 (Energia no contaminante): generacin de energias alternativas basadas en biocombustibles (biodiesel, bioetanol y biogas) y produccion de bioplasticos y otros productos alternativos a los dervados de trasnsformaciones quimicas de los combustibles fósiles.

La Comisión de Calidad del Centro en su reunión de 29 de mayo de 2023 acordó aprobar la propuesta de reasignación de competencias transversales en las asignaturas de los Grados en Biotecnología, Ingeniería Alimentaria, Ingeniería Agrícola, Ingeniería Agroambiental, Ciencias Agrarias y Bioeconomía, y en el Máster Universitario en Ingeniería Agronómica.
En virtud de dicho acuerdo esta asignatura ha sido designada como Asignatura NO Punto Control. Esto significa que si bien puede seguir trabajando una o varias competencias transversales que se abordan en distintos puntos y aspectos de la asignatura, dicha formación y evaluación no será objeto de recopilación de evidencias por los sistemas de acreditación de la calidad del Centro."""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "45 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/205000041/2025-26/eventSchedule> ;
    schema:description """Módulo I. (Temas 1-4)
Herramientas Biotecnológicas. Técnicas básicas de Ingeniería Genética. Fundamentos de la transferencia génica a organismos de interés biotecnológico. Nuevas tecnologías de amplia cobertura en la biotecnología (Genómica, Metabolómica y Proteómica). Herramientas bioinformáticas.

Módulo II. (Temas 5-12)
Aplicaciones de la Biotecnología en las Ciencias Agrarias y la Bioeconomia. Mejora de especies vegetales a estreses de tipo biotico y medioambiental. Mejora de la calidad nutritiva de los alimentos. Producción de biomoléculas de interés biotecnológico. Produccion de biocombustibles de origen vegetal."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/jesus.vicente%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/jesus.vicente%40upm.es> ;
    schema:name "Biotecnología Agrícola"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000041/2025-26/CB02> a ns1:Competency ;
    ns1:competencyCode "CB02" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar sus conocimientos a su trabajo o vocación de una forma profesional y posean las competencias que suelen demostrarse por medio de la elaboración y defensa de argumentos y la resolución de problemas dentro de su área de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000041/2025-26/CG09> a ns1:Competency ;
    ns1:competencyCode "CG09" ;
    ns1:competencyDescription "Familiarizarse con los fundamentos de las nuevas tecnologías necesarios para llevar a cabo investigación, gestión de la producción, y desarrollo adecuados a los nuevos retos en el ámbito agrario, incluyendo los aspectos éticos y bioéticos del área."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000041/2025-26/CT01> a ns1:Competency ;
    ns1:competencyCode "CT01" ;
    ns1:competencyDescription "Capacidad para aplicar de forma profesional a su trabajo los conocimientos adquiridos considerando sus impactos en un contexto global y social."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000041/2025-26/RA109> a ns1:LearningResult ;
    ns1:learningResultCode "RA109" ;
    ns1:learningResultDescription "Adquirir conocimientos las principales técnicas de observación y manipulación de microorganismos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000041/2025-26/RA120> a ns1:LearningResult ;
    ns1:learningResultCode "RA120" ;
    ns1:learningResultDescription "Conocer y aplicar herramientas moleculares aplicadas a estudios de análisis genético."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000041/2025-26/RA121> a ns1:LearningResult ;
    ns1:learningResultCode "RA121" ;
    ns1:learningResultDescription "Conocer la información genética desde un punto de vista molecular."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000041/2025-26/RA122> a ns1:LearningResult ;
    ns1:learningResultCode "RA122" ;
    ns1:learningResultDescription "Conocer los mecanismos de expresión génica y su control."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000041/2025-26/RA173> a ns1:LearningResult ;
    ns1:learningResultCode "RA173" ;
    ns1:learningResultDescription "Conocer el marco legal en el que se desarrolla la bioeconomía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000041/2025-26/RA237> a ns1:LearningResult ;
    ns1:learningResultCode "RA237" ;
    ns1:learningResultDescription "Conocer la utilidad de las tecnologías de análisis molecular y genómico en la mejora de plantas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000041/2025-26/didactic_resource/1> a ns1:DidacticResource ;
