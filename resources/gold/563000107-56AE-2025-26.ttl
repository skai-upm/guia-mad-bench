    ns1:itemIndex 11 ;
    ns1:syllabusDescription "2.4. Bus profibús. Diferentes especificaciones. Características. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000107/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "3. Sistemas avanzados de procesos industriales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000107/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "3.1. Introducción a las diferentes tecnologías de automatización de procesos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000107/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "3.2. Fundamentos de los sistemas de fabricación flexible. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000107/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "3.3. Diseño de procesos basados en metodología FMS. Análisis de la flexibilidad. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000107/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "3.4. Simulación y optimización de procesos. Mejora de los diseños flexibles previos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000107/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "3.5. Sistemas avanzados de control y supervisión en la automatización de procesos. Sistemas SCADA. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000107/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "3.6. Sistemas de seguridad. Prevención de riesgos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000107/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Módulos y estructuras complejas. Funciones parametrizables y módulos de datos. Entornos de desarrollo. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000107/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "1.3. E/S analógicas. Monitorización y control de variables continuas de proceso. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000107/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "1.4. Módulos de sistema. Bloques de inicialización. Tratamiento de alarmas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000107/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "1.5. Unidades de comunicaciones. Programación de periferia descentralizada. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000107/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "1.6. Puesta en marcha y depuración de programas. Sin subniveles"@es .

