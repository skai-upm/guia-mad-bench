<https://guia-kg.skai.etsisi.upm.es/resource/53001643/2025-26/MUEI.CT07> a ns1:Competency ;
    ns1:competencyCode "MUEI.CT07" ;
    ns1:competencyDescription "Trabajo en contextos internacionales"@es .

