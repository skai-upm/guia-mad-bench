<https://guia-kg.skai.etsisi.upm.es/resource/65001016/2025-26/CG%201> a ns1:Competency ;
    ns1:competencyCode "CG 1" ;
    ns1:competencyDescription "Conocer y aplicar conocimientos de ciencias y tecnologías básicas a la práctica de la Tecnología Minera."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001016/2025-26/CG%2010> a ns1:Competency ;
    ns1:competencyCode "CG 10" ;
    ns1:competencyDescription "Creatividad."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001016/2025-26/CG%202> a ns1:Competency ;
    ns1:competencyCode "CG 2" ;
    ns1:competencyDescription "Poseer capacidad para diseñar, analizar, calcular, proyectar, construir, mantener, conservar, explotar, desarrollar, implementar, gestionar y mejorar productos, sistemas y procesos en los distintos ámbitos de las Tecnologías Mineras, usando técnicas analíticas, computacionales o experimentales apropiadas, incluyendo la función de asesoría en estos campos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001016/2025-26/CG%203> a ns1:Competency ;
    ns1:competencyCode "CG 3" ;
    ns1:competencyDescription "Aplicar los conocimientos adquiridos para identificar, formular y resolver problemas dentro de contextos amplios y multidisciplinarios, siendo capaces de integrar conocimientos, trabajando en equipos multidisciplinares."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001016/2025-26/CG%204> a ns1:Competency ;
    ns1:competencyCode "CG 4" ;
    ns1:competencyDescription "Comprender el impacto de la tecnología minera en el medio ambiente, el desarrollo sostenible de la sociedad. desarrollando la capacidad para la realización de estudios de ordenación del territorio y de los aspectos medioambientales relacionados con los proyectos, plantas e instalaciones, en su ámbito"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001016/2025-26/CG%205> a ns1:Competency ;
    ns1:competencyCode "CG 5" ;
    ns1:competencyDescription "Saber comunicar los conocimientos y conclusiones, tanto de forma oral, escrita y gráfica, a públicos especializados y no especializados de un modo claro y sin ambigüedades."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001016/2025-26/CG%206> a ns1:Competency ;
    ns1:competencyCode "CG 6" ;
    ns1:competencyDescription "Poseer habilidades de aprendizaje que permitan continuar estudiando a lo largo de la vida para su adecuado desarrollo profesional"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001016/2025-26/CG%207> a ns1:Competency ;
    ns1:competencyCode "CG 7" ;
    ns1:competencyDescription "Incorporar nuevas tecnologías y herramientas de la ingeniería en tecnología minera en sus actividades profesionales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001016/2025-26/F18> a ns1:Competency ;
    ns1:competencyCode "F18" ;
    ns1:competencyDescription "Capacidad para aplicar metodologías de estudios y evaluaciones de impacto ambiental y, en general, de tecnologías ambientales, sostenibilidad y tratamiento de residuos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001016/2025-26/F19> a ns1:Competency ;
    ns1:competencyCode "F19" ;
    ns1:competencyDescription "Capacidad de planificación y gestión integral de obras, mediciones, replanteos, control y seguimiento."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001016/2025-26/RA84> a ns1:LearningResult ;
    ns1:learningResultCode "RA84" ;
    ns1:learningResultDescription "Comprender los fundamentos generales de la gestión del medio ambiente en la empresa, de la evaluación de impacto ambiental y de las técnicas correctoras para la minimización de impactos ambientales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001016/2025-26/RA85> a ns1:LearningResult ;
    ns1:learningResultCode "RA85" ;
    ns1:learningResultDescription "Conocer la legislación, las herramientas y técnicas de análisis, control y gestión medioambiental."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001016/2025-26/RA86> a ns1:LearningResult ;
    ns1:learningResultCode "RA86" ;
    ns1:learningResultDescription "Conocer la problemática de la contaminación atmosférica."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001016/2025-26/RA87> a ns1:LearningResult ;
    ns1:learningResultCode "RA87" ;
    ns1:learningResultDescription "Comprender los fundamentos para la reducción de la contaminación atmosférica."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001016/2025-26/RA88> a ns1:LearningResult ;
    ns1:learningResultCode "RA88" ;
    ns1:learningResultDescription "Conocer la problemática y gestión de los residuos sólidos y líquidos."@es .

