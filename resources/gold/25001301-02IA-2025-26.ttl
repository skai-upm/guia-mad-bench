    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/25001301/2025-26/eventSchedule> ;
    schema:description """Descriptor:
Propiedades del agua y ecuaciones del movimiento de los fluidos en conductos y en medios porosos. Aplicaciones al proyecto de conducciones y de obras especiales. Dispositivos y obras para el aforo, la regulación y el control del agua. El ciclo del agua: evapotranspiración, precipitación, infiltración y generación de escorrentía. Redes de observación, características y selección de sus elementos. Análisis de los datos hidrológicos. Tormentas e hidrogramas posibles, delimitación de zonas con riesgo de inundación, proyecto de desagües, canalizaciones y obras de protección. El agua subterráneo, flujo hacia pozos y ríos, estimación de la evolución de los niveles piezométricos. Ecuaciones de transporte, difusión y dispersión de sustancias"""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/sergio.zubelzu%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/leonor.rodriguez.sinobas%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/raul.sanchez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/sergio.zubelzu%40upm.es> ;
    schema:name "Hidraulica e Hidrologia Ambiental"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001301/2025-26/CE21> a ns1:Competency ;
    ns1:competencyCode "CE21" ;
    ns1:competencyDescription "Capacidad para describir y cuantificar el movimiento del agua y de las sustancias que transporta mediante principios físicos racionales, seleccionar, calibrar y proyectar una red hidrológica de medida y control, y de realizar la modelización de un sistema hidrológico. Capacidad para proyectar medidas correctoras o de protección de las masas de agua en cuencas hidrográficas o en sistemas de explotación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001301/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Que los estudiantes hayan demostrado poseer y comprender conocimientos en un área de estudio que parte de la base de la educación secundaria general, y se suele encontrar a un nivel que, si bien se apoya en libros de texto avanzados, incluye también algunos aspectos que implican conocimientos procedentes de la vanguardia de su campo de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001301/2025-26/CG14> a ns1:Competency ;
    ns1:competencyCode "CG14" ;
    ns1:competencyDescription "Análisis y síntesis, razonamiento crítico y resolución de problemas científicos y técnicos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001301/2025-26/CG15> a ns1:Competency ;
    ns1:competencyCode "CG15" ;
    ns1:competencyDescription "Adaptación a cambios tecnológicos y motivación por la calidad"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001301/2025-26/CG5> a ns1:Competency ;
    ns1:competencyCode "CG5" ;
    ns1:competencyDescription "Que los estudiantes hayan desarrollado aquellas habilidades de aprendizaje necesarias para emprender estudios posteriores con un alto grado de autonomía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001301/2025-26/RA113> a ns1:LearningResult ;
    ns1:learningResultCode "RA113" ;
    ns1:learningResultDescription "Capacidad para explicar y expresar los principios del movimiento del agua y de las sustancias que transporta."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001301/2025-26/RA114> a ns1:LearningResult ;
    ns1:learningResultCode "RA114" ;
    ns1:learningResultDescription "Capacidad para resolver las ecuaciones y cuantificar la incertidumbre de datos y resultados."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001301/2025-26/RA115> a ns1:LearningResult ;
    ns1:learningResultCode "RA115" ;
    ns1:learningResultDescription "Conocimiento de dispositivos e instalaciones de medida y control, así como de los criterios para su selección, instalación y calibración."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001301/2025-26/RA116> a ns1:LearningResult ;
    ns1:learningResultCode "RA116" ;
    ns1:learningResultDescription "Capacidad para proyectar obras de captación, conducción y distribución de agua así como de medidas de restauración y protección de cuencas hidrográficas o de masas de agua en sistemas de explotación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001301/2025-26/RA117> a ns1:LearningResult ;
    ns1:learningResultCode "RA117" ;
    ns1:learningResultDescription "Capacidad para emitir informes sobre estudios hidrológicos y de gestión de recursos hídricos y y de manejo integral de cuencas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001301/2025-26/RA118> a ns1:LearningResult ;
    ns1:learningResultCode "RA118" ;
    ns1:learningResultDescription "Conocimientos sobre el estado actual y los retos científicos y tecnológicos de la hidráulica y de la hidrología en su entorno ambiental y socioeconómico y para discutir la posible evolución futura."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001301/2025-26/RA438> a ns1:LearningResult ;
    ns1:learningResultCode "RA438" ;
    ns1:learningResultDescription "Capacidad para programar rutinas informáticas para calcular fenómenos y procesos hidráulicos e hidrológicos."@es .

