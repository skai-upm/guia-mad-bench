<https://guia-kg.skai.etsisi.upm.es/resource/45001437/2025-26/CM40.2> a ns1:Competency ;
    ns1:competencyCode "CM40.2" ;
    ns1:competencyDescription "Comprensión del fenómeno urbano y sus factores determinantes (historia, economía, actividad humana, movilidad)."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001437/2025-26/CT3> a ns1:Competency ;
    ns1:competencyCode "CT3" ;
    ns1:competencyDescription "Capacidad de actuar con efectividad como miembro de equipos interdisciplinares. Desarrolla la competencia transversal 5ª de la normativa UPM."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001437/2025-26/CT4> a ns1:Competency ;
    ns1:competencyCode "CT4" ;
    ns1:competencyDescription "Capacidad de preparar y presentar con efectividad comunicaciones orales, escritas y gráficas. Completa el desarrollo de la competencia transversal 4ª del real decreto y desarrolla la competencia transversal 2ª de la normativa UPM."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001437/2025-26/RA101> a ns1:LearningResult ;
    ns1:learningResultCode "RA101" ;
    ns1:learningResultDescription "Explica el fenómeno urbano y sus factores determinantes (historia, economía, actividad humana, movilidad)."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001437/2025-26/RA102> a ns1:LearningResult ;
    ns1:learningResultCode "RA102" ;
    ns1:learningResultDescription "Identifica la influencia de las infraestructuras en la ordenación del territorio, el urbanismo y los servicios urbanos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001437/2025-26/RA103> a ns1:LearningResult ;
    ns1:learningResultCode "RA103" ;
    ns1:learningResultDescription "Valora los efectos social, económico, ambiental, político y globalizador de los sistemas de transporte, el urbanismo y la ordenación territorial."@es .

