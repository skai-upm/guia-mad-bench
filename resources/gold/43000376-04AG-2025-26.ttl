<https://guia-kg.skai.etsisi.upm.es/resource/43000376/2025-26/CB06> a ns1:Competency ;
    ns1:competencyCode "CB06" ;
    ns1:competencyDescription "Poseer y comprender conocimientos que aporten una base u oportunidad de ser originales en el desarrollo y/o aplicación de ideas, a menudo en un contexto de investigación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000376/2025-26/CB07> a ns1:Competency ;
    ns1:competencyCode "CB07" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en entornos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000376/2025-26/CB08> a ns1:Competency ;
    ns1:competencyCode "CB08" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de integrar conocimientos y enfrentarse a la complejidad de formular juicios a partir de una información que, siendo incompleta o limitada, incluya reflexiones sobre las responsabilidades sociales y éticas vinculadas a la aplicación de sus conocimientos y juicios"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000376/2025-26/CB10> a ns1:Competency ;
    ns1:competencyCode "CB10" ;
    ns1:competencyDescription "Que los estudiantes posean las habilidades de aprendizaje que les permitan continuar estudiando de un modo que habrá de ser en gran medida autodirigido o autónomo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000376/2025-26/CE33> a ns1:Competency ;
    ns1:competencyCode "CE33" ;
    ns1:competencyDescription "Capacidad para aplicar los conocimientos técnicos en actividades de I+D+i dentro del ámbito de la ingeniería civil."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000376/2025-26/CE37> a ns1:Competency ;
    ns1:competencyCode "CE37" ;
    ns1:competencyDescription "Capacidad para integrar y aplicar los conocimientos técnicos en asesoría, mantenimiento, conservación, evaluación técnica, explotación, evaluación histórico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000376/2025-26/CE40> a ns1:Competency ;
    ns1:competencyCode "CE40" ;
    ns1:competencyDescription "Capacidad de aplicación integral de conocimientos en asesoría, análisis, diseño, cálculo, construcción, mantenimiento, conservación, explotación, gestión legal, gestión empresarial, planificación y gestión técnica de infraestructuras y sistemas de transporte."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000376/2025-26/CGP01> a ns1:Competency ;
    ns1:competencyCode "CGP01" ;
    ns1:competencyDescription "Capacitación científico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000376/2025-26/CGP06> a ns1:Competency ;
    ns1:competencyCode "CGP06" ;
    ns1:competencyDescription "Conocimiento para aplicar las capacidades técnicas y gestoras en actividades de I+D+i dentro del ámbito de la ingeniería civil. Incorpora las competencias CB6, CB7 y CB8."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000376/2025-26/CGP17> a ns1:Competency ;
    ns1:competencyCode "CGP17" ;
    ns1:competencyDescription "Capacidad de aplicación de técnicas de gestión empresarial y legislación laboral. Incorpora las competencias CB6, CB7 y CB8."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000376/2025-26/CT2> a ns1:Competency ;
    ns1:competencyCode "CT2" ;
    ns1:competencyDescription "Polivalencia y capacidad de aprendizaje autónomo. Desarrolla la competencia transversal 5ª del Real Decreto."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000376/2025-26/CT7> a ns1:Competency ;
    ns1:competencyCode "CT7" ;
    ns1:competencyDescription "Capacidad de utilización de los servicios de información y comunicación para el ejercicio de las funciones profesionales del perfil de egreso. Desarrolla la competencia transversal 3ª de la normativa UPM."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000376/2025-26/RA5> a ns1:LearningResult ;
    ns1:learningResultCode "RA5" ;
    ns1:learningResultDescription "Conoce los fundamentos económicos teóricos y metodológicos de las técnicas de financiación, planificación, explotación, y gestión empresarial y laboral aplicadas a las infraestructuras y servicios de ingeniería civil."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000376/2025-26/didactic_resource/1> a ns1:DidacticResource ;
    ns1:bibliographyTitle "Varian, H.R.: Microeconomía Intermedia. Antoni Bosch ed."@es ;
    ns1:bibliographyType "Bibliografía"@es .

