    ns1:bibliographyTitle "Stiglitz, J.: Macroeconomía. Ed. Ariel, 2004"@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000376/2025-26/didactic_resource/4> a ns1:DidacticResource ;
    ns1:bibliographyTitle "López Corral, Antonio M. y Sánchez Soliño, A. (2000): Economía Pública e infraestructuras. Servicio de Publicaciones de la E.T.S. de Ingenieros de Caminos de Madrid"@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000376/2025-26/didactic_resource/5> a ns1:DidacticResource ;
