    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/143005028/2025-26/eventSchedule> ;
    schema:description """La asignatura tiene como objetivo conocer la dinámica de cualquier aeronave y como obtener los modelos matemáticos de la misma. A partir de estos modelos, la asignatura introduce los conceptos de control automático y como aplicarlos a la estabilidad y control de cualquier aeronave en vuelo.
Además la asignatura introduce aquellos aspectos relacionados con las técnicas clásicas y modernas de control automático."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/javier.crespo%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/angel.rodriguez.sevillano%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/javier.crespo%40upm.es> ;
    schema:name "Control de Vehiculos Aeroespaciales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005028/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Poseer y comprender conocimientos que aporten una base u oportunidad de ser originales en el desarrollo de nuevos conceptos y técnicas aplicados al Sistema del Transporte Aéreo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005028/2025-26/CG2> a ns1:Competency ;
    ns1:competencyCode "CG2" ;
    ns1:competencyDescription "Aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en los entornos de evolución previstos en los Sistemas de Transporte Aéreo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005028/2025-26/CG6> a ns1:Competency ;
    ns1:competencyCode "CG6" ;
    ns1:competencyDescription "Que los estudiantes posean las habilidades de aprendizaje que les permitan continuar estudiando de un modo que habrá de ser en gran medida autodirigido o autónomo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005028/2025-26/RA130> a ns1:LearningResult ;
    ns1:learningResultCode "RA130" ;
    ns1:learningResultDescription "El alumno conoce, comprende los modelos matemáticos de aeronaves"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005028/2025-26/RA131> a ns1:LearningResult ;
    ns1:learningResultCode "RA131" ;
    ns1:learningResultDescription "El alumno posee la capacidad de analizar la estabilidad de un sistema de vuelo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005028/2025-26/RA132> a ns1:LearningResult ;
    ns1:learningResultCode "RA132" ;
    ns1:learningResultDescription "El alumno alcanza a conocer el procedimiento de diseño de un sistema de control aplicado a aeronaves"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005028/2025-26/RA26> a ns1:LearningResult ;
    ns1:learningResultCode "RA26" ;
    ns1:learningResultDescription "El alumno conoce y comprende los sistemas fundamentales de los equipos embarcados de aviónica, sus instalaciones eléctricas y electrónicas asociadas y los principios del control automático de vuelo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005028/2025-26/RA37> a ns1:LearningResult ;
    ns1:learningResultCode "RA37" ;
    ns1:learningResultDescription "Conocimiento, comprensión, aplicación, análisis y síntesis de los métodos aplicados a la optimización y control de sistemas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005028/2025-26/RA89> a ns1:LearningResult ;
    ns1:learningResultCode "RA89" ;
    ns1:learningResultDescription "El alumno conoce las técnicas de cálculo variacional de resolución de problemas de control óptimo"@es .

