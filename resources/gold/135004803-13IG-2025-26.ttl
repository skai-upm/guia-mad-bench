        <https://guia-kg.skai.etsisi.upm.es/resource/ana.hernando%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/antonio.garcia.abril%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/carlos.iglesias%40upm.es> ;
    schema:name "Proyectos de Ingenieria, Evalucion y Correccion de Impactos Ambientales"@es .

