    ns1:itemIndex 11 ;
    ns1:syllabusDescription "12. Conos. Generalidades. Representación. Secciones planas. Elíptica, Parabólica e Hiperbólica. Intersección con una recta. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000003/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "13. Cilindros. Generalidades. Representación. Secciones planas. Elíptica, Parabólica e Hiperbólica. Intersección con una recta. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000003/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "14. Intersección de superficies. Tipos y casos generales. Método general. Tipos: penetración, mordedura, simple tangencia y doble tangencia. Tipos y Casos particulares. Métodos de resolución. Sin subniveles"@es .

