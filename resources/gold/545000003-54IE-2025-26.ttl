    ns1:itemIndex 4 ;
    ns1:syllabusDescription "5. Perpendicularidad. Distancias. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000003/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "6. Ángulos. Ángulo de recta y plano. Ángulo de dos planos. Problemas inversos de ángulos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000003/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "7. Estudio de superficies - Prisma y Pirámide. Generación. Representación. Sección plana. Intersección con una recta. Sin subniveles"@es .

