<https://guia-kg.skai.etsisi.upm.es/resource/53001905/2025-26/MUCTN.CB06> a ns1:Competency ;
    ns1:competencyCode "MUCTN.CB06" ;
    ns1:competencyDescription "Poseer y comprender conocimientos que aporten una base u oportunidad de ser originales en el desarrollo y/o aplicación de ideas, a menudo en un contexto de investigación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001905/2025-26/MUCTN.CB07> a ns1:Competency ;
    ns1:competencyCode "MUCTN.CB07" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en entornos nuevos o poco conocidos dentro de contextos más amplios (o multidisciplinares) relacionados con su área de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001905/2025-26/MUCTN.CB10> a ns1:Competency ;
    ns1:competencyCode "MUCTN.CB10" ;
    ns1:competencyDescription "Que los estudiantes posean las habilidades de aprendizaje que les permitan continuar estudiando de un modo que habrá de ser en gran medida autodirigido o autónomo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001905/2025-26/MUCTN.CT01> a ns1:Competency ;
    ns1:competencyCode "MUCTN.CT01" ;
    ns1:competencyDescription "Aplica. Habilidad para aplicar conocimientos científicos, matemáticos y tecnológicos en sistemas relacionados con la práctica de la ingeniería"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001905/2025-26/MUCTN.CT05> a ns1:Competency ;
    ns1:competencyCode "MUCTN.CT05" ;
    ns1:competencyDescription "Resuelve. Habilidad para identificar, formular y resolver problemas de ingeniería"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001905/2025-26/MUCTN.CT09> a ns1:Competency ;
    ns1:competencyCode "MUCTN.CT09" ;
    ns1:competencyDescription "Se actualiza. Reconocimiento de la necesidad y la habilidad para comprometerse al aprendizaje continuo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001905/2025-26/MUCTN.CT11> a ns1:Competency ;
    ns1:competencyCode "MUCTN.CT11" ;
    ns1:competencyDescription "Usa herramientas. Habilidad para usar las técnicas, destrezas y herramientas ingenieriles modernas necesarias para la práctica de la ingeniería"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001905/2025-26/MUII.CE04> a ns1:Competency ;
    ns1:competencyCode "MUII.CE04" ;
    ns1:competencyDescription "Capacidad para el análisis y diseño de procesos químicos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001905/2025-26/MUII.CG01> a ns1:Competency ;
    ns1:competencyCode "MUII.CG01" ;
    ns1:competencyDescription "Tener conocimientos adecuados de los aspectos científicos y tecnológicos de: métodos matemáticos, analíticos y numéricos en la ingeniería, ingeniería eléctrica, ingeniería energética, ingeniería química, ingeniería mecánica, mecánica de medios continuos, electrónica industrial, automática, fabricación, materiales, métodos cuantitativos de gestión, informática industrial, urbanismo, infraestructuras, etc."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001905/2025-26/MUII.CG06> a ns1:Competency ;
    ns1:competencyCode "MUII.CG06" ;
    ns1:competencyDescription "Gestionar técnica y económicamente proyectos, instalaciones, plantas, empresas y centros tecnológicos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001905/2025-26/MUII.CG08> a ns1:Competency ;
    ns1:competencyCode "MUII.CG08" ;
    ns1:competencyDescription "Aplicar los conocimientos adquiridos y resolver problemas en entornos nuevos o poco conocidos dentro de contextos más amplios y multidisciplinares."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001905/2025-26/MUII.CG11> a ns1:Competency ;
    ns1:competencyCode "MUII.CG11" ;
    ns1:competencyDescription "Poseer las habilidades de aprendizaje que permitan continuar estudiando de un modo autodirigido o autónomo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001905/2025-26/RA75> a ns1:LearningResult ;
    ns1:learningResultCode "RA75" ;
    ns1:learningResultDescription "Identificar, analizar, e interpretar los datos del problema planteado por el profesor"@es .

