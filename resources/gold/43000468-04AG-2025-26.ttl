<https://guia-kg.skai.etsisi.upm.es/resource/43000468/2025-26/CE23> a ns1:Competency ;
    ns1:competencyCode "CE23" ;
    ns1:competencyDescription "Conocimiento de todo tipo de estructuras y sus materiales, y capacidad para diseñar, proyectar, ejecutar y mantener las estructuras y edificaciones de obra civil."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000468/2025-26/CE30> a ns1:Competency ;
    ns1:competencyCode "CE30" ;
    ns1:competencyDescription "Capacidad de planificación, gestión y explotación de infraestructuras relacionadas con la ingeniería civil."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000468/2025-26/CE32> a ns1:Competency ;
    ns1:competencyCode "CE32" ;
    ns1:competencyDescription "Capacidad para aplicar los conocimientos técnicos en la evaluación de proyectos, obras e infraestructuras dentro del ámbito de la ingeniería civil."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000468/2025-26/CE34> a ns1:Competency ;
    ns1:competencyCode "CE34" ;
    ns1:competencyDescription "Capacidad para integrar y aplicar los conocimientos técnicos en asesoría, análisis, cálculo, proyecto, construcción, y evaluación técnica de infraestructuras de ingeniería civil."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000468/2025-26/CGP12> a ns1:Competency ;
    ns1:competencyCode "CGP12" ;
    ns1:competencyDescription "Capacidad para planificar, diseñar y gestionar infraestructuras, así como su mantenimiento, conservación y explotación. Incorpora las competencias CB6, CB7 y CB8."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000468/2025-26/CT1> a ns1:Competency ;
    ns1:competencyCode "CT1" ;
    ns1:competencyDescription "Capacidad de preparar y presentar comunicaciones orales, escritas y gráficas, estructurada y argumentadamente. Desarrolla la competencia transversal 4ª del Real Decreto."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000468/2025-26/CT4> a ns1:Competency ;
    ns1:competencyCode "CT4" ;
    ns1:competencyDescription "Capacidad de organizar y dirigir los esfuerzos de un equipo. Desarrolla la competencia transversal 5ª de la normativa UPM."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000468/2025-26/CT7> a ns1:Competency ;
    ns1:competencyCode "CT7" ;
    ns1:competencyDescription "Capacidad de utilización de los servicios de información y comunicación para el ejercicio de las funciones profesionales del perfil de egreso. Desarrolla la competencia transversal 3ª de la normativa UPM."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000468/2025-26/RA130> a ns1:LearningResult ;
    ns1:learningResultCode "RA130" ;
    ns1:learningResultDescription "Identificar la problemática particular de realizar un proyecto y la completa definición del mismo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000468/2025-26/RA131> a ns1:LearningResult ;
    ns1:learningResultCode "RA131" ;
    ns1:learningResultDescription "Entender el nuevo panorama profesional del proyecto que se está vertebrando en la actualidad y que en lo sucesivo marcará el nuevo marco de actividad laboral de la construcción y de la ingeniería civil."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000468/2025-26/RA132> a ns1:LearningResult ;
    ns1:learningResultCode "RA132" ;
    ns1:learningResultDescription "Emplear nuevos lenguajes y tecnologías de trabajo colaborativo para la planificación, diseño y gestión de proyectos de construcción."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000468/2025-26/RA133> a ns1:LearningResult ;
    ns1:learningResultCode "RA133" ;
    ns1:learningResultDescription "Planificar, organizar y dirigir la ejecución de obras de construcción, así como de su mantenimiento"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000468/2025-26/RA134> a ns1:LearningResult ;
    ns1:learningResultCode "RA134" ;
    ns1:learningResultDescription "Comprender y solucionar problemas de gran complejidad derivados de los nuevos paradigmas de demanda a los profesionales de la ingeniería civil"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000468/2025-26/RA135> a ns1:LearningResult ;
    ns1:learningResultCode "RA135" ;
    ns1:learningResultDescription "Emplear herramientas de control y edición de la información en la red de interés para la ingeniería civil"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000468/2025-26/RA136> a ns1:LearningResult ;
    ns1:learningResultCode "RA136" ;
    ns1:learningResultDescription "Estructurar procedimientos, técnicas y estrategias competitivas para el acceso al encargo profesional."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000468/2025-26/RA137> a ns1:LearningResult ;
    ns1:learningResultCode "RA137" ;
    ns1:learningResultDescription "Capacidad de intercambio y de interconexión con estructuras de trabajo internacional a partir de las herramientas de la metodología conocida como Building Information Modelling (BIM)"@es .

