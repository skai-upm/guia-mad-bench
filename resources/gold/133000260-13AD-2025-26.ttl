    ns1:competencyDescription "Búsqueda bibliográfica, análisis de documentación y tratamiento de la información procedente de diversas fuentes y de su análisis y síntesis aplicándola a la resolución de problemas complejos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000260/2025-26/RA152> a ns1:LearningResult ;
    ns1:learningResultCode "RA152" ;
    ns1:learningResultDescription "Identificar y describir las principales especies utilizadas en el bosque urbano, y aplicar criterios técnicos y ecológicos en el uso de estas especies"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000260/2025-26/RA153> a ns1:LearningResult ;
    ns1:learningResultCode "RA153" ;
    ns1:learningResultDescription "Conocer las bases técnicas para el mantenimiento y conservación de árboles urbanos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000260/2025-26/RA154> a ns1:LearningResult ;
    ns1:learningResultCode "RA154" ;
    ns1:learningResultDescription "Identificar los condicionantes ecológicos, económicos y sociológicos de la problemática de la gestión del arbolado en el entorno urbano"@es .

