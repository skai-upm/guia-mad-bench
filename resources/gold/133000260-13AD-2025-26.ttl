<https://guia-kg.skai.etsisi.upm.es/resource/133000260/2025-26/syllabus> a ns1:Syllabus ;
    ns1:hasItem <https://guia-kg.skai.etsisi.upm.es/resource/133000260/2025-26/syllabus/0>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000260/2025-26/syllabus/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000260/2025-26/syllabus/2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000260/2025-26/syllabus/3>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000260/2025-26/syllabus/4>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000260/2025-26/syllabus/5>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000260/2025-26/syllabus/6> .

<https://guia-kg.skai.etsisi.upm.es/resource/133000260/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Bosque urbano e infraestructuras verdes: Introducción, tipologías, servicios ecosistémicos de los bosques urbanos Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000260/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "2. El ecosistema urbano: El suelo en la ciudad. Efecto de la ciudad en el clima, la isla de calor Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000260/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "3. Botánica urbana: conservación y biodiversidad: Flora ornamental y vegetación urbana. Biodiversidad y especies invasoras. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000260/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "4. Selvicultura del bosque urbano. Toma de datos, censo e inventario. Valoración del bosque urbano: el ejemplo de la ciudad de Madrid Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000260/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "5. Riesgo y daños en arbolado. Plantación. Mantenimiento del arbolado urbano, tratamientos selvícolas y podas. Técnicas de tala. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000260/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "6. Planificación y gestión Elección de objetivos en los planes de manejo. Programación y ejecución de trabajos. Principios de gestión de sanidad vegetal Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000260/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "7. Comunicación y participación. Sin subniveles"@es .

