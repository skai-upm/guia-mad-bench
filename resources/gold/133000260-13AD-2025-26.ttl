    ns1:competencyCode "CE 6.1" ;
    ns1:competencyDescription "Capacidad para la gestion de recursos naturales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000260/2025-26/CT01> a ns1:Competency ;
    ns1:competencyCode "CT01" ;
    ns1:competencyDescription "Habilidades de comunicación escrita y oral"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000260/2025-26/CT06> a ns1:Competency ;
