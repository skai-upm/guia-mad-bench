<https://guia-kg.skai.etsisi.upm.es/resource/133000353/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/133000353/2025-26/CB06>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000353/2025-26/CB07>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000353/2025-26/CB08>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000353/2025-26/CE%206.1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000353/2025-26/CE%206.2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000353/2025-26/CT01>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000353/2025-26/CT10> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/133000353/2025-26/didactic_resource/1> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/133000353/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/133000353/2025-26/RA207> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/133000353/2025-26/syllabus> ;
    ns1:inpersonHours "40 horas (51.3%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation """Esta asignatura es optativa
Las competencias y los resultados de aprendizaje de esta asignatura son conforme con la memoria que verifica el título ."""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "41 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/133000353/2025-26/eventSchedule> ;
    schema:description """Se estudian los tres principios fundamentales de la Termodinámica (Principio Cero, Primer Principio, Segundo Principio y
Tercer Principio) y sus principales aplicados a los sistemas biológicos.
Se estudia la Termodinámica de los Procesos Irreversibles y sus aplicaciones a los seres vivos.
En especial se estudia la relación de estos principios con los procesos vitales."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/francisco.marcos%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/c.pascual%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/francisco.marcos%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/m.quintanilla%40upm.es> ;
    schema:name "Termodinámica y Vida"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000353/2025-26/CB06> a ns1:Competency ;
    ns1:competencyCode "CB06" ;
    ns1:competencyDescription "Poseer y comprender conocimientos que aporten una base u oportunidad de ser originales en el desarrollo y/o apl0icación de ideas, a menudo en un contexto de investigación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000353/2025-26/CB07> a ns1:Competency ;
    ns1:competencyCode "CB07" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en entornos nuevos o poco conocidos dentro de contextos más amplios (o multidisciplinares) relacionados con su área de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000353/2025-26/CB08> a ns1:Competency ;
    ns1:competencyCode "CB08" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de integrar conocimientos y enfrentarse a la complejidad de formular juicios a partir de una información que, siendo incompleta o limitada, incluya reflexiones sobre las responsabilidades sociales y éticas vinculadas a la aplicación de sus conocimientos y juicios"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000353/2025-26/CE%206.1> a ns1:Competency ;
    ns1:competencyCode "CE 6.1" ;
    ns1:competencyDescription "Capacidad para la gestion de recursos naturales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000353/2025-26/CE%206.2> a ns1:Competency ;
    ns1:competencyCode "CE 6.2" ;
    ns1:competencyDescription "Conocimientos y habilidades para la mejora ambiental del medio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000353/2025-26/CT01> a ns1:Competency ;
    ns1:competencyCode "CT01" ;
    ns1:competencyDescription "Habilidades de comunicación escrita y oral"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000353/2025-26/CT10> a ns1:Competency ;
    ns1:competencyCode "CT10" ;
    ns1:competencyDescription "Valores humanos positivos: Respeto a los derechos humanos fundamentales; los principios de igualdad de oportunidades, accesibilidad universal y no discriminación; y los valores propios de una cultura de paz y de valores democráticos. Compromiso con estos derechos, principios y valores, motivación, actitud positiva y entusiasta; ética, integridad y honestidad profesional"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000353/2025-26/RA207> a ns1:LearningResult ;
    ns1:learningResultCode "RA207" ;
    ns1:learningResultDescription "Conocer las relaciones y las aplicaciones de los principios de la Termodinámica relacionados con la vida"@es .

