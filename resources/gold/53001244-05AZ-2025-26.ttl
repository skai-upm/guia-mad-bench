        <https://guia-kg.skai.etsisi.upm.es/resource/rosamaria.decastro%40upm.es> ;
    schema:name "Instalaciones Electricas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001244/2025-26/%28a%29> a ns1:Competency ;
    ns1:competencyCode "(a)" ;
    ns1:competencyDescription "APLICA. Habilidad para aplicar conocimientos científicos, matemáticos y tecnológicos en sistemas relacionados con la práctica de la ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001244/2025-26/%28b%29> a ns1:Competency ;
    ns1:competencyCode "(b)" ;
    ns1:competencyDescription "EXPERIMENTA. Habilidad para diseñar y realizar experimentos así como analizar e interpretar datos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001244/2025-26/%28c%29> a ns1:Competency ;
    ns1:competencyCode "(c)" ;
    ns1:competencyDescription "DISEÑA. Habilidad para diseñar un sistema, componente o proceso que alcance los requisitos deseados teniendo en cuenta restricciones realistas tales como las económicas, medioambientales, sociales, políticas, éticas, de salud y seguridad, de fabricación y de sostenibilidad."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001244/2025-26/%28d%29> a ns1:Competency ;
    ns1:competencyCode "(d)" ;
    ns1:competencyDescription "TRABAJA EN EQUIPO. Habilidad para trabajar en equipos multidisciplinares."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001244/2025-26/%28e%29> a ns1:Competency ;
    ns1:competencyCode "(e)" ;
    ns1:competencyDescription "RESUELVE. Habilidad para identificar, formular y resolver problemas de ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001244/2025-26/%28f%29> a ns1:Competency ;
    ns1:competencyCode "(f)" ;
    ns1:competencyDescription "ES RESPONSABLE. Comprensión de la responsabilidad ética y profesional."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001244/2025-26/%28g%29> a ns1:Competency ;
    ns1:competencyCode "(g)" ;
    ns1:competencyDescription "COMUNICA. Habilidad para comunicar eficazmente."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001244/2025-26/%28h%29> a ns1:Competency ;
    ns1:competencyCode "(h)" ;
    ns1:competencyDescription "ENTIENDE LOS IMPACTOS. Educación amplia necesaria para entender el impacto de las soluciones ingenieriles en un contexto social global."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001244/2025-26/%28i%29> a ns1:Competency ;
    ns1:competencyCode "(i)" ;
    ns1:competencyDescription "SE ACTUALIZA. Reconocimiento de la necesidad y la habilidad para comprometerse al aprendizaje continuo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001244/2025-26/%28j%29> a ns1:Competency ;
    ns1:competencyCode "(j)" ;
    ns1:competencyDescription "CONOCE. Conocimiento de los temas contemporáneos."@es .

