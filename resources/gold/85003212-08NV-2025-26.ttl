    ns1:competencyCode "CT UPM 3" ;
    ns1:competencyDescription "Comunicación oral y escrita"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003212/2025-26/RA1> a ns1:LearningResult ;
    ns1:learningResultCode "RA1" ;
    ns1:learningResultDescription "Resolver problemas de electromagnetismo, ondas electromagnéticas, termodinámica y óptica relacionados con la ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003212/2025-26/RA11> a ns1:LearningResult ;
    ns1:learningResultCode "RA11" ;
    ns1:learningResultDescription "Conocer el significado y las unidades de las magnitudes físicas, así como su orden de magnitud y resolver problemas básicos de ingeniería, expresando el resultado numérico en las unidades físicas correspondientes."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003212/2025-26/RA3> a ns1:LearningResult ;
    ns1:learningResultCode "RA3" ;
    ns1:learningResultDescription "Utilizar correctamente métodos básicos de medida experimental, así como tratar adecuadamente los datos, relacionándolos con las leyes físicas apropiadas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003212/2025-26/RA4> a ns1:LearningResult ;
    ns1:learningResultCode "RA4" ;
    ns1:learningResultDescription "Comprender y aplicar los conceptos fundamentales del electromagnetismo a la resolución de problemas básicos de campos eléctricos y magnéticos, así como de circuitos eléctricos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003212/2025-26/RA5> a ns1:LearningResult ;
    ns1:learningResultCode "RA5" ;
    ns1:learningResultDescription "Resolver las ecuaciones de Maxwell para la propagación de campos eléctricos y magnéticos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003212/2025-26/RA6> a ns1:LearningResult ;
    ns1:learningResultCode "RA6" ;
    ns1:learningResultDescription "Comprender los conceptos fundamentales de la óptica geométrica, física y electromagnética."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003212/2025-26/RA7> a ns1:LearningResult ;
    ns1:learningResultCode "RA7" ;
    ns1:learningResultDescription "Comprender el concepto estadístico de temperatura, aplicándolo a los gases ideales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003212/2025-26/RA8> a ns1:LearningResult ;
    ns1:learningResultCode "RA8" ;
    ns1:learningResultDescription "Comprender los conceptos básicos de la Termodinámica y aplicarlos a problemas de interés en ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003212/2025-26/RA9> a ns1:LearningResult ;
    ns1:learningResultCode "RA9" ;
    ns1:learningResultDescription "Conocer y aplicar los Principios de la Termodinámica a procesos térmicos."@es .

