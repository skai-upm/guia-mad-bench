    ns1:competencyDescription "Poseer y comprender conocimientos que aporten una base u oportunidad de ser originales en el desarrollo y/o apl0icación de ideas, a menudo en un contexto de investigación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000236/2025-26/CE%202.1> a ns1:Competency ;
    ns1:competencyCode "CE 2.1" ;
    ns1:competencyDescription "Conocimiento y capacidad para diseñar planes de desarrollo integral sostenible de comarcas forestales y el desarrollo de indicadores de gestión"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000236/2025-26/CE%202.2> a ns1:Competency ;
    ns1:competencyCode "CE 2.2" ;
    ns1:competencyDescription "Capacidad para diseñar y redactar planes de declaración y/o ordenación de espacios naturales protegidos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000236/2025-26/CE%202.3> a ns1:Competency ;
    ns1:competencyCode "CE 2.3" ;
    ns1:competencyDescription "Capacidad para la elaboración de Planes de Ordenación del Territorio, Áreas de Montaña y Zonas Costeras"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000236/2025-26/CE%202.4> a ns1:Competency ;
    ns1:competencyCode "CE 2.4" ;
    ns1:competencyDescription "Capacidad para la planificación hidrólogica y la lucha contra la desertificación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000236/2025-26/CT02> a ns1:Competency ;
    ns1:competencyCode "CT02" ;
    ns1:competencyDescription "Integrar los conocimientos previos (propios de grado) de manera crítica y relacionada de forma que se puedan aplicar al estudio de situaciones reales y a la propuesta de alternativas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000236/2025-26/CT04> a ns1:Competency ;
    ns1:competencyCode "CT04" ;
    ns1:competencyDescription "Capacidad crítica para el análisis, la síntesis y el aprendizaje mediante el intercambio de opiniones, presentando argumentos sólidos y estructurados"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000236/2025-26/RA80> a ns1:LearningResult ;
    ns1:learningResultCode "RA80" ;
    ns1:learningResultDescription "Tener la capacidad de reunir e interpretar datos del medio físico de los sistemas forestales que son condicionantes de las actividades propias de la ingeniería de montes"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000236/2025-26/RA81> a ns1:LearningResult ;
    ns1:learningResultCode "RA81" ;
    ns1:learningResultDescription "Comprender la importancia de los aspectos del medio físico en la planificación y ejecución de la actividad forestal"@es .

