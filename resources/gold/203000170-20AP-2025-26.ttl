    schema:courseCode 203000170 ;
    schema:hasCourseInstance <https://guia-kg.skai.etsisi.upm.es/resource/203000170/2025-26> ;
    schema:name "Soil Map For Precision Agriculture"@en,
        "Mapa de Suelos para Agricultura de Precisión"@es ;
    schema:numberOfCredits 4.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/203000170/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/203000170/2025-26/C4>,
        <https://guia-kg.skai.etsisi.upm.es/resource/203000170/2025-26/CEH2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/203000170/2025-26/CEH6>,
        <https://guia-kg.skai.etsisi.upm.es/resource/203000170/2025-26/CT01>,
        <https://guia-kg.skai.etsisi.upm.es/resource/203000170/2025-26/CT02> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/203000170/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/203000170/2025-26/didactic_resource/2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/203000170/2025-26/didactic_resource/3>,
        <https://guia-kg.skai.etsisi.upm.es/resource/203000170/2025-26/didactic_resource/4> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/203000170/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/203000170/2025-26/RA17>,
        <https://guia-kg.skai.etsisi.upm.es/resource/203000170/2025-26/RA7>,
        <https://guia-kg.skai.etsisi.upm.es/resource/203000170/2025-26/RA8> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/203000170/2025-26/syllabus> ;
    ns1:inpersonHours "40 horas (38.5%)"@es ;
    ns1:numberOfCredits 4.0 ;
    ns1:otherInformation "La asignatura se relaciona con el ODS12 y con el OD15, al promover, a través del conocimiento exhaustivo del suelo y su distribución, una producción sostenible que detenga e incluso invierta la degradación de tierras."@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "40 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/203000170/2025-26/eventSchedule> ;
    schema:description """La asignatura se concreta en la sistematización de los conocimientos de alumno/a y la formación de una base de datos relacionada con el clima, la geología, la vegetación y el suelo que sirve de partida para la creación de un Sistema de Información Geográfica (SIG/GIS) que permite el análisis y evaluación de un medio agrario concreto para la implementación de sistemas de agricultura de precisión. Se reduce a los siguientes ítems:
Reconocimiento de Suelos: adquisición y sistematización de datos de campo y laboratorio
Sistemas de clasificación del suelo (Unidad taxonómicas del mapa)
Técnicas de cartografía de suelos (representación y temas asociados
Tipología de Inventarios del Recurso Suelo (IRS) y sus aplicaciones
Técnicas SIG de organización de datos relacionados con el suelo
Aplicación a la valorización de suelo y a la toma de decisiones (evaluación del medio, ordenación del territorio y agricultura de precisión)
La asignatura se completa con aplicaciones relacionadas con la fotointerpretación y el manejo de imágenes obtenidas mediante sensores remotos, el análisis de mapas de suelos obtenidos con diferentes metodologías y a diferentes escalas y la realización de un trabajo personalizado de curso: un SIG/GIS de suelos que incluirá la(s) evaluación(es) correspondiente(s)"""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/joaquin.camara%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/joaquin.camara%40upm.es> ;
    schema:name "Mapa de Suelos para Agricultura de Precisión"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000170/2025-26/C4> a ns1:Competency ;
    ns1:competencyCode "C4" ;
    ns1:competencyDescription "Saber integrar la información espacial y temática (suelo, cultivo) con rigor, prestando especial atención a los conceptos de precisión y calidad de los datos geográficos, en una base de datos geoespaciales (creación y consultas) para su aplicación en un entorno profesional."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000170/2025-26/CEH2> a ns1:Competency ;
    ns1:competencyCode "CEH2" ;
    ns1:competencyDescription "Poseer conocimiento avanzado y ser capaz de desarrollar tecnología en gestión de equipos e instalaciones que se integren en los procesos y sistemas de producción agroalimentaria."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000170/2025-26/CEH6> a ns1:Competency ;
    ns1:competencyCode "CEH6" ;
    ns1:competencyDescription "Poseer conocimiento avanzado y ser capaz de desarrollar tecnología en sistemas de producción vegetal y en sistemas integrados de protección de cultivos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000170/2025-26/CT01> a ns1:Competency ;
    ns1:competencyCode "CT01" ;
    ns1:competencyDescription "Análisis y síntesis: reconocer y describir los elementos constitutivos de una realidad y organizar la información significativa, aplicando el pensamiento crítico, según criterios preestablecidos adecuados a un propósito."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000170/2025-26/CT02> a ns1:Competency ;
    ns1:competencyCode "CT02" ;
    ns1:competencyDescription "Resolución de problemas: capacidad para describir, organizar y analizar los elementos constitutivos de un problema complejo y diseñar estrategias que permitan alcanzar una solución científico"@es .

