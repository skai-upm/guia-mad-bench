<https://guia-kg.skai.etsisi.upm.es/resource/203000001/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Tema 1. Ecosistemas y agrosistemas. Contextualización de los sistemas productivos. Objetivos de Desarrollo Sostenible (ODS)"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000001/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Motores de cambio y cambios en los sistemas de producción Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000001/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Agricultura integrada; agricultura de conservación; agricultura ecológica (organic farming); agroecología. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000001/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "1.3. Rendimientos y Relación equivalente de área. Intensificación en sistemas de producción. Brecha de rendimientos Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000001/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "2. Tema 2. Determinantes de la sostenibilidad de los sistemas agrarios. Determinantes técnicos de la sostenibilidad de sistemas agrícolas Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000001/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "3. Tema 3. Explotaciones agrícolas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000001/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "3.1. Explotaciones agrícolas y componentes abióticos: clima, territorio - estructura del suelo, topografía y fertilidad del suelo-, agua, nutrientes. Eficiencia en el uso del agua y del nitrógeno. La necesidad de la cuantificación Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000001/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "3.2. Explotaciones agrícolas y componentes biológicos: Diversidad genética. Especies y cultivares. Cambios en la estructura genética. Desarrollo de cultivares. Avance genético y mantenimiento de la diversidad. Policultivos. Normas de la UE. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000001/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "4. Tema 4. Conexión con otras asignaturas: Relaciones entre los niveles operacionales y geo-espaciales de los sistemas de producción."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000001/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "4.1. Articulación y análisis del sistema de producción. Marcos integrados de modelización: integración de modelos de simulaciones a varias escalas y resoluciones espaciales. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20AB%20-%20Master%20Univ%20en%20Tecnologia%20Agroambiental%20para%20una%20Agricultura%20Sostenible> a ns1:MasterDegree ;
    ns1:degreeCode "20AB"@es ;
    ns1:hasCourse <https://guia-kg.skai.etsisi.upm.es/resource/203000001> ;
    schema:name "Master Univ en Tecnologia Agroambiental para una Agricultura Sostenible"@es .

