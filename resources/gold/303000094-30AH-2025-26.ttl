<https://guia-kg.skai.etsisi.upm.es/resource/303000094/2025-26/syllabus> a ns1:Syllabus ;
    ns1:hasItem <https://guia-kg.skai.etsisi.upm.es/resource/303000094/2025-26/syllabus/0>,
        <https://guia-kg.skai.etsisi.upm.es/resource/303000094/2025-26/syllabus/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/303000094/2025-26/syllabus/10>,
        <https://guia-kg.skai.etsisi.upm.es/resource/303000094/2025-26/syllabus/11>,
        <https://guia-kg.skai.etsisi.upm.es/resource/303000094/2025-26/syllabus/12>,
        <https://guia-kg.skai.etsisi.upm.es/resource/303000094/2025-26/syllabus/2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/303000094/2025-26/syllabus/3>,
        <https://guia-kg.skai.etsisi.upm.es/resource/303000094/2025-26/syllabus/4>,
        <https://guia-kg.skai.etsisi.upm.es/resource/303000094/2025-26/syllabus/5>,
        <https://guia-kg.skai.etsisi.upm.es/resource/303000094/2025-26/syllabus/6>,
        <https://guia-kg.skai.etsisi.upm.es/resource/303000094/2025-26/syllabus/7>,
        <https://guia-kg.skai.etsisi.upm.es/resource/303000094/2025-26/syllabus/8>,
        <https://guia-kg.skai.etsisi.upm.es/resource/303000094/2025-26/syllabus/9> .

<https://guia-kg.skai.etsisi.upm.es/resource/303000094/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Differential and Riemannian Geometry"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000094/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Differentiable manifolds. Riemannian metrics. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000094/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "2.5. Embedding of projective curves. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000094/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "2.6. Plane curves. Genus-degree formula. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000094/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "2.7. Complex tori and elliptic curves. Group structure and applications in cryptography. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000094/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Calculus on Riemannian manifolds. Levi-Civita connection. Gradient, Hessian, and Laplacian of a function. Geodesics and the exponential map. Hopf-Rinow theorem. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000094/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "1.3. Curvatures on a Riemannian manifold. Spaces of constant sectional curvature. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000094/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "1.4. Isometric immersions. Second fundamental form. Fundamental equations. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000094/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "2. Complex Geometry"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000094/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "2.1. Complex manifolds. Complex structures on a differentiable manifold. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000094/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "2.2. Projective space, affine and projective manifolds. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000094/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "2.3. Hermitian and Kähler metrics. Some properties of Kähler manifolds. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000094/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "2.4. Complex curves and Riemann surfaces. Holomorphic and meromorphic functions, and branched coverings. Sin subniveles"@es .

