<https://guia-kg.skai.etsisi.upm.es/resource/105000160/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/105000160/2025-26/C10>,
        <https://guia-kg.skai.etsisi.upm.es/resource/105000160/2025-26/C19>,
        <https://guia-kg.skai.etsisi.upm.es/resource/105000160/2025-26/C5>,
