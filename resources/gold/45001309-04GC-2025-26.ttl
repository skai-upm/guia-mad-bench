<https://guia-kg.skai.etsisi.upm.es/resource/45001309/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. TRATAMIENTO DE AGUAS PARA ABASTECIMIENTO"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001309/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Necesidades de agua. Recursos para abastecimiento. Normativa sobre calidad de aguas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001309/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "2.3. Redes de distribución. Trazado, diseño, construcción y dimensionado. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001309/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "3. Redes de saneamiento de aguas residuales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001309/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "3.1. Sistemas de evacuación de aguas residuales. Tipos de redes de saneamiento. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001309/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "3.2. Características de las redes de saneamiento. Instalaciones complementarias. Normativa relacionada. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001309/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "3.3. Caudales de aguas negras. Caudales de escorrentía superficial. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001309/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "3.4. Régimen hidráulico de un colector. Diseño de colectores. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001309/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "3.5. Diseño de otras instalaciones de la red. Bombeo de aguas residuales. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001309/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "3.6. Materiales para la construcción de alcantarillas y colectores. Juntas. Normativa relacionada. Sin subniveles"@es .

