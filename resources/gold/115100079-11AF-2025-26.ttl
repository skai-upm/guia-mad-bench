    ns1:numberOfCredits 6.0 ;
    ns1:otherInformation """La planificación de la asignatura se relaciona con los siguientes ODS:
4. Educación de calidad
5. Igualdad de Género
16. Paz, justicia e instituciones solidarias
La plataforma utilizada para las turorías será preferentemente Zoom"""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "65 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/115100079/2025-26/eventSchedule> ;
    schema:description "La asignatura, de orientación práctica y competencial, está enfocada al desarrollo de las capacidades personales de expresión, comunicación y creación a través del cuerpo. Por un lado, se realizará un trabajo personalizado para indagar en el propio potencial y posteriormente establecer e implementar actividades teórico-prácticas destinadas a la mejora del potencial propio. Al mismo tiempo, se trabajará en un proyecto de creación grupal. Todo ello, utilizando técnicas y estrategias de trabajo activo y cooperativo."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/j.coteron%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/j.coteron%40upm.es> ;
    schema:name "Expresión y Creatividad en el Movimiento"@es .

