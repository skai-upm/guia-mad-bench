<https://guia-kg.skai.etsisi.upm.es/resource/20504414/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/20504414/2025-26/CG02> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/20504414/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/20504414/2025-26/didactic_resource/2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/20504414/2025-26/didactic_resource/3>,
        <https://guia-kg.skai.etsisi.upm.es/resource/20504414/2025-26/didactic_resource/4>,
