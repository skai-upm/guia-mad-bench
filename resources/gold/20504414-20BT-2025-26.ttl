        <https://guia-kg.skai.etsisi.upm.es/resource/20504414/2025-26/didactic_resource/6> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/20504414/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/20504414/2025-26/RA75>,
        <https://guia-kg.skai.etsisi.upm.es/resource/20504414/2025-26/RA76>,
        <https://guia-kg.skai.etsisi.upm.es/resource/20504414/2025-26/RA77>,
        <https://guia-kg.skai.etsisi.upm.es/resource/20504414/2025-26/RA78>,
        <https://guia-kg.skai.etsisi.upm.es/resource/20504414/2025-26/RA79>,
        <https://guia-kg.skai.etsisi.upm.es/resource/20504414/2025-26/RA80> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/20504414/2025-26/syllabus> ;
    ns1:inpersonHours "39 horas (50%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation """El contenido de la asignatura incide en la consecución de los ODS2 ODS13, ODS14, y ODS15 a través de su aplicaciones a la producción de alimentos y a la reduccion de la contaminación por fertilizantes y pesticidas. Se incidirá en dichas conexiones a lo largo de las clases y seminarios previstos.
El cronograma que se muestra en el apartado 6 podrá sufrir pequeñas modificaciones durante el curso, dependiendo de circunstancias diversas, lo que se comunicará a los alumnos con suficiente antelación
El alumno deberá llevar a las prácticas los siguientes elementos de seguridad: bata de laboratorio. Si no la lleva no podrá realizar las prácticas, asumiendo las consecuencias que se deriven de ello en relación a la evaluación de la asignatura.
La Comisión de Calidad del Centro en su reunión de 29 de mayo de 2023 acordó aprobar la propuesta de reasignación de competencias transversales en las asignaturas de los Grados en Biotecnología, Ingeniería Alimentaria, Ingeniería Agrícola, Ingeniería Agroambiental, Ciencias Agrarias y Bioeconomía, y en el Máster Universitario en Ingeniería Agronómica. En virtud de dicho acuerdo esta asignatura ha sido designada como "Asignatura NO Punto Control\""""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "39 horas"@es ;
    schema:activitiesWorkload "100.01%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/20504414/2025-26/eventSchedule> ;
    schema:description """La asignatura de Microbiología Agrícola pretende transmitir al alumno el papel relevante de los microorganismos en la fertilidad de los suelos y en la produccion de los cultivos. Se presentan las características generales de dos tipos de hábitts relevantes, el suelo y las propias plantas, como sustrato para el desarrollo de los microorganismos, y el papel de los mismos en los ciclos biogeoquímicos de los elementos. En la segunda parte de la asignatura se revisan los distintos tipos de asociaciones simbióticas que potencian el crecimiento vegetal, como la simbiosis Rhizobium-leguminosa, actinorizas y micorrizas, así como otros microorganismos con actividad promotora del crecimiento vegetal (PGPRs) que pueden actuar como biofertilizantes, bioestimulantes, y agentes de biocontrol.
La superación de esta asignatura permite al alumno adquirir las siguientes competencias específicas de itinerario:
CEI1.3 - Habilidad para comprender y utilizar los conocimientos de la biotecnología en la agricultura y la ganadería.
CEI1.8 - Capacidad para asimilar las aplicaciones de los microorganismos"""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/jose.palacios%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/jose.palacios%40upm.es> ;
    schema:name "Microbiología Agrícola"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504414/2025-26/CG02> a ns1:Competency ;
    ns1:competencyCode "CG02" ;
    ns1:competencyDescription "Familiarizarse con el trabajo en el laboratorio, la instrumentación y los métodos experimentales. Además, ser capaz de realizar experimentos y/o diseñar aplicaciones de forma independiente y describir, cuantificar, analizar y evaluar críticamente los resultados obtenidos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504414/2025-26/RA75> a ns1:LearningResult ;
    ns1:learningResultCode "RA75" ;
    ns1:learningResultDescription "Conocer las posibilidades de los microorganismos en el control de factores de estrés bióticos y abióticos en plantas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504414/2025-26/RA76> a ns1:LearningResult ;
    ns1:learningResultCode "RA76" ;
    ns1:learningResultDescription "Conocer las principales técnicas que se emplean para caracterizar comunidades microbianas en hábitats naturales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504414/2025-26/RA77> a ns1:LearningResult ;
    ns1:learningResultCode "RA77" ;
    ns1:learningResultDescription "Conocer las características de las plantas como hábitats de microorganismos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504414/2025-26/RA78> a ns1:LearningResult ;
    ns1:learningResultCode "RA78" ;
    ns1:learningResultDescription "Conocer las posibilidades de los microorganismos como promotores del crecimiento de las plantas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504414/2025-26/RA79> a ns1:LearningResult ;
    ns1:learningResultCode "RA79" ;
    ns1:learningResultDescription "Conocer el papel de los microorganismos en el ciclo de elementos químicos relevantes para la nutrición de las plantas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504414/2025-26/RA80> a ns1:LearningResult ;
    ns1:learningResultCode "RA80" ;
    ns1:learningResultDescription "Adquirir conocimientos generales sobre el papel de los microorganismos en la fertilidad del suelo"@es .

