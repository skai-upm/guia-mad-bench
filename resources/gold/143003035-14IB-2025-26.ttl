<https://guia-kg.skai.etsisi.upm.es/resource/143003035/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. PANORAMA ENERGÉTICO MUNDIAL"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143003035/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Introducción. Las formas de energía. Fuentes de energía. Fuentes no renovables de energía. Fuentes renovables de energía. Relación entre fuentes y combustibles. La energía en España. El problema de la energía. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143003035/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "6. COMPORTAMIENTO REAL DE LAS PILAS DE COMBUSTIBLE"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143003035/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "6.1. Introducción al funcionamiento real de las pilas de combustible. Voltaje de una pila de combustible. Irreversibilidades. Polarización por activación, óhmica y por concentración. Curva de polarización. Modelo de curva de polarización. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143003035/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "7. ESTUDIO DE LOS PROCESOS DE TRANSPORTE DE CARGA EN LAS PILAS DE COMBUSTIBLE"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143003035/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "7.1. Introducción. Movimiento de carga. Transporte de carga en metales. Transporte de carga en electrolitos poliméricos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143003035/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "8. ESTUDIO DE LOS PROCESOS DE TRANSPORTE DE MASA EN LAS PILAS DE COMBUSTIBLE"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143003035/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "8.1. Introducción. Transporte por difusión. Efecto de la concentración sobre el voltaje de Nernst. Efecto de la concentración sobre la velocidad de reacción. Transporte convectivo. Estructura de las placas bipolares. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143003035/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "9. ESTUDIO DE LOS PROCESOS DE TRANSPORTE DE CALOR EN LAS PILAS DE COMBUSTIBLE"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143003035/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "9.1. Transferencia de calor. Estudio detallado de la transferencia de calor. Calor transferido al sistema de refrigeración. Calor disipado por convección natural y radiación. Calor transferido al gas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143003035/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "10. DISEÑO DE PILAS DE COMBUSTIBLE"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143003035/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "10.1. Introducción. Placas bipolares. Cálculos preliminares para el dimensionado. Fluidodinámica de un stack. Optimización del diseño. Cálculo de pernos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143003035/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "2. PRINCIPIO DE LAS PILAS DE COMBUSTIBLE"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143003035/2025-26/syllabus/20> a ns1:SyllabusItem ;
    ns1:itemIndex 20 ;
    ns1:syllabusDescription "11. APLICACIÓN DE LAS PILAS DE COMBUSTIBLE COMO SISTEMA DE PROPULSIÓN DE AERONAVES"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143003035/2025-26/syllabus/21> a ns1:SyllabusItem ;
    ns1:itemIndex 21 ;
    ns1:syllabusDescription "11.1. Introducción. Pilas de combustible en UAV. Almacenamiento. Sistemas de propulsión en UAV. Modelos de pila de combustible y atmósfera en vuelo UAV. Ensayos. Conclusiones. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143003035/2025-26/syllabus/22> a ns1:SyllabusItem ;
    ns1:itemIndex 22 ;
    ns1:syllabusDescription "12. APLICACIÓN DE LAS PILAS DE COMBUSTIBLE COMO SISTEMA DE PRODUCCIÓN DE ENERGÍA EN AERONAVES"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143003035/2025-26/syllabus/23> a ns1:SyllabusItem ;
    ns1:itemIndex 23 ;
    ns1:syllabusDescription "12.1. Perspectiva histórica. Aplicaciones de las pilas de combustible en la aviación comercial. Sistemas auxiliares (Balance of Plants). Sustitución del sistema de emergencia. Análisis RAMTS. Análisis de resultados. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143003035/2025-26/syllabus/24> a ns1:SyllabusItem ;
    ns1:itemIndex 24 ;
    ns1:syllabusDescription "13. PRÁCTICAS DE LABORATORIO"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143003035/2025-26/syllabus/25> a ns1:SyllabusItem ;
    ns1:itemIndex 25 ;
    ns1:syllabusDescription "13.1. Estudio de los componentes de una pila PEMFC. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143003035/2025-26/syllabus/26> a ns1:SyllabusItem ;
    ns1:itemIndex 26 ;
    ns1:syllabusDescription "13.2. Determinación de la curva de polarización de pilas de combustible. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143003035/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "2.1. Introducción. Perspectiva histórica y evolución, tendencias actuales. Las pilas de combustible en el panorama energético mundial: fuentes de energía. Tipos de pilas de combustible. Componentes de las pilas de combustible. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143003035/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "3. COMPONENTES Y MATERIALES DE LAS PILAS DE COMBUSTIBLE"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143003035/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "3.1. Componentes de las pilas de combustible: descripción general. Membranas. Electrodos (GDLs y catalizadores). Placas bipolares Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143003035/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "4. EL HIDRÓGENO COMO VECTOR ENERGÉTICO"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143003035/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "4.1. Características del hidrógeno. Métodos de producción. Métodos de almacenamiento. Cálculos para el hidrógeno como gas real. Predimensionamiento de tanques presurizados. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143003035/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "5. TERMODINÁMICA DE LAS PILAS DE COMBUSTIBLE"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143003035/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "5.1. Trabajo eléctrico de una pila de combustible internamente reversible. Potencial reversible (ideal) de una pila de combustible. Ecuación de Nernst. Influencia de la presión y de la temperatura en el potencial reversible. Rendimiento. Sin subniveles"@es .

