    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/115100141/2025-26/eventSchedule> ;
    schema:description "Los alumnos que cursen esta asignatura, deberán completar y perfeccionar, el conocimiento en profundidad, de las características que requieren las/los gimnastas que practican este deporte. Complementandolo con la metodología pedagógica y científica adecuada de la enseñanza técnica y planificación deportiva, podrán conseguir el conocimiento para su futuro profesional de un buen método que facilitará la consecución de los objetivos de máxima optimización del rendimiento deportivo, en los diferentes niveles, de esta especialidad de Gimnasia Ritmica y en sus dos modalidades, Conjunto e Individual. En este último curso se focaliza la formación hacia el contenido de la preparación física en la gimnasia rítmica."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/monica.hontoria%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/monica.hontoria%40upm.es> ;
    schema:name "Aplicación Deportiva II: Gimnasia Rítmica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100141/2025-26/CE01> a ns1:Competency ;
    ns1:competencyCode "CE01" ;
    ns1:competencyDescription "Diseñar, desarrollar y evaluar los procesos de enseñanza¿aprendizaje relativos a la actividad física y el deporte con atención a las características individuales y contextuales de las personas. Nivel 3."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100141/2025-26/CE03> a ns1:Competency ;
    ns1:competencyCode "CE03" ;
    ns1:competencyDescription "Identificar y prevenir los riesgos que se derivan para la salud de los escolares en la práctica de actividades físicas inadecuadas o realizadas de forma incorrecta. Nivel 3."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100141/2025-26/CE07> a ns1:Competency ;
    ns1:competencyCode "CE07" ;
    ns1:competencyDescription "Planificar, desarrollar y evaluar la realización de programas y procesos de entrenamiento deportivo en sus distintos niveles. Nivel 3."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100141/2025-26/CE08> a ns1:Competency ;
    ns1:competencyCode "CE08" ;
    ns1:competencyDescription "Aplicar de manera fundamentada y argumentada los principios fisiológicos, biomecánicos, comportamentales y sociales, durante la dirección del entrenamiento deportivo. Nivel 3."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100141/2025-26/CE10> a ns1:Competency ;
    ns1:competencyCode "CE10" ;
    ns1:competencyDescription "Seleccionar y saber utilizar el material y equipamiento deportivo adecuado para cada tipo de actividad de entrenamiento deportivo. Nivel 3."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100141/2025-26/CE11> a ns1:Competency ;
    ns1:competencyCode "CE11" ;
    ns1:competencyDescription "Promover y evaluar la formación de hábitos perdurables y autónomos de práctica actividad física y del deporte, entre la población que realiza entrenamiento deportivo. Nivel 3."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100141/2025-26/CE26> a ns1:Competency ;
    ns1:competencyCode "CE26" ;
    ns1:competencyDescription "Presentar de forma oral y escrita, información clara y detallada de una amplia serie de temas relacionados con la especialidad del alumno, utilizando el lenguaje específico de cada campo académico y profesional."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100141/2025-26/CG03> a ns1:Competency ;
    ns1:competencyCode "CG03" ;
    ns1:competencyDescription "Organizar y planificar propuestas de acción, programas y actividades propias de su campo profesional en sus diferentes ámbitos de aplicación y desarrollo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100141/2025-26/CG04> a ns1:Competency ;
    ns1:competencyCode "CG04" ;
    ns1:competencyDescription "Mostrar disposición y habilidad para el trabajo y el liderazgo en equipo."@es .

