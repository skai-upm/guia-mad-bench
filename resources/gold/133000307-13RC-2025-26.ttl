    ns1:itemIndex 1 ;
    ns1:syllabusDescription "2. Tema 2. Estructura del patrón del paisaje. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000307/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "11. Caso práctico Tema 6. Identificación de corredores ecológicos a través de la matriz del paisaje y determinación de las prioridades para su conservación. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000307/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "3. Tema 3. Dinámica del patrón del paisaje. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000307/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "4. Tema 4. Conectividad funcional del paisaje: concepto e implicaciones Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000307/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "5. Tema 5. Priorización de teselas por su importancia para la conectividad y disponibilidad de hábitat Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000307/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "6. Tema 6. Caracterización de la resistencia de la matriz del paisaje y determinación de rutas favorables para el movimiento Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000307/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "7. Práctica 1. Identificación y caracterización de elementos del paisaje. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000307/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "8. Práctica 2. Herramientas SIG para la evaluación de la estructura del patrón del paisaje. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000307/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "9. Práctica 3. Herramientas SIG para la evaluación de la dinámica del patrón del paisaje. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000307/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "10. Caso práctico Tema 5. Evaluación de la contribución de las teselas de hábitat y su restauración a la conectividad del paisaje. Sin subniveles"@es .

