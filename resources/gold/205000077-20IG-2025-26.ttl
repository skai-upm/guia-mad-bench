    ns1:numberOfCredits 6.0 ;
    ns1:otherInformation """La asignatura se relaciona con el ODS8.
Otra información:
"La Comisión de Calidad del Centro en su reunión de 29 de mayo de 2023 acordó aprobar la propuesta de reasignación de competencias transversales en las asignaturas de los Grados en Biotecnología, Ingeniería Alimentaria, Ingeniería Agrícola, Ingeniería Agroambiental, Ciencias Agrarias y Bioeconomía, y en el Máster Universitario en Ingeniería Agronómica. En virtud de dicho acuerdo esta asignatura ha sido designada como "Asignatura NO Punto Control*". Esto significa que si bien puede seguir trabajando una o varias competencias transversales que se abordan en distintos puntos y aspectos de la asignatura, dicha formación y evaluación no será objeto de recopilación de evidencias por los sistemas de acreditación de la calidad del Centro".
*Asignatura punto control (APC): aquella asignatura en la que se verificará la formación y evaluación de la competencia transversal que le corresponda."""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "68 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/205000077/2025-26/eventSchedule> ;
    schema:description "El objetivo general de la asignatura es que el alumnado adquiera una visión general e introductoria sobre la empresa como unidad económica fundamental, desde la perspectiva de su administración práctica. Los conocimientos que se desarrollan a lo largo del curso pretenden proporcionar al futuro egresado una idea sobre cómo debe gestionarse una empresa en cada una de las áreas funcionales de las que se compone. De esta forma, podrán entender y comprender los conceptos básicos relativos a la administración empresarial, muy útiles para su vida profesional."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/emilio.pindado%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/beatriz.encinas%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/cristina.lopezcozar%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/emilio.pindado%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/j.herreroen%40upm.es> ;
    schema:name "Introducción a la Administración de Empresas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000077/2025-26/CB04> a ns1:Competency ;
    ns1:competencyCode "CB04" ;
    ns1:competencyDescription "Que los estudiantes puedan transmitir información, ideas, problemas y soluciones a un público tanto especializado como no especializado"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000077/2025-26/CE07> a ns1:Competency ;
    ns1:competencyCode "CE07" ;
    ns1:competencyDescription "Conocimiento adecuado del concepto de empresa, marco institucional y jurídico de la empresa. Organización y gestión de empresas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000077/2025-26/CE17> a ns1:Competency ;
    ns1:competencyCode "CE17" ;
    ns1:competencyDescription "Capacidad para conocer, comprender y utilizar los principios de la toma de decisiones mediante el uso de los recursos disponibles para el trabajo en grupos multidisciplinares."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000077/2025-26/CG03> a ns1:Competency ;
    ns1:competencyCode "CG03" ;
    ns1:competencyDescription "Capacidad para dirigir la ejecución de las obras objeto de los proyectos relativos a industrias agroalimentarias, explotaciones agrarias y espacios verdes y sus edificaciones, infraestructuras e instalaciones, la prevención de riesgos asociados a esa ejecución y la dirección de equipos multidisciplinares y gestión de recursos humanos, de conformidad con criterios deontológicos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000077/2025-26/CG06> a ns1:Competency ;
    ns1:competencyCode "CG06" ;
    ns1:competencyDescription "Capacidad para la dirección y gestión de toda clase de industrias agroalimentarias, explotaciones agrícolas y ganaderas, espacios verdes urbanos y/o rurales, y áreas deportivas públicas o privadas, con conocimiento de las nuevas tecnologías, los procesos de calidad, trazabilidad y certificación y las técnicas de marketing y comercialización de productos alimentarios y plantas cultivadas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000077/2025-26/CG07> a ns1:Competency ;
    ns1:competencyCode "CG07" ;
    ns1:competencyDescription "Conocimiento en materias básicas, científicas y tecnológicas que permitan un aprendizaje continuo, así como una capacidad de adaptación a nuevas situaciones o entornos cambiantes"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000077/2025-26/CG09> a ns1:Competency ;
    ns1:competencyCode "CG09" ;
    ns1:competencyDescription "Capacidad de liderazgo, comunicación y transmisión de conocimientos, habilidades y destrezas en los ámbitos sociales de actuación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000077/2025-26/CG10> a ns1:Competency ;
    ns1:competencyCode "CG10" ;
    ns1:competencyDescription "Capacidad para la búsqueda y utilización de la normativa y reglamentación relativa a su ámbito de actuación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000077/2025-26/CG12> a ns1:Competency ;
    ns1:competencyCode "CG12" ;
    ns1:competencyDescription "Capacidad para el trabajo en equipos multidisciplinares y multiculturales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000077/2025-26/CT07> a ns1:Competency ;
