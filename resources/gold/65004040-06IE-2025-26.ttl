<https://guia-kg.skai.etsisi.upm.es/resource/65004040> a ns1:Course ;
    ns1:courseType "Optativa"@es ;
    ns1:courseYear 4 ;
    ns1:semester "Octavo semestre"@es ;
    schema:courseCode 65004040 ;
    schema:hasCourseInstance <https://guia-kg.skai.etsisi.upm.es/resource/65004040/2025-26> ;
    schema:name "Energy And Underground Space II"@en,
        "Energia y Espacio Subterraneo II"@es ;
    schema:numberOfCredits 3.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/65004040/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/65004040/2025-26/CE47>,
        <https://guia-kg.skai.etsisi.upm.es/resource/65004040/2025-26/CE48>,
        <https://guia-kg.skai.etsisi.upm.es/resource/65004040/2025-26/CE53>,
        <https://guia-kg.skai.etsisi.upm.es/resource/65004040/2025-26/CE54>,
        <https://guia-kg.skai.etsisi.upm.es/resource/65004040/2025-26/CG1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/65004040/2025-26/CG3>,
        <https://guia-kg.skai.etsisi.upm.es/resource/65004040/2025-26/CG5>,
        <https://guia-kg.skai.etsisi.upm.es/resource/65004040/2025-26/CG6> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/65004040/2025-26/didactic_resource/1> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/65004040/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/65004040/2025-26/RA336>,
        <https://guia-kg.skai.etsisi.upm.es/resource/65004040/2025-26/RA337>,
        <https://guia-kg.skai.etsisi.upm.es/resource/65004040/2025-26/RA338>,
        <https://guia-kg.skai.etsisi.upm.es/resource/65004040/2025-26/RA339> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/65004040/2025-26/syllabus> ;
    ns1:inpersonHours "32 horas (41%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation "En la asignatura se persiguen los ODS 7, 9 y 13 promoviendo la responsabilidad en la gestión de residuos nucleares y el aprovechamiento del espacio subterráneo, con una exploración y desarrollo de proyectos de almacenamiento sostenible de energía limpia (aire comprimido e hidrógeno) y una mitigación del cambio climático promovido por el almacenamiento geológico de CO2,"@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "32 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/65004040/2025-26/eventSchedule> ;
    schema:description "Durante la asignatura, se explicará la interrelación entre energía y subsuelo. En este caso, se enfocarán las nuevas formas de relacionar ambos espacios y ciencias; ahondando principalmente en lo relacionado al almacenamiento geológico profundo."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/lauramaria.valle%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/lauramaria.valle%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/mariajose.crespo%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/ramon.rodripons%40upm.es> ;
    schema:name "Energia y Espacio Subterraneo II"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004040/2025-26/CE47> a ns1:Competency ;
    ns1:competencyCode "CE47" ;
    ns1:competencyDescription "Comprender los fundamentos de la geología, geomorfología y climatología y su aplicación a los recursos energéticos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004040/2025-26/CE48> a ns1:Competency ;
    ns1:competencyCode "CE48" ;
    ns1:competencyDescription "Comprender el aprovechamiento, transformación y gestión de los recursos energéticos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004040/2025-26/CE53> a ns1:Competency ;
    ns1:competencyCode "CE53" ;
    ns1:competencyDescription "Aplicar los principios de la tecnología ambiental a la evaluación de impactos, al tratamiento de residuos y a la sostenibilidad."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004040/2025-26/CE54> a ns1:Competency ;
    ns1:competencyCode "CE54" ;
    ns1:competencyDescription "Conocer las tecnologías de reducción de emisiones en la plantas de generación de energía."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004040/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Conocer y aplicar conocimientos de ciencias y tecnologías básicas a la práctica de la Ingeniería de la Energía."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004040/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Aplicar los conocimientos adquiridos para identificar, formular y resolver problemas dentro de contextos amplios y multidisciplinarios, siendo capaces de integrar conocimientos, trabajando en equipos multidisciplinares."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004040/2025-26/CG5> a ns1:Competency ;
    ns1:competencyCode "CG5" ;
    ns1:competencyDescription "Saber comunicar los conocimientos y conclusiones, tanto de forma oral, escrita y gráfica, a públicos especializados y no especializados de un modo claro y sin ambigüedades."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004040/2025-26/CG6> a ns1:Competency ;
    ns1:competencyCode "CG6" ;
    ns1:competencyDescription "Poseer habilidades de aprendizaje que permitan continuar estudiando a lo largo de la vida para su adecuado desarrollo profesional."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004040/2025-26/RA336> a ns1:LearningResult ;
    ns1:learningResultCode "RA336" ;
    ns1:learningResultDescription "Conocer los aspectos geológicos e hidrogeológicos y de mecánica de rocas que condicionan el almacenamiento de los residuos radiactivos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004040/2025-26/RA337> a ns1:LearningResult ;
    ns1:learningResultCode "RA337" ;
    ns1:learningResultDescription "Conocer las técnicas geofísicas, petrofísicas y geoquímicas a emplear en el estudio de un emplazamiento relacionado con en espacio subterráneo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004040/2025-26/RA338> a ns1:LearningResult ;
    ns1:learningResultCode "RA338" ;
    ns1:learningResultDescription "Conocer las diferentes tecnologías aplicables para el uso eficiente y seguro del espacio subterráneo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004040/2025-26/RA339> a ns1:LearningResult ;
    ns1:learningResultCode "RA339" ;
    ns1:learningResultDescription "Conocer análogos activos o en desarrollo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004040/2025-26/didactic_resource/1> a ns1:DidacticResource ;
    ns1:bibliographyDescription """Conferencias, seminarios de actualidad relacionados con la materia.
Videos explicativos de tecnologías ligadas a proyectos (web propia)"""@es ;
    ns1:bibliographyTitle "Conferencias y seminarios. Videos de tecnología"@es ;
    ns1:bibliographyType "Recursos web"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004040/2025-26/evaluation> a ns1:EvaluationSystem ;
    ns1:evaluationDescription """La evaluación será mediante trabajo en equipo (no superior a 5 alumnos/grupo). Los alumnos profundizarán en alguno de los temas mostrados y explicados en la asignatura.
Se organizará una interactuación profesor-grupos de trabajo para guiar el trabajo y preparar la presentación.
La evaluación será mediante presentación: en la fecha convenida con los alumnos se realizarán las presentaciones (comunicación oral).
Los alumnos entregarán el material gráfico presentado así como una memoria descriptiva del trabajo."""@es .

