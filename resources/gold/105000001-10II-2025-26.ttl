<https://guia-kg.skai.etsisi.upm.es/resource/105000001/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Circuitos en corriente continua"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000001/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Carga eléctrica. Ley de Coulomb. Campo eléctrico. Potencial. Capacidad. Condensador plano. Asociación de condensadores. Energía de un condensador cargado Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000001/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "2. Física de Semiconductores. El Diodo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000001/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "2.1. Clasificación de los materiales. Nociones de teoría de bandas para el estado sólido. Semiconductores: extrínsecos e intrínsecos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000001/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "2.2. Conducción en semiconductores. Estructura de la unión p-n. Zona de carga espacial. Potencial de contacto. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000001/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "2.3. El diodo. Ley del diodo. Curvas características. Modelos eléctricos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000001/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "2.4. Otros tipos de diodos: Zener y LED. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000001/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "2.5. Aplicación de los diodos: limitadores de tensión y rectificadores."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000001/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "2.5.1. Sesión de laboratorio 3: diodos y rectificador de media onda. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000001/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "2.6. Ejercicios con diodos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000001/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "3. El Transistor MOS"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000001/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "3.1. Características del transistor MOS. Estructura y geometría del transistor MOS. Polarización. Tipos de transistores MOS. Simbología. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000001/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Corriente eléctrica, intensidad de corriente. Conductancia y resistencia eléctrica. Ley de Ohm. Asociación de resistencias. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000001/2025-26/syllabus/20> a ns1:SyllabusItem ;
    ns1:itemIndex 20 ;
    ns1:syllabusDescription "3.2. Modelo en continua. Curvas características (con Microwind). Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000001/2025-26/syllabus/21> a ns1:SyllabusItem ;
    ns1:itemIndex 21 ;
    ns1:syllabusDescription "3.3. El transistor MOS como conmutador: Inversor CMOS. Función de transferencia. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000001/2025-26/syllabus/22> a ns1:SyllabusItem ;
    ns1:itemIndex 22 ;
    ns1:syllabusDescription "3.4. Retardos de propagación. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000001/2025-26/syllabus/23> a ns1:SyllabusItem ;
    ns1:itemIndex 23 ;
    ns1:syllabusDescription "3.5. Puerta de transmisión CMOS. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000001/2025-26/syllabus/24> a ns1:SyllabusItem ;
    ns1:itemIndex 24 ;
    ns1:syllabusDescription "3.6. Circuitos lógicos CMOS: características generales. Ejemplos de puertas lógicas simples."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000001/2025-26/syllabus/25> a ns1:SyllabusItem ;
    ns1:itemIndex 25 ;
    ns1:syllabusDescription "3.6.1. Sesión de laboratorio 4: construcción de puertas lógicas con un circuito integrado. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000001/2025-26/syllabus/26> a ns1:SyllabusItem ;
    ns1:itemIndex 26 ;
    ns1:syllabusDescription "4. Tecnología de fabricación de circuitos integrados CMOS. Diseño de puertas básicas con herramienta CAD"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000001/2025-26/syllabus/27> a ns1:SyllabusItem ;
    ns1:itemIndex 27 ;
    ns1:syllabusDescription "4.1. Procesos básicos de fabricación:obtención de lingotes, corte en obleas, oxidación, obtención de máscaras, litografiado, etc. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000001/2025-26/syllabus/28> a ns1:SyllabusItem ;
    ns1:itemIndex 28 ;
    ns1:syllabusDescription "4.2. Proceso de fabricación. Efecto \"latch-up\". Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000001/2025-26/syllabus/29> a ns1:SyllabusItem ;
    ns1:itemIndex 29 ;
    ns1:syllabusDescription "4.3. Representación simbólica de layout: código de barras. Ejemplos: puertas simples."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000001/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "1.3. Fuerza electromotriz. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000001/2025-26/syllabus/30> a ns1:SyllabusItem ;
    ns1:itemIndex 30 ;
    ns1:syllabusDescription "4.3.1. Sesión en aula de informática 5a : realización de un inversor (Microwind). Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000001/2025-26/syllabus/31> a ns1:SyllabusItem ;
    ns1:itemIndex 31 ;
    ns1:syllabusDescription "4.4. Puertas NAND y NOR."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000001/2025-26/syllabus/32> a ns1:SyllabusItem ;
    ns1:itemIndex 32 ;
    ns1:syllabusDescription "4.4.1. Sesión en aula de informática 5b: realización de una puerta CMOS con 4 entradas (Microwind).). Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000001/2025-26/syllabus/33> a ns1:SyllabusItem ;
    ns1:itemIndex 33 ;
    ns1:syllabusDescription "4.5. Multiplexor 2:1 (con puertas de transmisión). Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000001/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "1.4. Elementos activos de un circuito: Generadores ideales y reales. Equivalencia de generadores. Divisores de tensión y corriente. Potencia y energía. Ley de Joule. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000001/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "1.5. Análisis de circuitos de corriente continua. Leyes de Kirchhoff. Aplicación de los métodos de mallas y de nudos. Teoremas de Thévenin y Norton. Equivalencia."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000001/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "1.5.1. Sesión de laboratorio 1: comprobación de las leyes de Kirchhoff. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000001/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "1.6. Carga y descarga de un condensador a través de una resistencia."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000001/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "1.6.1. Sesión de laboratorio 2: carga y descarga de un condensador. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000001/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "1.7. Ejemplos de aplicación. Sin subniveles"@es .

