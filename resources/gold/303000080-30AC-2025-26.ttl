    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/303000080/2025-26/eventSchedule> ;
    schema:description """La asignatura pretende dar a conocer las diferentes técnicas actuales de tratamiento gráfico y cuáles son las tendencias en un horizonte próximo, además se mostrarán y discutirán las principales líneas de investigación tomando como referencia las principales bases de datos para Información científica.
Se trata de una asignatura eminentemente práctica, en la que se pretende aprender haciendo, y en la que el protagonismo de cada estudiante será la clave de su propio aprendizaje.
Por ello se propone un método de trabajo en el que primarán las actividades de los estudiantes, realizadas, tanto dentro como fuera del aula, tanto individuales como en equipo.
Habrá materiales en Moodle como referencia, los estudiantes buscarán y elaboraran materiales de estudio propios. Los temas se trabajarán inicialmente en el aula, siendo las clases de formato taller o seminario. Las tareas se completarán fuera del aula, y prácticamente de manera semanal habrá entregas evaluables sobre los temas tratados."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/mariajesus.garcia.garcia%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/mariajesus.casati%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/mariajesus.garcia.garcia%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/mvelazquezredondo%40upm.es> ;
    schema:name "Innovacion e Investigacion Educativa"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000080/2025-26/CON18.CE24.> a ns1:Competency ;
    ns1:competencyCode "CON18.CE24." ;
    ns1:competencyDescription "Conocer y aplicar propuestas docentes innovadoras en el ámbito de la especialización cursada. TIPO: Conocimientos o contenidos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000080/2025-26/CON19.CE26.> a ns1:Competency ;
    ns1:competencyCode "CON19.CE26." ;
    ns1:competencyDescription "Identificar problemas relativos a la enseñanza y aprendizaje de las materias de la especialización y plantear alternativas y soluciones. TIPO: Conocimientos o contenidos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000080/2025-26/HAB18.CE25.> a ns1:Competency ;
    ns1:competencyCode "HAB18.CE25." ;
    ns1:competencyDescription "Analizar críticamente el desempeño de la docencia, de las buenas prácticas y de la orientación, utilizando indicadores de calidad. TIPO: Habilidades o destrezas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000080/2025-26/HAB19.CE27.> a ns1:Competency ;
    ns1:competencyCode "HAB19.CE27." ;
    ns1:competencyDescription "Conocer y aplicar metodologías y técnicas básicas de investigación y evaluación educativas y ser capaz de diseñar y desarrollar proyectos de investigación, innovación y evaluación. TIPO: Habilidades o destrezas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000080/2025-26/HAB2.CG3.> a ns1:Competency ;
    ns1:competencyCode "HAB2.CG3." ;
    ns1:competencyDescription "Buscar, obtener, procesar y comunicar información (oral, impresa, audiovisual, digital o multimedia), transformarla en conocimiento y aplicarla en los procesos de enseñanza y aprendizaje en las materias propias de la especialización cursada. TIPO:"@es .

