    ns1:learningResultCode "RA178" ;
    ns1:learningResultDescription "Analizar proyectos de innovación educativa realizados en Secundaria y Bachillerato para evaluar sus deficiencias y fortalezas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000080/2025-26/RA179> a ns1:LearningResult ;
