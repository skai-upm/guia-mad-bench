<https://guia-kg.skai.etsisi.upm.es/resource/33000912/2025-26/syllabus> a ns1:Syllabus ;
    ns1:hasItem <https://guia-kg.skai.etsisi.upm.es/resource/33000912/2025-26/syllabus/0>,
        <https://guia-kg.skai.etsisi.upm.es/resource/33000912/2025-26/syllabus/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/33000912/2025-26/syllabus/2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/33000912/2025-26/syllabus/3>,
        <https://guia-kg.skai.etsisi.upm.es/resource/33000912/2025-26/syllabus/4>,
        <https://guia-kg.skai.etsisi.upm.es/resource/33000912/2025-26/syllabus/5> .

<https://guia-kg.skai.etsisi.upm.es/resource/33000912/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Introducción y conceptos básicos: Pobreza, exclusión e (in)justicias socioespaciales. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000912/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "2. Agendas internacionales frente a los retos socioespaciales (de la DUDH NAU y ODS 1 y 11) Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000912/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "3. (In)justicias socioespaciales: Segregación, gentrificación y procesos necropolíticos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000912/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "4. Procesos de resistencia frente a las (in)justicias socioespaciales: de la ?informalidad? a la coproducción del espacio. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000912/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "5. Análisis crítico de procesos de coproducción del espacio y de la planificación en diferentes contextos del Sur Global en el siglo XXI. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000912/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "6. Exclusión residencial, políticas de vivienda y exigibilidad de derechos. Sin subniveles"@es .

