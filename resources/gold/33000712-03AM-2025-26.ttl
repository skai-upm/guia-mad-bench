<https://guia-kg.skai.etsisi.upm.es/resource/33000712/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Conocimiento sobre la acción de pensar la arquitectura desde una interpretación racional de la realidad Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000712/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "2. Conocimiento, concepción, práctica y desarrollo de proyectos básicos y de ejecución, croquis, anteproyectos, proyectos urbanos y dirección de obras. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000712/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "11. Capacidad para aplicar los conocimientos técnico-constructivos en el proyecto y definir una respuesta precisa y ajustada a las definiciones proyectuales previas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000712/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "12. Capacidad para aplicar los conocimientos sobre instalaciones y técnicas aplicadas en el proyecto y definir una respuesta precisa y ajustada a las definiciones proyectuales previas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000712/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "13. Conocimiento y práctica sobre vínculos entre Medioambiente y paisaje Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000712/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "14. Aptitud para el ejercicio de la crítica arquitectónica. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000712/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "15. Aptitud para reflexionar y analizar sobre los procesos de ideación arquitectónica con apoyo de la geometría Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000712/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "16. Ampliación de conocimientos sobre las herramientas básicas de la representación arquitectónica Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000712/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "17. Aptitud para la generación de sistemas arquitectónicos básicos Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000712/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "18. Conocimiento y práctica sobre accesibilidad universal de las personas con discapacidad. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000712/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "19. Conocimiento y aplicación de normativas legales vigentes. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000712/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "20. Conocimiento y práctica de los principios básicos del habitar; el concepto arquetípico de casa; la casa como tipo arquitectónico Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000712/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "3. Conocimiento de modelos de generación arquitectónica contemporánea, utilización de referencias de estrategias proyectuales del siglo XX Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000712/2025-26/syllabus/20> a ns1:SyllabusItem ;
    ns1:itemIndex 20 ;
    ns1:syllabusDescription "21. Conocimiento y práctica sobre el trabajo a diferentes escalas Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000712/2025-26/syllabus/21> a ns1:SyllabusItem ;
    ns1:itemIndex 21 ;
    ns1:syllabusDescription "22. Conocimiento y práctica del funcionamiento de la unidad de vivienda y de fórmulas de agrupación a partir de unidades sencillas independientes Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000712/2025-26/syllabus/22> a ns1:SyllabusItem ;
    ns1:itemIndex 22 ;
    ns1:syllabusDescription "23. Conocimiento y práctica sobre Intervención en los modelos y su transformación Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000712/2025-26/syllabus/23> a ns1:SyllabusItem ;
    ns1:itemIndex 23 ;
    ns1:syllabusDescription "24. Aptitud para el manejo de contrastes entre densidades y vacíos, entre lo construido y el espacio vacío generado. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000712/2025-26/syllabus/24> a ns1:SyllabusItem ;
    ns1:itemIndex 24 ;
    ns1:syllabusDescription "25. Aptitud para analizar ejemplos arquitectónicos contemporáneos Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000712/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "4. Conocimiento y práctica sobre conservación, restauración y rehabilitación del patrimonio construido. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000712/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "5. Aptitud para la elaboración de programas funcionales de edificios y espacios urbanos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000712/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "6. Conocimiento de la ciudad como forma de agrupación Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000712/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "7. Conocimiento de la redacción y gestión de planes urbanísticos a cualquier escala. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000712/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "8. Aptitud para el trabajo con la gran escala, el territorio y el paisaje Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000712/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "9. Capacidad para poner en práctica algunas variables de proyecto relacionadas con el estudio de referencias arquitectónicas contemporáneas; modos de habitar; relación interior-exterior; proyectar desde el exterior y desde el interior Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000712/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "10. Capacidad para aplicar los conocimientos técnico-estructurales en el proyecto y definir una respuesta precisa y ajustada a las definiciones proyectuales previas. Sin subniveles"@es .

