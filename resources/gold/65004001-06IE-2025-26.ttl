<https://guia-kg.skai.etsisi.upm.es/resource/65004001/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Espacios Vectoriales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004001/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Definición de espacio vectorial. Los espacios R^n y C^n Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004001/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "2.5. Inversa de una matriz: existencia y cálculo mediante el algoritmo de Gauss-Jordan Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004001/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "3. Aplicaciones Lineales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004001/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "3.1. Definición de aplicación. Aplicaciones inyectivas, suryectivas y biyectivas. Definición y propiedades de las aplicaciones lineales Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004001/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "3.2. Expresión de una aplicación lineal respecto de una base. Matriz asociada a una aplicación lineal Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004001/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "3.3. Cambios de base de vectores y de endomorfismos lineales. Semejanza y congruencia de matrices Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004001/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "3.4. Definición y propiedades de la imagen, núcleo y rango de una aplicación lineal o matriz. Teorema del rango-nulidad Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004001/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "3.5. Composición e inversas de aplicaciones lineales. Relación con el producto matricial y con la inversa de una matriz Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004001/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "4. Sistemas de Ecuaciones Lineales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004001/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "4.1. Definición de un sistema lineal. Expresión matricial de un sistema lineal Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004001/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "4.2. Estructura de las soluciones de un sistema lineal Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004001/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Clausura, dependencia e independencia lineal. Subespacios vectoriales Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004001/2025-26/syllabus/20> a ns1:SyllabusItem ;
    ns1:itemIndex 20 ;
    ns1:syllabusDescription "4.3. Teorema de Rouché-Frobenius Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004001/2025-26/syllabus/21> a ns1:SyllabusItem ;
    ns1:itemIndex 21 ;
    ns1:syllabusDescription "4.4. Resolución de sistemas por reducción gaussiana Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004001/2025-26/syllabus/22> a ns1:SyllabusItem ;
    ns1:itemIndex 22 ;
    ns1:syllabusDescription "5. Producto Escalar y Norma. Espacios euclídeos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004001/2025-26/syllabus/23> a ns1:SyllabusItem ;
    ns1:itemIndex 23 ;
    ns1:syllabusDescription "5.1. Definición y propiedades del producto escalar y de la norma en R^n y C^n. Producto interno y norma en espacios vectoriales generales. Espacios euclídeos Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004001/2025-26/syllabus/24> a ns1:SyllabusItem ;
    ns1:itemIndex 24 ;
    ns1:syllabusDescription "5.2. Ortogonalidad. Suplementario ortogonal de un subespacio. Familias y bases ortogonales y ortonormales Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004001/2025-26/syllabus/25> a ns1:SyllabusItem ;
    ns1:itemIndex 25 ;
    ns1:syllabusDescription "5.3. Matrices unitarias y ortogonales. Matrices de giro. Propiedades Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004001/2025-26/syllabus/26> a ns1:SyllabusItem ;
    ns1:itemIndex 26 ;
    ns1:syllabusDescription "5.4. Ortogonalización de Gram-Schmidt Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004001/2025-26/syllabus/27> a ns1:SyllabusItem ;
    ns1:itemIndex 27 ;
    ns1:syllabusDescription "5.5. Teorema de la proyección ortogonal. Matrices de proyección ortogonal Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004001/2025-26/syllabus/28> a ns1:SyllabusItem ;
    ns1:itemIndex 28 ;
    ns1:syllabusDescription "5.6. El problema de mínimos cuadrados Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004001/2025-26/syllabus/29> a ns1:SyllabusItem ;
    ns1:itemIndex 29 ;
    ns1:syllabusDescription "6. Diagonalización de Matrices Cuadradas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004001/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "1.3. Bases y dimensión de un subespacio vectorial Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004001/2025-26/syllabus/30> a ns1:SyllabusItem ;
    ns1:itemIndex 30 ;
    ns1:syllabusDescription "6.1. Introducción a la diagonalización de matrices Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004001/2025-26/syllabus/31> a ns1:SyllabusItem ;
    ns1:itemIndex 31 ;
    ns1:syllabusDescription "6.2. Definición de valor y vector propio de una matriz cuadrada Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004001/2025-26/syllabus/32> a ns1:SyllabusItem ;
    ns1:itemIndex 32 ;
    ns1:syllabusDescription "6.3. Polinomio característico y subespacios propios de una matriz cuadrada Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004001/2025-26/syllabus/33> a ns1:SyllabusItem ;
    ns1:itemIndex 33 ;
    ns1:syllabusDescription "6.4. Diagonalización de una matriz cuadrada. Propiedades de la diagonalización. Polinomios de matrices. Teorema de Cayley-Hamilton Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004001/2025-26/syllabus/34> a ns1:SyllabusItem ;
    ns1:itemIndex 34 ;
    ns1:syllabusDescription "6.5. Diagonalización unitaria y ortogonal. Teorema espectral. Descomposición espectral de una matriz Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004001/2025-26/syllabus/35> a ns1:SyllabusItem ;
    ns1:itemIndex 35 ;
    ns1:syllabusDescription "7. Formas Bilineales y Cuadráticas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004001/2025-26/syllabus/36> a ns1:SyllabusItem ;
    ns1:itemIndex 36 ;
    ns1:syllabusDescription "7.1. Definiciones y propiedades de las formas bilineales y cuadráticas. Matriz de Gram de una forma bilineal o cuadrática Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004001/2025-26/syllabus/37> a ns1:SyllabusItem ;
    ns1:itemIndex 37 ;
    ns1:syllabusDescription "7.2. Cocientes de Rayleigh. Clasificación de matrices reales simétricas. Criterio de Sylvester Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004001/2025-26/syllabus/38> a ns1:SyllabusItem ;
    ns1:itemIndex 38 ;
    ns1:syllabusDescription "7.3. Aplicación de las formas cuadráticas a la clasificación y el estudio de las curvas cónicas Sin subniveles"@es .

