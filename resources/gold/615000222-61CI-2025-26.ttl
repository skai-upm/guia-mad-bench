<https://guia-kg.skai.etsisi.upm.es/resource/615000222/2025-26/CC7> a ns1:Competency ;
    ns1:competencyCode "CC7" ;
    ns1:competencyDescription "Conocimiento, diseño y utilización de forma eficiente los tipos y estructuras de datos más adecuados a la resolución de un problema."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000222/2025-26/CG04> a ns1:Competency ;
    ns1:competencyCode "CG04" ;
    ns1:competencyDescription "Conocimiento de los fundamentos del uso y programación de los computadores, los sistemas operativos, las bases de datos y, en general, los programas informáticos con aplicación en ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000222/2025-26/CT2> a ns1:Competency ;
    ns1:competencyCode "CT2" ;
    ns1:competencyDescription "Resolución de problemas: Identificar, analizar y definir los elementos significativos que constituyen un problema para resolverlo con criterio y de forma efectiva."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000222/2025-26/RA216> a ns1:LearningResult ;
    ns1:learningResultCode "RA216" ;
    ns1:learningResultDescription "Establece estrategias de pruebas y depuración de programas utilizando trazas y/o debug"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000222/2025-26/RA23> a ns1:LearningResult ;
    ns1:learningResultCode "RA23" ;
    ns1:learningResultDescription "Resuelve problemas definiendo los elementos significativos que los constituyen, de manera razonada, expresando con precisión las argumentaciones necesarias y las conclusiones"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000222/2025-26/RA67> a ns1:LearningResult ;
    ns1:learningResultCode "RA67" ;
    ns1:learningResultDescription "Comprende los elementos de los lenguajes de programación de un paradigma estructurado"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000222/2025-26/RA68> a ns1:LearningResult ;
    ns1:learningResultCode "RA68" ;
    ns1:learningResultDescription "Modela y diseña soluciones atendiendo a los compromisos de eficiencia y modularidad"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000222/2025-26/RA69> a ns1:LearningResult ;
    ns1:learningResultCode "RA69" ;
    ns1:learningResultDescription "Implementa, prueba y verifica soluciones atendiendo a criterios de eficacia, legibilidad y documentación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000222/2025-26/RA70> a ns1:LearningResult ;
    ns1:learningResultCode "RA70" ;
    ns1:learningResultDescription "Utiliza entornos y herramientas de desarrollo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000222/2025-26/RA71> a ns1:LearningResult ;
