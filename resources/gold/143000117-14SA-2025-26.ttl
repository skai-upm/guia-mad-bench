    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000117/2025-26/didactic_resource/5> a ns1:DidacticResource ;
    ns1:bibliographyTitle "HALE, F.J., Introduction to space flight, Prentice-Hall, 1994."@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000117/2025-26/didactic_resource/6> a ns1:DidacticResource ;
    ns1:bibliographyTitle "GALLAIS, P., Atmospheric re-entry vehicle mechanics, Springer, 2007."@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000117/2025-26/didactic_resource/7> a ns1:DidacticResource ;
    ns1:bibliographyTitle "HIRSCHEL, E.H., Selected aerothermodynamic design problems of hypersonic flight vehicles, AIAA, 2009."@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000117/2025-26/didactic_resource/8> a ns1:DidacticResource ;
