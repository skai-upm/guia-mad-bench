        <https://guia-kg.skai.etsisi.upm.es/resource/angel.sanz.andres%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/ja.cardenas%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/luis.ayuso%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/mikel.ogueta%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/rodolfo.sant%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/s.franchini%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/sergio.marin.coca%40upm.es> ;
    schema:name "Aerodinámica de Altas Velocidades y Fenómenos de Reentrada"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000117/2025-26/E01> a ns1:Competency ;
    ns1:competencyCode "E01" ;
    ns1:competencyDescription "Aplicar los principios físicos y matemáticos avanzados y los métodos numéricos empleados en el análisis de problemas típicos de la ingeniería de sistemas espaciales. Evaluar e interpretar críticamente los resultados obtenidos con estos métodos, tanto cualitativa como cuantitativamente"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000117/2025-26/E03> a ns1:Competency ;
    ns1:competencyCode "E03" ;
    ns1:competencyDescription "Conocer y comprender el entorno espacial y planetario, y su efecto en la operación de los vehículos aeroespaciales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000117/2025-26/E07> a ns1:Competency ;
    ns1:competencyCode "E07" ;
    ns1:competencyDescription "Conocer las fases de diseño, desarrollo, integración, ensayos, lanzamiento y operación en órbita de un vehículo espacial."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000117/2025-26/E24> a ns1:Competency ;
    ns1:competencyCode "E24" ;
    ns1:competencyDescription "Evaluar la bondad de un determinado diseño para satisfacer los requisitos de misión"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000117/2025-26/RA11> a ns1:LearningResult ;
    ns1:learningResultCode "RA11" ;
    ns1:learningResultDescription "Resolver problemas relacionados con flujo hipersónico no viscoso."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000117/2025-26/RA12> a ns1:LearningResult ;
    ns1:learningResultCode "RA12" ;
    ns1:learningResultDescription "Entender los problemas relacionados con flujo hipersónico viscoso."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000117/2025-26/RA13> a ns1:LearningResult ;
    ns1:learningResultCode "RA13" ;
    ns1:learningResultDescription "Entender los efectos de las altas temperaturas en la aerodinámica hipersónica."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000117/2025-26/RA14> a ns1:LearningResult ;
    ns1:learningResultCode "RA14" ;
    ns1:learningResultDescription "Entender los problemas del diseño de los vehículos lanzadores y de reentrada."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000117/2025-26/didactic_resource/1> a ns1:DidacticResource ;
    ns1:bibliographyTitle "BARRERO, A., MESEGUER, J. & SANZ ANDRÉS, A., Aerodinámica de altas velocidades. 2ª edición, Garceta Grupo Editorial, Madrid, España, 2011."@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000117/2025-26/didactic_resource/2> a ns1:DidacticResource ;
    ns1:bibliographyTitle "ANDERSON, J.D., Hypersonic and high-temperature gas dynamics, AIAA, 2006."@es ;
    ns1:bibliographyType "Bibliografía"@es .

