<https://guia-kg.skai.etsisi.upm.es/resource/143000117/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Introducción a la Aerodinámica de altas velocidades"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000117/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Introducción de la asignatura. 1.2 Historia, presente y futuro de la AAV. 1.3. Problemas de la entrada atmosférica. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000117/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "6.1. Ecuaciones generales de la dinámica de la re-entrada. 6.2. Re-entrada balística. 6.3. Re-entrada en vuelo de planeo. 6.4. Movimiento fugoide. 6.5. Solución numérica de la dinámica de la re-entrada. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000117/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "2. Modelos de atmósferas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000117/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "2.1. Atmósfera Estándar Internacional. 2.2. Modelos dinámicos de atmósferas. 2.3. Modelos empíricos. 2.4. Atmósferas planetarias. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000117/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "3. Aerodinámica de altas velocidades Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000117/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "4. Métodos numéricos en aerodinámica de altas velocidades"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000117/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "4.1. Proceso de trabajo en CFD. 4.2. Preproceso: Diseño. 4.3. Preproceso: Mallado. 4.4. Cálculo en hipersónico (Fluent). 4.5. Posproceso. 4.6. Turbulencia. 4.7. Trabajo final. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000117/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "5. Decaimiento orbital"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000117/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "5.1. Ecuación horaria del decaimiento orbital. 5.2. Tiempo de degradación, duración de una misión espacial. 5.3. Análisis de sensibilidad. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000117/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "6. Dinámica de la entrada atmosférica"@es .

