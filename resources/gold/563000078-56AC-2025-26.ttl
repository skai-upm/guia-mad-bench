    ns1:inpersonHours "32 horas (41%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation """La asignatura estudia materiales polímeros en aplicación en envases y embalajes y sus técnicas de fabricación. Se destaca el uso sostenible de estos materiales, mediante la optimización de los procesos con el mínimo consumo energético y recursos y mínimas emisiones, reutilización de los productos, reciclado de los materiales, etc.
La asignatura esta relacionada el lo ODS12, ODS13 Y ODS14 . Si bien en mayor o menor medida podría estar relacionada con casi todas los objetivos de desarrollo sostenible"""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "32 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/563000078/2025-26/eventSchedule> ;
    schema:description "Se estudiarán los diferentes tipos de materiales poliméricos y compuestos con aplicación en el campo de envases y embalajes, incluyendo la selección de materiales para aplicaciones específicas. Se analizarán las características de los diferentes métodos de transformación de materiales poliméricos y compuestos para aplicación en el campo del envases y embalajes, y los requisitos de los materiales para la selección de la técnica de moldeo que permitiá un diseño específico del prducto fabricado. Se analizarán finalmente las posibilidades de reciclado del producto de base polimérica, una vez se ha acabado su vida útil."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/carmen.fonseca%40upm.es> ;
    schema:inLanguage "Inglés/Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/almudena.ochoa%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/carmen.fonseca%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/t.aguinaco%40upm.es> ;
    schema:name "Materiales Polimericos y Nanocompuestos para Envase y Embalaje"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000078/2025-26/CE1> a ns1:Competency ;
    ns1:competencyCode "CE1" ;
    ns1:competencyDescription "Capacidad de diseñar, innovar y gestionar nuevos productos teniendo en cuenta criterios de calidad y medioambientales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000078/2025-26/CE5> a ns1:Competency ;
    ns1:competencyCode "CE5" ;
    ns1:competencyDescription "Capacidad para seleccionar los materiales adecuados para un correcto diseño de producto"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000078/2025-26/CE7> a ns1:Competency ;
    ns1:competencyCode "CE7" ;
    ns1:competencyDescription "Capacidad para realizar proyectos de lanzamiento y comercialización de productos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000078/2025-26/CG4> a ns1:Competency ;
    ns1:competencyCode "CG4" ;
    ns1:competencyDescription "Conocimiento de los procesos industriales para ser capaz de decidir sobre los criterios adecuados en la fabricación de productos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000078/2025-26/RA27> a ns1:LearningResult ;
    ns1:learningResultCode "RA27" ;
    ns1:learningResultDescription "Aplicar el conocimiento de las propiedades funcionales de los materiales poliméricos a las aplicaciones en el campo del envase y embalaje."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000078/2025-26/RA28> a ns1:LearningResult ;
    ns1:learningResultCode "RA28" ;
    ns1:learningResultDescription "Conocer y seleccionar distintos materiales poliméricos avanzados y compuestos y sus procesos de fabricación en el campo de envase y embalaje"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000078/2025-26/RA29> a ns1:LearningResult ;
    ns1:learningResultCode "RA29" ;
    ns1:learningResultDescription "Conocer las posibilidades de diseño de moldes, cabezales y boquillas de acuerdo a la forma y las dimensiones del producto y propiedades finales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000078/2025-26/RA30> a ns1:LearningResult ;
    ns1:learningResultCode "RA30" ;
    ns1:learningResultDescription "Analizar la viabilidad de reciclado de distintos materiales poliméricos y sus mezclas"@es .

