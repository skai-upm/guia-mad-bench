    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/55000044/2025-26/syllabus> ;
    ns1:inpersonHours "36 horas (46.2%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation ""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "36 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/55000044/2025-26/eventSchedule> ;
    schema:description """La asignatura de Alemán 1 tiene como finalidad capacitar al alumnado para usar el idioma de manera suficiente, receptiva y productivamente, tanto en forma hablada como escrita, así como para mediar entre hablantes en alemán despacio, en situaciones cotidianas y de inmediata necesidad que requieran comprender y producir textos o discursos breves, en diversos registros y en lengua estándar, que traten de aspectos básicos concretos de temas generales y que contengan expresiones, léxico y estructuras de uso frecuente.
La asignatura de Alemán 1 presenta las características del nivel de competencia A1 según se define en el Marco Común Europeo de Referencia para las Lenguas"""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/ismael.arinas%40upm.es> ;
    schema:inLanguage "Alemán/Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/elena.zapatero%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/ismael.arinas%40upm.es> ;
    schema:name "Aleman I"@es .

