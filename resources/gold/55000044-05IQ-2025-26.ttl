<https://guia-kg.skai.etsisi.upm.es/resource/55000044/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Tema 1. Saludar y presentarse."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000044/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Fórmulas para presentarse y saludarse. Los números Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000044/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "4.1. Concertar citas. Fechas, meses y estaciones del año. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000044/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "4.2. Los verbos modales. El conector \"denn\". Preposiciones temporales Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000044/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "5. Tema 5. Tiempo libre"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000044/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "5.1. Actividades para el tiempo libre. El fin de semana. ¿Qué hora es? ¿A qué hora nos vemos? Prendas de vestir, los colores Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000044/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "5.2. El presente: verbos con vocales cambiantes y verbos con sílabas separables. El pretérito perfecto compuesto. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000044/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "6. Tema 6. Vivienda y turismo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000044/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "6.1. Anuncios y conversaciones sobre la búsqueda de vivienda y mobiliario. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000044/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "6.2. El pretérito perfecto compuesto; formas irregulares y verbos con sílabas separables y no separables. Complemento dativo y acusativo de lugar. El imperativo Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000044/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Los verbos regulares: el presente. El sustantivo. Pronombres personales. Oraciones de interrogación. Partículas modales Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000044/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "2. Tema 2. Personas y objetos. La familia."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000044/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "2.1. La familia. Distintas generaciones. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000044/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "2.2. Los artículos. El complemento acusativo. Las oraciones de interrogación. El pretérito perfecto. Los conectores \"aber\", \"oder\" y \"und\" Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000044/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "3. Tema 3. La vida del estudiante"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000044/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "3.1. Leer la hora. La comida. Los precios. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000044/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "3.2. Los pronombres personales. Las oraciones de interrogación. Partículas modales Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000044/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "4. Tema 4. Vivir y trabajar"@es .

