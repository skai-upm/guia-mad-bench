    schema:numberOfCredits 3.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/55000044/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/55000044/2025-26/CG%205>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55000044/2025-26/CG%206> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/55000044/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55000044/2025-26/didactic_resource/2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55000044/2025-26/didactic_resource/3> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/55000044/2025-26/evaluation> ;
