<https://guia-kg.skai.etsisi.upm.es/resource/55000044/2025-26/didactic_resource/1> a ns1:DidacticResource ;
    ns1:bibliographyDescription "Die Lektionen im Kursbuch enthalten jeweils eine sich abgeschlossene Lektionesgeschichte. Im MIttelpunkt stehen Personen, die sich in Situationen befinden, die das Agieren im deutschsprachigen Umfeld erlauben."@es ;
    ns1:bibliographyTitle "DaF kompakt A1 Kurs"@es ;
    ns1:bibliographyType "Otros"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000044/2025-26/didactic_resource/2> a ns1:DidacticResource ;
    ns1:bibliographyDescription "Das Buch richtet sich an Erwachsene, die Deutsch lernen. Dabei wird Grammatik in sprachliches Handeln integriert."@es ;
    ns1:bibliographyTitle "studio d A1"@es ;
    ns1:bibliographyType "Otros"@es .

