        <https://guia-kg.skai.etsisi.upm.es/resource/mario.vega%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/nestor.lucas%40upm.es> ;
    schema:name "Sistemas Operativos"@es .

