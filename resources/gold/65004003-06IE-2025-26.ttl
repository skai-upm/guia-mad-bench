    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/65004003/2025-26/eventSchedule> ;
    schema:description "En esta asignatura, de carácter básico, se estudian las funciones reales de varias variables y constituye la continuación del estudio realizado en la asignatura de Cálculo I relativo a funciones de una variable. Se generalizan conceptos anteriores y se añaden otros nuevos propios del análisis matemático en varias variables, así como el análisis vectorial y los correspondientes teoremas. Con todo ello, se busca que el alumno que curse y supere esta asignatura esté capacitado para resolver problemas matemáticos que puedan plantearse en distintas disciplinas científicas y de ingeniería."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/ramon.rodripons%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/bogar.diaz%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/carlos.paredes%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/ramon.rodripons%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/santiago.gomez%40upm.es> ;
    schema:name "Calculo II"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004003/2025-26/CE2> a ns1:Competency ;
    ns1:competencyCode "CE2" ;
    ns1:competencyDescription "Aplicar los conocimientos sobre ecuaciones diferenciales y ecuaciones en derivadas parciales a problemas de ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004003/2025-26/CE3> a ns1:Competency ;
    ns1:competencyCode "CE3" ;
    ns1:competencyDescription "Conocer los fundamentos matemáticos de los métodos numéricos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004003/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Conocer y aplicar conocimientos de ciencias y tecnologías básicas a la práctica de la Ingeniería de la Energía."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004003/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Aplicar los conocimientos adquiridos para identificar, formular y resolver problemas dentro de contextos amplios y multidisciplinarios, siendo capaces de integrar conocimientos, trabajando en equipos multidisciplinares."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004003/2025-26/CG5> a ns1:Competency ;
    ns1:competencyCode "CG5" ;
    ns1:competencyDescription "Saber comunicar los conocimientos y conclusiones, tanto de forma oral, escrita y gráfica, a públicos especializados y no especializados de un modo claro y sin ambigüedades."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004003/2025-26/RA16> a ns1:LearningResult ;
    ns1:learningResultCode "RA16" ;
    ns1:learningResultDescription "Conocer las técnicas de cálculo en varias variables."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004003/2025-26/RA17> a ns1:LearningResult ;
    ns1:learningResultCode "RA17" ;
    ns1:learningResultDescription "Aplicar el desarrollo en serie a la resolución de problemas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004003/2025-26/RA18> a ns1:LearningResult ;
    ns1:learningResultCode "RA18" ;
    ns1:learningResultDescription "Aplicar los recursos del cálculo diferencial multivariable a la resolución de problemas en ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004003/2025-26/RA19> a ns1:LearningResult ;
    ns1:learningResultCode "RA19" ;
    ns1:learningResultDescription "Aplicar los recursos del cálculo integral multivariable a la resolución de problemas en ingeniería."@es .

