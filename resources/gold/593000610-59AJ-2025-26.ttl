    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/593000610/2025-26/eventSchedule> ;
    schema:description """1. Short range radio characteristics and applications.
2. Radio frequency identification (RFID)
3. Near Field Communications (NFC): Proximity and Vicinity
4. Wireless Personal Area Nettworks: Bluetooth and Bluetooth Low Energy (BLE)
5. Ultra-wide band Technology (UWB)
6. Wireless Local Area Networks (IEEE 802.11)"""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/jose.arques%40upm.es> ;
