    ns1:competencyCode "CE51" ;
    ns1:competencyDescription "Comprender los procesos para la gestión financiera de las empresas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000102/2025-26/CE66> a ns1:Competency ;
    ns1:competencyCode "CE66" ;
    ns1:competencyDescription "Comprender las diferentes teorías sobre la organización de la empresa."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000102/2025-26/CE67> a ns1:Competency ;
    ns1:competencyCode "CE67" ;
    ns1:competencyDescription "Comprender la organización funcional de la empresa: sus objetivos y técnicas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000102/2025-26/CG15> a ns1:Competency ;
    ns1:competencyCode "CG15" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de planificar eficientemente los trabajos en el ámbito de la administración y dirección de empresas, priorizando las tareas a desempeñar y evaluando los recursos y el tiempo necesario para llevarlas a cabo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000102/2025-26/CG16> a ns1:Competency ;
    ns1:competencyCode "CG16" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de comunicar conocimientos y conclusiones del ámbito de la administración y dirección de empresas, tanto de forma oral como escrita, a públicos especializados y no especializados, expresándose de manera fluida y sin ambigüedades."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000102/2025-26/CG19> a ns1:Competency ;
    ns1:competencyCode "CG19" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de trabajar en equipos multidisciplinares, aplicando los conocimientos adquiridos en el ámbito de la administración y dirección de empresas, fomentando el espíritu de equipo y la coordinación en las tareas de los diversos miembros."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000102/2025-26/CG23> a ns1:Competency ;
    ns1:competencyCode "CG23" ;
    ns1:competencyDescription "Que los estudiantes adquieran un compromiso ético en su trabajo en el ámbito de la administración y dirección de empresas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000102/2025-26/RA86> a ns1:LearningResult ;
    ns1:learningResultCode "RA86" ;
    ns1:learningResultDescription "Comprender los principios fundamentales de la Teoría de la Empresa y los conceptos y herramientas necesarios para la dirección de organizaciones."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000102/2025-26/RA89> a ns1:LearningResult ;
    ns1:learningResultCode "RA89" ;
    ns1:learningResultDescription "Desarrollar la capacidad de búsqueda, almacenamiento y tratamiento de información para la toma de decisiones y el aprendizaje autónomo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000102/2025-26/RA91> a ns1:LearningResult ;
    ns1:learningResultCode "RA91" ;
    ns1:learningResultDescription "Poder exponer y comunicar sus ideas y reflexiones, tanto de forma oral como escrita."@es .

