    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/145009032/2025-26/eventSchedule> ;
    schema:description "Habilitar al alumno para la utilización de parámetros en el diseño, y hacer que el usuario de CATIA pase de ser un principiante a manejar toda la riqueza avanzada de CATIA en cuanto a la posibilidad de programar aplicaciones geométricas dentro del propio entorno. Se hará hincapié en las herramientas internas de CATIA que permiten parametrizar diseños sin necesidad de recurrir a lenguajes de programación externos (VisualBasic Script) que permitirán automatizar tareas repetitivas, acelerar la generación de geometrías complejas y automatizar el máximo número posible de etapas del proceso de diseño."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/mariadolores.sondesa%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/mariadolores.sondesa%40upm.es> ;
    schema:name "Uso de Parámetros, Herramientas de Automatización y Simulaciones en Catia V5: un Enfoque Práctico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145009032/2025-26/CE01> a ns1:Competency ;
    ns1:competencyCode "CE01" ;
    ns1:competencyDescription "Capacidad para la resolución de los problemas matemáticos que puedan plantearse en la ingeniería. Aptitud para aplicar los conocimientos sobre: álgebra lineal; geometría; geometría diferencial; cálculo diferencial e integral; ecuaciones diferenciales y en derivadas parciales; métodos numéricos; algoritmos numéricos; estadística y optimización."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145009032/2025-26/CE05> a ns1:Competency ;
    ns1:competencyCode "CE05" ;
    ns1:competencyDescription "Capacidad de visión espacial y conocimiento de las técnicas de representación gráfica, tanto por métodos tradicionales de geometría métrica y geometría descriptiva, como mediante las aplicaciones de diseño asistido por ordenador."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145009032/2025-26/CE17> a ns1:Competency ;
    ns1:competencyCode "CE17" ;
    ns1:competencyDescription "Conocimiento adecuado y aplicado a la ingeniería de: Los elementos fundamentales de los diversos tipos de aeronaves; los elementos funcionales del sistema de navegación aérea y las instalaciones eléctricas y electrónicas asociadas; los fundamentos del diseño y construcción de aeropuertos y sus diversos elementos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145009032/2025-26/CE55> a ns1:Competency ;
    ns1:competencyCode "CE55" ;
    ns1:competencyDescription "Conocimiento adecuado y aplicado a la Ingeniería de los métodos de diseño y proyecto aeronáutico"@es .

