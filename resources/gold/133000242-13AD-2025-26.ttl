    ns1:hasItem <https://guia-kg.skai.etsisi.upm.es/resource/133000242/2025-26/syllabus/0>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000242/2025-26/syllabus/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000242/2025-26/syllabus/10>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000242/2025-26/syllabus/11>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000242/2025-26/syllabus/12>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000242/2025-26/syllabus/13>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000242/2025-26/syllabus/2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000242/2025-26/syllabus/3>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000242/2025-26/syllabus/4>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000242/2025-26/syllabus/5>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000242/2025-26/syllabus/6>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000242/2025-26/syllabus/7>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000242/2025-26/syllabus/8>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000242/2025-26/syllabus/9> .

<https://guia-kg.skai.etsisi.upm.es/resource/133000242/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Introducción. El material genético."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000242/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Genética directa. Genotipo y fenotipo. Interacción y epistasis. Pleiotropía. Factores letales. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000242/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "3.1. Introducción. Genética cuantitativa. Valor aditivo. Genes mayores y menores. Aditividad, dominancia y sobredominancia. Heredabilidad. Predicción de la ganancia genética. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000242/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "3.2. Ensayos. Diseño de cruzamientos. Ciclo de mejora. Selección de rasgos múltiples. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000242/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "3.3. Mejora para la resistencia. Resistencia a factores bióticos y abióticos. Mejora para la producción. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000242/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "3.4. Materiales de Base y Materiales Forestales de Reproducción. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000242/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. El material genético. Estructura del ADN. Replicación. Mitosis y meiosis. Recombinación y mapas genéticos. Expresión genética. Epigenética. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000242/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "1.3. Marcadores moleculares. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000242/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "2. Estrategias de conservación de recursos genéticos forestales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000242/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "2.1. Introducción. Genética de poblaciones. Equilibrio de Hardy-Weinberg. Fuerzas evolutivas y alteraciones del equilibrio. Estimadores de diversidad y diferenciación. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000242/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "2.2. Análisis de recursos genéticos. Diversidad. Flujo genético. Aislamiento. Tamaño poblacional. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000242/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "2.3. Conservación evolutiva y conservación estática. Conservación in situ y conservación ex situ. Criterios para el establecimiento de redes de conservación de RGF. Monitorización de RGF. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000242/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
