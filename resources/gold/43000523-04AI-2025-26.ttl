<https://guia-kg.skai.etsisi.upm.es/resource/43000523/2025-26/MICCPCB07> a ns1:Competency ;
    ns1:competencyCode "MICCPCB07" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en entornos nuevos o poco conocidos dentro de contextos más amplios (o multidisciplinares) relacionados con su área de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000523/2025-26/MICCPCB08> a ns1:Competency ;
    ns1:competencyCode "MICCPCB08" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de integrar conocimientos y enfrentarse a la complejidad de formular juicios a partir de una información que, siendo incompleta o limitada, incluya reflexiones sobre las responsabilidades sociales y éticas vinculadas a la aplicación de sus conocimientos y juicios"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000523/2025-26/MICCPCB09> a ns1:Competency ;
    ns1:competencyCode "MICCPCB09" ;
    ns1:competencyDescription "Que los estudiantes sepan comunicar sus conclusiones y los conocimientos y razones últimas que las sustentan a públicos especializados y no especializados de un modo claro y sin ambigüedades"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000523/2025-26/MICCPCE27> a ns1:Competency ;
    ns1:competencyCode "MICCPCE27" ;
    ns1:competencyDescription "Conocimientos y capacidades que permiten comprender los fenómenos dinámicos del medio océano"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000523/2025-26/MICCPCE30> a ns1:Competency ;
    ns1:competencyCode "MICCPCE30" ;
    ns1:competencyDescription "Capacidad de planificación, gestión y explotación de infraestructuras relacionadas con la ingeniería civil. Incorpora las competencias CB6, CB7 y CB8."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000523/2025-26/MICCPCE32> a ns1:Competency ;
    ns1:competencyCode "MICCPCE32" ;
    ns1:competencyDescription "Capacidad para aplicar los conocimientos técnicos en la evaluación de proyectos, obras e infraestructuras dentro del ámbito de la ingeniería civil."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000523/2025-26/MICCPCGP06> a ns1:Competency ;
    ns1:competencyCode "MICCPCGP06" ;
    ns1:competencyDescription "Conocimiento para aplicar las capacidades técnicas y gestoras en actividades de I+D+i dentro del ámbito de la ingeniería civil. Incorpora las competencias CB6, CB7 y CB8."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000523/2025-26/MICCPCGP07> a ns1:Competency ;
    ns1:competencyCode "MICCPCGP07" ;
    ns1:competencyDescription "Capacidad para planificar, proyectar, inspeccionar y dirigir obras de infraestructuras de trans¬portes terrestres (carreteras, ferrocarriles, puentes, túneles y vías urbanas) o marítimos (obras e ins"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000523/2025-26/MICCPCGP10> a ns1:Competency ;
    ns1:competencyCode "MICCPCGP10" ;
    ns1:competencyDescription "Capacidad para la realización de estudios de planificación territorial, del medio litoral, de la ordenación y defensa de costas y de los aspectos medioambientales relacionados con las infraestructuras. Incorpora las competencias CB6, CB7 y CB8."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000523/2025-26/MICCPCGP18> a ns1:Competency ;
    ns1:competencyCode "MICCPCGP18" ;
    ns1:competencyDescription "Conocimientos adecuados de los aspectos científicos y tecnológicos de métodos matemáticos, analíticos y numéricos de la ingeniería, mecánica de fluidos, mecánica de medios continuos, cálculo de estructuras, ingeniería del terreno, ingeniería marítima, obras y aprovechamientos hidráulicos y obras lineales. Incorpora las competencias CB6, CB7 y CB8."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000523/2025-26/MICCPCT01> a ns1:Competency ;
    ns1:competencyCode "MICCPCT01" ;
    ns1:competencyDescription "Capacidad de preparar y presentar comunicaciones orales, escritas y gráficas, estructurada y argumentadamente. Desarrolla la competencia CB9."@es .

