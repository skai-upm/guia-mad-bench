        <https://guia-kg.skai.etsisi.upm.es/resource/45000210/2025-26/didactic_resource/5>,
        <https://guia-kg.skai.etsisi.upm.es/resource/45000210/2025-26/didactic_resource/6> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/45000210/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/45000210/2025-26/RA221>,
        <https://guia-kg.skai.etsisi.upm.es/resource/45000210/2025-26/RA222> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/45000210/2025-26/syllabus> ;
    ns1:inpersonHours "64 horas y 30 minutos (41.3%)"@es ;
    ns1:numberOfCredits 6.0 ;
    ns1:otherInformation """El alumno debe hacer un seguimiento al día de la asignatura y deberá realizar todos los supuestos que se le propongan para ser capaz de seguir el ritmo acumulativo de conocimientos necesario.
Por otra parte, en esta asignatura se intenta trabajar el objetivo número 8 de la lista de Objetivos de crecimiento sostenible de Naciones Unidas, relativo al trabajo decente y al crecimiento económico. Para ello la asignatura trabaja el concepto de imagen fiel de la empresa y la necesidad de aportar información contable transparente y fiable que contribuya a la creación de relaciones comerciales de confianza y que contribuya a la mejor gestión de la responsabilidad social corporativa de la empresa."""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "64 horas y 30 minutos"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/45000210/2025-26/eventSchedule> ;
    schema:description "En esta asignatura se introduce al alumno en el lenguaje y la metodología contable. Se inicia al alumno en los conceptos básicos contables, en las cuentas anuales y en el manejo contable de las operaciones que tienen lugar en la empresa."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/mariabelen.munoz%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/alberto.martinez.delgado%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/mariabelen.munoz%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/mario.araus%40upm.es> ;
    schema:name "Introducción la Contabilidad"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000210/2025-26/30AD.%20E01> a ns1:Competency ;
    ns1:competencyCode "30AD. E01" ;
    ns1:competencyDescription "Conocer la técnica contable en relación con la situación y los resultados de la empresa, y los flujos habidos en un período."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000210/2025-26/30AD.%20E02> a ns1:Competency ;
    ns1:competencyCode "30AD. E02" ;
    ns1:competencyDescription "Comprender el impacto de las operaciones económicas que desarrollan las empresas en su patrimonio empresarial."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000210/2025-26/30AD.%20G02> a ns1:Competency ;
    ns1:competencyCode "30AD. G02" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de planificar eficientemente los trabajos en el ámbito de la administración y dirección de empresas, priorizando las tareas a desempeñar y evaluando los recursos y el tiempo necesario para llevarlas a cabo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000210/2025-26/30AD.%20G06> a ns1:Competency ;
    ns1:competencyCode "30AD. G06" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de trabajar en equipos multidisciplinares, aplicando los conocimientos adquiridos en el ámbito de la administración y dirección de empresas, fomentando el espíritu de equipo y la coordinación en las tareas de los diversos miembros."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000210/2025-26/30AD.%20G10> a ns1:Competency ;
    ns1:competencyCode "30AD. G10" ;
    ns1:competencyDescription "Que los estudiantes adquieran un compromiso ético en su trabajo en el ámbito de la administración y dirección de empresas."@es .

