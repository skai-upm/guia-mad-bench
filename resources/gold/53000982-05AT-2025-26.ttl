    schema:courseCode 53000982 ;
    schema:hasCourseInstance <https://guia-kg.skai.etsisi.upm.es/resource/53000982/2025-26> ;
    schema:name "Devices And Installations In Railways"@en,
        "Instalaciones y Equipos Ferroviarios"@es ;
    schema:numberOfCredits 3.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/53000982/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/53000982/2025-26/CE3>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53000982/2025-26/CE7>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53000982/2025-26/CE9>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53000982/2025-26/CG%201> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/53000982/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53000982/2025-26/didactic_resource/2> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/53000982/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/53000982/2025-26/RA74>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53000982/2025-26/RA75>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53000982/2025-26/RA76>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53000982/2025-26/RA77>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53000982/2025-26/RA78> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/53000982/2025-26/syllabus> ;
    ns1:inpersonHours "30 horas (38.5%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation """Dentro de la asignatura se realiza al menos una visita a un punto de interés en el entorno de la ciudad de Madrid de aplicación para alguno de los módulos impartidos.
Es habitual también la participación de algún experto de empresas ferroviarias a modo de clase magistral práctica."""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "30 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/53000982/2025-26/eventSchedule> ;
    schema:description """La asignatura está planteada como una exposición de todos los subsistemas que forman parte de un sistema ferroviario con una visión global de integración, y con un detalle que permite calcular hasta un primer orden de magnitud cada uno de esos sistemas.
De esta forma el alumno conseguirá:
Conocer los diversos sistemas que conforman el ferrocarril.
Adquirir la cultura de trabajo ferroviaria.
Concienciarse del carácter multidisciplinar del ferrocarril.
Alcanzar un nivel de cálculo de primer orden de magnitud en los diversos sistemas."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/josemanuel.mera%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/joaquin.maroto%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/josemanuel.mera%40upm.es> ;
    schema:name "Instalaciones y Equipos Ferroviarios"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000982/2025-26/CE3> a ns1:Competency ;
    ns1:competencyCode "CE3" ;
    ns1:competencyDescription "Utilizar conocimientos multidisciplinarios de mecánica, electrotecnia, control, medios continuos y materiales para el desarrollo de procesos, utillajes y máquinas de fabricación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000982/2025-26/CE7> a ns1:Competency ;
    ns1:competencyCode "CE7" ;
    ns1:competencyDescription "Analizar y diseñar vehículos y sistemas vehiculares e interpretar los comportamientos de los principales sistemas vehiculares para su aplicación al diseño y evaluación de sus comportamientos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000982/2025-26/CE9> a ns1:Competency ;
    ns1:competencyCode "CE9" ;
    ns1:competencyDescription "Redactar de documentación técnica y no especializada dentro del ámbito de la ingeniería mecánica. Búsqueda de fuentes y uso de Bases de datos. Difusión de resultados."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000982/2025-26/CG%201> a ns1:Competency ;
    ns1:competencyCode "CG 1" ;
    ns1:competencyDescription "Aplicar conocimientos de ciencias y tecnologías avanzadas a la práctica de la Ingeniería Mecánica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000982/2025-26/RA74> a ns1:LearningResult ;
    ns1:learningResultCode "RA74" ;
    ns1:learningResultDescription "Análisis de las prestaciones de un vehículo ferroviario."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000982/2025-26/RA75> a ns1:LearningResult ;
    ns1:learningResultCode "RA75" ;
    ns1:learningResultDescription "Conocimiento del comportamiento de la vía férrea"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000982/2025-26/RA76> a ns1:LearningResult ;
    ns1:learningResultCode "RA76" ;
    ns1:learningResultDescription "Conocimiento de los sistemas de señalización ferroviaria y su interacción con la operación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000982/2025-26/RA77> a ns1:LearningResult ;
    ns1:learningResultCode "RA77" ;
    ns1:learningResultDescription "Conocer y calcular sistemas de electrificación ferroviaria a nivel básico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000982/2025-26/RA78> a ns1:LearningResult ;
    ns1:learningResultCode "RA78" ;
    ns1:learningResultDescription "Conocer y analizar la dinámica de un vehículo ferroviario tanto en confort como en seguridad"@es .

