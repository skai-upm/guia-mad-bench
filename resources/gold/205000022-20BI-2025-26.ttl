<https://guia-kg.skai.etsisi.upm.es/resource/205000022/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. UT1.- Tecnología de producción de cereales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000022/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Tema 1.- Aspectos comunes al grupo de los cereales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000022/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "1.2.3. Parámetros de producción y calidad de las cebadas utilizadas en la fabricación de piensos. Calidad maltera y calidad cervecera e influencia de las técnicas de cultivo en dichos parámetros de producción y calidad. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000022/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "1.2.4. Exigencias ecológicas: Térmicas, lumínicas, hídricas, edáficas y nutricionales. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000022/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "1.2.5. Técnicas de cultivo. Laboreo, siembra, fertilización mineral y orgánica, manejo de recursos hídricos, recolección, almacenamiento y conservación. Material vegetal. Variedades de cebada. Mejora genética. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000022/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "1.3. Tema 3. Trigo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000022/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "1.3.1. Introducción: Origen y clasificación de los trigos cultivados. Zonas productivas, superficies y rendimientos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000022/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "1.3.2. Morfología: Características de las raíces, hojas, tallo, inflorescencia y grano. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000022/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "1.3.3. Parámetros de producción y calidad del trigo blando y del trigo duro e influencia de las técnicas de cultivo en dichos parámetros de producción y calidad. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000022/2025-26/syllabus/17> a ns1:SyllabusItem ;
