<https://guia-kg.skai.etsisi.upm.es/resource/53001972/2025-26/RA32> a ns1:LearningResult ;
    ns1:learningResultCode "RA32" ;
    ns1:learningResultDescription "Aplicar conocimientos científicos, matemáticos y tecnológicos en sistemas relacionados con la práctica de la ingeniería ambiental"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001972/2025-26/RA42> a ns1:LearningResult ;
    ns1:learningResultCode "RA42" ;
    ns1:learningResultDescription "Utilizar las técnicas, destrezas y herramientas ingenieriles modernas necesarias para la práctica de la ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001972/2025-26/RA5> a ns1:LearningResult ;
    ns1:learningResultCode "RA5" ;
    ns1:learningResultDescription "Será capaz de aplicar las técnicas numéricas a la modelización y resolución de problemas de calidad y gestión de aire, agua y suelos."@es .

