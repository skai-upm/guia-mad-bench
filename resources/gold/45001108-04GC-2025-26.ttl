    ns1:numberOfCredits 9.0 ;
    ns1:otherInformation "Esta asignatura contribuye a los objetivos 6, 8, 9, 10, 11 de desarrollo sostenible de la ONU a través del resultado de aprendizaje RA17, 18, 19 y 20, así como las metas 9.A y 9.B de la Agenda 2030."@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
