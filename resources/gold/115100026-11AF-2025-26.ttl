    ns1:numberOfCredits 6.0 ;
    ns1:otherInformation """La asignatura permite el trabajo de objetivos de desarrollo sostenible del 2030 (ODS), en concreto:
- ODS 3: Salud y bienestar.
- ODS4: Educación de calidad.
- ODS 5: Igualdad de género: lenguaje.
- ODS10: Reducción de las desigualdades
BIBLIOGRAFÍA BÁSICA
Blázquez, D. (2016). Métodos de enseñanza en Educación física: enfoques innovadores para la enseñanza de competencias. Ed. INDE. Barcelona.
Blázquez, D. (1990). Evaluar en educación física. Ed. INDE. Barcelona.
Delgado, M. A. (1991). Los estilos de enseñanza en la educación física. Propuesta para una reforma de la enseñanza. Granada: ICE.
Fernández, E. (2002). Didáctica de la educación física en la educación primaria. Ed. Síntesis. Madrid.
Méndez, R. (2012). Programación del entrenamiento y gestión técnica en salas de fitness y musculación. Ed. Altius Sport. Madrid.
Mosston, M., y Ashworth, S. (2008). Teaching Physical Education. First Online Edition. Pearson education
Muñoz, A. (2012). Caos o Planificación. Estrategias para el docente. Bulletin Dance. Buenos Aires.
Piernas, A.S., y Díaz, I.R. (2016). Metodología de enseñanza en el fútbol. Ed. INDE. Barcelona.
Viciana, J. (2002). Planificar en educación física. Ed. INDE. Barcelona."""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "62 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/115100026/2025-26/eventSchedule> ;
    schema:description "Dotará al futuro Graduado en Ciencias de la Actividad Física y del Deporte de los conocimientos y competencias que le permitan llevar a cabo la enseñanza de las actividades físicas en diferentes campos de actuación con una visión actual, responsable e innovadora, donde pueda comprender y conocer cómo abordar la enseñanza en el ámbito de la educación física, la educación física extraescolar, educación deportiva, así como la gestión de la metodología de enseñanza en contextos de recreación, tiempo libre, entrenamiento o rendimiento."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/maitegomez.lopez%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/aparada%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/maitegomez.lopez%40upm.es> ;
    schema:name "Diseño, Intervención y Evaluación en Afyd"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100026/2025-26/CE01> a ns1:Competency ;
    ns1:competencyCode "CE01" ;
    ns1:competencyDescription "Diseñar, desarrollar y evaluar los procesos de enseñanza¿aprendizaje relativos a la actividad física y el deporte con atención a las características individuales y contextuales de las personas. Nivel 3."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100026/2025-26/CE02> a ns1:Competency ;
    ns1:competencyCode "CE02" ;
    ns1:competencyDescription "Aplicar, de manera fundamentada y argumentada, los principios fisiológicos, biomecánicos, comportamentales y sociales en el diseño y puesta en práctica de propuestas y programas de Educación Física en el contexto educativo. Nivel 3."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100026/2025-26/CE03> a ns1:Competency ;
    ns1:competencyCode "CE03" ;
    ns1:competencyDescription "Identificar y prevenir los riesgos que se derivan para la salud de los escolares en la práctica de actividades físicas inadecuadas o realizadas de forma incorrecta. Nivel 3."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100026/2025-26/CE04> a ns1:Competency ;
    ns1:competencyCode "CE04" ;
    ns1:competencyDescription "Planificar, desarrollar y evaluar la realización de programas de deporte escolar orientados al desarrollo personal y social de las personas implicadas y dotados de una dimensión educativa. Nivel 3."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100026/2025-26/CE05> a ns1:Competency ;
    ns1:competencyCode "CE05" ;
    ns1:competencyDescription "Seleccionar y saber utilizar, en la puesta en práctica de programas de Educación Física, el material y equipamiento deportivo adecuado para cada tipo de actividad y para cada contexto. Nivel 3."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100026/2025-26/CE06> a ns1:Competency ;
    ns1:competencyCode "CE06" ;
    ns1:competencyDescription "Promover y evaluar la formación de hábitos perdurables y autónomos de práctica actividad física y del deporte entre la población escolar. Nivel 3."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100026/2025-26/CG01> a ns1:Competency ;
    ns1:competencyCode "CG01" ;
    ns1:competencyDescription "Desarrollar y mostrar en su aplicación una alta capacidad de análisis y de síntesis de la información relativa al campo de conocimiento y profesional."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100026/2025-26/CG03> a ns1:Competency ;
    ns1:competencyCode "CG03" ;
    ns1:competencyDescription "Organizar y planificar propuestas de acción, programas y actividades propias de su campo profesional en sus diferentes ámbitos de aplicación y desarrollo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100026/2025-26/CG04> a ns1:Competency ;
    ns1:competencyCode "CG04" ;
    ns1:competencyDescription "Mostrar disposición y habilidad para el trabajo y el liderazgo en equipo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100026/2025-26/CG08> a ns1:Competency ;
    ns1:competencyCode "CG08" ;
    ns1:competencyDescription "Aplicar los conocimientos adquiridos en los procesos de formación en la práctica profesional, en diferentes contextos y situaciones."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100026/2025-26/CG13> a ns1:Competency ;
    ns1:competencyCode "CG13" ;
    ns1:competencyDescription "Desarrollar habilidades adecuadas de comunicación oral y escrita en lengua inglesa y en otras lenguas de presencia significativa en el ámbito científico y específico de conocimiento, que permitan la adecuada comunicación y transferencia de conocimientos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100026/2025-26/RA310> a ns1:LearningResult ;
    ns1:learningResultCode "RA310" ;
    ns1:learningResultDescription "Aplicar los principios básicos adquiridos en los módulos de Ciencias Sociales y Ciencias de la Salud a las actividades físico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100026/2025-26/RA311> a ns1:LearningResult ;
    ns1:learningResultCode "RA311" ;
    ns1:learningResultDescription "Diseño de propuestas de enseñanza"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100026/2025-26/RA324> a ns1:LearningResult ;
    ns1:learningResultCode "RA324" ;
    ns1:learningResultDescription "Saber elegir los materiales e instalaciones adecuadas para la práctica de la actividad física y el deporte en diferentes contextos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100026/2025-26/RA325> a ns1:LearningResult ;
    ns1:learningResultCode "RA325" ;
    ns1:learningResultDescription "Aplicar las habilidades físicas básicas a la acción educativa en educación física y deporte."@es .

