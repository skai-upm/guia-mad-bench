        <https://guia-kg.skai.etsisi.upm.es/resource/305000104/2025-26/syllabus/11>,
        <https://guia-kg.skai.etsisi.upm.es/resource/305000104/2025-26/syllabus/12>,
        <https://guia-kg.skai.etsisi.upm.es/resource/305000104/2025-26/syllabus/13>,
        <https://guia-kg.skai.etsisi.upm.es/resource/305000104/2025-26/syllabus/14>,
        <https://guia-kg.skai.etsisi.upm.es/resource/305000104/2025-26/syllabus/15>,
        <https://guia-kg.skai.etsisi.upm.es/resource/305000104/2025-26/syllabus/16>,
        <https://guia-kg.skai.etsisi.upm.es/resource/305000104/2025-26/syllabus/17>,
        <https://guia-kg.skai.etsisi.upm.es/resource/305000104/2025-26/syllabus/18>,
        <https://guia-kg.skai.etsisi.upm.es/resource/305000104/2025-26/syllabus/19>,
        <https://guia-kg.skai.etsisi.upm.es/resource/305000104/2025-26/syllabus/2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/305000104/2025-26/syllabus/3>,
        <https://guia-kg.skai.etsisi.upm.es/resource/305000104/2025-26/syllabus/4>,
        <https://guia-kg.skai.etsisi.upm.es/resource/305000104/2025-26/syllabus/5>,
        <https://guia-kg.skai.etsisi.upm.es/resource/305000104/2025-26/syllabus/6>,
        <https://guia-kg.skai.etsisi.upm.es/resource/305000104/2025-26/syllabus/7>,
        <https://guia-kg.skai.etsisi.upm.es/resource/305000104/2025-26/syllabus/8>,
        <https://guia-kg.skai.etsisi.upm.es/resource/305000104/2025-26/syllabus/9> .

<https://guia-kg.skai.etsisi.upm.es/resource/305000104/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Topología de R^n"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000104/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Normas. Métricas. Bolas abiertas y cerradas. Conjuntos abiertos y cerrados. Interior de un conjunto. Adherencia de un conjunto. Puntos frontera. Conjuntos acotados. Conjuntos compactos. Conjuntos conexos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000104/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "3.2. Propiedades inmediatas de la diferenciabilidad. Matriz Jacobiana. Diferencial de la composición de dos funciones. Regla de la cadena. Gradiente. Interpretación geométrica. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000104/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "3.3. Derivadas parciales iteradas. Teorema de Schwartz. Funciones de clase C^k .Interpretación geométrica. Aproximación de funciones. Polinomio de Taylor. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000104/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "4. Aplicaciones de la derivación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000104/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "4.1. Teorema de la función inversa. Teorema de la función implícita. Cambios de variable. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000104/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "4.2. Parametrizaciones de una curva. Recta tangente a una curva en un punto. Superficies en forma implícita. Superficies parametrizadas. Plano tangente y recta normal a una superficie en un punto. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000104/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "4.3. Conjuntos de nivel. Dimensión. Espacios Tangentes. Relación con el Teorema de Rouché-Frobenius. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000104/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "4.4. Extremos relativos en conjuntos abiertos. Puntos críticos. Criterio de la matriz Hessiana. Extremos condicionados. Método de los multiplicadores de Lagrange. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000104/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "5. Integral de Riemann en varias variables."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000104/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "5.1. Particiones. Propiedades. Sumas superior e inferior asociadas a una partición. Sumas de Riemann. Integral de Riemann. Integración en conjuntos medibles Jordan. Integrabilidad de funciones continuas. Criterio de integrabilidad. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000104/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "5.2. Integrales iteradas. Teorema de Fubini. Descripción de regiones ?horizontales? y ?verticales?. Teorema del cambio de variable. Caso particular de coordenadas polares, cilíndricas y esféricas. Aplicaciones de la integración múltiple. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000104/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Sucesiones acotadas. Sucesiones convergentes. Límite de una sucesión. Convergencia de una sucesión a partir de la convergencia de sus componentes. Teorema de Bolzano-Weierstrass. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000104/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "2. Funciones de varias variables reales. Límites y continuidad."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000104/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "2.1. Funciones reales de variable vectorial. Funciones vectoriales de variable vectorial. Representación de funciones. Curva de nivel. Conjunto de nivel. Secciones. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000104/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "2.2. Límites. Límites según subconjuntos. Continuidad de aplicaciones. Continuidad y operaciones. Continuidad de la composición. Continuidad en un conjunto. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000104/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "2.3. Continuidad uniforme. Teorema de existencia de máximo y mínimo de funciones escalares continuas definidas sobre conjuntos compactos. Si f es continua e inyectiva sobre un compacto entonces tiene inversa continua. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000104/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "2.4. Teorema de los valores intermedios para funciones escalares continuas definidas sobre conjuntos conexos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000104/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "3. Diferenciación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000104/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "3.1. Propiedades. Derivada respecto de un vector en un punto. Derivadas parciales. Diferencial de una función. Relación entre diferenciabilidad y continuidad Sin subniveles"@es .

