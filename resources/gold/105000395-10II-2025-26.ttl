<https://guia-kg.skai.etsisi.upm.es/resource/105000395/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/105000395/2025-26/CG> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/105000395/2025-26/didactic_resource/1> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/105000395/2025-26/evaluation> ;
