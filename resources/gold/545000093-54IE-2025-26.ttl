<https://guia-kg.skai.etsisi.upm.es/resource/545000093/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/545000093/2025-26/CT02>,
        <https://guia-kg.skai.etsisi.upm.es/resource/545000093/2025-26/CT03>,
        <https://guia-kg.skai.etsisi.upm.es/resource/545000093/2025-26/CT04>,
