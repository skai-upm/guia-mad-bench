    schema:name "Laboratorio de Trabajo Crítica Práctica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000876/2025-26/C10> a ns1:Competency ;
    ns1:competencyCode "C10" ;
    ns1:competencyDescription "Integrar los conocimientos adquiridos y articularlos en la elaboración de proyectos arquitectónicos (con carácter original e inéditos), siendo capaces de aportar soluciones en contextos caracterizados por la complejidad e incertidumbre TIPO: Competencias."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000876/2025-26/C3> a ns1:Competency ;
    ns1:competencyCode "C3" ;
    ns1:competencyDescription "Comunicar y trabajar en equipos multidisciplinares vinculados a la formalización del proyecto arquitectónico, articulando las distintas dimensiones internas y externas a la especialidad, en particular aquéllas relativas a los procesos de negociación, toma de decisiones y consecución de consensos colectivos TIPO: Competencias."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000876/2025-26/C6> a ns1:Competency ;
    ns1:competencyCode "C6" ;
    ns1:competencyDescription "Desarrollar laboratorios de pensamiento desde la teoría y crítica contemporánea en el comportamiento de las geometrías y topologías complejas en el proyecto arquitectónico TIPO: Competencias."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000876/2025-26/C9> a ns1:Competency ;
    ns1:competencyCode "C9" ;
    ns1:competencyDescription "Crear áreas de oportunidad proyectual TIPO: Competencias."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000876/2025-26/K1> a ns1:Competency ;
    ns1:competencyCode "K1" ;
    ns1:competencyDescription "Analizar críticamente obras arquitectónicas TIPO: Conocimientos o contenidos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000876/2025-26/K11> a ns1:Competency ;
    ns1:competencyCode "K11" ;
    ns1:competencyDescription "Explicar proyectos de investigación o tesis en proyectos arquitectónicos TIPO: Conocimientos o contenidos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000876/2025-26/K7> a ns1:Competency ;
    ns1:competencyCode "K7" ;
    ns1:competencyDescription "Señalar posibles soluciones arquitectónicas a problemas localizados en nuevos entornos (o contemporáneos) relacionados con el proyecto arquitectónico TIPO: Conocimientos o contenidos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000876/2025-26/K8> a ns1:Competency ;
    ns1:competencyCode "K8" ;
    ns1:competencyDescription "Enunciar tesis novedosas a partir de una información que, siendo limitada, incluya reflexiones sobre las responsabilidades sociales y éticas del proyecto arquitectónico TIPO: Conocimientos o contenidos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000876/2025-26/K9> a ns1:Competency ;
    ns1:competencyCode "K9" ;
    ns1:competencyDescription "Explicar de forma efectiva ideas y proyectos a través de presentaciones y publicaciones TIPO: Conocimientos o contenidos."@es .

