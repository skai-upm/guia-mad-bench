<https://guia-kg.skai.etsisi.upm.es/resource/33000876/2025-26/SK1> a ns1:Competency ;
    ns1:competencyCode "SK1" ;
    ns1:competencyDescription "Aplicar a entornos nuevos o poco conocidos, dentro de contextos más amplios (o multidisciplinares), los conceptos, principios, teorías o modelos relacionados con el área de pensamiento teórico del proyecto arquitectónico TIPO: Habilidades o destrezas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000876/2025-26/SK2> a ns1:Competency ;
    ns1:competencyCode "SK2" ;
