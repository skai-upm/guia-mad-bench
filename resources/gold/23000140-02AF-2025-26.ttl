    schema:name "Evaluacion Participativa, Colaborativa y para el Empoderamiento"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000140/2025-26/CE12> a ns1:Competency ;
    ns1:competencyCode "CE12" ;
    ns1:competencyDescription "Conocer las metodologías participativas en la formulación, ejecución seguimiento y evaluación de un programa o proyecto de desarrollo y su multidimensionalidad (humana, territorial, ambiental)."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000140/2025-26/CE13> a ns1:Competency ;
    ns1:competencyCode "CE13" ;
    ns1:competencyDescription "Conocimiento análisis y aplicación de metodologías de evaluación participativa encaminadas al aprendizaje interno de las organizaciones susceptibles de ser aplicadas a los programas y proyectos de desarrollo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000140/2025-26/CE41> a ns1:Competency ;
    ns1:competencyCode "CE41" ;
    ns1:competencyDescription "Metodologías de investigación científica basadas en la gestión relacional de la información, razonamiento lógico y análisis crítico de documentos, comprensión global y contextual de situaciones complejas y análisis multicriterio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000140/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Habilidades de comunicación escrita y oral: Concluir aportaciones por escrito, desarrollando la capacidad de síntesis y presentación de las ideas propias en un grupo de trabajo y en exposición pública."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000140/2025-26/CG10> a ns1:Competency ;
    ns1:competencyCode "CG10" ;
    ns1:competencyDescription "Valores humanos positivos para la investigación: Respeto a los derechos humanos fundamentales; los principios de igualdad de oportunidades, accesibilidad universal y no discriminación; y los valores propios de una cultura de paz y de valores democráticos. Compromiso con estos derechos, principios y valores, motivación, actitud positiva y entusiasta; ética, integridad y honestidad investigadora"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000140/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Fortalecer conocimiento oral y escrito de idioma inglés"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000140/2025-26/CG4> a ns1:Competency ;
    ns1:competencyCode "CG4" ;
    ns1:competencyDescription "Capacidad crítica para el análisis, síntesis y aprendizaje mediante el intercambio de opiniones, presentando argumentos sólidos y estructurados"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000140/2025-26/CG7> a ns1:Competency ;
    ns1:competencyCode "CG7" ;
    ns1:competencyDescription "Capacidad de trabajo en equipo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000140/2025-26/CG8> a ns1:Competency ;
    ns1:competencyCode "CG8" ;
    ns1:competencyDescription "Capacidad de observación, generación de hipótesis y planteamiento de problemas experimentales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000140/2025-26/RA16> a ns1:LearningResult ;
    ns1:learningResultCode "RA16" ;
    ns1:learningResultDescription "Reconocer las claves de las diferentes metodologías de evaluación participativas comprendiendo la utilidad de cada una a la hora de aplicarlas a casos reales y adaptarlas a cada contexto."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000140/2025-26/RA17> a ns1:LearningResult ;
    ns1:learningResultCode "RA17" ;
    ns1:learningResultDescription "Capacidad de gestionar el cambio y la evolución de los proyectos/programas desde la evaluación y los diferentes recursos metodológicos para involucrar a todos los actores de los proyectos/programas en el proceso."@es .

