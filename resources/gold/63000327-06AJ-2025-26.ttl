    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/63000327/2025-26/eventSchedule> ;
    schema:description """La asignatura pretende que el alumno adquiera conocimientos sobre cuencas hidrológicas e hidrogeológicas, estudios hidrostratigráficos, caracterización del flujo y su hidroquímica.
Evaluación de riesgos geológicos asociados a cuencas,
Determinar afección de cuencas con el desarrollo y abandono de proyectos mineros..
Aplicar el Análisis de cuenca en la investigación y gestión de recursos.
Conocer los mecanismos de formación de cuencas sedimentarias, sus tipos, procesos de relleno. Aplicación a la gestión del espacio subterráneo.
Aplicar la teledetección como herramienta de apoyo en la toma de datos."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/joseeugenio.ortiz%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/joseeugenio.ortiz%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/juan.pous%40upm.es> ;
    schema:name "Análisis de Cuencas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000327/2025-26/CB06> a ns1:Competency ;
    ns1:competencyCode "CB06" ;
    ns1:competencyDescription "Poseer y comprender conocimientos que aporten una base u oportunidad de ser originales en el desarrollo y/o aplicación de ideas, a menudo en un contexto de investigación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000327/2025-26/CB07> a ns1:Competency ;
    ns1:competencyCode "CB07" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en entornos nuevos o poco conocidos dentro de contextos más amplios (o multidisciplinares) relacionados con su área de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000327/2025-26/CB08> a ns1:Competency ;
    ns1:competencyCode "CB08" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de integrar conocimientos y enfrentarse a la complejidad de formular juicios a partir de una información que, siendo incompleta o limitada, incluya reflexiones sobre las responsabilidades sociales y éticas vinculadas a la aplicación de sus conocimientos y juicios"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000327/2025-26/CB09> a ns1:Competency ;
    ns1:competencyCode "CB09" ;
    ns1:competencyDescription "Que los estudiantes sepan comunicar sus conclusiones y los conocimientos y razones últimas que las sustentan a públicos especializados y no especializados de un modo claro y sin ambigüedades"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000327/2025-26/CB10> a ns1:Competency ;
    ns1:competencyCode "CB10" ;
    ns1:competencyDescription "Que los estudiantes posean las habilidades de aprendizaje que les permitan continuar estudiando de un modo que habrá de ser en gran medida autodirigido o autónomo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000327/2025-26/CE03> a ns1:Competency ;
    ns1:competencyCode "CE03" ;
    ns1:competencyDescription "Estar capacitado para el estudio de una cuenca hidrográfica/hidrogeológica compleja, como recurso renovable y en los agentes antrópicos que pudieran afectarlas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000327/2025-26/CE04> a ns1:Competency ;
    ns1:competencyCode "CE04" ;
    ns1:competencyDescription "Estar capacitado para realizar análisis de cuencas sedimentarias de acuerdo a la información geográfica, s.l. disponible realizando modelos de cuenca y, en su caso, analizando informes y transmitiendo conocimiento mediante diálogo con expertos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000327/2025-26/CG01> a ns1:Competency ;
    ns1:competencyCode "CG01" ;
    ns1:competencyDescription "Capacidad para aplicar los conocimientos teóricos y prácticos adquiridos a lo largo del Máster para resolver problemas concretos relacionados con la Ingeniería Geológica y la Geotecnia en cualquier tipo de proyectos, incluidos aquellos que presentan problemas nuevos o afectan a entornos o medios poco conocidos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000327/2025-26/CG02> a ns1:Competency ;
    ns1:competencyCode "CG02" ;
    ns1:competencyDescription "Capacidad para evaluar, diseñar, desarrollar, implementar, gestionar y mejorar productos, sistemas y procesos en los distintos ámbitos de la Ingeniería Geológica, en relación al medio físico usando técnicas analíticas, computacionales o experimentales avanzadas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000327/2025-26/CG03> a ns1:Competency ;
    ns1:competencyCode "CG03" ;
    ns1:competencyDescription "Capacidad para adquirir habilidades y predisposición para el aprendizaje autónomo o dirigido en Ingeniería Geológica que permitan la formación continua, ya sea en el ámbito de la investigación (Doctorado) o del perfeccionamiento profesional."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000327/2025-26/CG05> a ns1:Competency ;
    ns1:competencyCode "CG05" ;
    ns1:competencyDescription "Capacidad para integrar conocimientos de ingeniería geológica y geotecnia y formular juicios, aún cuando la información sea limitada o incompleta."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000327/2025-26/CT02> a ns1:Competency ;
    ns1:competencyCode "CT02" ;
    ns1:competencyDescription "Capacidad para el trabajo en grupo y dirigir, organizar y supervisar equipos multidisciplinares"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000327/2025-26/CT03> a ns1:Competency ;
    ns1:competencyCode "CT03" ;
    ns1:competencyDescription "Creatividad, iniciativa y capacidad emprendedora."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000327/2025-26/RA1> a ns1:LearningResult ;
    ns1:learningResultCode "RA1" ;
    ns1:learningResultDescription "Análisis de los conceptos aprovechamiento sostenible en la explotación de los recursos hidrogeológicos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000327/2025-26/RA10> a ns1:LearningResult ;
    ns1:learningResultCode "RA10" ;
    ns1:learningResultDescription "Conocer y aplicar las tipologías de cuencas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000327/2025-26/RA11> a ns1:LearningResult ;
    ns1:learningResultCode "RA11" ;
    ns1:learningResultDescription "Análisis y evaluación del relleno de cuencas. Crear modelos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000327/2025-26/RA12> a ns1:LearningResult ;
    ns1:learningResultCode "RA12" ;
    ns1:learningResultDescription "La evolución de las cuencas. Aplicación a la investigación de recursos y a la gestión del espacio subterráneo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000327/2025-26/RA2> a ns1:LearningResult ;
    ns1:learningResultCode "RA2" ;
    ns1:learningResultDescription "Capacidad para la evaluación y aplicación geológica de la cuenca y su heterogeneidad litológica: arquitectura sedimentaria, geometría estructural y caracteres litológicos principales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000327/2025-26/RA3> a ns1:LearningResult ;
    ns1:learningResultCode "RA3" ;
    ns1:learningResultDescription "Capacidad de evaluar la geología regional."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000327/2025-26/RA4> a ns1:LearningResult ;
    ns1:learningResultCode "RA4" ;
    ns1:learningResultDescription "Capacidad de analizar y evaluar la geomorfología regional con especial incidencia en los sistemas acuáticos y de ribera."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000327/2025-26/RA5> a ns1:LearningResult ;
    ns1:learningResultCode "RA5" ;
    ns1:learningResultDescription "Evaluar los riesgos geológicos mediante el análisis de cuencas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000327/2025-26/RA6> a ns1:LearningResult ;
    ns1:learningResultCode "RA6" ;
    ns1:learningResultDescription "Analizar y evaluar la relación de cuencas en la ordenación del territorio."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000327/2025-26/RA7> a ns1:LearningResult ;
    ns1:learningResultCode "RA7" ;
    ns1:learningResultDescription "Crear sistemas que permitan determinar la afección en la cuenca tras el abandono minero."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000327/2025-26/RA8> a ns1:LearningResult ;
    ns1:learningResultCode "RA8" ;
    ns1:learningResultDescription "Actuar en equipo con expertos de otras disciplinas en materias relacionadas con la Agua y la extracción de recursos naturales y energéticos, colaborando en el desarrollo de proyectos complejos, definiendo e integrando técnicas y tecnologías con filosofías y protocolos (sostenibilidad, ecogestión, eficiencia, etc.), aplicando para ello una visión integral y capacidad analítica; como asesorar a organismos, empresas e instituciones privadas, estatales o internacionales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000327/2025-26/RA9> a ns1:LearningResult ;
    ns1:learningResultCode "RA9" ;
    ns1:learningResultDescription "Conocer los mecanismos de formación"@es .

