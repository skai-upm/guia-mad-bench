    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/63000123/2025-26/eventSchedule> ;
    schema:description "La asignatura pretende familiarizar a estudiantes de distintas procedencias (graduados en Ingeniería de la Energía, Ingeniería Geológica, Ingeniería en Tecnologías Mineras...), con los recursos energéticos, los parámetros científicos, técnicos, económicos, sociales y ambientales que condicionan su explotación y las técnicas más importantes que permiten reconocer dichos recursos, evaluarlos, establecer su valor de mercado y la repercusión social y ambiental de su explotación."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/isabelkitina.arribas%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/isabelkitina.arribas%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/ramon.rodripons%40upm.es> ;
    schema:name "Investigacion y Gestion de Recursos Energeticos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000123/2025-26/CE04> a ns1:Competency ;
    ns1:competencyCode "CE04" ;
    ns1:competencyDescription "Conocimiento adecuado de modelización, evaluación y gestión de recursos geológicos, incluidas las aguas subterráneas, minerales y termales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000123/2025-26/CE10> a ns1:Competency ;
    ns1:competencyCode "CE10" ;
    ns1:competencyDescription "Capacidad para evaluar y gestionar ambientalmente proyectos, plantas e instalaciones propias de los campos de actividad del ingeniero de minas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000123/2025-26/CG01> a ns1:Competency ;
    ns1:competencyCode "CG01" ;
    ns1:competencyDescription "Capacitación científico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000123/2025-26/CG04> a ns1:Competency ;
    ns1:competencyCode "CG04" ;
    ns1:competencyDescription "Conocimiento de la profesión de Ingeniero de Minas y de las actividades que se puedan realizar en el ámbito de la misma"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000123/2025-26/CG06> a ns1:Competency ;
    ns1:competencyCode "CG06" ;
    ns1:competencyDescription "Capacidad para la exploración, investigación, modelización y evaluación de yacimientos de recursos geológicos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000123/2025-26/CT04> a ns1:Competency ;
    ns1:competencyCode "CT04" ;
    ns1:competencyDescription "Capacidad para trabajar de forma efectiva como individuo, organizando y planificando su propio trabajo, de forma independiente o como miembro de un equipo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000123/2025-26/CT05> a ns1:Competency ;
    ns1:competencyCode "CT05" ;
    ns1:competencyDescription "Capacidad para gestionar la información, identificando las fuentes necesarias, los principales tipos de documentos técnicos y científicos, de una manera adecuada y eficiente"@es .

