<https://guia-kg.skai.etsisi.upm.es/resource/45000129/2025-26/CE%202.> a ns1:Competency ;
    ns1:competencyCode "CE 2." ;
    ns1:competencyDescription "Saber modelizar el comportamiento (mecánico, electrónico, químico o biológico) de los materiales y su integración en componentes y dispositivos./ Know how to model the behavior (mechanical, electronic, chemical or biological) of materials and their integration into components and devices."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000129/2025-26/CE%207.> a ns1:Competency ;
    ns1:competencyCode "CE 7." ;
    ns1:competencyDescription "Saber diseñar, desarrollar y controlar los procesos de producción y transformación de materiales / Know how to design, develop and control the processes of production and transformation of materials"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000129/2025-26/CE%208.> a ns1:Competency ;
    ns1:competencyCode "CE 8." ;
    ns1:competencyDescription "Saber diseÃ±ar y gestionar la utilizaciÃ³n y durabilidad de componentes y dispositivos con materiales, con especial cuidado en el deterioro de materiales y siendo respetuosos con el medio ambiente / Know how to design and manage the use and durability of components and devices with materials, with special care in the deterioration of materials and being respectful with the environment"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000129/2025-26/CG%2011> a ns1:Competency ;
    ns1:competencyCode "CG 11" ;
    ns1:competencyDescription "Responsabilidad y ética profesional/ Responsibility and professional ethics"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000129/2025-26/CG%202> a ns1:Competency ;
    ns1:competencyCode "CG 2" ;
    ns1:competencyDescription "Capacidad de trabajo en equipo/ Ability to work in a team"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000129/2025-26/CG%203> a ns1:Competency ;
    ns1:competencyCode "CG 3" ;
    ns1:competencyDescription "Comunicación oral y escrita"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000129/2025-26/CG%209> a ns1:Competency ;
    ns1:competencyCode "CG 9" ;
    ns1:competencyDescription "Capacidad de trabajo interdisciplinar/ Capacity for interdisciplinary work"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000129/2025-26/RA33> a ns1:LearningResult ;
    ns1:learningResultCode "RA33" ;
    ns1:learningResultDescription "Conocer los principios de funcionamiento y organizativos de los materiales blandos y del material celular. Conocer la dinámica de las interacciones débiles y los mecanismos de autoensamblaje. Conocer y saber predecir la respuesta a campos eléctricos y magnéticos y su interacción con las tensiones de origen mecánico."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000129/2025-26/RA34> a ns1:LearningResult ;
    ns1:learningResultCode "RA34" ;
    ns1:learningResultDescription "Utilizar con soltura la comunicación oral y escrita"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000129/2025-26/RA35> a ns1:LearningResult ;
    ns1:learningResultCode "RA35" ;
    ns1:learningResultDescription "Saber trabajar en equipo en entornos interdisciplinares. Ejecutar el trabajo con responsabilidad y respeto a los demás."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000129/2025-26/RA64> a ns1:LearningResult ;
    ns1:learningResultCode "RA64" ;
    ns1:learningResultDescription "Entender, asimilar y manejar los conceptos básicos que describen el comportamiento químico y biológico de los materiales en su interacción con el entorno. Conocer y saber relacionar dicho comportamiento con la estructura del material y su jerarquización a diferentes escalas atómico, molecular y macroscópico."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000129/2025-26/RA65> a ns1:LearningResult ;
    ns1:learningResultCode "RA65" ;
    ns1:learningResultDescription "Conocer y saber calcular mediante las teorías más relevantes la degradación y corrosión química y biológica de los materiales. Conocer y saber aplicar las técnicas de protección y durabilidad."@es .

