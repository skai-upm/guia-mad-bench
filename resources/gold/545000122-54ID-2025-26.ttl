    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/545000122/2025-26/eventSchedule> ;
    schema:description """Esta asignatura tiene como objetivo fundamental profundizar en el aprendizaje de la teoría macroeconómica, dominar sus modelos básicos y ejercitarse en el análisis e interpretación de los fenómenos económicos y de las políticas macroeconómicas.
En concreto, la asignatura aborda aspectos fundamentales de la teoría macroeconómica y de la política macroeconómica, utilizando un enfoque práctico."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/juanramon.ferrer%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/juanramon.ferrer%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/julio.estavillo%40upm.es> ;
    schema:name "Ampliacion de Macroeconomia"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000122/2025-26/CE56> a ns1:Competency ;
    ns1:competencyCode "CE56" ;
    ns1:competencyDescription "Entender el funcionamiento de los mercados financieros nacionales e internacionales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000122/2025-26/CE57> a ns1:Competency ;
    ns1:competencyCode "CE57" ;
    ns1:competencyDescription "Conocer las principales teorías sobre el comportamiento de la economía tanto a nivel individual como agregado."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000122/2025-26/CE58> a ns1:Competency ;
    ns1:competencyCode "CE58" ;
    ns1:competencyDescription "Comprender las bases que configuran la actual estructura de la economía mundial y española."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000122/2025-26/CE59> a ns1:Competency ;
    ns1:competencyCode "CE59" ;
    ns1:competencyDescription "Conocer la determinación de los principales indicadores y agregados económicos, así como su impacto sobre las decisiones de la empresa."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000122/2025-26/CE60> a ns1:Competency ;
    ns1:competencyCode "CE60" ;
    ns1:competencyDescription "Comprender las variables e indicadores que caracterizan la política macroeconómica de un sector y un entorno geográfico."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000122/2025-26/CE61> a ns1:Competency ;
    ns1:competencyCode "CE61" ;
    ns1:competencyDescription "Comprender el contexto económico, regional, nacional e internacional que rodea a la empresa así como interpretar su impacto en la misma."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000122/2025-26/CG14> a ns1:Competency ;
    ns1:competencyCode "CG14" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de comprender, interpretar, sintetizar y evaluar de forma crítica información proveniente de fuentes diversas en el ámbito de la administración y dirección de empresas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000122/2025-26/CG19> a ns1:Competency ;
    ns1:competencyCode "CG19" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de trabajar en equipos multidisciplinares, aplicando los conocimientos adquiridos en el ámbito de la administración y dirección de empresas, fomentando el espíritu de equipo y la coordinación en las tareas de los diversos miembros."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000122/2025-26/CG20> a ns1:Competency ;
    ns1:competencyCode "CG20" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de trabajar en entornos diversos, comprendiendo y adaptándose a situaciones nuevas en el ámbito de la administración y dirección de empresas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000122/2025-26/CG22> a ns1:Competency ;
    ns1:competencyCode "CG22" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de trabajar en el ámbito de la administración y dirección de empresas aplicando criterios de calidad y sostenibilidad."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000122/2025-26/RA100> a ns1:LearningResult ;
    ns1:learningResultCode "RA100" ;
    ns1:learningResultDescription "Poder exponer y comunicar las soluciones a los problemas tanto de forma oral como escrita."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000122/2025-26/RA124> a ns1:LearningResult ;
    ns1:learningResultCode "RA124" ;
    ns1:learningResultDescription "Entender el funcionamiento de una economía de mercado tanto a nivel microeconómico como macroeconómico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000122/2025-26/RA125> a ns1:LearningResult ;
    ns1:learningResultCode "RA125" ;
    ns1:learningResultDescription "Entender los fundamentos de los intercambios comerciales y del marco monetario que los condiciona, así como sus implicaciones para la adopción de políticas comerciales y macroeconómicas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000122/2025-26/RA127> a ns1:LearningResult ;
    ns1:learningResultCode "RA127" ;
    ns1:learningResultDescription "Saber utilizar correctamente los conceptos e instrumentos básicos del análisis para su aplicación a la realidad económica."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000122/2025-26/RA128> a ns1:LearningResult ;
    ns1:learningResultCode "RA128" ;
    ns1:learningResultDescription "Conocer y gestionar las fuentes de información económica relevante y su contenido. Ser capaz de analizar esa información, y de extraer conclusiones sobre diversos aspectos de la realidad económica."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000122/2025-26/didactic_resource/1> a ns1:DidacticResource ;
    ns1:bibliographyDescription "Libro de texto básico recomendado"@es ;
    ns1:bibliographyTitle "Dornbusch, R., Fischer, S. y Startz, R. (2015) Macroeconomía. (12ª Ed.) McGraw Hill, Madrid."@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000122/2025-26/didactic_resource/2> a ns1:DidacticResource ;
    ns1:bibliographyDescription "Otros libros de texto"@es ;
    ns1:bibliographyTitle "Mankiw, G. (2014) Macroeconomía (8ª Ed.). Antoni Bosch"@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000122/2025-26/didactic_resource/3> a ns1:DidacticResource ;
    ns1:bibliographyDescription "Otros libros de texto"@es ;
    ns1:bibliographyTitle "Blanchard, O. (2017) Macroeconomía (7ª Ed.) Pearson-Prentice Hall, Madrid."@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000122/2025-26/didactic_resource/4> a ns1:DidacticResource ;
    ns1:bibliographyDescription "A lo largo del curso se pondrá a disposición de los alumnos un guión de cada tema. El alumno deberá complementarlo con sus propios apuntes y el libro de texto."@es ;
    ns1:bibliographyTitle "Diapositivas y material didáctico en Moodle"@es ;
    ns1:bibliographyType "Recursos web"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000122/2025-26/didactic_resource/5> a ns1:DidacticResource ;
    ns1:bibliographyDescription "Se proporcionará a los alumnos estadísiticas oficiales de las variables agregadas macroeconómicas más importantes para ilustrar las lecciones teóricas de la asignatura"@es ;
    ns1:bibliographyTitle "Estadísticas sobre variables agregadas macroeconómicas"@es ;
    ns1:bibliographyType "Recursos web"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000122/2025-26/evaluation> a ns1:EvaluationSystem ;
    ns1:evaluationDescription """CALIFICACIÓN DE LA ASIGNATURA MEDIANTE EVALUACIÓN PROGRESIVA/DISTRIBUIDA
La calificación final de la asignatura se obtendrá ponderando cada actividad de evaluación, tal como aparecen descritas en el cronograma y en la tabla de actividades de evaluación, por su peso correspondiente.

EVALUACIÓN MEDIANTE PRUEBA DE EVALUACIÓN GLOBAL
La evaluación por prueba global consistirá en un examen escrito compuesto por una serie de ejercicios teóricos y prácticos sobre toda la materia desarrollada a lo largo del curso. La calificación final será directamente la obtenida en el examen final.

EVALUACIÓN EXTRAORDINARIA
La evaluación extraordinaria sigue los mismos criterios que la evaluación mediante prueba global de la convocatoria ordinaria."""@es ;
    ns1:hasEvaluationTrial <https://guia-kg.skai.etsisi.upm.es/resource/545000122/2025-26/evaluation/trial1>,
