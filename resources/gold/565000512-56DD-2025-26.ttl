        <https://guia-kg.skai.etsisi.upm.es/resource/565000512/2025-26/syllabus/9> .

<https://guia-kg.skai.etsisi.upm.es/resource/565000512/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Preliminares"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000512/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Gráficas razonadas de funciones. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000512/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "3.1. Funciones reales de varias variables. Conjuntos de nivel. Límites, continuidad, derivadas parciales, derivadas direccionales y diferencial de una función escalar. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000512/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "3.2. Funciones vectoriales diferenciables. Regla de la cadena: derivadas en implícitas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000512/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "3.3. Fórmula de Taylor. Extremos relativos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000512/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "4. Series numéricas y de potencias"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000512/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "4.1. Series Numéricas: Sucesiones. Sucesiones sumables. Series. Criterio general de convergencia. Series geométricas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000512/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "4.2. Series de términos positivos. Criterio de la integral. Criterio de comparación. Criterios del cociente y de la raíz para series de términos positivos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000512/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "4.3. Series de términos cualesquiera. Convergencia absoluta. Series alternadas. Criterio de Leibniz. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000512/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "4.4. Introducción a las series de potencias. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000512/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Métodos generales de integración. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000512/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "1.3. Polinomio de Taylor. Teorema de Taylor. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000512/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "2. Cálculo Integral en una variable"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000512/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "2.1. Integral de Riemann y Teorema fundamental del Cálculo Infinitesimal:construcción y definición de la integral de Riemann. Propiedades de la integral definida. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000512/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "2.2. Teorema fundamental del Cálculo Infinitesimal. Cálculo de integrales definidas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000512/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "2.3. Aplicaciones geométricas: cálculo de áreas planas. Rectificación de curvas. Volúmenes de cuerpos de revolución. Cálculo de volúmenes por secciones. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000512/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "2.4. Integrales impropias: de primera especie, de segunda especie. Integral de función no acotada en intervalo no acotado. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000512/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "3. Cálculo diferencial en varias variables"@es .

