    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/135003015/2025-26/eventSchedule> ;
    schema:description """Es una asignatura básica en la formación de un ingeniero experto en tecnologías ambientales por el contacto con el recurso agua. A diferencia de otras titulaciones, en esta concretamente se tratarán temas relacionados con la gestión del agua en el medioambiente y sus connotaciones con los principales problemas que pueda tener la gestión del agua de superficie.
Se comienza con unas sesiones de conceptos generales básicos y fundamentales y se va a adentrando en la comprensión de aparatos de medida, del tratamiento de datos hidro-meteorológicos, de la estimación de caudales líquidos, de la contaminación de las aguas por erosión de suelos, del transporte de los materiales en suspensión.
Se dedicará una parte importante a conocer fundamentos en la calidad de las aguas
Se enseñarán diferentes técnicas de restauración de ríos y riberas y de laderas"""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/josecarlos.robredo%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/antonio.gasco%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/josecarlos.robredo%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/josel.garcia%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/ricardo.garcia%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/sergio.defrutos%40upm.es> ;
    schema:name "Hidrologia"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003015/2025-26/CB5> a ns1:Competency ;
    ns1:competencyCode "CB5" ;
    ns1:competencyDescription "Que los estudiantes hayan desarrollado aquellas habilidades de aprendizaje necesarias para emprender estudios posteriores con un alto grado de autonomía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003015/2025-26/CE11> a ns1:Competency ;
    ns1:competencyCode "CE11" ;
    ns1:competencyDescription "Capacidad de interpretación del medio ambiente como sistema complejo: identificación de los factores, los procesos y las interacciones que configuran los distintos compartimentos medioambientales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003015/2025-26/CE15> a ns1:Competency ;
    ns1:competencyCode "CE15" ;
    ns1:competencyDescription "Capacidad para conocer, comprender y utilizar los principios de: Ciencias del Medio Físico: Geología, Climatología y Edafología y aplicarlos en problemas relacionados con la ingeniería ambiental y de análisis de la estructura y el funcionamiento hídrico de las cuencas vertientes"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003015/2025-26/CG5> a ns1:Competency ;
    ns1:competencyCode "CG5" ;
    ns1:competencyDescription "Capacidad para analizar, resolver problemas e identificar riesgos e impactos ambientales relacionados con la gestión del agua"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003015/2025-26/CG8> a ns1:Competency ;
    ns1:competencyCode "CG8" ;
    ns1:competencyDescription "Capacidad para la evaluación y control de la contaminación en el medio natural."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003015/2025-26/CT11> a ns1:Competency ;
    ns1:competencyCode "CT11" ;
    ns1:competencyDescription "Habilidad para aplicar conocimientos científicos, matemáticos y tecnológicos en sistemas relacionados con la práctica de la ingeniería"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003015/2025-26/RA100> a ns1:LearningResult ;
    ns1:learningResultCode "RA100" ;
    ns1:learningResultDescription "Conocer los procesos de Geodinámica Externa e Interna modeladores de la Tierra"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003015/2025-26/RA106> a ns1:LearningResult ;
    ns1:learningResultCode "RA106" ;
    ns1:learningResultDescription "Conocer, comprender y aplicar los principios del movimiento de los fluidos y de las sustancias que transportan."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003015/2025-26/RA107> a ns1:LearningResult ;
    ns1:learningResultCode "RA107" ;
    ns1:learningResultDescription "Conocer los dispositivos e instalaciones de medida y control, y comprender los criterios para su selección, instalación y calibración."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003015/2025-26/RA43> a ns1:LearningResult ;
    ns1:learningResultCode "RA43" ;
    ns1:learningResultDescription "Capacidad para comprender los procesos de hidrología superficial y subterránea e identificar los factores determinantes de cada uno de ellos y la escala espacial y temporal a la que actúan"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003015/2025-26/RA44> a ns1:LearningResult ;
    ns1:learningResultCode "RA44" ;
    ns1:learningResultDescription "Capacidad para reconocer y evaluar los efectos de las actividades humanas en el comportamiento hidrológico de las cuencas y para estimar su integridad hidroló"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003015/2025-26/RA87> a ns1:LearningResult ;
    ns1:learningResultCode "RA87" ;
    ns1:learningResultDescription "Recopilar y sintetizar información de fuentes bibliográficas (libros, revistas e Internet) y de clases magistrales"@es .

