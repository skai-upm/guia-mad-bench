    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/25001101/2025-26/eventSchedule> ;
    schema:description """Funciones, curvas parametrizadas.
Derivada y aplicaciones. Aproximación lineal. Problemas de optimización.
Series. Convergencia. Series de Taylor.
Integración. Integrales impropias. Integral sobre una curva. Aplicaciones de la integral: áreas, volúmenes, longitud de arco, trabajo.
Ecuaciones diferenciales de primer orden. Resolución gráfica y numérica."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/fj.taguas%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/fj.taguas%40upm.es> ;
    schema:name "Calculo Diferencial e Integral"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001101/2025-26/CE1> a ns1:Competency ;
    ns1:competencyCode "CE1" ;
    ns1:competencyDescription "Capacidad para utilizar los conocimientos matemáticos en la resolución de problemas que puedan plantearse en el ámbito de la Ingeniería Agroambiental. Aptitud para aplicar los conocimientos sobre: Álgebra lineal; geometría; geometría diferencial; Aptitud para aplicar los conocimientos sobre: Cálculo diferencial e integral; ecuaciones diferenciales y en derivadas parciales; métodos numéricos, algorítmica numérica; Informática: Aplicaciones en la ingeniería Agronómica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001101/2025-26/CG13> a ns1:Competency ;
    ns1:competencyCode "CG13" ;
    ns1:competencyDescription "Iniciativa, creatividad y espíritu emprendedor"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001101/2025-26/CG14> a ns1:Competency ;
    ns1:competencyCode "CG14" ;
    ns1:competencyDescription "Análisis y síntesis, razonamiento crítico y resolución de problemas científicos y técnicos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001101/2025-26/CG5> a ns1:Competency ;
    ns1:competencyCode "CG5" ;
    ns1:competencyDescription "Que los estudiantes hayan desarrollado aquellas habilidades de aprendizaje necesarias para emprender estudios posteriores con un alto grado de autonomía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001101/2025-26/CG6> a ns1:Competency ;
    ns1:competencyCode "CG6" ;
    ns1:competencyDescription "Transmitir con claridad y rigor información, ideas, problemas y soluciones de forma oral y escrita"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001101/2025-26/RA129> a ns1:LearningResult ;
    ns1:learningResultCode "RA129" ;
    ns1:learningResultDescription "Capacidad para establecer las relaciones funcionales entre las variables que involucran problemas de la realidad (Física, Ingeniería, etc.) y para analizar los aspectos relevantes de la dependencia funcional (orden de crecimiento, optimización,&#8230;.) mediante las herramientas del Cálculo Diferencial, estableciendo las consecuencias prácticas en cada contexto derivadas del análisis anterior. Uso del Cálculo Integral en problemas reales en los que éste es necesario (longitudes de curvas, trabajo de una fuerza no constante, etc.)."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001101/2025-26/RA130> a ns1:LearningResult ;
    ns1:learningResultCode "RA130" ;
    ns1:learningResultDescription "Capacidad para la formulación de leyes de evolución o dependencia en forma de ecuaciones diferenciales en escenarios de la realidad (Ciencias de la Naturaleza, Ingeniería, Ciencias Sociales, &#8230;.). Identificación de los patrones básicos (crecimiento y decaimiento exponencial, comportamientos oscilatorios, etc.). Análisis de los mismos mediante métodos analíticos y/o numéricos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001101/2025-26/RA501> a ns1:LearningResult ;
    ns1:learningResultCode "RA501" ;
    ns1:learningResultDescription "Interpretar geométricamente la derivada de una función en un punto"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001101/2025-26/RA502> a ns1:LearningResult ;
    ns1:learningResultCode "RA502" ;
    ns1:learningResultDescription "Representar gráficamente funciones reales de una variable real"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001101/2025-26/RA503> a ns1:LearningResult ;
    ns1:learningResultCode "RA503" ;
    ns1:learningResultDescription "Aproximar funciones mediante el polinomio de Taylor y series de potencias"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001101/2025-26/RA506> a ns1:LearningResult ;
    ns1:learningResultCode "RA506" ;
    ns1:learningResultDescription "Resolver problemas de optimización en una variable"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001101/2025-26/RA507> a ns1:LearningResult ;
    ns1:learningResultCode "RA507" ;
    ns1:learningResultDescription "Aplicar la integración al cálculo de áreas y volúmenes"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001101/2025-26/RA508> a ns1:LearningResult ;
    ns1:learningResultCode "RA508" ;
    ns1:learningResultDescription "Calcular integrales definidas e indefinidas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001101/2025-26/RA509> a ns1:LearningResult ;
    ns1:learningResultCode "RA509" ;
    ns1:learningResultDescription "Resolver ecuaciones diferenciales ordinarias elementales"@es .

