<https://guia-kg.skai.etsisi.upm.es/resource/613000099/2025-26/RA51> a ns1:LearningResult ;
    ns1:learningResultCode "RA51" ;
    ns1:learningResultDescription "Resuelve problemas aplicando soluciones basadas en frameworks y herramientas de libre distribución"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000099/2025-26/RA52> a ns1:LearningResult ;
