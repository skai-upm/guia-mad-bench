    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/53001278/2025-26/eventSchedule> ;
    schema:description "Las asignatura repasa las tecnologías actuales de las centrales térmicas para generación de electricidad e introduce al alumno en las soluciones avanzadas de futuro. Esas soluciones están orientadas a mejorar el rendimiento de las plantas, la mejor utilización de diversos tipos de combustibles y recursos, la reducción del impacto ambiental (NOx, SOx, partículas, GEI) y la descarbonización progresiva del sector de generación de electricidad. El enfoque de la asignatura es eminentemente práctico con la idea última de diseñar sistemas y simular el comportamiento térmico de las instalaciones."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/ja.fbenitez%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/ja.fbenitez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/javier.munoz.anton%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/lf.gonzalez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/santiago.terron%40upm.es> ;
    schema:name "Centrales Termicas"@es .

