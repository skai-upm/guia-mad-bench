<https://guia-kg.skai.etsisi.upm.es/resource/613000111/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/613000111/2025-26/CE03>,
        <https://guia-kg.skai.etsisi.upm.es/resource/613000111/2025-26/CE04>,
