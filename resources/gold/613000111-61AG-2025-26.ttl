        <https://guia-kg.skai.etsisi.upm.es/resource/613000111/2025-26/didactic_resource/2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/613000111/2025-26/didactic_resource/3> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/613000111/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/613000111/2025-26/RA18>,
        <https://guia-kg.skai.etsisi.upm.es/resource/613000111/2025-26/RA19>,
        <https://guia-kg.skai.etsisi.upm.es/resource/613000111/2025-26/RA20> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/613000111/2025-26/syllabus> ;
    ns1:inpersonHours "62 horas (39.7%)"@es ;
    ns1:numberOfCredits 6.0 ;
    ns1:otherInformation """En la entrega de prácticas se solicita adicionalmente una breve memoria explicativa en la que se detalla el proceso realizado para encontrar la solución pedida. A través de esa descripción se evaluarán las competencias de análisis y síntesis junto con la de razonamiento crítico.

Objetivos de Desarrollo Sostenible:
Esta asignatura está alineada con el Objetivo 4: Educación de calidad, que tiene como finalidad "Garantizar una educación inclusiva, equitativa y de calidad, y promover oportunidades de aprendizaje durante toda la vida para todos", tal como se define en los Objetivos de Desarrollo Sostenible (ODS) establecidos por la Organización de las Naciones Unidas (ONU)."""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "62 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/613000111/2025-26/eventSchedule> ;
    schema:description """Esta asignatura presenta los conceptos básicos de la programación de aplicaciones distribuidas de alta escalabilidad.
Se enseñan los conceptos básicos del paradigma de desarrollo de aplicaciones distribuidas en entornos Big Data.
Se hace énfasis en el paradigma batch/off-line particularizando en las arquitecturas Hadoop Map-Reduce y Apache-Spark."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/a.mozo%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/a.mozo%40upm.es> ;
    schema:name "Servicios y Protocolos de Aplicaciones en Internet"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000111/2025-26/CE03> a ns1:Competency ;
    ns1:competencyCode "CE03" ;
    ns1:competencyDescription "Capacidad para modelar, diseñar, definir la arquitectura, implantar, gestionar, operar, administrar y mantener aplicaciones, redes, sistemas y servicios en el ámbito de los Sistemas Distribuidos y Empotrados."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000111/2025-26/CE04> a ns1:Competency ;
    ns1:competencyCode "CE04" ;
    ns1:competencyDescription "Capacidad de comprender y saber aplicar el funcionamiento y organización de Internet, las tecnologías y protocolos de redes de nueva generación, los modelos de componentes, software intermediario y los servicios."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000111/2025-26/CE06> a ns1:Competency ;
    ns1:competencyCode "CE06" ;
    ns1:competencyDescription "Capacidad para diseñar y evaluar aplicaciones y sistemas basados en computación distribuida y para implantar sistemas operativos y servidores."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000111/2025-26/CG09> a ns1:Competency ;
    ns1:competencyCode "CG09" ;
    ns1:competencyDescription "Capacidad de análisis y síntesis."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000111/2025-26/CG11> a ns1:Competency ;
    ns1:competencyCode "CG11" ;
    ns1:competencyDescription "Razonamiento crítico."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000111/2025-26/RA18> a ns1:LearningResult ;
    ns1:learningResultCode "RA18" ;
    ns1:learningResultDescription "Identifica, comprende los algoritmos y protocolos utilizados en los sistemas distribuidos y en el nivel de aplicación de Internet"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000111/2025-26/RA19> a ns1:LearningResult ;
    ns1:learningResultCode "RA19" ;
    ns1:learningResultDescription "Entiende los principios de la programacion de aplicaciones en escenarios Big Data"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000111/2025-26/RA20> a ns1:LearningResult ;
    ns1:learningResultCode "RA20" ;
    ns1:learningResultDescription "Diseña aplicaciones masivamente paralelas utilizando paradigmas batch"@es .

