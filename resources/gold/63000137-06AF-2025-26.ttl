    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000137/2025-26/didactic_resource/7> a ns1:DidacticResource ;
    ns1:bibliographyTitle "Continuum mechanics, concise theory and problems (P. Chadwick). 1976, reimpreso por Dover 1999."@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000137/2025-26/didactic_resource/8> a ns1:DidacticResource ;
