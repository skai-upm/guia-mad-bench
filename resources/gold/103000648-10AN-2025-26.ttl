    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/103000648/2025-26/eventSchedule> ;
    schema:description "En esta asignatura se pretende que el alumno profundice en la problemática funcional de la empresa de Ti. Para ello se adentra en las áreas de Producción, marketing y recursos humanos, con especial mención a las particularidades de estas áreas en las empresas del sector. De este modo, junto con las asignaturas de dirección financiera y Planificación estratégica, se consigue que el alumno tenga una visión general de los aspectos de gestión de estas compañías ."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/pilar.quevedo%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/antonio.martinm%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/pilar.quevedo%40upm.es> ;
    schema:name "Direccion de Empresas de Ti"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000648/2025-26/CB7> a ns1:Competency ;
    ns1:competencyCode "CB7" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en entornos nuevos o poco conocidos dentro de contextos más amplios (o multidisciplinares) relacionados con su área de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000648/2025-26/CE1> a ns1:Competency ;
    ns1:competencyCode "CE1" ;
    ns1:competencyDescription "Capacidad para la integración de tecnologías, aplicaciones, servicios y sistemas propios de la Ingeniería Informática, con carácter generalista, y en contextos más amplios y multidisciplinares."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000648/2025-26/CE2> a ns1:Competency ;
    ns1:competencyCode "CE2" ;
    ns1:competencyDescription "Capacidad para la planificación estratégica, elaboración, dirección, coordinación, y gestión técnica y económica de proyectos en los ámbitos de la ingeniería informática relacionados, entre otros, con sistemas, aplicaciones, servicios, redes, infraestructuras o instalaciones informáticas y centros o factorías de desarrollo de software, respetando el adecuado cumplimiento de los criterios de calidad y medioambientales y en entornos de trabajo multidisciplinares."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000648/2025-26/CE3> a ns1:Competency ;
    ns1:competencyCode "CE3" ;
    ns1:competencyDescription "Capacidad para la dirección de proyectos de investigación, desarrollo e innovación, en empresas y centros tecnológicos, con garantía de la seguridad para las personas y bienes, la calidad final de los productos y su homologación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000648/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Capacidad de organizar y planificar"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000648/2025-26/CG13> a ns1:Competency ;
    ns1:competencyCode "CG13" ;
    ns1:competencyDescription "Habilidades de gestión y capacidad de liderar un equipo que puede estar integrado por disciplinas y niveles distintos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000648/2025-26/CG2> a ns1:Competency ;
    ns1:competencyCode "CG2" ;
    ns1:competencyDescription "Capacidad de gestionar la información"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000648/2025-26/CG8> a ns1:Competency ;
    ns1:competencyCode "CG8" ;
    ns1:competencyDescription "Comprensión amplia de las técnicas y métodos aplicables en una especialización concreta, así como de sus límites"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000648/2025-26/RA119> a ns1:LearningResult ;
    ns1:learningResultCode "RA119" ;
    ns1:learningResultDescription "Comprender y aplicar los conceptos relacionados con la gobernanza corporativa de la TI y la gestión de la misma"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000648/2025-26/RA148> a ns1:LearningResult ;
    ns1:learningResultCode "RA148" ;
    ns1:learningResultDescription "Comprender cómo crear valor en TI"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000648/2025-26/RA154> a ns1:LearningResult ;
    ns1:learningResultCode "RA154" ;
    ns1:learningResultDescription "Ser capaces de analizar cómo ampliar el mercado objetivo mediante la internalización del Negocio y/o la Compañía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000648/2025-26/RA156> a ns1:LearningResult ;
    ns1:learningResultCode "RA156" ;
    ns1:learningResultDescription "Conocer los mecanismos mediante los que se dirige y gestiona una estructura empresarial enfocada a cada tipo de Negocio TI"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000648/2025-26/RA175> a ns1:LearningResult ;
    ns1:learningResultCode "RA175" ;
    ns1:learningResultDescription "Aplicar técnicas para el análisis del entorno de la empresa"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000648/2025-26/RA176> a ns1:LearningResult ;
    ns1:learningResultCode "RA176" ;
    ns1:learningResultDescription "Aplicar las técnicas para la valoración interna de la empresa"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000648/2025-26/RA177> a ns1:LearningResult ;
    ns1:learningResultCode "RA177" ;
    ns1:learningResultDescription "Conoce los problemas de la implantación y las relaciones entre estrategia y recursos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000648/2025-26/RA178> a ns1:LearningResult ;
    ns1:learningResultCode "RA178" ;
    ns1:learningResultDescription "Conocer en qué consiste la función financiera en la empresa y su importancia estratégica."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000648/2025-26/RA179> a ns1:LearningResult ;
    ns1:learningResultCode "RA179" ;
    ns1:learningResultDescription "Conocer el papel del sistema productivo de la empresa y maneja herramientas de investigación operativa para la toma de decisiones en producción."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000648/2025-26/RA180> a ns1:LearningResult ;
    ns1:learningResultCode "RA180" ;
    ns1:learningResultDescription "Conocer el papel del sistema comercial en la empresa y maneja las variables de marketing mix."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000648/2025-26/RA29> a ns1:LearningResult ;
    ns1:learningResultCode "RA29" ;
    ns1:learningResultDescription "Entendimiento de la Gestión de Recursos Humanos asignados al proyecto, perfiles y costes."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000648/2025-26/RA30> a ns1:LearningResult ;
    ns1:learningResultCode "RA30" ;
    ns1:learningResultDescription "Entendimiento de la Gestión de Compras y Subcontratos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000648/2025-26/RA31> a ns1:LearningResult ;
    ns1:learningResultCode "RA31" ;
    ns1:learningResultDescription "Comprensión de los stakeholders del proyecto y su gestión."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000648/2025-26/RA36> a ns1:LearningResult ;
    ns1:learningResultCode "RA36" ;
    ns1:learningResultDescription "Identificar y caracterizar las implicaciones económicas de las decisiones empresariales: escala y alcance de las operaciones, experiencia y aprendizaje, integración vertical, diversificación, crecimiento, ?"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000648/2025-26/RA38> a ns1:LearningResult ;
    ns1:learningResultCode "RA38" ;
    ns1:learningResultDescription "Aplicar estas herramientas y metodologías para el diseño y análisis de estrategias y políticas empresariales en contextos competitivos, especialmente en aquellos que están inmersos en la nueva economía del conocimiento"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000648/2025-26/RA52> a ns1:LearningResult ;
    ns1:learningResultCode "RA52" ;
    ns1:learningResultDescription "Competencias transversales asociados a la asignatura"@es .

