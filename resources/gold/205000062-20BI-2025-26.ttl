<https://guia-kg.skai.etsisi.upm.es/resource/205000062> a ns1:Course ;
    ns1:courseType "Optativa"@es ;
    ns1:courseYear 3 ;
    ns1:semester "Sexto semestre"@es ;
    schema:courseCode 205000062 ;
    schema:hasCourseInstance <https://guia-kg.skai.etsisi.upm.es/resource/205000062/2025-26> ;
    schema:name "Biotechnology Applied To Animal Production"@en,
        "Biotecnología Aplicada a la Producción Animal"@es ;
    schema:numberOfCredits 3.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/205000062/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/205000062/2025-26/CB02>,
        <https://guia-kg.skai.etsisi.upm.es/resource/205000062/2025-26/CG09>,
        <https://guia-kg.skai.etsisi.upm.es/resource/205000062/2025-26/CT01> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/205000062/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/205000062/2025-26/didactic_resource/2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/205000062/2025-26/didactic_resource/3> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/205000062/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/205000062/2025-26/RA107>,
        <https://guia-kg.skai.etsisi.upm.es/resource/205000062/2025-26/RA167>,
        <https://guia-kg.skai.etsisi.upm.es/resource/205000062/2025-26/RA403>,
        <https://guia-kg.skai.etsisi.upm.es/resource/205000062/2025-26/RA404> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/205000062/2025-26/syllabus> ;
    ns1:inpersonHours "45 horas (55.6%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation """La Comisión de Calidad del Centro en su reunión de 29 de mayo de 2023 acordó aprobar la propuesta de reasignación de competencias transversales en las asignaturas de los Grados en Biotecnología, Ingeniería Alimentaria, Ingeniería Agrícola, Ingeniería Agroambiental, Ciencias Agrarias y Bioeconomía, y en el Máster Universitario en Ingeniería Agronómica. En virtud de dicho acuerdo esta asignatura ha sido designada como ?Asignatura NO Punto Control*?. Esto significa que si bien puede seguir trabajando una o varias competencias transversales que se abordan en distintos puntos y aspectos de la asignatura, dicha formación y evaluación no será objeto de recopilación de evidencias por los sistemas de acreditación de la calidad del Centro?. *Asignatura punto control (APC): aquella asignatura en la que se verificará la formación y evaluación de la competencia transversal que le corresponda.
Para las prácticas de reproducción se dispone del Permiso correspondiente expedido por el Comité de Ética de la Universidad Politécnica de Madrid con referencia PDELUPDI00-PGR-ANIMALES-20221216. Los estudiantes deberán llevar a las prácticas, ropa cómoda, calzado adecuado y su propia bata. En caso de no llevarla, el profesor se reserva el derecho a no permitir que el estudiante realice la práctica asumiendo las consecuencias que ello pudiera acarrear en términos de evaluación de la asignatura.
La asignatura se relaciona con el ODS2, ODS3, ODS8, ODS12 y el ODS13."""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "45 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/205000062/2025-26/eventSchedule> ;
    schema:description """Descriptores: Biotecnología en el contexto de la producción animal. Aplicaciones de la
biotecnología en reproducción. Biotecnología reproductiva aplicada a la producción de espermatozoides. Biotecnología reproductiva aplicada a la
producción de ovocitos. Biotecnología reproductiva aplicada a la producción de
embriones. Aplicaciones de la biotecnología en nutrición animal: Nutrientes, enzimas, pre- y pro- bióticos, nutrigenómica y nutrigenética."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/david.menoyo%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/david.menoyo%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/pilar.grebollar%40upm.es> ;
    schema:name "Biotecnología Aplicada a la Producción Animal"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000062/2025-26/CB02> a ns1:Competency ;
    ns1:competencyCode "CB02" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar sus conocimientos a su trabajo o vocación de una forma profesional y posean las competencias que suelen demostrarse por medio de la elaboración y defensa de argumentos y la resolución de problemas dentro de su área de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000062/2025-26/CG09> a ns1:Competency ;
    ns1:competencyCode "CG09" ;
    ns1:competencyDescription "Familiarizarse con los fundamentos de las nuevas tecnologías necesarios para llevar a cabo investigación, gestión de la producción, y desarrollo adecuados a los nuevos retos en el ámbito agrario, incluyendo los aspectos éticos y bioéticos del área."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000062/2025-26/CT01> a ns1:Competency ;
    ns1:competencyCode "CT01" ;
    ns1:competencyDescription "Capacidad para aplicar de forma profesional a su trabajo los conocimientos adquiridos considerando sus impactos en un contexto global y social."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000062/2025-26/RA107> a ns1:LearningResult ;
    ns1:learningResultCode "RA107" ;
    ns1:learningResultDescription "Poder exponer y comunicar sus ideas y reflexiones, tanto de forma oral como escrita."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000062/2025-26/RA167> a ns1:LearningResult ;
    ns1:learningResultCode "RA167" ;
    ns1:learningResultDescription "Conocer y aplicar las principales técnicas de control de la reproducción y ser capaz de interpretar los principales índices reproductivos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000062/2025-26/RA403> a ns1:LearningResult ;
    ns1:learningResultCode "RA403" ;
    ns1:learningResultDescription "Comprender y manejar el concepto de Nutrigenómica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000062/2025-26/RA404> a ns1:LearningResult ;
    ns1:learningResultCode "RA404" ;
    ns1:learningResultDescription "Comprender y manejar las aplicaciones de la biotecnología en el contexto de la producción animal."@es .

