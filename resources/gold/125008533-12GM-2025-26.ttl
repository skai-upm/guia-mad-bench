<https://guia-kg.skai.etsisi.upm.es/resource/125008533/2025-26/CG03> a ns1:Competency ;
    ns1:competencyCode "CG03" ;
    ns1:competencyDescription "Comprender los problemas de implantación en el terreno de las infraestructuras, construcciones y edificaciones proyectadas desde las distintas especialidades de la ingeniería, analizar los mismos y proceder a su implantación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125008533/2025-26/CG04> a ns1:Competency ;
    ns1:competencyCode "CG04" ;
    ns1:competencyDescription "Capacidad para toma de decisiones, de liderazgo, gestión de recursos humanos y dirección de equipos interdisciplinares relacionados con la información espacial"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125008533/2025-26/CG09> a ns1:Competency ;
    ns1:competencyCode "CG09" ;
    ns1:competencyDescription "Planificación, proyecto, dirección, ejecución y gestión de procesos y productos de aplicación a la obra civil y la edificación, en el ámbito geomático"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125008533/2025-26/CG10> a ns1:Competency ;
    ns1:competencyCode "CG10" ;
    ns1:competencyDescription "Planificación, proyecto, dirección, ejecución y gestión de procesos y productos de aplicación a la ingeniería medio ambiental, agronómica, forestal y minera, en el ámbito geomático"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125008533/2025-26/CT01> a ns1:Competency ;
    ns1:competencyCode "CT01" ;
    ns1:competencyDescription "COMUNICACIÓN ORAL Y ESCRITA Capacidad para transmitir conocimientos y expresar ideas y argumentos de manera clara, rigurosa y convincente, tanto de forma oral como escrita, utilizando los recursos gráficos y los medios necesarios adecuadamente y adaptándose a las características de la situación y de la audiencia."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125008533/2025-26/CT03> a ns1:Competency ;
    ns1:competencyCode "CT03" ;
    ns1:competencyDescription "RESPETO MEDIO"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125008533/2025-26/CT04> a ns1:Competency ;
    ns1:competencyCode "CT04" ;
    ns1:competencyDescription "CREATIVIDAD Capacidad para resolver de forma nueva y original situaciones o problemas en el ámbito de la ingeniería"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125008533/2025-26/RA101> a ns1:LearningResult ;
    ns1:learningResultCode "RA101" ;
    ns1:learningResultDescription "Aplicación de la normativa en el trazado de carreteras (tipo de carretera, enlaces, glorietas¿)"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125008533/2025-26/RA102> a ns1:LearningResult ;
    ns1:learningResultCode "RA102" ;
    ns1:learningResultDescription "Trazado de ferrocarriles. Renovación, mejoras de trazado obras de nuevo trazado. Controles geométricos para la recepción de obra. Estaciones y aparatos de vía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125008533/2025-26/RA104> a ns1:LearningResult ;
    ns1:learningResultCode "RA104" ;
    ns1:learningResultDescription "Estructuras. Ingeniería geotécnica. Obras sanitarias y urbanizaciones. Maquinaria de obra pública"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125008533/2025-26/RA180> a ns1:LearningResult ;
    ns1:learningResultCode "RA180" ;
    ns1:learningResultDescription "Conocimiento de técnicas para el cálculo y diseño de obras civiles y de edificación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125008533/2025-26/RA181> a ns1:LearningResult ;
    ns1:learningResultCode "RA181" ;
    ns1:learningResultDescription "Conocimiento general de las diferentes obras públicas, hidráulicas, estructuras, ingeniería geotécnica, carreteras, ferrocarriles, puertos, ingeniería medioambiental"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125008533/2025-26/RA182> a ns1:LearningResult ;
    ns1:learningResultCode "RA182" ;
    ns1:learningResultDescription "Conocimiento de procedimientos constructivos en edificación y obra pública."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125008533/2025-26/RA185> a ns1:LearningResult ;
    ns1:learningResultCode "RA185" ;
    ns1:learningResultDescription "Identificación de maquinaria auxiliar de construcción y edificación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125008533/2025-26/RA186> a ns1:LearningResult ;
