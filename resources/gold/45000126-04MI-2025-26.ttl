    ns1:otherInformation """Assistance to classes and participation during the sessions is strongly recommended.
Also, inputs to the fora in the Moodle platform are suggested, either to contribute to discussion of doubts, or to propose debates on any topics related to Nanotechnology."""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
