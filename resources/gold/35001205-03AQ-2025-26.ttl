<https://guia-kg.skai.etsisi.upm.es/resource/35001205/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/35001205/2025-26/CE%2049>,
        <https://guia-kg.skai.etsisi.upm.es/resource/35001205/2025-26/CE%2053>,
        <https://guia-kg.skai.etsisi.upm.es/resource/35001205/2025-26/CE%2054>,
        <https://guia-kg.skai.etsisi.upm.es/resource/35001205/2025-26/CG%2010.>,
        <https://guia-kg.skai.etsisi.upm.es/resource/35001205/2025-26/CG%2026.>,
        <https://guia-kg.skai.etsisi.upm.es/resource/35001205/2025-26/CG%203.> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/35001205/2025-26/didactic_resource/1> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/35001205/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/35001205/2025-26/RA10>,
        <https://guia-kg.skai.etsisi.upm.es/resource/35001205/2025-26/RA106>,
        <https://guia-kg.skai.etsisi.upm.es/resource/35001205/2025-26/RA11>,
        <https://guia-kg.skai.etsisi.upm.es/resource/35001205/2025-26/RA12>,
        <https://guia-kg.skai.etsisi.upm.es/resource/35001205/2025-26/RA304>,
        <https://guia-kg.skai.etsisi.upm.es/resource/35001205/2025-26/RA305>,
        <https://guia-kg.skai.etsisi.upm.es/resource/35001205/2025-26/RA306>,
        <https://guia-kg.skai.etsisi.upm.es/resource/35001205/2025-26/RA7> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/35001205/2025-26/syllabus> ;
    ns1:inpersonHours "115 horas y 30 minutos (71.3%)"@es ;
    ns1:numberOfCredits 6.0 ;
    ns1:otherInformation """Respecto al profesorado, las horas de tutoría son orientativas. Los horarios deberán ser confirmados por el profesor correspondiente.
En el cronograma se sigue una planificación teórica de la asignatura pero pueden surgir algunas modificaciones a lo largo del curso, siempre a criterio del profesor. Igualmente el cronograma se verá probablemente afectado por circunstancias ajenas a la docencia que se plantean cada año (eventualidades, imprevistos, festivos, etc.).
Por el carácter teórico de esta asignatura, que conlleva una elevada cantidad de lenguaje oral y muy especialmente.escrito, es aconsejable para los estudiantes ERASMUS no matricularse en la misma si no tienen un alto grado de conocimiento del castellano."""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "115 horas y 30 minutos"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/35001205/2025-26/eventSchedule> ;
    schema:description "La asignatura recorre la historia del arte europeo desde el clasicismo antiguo hasta las vanguardias históricas. Su objetivo, aparte de dotar al alumno de un conocimiento esencial acerca de los distintos períodos y estilos artísticos, es desarrollar las habilidades de análisis estético y la comprensión de los diversos contextos culturales en los que la arquitectura se ha gestado y desarrollado a lo largo de la historia de Europa. La asignatura explora especialmente la estrecha relación existente entre las artes plásticas y la arquitectura de cada período, así como las influencias que se han establecido entre las artes a lo largo de los distintos períodos."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/david.rivera%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/alberto.ruizc%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/alejandro.valdivieso%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/david.rivera%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/eduardo.prieto%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/guiomar.martin%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/joseantonio.flores%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/nicolas.marine%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/salvador.guerrero%40upm.es> ;
    schema:name "Historia del Arte y de la Arquitectura"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35001205/2025-26/CE%2049> a ns1:Competency ;
    ns1:competencyCode "CE 49" ;
    ns1:competencyDescription "Conocimiento adecuado de la historia general de la arquitectura."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35001205/2025-26/CE%2053> a ns1:Competency ;
    ns1:competencyCode "CE 53" ;
    ns1:competencyDescription "Conocimiento adecuado de las tradiciones arquitectónicas, urbanísticas y paisajísticas de la cultura occidental, así como de sus fundamentos técnicos, climáticos, económicos, sociales e ideológicos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35001205/2025-26/CE%2054> a ns1:Competency ;
    ns1:competencyCode "CE 54" ;
    ns1:competencyDescription "Conocimiento adecuado de la estética y la teoría e historia de las bellas artes y las artes aplicadas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35001205/2025-26/CG%2010.> a ns1:Competency ;
    ns1:competencyCode "CG 10." ;
    ns1:competencyDescription "Cultura histórica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35001205/2025-26/CG%2026.> a ns1:Competency ;
    ns1:competencyCode "CG 26." ;
    ns1:competencyDescription "Comunicación oral y escrita en la lengua nativa"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35001205/2025-26/CG%203.> a ns1:Competency ;
    ns1:competencyCode "CG 3." ;
    ns1:competencyDescription "Sensibilidad estética"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35001205/2025-26/RA10> a ns1:LearningResult ;
    ns1:learningResultCode "RA10" ;
    ns1:learningResultDescription "El alumno sabrá identificar las características distintivas de cada período del arte occidental"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35001205/2025-26/RA106> a ns1:LearningResult ;
    ns1:learningResultCode "RA106" ;
    ns1:learningResultDescription "Analizar, a través de la documentación encontrada o suministrada, aspectos relevantes de un edificio o de la obra de un arquitecto determinado"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35001205/2025-26/RA11> a ns1:LearningResult ;
    ns1:learningResultCode "RA11" ;
    ns1:learningResultDescription "El alumno será capaz de encontrar documentación fiable (textual, gráfica, fotográfica e infográfica) de un tema, edificio, periodo o arquitecto determinados."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35001205/2025-26/RA12> a ns1:LearningResult ;
    ns1:learningResultCode "RA12" ;
    ns1:learningResultDescription "El alumno será capaz de analizar la documentación encontrada para extraer la información relevante para su estudio"@es .

