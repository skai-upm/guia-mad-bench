    ns1:numberOfCredits 4.5 ;
    ns1:otherInformation """IMPORTANTE: El cronograma solo es orientativo de las horas de cada tema. El cronograma actualizado se les proporcionara al alumno al inicio del curso, vía moodle

Al ser una asignatura con contenidos muy actuales, la información se suele encontrar en artículos técnicos en inglés. Esto obliga a que los alumnos sepan desenvolverse en la lectura y comprensión de textos en otro idioma.
Objetivo de desarrollo sostenible que cubre esta asignatura es: ods 7"""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "62 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/65004034/2025-26/eventSchedule> ;
    schema:description """Esta asignatura es un complemento al resto de asignaturas del grado de energía. En ella se mezclan temas propios de los combustibles y temas de generación de corte más eléctrico.
Se trata de dar una visión de tecnologías que aunque a día de hoy son marginales o están en fase de investigación, pueden ser relevantes en el futuro."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/pablo.reina%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/daniel.serrano.jimenez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/enrique.querol%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/pablo.reina%40upm.es> ;
    schema:name "Tecnicas Avanzadas en Combustibles y Energia"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004034/2025-26/CE24> a ns1:Competency ;
    ns1:competencyCode "CE24" ;
    ns1:competencyDescription "Relacionar el conocimiento de los procesos de la combustión con el uso eficiente de los combustibles sólidos, líquidos y gaseosos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004034/2025-26/CE25> a ns1:Competency ;
    ns1:competencyCode "CE25" ;
    ns1:competencyDescription "Conocer las características y especificaciones de los combustibles sólidos, líquidos y gaseosos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004034/2025-26/CE48> a ns1:Competency ;
    ns1:competencyCode "CE48" ;
    ns1:competencyDescription "Comprender el aprovechamiento, transformación y gestión de los recursos energéticos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004034/2025-26/CE53> a ns1:Competency ;
    ns1:competencyCode "CE53" ;
    ns1:competencyDescription "Aplicar los principios de la tecnología ambiental a la evaluación de impactos, al tratamiento de residuos y a la sostenibilidad."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004034/2025-26/CE54> a ns1:Competency ;
    ns1:competencyCode "CE54" ;
    ns1:competencyDescription "Conocer las tecnologías de reducción de emisiones en la plantas de generación de energía."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004034/2025-26/CG2> a ns1:Competency ;
    ns1:competencyCode "CG2" ;
    ns1:competencyDescription "Poseer capacidad para diseñar, desarrollar, implementar, gestionar y mejorar productos, sistemas y procesos en los distintos ámbitos energéticos, usando técnicas analíticas, computacionales o experimentales apropiadas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004034/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Aplicar los conocimientos adquiridos para identificar, formular y resolver problemas dentro de contextos amplios y multidisciplinarios, siendo capaces de integrar conocimientos, trabajando en equipos multidisciplinares."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004034/2025-26/CG6> a ns1:Competency ;
    ns1:competencyCode "CG6" ;
    ns1:competencyDescription "Poseer habilidades de aprendizaje que permitan continuar estudiando a lo largo de la vida para su adecuado desarrollo profesional."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004034/2025-26/RA186> a ns1:LearningResult ;
    ns1:learningResultCode "RA186" ;
    ns1:learningResultDescription "Conocer las características, ventajas e inconvenientes de los posibles combustibles del futuro."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004034/2025-26/RA187> a ns1:LearningResult ;
    ns1:learningResultCode "RA187" ;
    ns1:learningResultDescription "Conocer las tecnologías de generación de combustibles renovables y sintéticos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004034/2025-26/RA188> a ns1:LearningResult ;
    ns1:learningResultCode "RA188" ;
    ns1:learningResultDescription "Comprender los procesos que permiten obtener combustibles sintéticos ó alternativos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004034/2025-26/RA189> a ns1:LearningResult ;
    ns1:learningResultCode "RA189" ;
    ns1:learningResultDescription "Conocer los estudios necesarios para poder alternar entre distintos combustibles gaseosos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004034/2025-26/RA190> a ns1:LearningResult ;
    ns1:learningResultCode "RA190" ;
    ns1:learningResultDescription "Conocer los fundamentos y tecnologías principales de gasificación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004034/2025-26/RA191> a ns1:LearningResult ;
    ns1:learningResultCode "RA191" ;
    ns1:learningResultDescription "Conocer las emisiones producidas por el uso de combustibles y las tecnologías desarrolladas para minimizarlas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004034/2025-26/RA192> a ns1:LearningResult ;
    ns1:learningResultCode "RA192" ;
    ns1:learningResultDescription "Comprender las técnicas de generación, almacenamiento y uso del hidrógeno, como vector energético."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004034/2025-26/RA193> a ns1:LearningResult ;
    ns1:learningResultCode "RA193" ;
    ns1:learningResultDescription "Comprender las técnicas básicas de captura de CO2 y las técnicas de limitación de emisiones en sistemas de generación de energía."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004034/2025-26/RA194> a ns1:LearningResult ;
    ns1:learningResultCode "RA194" ;
    ns1:learningResultDescription "Comprender el funcionamiento de sistemas de almacenamiento de energía y su uso con fuentes de energía no despachable"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004034/2025-26/RA195> a ns1:LearningResult ;
    ns1:learningResultCode "RA195" ;
    ns1:learningResultDescription "Comprender los nuevos conceptos de generación de energía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004034/2025-26/RA196> a ns1:LearningResult ;
    ns1:learningResultCode "RA196" ;
    ns1:learningResultDescription "Comprender el aprovechamiento, transformación y gestión de los recursos energéticos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004034/2025-26/RA197> a ns1:LearningResult ;
