<https://guia-kg.skai.etsisi.upm.es/resource/45000262/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Tema 1. Una perspectiva integral: ciudad, transporte y desarrollo sostenible Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000262/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "2. Tema 2. Evolución histórica del transporte urbano. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000262/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "11. Tema 11. La planificación y gestión de la movilidad no motorizada Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000262/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "12. Tema 12. Perspectivas y tendencias de la movilidad urbana: aportaciones tecnológicas, institucionales y de normativa. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000262/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "13. Tema 13. Planificación y medio urbano: consideraciones éticas Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000262/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "3. Tema 3. Forma urbana, usos del suelo y movilidad. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000262/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "4. Tema 4. Planificación integrada del transporte urbano. Planes de movilidad sostenible. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000262/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "5. Tema 5. Caracterización de la movilidad urbana: fuentes de datos e información; indicadores; modelos de oferta y demanda de transporte urbano. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000262/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "6. Tema 6. Las redes de transporte urbano: red del tráfico viario; redes de transporte público; redes peatonales y ciclistas Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000262/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "7. Tema 7. Redes de transporte y espacio público: criterios de diseño. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000262/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "8. Tema 8. El marco regulador del transporte y tráfico urbano. Financiación. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000262/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "9. Tema 9. La gestión de la demanda de transporte. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000262/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "10. Tema 10. La planificación y explotación de los servicios de transporte público urbano Sin subniveles"@es .

