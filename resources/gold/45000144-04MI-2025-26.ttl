<https://guia-kg.skai.etsisi.upm.es/resource/45000144/2025-26/CE%2010.> a ns1:Competency ;
    ns1:competencyCode "CE 10." ;
    ns1:competencyDescription "Saber evaluar la seguridad, durabilidad e integridad estructural de los materiales y componentes fabricados con ellos/ Know how to evaluate the safety, durability and structural integrity of the materials and components manufactured with them"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000144/2025-26/CE%207.> a ns1:Competency ;
    ns1:competencyCode "CE 7." ;
    ns1:competencyDescription "Saber diseñar, desarrollar y controlar los procesos de producción y transformación de materiales / Know how to design, develop and control the processes of production and transformation of materials"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000144/2025-26/CG%2011> a ns1:Competency ;
    ns1:competencyCode "CG 11" ;
    ns1:competencyDescription "Responsabilidad y ética profesional/ Responsibility and professional ethics"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000144/2025-26/CG%202> a ns1:Competency ;
