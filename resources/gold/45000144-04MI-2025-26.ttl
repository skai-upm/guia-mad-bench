    ns1:competencyDescription "Comunicación oral y escrita"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000144/2025-26/CG%209> a ns1:Competency ;
    ns1:competencyCode "CG 9" ;
    ns1:competencyDescription "Capacidad de trabajo interdisciplinar/ Capacity for interdisciplinary work"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000144/2025-26/RA34> a ns1:LearningResult ;
    ns1:learningResultCode "RA34" ;
    ns1:learningResultDescription "Utilizar con soltura la comunicación oral y escrita"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000144/2025-26/RA35> a ns1:LearningResult ;
    ns1:learningResultCode "RA35" ;
    ns1:learningResultDescription "Saber trabajar en equipo en entornos interdisciplinares. Ejecutar el trabajo con responsabilidad y respeto a los demás."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000144/2025-26/RA36> a ns1:LearningResult ;
    ns1:learningResultCode "RA36" ;
    ns1:learningResultDescription "Conocer y comprender los procesos de obtención de las distintas familias de materiales, sabiendo entender de forma integradora los aspectos comunes de las tecnologías utilizadas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000144/2025-26/RA37> a ns1:LearningResult ;
    ns1:learningResultCode "RA37" ;
    ns1:learningResultDescription "Conocer y comprender las distintas técnicas de procesado, poniendo de relieve los aspectos comunes a cada familia de materiales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000144/2025-26/RA38> a ns1:LearningResult ;
    ns1:learningResultCode "RA38" ;
    ns1:learningResultDescription "Conocer y comprender los procesos biológicos de desarrollo de materiales y su aplicación a nuevas rutas de obtención y procesado de materiales orgánicos e inorgánicos para todo tipo de aplicaciones"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000144/2025-26/RA39> a ns1:LearningResult ;
    ns1:learningResultCode "RA39" ;
    ns1:learningResultDescription "Conocer y valorar los aspectos medioambientales y de seguridad en relación con la obtención y transformación de materiales."@es .

