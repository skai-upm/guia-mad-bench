    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/65003032/2025-26/eventSchedule> ;
    schema:description """Esta asignatura trata sobre los recursos geológicos en sentido amplio, de forma preferente los minerales y rocas utilizados en la industria, bien como menas o como minerales y rocas industriales.
Se verán sus características, origen y forma de prospección, así como de forma fundamental sus aplicaciones en todas las ramas de la industria."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/joseluis.parra%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/jorgeluis.costafreda%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/joseluis.parra%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/leticia.presa.madrigal%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/mteresa.gonzalez%40upm.es> ;
    schema:name "Mineralogia y Petrologia"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65003032/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Conocer y aplicar conocimientos de ciencias y tecnologías básicas a la práctica de la Ingeniería Geológica."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65003032/2025-26/CG2> a ns1:Competency ;
    ns1:competencyCode "CG2" ;
    ns1:competencyDescription "Poseer capacidad para diseñar, desarrollar, implementar, gestionar y mejorar productos, sistemas y procesos en los distintos ámbitos geológicos, usando técnicas analíticas, computacionales o experimentales apropiadas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65003032/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Aplicar los conocimientos adquiridos para identificar, formular y resolver problemas dentro de contextos amplios y multidisciplinarios, siendo capaces de integrar conocimientos, trabajando en equipos multidisciplinares."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65003032/2025-26/CG5> a ns1:Competency ;
    ns1:competencyCode "CG5" ;
    ns1:competencyDescription "Saber comunicar los conocimientos y conclusiones, tanto de forma oral, escrita y gráfica, a públicos especializados y no especializados de un modo claro y sin ambigüedades."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65003032/2025-26/CG6> a ns1:Competency ;
    ns1:competencyCode "CG6" ;
    ns1:competencyDescription "Poseer habilidades de aprendizaje que permitan continuar estudiando a lo largo de la vida para su adecuado desarrollo profesional."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65003032/2025-26/CG7> a ns1:Competency ;
    ns1:competencyCode "CG7" ;
    ns1:competencyDescription "Incorporar nuevas tecnologías y herramientas de la Ingeniería Geológica en sus actividades profesionales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65003032/2025-26/F25> a ns1:Competency ;
    ns1:competencyCode "F25" ;
    ns1:competencyDescription "Ensayos mineralógicos, petrográficos y geotécnicos. Técnicas de muestreo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65003032/2025-26/F26> a ns1:Competency ;
    ns1:competencyCode "F26" ;
    ns1:competencyDescription "Control de la calidad de los materiales empleados"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65003032/2025-26/RA170> a ns1:LearningResult ;
    ns1:learningResultCode "RA170" ;
    ns1:learningResultDescription "Conocer los conceptos y principios básicos de la Mineralogía y de la Petrografía."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65003032/2025-26/RA171> a ns1:LearningResult ;
    ns1:learningResultCode "RA171" ;
    ns1:learningResultDescription "Conocer y aplicar la terminología científica cristalográfica, mineralógica y petrográfica."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65003032/2025-26/RA172> a ns1:LearningResult ;
    ns1:learningResultCode "RA172" ;
    ns1:learningResultDescription "Reconocer los principales minerales y rocas, de visu y con el microscopio."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65003032/2025-26/RA173> a ns1:LearningResult ;
    ns1:learningResultCode "RA173" ;
    ns1:learningResultDescription "Identificar rocas y minerales con contextos geológicos concretos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65003032/2025-26/RA174> a ns1:LearningResult ;
    ns1:learningResultCode "RA174" ;
    ns1:learningResultDescription "Conocer las principales aplicaciones industriales de minerales y rocas."@es .

