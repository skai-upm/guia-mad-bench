    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/43000557/2025-26/eventSchedule> ;
    schema:description "La asignatura de Ingeniería de Rocas pretende explicar los fundamentos de la Mecánica de Rocas, exponiendo las particularidades y diferencias que presenta respecto de la Mecánica de Suelos. Se introduce la caracterización del macizo rocoso, los criterios de rotura y deformabilidad de la roca matriz y de las discontinuidades y se estudian las aplicaciones a problemas de cimentaciones, túneles y taludes. Se dan las bases y fundamentos así como clases de laboratorio y salidas de campo para, mediante diversos escenarios realistas supuestos y con ayuda de aplicaciones virtuales, poder resolver problemas de ingeniería de rocas."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/rubenangel.galindo%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/l.jorda%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/rubenangel.galindo%40upm.es> ;
    schema:name "Ingeniería de Rocas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000557/2025-26/MICCPCB07> a ns1:Competency ;
    ns1:competencyCode "MICCPCB07" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en entornos nuevos o poco conocidos dentro de contextos más amplios (o multidisciplinares) relacionados con su área de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000557/2025-26/MICCPCE19> a ns1:Competency ;
    ns1:competencyCode "MICCPCE19" ;
    ns1:competencyDescription "Capacidad para abordar y resolver problemas matemáticos avanzados de ingeniería, desde el planteamiento del problema hasta el desarrollo de la formulación y su implementación en un programa de ordenador. En particular, capacidad para formular, programar y aplicar modelos analíticos y numéricos avanzados de cálculo, proyecto, planificación y gestión, así como capacidad para la interpretación de los resultados obtenidos, en el contexto de la ingeniería civil. Incorpora las competencias CB6, CB7 y CB8"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000557/2025-26/MICCPCE21> a ns1:Competency ;
    ns1:competencyCode "MICCPCE21" ;
    ns1:competencyDescription "Aplicación de los conocimientos de la mecánica de suelos y de las rocas para el desarrollo del estudio, proyecto, construcción y explotación de cimentaciones, desmontes, terraplenes, túneles y demás construcciones realizadas sobre o a través del terreno, cualquiera que sea la naturaleza y el estado de éste, y cualquiera que sea la finalidad de la obra de que se trate. Incorpora las competencias CB6, CB7 y CB8"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000557/2025-26/MICCPCE34> a ns1:Competency ;
    ns1:competencyCode "MICCPCE34" ;
    ns1:competencyDescription "Capacidad para integrar y aplicar los conocimientos técnicos en asesoría, análisis, cálculo, proyecto, construcción, y evaluación técnica de infraestructuras de ingeniería civil. Incorpora las competencias CB6, CB7 y CB8."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000557/2025-26/MICCPCGP01> a ns1:Competency ;
    ns1:competencyCode "MICCPCGP01" ;
    ns1:competencyDescription "Capacitación científico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000557/2025-26/MICCPCT01> a ns1:Competency ;
    ns1:competencyCode "MICCPCT01" ;
    ns1:competencyDescription "Capacidad de preparar y presentar comunicaciones orales, escritas y gráficas, estructurada y argumentadamente. Desarrolla la competencia CB9."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000557/2025-26/MICCPCT02> a ns1:Competency ;
    ns1:competencyCode "MICCPCT02" ;
    ns1:competencyDescription "Polivalencia y capacidad de aprendizaje autónomo. Desarrolla la competencia CB10."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000557/2025-26/MICCPCT08> a ns1:Competency ;
    ns1:competencyCode "MICCPCT08" ;
    ns1:competencyDescription "Capacidad de diseñar, analizar e interpretar experimentos relevantes en ingeniería civil."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000557/2025-26/RA197> a ns1:LearningResult ;
    ns1:learningResultCode "RA197" ;
    ns1:learningResultDescription "Aprecia y analiza las incertidumbre de los proyectos y determina la estrategia para su consideración."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000557/2025-26/RA20> a ns1:LearningResult ;
    ns1:learningResultCode "RA20" ;
    ns1:learningResultDescription "Aplica y evalúa modelos avanzados de ingeniería estructural y geotécnica en proyecto y ejecución de obras"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000557/2025-26/RA213> a ns1:LearningResult ;
    ns1:learningResultCode "RA213" ;
    ns1:learningResultDescription "Asume los principios de incertidumbre y riesgo en la aplicación de los métodos y modelos de ingeniería de caminos, canales y puertos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000557/2025-26/RA255> a ns1:LearningResult ;
    ns1:learningResultCode "RA255" ;
    ns1:learningResultDescription "Realiza individualmente un proyecto o una preinvestigación originales de Ingeniería estructural, geotécnica o de materiales estructurales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000557/2025-26/RA44> a ns1:LearningResult ;
    ns1:learningResultCode "RA44" ;
    ns1:learningResultDescription "Hacer una presentación oral de sus conocimientos aplicados, mediante la resolución de casos prácticos individualmente y en grupo."@es .

