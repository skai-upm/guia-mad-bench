<https://guia-kg.skai.etsisi.upm.es/resource/53001251> a ns1:Course ;
    ns1:courseType "Optativa"@es ;
    ns1:courseYear 2 ;
    ns1:semester "Cuarto semestre"@es ;
    schema:courseCode 53001251 ;
    schema:hasCourseInstance <https://guia-kg.skai.etsisi.upm.es/resource/53001251/2025-26> ;
    schema:name "Elasticity, Plasticity And Fracture"@en,
        "Elasticidad, Plasticidad y Rotura"@es ;
    schema:numberOfCredits 4.5 .

<https://guia-kg.skai.etsisi.upm.es/resource/53001251/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/53001251/2025-26/%28a%29>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001251/2025-26/%28b%29>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001251/2025-26/%28e%29>,
