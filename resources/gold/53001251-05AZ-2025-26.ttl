    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/53001251/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001251/2025-26/didactic_resource/2> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/53001251/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/53001251/2025-26/RA104>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001251/2025-26/RA105>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001251/2025-26/RA106> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/53001251/2025-26/syllabus> ;
    ns1:inpersonHours "44 horas y 30 minutos (38%)"@es ;
    ns1:numberOfCredits 4.5 ;
    ns1:otherInformation ""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "44 horas y 30 minutos"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/53001251/2025-26/eventSchedule> ;
    schema:description "Asignatura de introducción a la Mecánica del Sólido Deformable en donde, después de presentar los modelos matemáticos de equilibrio y cinemático, se estudia el comportamiento de los materiales tecnológicos en régimen elásto-plástico, así como las tres modalidades fundamentales de rotura: dúctil, frágil y por fatiga. Los distintos temas se ilustran con actividades de laboratorio y problemas industriales"@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/antonio.ros%40upm.es> ;
    schema:inLanguage "Inglés/Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/antonio.ros%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/rodado.lopez%40upm.es> ;
    schema:name "Elasticidad, Plasticidad y Rotura"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001251/2025-26/%28a%29> a ns1:Competency ;
    ns1:competencyCode "(a)" ;
    ns1:competencyDescription "APLICA. Habilidad para aplicar conocimientos científicos, matemáticos y tecnológicos en sistemas relacionados con la práctica de la ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001251/2025-26/%28b%29> a ns1:Competency ;
    ns1:competencyCode "(b)" ;
    ns1:competencyDescription "EXPERIMENTA. Habilidad para diseñar y realizar experimentos así como analizar e interpretar datos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001251/2025-26/%28e%29> a ns1:Competency ;
    ns1:competencyCode "(e)" ;
    ns1:competencyDescription "RESUELVE. Habilidad para identificar, formular y resolver problemas de ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001251/2025-26/%28k%29> a ns1:Competency ;
    ns1:competencyCode "(k)" ;
    ns1:competencyDescription "USA HERRAMIENTAS. Habilidad para usar las técnicas, destrezas y herramientas ingenieriles modernas necesarias para la práctica de la ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001251/2025-26/RA104> a ns1:LearningResult ;
    ns1:learningResultCode "RA104" ;
    ns1:learningResultDescription "Comprender que el Cálculo de Estructuras es una de las fases que conforman el proceso global del proyecto de una estructura; y en ella habrá de determinarse, mediante la aplicación de los Principios de la Mecánica de los Sólidos Deformables, si la estructura podrá desempeñar la función para la que inicialmente fue concebida."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001251/2025-26/RA105> a ns1:LearningResult ;
    ns1:learningResultCode "RA105" ;
    ns1:learningResultDescription "Relacionar los desplazamientos y esfuerzos que se producen en una estructura de barras con el sistema de solicitaciones aplicado sobre la misma; teniendo en cuenta que han de satisfacerse las relaciones básicas de Equilibrio, Compatibilidad y Comportamiento."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001251/2025-26/RA106> a ns1:LearningResult ;
    ns1:learningResultCode "RA106" ;
    ns1:learningResultDescription "Comprender la sistematización en el cálculo y su implementación en ordenadores como aproximación al uso de esta herramienta en el cálculo de estructuras."@es .

