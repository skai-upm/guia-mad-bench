<https://guia-kg.skai.etsisi.upm.es/resource/53001254/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/53001254/2025-26/%28g%29>,
