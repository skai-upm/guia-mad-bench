<https://guia-kg.skai.etsisi.upm.es/resource/565000464/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. INTRODUCCIÓN"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000464/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Concepto de Operación Básica de la Ingeniería Química. Diagramas de flujo. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000464/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "3.2. Medición de caudales. Fundamentos y tipos de medidores. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000464/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "3.3. Equipos de impulsión de fluidos:clasificación y selección. Bombas centrífugas: curvas características, cavitación, carga neta positiva de aspiración. Impulsión de gases: ventiladores, soplantes y compresores. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000464/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "4. OPERACIONES BASADAS EN FLUJO DE FLUIDOS"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000464/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "4.1. Flujo de fluidos alrededor de cuerpos sumergidos. Ecuaciones y casos de interés. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000464/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "4.2. Sedimentación libre y obstaculizada: Fundamentos, equipos y cálculos. Velocidad de sedimentación. Separación continua y discontinua. Espesadores y clarificadores. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000464/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "4.3. Filtración industrial: Fundamentos, equipos y cálculos. Filtros de líquidos y filtros de gases. Equipos (vacío, presión), operación contínua y discontínua y operaciones auxiliares. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000464/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "5. INTERCAMBIO DE CALOR"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000464/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "5.1. Mecanismos y estimación de propiedades térmicas. Aislamientos térmicos y ahorro energético. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000464/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "5.2. Intercambiadores de calor de carcasa y tubos lisos. Diseño térmico. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000464/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "5.3. Otros Intercambiadores de calor de interés en la Industria Química (compactos, de bayoneta, etc.) Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000464/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Fenómenos de transporte. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000464/2025-26/syllabus/20> a ns1:SyllabusItem ;
    ns1:itemIndex 20 ;
    ns1:syllabusDescription "6. EVAPORACIÓN INDUSTRIAL"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000464/2025-26/syllabus/21> a ns1:SyllabusItem ;
    ns1:itemIndex 21 ;
    ns1:syllabusDescription "6.1. Diagramas de ebullición y H - x. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000464/2025-26/syllabus/22> a ns1:SyllabusItem ;
    ns1:itemIndex 22 ;
    ns1:syllabusDescription "6.2. Evaporadores y sus accesorios. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000464/2025-26/syllabus/23> a ns1:SyllabusItem ;
    ns1:itemIndex 23 ;
    ns1:syllabusDescription "6.3. Análisis térmico de sistemas de evaporación. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000464/2025-26/syllabus/24> a ns1:SyllabusItem ;
    ns1:itemIndex 24 ;
    ns1:syllabusDescription "7. CRISTALIZACIÓN INDUSTRIAL"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000464/2025-26/syllabus/25> a ns1:SyllabusItem ;
    ns1:itemIndex 25 ;
    ns1:syllabusDescription "7.1. Tipos de cristales y parámetros de calidad. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000464/2025-26/syllabus/26> a ns1:SyllabusItem ;
    ns1:itemIndex 26 ;
    ns1:syllabusDescription "7.2. Técnicas de cristalización industrial. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000464/2025-26/syllabus/27> a ns1:SyllabusItem ;
    ns1:itemIndex 27 ;
    ns1:syllabusDescription "7.3. Cristalizadores y sus accesorios. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000464/2025-26/syllabus/28> a ns1:SyllabusItem ;
    ns1:itemIndex 28 ;
    ns1:syllabusDescription "7.4. Análisis térmico. Soluciones gráficas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000464/2025-26/syllabus/29> a ns1:SyllabusItem ;
    ns1:itemIndex 29 ;
    ns1:syllabusDescription "8. ALMACENAMIENTO DE MATERIALES EN PLANTAS QUÍMICAS"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000464/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "2. MECÁNICA DE FLUIDOS NO NEWTONIANOS"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000464/2025-26/syllabus/30> a ns1:SyllabusItem ;
    ns1:itemIndex 30 ;
    ns1:syllabusDescription "8.1. Instalaciones y equipos de almacenamiento. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000464/2025-26/syllabus/31> a ns1:SyllabusItem ;
    ns1:itemIndex 31 ;
    ns1:syllabusDescription "8.2. Sistemas de prevención y análisis de riesgos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000464/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "2.1. Generalidades. Fluidos y flujo de fluidos: definición y clasificación. Flujo interno y externo. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000464/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "2.2. Viscosidad y reología: fluidos newtonianos y no newtonianos. Modelos matemáticos empíricos. Capa límite fluidodinámica. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000464/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "2.3. Ecuaciones básicas en el flujo de fluidos interno. Ecuación de continuidad. Ecuación de conservación de energía mecánica. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000464/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "2.4. Flujo laminar y turbulento en tuberías. Aplicación a problemas más habituales. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000464/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "3. ELEMENTOS DE INSTALACIONES DE TRANSPORTE DE FLUIDOS."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000464/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "3.1. Conducciones y accesorios. Válvulas de proceso. Tuberías en parelelo y en serie. Redes de tuberías Sin subniveles"@es .

