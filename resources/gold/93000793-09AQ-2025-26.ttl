<https://guia-kg.skai.etsisi.upm.es/resource/93000793/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Tema 1. Introducción a las tecnologías de acceso radio. Regulación. Chapter 1. Introduction to radio access technologies. Regulation. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000793/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "2. Tema 2. Revisión de conceptos básicos de radiocomunicaciones. Chapter 2. A review of basic concepts of radiocommunications."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000793/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "2.1. Práctica 1. Planificación de sistemas de radiocomunicaciones. Practice 1. Radio planning of communication systems. Sin subniveles"@es .

