    schema:name "Tecnologias de Acceso Radio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000793/2025-26/CE1> a ns1:Competency ;
    ns1:competencyCode "CE1" ;
    ns1:competencyDescription "Capacidad para aplicar métodos de la teoría de la información, la modulación adaptativa y codificación de canal, así como técnicas avanzadas de procesado digital de señal a los sistemas de comunicaciones y audiovisuales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000793/2025-26/CE2> a ns1:Competency ;
    ns1:competencyCode "CE2" ;
    ns1:competencyDescription "Capacidad para desarrollar sistemas de radiocomunicaciones: diseño de antenas, equipos y subsistemas, modelado de canales, cálculo de enlaces y planificación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000793/2025-26/CE4> a ns1:Competency ;
    ns1:competencyCode "CE4" ;
    ns1:competencyDescription "Capacidad para diseñar y dimensionar redes de transporte, difusión y distribución de señales multimedia."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000793/2025-26/CE6> a ns1:Competency ;
    ns1:competencyCode "CE6" ;
    ns1:competencyDescription "Capacidad para modelar, diseñar, implantar, gestionar, operar, administrar y mantener redes, servicios y contenidos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000793/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Poseer y comprender conocimientos que aporten una base u oportunidad de ser originales en el desarrollo y/o aplicación de ideas, a menudo en un contexto de investigación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000793/2025-26/CG5> a ns1:Competency ;
    ns1:competencyCode "CG5" ;
    ns1:competencyDescription "Que los estudiantes posean las habilidades de aprendizaje que les permitan continuar estudiando de un modo que habrá de ser en gran medida autodirigido o autónomo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000793/2025-26/CT4> a ns1:Competency ;
    ns1:competencyCode "CT4" ;
    ns1:competencyDescription "Capacidad para trabajar de forma efectiva como individuo, organizando y planificando su propio trabajo, de forma independiente o como miembro de un equipo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000793/2025-26/CT5> a ns1:Competency ;
    ns1:competencyCode "CT5" ;
    ns1:competencyDescription "Capacidad para gestionar la información, identificando las fuentes necesarias, los principales tipos de documentos técnicos y científicos, de una manera adecuada y eficiente."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000793/2025-26/CT7> a ns1:Competency ;
    ns1:competencyCode "CT7" ;
    ns1:competencyDescription "Capacidad para trabajar en contextos internacionales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000793/2025-26/RA117> a ns1:LearningResult ;
    ns1:learningResultCode "RA117" ;
    ns1:learningResultDescription "Conocer los aspectos básicos de los sistemas y servicios de radiocomunicaciones, su marco regulatorio y estándares técnicos de referencia."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000793/2025-26/RA118> a ns1:LearningResult ;
    ns1:learningResultCode "RA118" ;
    ns1:learningResultDescription "Capacidad de describir un enlace radioeléctrico con arreglo a los parámetros técnicos más relevantes de transmisor y receptor, y de la caracterización de la propagación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000793/2025-26/RA119> a ns1:LearningResult ;
