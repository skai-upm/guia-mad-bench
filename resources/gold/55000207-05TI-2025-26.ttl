    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/55000207/2025-26/eventSchedule> ;
    schema:description """1. Sistemas de energía eléctrica.
2. Parámetros de líneas eléctricas.
3. Modelos de líneas eléctricas.
4. Transformador de potencia como elemento de red.
5. Generador síncrono como elemento de red
6. Análisis de redes en régimen permanente.
7. Cortocircuitos simétricos.
8. Estabilidad."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/sergio.martinez%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/julio.garciam%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/sergio.martinez%40upm.es> ;
    schema:name "Sistemas de Energia Electrica I"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000207/2025-26/CE25B> a ns1:Competency ;
    ns1:competencyCode "CE25B" ;
    ns1:competencyDescription "Conocimiento sobre sistemas eléctricos de potencia y sus aplicaciones."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000207/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Conocer y aplicar conocimientos de ciencias y tecnologías básicas a la práctica de la Ingeniería Industrial."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000207/2025-26/CG2> a ns1:Competency ;
    ns1:competencyCode "CG2" ;
    ns1:competencyDescription "Poseer capacidad para diseñar, desarrollar, implementar, gestionar y mejorar productos, sistemas y procesos en los distintos ámbitos industriales, usando técnicas analíticas, computacionales o experimentales apropiadas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000207/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Aplicar los conocimientos adquiridos para identificar, formular y resolver problemas dentro de contextos amplios y multidisciplinarios, siendo capaces de integrar conocimientos, trabajando en equipos multidisciplinares."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000207/2025-26/CG4> a ns1:Competency ;
    ns1:competencyCode "CG4" ;
    ns1:competencyDescription "Comprender el impacto de la ingeniería industrial en el medio ambiente, el desarrollo sostenible de la sociedad y la importancia de trabajar en un entorno profesional y responsable."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000207/2025-26/CG5> a ns1:Competency ;
    ns1:competencyCode "CG5" ;
    ns1:competencyDescription "Saber comunicar los conocimientos y conclusiones, de forma oral, escrita y gráfica, a públicos especializados y no especializados de un modo claro y sin ambigüedades."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000207/2025-26/CG6> a ns1:Competency ;
    ns1:competencyCode "CG6" ;
    ns1:competencyDescription "Poseer habilidades de aprendizaje que permitan continuar estudiando a lo largo de la vida para su adecuado desarrollo profesional."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000207/2025-26/CG7> a ns1:Competency ;
    ns1:competencyCode "CG7" ;
    ns1:competencyDescription "Incorporar nuevas tecnologías y herramientas de la Ingeniería Industrial en sus actividades profesionales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000207/2025-26/CG8> a ns1:Competency ;
    ns1:competencyCode "CG8" ;
    ns1:competencyDescription "Capacidad de trabajar en un entorno bilingüe (inglés"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000207/2025-26/RA151> a ns1:LearningResult ;
    ns1:learningResultCode "RA151" ;
    ns1:learningResultDescription "Conocimiento básico de los sistemas eléctricos de potencia y sus aplicaciones."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000207/2025-26/RA152> a ns1:LearningResult ;
    ns1:learningResultCode "RA152" ;
    ns1:learningResultDescription "Capacidad de entender el funcionamiento de los sistemas de energía eléctrica, en régimen normal y perturbado."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000207/2025-26/RA153> a ns1:LearningResult ;
    ns1:learningResultCode "RA153" ;
    ns1:learningResultDescription "Habilidad para utilizar sus herramientas básicas de análisis."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000207/2025-26/didactic_resource/1> a ns1:DidacticResource ;
    ns1:bibliographyDescription """Libro de texto básico.
Existe una versión en español: J.J. Grainger, W.D. Stevenson Jr., Análisis de Sistemas de Potencia, McGraw-Hill, 1996."""@es ;
    ns1:bibliographyTitle "J.J. Grainger, W.D. Stevenson Jr., Power System Analysis, McGraw-Hill, 1994."@es ;
    ns1:bibliographyType "Bibliografía"@es .

