    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/143003032/2025-26/eventSchedule> ;
    schema:description "Este curso tiene como objetivo dar a conocer las fuentes más importantes de contaminación de los sistemas propulsivos utilizados en el campo aeronáutico (aerorreactores y motores alternativos), estudiando su origen, sus efectos sobre el medio ambiente y los usuarios, los procesos que intervienen en su formación, la influencia que las variables de operación y diseño del sistema propulsivo tienen sobre ellos, los métodos de evaluación y medida y los sistemas de reducción y eliminación."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/al.millan%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/al.millan%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/juanramon.arias%40upm.es> ;
    schema:name "Contaminación de Sistemas Propulsivos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143003032/2025-26/CE> a ns1:Competency ;
    ns1:competencyCode "CE" ;
    ns1:competencyDescription "SP"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143003032/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Capacidad para proyectar, construir, inspeccionar, certificar y mantener todo tipo de aeronaves y vehículos espaciales, con sus correspondientes subsistemas/ Ability to project, build, monitor, certify and maintain all types of aircraft and spacecraft, as well as their related subsystems."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143003032/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Capacidad para la dirección general y la dirección técnica de proyectos de investigación, desarrollo e innovación, en empresas y centros tecnológicos aeronáuticos y espaciales/ Ability to generally and technically manage research, development and innovation projects in aeronautical and space technology companies and centres."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143003032/2025-26/CG4> a ns1:Competency ;
    ns1:competencyCode "CG4" ;
    ns1:competencyDescription "Capacidad de integrar sistemas aeroespaciales complejos y equipos de trabajo multidisciplinares/ Ability to integrate complex aerospace systems and cross"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143003032/2025-26/CG5> a ns1:Competency ;
    ns1:competencyCode "CG5" ;
    ns1:competencyDescription "Capacidad para analizar y corregir el impacto ambiental y social de las soluciones técnicas de cualquier sistema aeroespacial/ Ability to analyse and correct environmental and social impact of technical solutions of any aerospace system."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143003032/2025-26/CG6> a ns1:Competency ;
    ns1:competencyCode "CG6" ;
    ns1:competencyDescription "Capacidad para el análisis y la resolución de problemas aeroespaciales en entornos nuevos o desconocidos, dentro de contextos amplios y complejos/ Ability to analyse and solve aerospace issues within new or unknown environments, in broad and complex contexts."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143003032/2025-26/CT1> a ns1:Competency ;
    ns1:competencyCode "CT1" ;
    ns1:competencyDescription "Capacidad para comprender los contenidos de clases magistrales, conferencias y seminarios, así como cualquier información y documentación en lengua inglesa/ Ability to understand lectures, conferences and seminars content, as well as any information and documentation issued in English."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143003032/2025-26/CT2> a ns1:Competency ;
    ns1:competencyCode "CT2" ;
    ns1:competencyDescription "Capacidad para dinamizar y liderar equipos de trabajo multidisciplinares/ Ability to energise and lead cross"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143003032/2025-26/CT3> a ns1:Competency ;
    ns1:competencyCode "CT3" ;
    ns1:competencyDescription "Capacidad para adoptar soluciones creativas que satisfagan adecuadamente las diferentes necesidades planteadas/ Ability to adopt creative solutions, which appropriately meet the different requirements."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143003032/2025-26/CT4> a ns1:Competency ;
    ns1:competencyCode "CT4" ;
    ns1:competencyDescription "Capacidad para trabajar de forma efectiva como individuo, organizando y planificando su propio trabajo, de forma independiente o como miembro de un equipo/ Ability to work effectively as an individual, organise and plan their own tasks, both independently or as a member of a team"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143003032/2025-26/CT5> a ns1:Competency ;
    ns1:competencyCode "CT5" ;
    ns1:competencyDescription "Capacidad para gestionar la información, identificando las fuentes necesarias, los principales tipos de documentos técnicos y científicos, de una manera adecuada y eficiente/ Ability to manage information, to identify the required sources, the main types of technical and scientific documents, in a proper and efficient manner."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143003032/2025-26/CT6> a ns1:Competency ;
    ns1:competencyCode "CT6" ;
    ns1:competencyDescription "Capacidad para emitir juicios sobre implicaciones económicas, administrativas, sociales, éticas y medioambientales ligadas a la aplicación de sus conocimientos/ Ability to make judgments regarding economic, administrative, social, ethical and environmental implications related to the application of their knowledge."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143003032/2025-26/RA76> a ns1:LearningResult ;
    ns1:learningResultCode "RA76" ;
    ns1:learningResultDescription "RA3."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143003032/2025-26/RA93> a ns1:LearningResult ;
    ns1:learningResultCode "RA93" ;
    ns1:learningResultDescription "Conocimiento y comprensión de la influencia de parámetros de diseño y operación sobre la emisión de contaminantes"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143003032/2025-26/RA94> a ns1:LearningResult ;
    ns1:learningResultCode "RA94" ;
    ns1:learningResultDescription "Conocimiento y comprensión de la formación de contaminantes en los sistemas de propulsión."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143003032/2025-26/RA95> a ns1:LearningResult ;
    ns1:learningResultCode "RA95" ;
    ns1:learningResultDescription "Conocimiento y comprensión de los métodos de reducción de contaminantes en los sistemas de propulsión."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143003032/2025-26/RA96> a ns1:LearningResult ;
    ns1:learningResultCode "RA96" ;
    ns1:learningResultDescription "Conocimiento de la normativa relativa a la emisión de contaminantes en los sistemas de propulsión."@es .

