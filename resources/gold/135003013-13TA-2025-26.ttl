<https://guia-kg.skai.etsisi.upm.es/resource/135003013/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Propiedades físicas de los fluidos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003013/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Estructura molecular y ecuación de estado. Densidad y peso específico. Presión, compresibilidad, tensión tangencial y viscosidad. Cohesión y adhesión. Energía superficial y ascenso capilar. Presión de vapor y calores específicos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003013/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "4. Dinámica del líquido real."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003013/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "4.1. Estabilidad del régimen laminar: experimento de Reynolds. Ecuación para el régimen laminar en tubos y sobre una ladera. Ecuación de Darcy para la filtración. Condiciones de contorno para la resolución numérica de la filtración en medios porosos saturados. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003013/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "4.2. Turbulencia. Capa límite. Separación de la capa límite. Empuje hidrodinámico y pérdida de carga en transiciones. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003013/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "5. Flujo en conductos a presión."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003013/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "5.1. Distribución de velocidad. Pérdida de carga en régimen uniforme, factor de rozamiento de Colebrook-White, ecuaciones empíricas monómico-potenciales. Flujo permanente en redes a presión. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003013/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "5.2. Turbomáquinas. Transformación de energía. Curvas características de bombas y leyes de semejanza. Agrupamiento de bombas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003013/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "6. Flujo de líquidos en conductos abiertos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003013/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "6.1. Flujo permanente y uniforme en conductos en lámina libre. Sección de máxima eficiencia hidráulica. Tensión tangencial sobre el contorno. Estabilidad de solera y taludes. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003013/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "6.2. Energía específica y régimen crítico. Transiciones. Resalto hidráulico y cuencos disipadores. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003013/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "6.3. Régimen gradualmente variado. Secciones de control. Régimen variable. Integración numérica. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003013/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "2. Hidrodinámica."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003013/2025-26/syllabus/20> a ns1:SyllabusItem ;
    ns1:itemIndex 20 ;
    ns1:syllabusDescription "7. Aforo, regulación y control."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003013/2025-26/syllabus/21> a ns1:SyllabusItem ;
    ns1:itemIndex 21 ;
    ns1:syllabusDescription "7.1. Relaciones hidrodinámicas en vertederos y compuertas. Coeficiente de desagüe. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003013/2025-26/syllabus/22> a ns1:SyllabusItem ;
    ns1:itemIndex 22 ;
    ns1:syllabusDescription "7.2. Equipos y técnicas para medida directa e indirecta del caudal y del nivel. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003013/2025-26/syllabus/23> a ns1:SyllabusItem ;
    ns1:itemIndex 23 ;
    ns1:syllabusDescription "7.3. Aforo en conductos y cauces naturales: métodos y obras y equipos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003013/2025-26/syllabus/24> a ns1:SyllabusItem ;
    ns1:itemIndex 24 ;
    ns1:syllabusDescription "8. Flujo de agua y transporte asociado de sustancias y partículas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003013/2025-26/syllabus/25> a ns1:SyllabusItem ;
    ns1:itemIndex 25 ;
    ns1:syllabusDescription "8.1. Flujo de agua en régimen variable y transportes asociados. Difusión. Advección y convección. Aproximaciones globales. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003013/2025-26/syllabus/26> a ns1:SyllabusItem ;
    ns1:itemIndex 26 ;
    ns1:syllabusDescription "8.2. Transporte en la capa límite. Transporte turbulento. Difusión y dispersión en canales y acuíferos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003013/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "2.1. Tipos de movimiento: permanente y variable, uniforme y variado, laminar y turbulento. Distribución de la velocidad en una sección transversal con movimiento uniforme. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003013/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "2.2. Equilibrio dinámico de la partícula fluida. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003013/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "2.3. Relaciones diferenciales para un volumen elemental de fluido. Conservación de la masa, de la cantidad de movimiento y de la energía. Condiciones de contorno. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003013/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "2.4. Método unidimensional de análisis de corrientes de fluidos. Ecuación de continuidad. Ecuación de la energía entre secciones con movimiento uniforme. Equilibrio de un volumen finito de tubo de corriente, ecuación global de Euler. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003013/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "3. Análisis dimensional y semejanza."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003013/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "3.1. Parámetros adimensionales. Ecuación general de la Hidráulica. Ecuaciones de desagüe, de rozamiento en conductos uniformes, pérdidas de energía singulares, empuje sobre cuerpos sumergidos, de desagüe sobre vertederos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003013/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "3.2. Generalización de resultados, semejanza y modelos físicos. Efecto de escala. Sin subniveles"@es .

