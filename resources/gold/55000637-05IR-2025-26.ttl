<https://guia-kg.skai.etsisi.upm.es/resource/55000637/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/55000637/2025-26/CE24>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55000637/2025-26/CG1> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/55000637/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55000637/2025-26/didactic_resource/2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55000637/2025-26/didactic_resource/3>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55000637/2025-26/didactic_resource/4> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/55000637/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/55000637/2025-26/RA104>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55000637/2025-26/RA105>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55000637/2025-26/RA109>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55000637/2025-26/RA111>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55000637/2025-26/RA112>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55000637/2025-26/RA113>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55000637/2025-26/RA114> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/55000637/2025-26/syllabus> ;
    ns1:inpersonHours "36 horas (46.2%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation "No hay información reseñable"@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "59 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/55000637/2025-26/eventSchedule> ;
    schema:description """El objetivo de la asignatura es trasmitir la base tecnológica de los sistemas de información, en concreto de los sistemas de información basados en la web, el diseño de bases de datos y el conocimiento de las distintas herramientas software que se utilizan para el desarrollo de webs que implanten un sistema de información.
Se trata de utilizar herramientas de uso libre y familiarzarse con el diseño de las bases de datos necesarias para gestionar de forma eficaz un sistema de información."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/angel.garcia%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/angel.garcia%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/pm.vigara%40upm.es> ;
    schema:name "Tecnologías de la Información"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000637/2025-26/CE24> a ns1:Competency ;
    ns1:competencyCode "CE24" ;
    ns1:competencyDescription "Conocimientos generales Modelo OSI de comunicaciones. Redes Ethernet. TCP/IP. Servicios de Internet. Redes móviles. Redes locales inalámbricas. Identificación electrónica. Aplicaciones de las micro, bio y nanotecnologías."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000637/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Conocer y aplicar conocimientos de ciencias y tecnologías básicas a la práctica de la Ingeniería de organización"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000637/2025-26/RA104> a ns1:LearningResult ;
    ns1:learningResultCode "RA104" ;
    ns1:learningResultDescription "Programar en lenguajes de alto nivel."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000637/2025-26/RA105> a ns1:LearningResult ;
    ns1:learningResultCode "RA105" ;
    ns1:learningResultDescription "Entender el funcionamiento de un computador."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000637/2025-26/RA109> a ns1:LearningResult ;
    ns1:learningResultCode "RA109" ;
    ns1:learningResultDescription "Conocer los aspectos básicos de las redes de comunicaciones y los principales estándares"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000637/2025-26/RA111> a ns1:LearningResult ;
    ns1:learningResultCode "RA111" ;
    ns1:learningResultDescription "Comprender el concepto de base de datos y los diferentes modelos utilizados en la actualidad para representar bases de datos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000637/2025-26/RA112> a ns1:LearningResult ;
    ns1:learningResultCode "RA112" ;
    ns1:learningResultDescription "Ser capaz de diseñar una base de datos relacional mediante herramientas de ayuda al diseño."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000637/2025-26/RA113> a ns1:LearningResult ;
    ns1:learningResultCode "RA113" ;
    ns1:learningResultDescription "Conocer el uso de un sistema de gestión de bases de datos relacionales más extendidos: MySQL."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000637/2025-26/RA114> a ns1:LearningResult ;
    ns1:learningResultCode "RA114" ;
    ns1:learningResultDescription "Construir una base de datos que soporte un sistema de información para la empresa"@es .

