    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/133000190/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/133000190/2025-26/RA10>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000190/2025-26/RA27>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000190/2025-26/RA28>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000190/2025-26/RA8> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/133000190/2025-26/syllabus> ;
    ns1:inpersonHours "38 horas (48.7%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation """Dado que la asignatura necesita del uso de software específico que está instalado en el aula informática de la ETSIME; la docencia se impartirá en la Escuela Técnica Superior de Ingenieros de Minas y Energía.
Esta asignatura está relacionada con los ODS3, ODS7, ODS11, ODS12, ODS13."""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "68 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/133000190/2025-26/eventSchedule> ;
    schema:description "En esta asignatura se darán los conceptos básicos sobre \"Análisis de Ciclo de Vida\". Se hablará de huella ambiental y huella de carbono. Los alumnos también aprenderán conceptos básicos acerca del análisis de costes de ciclo de vida y de ciclo de vida social. Los tres ciclos de vida, el ambiental, económico y social son necesarios para estudiar la sostenibilidad de los productos. También se verá algún indicador usado para ver la circularidad de los productos."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/mj.garcia%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/maria.scanales%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/mj.garcia%40upm.es> ;
    schema:name "Ciclo de Vida de Productos y Servicios"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000190/2025-26/CB08> a ns1:Competency ;
    ns1:competencyCode "CB08" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de integrar conocimientos y enfrentarse a la complejidad de formular juicios a partir de una información que, siendo incompleta o limitada, incluya reflexiones sobre las responsabilidades sociales y éticas vinculadas a la aplicación de sus conocimientos y juicios"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000190/2025-26/CB10> a ns1:Competency ;
    ns1:competencyCode "CB10" ;
    ns1:competencyDescription "Que los estudiantes posean las habilidades de aprendizaje que les permitan continuar estudiando de un modo que habrá de ser en gran medida autodirigido o autónomo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000190/2025-26/CE08> a ns1:Competency ;
    ns1:competencyCode "CE08" ;
    ns1:competencyDescription "El alumno podrá calcular el Análisis de Ciclo de Vida de los productos y la Huella de Carbono."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000190/2025-26/CG02> a ns1:Competency ;
    ns1:competencyCode "CG02" ;
    ns1:competencyDescription "El alumno podrá utilizar las herramientas necesarias para llevar a cabo los cambios en la empresa y en la sociedad para adoptar un modelo de economía circular."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000190/2025-26/RA10> a ns1:LearningResult ;
