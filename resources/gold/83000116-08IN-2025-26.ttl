        <https://guia-kg.skai.etsisi.upm.es/resource/83000116/2025-26/didactic_resource/2> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/83000116/2025-26/evaluation> ;
