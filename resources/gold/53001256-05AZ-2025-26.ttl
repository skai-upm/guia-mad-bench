        <https://guia-kg.skai.etsisi.upm.es/resource/53001256/2025-26/%28n%29> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/53001256/2025-26/didactic_resource/1>,
