<https://guia-kg.skai.etsisi.upm.es/resource/53001256/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/53001256/2025-26/%28a%29>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001256/2025-26/%28c%29>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001256/2025-26/%28e%29>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001256/2025-26/%28j%29>,
