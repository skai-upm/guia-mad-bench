        <https://guia-kg.skai.etsisi.upm.es/resource/53001256/2025-26/didactic_resource/3> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/53001256/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/53001256/2025-26/RA186>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001256/2025-26/RA324> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/53001256/2025-26/syllabus> ;
    ns1:inpersonHours "49 horas (41.9%)"@es ;
    ns1:numberOfCredits 4.5 ;
    ns1:otherInformation "La asignatura está programada en formato de formación presencial."@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "55 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/53001256/2025-26/eventSchedule> ;
    schema:description "En la asignatura se presentan a los alumnos los principales sistemas de los vehículos automóviles. Entre ellos destacan, el sistema de suspensión, el de transmisión incluyendo las últimas cajas de cambios incorporadas en vehículos actualmente en producción y la tracción 4x4, el de frenado y los buses multiplexados de comunicación del automóvil. Se utilizan con profusión esquemas y secciones de las piezas de los automóviles que permiten al alumno entender las características constructivas y el funcionamiento de los sistemas más habituales implantados en los automóviles. Se plantean las ecuaciones que permiten obtener los esfuerzos y parámetros de diseño, funcionamiento y optimización de algunos de los sistemas del automóvil. Los diseños actuales, se introducen en algunos apartados, como una evolución de diseños anteriores, permitiendo al alumno conocer diseños previos y los motivos que han propiciado su innovación."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/luis.martinez%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/luis.martinez%40upm.es> ;
    schema:name "Automoviles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001256/2025-26/%28a%29> a ns1:Competency ;
    ns1:competencyCode "(a)" ;
    ns1:competencyDescription "APLICA. Habilidad para aplicar conocimientos científicos, matemáticos y tecnológicos en sistemas relacionados con la práctica de la ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001256/2025-26/%28c%29> a ns1:Competency ;
    ns1:competencyCode "(c)" ;
    ns1:competencyDescription "DISEÑA. Habilidad para diseñar un sistema, componente o proceso que alcance los requisitos deseados teniendo en cuenta restricciones realistas tales como las económicas, medioambientales, sociales, políticas, éticas, de salud y seguridad, de fabricación y de sostenibilidad."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001256/2025-26/%28e%29> a ns1:Competency ;
    ns1:competencyCode "(e)" ;
    ns1:competencyDescription "RESUELVE. Habilidad para identificar, formular y resolver problemas de ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001256/2025-26/%28j%29> a ns1:Competency ;
    ns1:competencyCode "(j)" ;
    ns1:competencyDescription "CONOCE. Conocimiento de los temas contemporáneos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001256/2025-26/%28k%29> a ns1:Competency ;
    ns1:competencyCode "(k)" ;
    ns1:competencyDescription "USA HERRAMIENTAS. Habilidad para usar las técnicas, destrezas y herramientas ingenieriles modernas necesarias para la práctica de la ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001256/2025-26/%28n%29> a ns1:Competency ;
    ns1:competencyCode "(n)" ;
    ns1:competencyDescription "IDEA. Creatividad"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001256/2025-26/RA186> a ns1:LearningResult ;
    ns1:learningResultCode "RA186" ;
    ns1:learningResultDescription "Conocer el funcionamiento y los criterios de diseño de los principales sistemas de los automóviles actuales: suspensión, frenos, transmisiones y buses de comunicación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001256/2025-26/RA324> a ns1:LearningResult ;
    ns1:learningResultCode "RA324" ;
    ns1:learningResultDescription "Conocer las distintas tecnologías de seguridad de los vehículos automóviles"@es .

