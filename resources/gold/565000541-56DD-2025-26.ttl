<https://guia-kg.skai.etsisi.upm.es/resource/565000541/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Conceptos básicos. Circuitos de corriente continua."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000541/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Conceptos básicos de electricidad: diferencia de potencial, corriente eléctrica, intensidad de corriente, fuerza electromotriz, generadores de f.e.m., circuito eléctrico, elementos pasivos Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000541/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "2.3. Respuesta de los circuitos serie a una excitación sinusoidal: Impedancia. Resonancia. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000541/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "2.4. Respuesta de los circuitos paralelos: Admitancia. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000541/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "2.5. Potencia en corriente alterna. Potencias Activa, Reactiva y Aparente. Teorema de Boucherot. Factor de potencia: importancia y mejora. Medida de la potencia: vatímetros. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000541/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "3. Sistemas Trifásicos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000541/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "3.1. Generalidades. Secuencia de fases. Conexiones en estrella y en triángulo. Convenio de situación fasorial. Diagramas fasoriales. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000541/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "3.2. Receptores trifásicos equilibrados y desequilibrados. Acoplamientos en triángulo y en estrella. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000541/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "3.3. Potencia en los receptores trifásicos. Medida de la Potencia en los receptores trifásicos: Sistemas a cuatro hilos. Sistemas a tres hilos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000541/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "3.4. Potencia en los receptores trifásicos. Medida de la potencia activa en sistemas a tres y cuatro hilos. Método de los dos vatímetros. Medida de la potencia reactiva en sistemas equilibrados. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000541/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "3.5. Mejora del factor de potencia. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000541/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "4. Introducción a los Teoremas Generales de los Circuitos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000541/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Elementos pasivos ideales: resistencia, bobina y condensador. Ecuaciones de definición. Energía almacenada. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000541/2025-26/syllabus/20> a ns1:SyllabusItem ;
    ns1:itemIndex 20 ;
    ns1:syllabusDescription "4.1. Formas de onda. Síntesis de formas de onda básicas. Condiciones de continuidad. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000541/2025-26/syllabus/21> a ns1:SyllabusItem ;
    ns1:itemIndex 21 ;
    ns1:syllabusDescription "4.2. Teorema de superposición. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000541/2025-26/syllabus/22> a ns1:SyllabusItem ;
    ns1:itemIndex 22 ;
    ns1:syllabusDescription "4.3. Teoremas de Thevenin y Norton. Teorema de la máxima transferencia de potencia. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000541/2025-26/syllabus/23> a ns1:SyllabusItem ;
    ns1:itemIndex 23 ;
    ns1:syllabusDescription "5. Introducción al régimen transitorio de los circuitos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000541/2025-26/syllabus/24> a ns1:SyllabusItem ;
    ns1:itemIndex 24 ;
    ns1:syllabusDescription "5.1. Condiciones de continuidad. Circuitos equivalentes con condiciones iniciales nulas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000541/2025-26/syllabus/25> a ns1:SyllabusItem ;
    ns1:itemIndex 25 ;
    ns1:syllabusDescription "5.2. Circuitos de primer orden. Carga de un condensador. Respuesta de un circuito R-C a un pulso rectangular. Respuesta de un circuito R-L a un pulso rectangular. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000541/2025-26/syllabus/26> a ns1:SyllabusItem ;
    ns1:itemIndex 26 ;
    ns1:syllabusDescription "5.3. Circuitos de segundo orden. Parámetros que definen un sistema de segundo orden. Clasificación de los sistemas de segundo orden. Respuesta a entrada cero del circuito serie R-L-C. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000541/2025-26/syllabus/27> a ns1:SyllabusItem ;
    ns1:itemIndex 27 ;
    ns1:syllabusDescription "6. Prácticas de Laboratorio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000541/2025-26/syllabus/28> a ns1:SyllabusItem ;
    ns1:itemIndex 28 ;
    ns1:syllabusDescription "6.1. Explicativa Inicial Sin subniveles"@es .

