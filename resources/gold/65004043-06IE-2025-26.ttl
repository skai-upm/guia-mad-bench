    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/65004043/2025-26/eventSchedule> ;
    schema:description "La asignatura ofrece una visión global de las centrales térmicas generadoras de electricidad apartir de fuentes convencionales y alternativas e incluyendo los principales componentes y tecnologías. Se trabaja sobre el diseño, funcionamiento y tecnologías asociadas a estas centrales, incluyendo el análisis de los principales equipos y sistema."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/elisa.alonso%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/alberto.abanades%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/elisa.alonso%40upm.es> ;
    schema:name "Centrales Termicas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004043/2025-26/CE18> a ns1:Competency ;
    ns1:competencyCode "CE18" ;
    ns1:competencyDescription "Comprender el funcionamiento de las máquinas eléctricas y sus aplicaciones."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004043/2025-26/CE40> a ns1:Competency ;
    ns1:competencyCode "CE40" ;
    ns1:competencyDescription "Comprender el funcionamiento y la operación de las centrales eléctricas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004043/2025-26/CE45> a ns1:Competency ;
    ns1:competencyCode "CE45" ;
    ns1:competencyDescription "Aplicación de conocimientos de ingeniería al diseño, implantación y puesta en operación de plantas energéticas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004043/2025-26/CE53> a ns1:Competency ;
    ns1:competencyCode "CE53" ;
    ns1:competencyDescription "Aplicar los principios de la tecnología ambiental a la evaluación de impactos, al tratamiento de residuos y a la sostenibilidad."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004043/2025-26/CE58> a ns1:Competency ;
    ns1:competencyCode "CE58" ;
    ns1:competencyDescription "Aplicar los fundamentos de la prevención de riesgos laborales en los proyectos e instalaciones energéticos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004043/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Conocer y aplicar conocimientos de ciencias y tecnologías básicas a la práctica de la Ingeniería de la Energía."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004043/2025-26/CG5> a ns1:Competency ;
    ns1:competencyCode "CG5" ;
    ns1:competencyDescription "Saber comunicar los conocimientos y conclusiones, tanto de forma oral, escrita y gráfica, a públicos especializados y no especializados de un modo claro y sin ambigüedades."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004043/2025-26/CG6> a ns1:Competency ;
    ns1:competencyCode "CG6" ;
    ns1:competencyDescription "Poseer habilidades de aprendizaje que permitan continuar estudiando a lo largo de la vida para su adecuado desarrollo profesional."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004043/2025-26/CG7> a ns1:Competency ;
    ns1:competencyCode "CG7" ;
    ns1:competencyDescription "Incorporar nuevas tecnologías y herramientas de la Ingeniería Energética en sus actividades profesionales."@es .

