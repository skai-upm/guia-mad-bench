    ns1:learningResultCode "RA15" ;
    ns1:learningResultDescription "Analizar el concepto de sostenibilidad ambiental, económica y de recursos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002020/2025-26/RA16> a ns1:LearningResult ;
    ns1:learningResultCode "RA16" ;
    ns1:learningResultDescription "Comprender los problemas medioambientales de la producción energética"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002020/2025-26/RA17> a ns1:LearningResult ;
    ns1:learningResultCode "RA17" ;
    ns1:learningResultDescription "Análisis y resolución de problemas de sostenibilidad en el entorno de las energías renovables"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002020/2025-26/RA18> a ns1:LearningResult ;
