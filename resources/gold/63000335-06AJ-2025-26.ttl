<https://guia-kg.skai.etsisi.upm.es/resource/63000335/2025-26/CB07> a ns1:Competency ;
    ns1:competencyCode "CB07" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en entornos nuevos o poco conocidos dentro de contextos más amplios (o multidisciplinares) relacionados con su área de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000335/2025-26/CB08> a ns1:Competency ;
    ns1:competencyCode "CB08" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de integrar conocimientos y enfrentarse a la complejidad de formular juicios a partir de una información que, siendo incompleta o limitada, incluya reflexiones sobre las responsabilidades sociales y éticas vinculadas a la aplicación de sus conocimientos y juicios"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000335/2025-26/CB10> a ns1:Competency ;
    ns1:competencyCode "CB10" ;
    ns1:competencyDescription "Que los estudiantes posean las habilidades de aprendizaje que les permitan continuar estudiando de un modo que habrá de ser en gran medida autodirigido o autónomo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000335/2025-26/CG04> a ns1:Competency ;
    ns1:competencyCode "CG04" ;
    ns1:competencyDescription "Capacidad para plantear y dirigir el desarrollo de soluciones de ingeniería en entornos nuevos o poco conocidos, dentro de contextos más amplios o multidisciplinares, siendo capaces de integrar dichos conocimientos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000335/2025-26/CG05> a ns1:Competency ;
    ns1:competencyCode "CG05" ;
    ns1:competencyDescription "Capacidad para integrar conocimientos de ingeniería geológica y geotecnia y formular juicios, aún cuando la información sea limitada o incompleta."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000335/2025-26/CT01> a ns1:Competency ;
    ns1:competencyCode "CT01" ;
    ns1:competencyDescription "Capacidad de uso de la lengua inglesa para el trabajo en contextos internacionales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000335/2025-26/CT02> a ns1:Competency ;
    ns1:competencyCode "CT02" ;
    ns1:competencyDescription "Capacidad para el trabajo en grupo y dirigir, organizar y supervisar equipos multidisciplinares"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000335/2025-26/CT03> a ns1:Competency ;
    ns1:competencyCode "CT03" ;
    ns1:competencyDescription "Creatividad, iniciativa y capacidad emprendedora."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000335/2025-26/CT04> a ns1:Competency ;
    ns1:competencyCode "CT04" ;
    ns1:competencyDescription "Capacidad para la elaboración, planificación, coordinación y gestión técnica y económica de proyectos siguiendo criterios éticos, de calidad y medioambientales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000335/2025-26/RA1> a ns1:LearningResult ;
    ns1:learningResultCode "RA1" ;
    ns1:learningResultDescription "Análisis de los conceptos aprovechamiento sostenible en la explotación de los recursos hidrogeológicos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000335/2025-26/RA14> a ns1:LearningResult ;
    ns1:learningResultCode "RA14" ;
    ns1:learningResultDescription "Capacidad de aplicación a casos prácticos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000335/2025-26/RA34> a ns1:LearningResult ;
    ns1:learningResultCode "RA34" ;
    ns1:learningResultDescription "Creatividad"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000335/2025-26/RA54> a ns1:LearningResult ;
    ns1:learningResultCode "RA54" ;
    ns1:learningResultDescription "Comprensión de los riesgos que comporta el medio natural, del impacto de los fenómenos naturales sobre el medio ambiente y la sociedad."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000335/2025-26/RA55> a ns1:LearningResult ;
    ns1:learningResultCode "RA55" ;
    ns1:learningResultDescription "Saber diferenciar y caracterizar las componentes del riesgo. Valorar la incertidumbre asociada al análisis de riesgos naturales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000335/2025-26/RA57> a ns1:LearningResult ;
    ns1:learningResultCode "RA57" ;
    ns1:learningResultDescription "Desarrollar un estudio de un riesgo natural y su componente socio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000335/2025-26/RA72> a ns1:LearningResult ;
    ns1:learningResultCode "RA72" ;
    ns1:learningResultDescription "Analizar y evaluar resultados"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000335/2025-26/RA8> a ns1:LearningResult ;
    ns1:learningResultCode "RA8" ;
    ns1:learningResultDescription "Actuar en equipo con expertos de otras disciplinas en materias relacionadas con la Agua y la extracción de recursos naturales y energéticos, colaborando en el desarrollo de proyectos complejos, definiendo e integrando técnicas y tecnologías con filosofías y protocolos (sostenibilidad, ecogestión, eficiencia, etc.), aplicando para ello una visión integral y capacidad analítica; como asesorar a organismos, empresas e instituciones privadas, estatales o internacionales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000335/2025-26/RA82> a ns1:LearningResult ;
    ns1:learningResultCode "RA82" ;
    ns1:learningResultDescription "Ra1 Ra14"@es .

