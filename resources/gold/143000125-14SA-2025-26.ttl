    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/143000125/2025-26/eventSchedule> ;
    schema:description """La asignatura tiene como objetivos principales que el alumno se familiarice y entienda los procesos térmicos a bordo de un vehículo espacial, que sea capaz de aplicar las ecuaciones de balance térmico a un vehículo o sistema espacial obteniendo temperaturas y flujos de calor, y por último, que sea capaz de seleccionar y dimensionar los elementos de control térmico necesarios para cumplir los requisitos de los sistemas analizados.
Los contenidos de la asignatura se han definido para que se puedan alcanzar los objetivos previstos."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/javier.piqueras%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/alejandrojose.fernandez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/david.gonzalez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/ignacio.torralbo%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/javier.piqueras%40upm.es> ;
    schema:name "Transferencia de Calor y Control Térmico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000125/2025-26/E01> a ns1:Competency ;
    ns1:competencyCode "E01" ;
    ns1:competencyDescription "Aplicar los principios físicos y matemáticos avanzados y los métodos numéricos empleados en el análisis de problemas típicos de la ingeniería de sistemas espaciales. Evaluar e interpretar críticamente los resultados obtenidos con estos métodos, tanto cualitativa como cuantitativamente"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000125/2025-26/E02> a ns1:Competency ;
    ns1:competencyCode "E02" ;
    ns1:competencyDescription "Aplicar los métodos de análisis propios de un determinado subsistema, para verificar la adecuación del diseño del mismo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000125/2025-26/E03> a ns1:Competency ;
    ns1:competencyCode "E03" ;
    ns1:competencyDescription "Conocer y comprender el entorno espacial y planetario, y su efecto en la operación de los vehículos aeroespaciales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000125/2025-26/E10> a ns1:Competency ;
    ns1:competencyCode "E10" ;
    ns1:competencyDescription "Conocer los diferentes tipos de configuraciones de subsistemas y su relación con los distintos tipos de misión y los correspondientes requisitos, así como las relaciones entre diferentes subsistemas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000125/2025-26/E11> a ns1:Competency ;
    ns1:competencyCode "E11" ;
    ns1:competencyDescription "Establecer, diseñar, poner en práctica y adoptar un proceso de desarrollo de un subsistema de un vehículo espacial, y también del sistema completo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000125/2025-26/E12> a ns1:Competency ;
    ns1:competencyCode "E12" ;
    ns1:competencyDescription "Desarrollar los diferentes subsistemas específicos que conforman un vehículo espacial."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000125/2025-26/E13> a ns1:Competency ;
    ns1:competencyCode "E13" ;
    ns1:competencyDescription "Analizar los subsistemas específicos que conforman un vehículo espacial."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000125/2025-26/E14> a ns1:Competency ;
    ns1:competencyCode "E14" ;
    ns1:competencyDescription "Conocer los distintos tipos de ensayos ambientales, de radiación, estructurales y térmicos necesarios para verificar el diseño de una nave espacial"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000125/2025-26/E15> a ns1:Competency ;
    ns1:competencyCode "E15" ;
    ns1:competencyDescription "Desarrollar pruebas y experimentos para valorar y validar los resultados teóricos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000125/2025-26/E22> a ns1:Competency ;
    ns1:competencyCode "E22" ;
    ns1:competencyDescription "Calcular subsistemas de control térmico con la herramienta de uso industrial ESATAN"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000125/2025-26/E23> a ns1:Competency ;
    ns1:competencyCode "E23" ;
    ns1:competencyDescription "Desarrollar un trabajo de diseño de un producto propio de la ingeniería aeroespacial, utilizando eficazmente los recursos modernos de información y tecnologías, así como los recursos e infraestructuras disponibles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000125/2025-26/E24> a ns1:Competency ;
    ns1:competencyCode "E24" ;
    ns1:competencyDescription "Evaluar la bondad de un determinado diseño para satisfacer los requisitos de misión"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000125/2025-26/RA10> a ns1:LearningResult ;
    ns1:learningResultCode "RA10" ;
    ns1:learningResultDescription "RA10"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000125/2025-26/RA16> a ns1:LearningResult ;
    ns1:learningResultCode "RA16" ;
    ns1:learningResultDescription "Comprende la relevancia de las ciencias básicas y su aplicación en la ingeniería"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000125/2025-26/RA18> a ns1:LearningResult ;
    ns1:learningResultCode "RA18" ;
    ns1:learningResultDescription "Identifica y resuelve problemas aplicando los conocimientos adquiridos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000125/2025-26/RA19> a ns1:LearningResult ;
    ns1:learningResultCode "RA19" ;
    ns1:learningResultDescription "Se integra y forma parte activa de equipos de trabajo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000125/2025-26/RA20> a ns1:LearningResult ;
    ns1:learningResultCode "RA20" ;
    ns1:learningResultDescription "Razona críticamente y de forma asociativa"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000125/2025-26/RA21> a ns1:LearningResult ;
    ns1:learningResultCode "RA21" ;
    ns1:learningResultDescription "Se comunica correctamente de forma oral y escrita"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000125/2025-26/RA23> a ns1:LearningResult ;
    ns1:learningResultCode "RA23" ;
    ns1:learningResultDescription "Conoce y sabe utilizar programas de diseño de análisis de misión y trayectorias espaciales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000125/2025-26/RA24> a ns1:LearningResult ;
    ns1:learningResultCode "RA24" ;
    ns1:learningResultDescription "Entiende el entorno espacial de un satélite y sabe traducirlo a requisitos de misión."@es .

