<https://guia-kg.skai.etsisi.upm.es/resource/105000350/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Sistemas de ecuaciones lineales y espacios vectoriales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000350/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Cálculo matricial. Operaciones elementales de fila. Forma reducida. Rango. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000350/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "2.2. Tipos de homomorfismos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000350/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "2.3. Cambio de base asociado a un homomorfismo. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000350/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "3. Diagonalización"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000350/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "3.1. Valores y vectores propios. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000350/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "3.2. Subespacios propios. Caracterización de las matrices diagonalizables. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000350/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "4. Espacio vectorial euclídeo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000350/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "4.1. Producto escalar. Distancia y ángulo entre vectores. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000350/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "4.2. Bases ortogonales. Procedimiento de ortonormalización de Gram-Schmidt. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000350/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "4.3. Complemento ortogonal. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000350/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "4.4. Proyección ortogonal. Distancia entre vector y subespacio. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000350/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Resolución de sistemas por el método de Gauss y Gauss-Jordan. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000350/2025-26/syllabus/20> a ns1:SyllabusItem ;
    ns1:itemIndex 20 ;
    ns1:syllabusDescription "4.5. Diagonalización ortogonal. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000350/2025-26/syllabus/21> a ns1:SyllabusItem ;
    ns1:itemIndex 21 ;
    ns1:syllabusDescription "5. Aplicaciones ortogonales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000350/2025-26/syllabus/22> a ns1:SyllabusItem ;
    ns1:itemIndex 22 ;
    ns1:syllabusDescription "5.1. Aplicaciones ortogonales en el plano. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000350/2025-26/syllabus/23> a ns1:SyllabusItem ;
    ns1:itemIndex 23 ;
    ns1:syllabusDescription "5.2. Aplicaciones ortogonales en el espacio. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000350/2025-26/syllabus/24> a ns1:SyllabusItem ;
    ns1:itemIndex 24 ;
    ns1:syllabusDescription "6. Variedades afines"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000350/2025-26/syllabus/25> a ns1:SyllabusItem ;
    ns1:itemIndex 25 ;
    ns1:syllabusDescription "6.1. Variedades afines del plano y del espacio. Aplicaciones afines y movimientos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000350/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "1.3. Espacios vectoriales y subespacios Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000350/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "1.4. Dependencia lineal. Bases. Dimensión. Coordenadas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000350/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "1.5. Ecuaciones paramétricas e implícitas de un subespacio. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000350/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "1.6. Suma, intersección y suma directa de subespacios. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000350/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "1.7. Aplicación a la teoría de códigos lineales. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000350/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "2. Aplicaciones lineales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000350/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "2.1. Aplicaciones lineales. Núcleo e imagen. Fórmula de las dimensiones. Sin subniveles"@es .

