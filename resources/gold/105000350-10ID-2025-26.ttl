<https://guia-kg.skai.etsisi.upm.es/resource/105000350/2025-26/RA13> a ns1:LearningResult ;
    ns1:learningResultCode "RA13" ;
    ns1:learningResultDescription "Resolver sistemas de ecuaciones lineales. Conocer y manejar las propiedades de los espacios vectoriales y sus aplicaciones a la informática."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000350/2025-26/RA14> a ns1:LearningResult ;
    ns1:learningResultCode "RA14" ;
    ns1:learningResultDescription "Utilizar las matrices para la representación y manejo de datos y transformaciones, así como su aplicación a la geometría del plano y del espacio. Cálculo de autovalores y autovectores y sus aplicaciones a la informática."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000350/2025-26/RA146> a ns1:LearningResult ;
    ns1:learningResultCode "RA146" ;
    ns1:learningResultDescription "Tener capacidad de razonamiento y abstracción."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000350/2025-26/RA15> a ns1:LearningResult ;
    ns1:learningResultCode "RA15" ;
    ns1:learningResultDescription "Modelar matemáticamente problemas reales y conocer las técnicas para resolverlos."@es .

