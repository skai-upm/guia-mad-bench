<https://guia-kg.skai.etsisi.upm.es/resource/53001591/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Impacto de la energía en el desarrollo. Papel de la energía nuclear. // Energy impact on development. Role of nuclear energy. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001591/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "2. Residuos: uno de los principales problemas de la energía nuclear. // Nuclear waste: One of the main problems of nuclear energy."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001591/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "2.1. Tipos, cantidades y alternativas de gestión //Types, quantities and management alternatives. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001591/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "3. Para transmutar, primero hay que separar. // To transmute, partitioning first"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001591/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "3.1. Principios básicos de los métodos de separación utilizados en radioquímica. //Basic principles of separation methods in radiochemistry. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001591/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "3.2. Métodos utilizados para la separación del combustible nuclear // Spent nuclear fuel partitioning methods Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001591/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "4. Transmutación. // Transmutation"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001591/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "4.1. Transmutación de residuos radiactivos: teoría básica. // Transmutation of radioactive waste: basis. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001591/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "4.2. Sistemas de Transmutación: alternativas actuales; sistemas de reactores críticos y subcríticos// Transmutation Systems: current alternatives, critical and subcritical reactor systems. Sin subniveles"@es .

