    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/43000373/2025-26/eventSchedule> ;
    schema:description """Esta asignatura tiene como objetivo principal despertar la labor creativa de los ingenieros en el proyecto de estructuras. Los alumnos aprenderán a crear una idea, a conocer los materiales, con sus potenciales y límites en las aplicaciones estructurales, así como diseñar las principales tipologías estructurales a utilizar en puentes, edificios, torres, etc.. Los alumnos aprenderán a identificar la relación entre tipología estructural, distribución interna de esfuerzos y aprovechamiento de materiales. Todo el enfoque se basará en el marco de la sostenibilidad, y sus tres pilares. No hay un examen clásico. Los alumnos, en grupo de 2 o 3, deberán desarrollar un trabajo de curso que será presentado y defendido frente de un tribunal.
Las clases están diseñadas sin barreras idiomáticas para los estudiantes de intercambio. Aunque las clases son en español, todo el texto de las diapositivas está en inglés, con traducción al español de los términos técnicos más relevantes. La defensa del proyecto final se puede hacer en español o, si se prefiere, en inglés."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/leonardo.todisco%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/a.martinez.cutillas%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/leonardo.todisco%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/miguel.ortega%40upm.es> ;
    schema:name "Tipologia Estructural"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000373/2025-26/CB06> a ns1:Competency ;
    ns1:competencyCode "CB06" ;
    ns1:competencyDescription "Poseer y comprender conocimientos que aporten una base u oportunidad de ser originales en el desarrollo y/o aplicación de ideas, a menudo en un contexto de investigación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000373/2025-26/CB07> a ns1:Competency ;
    ns1:competencyCode "CB07" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en entornos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000373/2025-26/CB08> a ns1:Competency ;
    ns1:competencyCode "CB08" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de integrar conocimientos y enfrentarse a la complejidad de formular juicios a partir de una información que, siendo incompleta o limitada, incluya reflexiones sobre las responsabilidades sociales y éticas vinculadas a la aplicación de sus conocimientos y juicios"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000373/2025-26/CB10> a ns1:Competency ;
    ns1:competencyCode "CB10" ;
    ns1:competencyDescription "Que los estudiantes posean las habilidades de aprendizaje que les permitan continuar estudiando de un modo que habrá de ser en gran medida autodirigido o autónomo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000373/2025-26/CE22> a ns1:Competency ;
    ns1:competencyCode "CE22" ;
    ns1:competencyDescription "Conocimiento y capacidad para el análisis estructural mediante la aplicación de los métodos y programas de diseño y cálculo avanzado de estructuras, a partir del conocimiento y comprensión de las solicitaciones y su aplicación a las tipologías estructurales de la ingeniería civil. Capacidad para realizar evaluaciones de integridad estructural."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000373/2025-26/CE23> a ns1:Competency ;
    ns1:competencyCode "CE23" ;
    ns1:competencyDescription "Conocimiento de todo tipo de estructuras y sus materiales, y capacidad para diseñar, proyectar, ejecutar y mantener las estructuras y edificaciones de obra civil."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000373/2025-26/CE37> a ns1:Competency ;
    ns1:competencyCode "CE37" ;
    ns1:competencyDescription "Capacidad para integrar y aplicar los conocimientos técnicos en asesoría, mantenimiento, conservación, evaluación técnica, explotación, evaluación histórico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000373/2025-26/CE38> a ns1:Competency ;
    ns1:competencyCode "CE38" ;
    ns1:competencyDescription "Capacidad para integrar y aplicar los conocimientos técnicos en asesoría, análisis, diseño y modelización físico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000373/2025-26/CE39> a ns1:Competency ;
    ns1:competencyCode "CE39" ;
    ns1:competencyDescription "Capacidad predictiva para optimización de soluciones en ingeniería estructural."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000373/2025-26/CGP01> a ns1:Competency ;
    ns1:competencyCode "CGP01" ;
    ns1:competencyDescription "Capacitación científico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000373/2025-26/CGP06> a ns1:Competency ;
    ns1:competencyCode "CGP06" ;
    ns1:competencyDescription "Conocimiento para aplicar las capacidades técnicas y gestoras en actividades de I+D+i dentro del ámbito de la ingeniería civil. Incorpora las competencias CB6, CB7 y CB8."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000373/2025-26/CGP11> a ns1:Competency ;
    ns1:competencyCode "CGP11" ;
    ns1:competencyDescription "Capacidad para el proyecto, ejecución e inspección de estructuras (puentes, edificaciones, etc.), de obras de cimentación y de obras subterráneas de uso civil (túneles, aparcamientos), y el diagnóstico sobre su integridad. Incorpora las competencias CB6, CB7 y CB8."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000373/2025-26/CT2> a ns1:Competency ;
    ns1:competencyCode "CT2" ;
    ns1:competencyDescription "Polivalencia y capacidad de aprendizaje autónomo. Desarrolla la competencia transversal 5ª del Real Decreto."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000373/2025-26/RA18> a ns1:LearningResult ;
    ns1:learningResultCode "RA18" ;
    ns1:learningResultDescription "Proyecta estructuras y planifica su ejecución, mantenimiento, y preservación de integridad aplicando modelos y criterios orientados a la optimización resistente, funcional y medioambiental."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000373/2025-26/RA223> a ns1:LearningResult ;
    ns1:learningResultCode "RA223" ;
    ns1:learningResultDescription "Desarrolla una síntesis del comportamiento estructural, con una prospectiva nueva, la del proyecto"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000373/2025-26/RA224> a ns1:LearningResult ;
    ns1:learningResultCode "RA224" ;
    ns1:learningResultDescription "Asume los principios del diseño estructural. Despierta una sensibilidad por la labor creativa"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000373/2025-26/RA247> a ns1:LearningResult ;
    ns1:learningResultCode "RA247" ;
    ns1:learningResultDescription "Identifica la relación entre forma estructural, distribución interna de esfuerzos y aprovechamiento de los materiales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000373/2025-26/RA248> a ns1:LearningResult ;
    ns1:learningResultCode "RA248" ;
    ns1:learningResultDescription "Identifica las propiedades de los materiales y conoce sus potenciales y límites en aplicaciones estructurales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000373/2025-26/RA249> a ns1:LearningResult ;
    ns1:learningResultCode "RA249" ;
    ns1:learningResultDescription "Cuestiona los conceptos de diseño estructural de referencias históricas y contemporánea de manera crítica"@es .

