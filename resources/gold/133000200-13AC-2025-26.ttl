    schema:name "Fundamentos de Mineria Urbana"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000200/2025-26/CB06> a ns1:Competency ;
    ns1:competencyCode "CB06" ;
    ns1:competencyDescription "Poseer y comprender conocimientos que aporten una base u oportunidad de ser originales en el desarrollo y/o aplicación de ideas, a menudo en un contexto de investigación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000200/2025-26/CB07> a ns1:Competency ;
    ns1:competencyCode "CB07" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en entornos nuevos o poco conocidos dentro de contextos más amplios (o multidisciplinares) relacionados con su área de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000200/2025-26/CB08> a ns1:Competency ;
    ns1:competencyCode "CB08" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de integrar conocimientos y enfrentarse a la complejidad de formular juicios a partir de una información que, siendo incompleta o limitada, incluya reflexiones sobre las responsabilidades sociales y éticas vinculadas a la aplicación de sus conocimientos y juicios"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000200/2025-26/CB10> a ns1:Competency ;
    ns1:competencyCode "CB10" ;
    ns1:competencyDescription "Que los estudiantes posean las habilidades de aprendizaje que les permitan continuar estudiando de un modo que habrá de ser en gran medida autodirigido o autónomo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000200/2025-26/CE03> a ns1:Competency ;
    ns1:competencyCode "CE03" ;
    ns1:competencyDescription "El alumno podrá planificar proyectos de economía circular referidos a la interacción entre actividades e industrias."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000200/2025-26/CE04> a ns1:Competency ;
    ns1:competencyCode "CE04" ;
    ns1:competencyDescription "El alumno conocerá las nuevas tecnologías de la industria 4.0 y desarrollará mejoras en el diseño de los productos industriales.en el marco de la economía circular"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000200/2025-26/CE09> a ns1:Competency ;
    ns1:competencyCode "CE09" ;
    ns1:competencyDescription "El alumno podrá evaluar los procesos de optimización energética en el campo de la economía circular"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000200/2025-26/CG03> a ns1:Competency ;
    ns1:competencyCode "CG03" ;
    ns1:competencyDescription "El alumno tendrá capacidad para evaluar los procesos de producción y consumo que permitan una gestión sostenible de los recursos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000200/2025-26/CG04> a ns1:Competency ;
    ns1:competencyCode "CG04" ;
    ns1:competencyDescription "El alumno podrá aplicar los principios de economía circular al ciclo de vida de los productos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000200/2025-26/CT01> a ns1:Competency ;
    ns1:competencyCode "CT01" ;
    ns1:competencyDescription "El alumno desarrollará habilidades para trabajar en contextos internacionales, respetando y considerando entornos socioculturales y científico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000200/2025-26/CT03> a ns1:Competency ;
    ns1:competencyCode "CT03" ;
    ns1:competencyDescription "El alumno tendrá capacidad para gestionar la información procedente de diversas fuentes, valorando su relevancia, fiabilidad y pertinencia para un propósito determinado, analizándola y organizándola."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000200/2025-26/CT04> a ns1:Competency ;
    ns1:competencyCode "CT04" ;
    ns1:competencyDescription "El alumno tendrá capacidad para proponer alternativas creativas y originales, valorando su viabilidad en la solución de problemas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000200/2025-26/CT07> a ns1:Competency ;
    ns1:competencyCode "CT07" ;
    ns1:competencyDescription "El alumno tendrá capacidad para utilizar la lengua inglesa para la comunicación oral y escrita a nivel avanzado en entornos académicos y profesionales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000200/2025-26/RA11> a ns1:LearningResult ;
    ns1:learningResultCode "RA11" ;
    ns1:learningResultDescription "Capacidad de gestionar de manera sostenibe los residuos municipales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000200/2025-26/RA32> a ns1:LearningResult ;
