<https://guia-kg.skai.etsisi.upm.es/resource/103000680/2025-26/CE13> a ns1:Competency ;
    ns1:competencyCode "CE13" ;
    ns1:competencyDescription "Tener una visión de los distintos aspectos específicos y emergentes de la ingeniería del software, y profundizar en algunos de ellos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000680/2025-26/CE14> a ns1:Competency ;
    ns1:competencyCode "CE14" ;
    ns1:competencyDescription "Comprender lo que pueden y no pueden conseguir las prácticas actuales de ingeniería del software, y sus limitaciones y su posible futura evolución."@es .

