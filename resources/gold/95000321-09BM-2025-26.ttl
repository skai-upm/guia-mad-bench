<https://guia-kg.skai.etsisi.upm.es/resource/95000321/2025-26/CE12> a ns1:Competency ;
    ns1:competencyCode "CE12" ;
    ns1:competencyDescription "Saber buscar, obtener e interpretar la información de las principales bases de datos biomédicas y bibliográficos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000321/2025-26/CE43> a ns1:Competency ;
    ns1:competencyCode "CE43" ;
    ns1:competencyDescription "Capacidad de análisis e interpretación de señales e imágenes biomédicas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000321/2025-26/CE49> a ns1:Competency ;
    ns1:competencyCode "CE49" ;
    ns1:competencyDescription "Conocer los sistemas fisiológicos y órganos humanos tanto a nivel estructural como funcional y sus patologías más relevantes."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000321/2025-26/CE52> a ns1:Competency ;
    ns1:competencyCode "CE52" ;
    ns1:competencyDescription "Comprender el funcionamiento de los diferentes órganos y sistemas del cuerpo humano y la regulación de sus funciones para el mantenimiento de la homeostasis."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000321/2025-26/CE53> a ns1:Competency ;
    ns1:competencyCode "CE53" ;
    ns1:competencyDescription "Conocer y comprender las modificaciones fisiológicas y morfológicas que los procesos patológicos más relevantes ocasionan en el organismo humano."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000321/2025-26/CE54> a ns1:Competency ;
    ns1:competencyCode "CE54" ;
    ns1:competencyDescription "Aplicar de manera fundamentada, crítica y argumentada los principios fisiológicos para contribuir al desarrollo tecnológico en el ámbito de la salud."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000321/2025-26/CG01> a ns1:Competency ;
    ns1:competencyCode "CG01" ;
    ns1:competencyDescription "Desarrollar las habilidades de aprendizaje necesarias para emprender actividades o estudios posteriores de forma autónoma y con confianza."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000321/2025-26/CG02> a ns1:Competency ;
    ns1:competencyCode "CG02" ;
    ns1:competencyDescription "Aplicar de forma profesional a su trabajo los conocimientos adquiridos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000321/2025-26/CG05> a ns1:Competency ;
    ns1:competencyCode "CG05" ;
    ns1:competencyDescription "Tener capacidad de análisis y síntesis, pensar de forma integrada, abordar los problemas desde diferentes perspectivas y estar siempre preparado para ¿to think out of the box¿"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000321/2025-26/CG06> a ns1:Competency ;
    ns1:competencyCode "CG06" ;
    ns1:competencyDescription "Adoptar una actitud ante los problemas de su competencia que considere que su papel no es exclusivamente aportar soluciones sino, siempre que sea posible, participar además en la propia identificación u definición de dichos problemas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000321/2025-26/CG11> a ns1:Competency ;
    ns1:competencyCode "CG11" ;
    ns1:competencyDescription "Elaborar y defender argumentos y resolver los problemas de forma efectiva y creativa."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000321/2025-26/CG12> a ns1:Competency ;
    ns1:competencyCode "CG12" ;
    ns1:competencyDescription "Tener capacidad de iniciativa, integración, colaboración y potenciación de la discusión crítica en el ámbito del trabajo en equipo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000321/2025-26/RA164> a ns1:LearningResult ;
    ns1:learningResultCode "RA164" ;
    ns1:learningResultDescription "Realizar búsquedas bibliográficas y extraer/analizar las conclusiones más importantes"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000321/2025-26/RA165> a ns1:LearningResult ;
    ns1:learningResultCode "RA165" ;
    ns1:learningResultDescription "Presentar de forma oral o escrita las conclusiones más relevantes de un trabajo de investigación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000321/2025-26/RA167> a ns1:LearningResult ;
    ns1:learningResultCode "RA167" ;
    ns1:learningResultDescription "Profundizar en el estudio de las patologías de los distintos órganos y sistemas de forma integrada. Comprender que una gran mayoría de las enfermedades humanas se deben a alteraciones de la homeostasis asociadas a la disfunción de varios órganos o/y sistemas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000321/2025-26/RA169> a ns1:LearningResult ;
    ns1:learningResultCode "RA169" ;
    ns1:learningResultDescription "Conocimiento de las consecuencias funcionales y morfológicas de la acción de los patógenos sobre la homeostasis."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000321/2025-26/RA17> a ns1:LearningResult ;
    ns1:learningResultCode "RA17" ;
    ns1:learningResultDescription "Capacidad para elaborar informes con el tratamiento y la interpretación adecuada de resultados experimentales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000321/2025-26/RA171> a ns1:LearningResult ;
    ns1:learningResultCode "RA171" ;
    ns1:learningResultDescription "Conocimientos de las alteraciones funcionales de los diferentes sistemas y aparatos más relevantes y de sus fundamentos para la mejor comprensión y profundización de las tecnologías como uno de los objetivos básicos del Ingeniero Biomédico. Desarrollo básico en el conocimiento de las alteraciones funcionales patológicas de cada uno de los sistemas estudiados. Descripción de casos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000321/2025-26/RA95> a ns1:LearningResult ;
    ns1:learningResultCode "RA95" ;
    ns1:learningResultDescription "Conocimientos básicos sobre el funcionamiento e interacción de los diferentes sistemas característicos de la fisiología humana."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000321/2025-26/RA96> a ns1:LearningResult ;
    ns1:learningResultCode "RA96" ;
    ns1:learningResultDescription "Identificar las funciones de los distintos sistemas fisiológicos y los mecanismos biológicos que permiten el mantenimiento de la homeostasis"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000321/2025-26/RA97> a ns1:LearningResult ;
    ns1:learningResultCode "RA97" ;
    ns1:learningResultDescription "Reconocer y distinguir los distintos órganos y sistemas del cuerpo humano para su identificación mediante distintos sistemas de imagen."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000321/2025-26/RA98> a ns1:LearningResult ;
    ns1:learningResultCode "RA98" ;
    ns1:learningResultDescription "Adquirir terminología propia de ciencias de la salud."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000321/2025-26/RA99> a ns1:LearningResult ;
    ns1:learningResultCode "RA99" ;
    ns1:learningResultDescription "Adquirir una participación creativa, como tecnólogos, en el análisis de los problemas biomédicos planteados con el fin de obtener resultados válidos en cuestiones multidisciplinares"@es .

