    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Fenomenología del vuelo del Helicóptero."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145014002/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Definición y tipos de AAR. Helicópteros, convertibles, compuestos y ala fija. Sin subniveles"@es .

