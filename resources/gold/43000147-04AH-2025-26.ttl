    schema:hasCourseInstance <https://guia-kg.skai.etsisi.upm.es/resource/43000147/2025-26> ;
    schema:name "Advanced Dam Engineering"@en,
        "Ingenieria Avanzada de Presas"@es ;
    schema:numberOfCredits 4.5 .

<https://guia-kg.skai.etsisi.upm.es/resource/43000147/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/43000147/2025-26/CB8>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000147/2025-26/CE> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/43000147/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000147/2025-26/didactic_resource/2> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/43000147/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/43000147/2025-26/RA103>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000147/2025-26/RA104>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000147/2025-26/RA105>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000147/2025-26/RA17>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000147/2025-26/RA33>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000147/2025-26/RA98> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/43000147/2025-26/syllabus> ;
    ns1:inpersonHours "51 horas (43.6%)"@es ;
    ns1:numberOfCredits 4.5 ;
    ns1:otherInformation "La asignatura se relaciona con el ODS 6."@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "79 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/43000147/2025-26/eventSchedule> ;
    schema:description """La asignatura es de carácter investigador, y está orientada hacia al campo de la ingeniería de presas.
El alumno desarrollará sus capacidades de investigación a través del desarrollo de un breve trabajo de investigación aplicada, que se decidirá en función de sus conocimientos previos e intereses. El tema del trabajo estará preferiblemente relacionado con las líneas de investigación de los profesores: aliviaderos, rotura de presas, análisis de la seguridad de presas, optimización de presas y aliviaderos.
El trabajo en el aula consistirá fundamentalmente en el trabajo colaborativo para el desarrollo de los diversos trabajos asignados.
Al finalizar la signatura, el alumno deberá ser capaz de plantear y desarrollar correctamente un trabajo de investigación, y deberá tener un conocimiento avanzado de los temas desarrollados en los trabajos de todos los alumnos y trabajados colaborativamente en las clases."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/miguelangel.toledo%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/miguelangel.toledo%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/r.moran%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/rafael.martinez%40upm.es> ;
    schema:name "Ingenieria Avanzada de Presas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000147/2025-26/CB8> a ns1:Competency ;
    ns1:competencyCode "CB8" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de integrar conocimientos y enfrentarse a la complejidad de formular juicios a partir de una información que, siendo incompleta o limitada, incluya reflexiones sobre las responsabilidades sociales y éticas vinculadas a la aplicación de sus conocimientos y juicios"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000147/2025-26/CE> a ns1:Competency ;
    ns1:competencyCode "CE" ;
    ns1:competencyDescription "A2"@es,
        "A4"@es,
        "A7"@es,
        "A8"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000147/2025-26/RA103> a ns1:LearningResult ;
    ns1:learningResultCode "RA103" ;
    ns1:learningResultDescription "Aplica técnicas de optimización a la resolución de problemas de sistemas de ingeniería civil"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000147/2025-26/RA104> a ns1:LearningResult ;
    ns1:learningResultCode "RA104" ;
    ns1:learningResultDescription "Plantear de forma metodológicamente correcta una investigación en el campo de la Ingeniería de Presas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000147/2025-26/RA105> a ns1:LearningResult ;
    ns1:learningResultCode "RA105" ;
    ns1:learningResultDescription "Adquirir conocimiento especializado en algún aspecto de la Ingeniería de Presas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000147/2025-26/RA17> a ns1:LearningResult ;
    ns1:learningResultCode "RA17" ;
    ns1:learningResultDescription "Hacer una presentación oral de sus conocimientos aplicados, mediante la resolución de casos prácticos individualmente y en grupo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000147/2025-26/RA33> a ns1:LearningResult ;
    ns1:learningResultCode "RA33" ;
    ns1:learningResultDescription "Comunicar las conclusiones de sus análisis, así como las razones últimas de los mismos, a públicos especializados y no especializados en materia territorial y ambiental"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000147/2025-26/RA98> a ns1:LearningResult ;
    ns1:learningResultCode "RA98" ;
    ns1:learningResultDescription "Capacidad de analizar los resultados y plantear futuros desarrollos de investigación"@es .

