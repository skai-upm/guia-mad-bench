<https://guia-kg.skai.etsisi.upm.es/resource/303000092/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Fourier series"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000092/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Trigonometric approximation of periodic functions. Fourier coefficients. Fourier series. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000092/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "3.3. Trigonometric interpolation via DFT. Sin subniveles"@es .

