    ns1:itemIndex 11 ;
    ns1:syllabusDescription "3.4. Applications of DFT: data compression, filtering of digital signals. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000092/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "4. Continuous Wavelet Transform (CWT)"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000092/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "4.1. Definition of Wavelet. Continuous Wavelet Transform. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000092/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "4.2. Multiresolution Analysis Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000092/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "4.3. Wavelet families: Haar wavelet and Daubechies wavelet Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000092/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "5. Discrete Wavelet Transform (DWT)"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000092/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "5.1. Definition of DWT. Mallat's algorithm. Sin subniveles"@es .

