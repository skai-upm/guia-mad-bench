    ns1:syllabusDescription "3.1. Definition of the DFT of a vector. Motivation from Fourier coefficients. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000092/2025-26/syllabus/9> a ns1:SyllabusItem ;
