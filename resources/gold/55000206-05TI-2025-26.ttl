<https://guia-kg.skai.etsisi.upm.es/resource/55000206/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. MODULO I (10h) Accionamientos eléctricos industriales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000206/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Introducción, definición, componentes y tipos de accionamientos eléctricos Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000206/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "2.3. Modelo de la M.A. en vectores espaciales Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000206/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "2.4. Sistemas de control vectorial clásicos Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000206/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "2.5. Control directo de par (DTC) Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000206/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "2.6. Aplicación industriales del control vectorial de una MA (generación eólica, control de tracción de VE, accionamientos de bombeo, etc) Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000206/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "3. MODULO III (28h) Control de accionamientos eléctricos con Máquinas Síncronas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000206/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "3.1. Modelo en vectores espaciales de la máquina síncrona. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000206/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "3.2. Esquemas de regulación para máquinas síncronas Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000206/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "3.3. Principios de funcionamiento y accionamiento de máquinas de reluctancia conmutada. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000206/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "3.4. Aplicación en accionamientos industriales de máquinas síncronas y máquinas de reluctancia conmutada (generación eólica, motores de tracción, etc). Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000206/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Reducción del mecanismo y del sistema de transmisión al eje del motor. Ejemplo de un accionamiento tipo Grúa. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000206/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "1.3. Características mecánicas de las máquinas eléctricas y de los mecanismos. Tipos de pares de resistencia. Punto de funcionamiento. Estabilidad. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000206/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "1.4. Regímenes de funcionamiento de las máquinas eléctricas. Análisis de los flujos de potencia mecánica y eléctrica. Evaluación de las pérdidas en el accionamiento a partir de la característica mecánica. Pérdidas en los transitorios. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000206/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "1.5. Modelos simplificados de las máquinas de corriente continua, asíncronas y síncronas. Análisis de los regímenes transitorios de aceleración y aplicación del par de carga. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000206/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "1.6. Oscilogramas y gráficos en las coordenadas velocidad-par para diferentes ciclos de trabajo de los distintos accionamientos eléctricos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000206/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "2. MODULO II (18h) Control vectorial de Máquinas Asíncronas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000206/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "2.1. Introducción. Repaso del Control escalar de un motor asíncrono Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000206/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "2.2. Introducción a los vectores espaciales Sin subniveles"@es .

