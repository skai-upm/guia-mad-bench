<https://guia-kg.skai.etsisi.upm.es/resource/143005029> a ns1:Course ;
    ns1:courseType "Optativa"@es ;
    ns1:courseYear 1 ;
    ns1:semester "Segundo semestre"@es ;
    schema:courseCode 143005029 ;
    schema:hasCourseInstance <https://guia-kg.skai.etsisi.upm.es/resource/143005029/2025-26> ;
    schema:name "Discrete Control Systems."@en,
        "Sistemas de Control Discreto"@es ;
    schema:numberOfCredits 5.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/143005029/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/143005029/2025-26/CG2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/143005029/2025-26/CG6> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/143005029/2025-26/didactic_resource/1> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/143005029/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/143005029/2025-26/RA130>,
        <https://guia-kg.skai.etsisi.upm.es/resource/143005029/2025-26/RA131>,
        <https://guia-kg.skai.etsisi.upm.es/resource/143005029/2025-26/RA132> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/143005029/2025-26/syllabus> ;
    ns1:inpersonHours "45 horas y 45 minutos (35.2%)"@es ;
    ns1:numberOfCredits 5.0 ;
    ns1:otherInformation "Entre los objetivos iniciales de la asignatura está el desarrollo de plantas (actuadores+sistemas+sensores) para su análisis y optimización energética."@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "45 horas y 45 minutos"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/143005029/2025-26/eventSchedule> ;
    schema:description """La asignatura se centra en el análisis de los sistemas realimentados en los que el algoritmo de control se ejecuta con un ordenador (microprocesador).
Discretizado el modelo lineal del sistema a controlar, se fijan los requisitos de comportamiento del sistema realimentado, y se comprueba su cumplimiento.
En el caso de que no se cumplan los requisitos, se diseña un compensador o controlador discreto que obligue a que el sistema realimentado se comporte, en el dominio del tiempo y en el dominio de la frecuencia, según los requisitos exigidos."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/mariano.asensio%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/mariano.asensio%40upm.es> ;
    schema:name "Sistemas de Control Discreto"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005029/2025-26/CG2> a ns1:Competency ;
    ns1:competencyCode "CG2" ;
    ns1:competencyDescription "Aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en los entornos de evolución previstos en los Sistemas de Transporte Aéreo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005029/2025-26/CG6> a ns1:Competency ;
    ns1:competencyCode "CG6" ;
    ns1:competencyDescription "Que los estudiantes posean las habilidades de aprendizaje que les permitan continuar estudiando de un modo que habrá de ser en gran medida autodirigido o autónomo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005029/2025-26/RA130> a ns1:LearningResult ;
    ns1:learningResultCode "RA130" ;
    ns1:learningResultDescription "El alumno conoce, comprende los modelos matemáticos de aeronaves"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005029/2025-26/RA131> a ns1:LearningResult ;
    ns1:learningResultCode "RA131" ;
    ns1:learningResultDescription "El alumno posee la capacidad de analizar la estabilidad de un sistema de vuelo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005029/2025-26/RA132> a ns1:LearningResult ;
    ns1:learningResultCode "RA132" ;
    ns1:learningResultDescription "El alumno alcanza a conocer el procedimiento de diseño de un sistema de control aplicado a aeronaves"@es .

