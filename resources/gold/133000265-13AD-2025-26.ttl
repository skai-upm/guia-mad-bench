<https://guia-kg.skai.etsisi.upm.es/resource/133000265/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. 1.- Modelos dinámicos de población de fauna. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000265/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "2. 2.- Sistema regulatorio y normativo de las explotaciones de recursos naturales vinculados a la fauna cinegética. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000265/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "11. 11.- Mediciones y presupuestos de obras de ejecución. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000265/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "12. 12.- Procedimiento de licitación, ejecución de infraestructuras. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000265/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "13. 13.- Capturaderos, captación de aguas y abrevaderos, mallados y elementos de contención territorial, observacíon, elementos constructivos de apoyo, jaulas de cría y control, Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000265/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "14. 14.- Análisis económico de explotaciones y balances anuales. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000265/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "15. 15.- Modelos administrativos de control de las explotaciones y memorias prurianuales de planificación. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000265/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "16. 16.- Industria y servicios derivados de la actividad. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000265/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "3. 3.- Análisis de las estabilidad, sostenibilidad rendimientos y cuantificación de la explotabilidad. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000265/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "4. 4.- Control de fauna, control de la dinámica de poblaciones. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000265/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "5. 5.- Sistemas de protección, umbrales de defensa ecológica de especies vulnerables y control de competencias. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000265/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "6. 6.- Capacidades de carga, conceptos y consecuencias en la gestión de poblaciones. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000265/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "7. 7.- Sistemas de captura cinegéticos y de control. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000265/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "8. 8.- Planificación de explotaciones de gestión cinegética. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000265/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "9. 9.- Infraestructuras de explotaciones de control cinegético y de fauna. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000265/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "10. 10.- Dimensionamiento y proyectos de infraestructuras. Sin subniveles"@es .

