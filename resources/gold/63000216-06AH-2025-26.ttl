    ns1:learningResultCode "RA100" ;
    ns1:learningResultDescription "Conocer el problema energético e impacto medioambiental de los distintos modos de transporte"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000216/2025-26/RA101> a ns1:LearningResult ;
    ns1:learningResultCode "RA101" ;
    ns1:learningResultDescription "Aprender sobre las técnicas actuales para la reducción del consumo y de emisiones contaminantes"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000216/2025-26/RA102> a ns1:LearningResult ;
    ns1:learningResultCode "RA102" ;
    ns1:learningResultDescription "Aprender las herramientas de cálculo de las prestaciones de un vehículo que influyen sobre el consumo de energía"@es .

