    schema:name "Financial Mathematics"@en,
        "Matemáticas Financieras"@es ;
    schema:numberOfCredits 3.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/55000681/2025-26> a ns1:CourseGuide ;
