<https://guia-kg.skai.etsisi.upm.es/resource/95000009/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Introducción a la Electrónica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000009/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Repaso de conocimientos previos recomendados Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000009/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "3.1. Introducción. Regímenes de funcionamiento. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000009/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "3.2. El diodo en cuasi-estática. Ecuación de Shockley. Curva característica. Estados del diodo. Descripción cualitativa de su funcionamiento interno. Modificaciones de la ecuación de Shockley. Disrupción de la unión Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000009/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "3.3. Modelos aproximados del diodo en cuasi-estática y gran señal. Ilustración de la dificultad del análisis analítico con el modelo de Shockley. Análisis de circuitos mediante hipótesis-verificación, y cálculo de funciones de transferencia. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000009/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "3.4. Modelo aproximado del diodo en cuasi-estática (baja frecuencia) y pequeña señal. Análisis de circuitos mediante descomposición en polarización y pequeña señal. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000009/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "3.5. El diodo en dinámica. Modelo aproximado en pequeña señal y alta frecuencia. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000009/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "3.6. Otros diodos (varicap, túnel, zener, Schottky) Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000009/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "3.7. Ejemplos de circuitos con diodos Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000009/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "4. El transistor bipolar"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000009/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "4.1. Introducción y tipos (npn, pnp). Convenios de signos. Descripción cualitativa de su funcionamiento interno. Regímenes de funcionamiento. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000009/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "4.2. El transistor bipolar (BJT) en cuasi-estática. Estados del transistor bipolar. Ecuaciones de Ebers-Moll. Curvas características como cuadripolo en emisor común. Modificaciones de las ecuaciones de Ebers-Moll. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000009/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Introducción a la Electrónica. Señales analógicas y digitales. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000009/2025-26/syllabus/20> a ns1:SyllabusItem ;
    ns1:itemIndex 20 ;
    ns1:syllabusDescription "4.3. Modelos aproximados del BJT en cuasi-estática y gran señal. Análisis de circuitos mediante procesos de hipótesis-verificación, incluyendo el cálculo de funciones de transferencia. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000009/2025-26/syllabus/21> a ns1:SyllabusItem ;
    ns1:itemIndex 21 ;
    ns1:syllabusDescription "4.4. Modelos aproximados del BJT en cuasi-estática (baja frecuencia) y pequeña señal. Análisis de circuitos mediante descomposición en polarización y pequeña señal Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000009/2025-26/syllabus/22> a ns1:SyllabusItem ;
    ns1:itemIndex 22 ;
    ns1:syllabusDescription "4.5. El BJT en dinámica. Modelo aproximado en pequeña señal y alta frecuencia. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000009/2025-26/syllabus/23> a ns1:SyllabusItem ;
    ns1:itemIndex 23 ;
    ns1:syllabusDescription "4.6. Ejemplos de circuitos con BJTs Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000009/2025-26/syllabus/24> a ns1:SyllabusItem ;
    ns1:itemIndex 24 ;
    ns1:syllabusDescription "5. Transistores de efecto de campo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000009/2025-26/syllabus/25> a ns1:SyllabusItem ;
    ns1:itemIndex 25 ;
    ns1:syllabusDescription "5.1. Introducción y tipos (canal n, canal p). Convenios de signos. Similitud con el transistor bipolar. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000009/2025-26/syllabus/26> a ns1:SyllabusItem ;
    ns1:itemIndex 26 ;
    ns1:syllabusDescription "5.2. El MOSFET y el JFET. Descripción cualitativa de su funcionamiento interno. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000009/2025-26/syllabus/27> a ns1:SyllabusItem ;
    ns1:itemIndex 27 ;
    ns1:syllabusDescription "5.3. Los FET en cuasi-estática. Estados y ecuaciones cuadráticas. Curvas características como cuadripolo en fuente común. Modificaciones de las ecuaciones de los FET. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000009/2025-26/syllabus/28> a ns1:SyllabusItem ;
    ns1:itemIndex 28 ;
    ns1:syllabusDescription "5.4. Análisis de circuitos con FETs en cuasi-estática y gran señal mediante procesos de hipótesis-verificación, incluyendo el cálculo de funciones de transferencia. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000009/2025-26/syllabus/29> a ns1:SyllabusItem ;
    ns1:itemIndex 29 ;
    ns1:syllabusDescription "5.5. Modelos aproximados de los FET en cuasi-estática (baja frecuencia) y pequeña señal. Análisis de circuitos mediante descomposición en polarización y pequeña señal Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000009/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "1.3. Introducción a los semiconductores. Breves nociones de tecnología. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000009/2025-26/syllabus/30> a ns1:SyllabusItem ;
    ns1:itemIndex 30 ;
    ns1:syllabusDescription "5.6. Los FET en dinámica. Modelo aproximado en pequeña señal y alta frecuencia. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000009/2025-26/syllabus/31> a ns1:SyllabusItem ;
    ns1:itemIndex 31 ;
    ns1:syllabusDescription "5.7. Ejemplos de circuitos con FETs Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000009/2025-26/syllabus/32> a ns1:SyllabusItem ;
    ns1:itemIndex 32 ;
    ns1:syllabusDescription "6. Dispositivos optoelectrónicos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000009/2025-26/syllabus/33> a ns1:SyllabusItem ;
    ns1:itemIndex 33 ;
    ns1:syllabusDescription "6.1. Interacción entre los semiconductores y la luz. Absorción de luz con generación luminosa de pares electrón-hueco. Generación de luz por recombinación radiativa de pares electrón-hueco. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000009/2025-26/syllabus/34> a ns1:SyllabusItem ;
    ns1:itemIndex 34 ;
    ns1:syllabusDescription "6.2. Modulación de la conductividad del semiconductor. Fotorresistencias Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000009/2025-26/syllabus/35> a ns1:SyllabusItem ;
    ns1:itemIndex 35 ;
    ns1:syllabusDescription "6.3. Fotodiodos. Circuito equivalente y aplicaciones. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000009/2025-26/syllabus/36> a ns1:SyllabusItem ;
    ns1:itemIndex 36 ;
    ns1:syllabusDescription "6.4. Diodos emisores de luz. Emisión espontánea y estimulada. Diodos LED y láser. Aplicaciones. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000009/2025-26/syllabus/37> a ns1:SyllabusItem ;
    ns1:itemIndex 37 ;
    ns1:syllabusDescription "6.5. La célula solar. Circuito equivalente y parámetros de calidad. Descripción del estado del arte. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000009/2025-26/syllabus/38> a ns1:SyllabusItem ;
    ns1:itemIndex 38 ;
    ns1:syllabusDescription "6.6. El fototransistor. Circuito equivalente y aplicaciones. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000009/2025-26/syllabus/39> a ns1:SyllabusItem ;
    ns1:itemIndex 39 ;
    ns1:syllabusDescription "7. Introducción a los circuitos de conmutación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000009/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "2. Componentes electrónicos básicos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000009/2025-26/syllabus/40> a ns1:SyllabusItem ;
    ns1:itemIndex 40 ;
    ns1:syllabusDescription "7.1. Introducción. Conmutación cuasi-estática y dinámica Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000009/2025-26/syllabus/41> a ns1:SyllabusItem ;
    ns1:itemIndex 41 ;
    ns1:syllabusDescription "7.2. Circuitos conformadores de onda con diodos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000009/2025-26/syllabus/42> a ns1:SyllabusItem ;
    ns1:itemIndex 42 ;
    ns1:syllabusDescription "7.3. Circuitos de conmutación con diodos y condensadores. Cálculo de tiempos de retardo. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000009/2025-26/syllabus/43> a ns1:SyllabusItem ;
    ns1:itemIndex 43 ;
    ns1:syllabusDescription "7.4. Introducción a los circuitos digitales. Circuitos combinacionales. Ejemplos de puertas lógicas. Circuitos secuenciales. Ejemplo de celda biestable. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000009/2025-26/syllabus/44> a ns1:SyllabusItem ;
    ns1:itemIndex 44 ;
    ns1:syllabusDescription "7.5. Familias lógicas bipolares y MOS. Visualización de los transistores como interruptores controlados. Introducción a las puertas básicas NMOS y CMOS. Análisis en cuasi.-estatica y gran señal de la función de transferencia de inversores. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000009/2025-26/syllabus/45> a ns1:SyllabusItem ;
    ns1:itemIndex 45 ;
    ns1:syllabusDescription "7.6. Conmutación cuasi-estática de transistores concargas capacitivas. Cálculo de tiempos de retardo. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000009/2025-26/syllabus/46> a ns1:SyllabusItem ;
    ns1:itemIndex 46 ;
    ns1:syllabusDescription "8. Aplicaciones de la Electrónica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000009/2025-26/syllabus/47> a ns1:SyllabusItem ;
    ns1:itemIndex 47 ;
    ns1:syllabusDescription "8.1. Breve historia de la Electrónica. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000009/2025-26/syllabus/48> a ns1:SyllabusItem ;
    ns1:itemIndex 48 ;
    ns1:syllabusDescription "8.2. Aplicaciones de la Electrónica. El mercado de la Electrónica. Previsiones de futuro. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000009/2025-26/syllabus/49> a ns1:SyllabusItem ;
    ns1:itemIndex 49 ;
    ns1:syllabusDescription "8.3. Electrónica en la Ingeniería de Telecomunicación Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000009/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "2.1. Introducción a las técnicas de análisis de circuitos. Definiciones, notaciones y convenios de signos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000009/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "2.2. Componentes de dos terminales. Curva característica. Ejemplos. Componentes activos y pasivos. Componentes lineales. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000009/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "2.3. Disipación del calor de circuitos electrónicos. Nociones sobre diseño y análisis térmico. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000009/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "2.4. Componentes reales. Tolerancias y sensibilidad Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000009/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "3. El diodo"@es .

