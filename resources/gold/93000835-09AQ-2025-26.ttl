    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/93000835/2025-26/eventSchedule> ;
    schema:description """La asignatura Diseño Microelectrónico persigue el objetivo de formar a los alumnos del itinerario de Electrónica en el diseño full-custom de circuitos integrados VLSI. Esta asignatura proporciona un puente entre el diseño de sistemas y las tecnologías, procesos y dispositivos, planteando los requerimientos de los circuitos y sistemas que hacen uso de dichas tecnologías.
Esta asignatura proporciona a los futuros diseñadores de sistemas hardware una visión que cubre desde los aspectos de diseño de sistemas hasta los de trazado físico, pasando por sus circuitos y bloques componentes, fundamentalmente centrados en tecnología CMOS, que es la más utilizada hoy en día para el diseño de circuitos de aplicación. Se asegurará también una introducción básica a las estructuras y procesos tecnológicos necesarios en la labor de diseño de circuitos integrados.

La asignatura se organiza en clases teóricas que se complementan con sesiones prácticas de diseño de circuitos con herramientas profesionales."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/m.lopez.vallejo%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/amadeo.degracia%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/m.lopez.vallejo%40upm.es> ;
    schema:name "Diseño Microelectronico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000835/2025-26/CE10> a ns1:Competency ;
    ns1:competencyCode "CE10" ;
    ns1:competencyDescription "Capacidad para diseñar y fabricar circuitos integrados."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000835/2025-26/CE11> a ns1:Competency ;
    ns1:competencyCode "CE11" ;
    ns1:competencyDescription "Conocimiento de los lenguajes de descripción hardware para circuitos de alta complejidad."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000835/2025-26/CE12> a ns1:Competency ;
    ns1:competencyCode "CE12" ;
    ns1:competencyDescription "Capacidad para utilizar dispositivos lógicos programables, así como para diseñar sistemas electrónicos avanzados, tanto analógicos como digitales. Capacidad para diseñar componentes de comunicaciones como por ejemplo encaminadores, conmutadores, concentradores, emisores y receptores en diferentes bandas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000835/2025-26/CT3> a ns1:Competency ;
    ns1:competencyCode "CT3" ;
    ns1:competencyDescription "Capacidad para adoptar soluciones creativas que satisfagan adecuadamente las diferentes necesidades planteadas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000835/2025-26/CT4> a ns1:Competency ;
    ns1:competencyCode "CT4" ;
    ns1:competencyDescription "Capacidad para trabajar de forma efectiva como individuo, organizando y planificando su propio trabajo, de forma independiente o como miembro de un equipo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000835/2025-26/CT5> a ns1:Competency ;
    ns1:competencyCode "CT5" ;
    ns1:competencyDescription "Capacidad para gestionar la información, identificando las fuentes necesarias, los principales tipos de documentos técnicos y científicos, de una manera adecuada y eficiente."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000835/2025-26/RA87> a ns1:LearningResult ;
    ns1:learningResultCode "RA87" ;
    ns1:learningResultDescription "Comprender cómo distintas alternativas de diseño para un circuito integrado CMOS afectan a su área, velocidad, consumo de potencia, fiabilidad y coste."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000835/2025-26/RA88> a ns1:LearningResult ;
    ns1:learningResultCode "RA88" ;
    ns1:learningResultDescription "Ser capaz de tomar decisiones de diseño para un circuito integrado CMOS, verificando su impacto mediante simulación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000835/2025-26/RA89> a ns1:LearningResult ;
    ns1:learningResultCode "RA89" ;
    ns1:learningResultDescription "Conocer las opciones en el diseño de circuitos integrados de bloques combinacionales, secuenciales, rutas de datos, memorias y circuitos de propósito especiales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000835/2025-26/RA9> a ns1:LearningResult ;
    ns1:learningResultCode "RA9" ;
    ns1:learningResultDescription "Saber redactar informes técnicos sobre trabajos realizados, con una estructura, contenidos y lenguaje del nivel adecuado a un trabajo de ingeniería"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000835/2025-26/RA92> a ns1:LearningResult ;
    ns1:learningResultCode "RA92" ;
    ns1:learningResultDescription "Conocimiento práctico de métodos modernos de diseño y herramientas básicas para el diseño full"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000835/2025-26/RA93> a ns1:LearningResult ;
    ns1:learningResultCode "RA93" ;
    ns1:learningResultDescription "Conocimiento práctico de métodos modernos de diseño y herramientas básicas para el diseño con células estándar y FPGA."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000835/2025-26/RA94> a ns1:LearningResult ;
    ns1:learningResultCode "RA94" ;
    ns1:learningResultDescription "Diseñar, verificar y caracterizar un circuito integrado CMOS a partir de una especificación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000835/2025-26/didactic_resource/1> a ns1:DidacticResource ;
    ns1:bibliographyTitle "CMOS VLSI Design: A circuits and Systems Perspective N. Weste, D. Harris (Libro de referencia). Pearson Addison Wesley 2005."@es ;
    ns1:bibliographyType "Bibliografía"@es .

