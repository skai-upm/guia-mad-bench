        <https://guia-kg.skai.etsisi.upm.es/resource/565000514/2025-26/syllabus/6>,
        <https://guia-kg.skai.etsisi.upm.es/resource/565000514/2025-26/syllabus/7>,
        <https://guia-kg.skai.etsisi.upm.es/resource/565000514/2025-26/syllabus/8>,
        <https://guia-kg.skai.etsisi.upm.es/resource/565000514/2025-26/syllabus/9> .

<https://guia-kg.skai.etsisi.upm.es/resource/565000514/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Introducción a la Química. Estequiometría (5 horas)"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000514/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. El lenguaje de la Química. Estequiometría de las reacciones químicas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000514/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "2.3.3. Enlace metálico. Conductores, aislantes y semiconductores. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000514/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "2.3.4. Fuerzas intermoleculares: Fuerzas de van der Waals. Puente de hidrógeno. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000514/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "3. Estados de agregación de la materia (5 horas)"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000514/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "3.1. Gases reales. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000514/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "3.2. Sólidos: Sólidos cristalinos y amorfos. Clasificación de los sólidos según el tipo de enlace. Sólidos reales. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000514/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "3.3. Líquidos: Tensión superficial. Viscosidad. Evaporación y presión de vapor. Líquidos reales. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000514/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "3.4. Cambios de estado: Curvas de calentamiento y de enfriamiento. Equilibrios de fases. Diagramas de fases. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000514/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "3.5. Disoluciones: Solubilidad. Purificación de sustancias. Propiedades coligativas de las disoluciones. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000514/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "4. Fundamentos de la reacción química. Aplicaciones (40 horas)"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000514/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "4.1. Energía de las reacciones químicas. Transformaciones a presión y a volumen constante. Calorimetría. Termoquímica. Ley de Hess. Energías de enlace. Entropía, Energía libre y Cambio espontáneo. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000514/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Gases ideales. Mezclas de gases. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000514/2025-26/syllabus/20> a ns1:SyllabusItem ;
    ns1:itemIndex 20 ;
    ns1:syllabusDescription "4.2. Equilibrio químico: Constante de equilibrio. Factores que afectan al equilibrio químico. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000514/2025-26/syllabus/21> a ns1:SyllabusItem ;
    ns1:itemIndex 21 ;
    ns1:syllabusDescription "4.3. Cinética química: Velocidad y mecanismo de las reacciones químicas. Factores que influyen en la velocidad de reacción. Ecuación de velocidad. Determinación de leyes de velocidad. Catálisis. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000514/2025-26/syllabus/22> a ns1:SyllabusItem ;
    ns1:itemIndex 22 ;
    ns1:syllabusDescription "4.4. Equilibrios ácido-base: Teorías ácido-base. Constante de ionización. Concepto y cálculo del pH. Hidrólisis. Disoluciones amortiguadoras. Indicadores. Volumetrías de neutralización. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000514/2025-26/syllabus/23> a ns1:SyllabusItem ;
    ns1:itemIndex 23 ;
    ns1:syllabusDescription "4.5. Equilibrios de solubilidad: Producto de solubilidad. Factores que influyen en la solubilidad de los compuestos iónicos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000514/2025-26/syllabus/24> a ns1:SyllabusItem ;
    ns1:itemIndex 24 ;
    ns1:syllabusDescription "4.6. Reacciones de oxidación-reducción. Electroquímica: Ecuaciones redox. Volumetrías redox. Pilas galvánicas. Potencial normal. Espontaneidad. Ecuación de Nernst. Equilibrios en reacciones redox. Tipos de pilas. Electrólisis. Corrosión y protección. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000514/2025-26/syllabus/25> a ns1:SyllabusItem ;
    ns1:itemIndex 25 ;
    ns1:syllabusDescription "5. Temario experimental de Laboratorio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000514/2025-26/syllabus/26> a ns1:SyllabusItem ;
    ns1:itemIndex 26 ;
    ns1:syllabusDescription "5.1. (2 h) Conocimiento y manejo del material de Laboratorio. Normas de seguridad. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000514/2025-26/syllabus/27> a ns1:SyllabusItem ;
    ns1:itemIndex 27 ;
    ns1:syllabusDescription "5.2. (2 h) Métodos de separación. Preparación de disoluciones. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000514/2025-26/syllabus/28> a ns1:SyllabusItem ;
    ns1:itemIndex 28 ;
    ns1:syllabusDescription "5.3. (2 h) Calor de reacción. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000514/2025-26/syllabus/29> a ns1:SyllabusItem ;
    ns1:itemIndex 29 ;
    ns1:syllabusDescription "5.4. (2 h) Equilibrio químico y efecto de la temperatura en la cinética. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000514/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "1.3. Disoluciones. Formas de expresar la concentración de una disolución. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000514/2025-26/syllabus/30> a ns1:SyllabusItem ;
    ns1:itemIndex 30 ;
    ns1:syllabusDescription "5.5. (2 h) Cálculo de pH. Volumetrías. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000514/2025-26/syllabus/31> a ns1:SyllabusItem ;
    ns1:itemIndex 31 ;
    ns1:syllabusDescription "5.6. (2 h) Reacciones de oxidación-reducción. Fenómenos electroquímicos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000514/2025-26/syllabus/32> a ns1:SyllabusItem ;
    ns1:itemIndex 32 ;
    ns1:syllabusDescription "5.7. (2 h) Ensayos de corrosión y protección catódica del hierro. Examen de laboratorio. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000514/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "2. Estructura de la materia (10 horas)"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000514/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "2.1. Estructura atómica. Principios básicos de Mecánica Cuántica. Configuraciones electrónicas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000514/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "2.2. Clasificación periódica de los elementos. Propiedades periódicas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000514/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "2.3. Enlace químico: Naturaleza del enlace químico."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000514/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "2.3.1. Enlace iónico: Energía reticular. Estabilidad de compuestos iónicos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000514/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "2.3.2. Enlace covalente. Geometrías de moléculas e iones moleculares. Sin subniveles"@es .

