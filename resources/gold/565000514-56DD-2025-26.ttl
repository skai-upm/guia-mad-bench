<https://guia-kg.skai.etsisi.upm.es/resource/565000514/2025-26/H.7.> a ns1:Competency ;
    ns1:competencyCode "H.7." ;
    ns1:competencyDescription "Analizar productos, procesos y sistemas complejos en su campo de estudio; elegir y aplicar de forma pertinente métodos analíticos, de cálculo y experimentales ya establecidos e interpretar correctamente resultados de dichos análisis. TIPO: Habilidades o destrezas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000514/2025-26/H.8.> a ns1:Competency ;
    ns1:competencyCode "H.8." ;
    ns1:competencyDescription "Identificar, formular y resolver problemas de ingeniería en su especialidad; elegir y aplicar de forma adecuada métodos analíticos, de cálculo y experimentales ya establecidos; reconocer la importancia de las restricciones sociales, de salud y seguridad, ambientales, económicas e industriales. TIPO: Habilidades o destrezas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000514/2025-26/H.9.> a ns1:Competency ;
    ns1:competencyCode "H.9." ;
    ns1:competencyDescription "Proyectar, diseñar y desarrollar productos complejos (piezas, componentes, productos acabados, etc.), procesos y sistemas de su especialidad, que cumplan con los requisitos establecidos, incluyendo tener conciencia de los aspectos sociales, de salud y seguridad, ambientales, económicos e industriales; así como seleccionar y aplicar métodos de proyecto apropiados, utilizando algún conocimiento de vanguardia cuando sea adecuado. TIPO: Habilidades o destrezas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000514/2025-26/RA94> a ns1:LearningResult ;
    ns1:learningResultCode "RA94" ;
    ns1:learningResultDescription "Capacidad para conocer, entender y utilizar los principios de Química general."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000514/2025-26/RA95> a ns1:LearningResult ;
    ns1:learningResultCode "RA95" ;
    ns1:learningResultDescription "Capacidad para el trabajo en el laboratorio químico, trasladando los conocimientos teóricos al laboratorio y relacionando los contenidos con el mundo real."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000514/2025-26/RA96> a ns1:LearningResult ;
    ns1:learningResultCode "RA96" ;
    ns1:learningResultDescription "Capacidad para manipular productos químicos con seguridad."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000514/2025-26/RA97> a ns1:LearningResult ;
    ns1:learningResultCode "RA97" ;
    ns1:learningResultDescription "Reconocer e implantar buenas prácticas de medida y experimentación."@es .

