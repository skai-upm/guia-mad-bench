        <https://guia-kg.skai.etsisi.upm.es/resource/563000136/2025-26/CG06>,
        <https://guia-kg.skai.etsisi.upm.es/resource/563000136/2025-26/CG07> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/563000136/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/563000136/2025-26/didactic_resource/2>,
