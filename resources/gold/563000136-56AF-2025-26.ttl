        <https://guia-kg.skai.etsisi.upm.es/resource/563000136/2025-26/didactic_resource/5>,
        <https://guia-kg.skai.etsisi.upm.es/resource/563000136/2025-26/didactic_resource/6>,
        <https://guia-kg.skai.etsisi.upm.es/resource/563000136/2025-26/didactic_resource/7> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/563000136/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/563000136/2025-26/RA71>,
        <https://guia-kg.skai.etsisi.upm.es/resource/563000136/2025-26/RA73>,
        <https://guia-kg.skai.etsisi.upm.es/resource/563000136/2025-26/RA74>,
        <https://guia-kg.skai.etsisi.upm.es/resource/563000136/2025-26/RA75>,
        <https://guia-kg.skai.etsisi.upm.es/resource/563000136/2025-26/RA76> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/563000136/2025-26/syllabus> ;
    ns1:inpersonHours "37 horas (47.4%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation """La docencia será presencial.
Esta asignatura tiene relación con el ODS 9 Industria Innovación e Infraestructura : Construir infraestructuras resilientes, promover la industrialización sostenible y fomentar la innovación.
Los resultados de aprendizaje obtenidos con la asignatura permiten realizar un diseño eficiente de nuestras uniones estructurales, lo que repercute en mejorar la sostenibilidad de las infraestructuras necesarias tanto en los países desarrollados como en aquellos en vías de expansión. El enfoque de las enseñanzas, desarrollando aspectos prácticos pero fundamentado en los conceptos teóricos del diseño de uniones, permite asumir nuevos retos que ofrezcan soluciones innovadoras a problemas futuros."""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "37 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/563000136/2025-26/eventSchedule> ;
    schema:description "En la asignatura se aborda el diseño y calculo de uniones estructurales y la inspección de las mismas."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/j.pecharroman%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/francisco.santos%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/j.pecharroman%40upm.es> ;
    schema:name "Diseño y Cálculo de Uniones Estructurales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000136/2025-26/CB07> a ns1:Competency ;
    ns1:competencyCode "CB07" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en entornos nuevos o poco conocidos dentro de contextos más amplios (o multidisciplinares) relacionados con su área de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000136/2025-26/CB10> a ns1:Competency ;
    ns1:competencyCode "CB10" ;
    ns1:competencyDescription "Que los estudiantes posean las habilidades de aprendizaje que les permitan continuar estudiando de un modo que habrá de ser en gran medida autodirigido o autónomo."@es .

