<https://guia-kg.skai.etsisi.upm.es/resource/135004101/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Moléculas, enlace e interacciones intermoleculares"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004101/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Estructura electrónica de átomos polielectrónicos. Propiedades periódicas. Introducción al enlace: tipos de enlace. Enlace iónico. Enlace covalente: orbitales moleculares. Moléculas diatómicas. Polaridad de enlace Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004101/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "3. Cinética Química"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004101/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "3.1. Introducción a la Cinética Química: velocidad de reacción. Orden de reacción y ecuaciones de velocidad. Método de las velocidades iniciales de reacción. Ecuaciones integradas de velocidad Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004101/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "3.2. Mecanismos de reacción. Aproximación de la etapa limitante. Aproximación del estado estacionario Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004101/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "3.3. Velocidad de reacción y temperatura: ecuación de Arrhenius. Teoría de colisiones. Catálisis Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004101/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "4. Gases, liquidos y disoluciones"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004101/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "4.1. Leyes de los gases. Velocidades moleculares: distribución de Maxwell-Boltzmann Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004101/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "4.2. Equilibrio de fases. Equilibrio líquido-vapor: evaporación, presión de vapor. Variación de la presión de vapor con la temperatura: ebullición. Diagrama de fases Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004101/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "4.3. Disoluciones: unidades de concentración Disoluciones ideales: ley de Raoult. Propiedades coligativas Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004101/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "5. Equilibrio químico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004101/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "5.1. Efectos externos sobre el equilibrio Principio de Le Chatelier. Variación de la constante de equilibrio con la temperatura Sin subniveles"@es .

