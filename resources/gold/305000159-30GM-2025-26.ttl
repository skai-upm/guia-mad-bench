    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/305000159/2025-26/eventSchedule> ;
    schema:description """En este curso se presentan las herramientas necesarias, tanto analíticas como algebraicas, para trabajar con variedades, como por ejemplo campos vectoriales y formas. Las variedades diferenciables se pueden ver como una generalización de curvas y superficies proporcionando el contexto matemáticos para comprender el espacio en sus distintas manifestaciones. Actualmente el cálculo sobre las variedades diferenciables además de ser indispensable en la mayoría de las principales ramas de las matemáticas más teórica, adquiere cada vez mayor importancia en campos tan diversos como la genética, robótica, imagen biomédica y, por su puesto, física teórica.
Este curso es una introducción a los fundamentos de la geometría diferencial y se tratará de trabajar sin coordenadas. Las fórmulas en coordenadas se obtienen como información adicional. el temario del curso es el siguiente:
Variedades diferenciables
Variedades como subconjuntos de un espacio euclídeo
Variedades abstractas
Aplicaciones y funciones diferenciables
Valores y puntos críticos
Inmersiones, subvariedades, embebimientos, y difeomorfismos
Construcción de variedades por la imagen inversa. Teorema de la función implícita
Submersiones. Variedades cociente.
Foliaciones
El fibrado tangente
Campos vectoriales
Curvas integrales
Flujos
Transformación de campos vectoriales
Aplicación exponencial
Campos tensoriales y formas diferenciales
Formas diferenciales y campos tensoriales
Formas de volumen y orientación
Fibrados vectoriales
Álgebra exterior y tensorial. Campos tensoriales
Formas diferenciales y producto exterior
Distribuciones y variedades integrales. Teorema de Frobenius. Ideales diferenciales.
Integración en variedades
Variedades orientables. Aplicaciones que preservan la orientación
Integración sobre variedades. Teorema de Stokes
Cohomología de de Rham
Fibrados vectoriales
Fibrados vectoriales y pullback de fibrados vectoriales
Conexión lineal y transporte paralelo
Torsión y curvatura
Geodésicas"""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/eugenia.rosado%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/eugenia.rosado%40upm.es> ;
    schema:name "Geometría Diferencial"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000159/2025-26/CE1> a ns1:Competency ;
    ns1:competencyCode "CE1" ;
    ns1:competencyDescription "Comprender y utilizar el lenguaje matemático. Adquirir la capacidad para enunciar propiedades en distintos campos de la Matemática, para construir argumentaciones, elaborar cálculos y para transmitir los conocimientos matemáticos adquiridos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000159/2025-26/CE2> a ns1:Competency ;
    ns1:competencyCode "CE2" ;
    ns1:competencyDescription "Conocer y comprender demostraciones rigurosas de los principales teoremas de cada área de la Matemática y extraer de ellos corolarios mediante la particularización a casos concretos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000159/2025-26/CE3> a ns1:Competency ;
    ns1:competencyCode "CE3" ;
    ns1:competencyDescription "Asimilar la definición de un nuevo objeto matemático, en términos de otros ya conocidos, y ser capaz de utilizar este objeto en diferentes contextos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000159/2025-26/CE4> a ns1:Competency ;
    ns1:competencyCode "CE4" ;
    ns1:competencyDescription "Abstraer las propiedades estructurales de objetos matemáticos, de la realidad observada o de otros ámbitos distinguiéndolas de aquellas puramente ocasionales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000159/2025-26/CE5> a ns1:Competency ;
    ns1:competencyCode "CE5" ;
    ns1:competencyDescription "Comprobar con demostraciones hipótesis sobre un objeto matemático o refutarlas con contraejemplos, así como identificar errores en razonamientos incorrectos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000159/2025-26/CE7> a ns1:Competency ;
    ns1:competencyCode "CE7" ;
    ns1:competencyDescription "Resolver problemas de Matemáticas, mediante habilidades de cálculo básico y tecnologías de computación, planificando su resolución en función de las herramientas de que se disponga y de las restricciones de tiempo y recursos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000159/2025-26/CE8> a ns1:Competency ;
    ns1:competencyCode "CE8" ;
    ns1:competencyDescription "Utilizar aplicaciones informáticas de análisis estadístico, cálculo numérico y simbólico, visualización gráfica, optimización u otras para experimentar en Matemáticas, buscar soluciones y resolver modelos matemáticos de sistemas reales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000159/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Identificar la naturaleza, métodos y fines de los distintos campos de la Matemática y asociarlos con cierta perspectiva histórica de su desarrollo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000159/2025-26/CG2> a ns1:Competency ;
    ns1:competencyCode "CG2" ;
    ns1:competencyDescription "Reconocer la presencia de la Matemática subyacente en la Naturaleza, en la Ciencia, en la Tecnología y en el Arte. Reconocer a la Matemática como parte integrante de la Educación y la Cultura."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000159/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Utilizar las capacidades analíticas y de abstracción, la intuición y el pensamiento lógico y riguroso desarrolladas a través del estudio de la Matemática en contextos tanto matemáticos como no matemáticos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000159/2025-26/CG4> a ns1:Competency ;
    ns1:competencyCode "CG4" ;
    ns1:competencyDescription "Utilizar los conocimientos teóricos y prácticos adquiridos en la definición y planteamiento de problemas y en la búsqueda de sus soluciones tanto en contextos académicos como profesionales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000159/2025-26/CG5> a ns1:Competency ;
    ns1:competencyCode "CG5" ;
    ns1:competencyDescription "Sintetizar conocimientos y habilidades adquiridas en el campo de la matemática en diferentes materias del plan de estudios para enfocarlas en posteriores estudios especializados, tanto en una disciplina matemática como en cualquiera de las ciencias que requieran buenos fundamentos matemáticos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000159/2025-26/RA189> a ns1:LearningResult ;
    ns1:learningResultCode "RA189" ;
    ns1:learningResultDescription "Distinguir entre nociones local y global, intrínseca y extrínseca."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000159/2025-26/RA214> a ns1:LearningResult ;
    ns1:learningResultCode "RA214" ;
    ns1:learningResultDescription "Distinguir las nociones de variedad topológica y variedad diferenciable"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000159/2025-26/RA215> a ns1:LearningResult ;
    ns1:learningResultCode "RA215" ;
    ns1:learningResultDescription "Distinguir las nociones de inmersión y submersión"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000159/2025-26/RA250> a ns1:LearningResult ;
    ns1:learningResultCode "RA250" ;
    ns1:learningResultDescription "Interpretar un campo tangente como flujo de la variedad"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000159/2025-26/RA251> a ns1:LearningResult ;
    ns1:learningResultCode "RA251" ;
    ns1:learningResultDescription "Distinguir y manejar correctamente la derivada covariante y la derivada de Lie"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000159/2025-26/RA253> a ns1:LearningResult ;
    ns1:learningResultCode "RA253" ;
    ns1:learningResultDescription "Aplicar los conocimientos aprendidos al estudio de variedades de curvatura constante"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000159/2025-26/RA255> a ns1:LearningResult ;
    ns1:learningResultCode "RA255" ;
    ns1:learningResultDescription "Manejar los teoremas de Stokes y Gauss"@es .

