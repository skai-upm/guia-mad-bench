    ns1:learningResultCode "RA103" ;
    ns1:learningResultDescription "Conocimiento de la configuración jurídica básica de la empresa y del empresario y estudio de las obligaciones y contratos con especial referencia a los contratos básicos del tráfico jurídico empresarial."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000101/2025-26/RA104> a ns1:LearningResult ;
