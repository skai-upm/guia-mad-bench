        <https://guia-kg.skai.etsisi.upm.es/resource/123000710/2025-26/C6>,
        <https://guia-kg.skai.etsisi.upm.es/resource/123000710/2025-26/C7>,
        <https://guia-kg.skai.etsisi.upm.es/resource/123000710/2025-26/K1>,
