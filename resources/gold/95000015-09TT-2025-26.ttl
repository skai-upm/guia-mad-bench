<https://guia-kg.skai.etsisi.upm.es/resource/95000015/2025-26/RA543> a ns1:LearningResult ;
    ns1:learningResultCode "RA543" ;
    ns1:learningResultDescription "Adquirir los conceptos fundamentales del análisis de señales y sistemas en el dominio temporal"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000015/2025-26/RA544> a ns1:LearningResult ;
    ns1:learningResultCode "RA544" ;
    ns1:learningResultDescription "Metodología de análisis de señales y sistemas en tiempo continuo utilizando las transformadas de Fourier y de Laplace"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000015/2025-26/RA545> a ns1:LearningResult ;
    ns1:learningResultCode "RA545" ;
    ns1:learningResultDescription "Metodología de análisis de señales y sistemas en tiempo discreto utilizando las transformadas de Fourier y Z."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000015/2025-26/RA546> a ns1:LearningResult ;
