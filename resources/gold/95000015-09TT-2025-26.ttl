    ns1:itemIndex 4 ;
    ns1:syllabusDescription "1.1.3. Señales básicas: sinusoidal, exponencial, impulso unitario, escalón, rampa / Basic signals: sinusoid, exponential, unit impulse, unit step, ramp Sin subniveles"@es .

