    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/145022004/2025-26/eventSchedule> ;
    schema:description """Asignatura de primer curso donde se definen los contenidos para que el alumno adquiera las necesarias capacidades lógicas, psicomotrices y de formalización del pensamiento, a través del conocimiento de conceptos geométricos suficientes para la representación gráfica y su relación con la formalización analítica.
Por otra parte, facilitar el conocimiento del espacio euclídeo, de los sistemas y técnicas (tradicionales y asistidas) de representación, así como la interpretación de documentos gráficos de ingeniería (en sus diferentes soportes) y los básicos en el ámbito de los equipos y materiales aeroespaciales."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/s.avila%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/blanca.boado.cuartero%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/javier.perez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/mariajesus.casati%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/s.avila%40upm.es> ;
    schema:name "Expresión Gráfica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145022004/2025-26/CB1> a ns1:Competency ;
    ns1:competencyCode "CB1" ;
    ns1:competencyDescription "Que los estudiantes hayan demostrado poseer y comprender conocimientos en un área de estudio que parte de la base de la educación secundaria general, y se suele encontrar a un nivel que, si bien se apoya en libros de texto avanzados, incluye también algunos aspectos que implican conocimientos procedentes de la vanguardia de su campo de estudio."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145022004/2025-26/CFB3> a ns1:Competency ;
    ns1:competencyCode "CFB3" ;
    ns1:competencyDescription "Conocimientos básicos sobre el uso y programación de los ordenadores, sistemas operativos, bases de datos y programas informáticos con aplicación en ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145022004/2025-26/CFB5> a ns1:Competency ;
    ns1:competencyCode "CFB5" ;
    ns1:competencyDescription "Capacidad de visión espacial y conocimiento de las técnicas de representación gráfica, tanto por métodos tradicionales de geometría métrica y geometría descriptiva, como mediante las aplicaciones de diseño asistido por ordenador."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145022004/2025-26/CT%203> a ns1:Competency ;
    ns1:competencyCode "CT 3" ;
    ns1:competencyDescription "Capacidad para identificar y resolver problemas aplicando, con creatividad, los conocimientos adquiridos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145022004/2025-26/CT%206> a ns1:Competency ;
    ns1:competencyCode "CT 6" ;
    ns1:competencyDescription "Uso de las tecnologías de la información y de las comunicaciones."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145022004/2025-26/RA165> a ns1:LearningResult ;
    ns1:learningResultCode "RA165" ;
    ns1:learningResultDescription "Los resultados del aprendizaje correspondientes a esta asignatura han quedado definidos en el apartado de competencias de este documento, señalando los que corresponden a conocimientos, habilidades y competencias propiamente dichas. EGGITA"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145022004/2025-26/RA41> a ns1:LearningResult ;
    ns1:learningResultCode "RA41" ;
    ns1:learningResultDescription "Conocimientos: Conocer los principios generales sobre diseño geométrico y funcional y los sistemas y técnicas de representación,así como deducir comportamiento dinámico y mecanismos de sistemas aeronáuticos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145022004/2025-26/RA42> a ns1:LearningResult ;
    ns1:learningResultCode "RA42" ;
    ns1:learningResultDescription "Conocer el espacio euclídeo y los sistemas y técnicas (tradicionales y asistidas) de representación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145022004/2025-26/RA43> a ns1:LearningResult ;
    ns1:learningResultCode "RA43" ;
    ns1:learningResultDescription "Habilidades: Tener la capacidad de abstracción e idealización dimensional, así como de interpretar y crear los documentos técnicos para el diseño conceptual,preliminar y de detalle de modelos físicos y sistemas,pudiendo identificar y resolver problemas mecánicos ene sistemas aeroespaciales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145022004/2025-26/RA44> a ns1:LearningResult ;
    ns1:learningResultCode "RA44" ;
    ns1:learningResultDescription "Interpretar documentos gráficos de ingeniería (en sus diferentes soportes) y los básicos en el ámbito de los equipos y materiales aeroespaciales"@es .

