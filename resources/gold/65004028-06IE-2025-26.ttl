    ns1:itemIndex 3 ;
    ns1:syllabusDescription "4. Gestión económica de un proyecto. Presupuestos y gestión de compras. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004028/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "5. Gestión de proyectos de construcción y de montaje. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004028/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "6. Etapas y ciclo de vida de un proyecto. La Dirección y los riesgos. Sin subniveles"@es .

