        <https://guia-kg.skai.etsisi.upm.es/resource/65004028/2025-26/CG9> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/65004028/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/65004028/2025-26/didactic_resource/2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/65004028/2025-26/didactic_resource/3> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/65004028/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/65004028/2025-26/RA162>,
        <https://guia-kg.skai.etsisi.upm.es/resource/65004028/2025-26/RA163>,
        <https://guia-kg.skai.etsisi.upm.es/resource/65004028/2025-26/RA164>,
        <https://guia-kg.skai.etsisi.upm.es/resource/65004028/2025-26/RA165> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/65004028/2025-26/syllabus> ;
    ns1:inpersonHours "36 horas (46.2%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation "La asignatura se relaciona con el ODS7 (Garantizar el acceso a una energía asequible, segura, sostenible y moderna), ODS8 (Promover el crecimiento económico inclusivo y sostenible, el empleo y el trabajo decente para todos) y ODS9 (Construir infraestructuras resilientes, promover la industrialización sostenible y fomentar la innovación)."@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "38 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/65004028/2025-26/eventSchedule> ;
    schema:description """La asignatura de ingeniería de proyectos te acerca y da conocer un proyecto de ingeniería. Conocerás los tipos de proyectos y sus modalidades de contratación. Reúne las técnicas de programación de un proyecto de ingeniería,
contemplando: los límites tiempo, coste y alcance técnico.
Adicionalmente, se contemplan las teorías de gestión y dirección técnica y económica de proyectos: contemplando la cultura, el liderazgo, los riesgos y la gestión económica y de personas.
Por último, se contemplan las técnicas prácticas de planificación temporal, diagramas habitualmente considerados Barras y Redes, así como, la práctica de la planificación financiera: costes e ingresos."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/juan.pous%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/juan.pous%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/maria.chiquito%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/marta.fernandezh%40upm.es> ;
    schema:name "Ingenieria de Proyectos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004028/2025-26/CE45> a ns1:Competency ;
    ns1:competencyCode "CE45" ;
    ns1:competencyDescription "Aplicación de conocimientos de ingeniería al diseño, implantación y puesta en operación de plantas energéticas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004028/2025-26/CE56> a ns1:Competency ;
    ns1:competencyCode "CE56" ;
    ns1:competencyDescription "Aplicar los fundamentos de la ingeniería de proyectos en la Ingeniería de la Energía."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004028/2025-26/CE57> a ns1:Competency ;
    ns1:competencyCode "CE57" ;
    ns1:competencyDescription "Aplicar metodologías de control de calidad en la Ingeniería de la Energía."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004028/2025-26/CE58> a ns1:Competency ;
    ns1:competencyCode "CE58" ;
    ns1:competencyDescription "Aplicar los fundamentos de la prevención de riesgos laborales en los proyectos e instalaciones energéticos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004028/2025-26/CE59> a ns1:Competency ;
    ns1:competencyCode "CE59" ;
    ns1:competencyDescription "Firmar proyectos en el ámbito de la Ingeniería de la Energía."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004028/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Aplicar los conocimientos adquiridos para identificar, formular y resolver problemas dentro de contextos amplios y multidisciplinarios, siendo capaces de integrar conocimientos, trabajando en equipos multidisciplinares."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004028/2025-26/CG4> a ns1:Competency ;
    ns1:competencyCode "CG4" ;
    ns1:competencyDescription "Comprender el impacto de la ingeniería energética en el medio ambiente, el desarrollo sostenible de la sociedad y la importancia de trabajar en un entorno profesional y responsable."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004028/2025-26/CG5> a ns1:Competency ;
    ns1:competencyCode "CG5" ;
    ns1:competencyDescription "Saber comunicar los conocimientos y conclusiones, tanto de forma oral, escrita y gráfica, a públicos especializados y no especializados de un modo claro y sin ambigüedades."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004028/2025-26/CG6> a ns1:Competency ;
    ns1:competencyCode "CG6" ;
    ns1:competencyDescription "Poseer habilidades de aprendizaje que permitan continuar estudiando a lo largo de la vida para su adecuado desarrollo profesional."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004028/2025-26/CG9> a ns1:Competency ;
    ns1:competencyCode "CG9" ;
    ns1:competencyDescription "Organización y planificación en el ámbito de la empresa, y otras instituciones y organizaciones de proyectos y equipos humanos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004028/2025-26/RA162> a ns1:LearningResult ;
    ns1:learningResultCode "RA162" ;
    ns1:learningResultDescription "Aplicar los fundamentos básicos de la Ingeniería de Proyectos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004028/2025-26/RA163> a ns1:LearningResult ;
    ns1:learningResultCode "RA163" ;
    ns1:learningResultDescription "Aplicar la metodología y las técnicas necesarias para desarrollar un proyecto, incluidas las fases de planificación, desarrollo y puesta en marcha"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004028/2025-26/RA164> a ns1:LearningResult ;
    ns1:learningResultCode "RA164" ;
    ns1:learningResultDescription "Aplicar la normativa técnica y la legislación vigente relacionadas con el desarrollo y ejecución de un proyecto."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004028/2025-26/RA165> a ns1:LearningResult ;
    ns1:learningResultCode "RA165" ;
    ns1:learningResultDescription "Analizar alternativas y tomar decisiones para la realización de un proyecto, estableciendo previamente criterios de valoración técnicos, económicos, sociales y ambientales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004028/2025-26/didactic_resource/1> a ns1:DidacticResource ;
