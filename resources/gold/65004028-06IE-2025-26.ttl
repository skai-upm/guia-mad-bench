<https://guia-kg.skai.etsisi.upm.es/resource/65004028/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/65004028/2025-26/CE45>,
        <https://guia-kg.skai.etsisi.upm.es/resource/65004028/2025-26/CE56>,
