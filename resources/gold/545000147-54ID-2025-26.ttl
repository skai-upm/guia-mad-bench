    ns1:inpersonHours "68 horas (43.6%)"@es ;
    ns1:numberOfCredits 6.0 ;
    ns1:otherInformation """Esta asignatura se relaciona con los siguientes Objetivos de Desarrollo Sostenible (ODS):
Objetivo 8: Trabajo decente y crecimiento económico
Objetivo 12: Producción y consumo responsables"""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "68 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/545000147/2025-26/eventSchedule> ;
    schema:description """Los objetivos de la asignatura son:
Entender la naturaleza de la dirección estratégica, así como los conceptos de Misión, objetivos y valores de las empresas.
Conocer cómo se realiza un análisis del entorno, así como el análisis interno de la empresa.
Conocer las distintas estrategias y ventajas competitivas, así como las estrategias con base en las características de la industria.
Conocer las direcciones de desarrollo de la empresa, así como los aspectos relacionados con la evaluación e implantación de estrategias."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/daniel.fvega%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/daniel.fvega%40upm.es> ;
    schema:name "Direccion Estrategica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000147/2025-26/CE49> a ns1:Competency ;
    ns1:competencyCode "CE49" ;
    ns1:competencyDescription "Elaborar la estrategia comercial de la empresa."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000147/2025-26/CE67> a ns1:Competency ;
    ns1:competencyCode "CE67" ;
    ns1:competencyDescription "Comprender la organización funcional de la empresa: sus objetivos y técnicas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000147/2025-26/CE68> a ns1:Competency ;
    ns1:competencyCode "CE68" ;
    ns1:competencyDescription "Comprender la misión, visión, valores y estrategia de la empresa."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000147/2025-26/CE73> a ns1:Competency ;
    ns1:competencyCode "CE73" ;
    ns1:competencyDescription "Comprender los principios y directrices de la dirección estratégica."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000147/2025-26/CG14> a ns1:Competency ;
    ns1:competencyCode "CG14" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de comprender, interpretar, sintetizar y evaluar de forma crítica información proveniente de fuentes diversas en el ámbito de la administración y dirección de empresas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000147/2025-26/CG17> a ns1:Competency ;
    ns1:competencyCode "CG17" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de trabajar en un entorno bilingüe (inglés"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000147/2025-26/CG19> a ns1:Competency ;
    ns1:competencyCode "CG19" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de trabajar en equipos multidisciplinares, aplicando los conocimientos adquiridos en el ámbito de la administración y dirección de empresas, fomentando el espíritu de equipo y la coordinación en las tareas de los diversos miembros."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000147/2025-26/CG23> a ns1:Competency ;
    ns1:competencyCode "CG23" ;
    ns1:competencyDescription "Que los estudiantes adquieran un compromiso ético en su trabajo en el ámbito de la administración y dirección de empresas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000147/2025-26/RA134> a ns1:LearningResult ;
    ns1:learningResultCode "RA134" ;
    ns1:learningResultDescription "Conocer las diferentes áreas funcionales que constituyen las organizaciones."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000147/2025-26/RA135> a ns1:LearningResult ;
    ns1:learningResultCode "RA135" ;
    ns1:learningResultDescription "Conocer distintas alternativas de configuración organizativa."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000147/2025-26/RA136> a ns1:LearningResult ;
    ns1:learningResultCode "RA136" ;
    ns1:learningResultDescription "Realizar análisis sencillos concernientes a la gestión de las organizaciones y el conocimiento de su realidad interna y de su entorno."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000147/2025-26/RA137> a ns1:LearningResult ;
    ns1:learningResultCode "RA137" ;
    ns1:learningResultDescription "Madurar el espíritu emprendedor del alumno tanto en cuanto a su capacidad de buscar soluciones a problemas, como de generar nuevas ideas o dinamizar y liderar grupos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000147/2025-26/RA89> a ns1:LearningResult ;
    ns1:learningResultCode "RA89" ;
    ns1:learningResultDescription "Desarrollar la capacidad de búsqueda, almacenamiento y tratamiento de información para la toma de decisiones y el aprendizaje autónomo."@es .

