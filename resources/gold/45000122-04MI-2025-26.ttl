        <https://guia-kg.skai.etsisi.upm.es/resource/45000122/2025-26/syllabus/3>,
        <https://guia-kg.skai.etsisi.upm.es/resource/45000122/2025-26/syllabus/4> .

<https://guia-kg.skai.etsisi.upm.es/resource/45000122/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Introduction and presentation Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000122/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "2. Constituents and typology. Constituents. Fibers, reinforcement architecture, matrices, interphases, metal-matrix composites, ceramic-matrix composites, polymer-matrix composites. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000122/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "3. Micromechanics of Composites. Constitutive equations. Elastic behavior. Higro-thermal stresses. Conductivity. Strength and failure. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000122/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "4. Macromechanics of Composites. Orthotropic lamina. Failure criteria. Laminate theory Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000122/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "5. Behavior under service conditions. Requirements. Damage tolerance. NDE. Repairs. Joints. Sin subniveles"@es .

