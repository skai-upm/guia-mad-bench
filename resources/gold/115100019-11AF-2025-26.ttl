<https://guia-kg.skai.etsisi.upm.es/resource/115100019/2025-26/syllabus> a ns1:Syllabus ;
    ns1:hasItem <https://guia-kg.skai.etsisi.upm.es/resource/115100019/2025-26/syllabus/0>,
