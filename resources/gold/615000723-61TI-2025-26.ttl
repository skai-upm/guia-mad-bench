<https://guia-kg.skai.etsisi.upm.es/resource/615000723/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/615000723/2025-26/CBAS05>,
        <https://guia-kg.skai.etsisi.upm.es/resource/615000723/2025-26/CC11>,
