    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/615000723/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/615000723/2025-26/didactic_resource/2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/615000723/2025-26/didactic_resource/3>,
        <https://guia-kg.skai.etsisi.upm.es/resource/615000723/2025-26/didactic_resource/4>,
        <https://guia-kg.skai.etsisi.upm.es/resource/615000723/2025-26/didactic_resource/5> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/615000723/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/615000723/2025-26/RA92>,
        <https://guia-kg.skai.etsisi.upm.es/resource/615000723/2025-26/RA93>,
        <https://guia-kg.skai.etsisi.upm.es/resource/615000723/2025-26/RA96>,
        <https://guia-kg.skai.etsisi.upm.es/resource/615000723/2025-26/RA99> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/615000723/2025-26/syllabus> ;
    ns1:inpersonHours "70 horas (44.9%)"@es ;
    ns1:numberOfCredits 6.0 ;
    ns1:otherInformation "En esta asignatura se evaluará la competencia transversal: resolución de problemas. La forma de evaluar esta competencia es mediante la resolución de problemas del examen escrito global.Las actividades para el desarrollo de esta competencia en el aula consisten en la realización de ejercicios y problemas presentados a lo largo de la asignatura. Además se da retroalimentación mediante la evaluación de los problemas de las actividades que se realizan por cada tema.El peso de la competencia en la asignatura es de (aproximadamente) 20% de la nota final."@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "92 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/615000723/2025-26/eventSchedule> ;
    schema:description "El objetivo de la asignatura es describir los conceptos y términos fundamentales que conforman las redes de computadores, examinar los componentes hardware y software esenciales, así como los enlaces entre sus nodos y estaciones terminales y los protocolos que permiten la transmisión de datos, especialmente en las capas de red y transporte."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/tomas.robles%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/alfredo.valle%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/ernesto.jimenez.merino%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/tomas.robles%40upm.es> ;
    schema:name "Redes de Computadores"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000723/2025-26/CBAS05> a ns1:Competency ;
    ns1:competencyCode "CBAS05" ;
    ns1:competencyDescription "Conocimiento de la estructura, funcionamiento e interconexión de los sistemas informáticos, así como los fundamentos de su programación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000723/2025-26/CC11> a ns1:Competency ;
    ns1:competencyCode "CC11" ;
    ns1:competencyDescription "Conocimiento y aplicación de las características, funcionalidades y estructura de los Sistemas Distribuidos, las Redes de Computadores e Internet y diseñar e implementar aplicaciones basadas en ellas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000723/2025-26/CT02> a ns1:Competency ;
    ns1:competencyCode "CT02" ;
    ns1:competencyDescription "Resolución de problemas: Identificar, analizar y definir los elementos significativos que constituyen un problema para resolverlo con criterio y de forma efectiva."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000723/2025-26/RA92> a ns1:LearningResult ;
    ns1:learningResultCode "RA92" ;
    ns1:learningResultDescription "Diseña la interconexión de redes LAN y WAN mediante TCP/IP"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000723/2025-26/RA93> a ns1:LearningResult ;
    ns1:learningResultCode "RA93" ;
    ns1:learningResultDescription ".Entiende el funcionamiento de los protocolos de transporte TCP y UDP."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000723/2025-26/RA96> a ns1:LearningResult ;
    ns1:learningResultCode "RA96" ;
    ns1:learningResultDescription "Resuelve problemas abiertos, barajando varias alternativas, justificando las decisiones tomadas de manera razonada y crítica, expresando con precisión las argumentaciones necesarias y las conclusiones."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000723/2025-26/RA99> a ns1:LearningResult ;
    ns1:learningResultCode "RA99" ;
    ns1:learningResultDescription "Conoce el funcionamiento de los protocolos de transporte TCP y UDP."@es .

