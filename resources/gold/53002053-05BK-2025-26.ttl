    ns1:inpersonHours "35 horas (44.9%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation """Esta asignatura está relacionada con los ODS 7, 9, 11,12 y 13
La relación queda implicada en el desarrollo de las clases"""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "35 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/53002053/2025-26/eventSchedule> ;
    schema:description "La asignatura abarca las soluciones tecnológicas más relevantes que son aplicables en entornos de energía distribuida. Se busca dotar al alumno de las herramientas necesarias para diseñar la parte minorista de los sistemas eléctricos a medida que la transición energética vaya paulatinamente aumentando la flexibilidad y proactividad de los consumidores. El temario se centra, por una parte, en el diseño de redes inteligentes (smart grid) y sus aplicaciones prácticas y, por otra, en las soluciones asociadas a las instalaciones de los clientes (internet de las cosas, smart client)."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/alberto.ramos%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/alberto.ramos%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/eduardo.conde%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/pablo.reina%40upm.es> ;
    schema:name "Redes y Clientes Inteligentes"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002053/2025-26/CB7> a ns1:Competency ;
    ns1:competencyCode "CB7" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en entornos nuevos o poco conocidos dentro de contextos más amplios (o multidisciplinares) relacionados con su área de estudio/ Students are capable of applying their knowledge, understanding, and problem"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002053/2025-26/CE13> a ns1:Competency ;
    ns1:competencyCode "CE13" ;
    ns1:competencyDescription "Entender la evolución y el funcionamiento de los mercados de petróleo, gas y electricidad. Conocer los principales tipos de diseño de los mercados de electricidad y gas que existen en la experiencia internacional y los criterios bajo los que se han diseñado, y ser capaz de analizar cuál es la regulación más adecuada para cada situación./ Understand the evolution and operation of the oil, gas and electricity markets. Know the main types of design of electricity and gas markets that exist in international experience and the criteria under which they have been designed, and be able to analyze which is the most appropriate regulation for each situation."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002053/2025-26/CE19> a ns1:Competency ;
    ns1:competencyCode "CE19" ;
    ns1:competencyDescription "Entender el funcionamiento de redes eléctricas en un contexto de decarbonización de la sociedad/ Understand the operation of electrical networks in a context of decarbonization of society"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002053/2025-26/CE8> a ns1:Competency ;
    ns1:competencyCode "CE8" ;
    ns1:competencyDescription "Disponer de habilidades, criterios y conocimientos para investigar, desarrollar e innovar en el campo de la energía: tecnologías renovables y no renovables, almacenamiento, vectores energéticos, en un contexto de decarbonización del sistema./ Skills, criteria and knowledge to research, develop and innovate in the field of energy: renewable and non"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002053/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Aplicar conocimientos de ciencias y tecnologías avanzadas a la práctica profesional o investigadora de la Ingeniería Energética./ Apply knowledge of advanced science and technology to the professional or research practice of Energy Engineering."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002053/2025-26/CG8> a ns1:Competency ;
    ns1:competencyCode "CG8" ;
    ns1:competencyDescription "Incorporar nuevas tecnologías y herramientas avanzadas de la Ingeniería Energética en sus actividades profesionales o investigadoras./ Incorporate new technologies and advanced tools of Energy Engineering in their professional or research activities."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002053/2025-26/CT1> a ns1:Competency ;
    ns1:competencyCode "CT1" ;
    ns1:competencyDescription "Aplica. Habilidad para aplicar conocimientos científicos, matemáticos y tecnológicos en sistemas relacionados con la práctica de la ingeniería./ Apply. Ability to apply scientific, mathematical and technological knowledge in systems related to the practice of engineering."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002053/2025-26/CT10> a ns1:Competency ;
    ns1:competencyCode "CT10" ;
    ns1:competencyDescription "Conoce. Conocimiento de los temas contemporáneos./ Knowledge of contemporary issues."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002053/2025-26/CT3> a ns1:Competency ;
    ns1:competencyCode "CT3" ;
    ns1:competencyDescription "Diseña. Habilidad para diseñar un sistema, componente o proceso que alcance los requisitos deseados teniendo en cuenta restricciones realistas tales como las económicas, medioambientales, sociales, políticas, éticas, de salud y seguridad, de fabricación y de sostenibilidad./ Design. Ability to design a system, component or process that meets the desired requirements taking into account realistic constraints such as economic, environmental, social, political, ethical, health and safety, manufacturing and sustainability."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002053/2025-26/CT5> a ns1:Competency ;
    ns1:competencyCode "CT5" ;
    ns1:competencyDescription "Resuelve. Habilidad para identificar, formular y resolver problemas de ingeniería./ Solve. Ability to identify, formulate and solve engineering problems."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002053/2025-26/CT8> a ns1:Competency ;
    ns1:competencyCode "CT8" ;
    ns1:competencyDescription "Entiende los impactos. Educación amplia necesaria para entender el impacto de las soluciones ingenieriles en un contexto social global./ Understand the impacts. Broad education to understand the impact of engineering solutions in a global social context."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002053/2025-26/CT9> a ns1:Competency ;
    ns1:competencyCode "CT9" ;
    ns1:competencyDescription "Se actualiza. Reconocimiento de la necesidad y la habilidad para comprometerse al aprendizaje continuo./ Updating. Recognition of the need and ability to commit to continuous learning."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002053/2025-26/RA239> a ns1:LearningResult ;
    ns1:learningResultCode "RA239" ;
    ns1:learningResultDescription "Conocer y comprender la integración y gestión de redes energéticas inteligentes."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002053/2025-26/RA240> a ns1:LearningResult ;
    ns1:learningResultCode "RA240" ;
    ns1:learningResultDescription "Conocer y comprender el funcionamiento de contadores inteligentes y los dispositivos de control de la demanda"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002053/2025-26/RA241> a ns1:LearningResult ;
    ns1:learningResultCode "RA241" ;
    ns1:learningResultDescription "Calcular los sistemas de microgeneración necesarios para el abastecimiento de una pequeña demanda energética"@es .

