<https://guia-kg.skai.etsisi.upm.es/resource/95000014/2025-26/syllabus> a ns1:Syllabus ;
    ns1:hasItem <https://guia-kg.skai.etsisi.upm.es/resource/95000014/2025-26/syllabus/0>,
        <https://guia-kg.skai.etsisi.upm.es/resource/95000014/2025-26/syllabus/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/95000014/2025-26/syllabus/10>,
        <https://guia-kg.skai.etsisi.upm.es/resource/95000014/2025-26/syllabus/11>,
        <https://guia-kg.skai.etsisi.upm.es/resource/95000014/2025-26/syllabus/12>,
        <https://guia-kg.skai.etsisi.upm.es/resource/95000014/2025-26/syllabus/13>,
        <https://guia-kg.skai.etsisi.upm.es/resource/95000014/2025-26/syllabus/14>,
        <https://guia-kg.skai.etsisi.upm.es/resource/95000014/2025-26/syllabus/15>,
        <https://guia-kg.skai.etsisi.upm.es/resource/95000014/2025-26/syllabus/16>,
        <https://guia-kg.skai.etsisi.upm.es/resource/95000014/2025-26/syllabus/17>,
        <https://guia-kg.skai.etsisi.upm.es/resource/95000014/2025-26/syllabus/2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/95000014/2025-26/syllabus/3>,
        <https://guia-kg.skai.etsisi.upm.es/resource/95000014/2025-26/syllabus/4>,
        <https://guia-kg.skai.etsisi.upm.es/resource/95000014/2025-26/syllabus/5>,
        <https://guia-kg.skai.etsisi.upm.es/resource/95000014/2025-26/syllabus/6>,
        <https://guia-kg.skai.etsisi.upm.es/resource/95000014/2025-26/syllabus/7>,
        <https://guia-kg.skai.etsisi.upm.es/resource/95000014/2025-26/syllabus/8>,
        <https://guia-kg.skai.etsisi.upm.es/resource/95000014/2025-26/syllabus/9> .

<https://guia-kg.skai.etsisi.upm.es/resource/95000014/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Instrumentación / Señales y Medidas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000014/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Magnitudes eléctricas y unidades. Órdenes de magnitud. Criterios de signos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000014/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "2.2. Amplificadores. Parámetros característicos. Impedancias de entrada y salida. Función de transferencia. Respuesta en frecuencia. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000014/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "2.3. El Amplificador Operacional como elemento central de los bloques funcionales. Características. Conexión y alimentación. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000014/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "2.4. Bloques funcionales para amplificación. Amplificador inversor y no inversor, seguidor, conversor tensión-corriente y corriente-tensión. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000014/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "2.5. Bloques funcionales para amplificación. Amplificador de instrumentación. Tensiones común y diferencial. Ganancias. Factor de rechazo al modo común. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000014/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "2.6. Bloques funcionales para instrumentación y cálculo operativo: sumador, restador, diferenciador, integrador. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000014/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "2.7. Bloques funcionales en régimen no lineal. Comparadores con histéresis. Umbrales de comparación. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000014/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "2.8. Bloques funcionales para filtrado. Función de transferencia. Parámetros característicos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000014/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "2.9. Sistema analógico completo. Interconexión de bloques funcionales. Efectos de carga. Aplicaciones. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000014/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Señales. Clasificación. Alternancia. Periodicidad. Parámetros (valor de pico, valor pico-pico, valor medio, valor eficaz, periodo, frecuencia). Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000014/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "1.3. Régimen sinusoidal permanente. Estudio de la señal y sus parámetros característicos. Superposición de señales continua y alterna. Valor eficaz. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000014/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "1.4. Elementos de circuito. Fuentes de tensión y corriente ideales. Generadores de tensión y corriente ideales. Componentes electrónicos. Equivalente de Thévenin. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000014/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "1.5. Instrumentos de medida ideales y reales. Circuito equivalente. Impedancia interna. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000014/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "1.6. Proceso de medida. Conexión del instrumento. Perturbación causada por el instrumento. Efecto de carga. Estimación y corrección. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000014/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "1.7. Instrumentación de laboratorio. Descripción. Funciones. Particularidades. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000014/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "2. Electrónica / Sistemas Analógicos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000014/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "2.1. Bloques funcionales de un sistema analógico. Amplificadores. Filtros. Sin subniveles"@es .

