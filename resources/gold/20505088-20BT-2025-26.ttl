<https://guia-kg.skai.etsisi.upm.es/resource/20505088/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/20505088/2025-26/CE01>,
        <https://guia-kg.skai.etsisi.upm.es/resource/20505088/2025-26/CE09> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/20505088/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/20505088/2025-26/didactic_resource/2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/20505088/2025-26/didactic_resource/3>,
        <https://guia-kg.skai.etsisi.upm.es/resource/20505088/2025-26/didactic_resource/4>,
        <https://guia-kg.skai.etsisi.upm.es/resource/20505088/2025-26/didactic_resource/5>,
        <https://guia-kg.skai.etsisi.upm.es/resource/20505088/2025-26/didactic_resource/6> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/20505088/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/20505088/2025-26/RA126>,
        <https://guia-kg.skai.etsisi.upm.es/resource/20505088/2025-26/RA322>,
        <https://guia-kg.skai.etsisi.upm.es/resource/20505088/2025-26/RA323>,
        <https://guia-kg.skai.etsisi.upm.es/resource/20505088/2025-26/RA324>,
        <https://guia-kg.skai.etsisi.upm.es/resource/20505088/2025-26/RA325>,
        <https://guia-kg.skai.etsisi.upm.es/resource/20505088/2025-26/RA326> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/20505088/2025-26/syllabus> ;
    ns1:inpersonHours "31 horas y 20 minutos (40.2%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation "Si el número de alumnos fuera reducido, y existiera un consenso, se podría sustituir los trabajos de la asignatura por un trabajo de investigación en grupo, relacionado con la Biofísica."@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "32 horas y 20 minutos"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/20505088/2025-26/eventSchedule> ;
    schema:description """La asignatura de Biofísica trata de fundamentar el conocimiento que se tiene de las estructuras biológicas de pequeña escala, así como de algunos de los procesos que se producen tanto a nivel celular como a nivel orgánico.
Está organizada en tres grandes bloques: una primera parte introductoria en la que trata la Termodinámica Estadística con el estudio de la entropía, los estados fuera del equilibrio, las fluctuaciones y una pequeña incursión en los Sistemas Complejos. El segundo bloque parte de las fluctuaciones para estudiar la difusión (movimiento browniano y ley de Fick) y se pasará al transporte en fluidos, con el estudio de la sedimentación, ley de Stokes y fluidos con bajo número de Reynolds. El tercer bloque se centra en el nivel celular con el estudio de membranas, con la relación Nernst, la difusión y transporte activo a través de la membrana, pasando finalmente a las propiedades eléctricas de las membranas y trasmisión del impulso nervioso."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/juanmanuel.pastor%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/javier.galeano%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/juancarlos.losada%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/juanmanuel.pastor%40upm.es> ;
    schema:name "Biofísica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20505088/2025-26/CE01> a ns1:Competency ;
    ns1:competencyCode "CE01" ;
    ns1:competencyDescription "Capacidad para conocer las propiedades de la materia, los principios termodinámicos y sus aplicaciones prácticas, así como las características comunes de los procesos físicoquímicos de interés biotecnológico a escala de laboratorio e industrial."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20505088/2025-26/CE09> a ns1:Competency ;
    ns1:competencyCode "CE09" ;
    ns1:competencyDescription "Capacidad para dentificar y comprender los procesos físicos relacionados con la Biotecnología y las técnicas analíticas así como evaluar sus ventajas e inconvenientes frente a técnicas alternativas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20505088/2025-26/RA126> a ns1:LearningResult ;
    ns1:learningResultCode "RA126" ;
    ns1:learningResultDescription "Conocer las bases estructurales termodinámicas de la bioenergética celular y del transporte a través de membranas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20505088/2025-26/RA322> a ns1:LearningResult ;
    ns1:learningResultCode "RA322" ;
    ns1:learningResultDescription "Identificar la difusión como un mecanismo básico en el transporte a nivel celular y su relación con el movimiento browniano"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20505088/2025-26/RA323> a ns1:LearningResult ;
    ns1:learningResultCode "RA323" ;
    ns1:learningResultDescription "Conocer las características del movimiento de los fluidos a nivel celular y del transporte en estos fluidos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20505088/2025-26/RA324> a ns1:LearningResult ;
    ns1:learningResultCode "RA324" ;
    ns1:learningResultDescription "Identificar el papel de la estadística en la definición de los estados macroscópicos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20505088/2025-26/RA325> a ns1:LearningResult ;
    ns1:learningResultCode "RA325" ;
    ns1:learningResultDescription "Relacionar la entropía con el número de microestados y el orden de un sistema"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20505088/2025-26/RA326> a ns1:LearningResult ;
    ns1:learningResultCode "RA326" ;
    ns1:learningResultDescription "Comprender el papel fundamental de los iones en la membrana celular para su actividad y la transmisión de la señal eléctrica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20505088/2025-26/didactic_resource/1> a ns1:DidacticResource ;
    ns1:bibliographyDescription "Libro muy completo que incluye la casi totalidad del temario"@es ;
    ns1:bibliographyTitle "\"Física Biológica\", P. Nelson (Ed. Reverté)"@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20505088/2025-26/didactic_resource/2> a ns1:DidacticResource ;
    ns1:bibliographyDescription "Libro que incluye los temas de Termodinámica y de Membranas"@es ;
    ns1:bibliographyTitle "\"Temas de Biofísica\", J. Buceta, E. Koroutcheva, J.M. Pastor (Ed. UNED)"@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20505088/2025-26/didactic_resource/3> a ns1:DidacticResource ;
    ns1:bibliographyDescription "Libro sobre la parte de Termodinámica Estadística con más nivel físico y matemático"@es ;
    ns1:bibliographyTitle "\"Física Estadística\", F. Reif, Ed. Reverté"@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20505088/2025-26/didactic_resource/4> a ns1:DidacticResource ;
    ns1:bibliographyDescription "Libro de Física pero con ejemplos interesantes para los temas de Termodinámica y Fluidos"@es ;
    ns1:bibliographyTitle "\"Física para las Ciencias de la Vida\", A.H. Cromer, Ed. Reverté"@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20505088/2025-26/didactic_resource/5> a ns1:DidacticResource ;
