<https://guia-kg.skai.etsisi.upm.es/resource/55001074/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/55001074/2025-26/CE23C>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55001074/2025-26/CE25D>,
