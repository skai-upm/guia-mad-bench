    ns1:itemIndex 6 ;
    ns1:syllabusDescription "2.1. Nociones previas de Hidrostática e Hidrodinámica: concepto de nivel piezométrico y de potencial de fuerzas Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003016/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "2.2. El flujo de aguas subterráneas: superficies equipotenciales y líneas de flujo Sin subniveles"@es .

