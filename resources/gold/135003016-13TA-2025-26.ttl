    ns1:itemIndex 10 ;
    ns1:syllabusDescription "2.5. Utilización de trazadores para el estudio del flujo del agua subterránea Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003016/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "2.6. Flujo hacia las obras de captación: concepto de coeficiente de almacenamiento. Ensayos de bombeo. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003016/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "3. HIDROQUÍMICA Y CONTAMINACIÓN"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003016/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "3.1. Composición de las aguas subterráneas: constituyentes e importancia relativa Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003016/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "3.2. Análisis químico: expresión de resultados y error de balance Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003016/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "3.3. Interpretación y representación gráfica de datos hidroquimicos Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003016/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "3.4. Evolución hidroquímica del agua subterránea y procesos modificadores Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003016/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "3.5. Contaminación de aguas subterráneas: agentes y fuentes. Contaminación urbana, agrícola e industrial. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003016/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "3.6. Mecanismos de la contaminación. Comportamiento de los acuíferos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003016/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "3.7. Protección de las aguas subterráneas frente a la contaminación: vulnerabilidad. Descontaminación de acuíferos Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003016/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Infiltración: zona saturada y superficie freática Sin subniveles"@es .

