    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/85003111/2025-26/eventSchedule> ;
    schema:description """En la asignatura de Álgebra Lineal y Geometría se presentan las herramientas básicas para estudiar las soluciones de los sistemas de ecuaciones lineales y su aplicación a la geometría Euclídea.
El temario está estructurado en 4 bloques.

1. Introducción

I Matrices, Sistemas y Geometría

2. Conjuntos

3. Matrices y Vectores en n dimensiones

4. Sistemas de Ecuaciones Lineales: el método de Gauss

5. Sistemas homogéneos y no homogéneos

6. Matriz inversa y determinante

7. Dependencia e independencia lineal

II Geometría de los Subespacios Vectoriales

8. Subespacios vectoriales

9. Base y dimensión de un subespacio vectorial

10. Operaciones con subespacios vectoriales


III Algebra Lineal Euclídea

11. Complemento ortogonal y forma implícita de un subespacio
12. Proyección ortogonal sobre un subespacio
13. Base ortonormal de un subespacio
14. Aplicación a la resolución de sistemas por mínimos cuadrados

IV Transformaciones y Diagonalización

15. Transformaciones del plano y del espacio
16. Autovalores y diagonalización de matrices"""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/em.nungesser%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/em.nungesser%40upm.es> ;
    schema:name "álgebra Lineal y Geometría"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003111/2025-26/CB1> a ns1:Competency ;
    ns1:competencyCode "CB1" ;
    ns1:competencyDescription "Que los estudiantes hayan demostrado poseer y comprender conocimientos en un área de estudio que parte de la base de la educación secundaria general, y se suele encontrar a un nivel que, si bien se apoya en libros de texto avanzados, incluye también algunos aspectos que implican conocimientos procedentes de la vanguardia de su campo de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003111/2025-26/CB5> a ns1:Competency ;
    ns1:competencyCode "CB5" ;
    ns1:competencyDescription "Que los estudiantes hayan desarrollado aquellas habilidades de aprendizaje necesarias para emprender estudios posteriores con un alto grado de autonomía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003111/2025-26/CE%201> a ns1:Competency ;
    ns1:competencyCode "CE 1" ;
    ns1:competencyDescription "Capacidad para la resolución de los problemas matemáticos que puedan plantearse en la ingeniería. Aptitud para aplicar los conocimientos sobre: álgebra lineal; geometría; geometría diferencial; cálculo diferencial e integral; ecuaciones diferenciales y en derivadas parciales; métodos numéricos; algorítmica numérica; estadística y optimización."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003111/2025-26/CE%205> a ns1:Competency ;
    ns1:competencyCode "CE 5" ;
    ns1:competencyDescription "Capacidad de visión espacial y conocimiento de las técnicas de representación gráfica, tanto por métodos tradicionales de geometría métrica y geometría descriptiva, como mediante las aplicaciones de diseño asistido por ordenador."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003111/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Capacidad para el aprendizaje de nuevos métodos y teorías, y en la versatilidad para adaptarse a nuevas situaciones basándose en los conocimientos adquiridos en materias básicas y tecnológicas propias de la Arquitectura Naval."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003111/2025-26/RA29> a ns1:LearningResult ;
    ns1:learningResultCode "RA29" ;
    ns1:learningResultDescription "Aplicar los métodos de solución de sistemas de ecuaciones lineales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003111/2025-26/RA31> a ns1:LearningResult ;
    ns1:learningResultCode "RA31" ;
    ns1:learningResultDescription "Aplicar los conceptos de Álgebra Lineal a la geometría del plano y el espacio. Identificar y obtener ecuaciones de los movimientos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003111/2025-26/RA32> a ns1:LearningResult ;
    ns1:learningResultCode "RA32" ;
    ns1:learningResultDescription "Realizar operaciones con Matrices. Calcular el determinante y la inversa de una matriz"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003111/2025-26/RA33> a ns1:LearningResult ;
    ns1:learningResultCode "RA33" ;
    ns1:learningResultDescription "Calcular autovalores y autovectores de una transformación lineal. Diagonalizar una matriz"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003111/2025-26/RA34> a ns1:LearningResult ;
    ns1:learningResultCode "RA34" ;
    ns1:learningResultDescription "Obtener bases ortonormales de un subespacio. Calcular la proyección ortogonal sobre subespacios. Identificar transformaciones lineales ortogonales."@es .

