<https://guia-kg.skai.etsisi.upm.es/resource/105000123/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/105000123/2025-26/C1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/105000123/2025-26/C13>,
