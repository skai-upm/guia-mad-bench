        <https://guia-kg.skai.etsisi.upm.es/resource/105000123/2025-26/C5>,
        <https://guia-kg.skai.etsisi.upm.es/resource/105000123/2025-26/K1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/105000123/2025-26/S1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/105000123/2025-26/S12>,
        <https://guia-kg.skai.etsisi.upm.es/resource/105000123/2025-26/S2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/105000123/2025-26/S4> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/105000123/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/105000123/2025-26/didactic_resource/2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/105000123/2025-26/didactic_resource/3>,
        <https://guia-kg.skai.etsisi.upm.es/resource/105000123/2025-26/didactic_resource/4> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/105000123/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/105000123/2025-26/RA203> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/105000123/2025-26/syllabus> ;
    ns1:inpersonHours "63 horas y 30 minutos (40.7%)"@es ;
    ns1:numberOfCredits 6.0 ;
    ns1:otherInformation ""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "66 horas y 30 minutos"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/105000123/2025-26/eventSchedule> ;
    schema:description "La asignatura de Geometría Diferencial se centra en el estudio de las propiedades de las curvas (en el plano y en el espacio), y de las superficies inmersas en el espacio euclídeo. En el estudio de estos objetos es necesario usar muchas herramientas que se han visto anteriormente en las asignaturas de Álgebra Lineal y las de Cálculo fundamentalmente. Entre otros conceptos fundamentales, además de la de curva regular y superficie parametrizada, tenemos la noción de curvatura que será central en esta asignatura. En particular, vamos a definir una noción de curvatura para curvas (en las espaciales tendremos la torsión), y en las superficies tendremos distintas curvaturas. Estas curvaturas, además, tienen un significado geométrico. Todos los fundamentos que se ven en esta asignatura son útiles para luego entender la Geometría Diferencial en su formulación más general. Además, las aplicaciones de la geometría diferencial en diversos ámbitos ha sido determinante, desde la visión por computador a la relatividad."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/jonatan.sanchez%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/jonatan.sanchez%40upm.es> ;
    schema:name "Geometria Diferencial"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000123/2025-26/C1> a ns1:Competency ;
    ns1:competencyCode "C1" ;
    ns1:competencyDescription "Capacidad de resolución de problemas aplicando conocimientos de matemáticas, ciencias e ingeniería. TIPO: Competencias."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000123/2025-26/C13> a ns1:Competency ;
    ns1:competencyCode "C13" ;
    ns1:competencyDescription "Capacidad de elegir y usar los métodos analíticos y de modelización relevantes, y de describir una solución de forma abstracta. TIPO: Competencias."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000123/2025-26/C19> a ns1:Competency ;
    ns1:competencyCode "C19" ;
    ns1:competencyDescription "Capacidad para trabajar de forma efectiva como individuo, organizando y planificando su propio trabajo, de forma independiente o como miembro de un equipo. TIPO: Competencias."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000123/2025-26/C5> a ns1:Competency ;
    ns1:competencyCode "C5" ;
    ns1:competencyDescription "Capacidad de abstracción, análisis y síntesis. TIPO: Competencias."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000123/2025-26/K1> a ns1:Competency ;
    ns1:competencyCode "K1" ;
    ns1:competencyDescription "Comprender y utilizar el lenguaje matemático. Conocer demostraciones de teoremas clásicos. Comprender las definiciones de objetos matemáticos. TIPO: Conocimientos o contenidos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000123/2025-26/RA203> a ns1:LearningResult ;
    ns1:learningResultCode "RA203" ;
    ns1:learningResultDescription ""@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000123/2025-26/S1> a ns1:Competency ;
    ns1:competencyCode "S1" ;
    ns1:competencyDescription "Plantear nuevas definiciones. Poder enunciar resultados y construir demostraciones, detectar errores en ellas o encontrar contraejemplos. TIPO: Habilidades o destrezas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000123/2025-26/S12> a ns1:Competency ;
    ns1:competencyCode "S12" ;
    ns1:competencyDescription "Usar el Cálculo Diferencial e Integral y la Topología para el estudio de curvas y superficies. TIPO: Habilidades o destrezas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000123/2025-26/S2> a ns1:Competency ;
    ns1:competencyCode "S2" ;
    ns1:competencyDescription "Ser capaz de extraer de un objeto matemático aquellas propiedades fundamentales que lo caracterizan, distinguiéndolas de aquellas otras ocasionales compartidas con otros objetos matemáticos. TIPO: Habilidades o destrezas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000123/2025-26/S4> a ns1:Competency ;
    ns1:competencyCode "S4" ;
    ns1:competencyDescription "Comprender y ser capaz de encontrar soluciones a problemas matemáticos en diferentes áreas, utilizando para resolverlos las herramientas analíticas, numéricas o estadísticas disponibles. TIPO: Habilidades o destrezas."@es .

