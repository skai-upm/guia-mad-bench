<https://guia-kg.skai.etsisi.upm.es/resource/135004302/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. 1. Cálculo de probabilidades 1.1. Teoría de la probabilidad. 1.2. Variables y vectores aleatorios. 1.3. Relaciones entre variables aleatorias. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004302/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "2. 2. Modelos de distribución de probabilidad. 2.1. Modelos discretos. 2.2. Modelos continuos. 2.3. La distribución Normal Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004302/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "3. 3. Teoría de muestras 3.1. Funciones muestrales. 3.2. Estimación puntual. 3.3. Toma de decisiones. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004302/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "4. 4. Inferencia estadística 4.1. Intervalos de Confianza. 4.2. Contrastes de hipótesis Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004302/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "5. 5. Modelos lineales 5.1. Análisis de la Varianza (ADEVA o ANOVA). 5.2. Modelos de regresión. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004302/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "6. 6. Muestreo 6.1. Muestreo Aleatorio y Sistemático. 6.2. Muestreo Estratificado. 6.3. Otros tipos de muestreo Sin subniveles"@es .

