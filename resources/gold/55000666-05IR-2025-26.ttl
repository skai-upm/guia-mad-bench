    schema:name "Técnicas Avanzadas de Estadística"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000666/2025-26/CE6> a ns1:Competency ;
    ns1:competencyCode "CE6" ;
    ns1:competencyDescription "Capacidad para conocer, entender y utilizar los principios de estadística aplicada"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000666/2025-26/CG2> a ns1:Competency ;
    ns1:competencyCode "CG2" ;
    ns1:competencyDescription "Poseer capacidad para diseñar, desarrollar, implementar, gestionar y mejorar productos, sistemas y procesos en los distintos ámbitos industriales, usando técnicas analíticas, computacionales o experimentales apropiadas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000666/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Aplicar los conocimientos adquiridos para identificar, formular y resolver problemas dentro de contextos amplios y multidisciplinarios, siendo capaces de integrar conocimientos, trabajando en equipos multidisciplinarios."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000666/2025-26/CG5> a ns1:Competency ;
    ns1:competencyCode "CG5" ;
    ns1:competencyDescription "Saber comunicar los conocimientos y conclusiones, tanto de forma oral, escrita y gráfica, a públicos especializados y no especializados de un modo claro y sin ambigüedades"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000666/2025-26/CG6> a ns1:Competency ;
    ns1:competencyCode "CG6" ;
    ns1:competencyDescription "Poseer habilidades de aprendizaje que permitan continuar estudiando a lo largo de la vida para su adecuado desarrollo profesional"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000666/2025-26/CG7> a ns1:Competency ;
    ns1:competencyCode "CG7" ;
    ns1:competencyDescription "Incorporar nuevas tecnologías y herramientas de la Ingeniería de organización en sus actividades profesionales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000666/2025-26/RA124> a ns1:LearningResult ;
    ns1:learningResultCode "RA124" ;
    ns1:learningResultDescription "Formular y estimar modelos de regresión lineal. Conocer el alcance y las limitaciones de los modelos de regresión lineal. Seleccionar con criterio el modelo más adecuado entre las diferentes alternativas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000666/2025-26/RA125> a ns1:LearningResult ;
    ns1:learningResultCode "RA125" ;
    ns1:learningResultDescription "Emplear las técnicas fundamentales de análisis multivariante para resolver problemas que involucran varias variables: reducción de dimensión mediante análisis factorial, diferencia entre grupos mediante análisis discriminante y clasificación de datos mediante análisis cluster."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000666/2025-26/RA126> a ns1:LearningResult ;
    ns1:learningResultCode "RA126" ;
    ns1:learningResultDescription "Conocer comprender los principios básicos del análisis de datos cualitativos : Analizar tablas de contingencia I*J, formular, estimar e interpretar modelos loglineales; y formular, estimar e interpretar modelos de regresión con variable dependiente cualitativa."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000666/2025-26/RA21> a ns1:LearningResult ;
    ns1:learningResultCode "RA21" ;
    ns1:learningResultDescription "Identificar problemas que pueden plantearse en términos estadísticos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000666/2025-26/RA22> a ns1:LearningResult ;
    ns1:learningResultCode "RA22" ;
    ns1:learningResultDescription "Interpretar y comunicar los resultados del análisis estadístico con rigor utilizando el lenguaje apropiado"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000666/2025-26/RA23> a ns1:LearningResult ;
    ns1:learningResultCode "RA23" ;
    ns1:learningResultDescription "Comprender las limitaciones de los modelos estadísticos cuando se trabaja con problemas reales. Evaluar posibles métodos alternativos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000666/2025-26/RA24> a ns1:LearningResult ;
    ns1:learningResultCode "RA24" ;
    ns1:learningResultDescription "Utilizar programas de ordenador de análisis estadístico general y de cálculo científico"@es .

