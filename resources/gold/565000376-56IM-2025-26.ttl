        <https://guia-kg.skai.etsisi.upm.es/resource/565000376/2025-26/syllabus/16>,
        <https://guia-kg.skai.etsisi.upm.es/resource/565000376/2025-26/syllabus/2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/565000376/2025-26/syllabus/3>,
        <https://guia-kg.skai.etsisi.upm.es/resource/565000376/2025-26/syllabus/4>,
