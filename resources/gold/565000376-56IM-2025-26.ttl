    schema:description "La asignatura es una introducción a los Elementos Finitos y las Vibraciones Mecánicas utilizando Matlab."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/joseantonio.lozano%40upm.es> ;
