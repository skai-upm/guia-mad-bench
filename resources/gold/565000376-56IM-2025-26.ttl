        <https://guia-kg.skai.etsisi.upm.es/resource/565000376/2025-26/syllabus/11>,
        <https://guia-kg.skai.etsisi.upm.es/resource/565000376/2025-26/syllabus/12>,
        <https://guia-kg.skai.etsisi.upm.es/resource/565000376/2025-26/syllabus/13>,
