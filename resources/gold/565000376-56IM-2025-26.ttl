        <https://guia-kg.skai.etsisi.upm.es/resource/565000376/2025-26/syllabus/7>,
        <https://guia-kg.skai.etsisi.upm.es/resource/565000376/2025-26/syllabus/8>,
        <https://guia-kg.skai.etsisi.upm.es/resource/565000376/2025-26/syllabus/9> .

<https://guia-kg.skai.etsisi.upm.es/resource/565000376/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Introducción al método de los Elementos Finitos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000376/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Introducción. Esfuerzos y Equilibrio. Relaciones entre esfuerzo y deformación. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000376/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "6. Vibraciones en sistemas mecánicos de 2 GDL"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000376/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "6.1. Formulación del modelo mecánico. Cálculo de las frecuencias de vibración. Cálculo de los modos de vibración. Ejercicios de aplicación de la técnica de Bond-Graph. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000376/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "7. Vibraciones en árboles de transmisión"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000376/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "7.1. Introducción. Vibración forzada causada por fuerzas centrífugas. Concepto de resonancia y de velocidad crítica. Cálculo de frecuencias naturales a flexión en árboles de transmisión. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000376/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "7.2. Cálculo de frecuencias naturales a torsión en árboles de transmisión. Volantes de Inercia. Ejercicios de aplicación de la técnica de Bond-Graph. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000376/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "8. Medida de las vibraciones"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000376/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "8.1. Definición del nivel de vibración. Captadores de vibraciones. Analizadores de vibraciones. Aplicación de la medida de vibraciones al mantenimiento de máquinas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000376/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "2. Elementos Unidimensionales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000376/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "2.1. Introducción. Coordenadas y funciones de forma. Enfoque de la energía potencial. Ensamblaje de elementos. Propiedades de las matrices de rigidez. Efectos por cambio de temperatura. Sistemas Articulados. Vigas y Pórticos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000376/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "3. Elementos Bidimensionales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000376/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "3.1. Introducción. Triángulo de deformación unitaria constante. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000376/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "4. Introducción a la teoría general de vibraciones."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000376/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "4.1. Concepto. Clasificación de las vibraciones. Tratamiento de las vibraciones. Metodología de trabajo. Introducción a la técnica de Bond-Graph para la simulación de sistemas dinámicos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000376/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "5. Vibraciones en sistemas mecánicos de 1 GDL"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000376/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "5.1. Introducción. Formulación del modelo mecánico. Cálculo de la frecuencia de vibración. Método de Rayleigh, para el cálculo de frecuencias naturales. Ejercicios de aplicación de la técnica de Bond-Graph. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/56IM%20-%20Grado%20en%20Ingenier%C3%ADa%20Mec%C3%A1nica> a ns1:BachelorDegree ;
    ns1:degreeCode "56IM"@es ;
    ns1:hasCourse <https://guia-kg.skai.etsisi.upm.es/resource/565000376> ;
    schema:name "Grado en Ingeniería Mecánica"@es .

