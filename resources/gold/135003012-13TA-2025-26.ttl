    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/135003012/2025-26/CE5> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/135003012/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/135003012/2025-26/didactic_resource/2>,
