<https://guia-kg.skai.etsisi.upm.es/resource/305000118/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. El espacio proyectivo. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000118/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "2.5. Razón doble. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000118/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "2.6. Programa de Erlangen. Grupos de transformaciones. Relaciones entre las geometrías euclídea, afín y proyectiva. Geometrías no euclídeas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000118/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "3. Cónicas y cuádricas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000118/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "3.1. Descripción métrica de las cónicas. Cónicas como lugares geométricos. Secciones cónicas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000118/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "3.2. Clasificación de cuádricas afines. Cónicas del plano afín. Superficies cuádricas afines. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000118/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "3.3. Clasificación de cuádricas proyectivas. Cónicas del plano proyectivo. Superficies cuádricas proyectivas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000118/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "3.4. Completación proyectiva de cuádricas afines. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000118/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "4. Dualidad."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000118/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "4.1. El espacio proyectivo dual. Dualidad canónica. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000118/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "4.2. Aplicaciones del principio de dualidad. Puntos fijos e hiperplanos invariantes. Haces de hiperplanos. Colineaciones y correlaciones. Relación entre correlaciones y cuádricas proyectivas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000118/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Referencias proyectivas y coordenadas homogéneas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000118/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "1.3. Subespacios proyectivos. Operaciones con subespacios Ecuaciones de subespacios proyectivos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000118/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "1.4. Completación proyectiva de espacios afines, referencias afines y subespacios afines. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000118/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "2. Aplicaciones Proyectivas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000118/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "2.1. Aplicaciones proyectivas y representación matricial. Puntos fijos y subespacios invariantes. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000118/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "2.2. Completación proyectiva de aplicaciones afines. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000118/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "2.3. Algunas aplicaciones proyectivas. Elaciones y homologías. Proyecciones cónicas. Proyectividades involutivas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000118/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "2.4. Clasificación de proyectividades en la recta y en el plano proyectivo. Sin subniveles"@es .

