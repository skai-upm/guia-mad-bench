    schema:name "Sistemas Inteligentes"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105001035/2025-26/CE13> a ns1:Competency ;
    ns1:competencyCode "CE13" ;
    ns1:competencyDescription "Capacidad para conocer y diseñar entidades y sistemas inteligentes que incorporen capacidades como la autonomía, la situación en su entorno, la reactividad y proactividad, el aprendizaje, y habilidades sociales y organizativas, entre otras."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105001035/2025-26/CE14> a ns1:Competency ;
    ns1:competencyCode "CE14" ;
    ns1:competencyDescription "Capacidad para describir las técnicas de adquisición y representación del conocimiento, y modelos de razonamiento en entornos centralizados y distribuidos, y utilizarlas para desarrollar sistemas basados en el conocimiento orientados a la resolución de problemas y toma de decisiones que requieran conducta inteligente."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105001035/2025-26/CE16> a ns1:Competency ;
    ns1:competencyCode "CE16" ;
    ns1:competencyDescription "Capacidad para describir las técnicas de percepción y robótica cognitiva y utilizarlas para desarrollar sistemas que puedan percibir su entorno y desempeñar tareas de manipulación, navegación y planificación de su comportamiento, con cierto grado de autonomía."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105001035/2025-26/CG01> a ns1:Competency ;
    ns1:competencyCode "CG01" ;
    ns1:competencyDescription "Capacidad de trabajo en equipo, en entornos interdisciplinares y complejos, negociando y resolviendo conflictos, diseñando soluciones eficientes, fiables, robustas y responsables."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105001035/2025-26/RA115> a ns1:LearningResult ;
    ns1:learningResultCode "RA115" ;
    ns1:learningResultDescription "Diseñar y construir sistemas informáticos capaces de resolver problemas para los que no se conoce solución."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105001035/2025-26/RA116> a ns1:LearningResult ;
    ns1:learningResultCode "RA116" ;
    ns1:learningResultDescription "Dado un problema real elegir la tecnología de ciencia de datos o de inteligencia artificial existente en el mercado más apropiada para su solución y diseñar su desarrollo e integración analizando la viabilidad de su solución, lo que se puede y no se puede conseguir a través del estado actual de desarrollo de la tecnología usada, y lo que se espera que avance en el futuro"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105001035/2025-26/RA73> a ns1:LearningResult ;
    ns1:learningResultCode "RA73" ;
    ns1:learningResultDescription "RA"@es .

