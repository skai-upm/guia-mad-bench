    ns1:otherInformation "A lo largo de curso se contará con profesores colaboradores y especialistas relacionados con el sector de la información y la computación cuántica que nos darán su visión y experiencia durante algunas sesiones del curso."@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
