<https://guia-kg.skai.etsisi.upm.es/resource/33000942/2025-26/CB6> a ns1:Competency ;
    ns1:competencyCode "CB6" ;
    ns1:competencyDescription "Poseer y comprender conocimientos que aporten una base u oportunidad de ser originales en el desarrollo y/o aplicación de ideas, a menudo en un contexto de investigación.Tipo: Conocimiento"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000942/2025-26/CE4> a ns1:Competency ;
    ns1:competencyCode "CE4" ;
    ns1:competencyDescription "Capacidad para conocer en profundidad la base teórica de los procesos de la construcción industrializada y del prototipado en el proyecto arquitectónico.Tipo: Competencias"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000942/2025-26/CE5> a ns1:Competency ;
    ns1:competencyCode "CE5" ;
    ns1:competencyDescription "Capacidad para comprender los fundamentos e identificar las variables y sus categorías dentro de los procesos y estrategias de la construcción industrializada y el prototipado en el proyecto arquitectónico.Tipo: Competencias"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000942/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Capacidad para formular hipótesis innovadoras y desarrollar el proceso adecuado para ponerlo a prueba en base a criterios objetivos.Tipo: Habilidades"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000942/2025-26/CT1> a ns1:Competency ;
    ns1:competencyCode "CT1" ;
    ns1:competencyDescription "Capacidad para dinamizar y liderar equipos de trabajo multidisciplinares.Tipo: Habilidades"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000942/2025-26/CT2> a ns1:Competency ;
    ns1:competencyCode "CT2" ;
    ns1:competencyDescription "Capacidad para adoptar soluciones creativas que satisfagan adecuadamente las necesidades planteadas.Tipo: Habilidades"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000942/2025-26/CT3> a ns1:Competency ;
    ns1:competencyCode "CT3" ;
    ns1:competencyDescription "Capacidad para trabajar individualmente de forma efectiva, organizando y planificando su propio trabajo, de forma independiente o como miembro de un equipo.Tipo: Habilidades"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000942/2025-26/CT4> a ns1:Competency ;
    ns1:competencyCode "CT4" ;
    ns1:competencyDescription "Capacidad para gestionar, de una manera adecuada y eficiente, la información, identificando las fuentes Necesarias, y los diferentes tipos de documentos técnicos y científicos.Tipo: Habilidades"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000942/2025-26/CT5> a ns1:Competency ;
    ns1:competencyCode "CT5" ;
    ns1:competencyDescription "Capacidad para emitir juicios sobre las implicaciones económicas, administrativas, sociales, éticas y medioambientales, relacionadas con la aplicación de sus conocimientos.Tipo: Habilidades"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000942/2025-26/CT6> a ns1:Competency ;
    ns1:competencyCode "CT6" ;
    ns1:competencyDescription "Capacidad para trabajar en contextos internacionales.Tipo: Habilidades"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000942/2025-26/RA1> a ns1:LearningResult ;
    ns1:learningResultCode "RA1" ;
    ns1:learningResultDescription "El alumnado será capaz de incorporar aspectos relativos al clima en el proyecto arquitectónico."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000942/2025-26/RA2> a ns1:LearningResult ;
    ns1:learningResultCode "RA2" ;
    ns1:learningResultDescription "El alumnado será capaz de reconocer en que consisten las distintas áreas de la sostenibilidad y su relación con el proyecto arquitectónico."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000942/2025-26/RA3> a ns1:LearningResult ;
    ns1:learningResultCode "RA3" ;
    ns1:learningResultDescription "El alumnado podrá considerar los condicionantes logísticos en el proyecto arquitectónico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000942/2025-26/RA4> a ns1:LearningResult ;
    ns1:learningResultCode "RA4" ;
    ns1:learningResultDescription "El alumnado conocerá cuales son sus responsabilidades como técnico."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000942/2025-26/RA5> a ns1:LearningResult ;
    ns1:learningResultCode "RA5" ;
    ns1:learningResultDescription "El alumnado conocerá la normativa existente."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000942/2025-26/RA6> a ns1:LearningResult ;
    ns1:learningResultCode "RA6" ;
    ns1:learningResultDescription "El alumnado será capaz de planificar las fases del proyecto."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000942/2025-26/RA7> a ns1:LearningResult ;
    ns1:learningResultCode "RA7" ;
    ns1:learningResultDescription "El alumnado podrá identificar posibles soluciones a patentar."@es .

