<https://guia-kg.skai.etsisi.upm.es/resource/20504315> a ns1:Course ;
    ns1:courseType "Optativa"@es ;
    ns1:courseYear 3 ;
    ns1:semester "Quinto semestre"@es ;
    schema:courseCode 20504315 ;
    schema:hasCourseInstance <https://guia-kg.skai.etsisi.upm.es/resource/20504315/2025-26> ;
    schema:name "Principles Of Plant Production"@en,
        "Fundamentos de la Producción Vegetal"@es ;
    schema:numberOfCredits 3.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/20504315/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/20504315/2025-26/CB02> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/20504315/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/20504315/2025-26/didactic_resource/2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/20504315/2025-26/didactic_resource/3> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/20504315/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/20504315/2025-26/RA68>,
        <https://guia-kg.skai.etsisi.upm.es/resource/20504315/2025-26/RA69>,
        <https://guia-kg.skai.etsisi.upm.es/resource/20504315/2025-26/RA70>,
        <https://guia-kg.skai.etsisi.upm.es/resource/20504315/2025-26/RA71> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/20504315/2025-26/syllabus> ;
    ns1:inpersonHours "42 horas y 30 minutos (52.5%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation """La Comisión de Calidad del Centro en su reunión de 29 de mayo de 2023 acordó aprobar la propuesta de reasignación de competencias transversales en las asignaturas de los Grados en Biotecnología, Ingeniería Alimentaria, Ingeniería Agrícola, Ingeniería Agroambiental, Ciencias Agrarias y Bioeconomía, y en el Máster Universitario en Ingeniería Agronómica.
En virtud de dicho acuerdo esta asignatura ha sido designada como ?Asignatura NO Punto Control*?. Esto significa que si bien puede seguir trabajando una o varias competencias transversales que se abordan en distintos puntos y aspectos de la
asignatura, dicha formación y evaluación no será objeto de recopilación de evidencias por los sistemas de acreditación de la calidad del Centro.
Los alumnos habrán de dotarse de los medios mínimos para trabajar con seguridad durante las prácticas realizadas en el campo (calzado adecuado y protección solar). Aquellos alumnos que no se presenten con los medios requeridos no podrán realizar las prácticas asumiendo las consecuencias que ello pudiera acarrear en términos de evaluación de la asignatura.
Esta asignatura contribuye a ala formación de los estudiantes en los ODS, principalmente en los ODS2 (Hambre cero) y ODS6 (Agua limpia y saneamiento)."""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "44 horas y 30 minutos"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/20504315/2025-26/eventSchedule> ;
    schema:description """En esta asignatura se estudian las bases de la producción vegetal. Factores que influyen en la producción. Relación entre los cultivos y el medio. El suelo como medio físico, químico y biológico. Necesidades de agua de los cultivos y bases de la programación de riegos. Ciclo de nutrientes en el sistema de cultivo, fertilización y correcciones. Técnicas de preparación, laboreo del suelo y control de la erosión. Riego. Cultivo sin suelo. Técnicas de producción vegetal. Alternativas y rotaciones de los cultivos.
La superación de esta asignatura permite al alumno adquirir las siguientes competencias específicas de itinerario:
CEI1.1.- Capacidad de conocer, comprender y aplicar los principios de las bases de la producción y explotación vegetal.
CEI1.2.- Conocimientos básicos de los retos para la mejora de los cultivos agrícolas que puedan tener una aproximación biotecnológica"""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/miguel.quemada%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/jon.lizaso%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/miguel.quemada%40upm.es> ;
    schema:name "Fundamentos de la Producción Vegetal"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504315/2025-26/CB02> a ns1:Competency ;
    ns1:competencyCode "CB02" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar sus conocimientos a su trabajo o vocación de una forma profesional y posean las competencias que suelen demostrarse por medio de la elaboración y defensa de argumentos y la resolución de problemas dentro de su área de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504315/2025-26/RA68> a ns1:LearningResult ;
    ns1:learningResultCode "RA68" ;
    ns1:learningResultDescription "Conocer las características generales de un ecosistema agrícola y sus componentes, en relación con los ecosistemas naturales no manipulados por el hombre."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504315/2025-26/RA69> a ns1:LearningResult ;
    ns1:learningResultCode "RA69" ;
    ns1:learningResultDescription "Comprender las funciones del suelo y del clima en el sistema agrario y su influencia en los procesos fisiológicos y productivos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504315/2025-26/RA70> a ns1:LearningResult ;
    ns1:learningResultCode "RA70" ;
    ns1:learningResultDescription "Conocer las interacciones agua"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504315/2025-26/RA71> a ns1:LearningResult ;
    ns1:learningResultCode "RA71" ;
    ns1:learningResultDescription "Conocer las técnicas agronómicas aplicables a la producción vegetal"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504315/2025-26/didactic_resource/1> a ns1:DidacticResource ;
    ns1:bibliographyDescription "Medidor área foliar, medidor de la conductividad hídrica de la hoja, medidores de humedad del suelo, medidores de actividad clorofílica de la planta"@es ;
    ns1:bibliographyTitle "Equipos para el seguimiento del cultivo"@es ;
    ns1:bibliographyType "Equipamiento"@es .

