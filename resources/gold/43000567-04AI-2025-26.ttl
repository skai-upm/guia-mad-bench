    schema:name "Transport Demands Models"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000567/2025-26/MICCPCE28> a ns1:Competency ;
    ns1:competencyCode "MICCPCE28" ;
    ns1:competencyDescription "Conocimientos de la ingeniería y planificación del transporte, funciones y modos de transporte, el transporte urbano, la gestión de los servicios públicos de transporte, la demanda, los costes, la logística y la financiación de las infraestructuras y servicios de transporte. Incorpora las competencias CB6, CB7 y CB8."@es .

