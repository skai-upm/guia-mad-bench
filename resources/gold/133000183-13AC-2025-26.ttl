<https://guia-kg.skai.etsisi.upm.es/resource/133000183> a ns1:Course ;
    ns1:courseType "Obligatoria"@es ;
    ns1:courseYear 1 ;
    ns1:semester "Segundo semestre"@es ;
    schema:courseCode 133000183 ;
    schema:hasCourseInstance <https://guia-kg.skai.etsisi.upm.es/resource/133000183/2025-26> ;
    schema:name "Design Of Ciruclar Products And Services Ecodesign"@en,
        "Diseño de Productos y Servicios Circulares Ecodiseño"@es ;
    schema:numberOfCredits 3.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/133000183/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/133000183/2025-26/CG03> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/133000183/2025-26/didactic_resource/1> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/133000183/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/133000183/2025-26/RA10> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/133000183/2025-26/syllabus> ;
    ns1:inpersonHours "39 horas (50%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation """*Todo lo mencionado en esta guía de aprendizaje está sujeto a adaptaciones por el personal de la unidad docente en función del número de estudiantes y otras circunstancias que pudieran suceder con el fin de asegurar la calidad de aprendizaje.
Esta asignatura empieza su impartición en el segundo semestre con un esquema de presencialidad definido. En caso de un cambio en las condiciones sanitarias que obligara a un confinamiento total o parcial, habría que hacer una replanificación con las correspondientes adendas.
LAS COMPETENCIAS Y LOS RESULTADOS DE APRENDIZAJE DE ESTA ASIGNATURA SON CONFORMES CON LA MEMORIA VERIFICA DEL TÍTULO
ODS que aborda la asignatura: 6, 7, 9, 11,12 y 13"""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "40 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/133000183/2025-26/eventSchedule> ;
    schema:description "La asignatura de Ecodiseño se centra en la integración de principios de sostenibilidad en el proceso de diseño de productos y servicios, con el objetivo de minimizar su impacto ambiental a lo largo de todo su ciclo de vida. A través de una combinación de teoría y práctica, los estudiantes aprenderán a aplicar herramientas y metodologías de ecodiseño que fomenten la eficiencia en el uso de recursos, la reducción de residuos y el uso de materiales sostenibles. La asignatura también aborda la evaluación del rendimiento ambiental de productos y la búsqueda de soluciones innovadoras que contribuyan a una economía circular."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/a.garciai%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/a.garciai%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/belen.vazquezdequevedo%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/jv.lopez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/miguel.aguilar%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/sigfredo.ortuno%40upm.es> ;
    schema:name "Diseño de Productos y Servicios Circulares Ecodiseño"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000183/2025-26/CG03> a ns1:Competency ;
    ns1:competencyCode "CG03" ;
    ns1:competencyDescription "El alumno tendrá capacidad para evaluar los procesos de producción y consumo que permitan una gestión sostenible de los recursos."@es .

