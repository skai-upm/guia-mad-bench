<https://guia-kg.skai.etsisi.upm.es/resource/45000152/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Reading skills in academic and professional English for materials engineering"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000152/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Locating main and subsidiary information in complex sentences, paragraphs and texts. Reading techniques: scanning and skimming. Identifying coherence and cohesion in materials engineering texts. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000152/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "2.5. Creating awareness of different written registers and selecting the formal register in technical writing. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000152/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "2.6. The report layout: abstract, introduction, method, materials results and discussion, conclusion and bibliographical references. Writing a materials engineering (laboratory) report. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000152/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "2.7. The layout of letters in academic and professional contexts: addresses, salutation, main body ending and closing stages. Professional writing (résumés and cover letters). Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000152/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "2.8. Referencing bibliographical sources in materials engineering. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000152/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "3. Listening skills in academic and professional English for materials engineering"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000152/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "3.1. Listening to lectures. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000152/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "3.2. Predicting lecture content from the introduction. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000152/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "3.3. Identifying main and subsidiary ideas. Digressions. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000152/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "3.4. Note taking using abbreviations and symbols. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000152/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "3.5. Organizing notes. Sin subniveles"@es .

