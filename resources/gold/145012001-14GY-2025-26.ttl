    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/145012001/2025-26/eventSchedule> ;
    schema:description "La asignatura comprende un curso estándar de Estadística Descriptiva aplicada a la gestión. Se definen los conceptos de probabilidad y variable aleatoria y se introducen algunos modelos de probabilidad típicos. Además, se introducen los conceptos de muestreo, estimación y contraste de hipótesis. Se intenta que el alumno sea capaz de extraer conclusiones estadísticas razonadas en base a distintas técnicas de manipulación de datos introduciendo las técnicas de regresión lineal simple y múltiple."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/guiomar.ruiz%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/guiomar.ruiz%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/jesus.garicano.mena%40upm.es> ;
    schema:name "Estadística"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145012001/2025-26/CB03> a ns1:Competency ;
    ns1:competencyCode "CB03" ;
    ns1:competencyDescription "Que los estudiantes tengan la capacidad de reunir e interpretar datos relevantes (normalmente dentro de su área de estudio) para emitir juicios que incluyan una reflexión sobre temas relevantes de índole social, científica o ética"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145012001/2025-26/CB05> a ns1:Competency ;
    ns1:competencyCode "CB05" ;
    ns1:competencyDescription "Que los estudiantes hayan desarrollado aquellas habilidades de aprendizaje necesarias para emprender estudios posteriores con un alto grado de autonomía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145012001/2025-26/CE01> a ns1:Competency ;
    ns1:competencyCode "CE01" ;
    ns1:competencyDescription "Capacidad para la resolución de los problemas matemáticos que puedan plantearse en el ámbito de la gestión y operación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145012001/2025-26/CG01> a ns1:Competency ;
    ns1:competencyCode "CG01" ;
    ns1:competencyDescription "Capacidad para llevar a cabo actividades de proyección, de dirección técnica, de redacción de informes, y de asesoramiento técnico en tareas relativas a la industria del Transporte Aéreo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145012001/2025-26/CG04> a ns1:Competency ;
    ns1:competencyCode "CG04" ;
    ns1:competencyDescription "Capacidad para analizar implicaciones económicas, administrativas, sociales o medioambientales ligadas a la aplicación de nuevos conceptos y técnicas en el ámbito de la Gestión y Operación del Transporte Aéreo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145012001/2025-26/CT03> a ns1:Competency ;
    ns1:competencyCode "CT03" ;
    ns1:competencyDescription "Capacidad para identificar y resolver problemas aplicando, con creatividad, los conocimientos adquiridos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145012001/2025-26/CT07> a ns1:Competency ;
    ns1:competencyCode "CT07" ;
    ns1:competencyDescription "Habilidad para la comunicación oral y escrita"@es .

