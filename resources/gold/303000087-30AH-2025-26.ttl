<https://guia-kg.skai.etsisi.upm.es/resource/303000087/2025-26/RA17> a ns1:LearningResult ;
    ns1:learningResultCode "RA17" ;
    ns1:learningResultDescription "Modelar y realizar las simplificaciones adecuadas en modelos de vigas y placas que faciliten su análisis"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000087/2025-26/RA18> a ns1:LearningResult ;
    ns1:learningResultCode "RA18" ;
    ns1:learningResultDescription "Modelar y realizar las simplificaciones adecuadas en mecánica de fluidos que faciliten su análisis"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000087/2025-26/RA19> a ns1:LearningResult ;
    ns1:learningResultCode "RA19" ;
    ns1:learningResultDescription "Conocer y entender la relevancia de las leyes de conservación en la modelización de la mecánica de medios continuos sólidos y fluidos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000087/2025-26/RA20> a ns1:LearningResult ;
    ns1:learningResultCode "RA20" ;
    ns1:learningResultDescription "Conocer las ecuaciones que gobiernan la mecánica de fluidos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000087/2025-26/RA21> a ns1:LearningResult ;
    ns1:learningResultCode "RA21" ;
    ns1:learningResultDescription "Entender el análisis de estabilidad para modelos dinámicos"@es .

