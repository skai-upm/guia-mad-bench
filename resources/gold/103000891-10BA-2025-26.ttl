<https://guia-kg.skai.etsisi.upm.es/resource/103000891/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. General Context (scientific knowledge and its purpose, problems of scientific research, research work) / Planteamiento general (El conocimiento científico y su finalidad, problemática de la investigación científica, trabajos de investigación) Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000891/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "2. Scientific Work (choice of subject, setting objectives, formulating hypotheses, work method, tools and resources) / El trabajo científico (elección de tema, determinación de objetivos, formulación de hipótesis, método de trabajo, instrumentos y recursos) Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000891/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "3. Information Search (sources, publications, bibliographical searches, access to scientific documentation, etc.) / Búsqueda de información (fuentes, publicaciones, búsquedas bibliográficas, acceso a la documentación científica, internet,...) Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000891/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "4. Presentation and Defence of Work (legal aspects, formal aspects, visual aids to support the presentation) / Exposición y defensa del trabajo realizado (aspectos legales, aspectos formales, medios visuales como apoyo a la exposición) Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000891/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "5. Open Science principles applied to Research / Principios de la Ciencia Abierta Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000891/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "6. Intellectual Property Rights and Innovation / Propiedad Intelectual e Innovación Sin subniveles"@es .

