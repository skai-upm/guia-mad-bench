        <https://guia-kg.skai.etsisi.upm.es/resource/33000861/2025-26/K9>,
        <https://guia-kg.skai.etsisi.upm.es/resource/33000861/2025-26/SK1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/33000861/2025-26/SK11>,
        <https://guia-kg.skai.etsisi.upm.es/resource/33000861/2025-26/SK4>,
        <https://guia-kg.skai.etsisi.upm.es/resource/33000861/2025-26/SK7>,
        <https://guia-kg.skai.etsisi.upm.es/resource/33000861/2025-26/SK8> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/33000861/2025-26/didactic_resource/1> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/33000861/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/33000861/2025-26/RA31> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/33000861/2025-26/syllabus> ;
    ns1:inpersonHours "32 horas (30.8%)"@es ;
    ns1:numberOfCredits 4.0 ;
    ns1:otherInformation """La asignatura se relaciona con el ODS11 Ciudades y comunidades sostenibles.
Desarrollado desde un enfoque que proyecto de comunidades de vivienda mas relisentes y con un menor consumo de energia. Se estudian proyecto que cumplen con estos parámetros que se utilizarán como caso de estudio, análisis y crítica."""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "32 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/33000861/2025-26/eventSchedule> ;
    schema:description """TEORÍA
01 _ Explicación del tema de seminario. La ciudad americana en transformación.
02 _ Formas de vida. El futuro de la vivienda.
03_ Homelessness. La vivienda minima.
04_ Densidades Media_ La costa Oeste. Estudio de casos
05_ TOOLKITS / ADU?s como alternativas
06_ clase de Rene Davis/ introducción a la vivienda en la costa de california.
07_ Métodos de análisis. Referentes. Estudio de casos
08_ Análisis, comparación y crítica
09_ Proposición de temas de crítica e investigación.
CRÍTICA
09_ Presentación estructura de cada investigación.
10_ Presentación primera textos críticos y diagramas explicativos
11_ Análisis y crítica de referentes
12_ Análisis y crítica de referentes
13_ Presentación intermedia de textos y diagramas
14_ Presentación intermedia de textos y diagramas
15_ Presentación intermedia de textos y diagramas
PRESENTACIÓN FINAL
16_ Presentación final de textos y diagramas
17_ Fin de seminario"""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/nicolas.maruri%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/nicolas.maruri%40upm.es> ;
    schema:name "Escenarios de lo Contemporáneo 3 Ot"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000861/2025-26/C1> a ns1:Competency ;
    ns1:competencyCode "C1" ;
    ns1:competencyDescription "Elaborar y redactar conclusiones deducidas de los análisis y estudios realizados sobre obras o textos de proyectos arquitectónicos TIPO: Competencias."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000861/2025-26/C6> a ns1:Competency ;
    ns1:competencyCode "C6" ;
    ns1:competencyDescription "Desarrollar laboratorios de pensamiento desde la teoría y crítica contemporánea en el comportamiento de las geometrías y topologías complejas en el proyecto arquitectónico TIPO: Competencias."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000861/2025-26/K1> a ns1:Competency ;
    ns1:competencyCode "K1" ;
    ns1:competencyDescription "Analizar críticamente obras arquitectónicas TIPO: Conocimientos o contenidos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000861/2025-26/K2> a ns1:Competency ;
    ns1:competencyCode "K2" ;
    ns1:competencyDescription "Conocer en profundidad la historia del proyecto arquitectónico, influencias culturales que hayan podido vincularse al mismo, así como técnicas avanzadas de diseño arquitectónico TIPO: Conocimientos o contenidos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000861/2025-26/K3> a ns1:Competency ;
    ns1:competencyCode "K3" ;
    ns1:competencyDescription "Relacionar diferentes proyectos arquitectónicos, así como las estrategias y tácticas aplicadas en ellos TIPO: Conocimientos o Contenidos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000861/2025-26/K8> a ns1:Competency ;
    ns1:competencyCode "K8" ;
    ns1:competencyDescription "Enunciar tesis novedosas a partir de una información que, siendo limitada, incluya reflexiones sobre las responsabilidades sociales y éticas del proyecto arquitectónico TIPO: Conocimientos o contenidos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000861/2025-26/K9> a ns1:Competency ;
    ns1:competencyCode "K9" ;
    ns1:competencyDescription "Explicar de forma efectiva ideas y proyectos a través de presentaciones y publicaciones TIPO: Conocimientos o contenidos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000861/2025-26/RA31> a ns1:LearningResult ;
    ns1:learningResultCode "RA31" ;
    ns1:learningResultDescription "Los resultados del aprendizaje correspondientes a esta asignatura han quedado definidos en el apartado de competencias de este documento, señalando los que corresponden a conocimientos, habilidades y competencias propiamente dichas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000861/2025-26/SK1> a ns1:Competency ;
    ns1:competencyCode "SK1" ;
    ns1:competencyDescription "Aplicar a entornos nuevos o poco conocidos, dentro de contextos más amplios (o multidisciplinares), los conceptos, principios, teorías o modelos relacionados con el área de pensamiento teórico del proyecto arquitectónico TIPO: Habilidades o destrezas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000861/2025-26/SK11> a ns1:Competency ;
    ns1:competencyCode "SK11" ;
    ns1:competencyDescription "Proponer investigaciones sobre éticas ambientales y prácticas sostenibles dentro del ámbito del proyecto arquitectónico TIPO: Habilidades o destrezas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000861/2025-26/SK4> a ns1:Competency ;
    ns1:competencyCode "SK4" ;
    ns1:competencyDescription "Emitir juicios en función de criterios, de normas externas o de reflexiones personales, que se puedan apoyar en información limitada que incluya reflexiones sobre las responsabilidades sociales y éticas vinculadas a la aplicación de sus conocimientos y juicios en el ámbito del proyecto arquitectónico TIPO: Habilidades o destrezas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000861/2025-26/SK7> a ns1:Competency ;
    ns1:competencyCode "SK7" ;
    ns1:competencyDescription "Investigar con una mirada interdisciplinar en el ámbito del proyecto arquitectónico, integrando procesos y estrategias experimentales en la definición del proyecto TIPO: Habilidades o destrezas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000861/2025-26/SK8> a ns1:Competency ;
    ns1:competencyCode "SK8" ;
    ns1:competencyDescription "Detectar contextos contemporáneos en el ámbito del proyecto arquitectónico, desde el análisis de la escena contemporánea TIPO: Habilidades o destrezas."@es .

