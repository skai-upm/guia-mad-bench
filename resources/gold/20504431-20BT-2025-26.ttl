    ns1:courseType "Optativa"@es ;
    ns1:courseYear 4 ;
    ns1:semester "Octavo semestre"@es ;
    schema:courseCode 20504431 ;
    schema:hasCourseInstance <https://guia-kg.skai.etsisi.upm.es/resource/20504431/2025-26> ;
    schema:name "Advanced Immunology"@en,
        "Inmunología Aplicada"@es ;
    schema:numberOfCredits 5.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/20504431/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/20504431/2025-26/CE29> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/20504431/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/20504431/2025-26/didactic_resource/2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/20504431/2025-26/didactic_resource/3> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/20504431/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/20504431/2025-26/RA129>,
        <https://guia-kg.skai.etsisi.upm.es/resource/20504431/2025-26/RA131>,
        <https://guia-kg.skai.etsisi.upm.es/resource/20504431/2025-26/RA132>,
        <https://guia-kg.skai.etsisi.upm.es/resource/20504431/2025-26/RA133>,
        <https://guia-kg.skai.etsisi.upm.es/resource/20504431/2025-26/RA134>,
        <https://guia-kg.skai.etsisi.upm.es/resource/20504431/2025-26/RA264> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/20504431/2025-26/syllabus> ;
    ns1:inpersonHours "81 horas (60%)"@es ;
    ns1:numberOfCredits 5.0 ;
    ns1:otherInformation """- Si el aumento en el número de alumnos o alguna pandemia dificultara la organización de las prácticas en hospitales, serán sustituidas por resolución de casos prácticos (actividad del tipo clase de problemas).
- Si el aumento en el número de alumnos o alguna pandemia dificultara la presentación presencial del trabajo en grupo, se considerará la posibilidad de presentarlo de forma no presencial o de que sea un trabajo voluntario.
- Si alguna pandemia o acontecimiento relevante diferente dificulta la actividad presencial, tanto las clases teóricas como los exámenes podrán pasarse a formato telemático."""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "82 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/20504431/2025-26/eventSchedule> ;
    schema:description """BLOQUE 1 (B1). Inmunodeficiencias primarias y secundarias (Temas 1-6, 10h)
BLOQUE 2 (B2). Reacciones de Hipersensibilidad (Temas 7-16, 16h)
BLOQUE 3 (B3). Enfermedades autoinmunes (Temas 17-26, 11h)
BLOQUE 4 (B4). Prevención y tratamiento de las enfermedades inmunológicas (Temas 27-34, 14h)"""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/ca.blanco%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/ca.blanco%40upm.es> ;
    schema:name "Inmunología Aplicada"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504431/2025-26/CE29> a ns1:Competency ;
    ns1:competencyCode "CE29" ;
    ns1:competencyDescription "Capacidad para conocer y comprender los distintos tipos de respuesta inmune, los tipos celulares implicados, los factores que desencadenan la respuesta y la importancia de la biotecnología en el desarrollo de vacunas y anticuerpos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504431/2025-26/RA129> a ns1:LearningResult ;
    ns1:learningResultCode "RA129" ;
    ns1:learningResultDescription "Conocer las bases moleculares de las enfermedades causadas por agentes transmisibles, deficiencias del sistema inmune y defectos de estructuras moleculares"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504431/2025-26/RA131> a ns1:LearningResult ;
    ns1:learningResultCode "RA131" ;
    ns1:learningResultDescription "Conocer las aplicaciones de la inmunología a la prevención y tratamiento de las enfermedades."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504431/2025-26/RA132> a ns1:LearningResult ;
    ns1:learningResultCode "RA132" ;
    ns1:learningResultDescription "Conocer las aplicaciones de la inmunología al diagnóstico de las enfermedades"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504431/2025-26/RA133> a ns1:LearningResult ;
    ns1:learningResultCode "RA133" ;
    ns1:learningResultDescription "Conocer los conceptos fundamentales de la inmunidad celular, de la autoinmunidad y de las reacciones de hipersensibilidad, a un nivel elemental."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504431/2025-26/RA134> a ns1:LearningResult ;
    ns1:learningResultCode "RA134" ;
    ns1:learningResultDescription "Conocer las bases de la reacción inmune, con especial atención a la inmunidad humoral"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504431/2025-26/RA264> a ns1:LearningResult ;
    ns1:learningResultCode "RA264" ;
    ns1:learningResultDescription "Conocer los conceptos fundamentales de la inmunidad celular, de la autoinmunidad y de las reacciones de hipersensibilidad, a un nivel avanzado."@es .

