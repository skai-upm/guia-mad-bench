<https://guia-kg.skai.etsisi.upm.es/resource/95000583/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/95000583/2025-26/CE17>,
        <https://guia-kg.skai.etsisi.upm.es/resource/95000583/2025-26/CE18>,
        <https://guia-kg.skai.etsisi.upm.es/resource/95000583/2025-26/CG02> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/95000583/2025-26/didactic_resource/1>,
