<https://guia-kg.skai.etsisi.upm.es/resource/123000719/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Principios físicos fundamentales que intervienen en un sistema de Teledetección espacial de observación de la Tierra (ObT) Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/123000719/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "2. Modelización y Correcciones atmosféricas en el espectro visible, infrarrojo y térmico. Variables biofísicas de la superficie terrestre. Teledetección hiperespectral. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/123000719/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "3. Cartografía Ambiental y Temática a partir de Sistemas Espaciales de Observación de la Tierra. Georreferenciación de productos satelitales de ObT. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/123000719/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "4. Sistemas radar para la observación de la Tierra. Polarimetría SAR & Interferometría SAR Sin subniveles"@es .

