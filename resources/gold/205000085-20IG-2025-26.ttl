<https://guia-kg.skai.etsisi.upm.es/resource/205000085/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. MECÁNICA DE MATERIALES"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000085/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. CONCEPTOS GENERALES"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000085/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "1.2.1. Tracción y compresión puras. Distribución de tensiones, estudio de la deformación y cálculo de desplazamientos. Hiperestatismo. Efectos de la temperatura y de las deformaciones forzadas. Sistemas hiperestáticos en tracción-compresión Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000085/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "1.2.2. Introducción a la flexión. Tipos de flexión: pura, simple, y compuesta. Concepto y definición de: deformada, plano de flexión, centro y radio de curvatura, fibra neutra Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000085/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "1.2.3. Cortadura pura. Esfuerzo cortante. Tensiones y deformaciones cortantes en secciones de gran espesor. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000085/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "1.2.4. Flexión pura. Distribución de tensiones. Ley de Navier. Modulo resistente de una sección. Sección ideal Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000085/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "1.2.5. Flexión simple. Tensiones normales y tensiones cortantes. Distribución de tensiones. Ley de Navier. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000085/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "1.2.6. Flexión compuesta. Flexión esviada Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000085/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "1.2.7. Deformación por flexión. Curvatura. Ecuación de la elástica. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000085/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "1.2.8. Vigas hiperestáticas. Cálculo de reacciones, deformaciones y diagramas de esfuerzos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000085/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "1.2.9. Columnas cortas. Flexo-compresión. Núcleo de una sección transversal. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000085/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "1.2.10. Estabilidad elástica. Pandeo. Teoría de Euler para piezas ideales. Concepto de carga crítica. Longitud de pandeo. Esbeltez mecánica. Tensión crítica e Hipérbola de Euler. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000085/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.1.1. El sólido deformable. Hipótesis simplificadoras. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000085/2025-26/syllabus/20> a ns1:SyllabusItem ;
    ns1:itemIndex 20 ;
    ns1:syllabusDescription "2. ANÁLISIS ESTRUCTURAL"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000085/2025-26/syllabus/21> a ns1:SyllabusItem ;
    ns1:itemIndex 21 ;
    ns1:syllabusDescription "2.1. GENERALIDADES ESTRUCTURALES"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000085/2025-26/syllabus/22> a ns1:SyllabusItem ;
    ns1:itemIndex 22 ;
    ns1:syllabusDescription "2.1.1. Definición de nudo libre: Rígido y articulado. Definición de barra. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000085/2025-26/syllabus/23> a ns1:SyllabusItem ;
    ns1:itemIndex 23 ;
    ns1:syllabusDescription "2.1.2. Tipologías estructurales sencillas Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000085/2025-26/syllabus/24> a ns1:SyllabusItem ;
    ns1:itemIndex 24 ;
    ns1:syllabusDescription "2.1.3. Cálculo de estructuras por métodos informáticos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000085/2025-26/syllabus/25> a ns1:SyllabusItem ;
    ns1:itemIndex 25 ;
    ns1:syllabusDescription "2.2. ESTRUCTURAS DE NUDOS ARTICULADOS"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000085/2025-26/syllabus/26> a ns1:SyllabusItem ;
    ns1:itemIndex 26 ;
    ns1:syllabusDescription "2.2.1. Cálculo de estructuras de nudos articulados. Estabilidad estructural. Isostatismo e hiperestatismo. Cálculo de reacciones y de esfuerzos por métodos analíticos y gráficos Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000085/2025-26/syllabus/27> a ns1:SyllabusItem ;
    ns1:itemIndex 27 ;
    ns1:syllabusDescription "2.3. ESTRUCTURAS DE. NUDOS RIGIDOS"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000085/2025-26/syllabus/28> a ns1:SyllabusItem ;
    ns1:itemIndex 28 ;
    ns1:syllabusDescription "2.3.1. Cálculo de estructuras de nudos rígidos. Equilibrio de un nudo rígido. Rigidez de una barra asociada a un nudo. Concepto de momento repartido. Método de Cross. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000085/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "1.1.2. Equilibrio externo: Acciones y reacciones. Sistemas isostáticos e hiperestáticos Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000085/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "1.1.3. Equilibrio interno: conceptos de tensión y esfuerzo. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000085/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "1.1.4. Leyes y diagramas de esfuerzos. Principio de Superposición. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000085/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "1.1.5. Tensión. Tensiones normales y cortantes. Estado tensional en un punto. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000085/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "1.1.6. Movimiento y deformación. Estado de deformación en un punto. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000085/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "1.1.7. Relaciones entre tensiones y deformaciones. Ley de Hooke. Ensayos experimentales. Materiales lineales y no lineales. Diagramas tensión-deformación. Coeficiente de Poisson Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000085/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "1.2. SOLICITACIONES EN ELEMENTOS ESTRUCTURALES"@es .

