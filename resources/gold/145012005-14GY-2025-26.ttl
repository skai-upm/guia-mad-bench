    schema:name "Servicios e Infraestructuras Aeronáuticas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145012005/2025-26/CB02> a ns1:Competency ;
    ns1:competencyCode "CB02" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar sus conocimientos a su trabajo o vocación de una forma profesional y posean las competencias que suelen demostrarse por medio de la elaboración y defensa de argumentos y la resolución de problemas dentro de su área de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145012005/2025-26/CB04> a ns1:Competency ;
    ns1:competencyCode "CB04" ;
    ns1:competencyDescription "Que los estudiantes puedan transmitir información, ideas, problemas y soluciones a un público tanto especializado como no especializado"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145012005/2025-26/CE13> a ns1:Competency ;
    ns1:competencyCode "CE13" ;
    ns1:competencyDescription "Conocimiento adecuado de los fundamentos de sostenibilidad, mantenibilidad y operatividad de los aeropuertos y sus infraestructuras"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145012005/2025-26/CG05> a ns1:Competency ;
    ns1:competencyCode "CG05" ;
    ns1:competencyDescription "Capacidad para la búsqueda y utilización de la normativa y reglamentación relativa a su ámbito de actuación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145012005/2025-26/CT02> a ns1:Competency ;
    ns1:competencyCode "CT02" ;
    ns1:competencyDescription "Capacidad para el uso de la lengua inglesa"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145012005/2025-26/CT07> a ns1:Competency ;
    ns1:competencyCode "CT07" ;
    ns1:competencyDescription "Habilidad para la comunicación oral y escrita"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145012005/2025-26/CT08> a ns1:Competency ;
    ns1:competencyCode "CT08" ;
    ns1:competencyDescription "Capacidad de integrar el respeto al medio ambiente en el desarrollo de sus actividades"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145012005/2025-26/CT09> a ns1:Competency ;
    ns1:competencyCode "CT09" ;
    ns1:competencyDescription "Razonamiento crítico y capacidad de asociación que posibiliten el aprendizaje continuo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145012005/2025-26/RA78> a ns1:LearningResult ;
    ns1:learningResultCode "RA78" ;
    ns1:learningResultDescription "Conoce y comprende las distintas infraestructuras aeroportuarias y la navegación aérea y aplica convenientemente ese conocimiento para distinguirlas y clasificarlas adecuadamente."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145012005/2025-26/RA79> a ns1:LearningResult ;
    ns1:learningResultCode "RA79" ;
    ns1:learningResultDescription "Es capaz de valorar los roles de los aeropuertos y su relación con las compañías en el contexto del transporte aéreo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145012005/2025-26/RA80> a ns1:LearningResult ;
    ns1:learningResultCode "RA80" ;
    ns1:learningResultDescription "Es capaz de interpretar la operación aeroportuaria y sus repercusiones respecto del mercado del transporte aéreo, del dimensionamiento aeroportuario y de las características del pasajero."@es .

