<https://guia-kg.skai.etsisi.upm.es/resource/55000701/2025-26/RA374> a ns1:LearningResult ;
    ns1:learningResultCode "RA374" ;
    ns1:learningResultDescription "Reconocer e implementar buenas prácticas científicas de medida y experimentación."@es .

