<https://guia-kg.skai.etsisi.upm.es/resource/55000701/2025-26/RA573> a ns1:LearningResult ;
    ns1:learningResultCode "RA573" ;
    ns1:learningResultDescription "Capacidad y destreza para proyectar y llevar a cabo investigaciones experimentales, interpretar resultados y llegar a conclusiones en su campo de estudio"@es .

