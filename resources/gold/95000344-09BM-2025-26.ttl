    ns1:competencyCode "CE23" ;
    ns1:competencyDescription "Capacidad para conocer, utilizar y diseñar sistemas de información y comunicaciones en sanidad y biomedicina"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000344/2025-26/CE27> a ns1:Competency ;
    ns1:competencyCode "CE27" ;
    ns1:competencyDescription "Conocer los sistemas actuales y saber diseñar sistemas de consulta médica a través de redes de comunicaciones"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000344/2025-26/CG01> a ns1:Competency ;
    ns1:competencyCode "CG01" ;
    ns1:competencyDescription "Desarrollar las habilidades de aprendizaje necesarias para emprender actividades o estudios posteriores de forma autónoma y con confianza."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000344/2025-26/CG02> a ns1:Competency ;
    ns1:competencyCode "CG02" ;
