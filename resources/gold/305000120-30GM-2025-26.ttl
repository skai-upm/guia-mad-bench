    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/305000120/2025-26/eventSchedule> ;
    schema:description """Esta asignatura es una introducción a las funciones derivables de una variable compleja y sus propiedades principales, que las distinguen de las funciones de dos variables reales: desarrollo en series de potencias, conjunto de ceros, estimaciones de crecimiento, integración sobre curvas cerradas, singularidades, etc. Si la concreción temporal de las clases lo permitiera, se incluiría además un tema sobre aplicaciones coformes y el Teorema de la Aplicación de Riemann.

Para presentar esta asignatura se ha elegido el libro "Complex Analysis" de Donald Marshall, con el que se comparte el punto de vista de explotar las propiedades de las funciones analíticas (en algún sentido, polinomios de grado infinito) para luego demostrar la equivalencia de analiticidad y holomorfía y a partir de ahí desarrollar la teoría de Cauchy.
Para superar la materia tratada en esta asignatura es necesario dominar conceptos de análisis de funciones reales en una y varias variables, cálculo vectorial y topología."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/alicia.canton%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/alicia.canton%40upm.es> ;
    schema:name "Análisis Complejo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000120/2025-26/CE1> a ns1:Competency ;
    ns1:competencyCode "CE1" ;
    ns1:competencyDescription "Comprender y utilizar el lenguaje matemático. Adquirir la capacidad para enunciar propiedades en distintos campos de la Matemática, para construir argumentaciones, elaborar cálculos y para transmitir los conocimientos matemáticos adquiridos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000120/2025-26/CE2> a ns1:Competency ;
    ns1:competencyCode "CE2" ;
    ns1:competencyDescription "Conocer y comprender demostraciones rigurosas de los principales teoremas de cada área de la Matemática y extraer de ellos corolarios mediante la particularización a casos concretos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000120/2025-26/CE3> a ns1:Competency ;
    ns1:competencyCode "CE3" ;
    ns1:competencyDescription "Asimilar la definición de un nuevo objeto matemático, en términos de otros ya conocidos, y ser capaz de utilizar este objeto en diferentes contextos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000120/2025-26/CE5> a ns1:Competency ;
    ns1:competencyCode "CE5" ;
    ns1:competencyDescription "Comprobar con demostraciones hipótesis sobre un objeto matemático o refutarlas con contraejemplos, así como identificar errores en razonamientos incorrectos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000120/2025-26/CE7> a ns1:Competency ;
    ns1:competencyCode "CE7" ;
    ns1:competencyDescription "Resolver problemas de Matemáticas, mediante habilidades de cálculo básico y tecnologías de computación, planificando su resolución en función de las herramientas de que se disponga y de las restricciones de tiempo y recursos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000120/2025-26/CG5> a ns1:Competency ;
    ns1:competencyCode "CG5" ;
    ns1:competencyDescription "Sintetizar conocimientos y habilidades adquiridas en el campo de la matemática en diferentes materias del plan de estudios para enfocarlas en posteriores estudios especializados, tanto en una disciplina matemática como en cualquiera de las ciencias que requieran buenos fundamentos matemáticos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000120/2025-26/CT2> a ns1:Competency ;
    ns1:competencyCode "CT2" ;
    ns1:competencyDescription "Organizar y planificar tareas y proyectos, identificando objetivos, prioridades, plazos, recursos y riesgos, y controlando los procesos establecidos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000120/2025-26/RA173> a ns1:LearningResult ;
    ns1:learningResultCode "RA173" ;
    ns1:learningResultDescription "Describir, probar y aplicar las propiedades fundamentales de las funciones holomorfas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000120/2025-26/RA174> a ns1:LearningResult ;
    ns1:learningResultCode "RA174" ;
    ns1:learningResultDescription "Representación de funciones holomorfas como series de Taylor o de Laurent."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000120/2025-26/RA175> a ns1:LearningResult ;
    ns1:learningResultCode "RA175" ;
    ns1:learningResultDescription "Clasificar las singularidades aisladas de funciones holomorfas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000120/2025-26/RA176> a ns1:LearningResult ;
    ns1:learningResultCode "RA176" ;
    ns1:learningResultDescription "Calcular integrales reales y complejas mediante la teoría de Cauchy"@es .

