    ns1:competencyDescription "Utilizar las ventajas que aportan las herramientas de diseño y cálculos asistidos por computador (?M"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000973/2025-26/CE2> a ns1:Competency ;
    ns1:competencyCode "CE2" ;
    ns1:competencyDescription "Realizar actividades de análisis, diseño, fabricación, ensayo y mantenimiento de máquinas, productos y dispositivos, aplicando metodologías estructuradas, considerando el ciclo de vida global."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000973/2025-26/CE3> a ns1:Competency ;
    ns1:competencyCode "CE3" ;
    ns1:competencyDescription "Utilizar conocimientos multidisciplinarios de mecánica, electrotecnia, control, medios continuos y materiales para el desarrollo de procesos, utillajes y máquinas de fabricación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000973/2025-26/CE4> a ns1:Competency ;
    ns1:competencyCode "CE4" ;
    ns1:competencyDescription "Analizar, diseñar, planificar técnicas de optimización de procesos y modelado de información e instrumentación para la mejora del ciclo de vida del producto."@es .

