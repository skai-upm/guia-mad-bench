<https://guia-kg.skai.etsisi.upm.es/resource/205000167/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Fundamentos de gestión de residuos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000167/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Tema 1. Residuos: definición, clasificación y caracterización"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000167/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "1.3.2. Leyes sobre vertidos a cauces de dominio público hidráulico y a redes de saneamiento. Comunicaciones y autorizaciones. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000167/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "1.3.3. Ley sobre calidad del aire y protección de la atmósfera. Actividades potencialmente contaminantes de la atmósfera. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000167/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "1.3.4. Ley sobre prevención y control integrados de la contaminación. Autorización Ambiental Integrada. Registro Estatal de Emisiones y Fuentes Contaminantes (PRTR). Mejores Técnicas Disponibles (MTDs). Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000167/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "1.4. Tema 4. Normas y herramientas sobre gestión ambiental"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000167/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "1.4.1. Agenda 2030 y Objetivos de Desarrollo Sostenible. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000167/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "1.4.2. Análisis del ciclo de vida. Huella de carbono. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000167/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "1.4.3. Normalización de sistemas de gestión ambiental: normas ISO 14000 y normas EMAS. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000167/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "2. Gestión de residuos sólidos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000167/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "2.1. Tema 5. Prevención, reutilización y reciclado de residuos sólidos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000167/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "2.1.1. Medidas de prevención de residuos en la industria alimentaria. Gestión de stocks, cambio de materias primas y fuentes de energía, tecnologías limpias, cogeneración, trigeneración y ciclo combinado. Medidas contra el desperdicio alimentario. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000167/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.1.1. La generación de residuos en cifras. Residuos generados en la industria alimentaria. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000167/2025-26/syllabus/20> a ns1:SyllabusItem ;
    ns1:itemIndex 20 ;
    ns1:syllabusDescription "2.1.2. Medidas de reutilización. Envases reutilizables. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000167/2025-26/syllabus/21> a ns1:SyllabusItem ;
    ns1:itemIndex 21 ;
    ns1:syllabusDescription "2.1.3. Medidas de reciclado. Compostaje de residuos orgánicos. Etapas, condiciones y evolución. Reciclado de envases de plástico, vidrio y aluminio. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000167/2025-26/syllabus/22> a ns1:SyllabusItem ;
    ns1:itemIndex 22 ;
    ns1:syllabusDescription "2.2. Tema 6. Valorización de residuos sólidos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000167/2025-26/syllabus/23> a ns1:SyllabusItem ;
    ns1:itemIndex 23 ;
    ns1:syllabusDescription "2.2.1. Valorización energética de residuos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000167/2025-26/syllabus/24> a ns1:SyllabusItem ;
    ns1:itemIndex 24 ;
    ns1:syllabusDescription "2.2.2. Tecnologías de tratamiento térmico. Incineración, pirolisis y gasificación. Combustible sólido recuperado. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000167/2025-26/syllabus/25> a ns1:SyllabusItem ;
    ns1:itemIndex 25 ;
    ns1:syllabusDescription "2.2.3. Tecnologías de tratamiento biológico. Digestión anaerobia y generación de bioetanol. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000167/2025-26/syllabus/26> a ns1:SyllabusItem ;
    ns1:itemIndex 26 ;
    ns1:syllabusDescription "2.2.4. Tecnologías de tratamiento químico. Generación de biodiésel. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000167/2025-26/syllabus/27> a ns1:SyllabusItem ;
    ns1:itemIndex 27 ;
    ns1:syllabusDescription "2.2.5. Otras formas de valorización. Bioplásticos. Extracción de compuestos de alto valor añadido (y otras formas de separación). Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000167/2025-26/syllabus/28> a ns1:SyllabusItem ;
    ns1:itemIndex 28 ;
    ns1:syllabusDescription "2.3. Tema 7. Eliminación de residuos sólidos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000167/2025-26/syllabus/29> a ns1:SyllabusItem ;
    ns1:itemIndex 29 ;
    ns1:syllabusDescription "2.3.1. Concepto de vertedero controlado. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000167/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "1.1.2. Definición de residuo. Clasificación de residuos según su peligrosidad. Clasificación según su estado. Clasificación según su origen. Clasificación según su composición. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000167/2025-26/syllabus/30> a ns1:SyllabusItem ;
    ns1:itemIndex 30 ;
    ns1:syllabusDescription "2.3.2. Etapas en la gestión de un vertedero. Preparación de la fosa, llenado de celdas y sellado del vertedero. Condiciones mínimas y elementos de protección. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000167/2025-26/syllabus/31> a ns1:SyllabusItem ;
    ns1:itemIndex 31 ;
    ns1:syllabusDescription "2.3.3. Producción y gestión de lixiviados y biogás. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000167/2025-26/syllabus/32> a ns1:SyllabusItem ;
    ns1:itemIndex 32 ;
    ns1:syllabusDescription "3. Gestión de vertidos y emisiones gaseosas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000167/2025-26/syllabus/33> a ns1:SyllabusItem ;
    ns1:itemIndex 33 ;
    ns1:syllabusDescription "3.1. Tema 8. Sistemas de tratamiento de aguas residuales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000167/2025-26/syllabus/34> a ns1:SyllabusItem ;
    ns1:itemIndex 34 ;
    ns1:syllabusDescription "3.1.1. Caracterización de las aguas residuales. Demanda química y biológica de oxígeno. Habitantes equivalentes. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000167/2025-26/syllabus/35> a ns1:SyllabusItem ;
    ns1:itemIndex 35 ;
    ns1:syllabusDescription "3.1.2. Tratamiento primario de aguas residuales. Operaciones unitarias: objetivo, equipos, funcionamiento. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000167/2025-26/syllabus/36> a ns1:SyllabusItem ;
    ns1:itemIndex 36 ;
    ns1:syllabusDescription "3.1.3. Tratamiento secundario de aguas residuales. Procesos aerobios y anaerobios. Condiciones de operación, equipos, crecimiento de biomasa y purga de lodos. Gestión de lodos de depuradora. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000167/2025-26/syllabus/37> a ns1:SyllabusItem ;
    ns1:itemIndex 37 ;
    ns1:syllabusDescription "3.1.4. Tratamiento terciario de aguas residuales. Nitrificación-desnitrificación. Otras operaciones. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000167/2025-26/syllabus/38> a ns1:SyllabusItem ;
    ns1:itemIndex 38 ;
    ns1:syllabusDescription "3.2. Tema 9. Tratamiento de emisiones gaseosas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000167/2025-26/syllabus/39> a ns1:SyllabusItem ;
    ns1:itemIndex 39 ;
    ns1:syllabusDescription "3.2.1. Tipos de emisiones: partículas, compuestos gaseosos olorosos y no olorosos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000167/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "1.1.3. Caracterización física, química y biológica de residuos, vertidos y emisiones. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000167/2025-26/syllabus/40> a ns1:SyllabusItem ;
    ns1:itemIndex 40 ;
    ns1:syllabusDescription "3.2.2. Tratamiento de gases con presencia de partículas. Separación por decantación, absorción, filtración y precipitación electroquímica. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000167/2025-26/syllabus/41> a ns1:SyllabusItem ;
    ns1:itemIndex 41 ;
    ns1:syllabusDescription "3.2.3. Tratamiento de gases con compuestos contaminantes. Oxidación, absorción, adsorción y biofiltración. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000167/2025-26/syllabus/42> a ns1:SyllabusItem ;
    ns1:itemIndex 42 ;
    ns1:syllabusDescription "4. Valorización de residuos de la industria alimentaria"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000167/2025-26/syllabus/43> a ns1:SyllabusItem ;
    ns1:itemIndex 43 ;
    ns1:syllabusDescription "4.1. Tema 10. Valorización de residuos generados en industrias de alimentos de origen animal"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000167/2025-26/syllabus/44> a ns1:SyllabusItem ;
    ns1:itemIndex 44 ;
    ns1:syllabusDescription "4.1.1. Industria cárnica: gestión de SANDACH; producción de harinas y grasas; valorización de sangre; valorización de pieles de vacuno; gestión de plumas y tripas; obtención de colágeno, gelatina y otros compuestos de alto valor añadido. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000167/2025-26/syllabus/45> a ns1:SyllabusItem ;
    ns1:itemIndex 45 ;
    ns1:syllabusDescription "4.1.2. Industria pesquera: gestión de SANDACH; producción de harinas y aceites; producción de ácidos grasos omega-3; obtención de colágeno, gelatina, escualeno, ácido hialurónico y otros compuestos de alto valor añadido. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000167/2025-26/syllabus/46> a ns1:SyllabusItem ;
    ns1:itemIndex 46 ;
    ns1:syllabusDescription "4.1.3. Industria láctea: gestión del lactosuero; obtención de derivados deshidratados; separación de corrientes y obtención de lactosa, proteínas y otros. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000167/2025-26/syllabus/47> a ns1:SyllabusItem ;
    ns1:itemIndex 47 ;
    ns1:syllabusDescription "4.2. Tema 11. Valorización de residuos generados en industrias de alimentos de origen vegetal"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000167/2025-26/syllabus/48> a ns1:SyllabusItem ;
    ns1:itemIndex 48 ;
    ns1:syllabusDescription "4.2.1. Industria oleícola: gestión de orujo y alperujo; valorización de otras corrientes residuales como ramas, hojas, huesos. Gestión de aguas residuales. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000167/2025-26/syllabus/49> a ns1:SyllabusItem ;
    ns1:itemIndex 49 ;
    ns1:syllabusDescription "4.2.2. Industria de aceites de semillas: gestión de cascarillas; valorización de corrientes del proceso de refinado. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000167/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "1.2. Tema 2. Problemática ambiental asociada a la generación de residuos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000167/2025-26/syllabus/50> a ns1:SyllabusItem ;
    ns1:itemIndex 50 ;
    ns1:syllabusDescription "4.2.3. Industria de transformados vegetales: gestión de residuos de elaboración de zumos; valorización de la cáscara de naranja; valorización de la piel de manzana. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000167/2025-26/syllabus/51> a ns1:SyllabusItem ;
    ns1:itemIndex 51 ;
    ns1:syllabusDescription "4.3. Tema 12. Valorización de residuos generados en industrias de bebidas fermentadas y espirituosas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000167/2025-26/syllabus/52> a ns1:SyllabusItem ;
    ns1:itemIndex 52 ;
    ns1:syllabusDescription "4.3.1. Industria enológica: gestión de raspones, orujos y lías. Valorización de orujos: obtención de alcohol, tartratos, antocianos, aceite de pepita, harina. Piquetas. Tratamiento de vinazas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000167/2025-26/syllabus/53> a ns1:SyllabusItem ;
    ns1:itemIndex 53 ;
    ns1:syllabusDescription "4.3.2. Industria cervecera: gestión de bagazos, turbios, levadura, tierras de filtración. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000167/2025-26/syllabus/54> a ns1:SyllabusItem ;
    ns1:itemIndex 54 ;
    ns1:syllabusDescription "4.3.3. Industria de bebidas espirituosas: gestión de colas y cabezas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000167/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "1.2.1. Contaminación del medio ambiente debida a la generación de residuos: contaminación al medio edáfico, hídrico y atmosférico. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000167/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "1.2.2. Principales efectos de la contaminación al medio ambiente: eutrofización, calentamiento global, disminución de la capa de ozono, acidificación de las precipitaciones, smog fotoquímico. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000167/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "1.3. Tema 3. Legislación sobre residuos, vertidos y emisiones"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000167/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "1.3.1. Ley sobre residuos y suelos contaminados: Definiciones de residuo y subproducto. Obligaciones del productor de residuos. Ley sobre subproductos de origen animal no destinados a consumo humano (SANDACH): categorías y posibles tratamientos. Sin subniveles"@es .

