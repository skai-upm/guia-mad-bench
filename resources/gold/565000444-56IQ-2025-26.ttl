<https://guia-kg.skai.etsisi.upm.es/resource/565000444/2025-26/evaluation> a ns1:EvaluationSystem ;
    ns1:evaluationDescription """EVALUACIÓN PROGRESIVA
BREVE DESCRIPCIÓN DE LAS ACTIVIDADES EVALUABLES
