    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/115100095/2025-26/eventSchedule> ;
    schema:description """5.1. Descripción de la asignatura
Mediante esta asignatura, se pretende que el alumno de grado conozca los distintos aspectos relacionados con la
dirección y el entrenamiento de deportistas de alto nivel con discapacidad, para poder desarrollar las herramientas
necesarias para diseñar, elaborar, organizar, poner en práctica y evaluar planes de entrenamiento y tecnificación
para esos deportistas.
Además se conocerán las particularidades con respecto a esta tipología de deportistas en lo que al desarrollo de
los diferentes deportes paralímpicos se refiere, tomando contacto con miembros del Equipo Paralímpico Español,
tanto deportistas como técnicos y gestores."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/joseantonio.garcia%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/joseantonio.garcia%40upm.es> ;
    schema:name "Alto Rendimiento para Deportistas con Discapacidad"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100095/2025-26/CE16> a ns1:Competency ;
    ns1:competencyCode "CE16" ;
    ns1:competencyDescription "Seleccionar y saber utilizar el material y equipamiento deportivo, adecuado para cada tipo de actividad que practique la población de jóvenes, adultos, mayores y personas con discapacidad. Nivel 3."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100095/2025-26/CG06> a ns1:Competency ;
    ns1:competencyCode "CG06" ;
    ns1:competencyDescription "Transmitir información, ideas, problemas y soluciones a un público tanto especializado como no especializado."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100095/2025-26/RA111> a ns1:LearningResult ;
    ns1:learningResultCode "RA111" ;
    ns1:learningResultDescription "Ser capaces de planificar, organizar, dirigir y evaluar los recursos humanos de actividad física y deporte (profesionales de actividad física y deporte) en las diferentes organizaciones de actividad física y deporte desde una perspectiva integral, profesional y eficiente"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100095/2025-26/RA116> a ns1:LearningResult ;
    ns1:learningResultCode "RA116" ;
    ns1:learningResultDescription "Ser capaz de identificar los diferentes tipos de estructuras y funciones en las organizaciones de actividad física y deporte"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100095/2025-26/RA119> a ns1:LearningResult ;
    ns1:learningResultCode "RA119" ;
    ns1:learningResultDescription "Conocer la estructura de las Organizaciones de Actividad Física y Deporte"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100095/2025-26/RA131> a ns1:LearningResult ;
    ns1:learningResultCode "RA131" ;
    ns1:learningResultDescription "Conocer los aspectos específicos de entrenamiento en deportes de alto rendimiento para personas con discapacidad"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100095/2025-26/RA132> a ns1:LearningResult ;
    ns1:learningResultCode "RA132" ;
    ns1:learningResultDescription "Aprender a planificar los entrenamientos, concentraciones y viajes para deportistas con discapacidad, teniendo en cuenta las particularidades individuales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100095/2025-26/RA133> a ns1:LearningResult ;
    ns1:learningResultCode "RA133" ;
    ns1:learningResultDescription "Conocer el material específico de competición (sillas de ruedas, muletas, bastones...) así como las ayudas técnicas necesarias para el correcto entrenamiento de deportistas con discapacidad"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100095/2025-26/RA134> a ns1:LearningResult ;
    ns1:learningResultCode "RA134" ;
    ns1:learningResultDescription "Dominar el lenguaje propio relacionado con la discapacidad"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100095/2025-26/RA135> a ns1:LearningResult ;
    ns1:learningResultCode "RA135" ;
    ns1:learningResultDescription "Conocer la estructura federativa y asociativa del Deporte Adaptado a personas con discapacidad"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100095/2025-26/RA136> a ns1:LearningResult ;
    ns1:learningResultCode "RA136" ;
    ns1:learningResultDescription "Conocer aspectos técnicos y tácticos en los diferentes deportes adaptados a personas con discapacidad"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100095/2025-26/RA137> a ns1:LearningResult ;
    ns1:learningResultCode "RA137" ;
    ns1:learningResultDescription "Desarrollar adaptaciones orientadas a la posibilidad de práctica deportiva por personas con cualquier tipo de discapacidad"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100095/2025-26/RA14> a ns1:LearningResult ;
    ns1:learningResultCode "RA14" ;
    ns1:learningResultDescription "Saber aplicar los principios del entrenamiento y así como los fundamentos fisiológicos y biomecánicos a los programas de entrenamiento"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100095/2025-26/RA15> a ns1:LearningResult ;
    ns1:learningResultCode "RA15" ;
    ns1:learningResultDescription "Ser capaz de diseñar programas de entrenamiento según ciclos adaptados a periodos competitivos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100095/2025-26/RA16> a ns1:LearningResult ;
    ns1:learningResultCode "RA16" ;
    ns1:learningResultDescription "Saber adaptar métodos, cargas y procedimientos en función de la edad para un entrenamiento correcto"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100095/2025-26/RA18> a ns1:LearningResult ;
    ns1:learningResultCode "RA18" ;
    ns1:learningResultDescription "Desarrollar la capacidad de análisis y adaptación para la aplicación de programas de actividad física en personas con circunstancias especiales, edad, género, patología"@es .

