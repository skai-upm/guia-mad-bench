<https://guia-kg.skai.etsisi.upm.es/resource/45000151> a ns1:Course ;
    ns1:courseType "Optativa"@es ;
    ns1:courseYear 4 ;
    ns1:semester "Octavo semestre"@es ;
    schema:courseCode 45000151 ;
    schema:hasCourseInstance <https://guia-kg.skai.etsisi.upm.es/resource/45000151/2025-26> ;
    schema:name "Engineering Of Cell Material"@en,
        "Ingeniería del Material Celular"@es ;
    schema:numberOfCredits 4.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/45000151/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/45000151/2025-26/CE%202.>,
        <https://guia-kg.skai.etsisi.upm.es/resource/45000151/2025-26/CG%2011>,
        <https://guia-kg.skai.etsisi.upm.es/resource/45000151/2025-26/CG%202>,
        <https://guia-kg.skai.etsisi.upm.es/resource/45000151/2025-26/CG%203>,
        <https://guia-kg.skai.etsisi.upm.es/resource/45000151/2025-26/CG%209> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/45000151/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/45000151/2025-26/didactic_resource/2> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/45000151/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/45000151/2025-26/RA33>,
        <https://guia-kg.skai.etsisi.upm.es/resource/45000151/2025-26/RA34>,
        <https://guia-kg.skai.etsisi.upm.es/resource/45000151/2025-26/RA35>,
        <https://guia-kg.skai.etsisi.upm.es/resource/45000151/2025-26/RA64>,
        <https://guia-kg.skai.etsisi.upm.es/resource/45000151/2025-26/RA65> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/45000151/2025-26/syllabus> ;
    ns1:inpersonHours "35 horas (33.7%)"@es ;
    ns1:numberOfCredits 4.0 ;
    ns1:otherInformation """Esta asignatura contribuye a los siguientes Objetivos de Desarrollo sostenible de la ONU, a través de sus procesos de aprendizaje y con los resultados obtenidos:
OBJETIVO 3. Garantizar una vida saludable y promover el bienestar para todos y todas en todas las edades."""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "62 horas"@es ;
    schema:activitiesWorkload "170%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/45000151/2025-26/eventSchedule> ;
    schema:description """Esta asignatura pretende proporcionar a los estudiantes un conocimiento básico de la arquitectura y el comportamiento de las células, haciendo énfasis en el comportamiento mecánico de los filamentos del citoesqueleto, la membrana celular y los mecanismos de adhesión, como base para comprender la interacción mecanobiológica de las células con su entorno. Esta asignatura contribuye al desarrollo de los siguientes objetivos del título:
Obj 3. Conocer el comportamiento mecánico, electrónico, químico y biológico de los materiales y saber aplicarlo al diseño, cálculo y modelización de los aspectos de elementos, componentes y equipos.
Obj 6. Incentivar el gusto por la investigación científica."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/gustavo.plaza%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/gustavo.plaza%40upm.es> ;
    schema:name "Ingeniería del Material Celular"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000151/2025-26/CE%202.> a ns1:Competency ;
    ns1:competencyCode "CE 2." ;
    ns1:competencyDescription "Saber modelizar el comportamiento (mecánico, electrónico, químico o biológico) de los materiales y su integración en componentes y dispositivos./ Know how to model the behavior (mechanical, electronic, chemical or biological) of materials and their integration into components and devices."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000151/2025-26/CG%2011> a ns1:Competency ;
    ns1:competencyCode "CG 11" ;
    ns1:competencyDescription "Responsabilidad y ética profesional/ Responsibility and professional ethics"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000151/2025-26/CG%202> a ns1:Competency ;
    ns1:competencyCode "CG 2" ;
    ns1:competencyDescription "Capacidad de trabajo en equipo/ Ability to work in a team"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000151/2025-26/CG%203> a ns1:Competency ;
    ns1:competencyCode "CG 3" ;
    ns1:competencyDescription "Comunicación oral y escrita"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000151/2025-26/CG%209> a ns1:Competency ;
    ns1:competencyCode "CG 9" ;
    ns1:competencyDescription "Capacidad de trabajo interdisciplinar/ Capacity for interdisciplinary work"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000151/2025-26/RA33> a ns1:LearningResult ;
    ns1:learningResultCode "RA33" ;
    ns1:learningResultDescription "Conocer los principios de funcionamiento y organizativos de los materiales blandos y del material celular. Conocer la dinámica de las interacciones débiles y los mecanismos de autoensamblaje. Conocer y saber predecir la respuesta a campos eléctricos y magnéticos y su interacción con las tensiones de origen mecánico."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000151/2025-26/RA34> a ns1:LearningResult ;
    ns1:learningResultCode "RA34" ;
    ns1:learningResultDescription "Utilizar con soltura la comunicación oral y escrita"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000151/2025-26/RA35> a ns1:LearningResult ;
    ns1:learningResultCode "RA35" ;
    ns1:learningResultDescription "Saber trabajar en equipo en entornos interdisciplinares. Ejecutar el trabajo con responsabilidad y respeto a los demás."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000151/2025-26/RA64> a ns1:LearningResult ;
    ns1:learningResultCode "RA64" ;
    ns1:learningResultDescription "Entender, asimilar y manejar los conceptos básicos que describen el comportamiento químico y biológico de los materiales en su interacción con el entorno. Conocer y saber relacionar dicho comportamiento con la estructura del material y su jerarquización a diferentes escalas atómico, molecular y macroscópico."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000151/2025-26/RA65> a ns1:LearningResult ;
    ns1:learningResultCode "RA65" ;
    ns1:learningResultDescription "Conocer y saber calcular mediante las teorías más relevantes la degradación y corrosión química y biológica de los materiales. Conocer y saber aplicar las técnicas de protección y durabilidad."@es .

