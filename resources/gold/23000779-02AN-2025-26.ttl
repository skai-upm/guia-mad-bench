    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/23000779/2025-26/syllabus> ;
    ns1:inpersonHours "72 horas (46.2%)"@es ;
    ns1:numberOfCredits 6.0 ;
    ns1:otherInformation "La asignatura se puede entender como un conjunto de tres procesos distintos: primero, conocimiento de cómo los jardines transforman el territorio, cuáles son sus trazados y las herramientas y métodos que utilizan para desarrollarse espacialmente a lo largo de los siglos; segundo, cómo estas herramientas y recursos compositivos se utilizan en el siglo XX hasta la actualidad y, tercero, comprobación in situ de esta metodología paisajista en el territorio."@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Junio"@es ;
    ns1:totalHours "72 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/23000779/2025-26/eventSchedule> ;
    schema:description "La asignatura tiene como objetivo conocer la evolución de la composición del jardín a lo largo de la historia, desde sus orígenes hasta la actualidad, su expresión en las diferentes culturas y su relación con el paisaje."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/alberto.sanz%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/alberto.sanz%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/carmen.toribio%40upm.es> ;
    schema:name "Historia de la Jardinería"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000779/2025-26/C10> a ns1:Competency ;
    ns1:competencyCode "C10" ;
    ns1:competencyDescription "Capacidad de aplicar en cada proyecto o actividad, los conceptos y las caracterÃ­sticas especÃ­ficas de los diferentes tipos o tendencias paisajÃ­sticas; asimismo conocer sus diferencias esenciales, su evoluciÃ³n y sus posibilidades de adaptaciÃ³n en casos concretos TIPO: Competencias."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000779/2025-26/K5> a ns1:Competency ;
    ns1:competencyCode "K5" ;
    ns1:competencyDescription "Conocer la evolución histórica y los conceptos más avanzados de los diferentes paisajismos, sus características diferenciales y sus aplicaciones, así como sus posibilidades de evolución y adaptación en el futuro. TIPO: Conocimientos o contenidos."@es .

