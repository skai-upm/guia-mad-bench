<https://guia-kg.skai.etsisi.upm.es/resource/205000024/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/205000024/2025-26/CE17>,
        <https://guia-kg.skai.etsisi.upm.es/resource/205000024/2025-26/CE24>,
