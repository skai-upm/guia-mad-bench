<https://guia-kg.skai.etsisi.upm.es/resource/35001301/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Dotar al estudiante de herramientas para aprender a especular, a cuantificar, a abstraer y a concretar simultáneamente con el pensamiento y con el dibujo. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35001301/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "2. Formalizar y comunicar gráficamente los resultados obtenidos de manera efectiva. Sin subniveles"@es .

