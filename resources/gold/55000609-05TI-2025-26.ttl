    ns1:inpersonHours "32 horas (41%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation "La agenda ODS 2030 informa transversalmente el programa con particular foco en el nº 8 Innovación, industria e infraestructuras"@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
