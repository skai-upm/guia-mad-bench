<https://guia-kg.skai.etsisi.upm.es/resource/63000256/2025-26/RA24> a ns1:LearningResult ;
    ns1:learningResultCode "RA24" ;
    ns1:learningResultDescription "Comprender las modalidades conservativas y no conservativas en el transporte de contaminantes en el subsuelo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000256/2025-26/RA25> a ns1:LearningResult ;
