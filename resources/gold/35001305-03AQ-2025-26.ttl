    ns1:itemIndex 15 ;
    ns1:syllabusDescription "2.8. Curvatura de Gauss o total. Curvatura media. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35001305/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "2.9. Clasificación de los puntos de una superficie. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35001305/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "3. Superficies regladas."@es .

