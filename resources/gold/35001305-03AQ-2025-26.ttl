    ns1:itemIndex 10 ;
    ns1:syllabusDescription "2.3. Curvas contenidas en superficies. Líneas coordenadas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35001305/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "2.4. Primera forma fundamental. Medida sobre la superficie. Integral de superficie. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35001305/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "2.5. Segunda forma fundamental. Curvatura normal y geodésica. Teorema de Meusnier. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35001305/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "2.6. Curvaturas principales. Direcciones principales. Direcciones asintóticas. Sin subniveles"@es .

