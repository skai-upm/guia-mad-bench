<https://guia-kg.skai.etsisi.upm.es/resource/43000520> a ns1:Course ;
    ns1:courseType "Optativa"@es ;
    ns1:courseYear 2 ;
    ns1:semester """Tercer semestre
Cuarto semestre"""@es ;
    schema:courseCode 43000520 ;
    schema:hasCourseInstance <https://guia-kg.skai.etsisi.upm.es/resource/43000520/2025-26> ;
    schema:name "Seminars"@en,
        "Seminarios"@es ;
    schema:numberOfCredits 1.5 .

<https://guia-kg.skai.etsisi.upm.es/resource/43000520/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/43000520/2025-26/MSICCB06>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000520/2025-26/MSICCB10>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000520/2025-26/MSICCG09> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/43000520/2025-26/didactic_resource/1> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/43000520/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/43000520/2025-26/RA114> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/43000520/2025-26/syllabus> ;
    ns1:inpersonHours "28 horas (69.1%)"@es ;
    ns1:numberOfCredits 1.5 ;
    ns1:otherInformation """Consultar los títulos de los seminarios en la página web del Máster.
La asignatura se relaciona con el ODS4."""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "28 horas"@es ;
    schema:activitiesWorkload "620%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/43000520/2025-26/eventSchedule> ;
    schema:description "Los seminarios tienen como objetivo ofrecer al alumno un conocimiento de las técnicas de investigación y los conocimientos acordes con la evolución científico-tecnológica de la investigación en las materias del Máster. Pueden ser impartidos por profesores de los departamentos involucrados en el máster o por profesores invitados de otras universidades y países. Su contenido concreto dependerá de la disponibilidad de ponentes interesados en impartirlos y sus especializaciones."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/joseangel.sanchez%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/guillermo.martinez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/joseangel.sanchez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/maria.castro%40upm.es> ;
    schema:name "Seminarios"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000520/2025-26/MSICCB06> a ns1:Competency ;
    ns1:competencyCode "MSICCB06" ;
    ns1:competencyDescription "Poseer y comprender conocimientos que aporten una base u oportunidad de ser originales en el desarrollo y/o aplicación de ideas, a menudo en un contexto de investigación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000520/2025-26/MSICCB10> a ns1:Competency ;
    ns1:competencyCode "MSICCB10" ;
    ns1:competencyDescription "Que los estudiantes posean las habilidades de aprendizaje que les permitan continuar estudiando de un modo que habrá de ser en gran medida autodirigido o autónomo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000520/2025-26/MSICCG09> a ns1:Competency ;
    ns1:competencyCode "MSICCG09" ;
    ns1:competencyDescription "Gestión de la información"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000520/2025-26/RA114> a ns1:LearningResult ;
    ns1:learningResultCode "RA114" ;
    ns1:learningResultDescription "Capacidad para analizar y sintetizar los diversos contenidos de información de fuentes diversas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000520/2025-26/didactic_resource/1> a ns1:DidacticResource ;
