<https://guia-kg.skai.etsisi.upm.es/resource/143003013/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. INTRODUCCIÓN Y DEFINICIÓN DEL MODELADO DEL HELICÓPTERO."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143003013/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Problema general de la mecánica del vuelo de helicópteros y su formulación canónica. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143003013/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "3.1. Problema general del vuelo equilibrado. Vuelo rectilíneo y vuelo en giro coordinado. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143003013/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "3.2. Modelado de las acciones de los distintos componentes del helicóptero. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143003013/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "3.3. Discusión de problemas de interés. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143003013/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "3.4. Condiciones de vuelo de interés. Vuelo a nivel, ascenso, descenso y autorrotación. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143003013/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "3.5. Influencia de los parámetros de diseño en el vuelo equilibrado. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143003013/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "3.6. Implementación en Matlab. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143003013/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "4. ANÁLISIS LINEAL DE LA ESTABILIDAD Y RESPUESTA AL MANDO DEL HELICÓPTERO."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143003013/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "4.1. Problema general de la estabilidad y la respuesta al mando. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143003013/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "4.2. Determinación computacional de derivadas de estabilidad y derivadas de control en una condición de vuelo equilibrado general. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143003013/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "4.3. Simulación computacional de los problemas longitudinal y lateral. Acoplamientos dinámicos en helicópteros. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143003013/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Tipos de modelos de helicópteros. El modelo de 6 gdl. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143003013/2025-26/syllabus/20> a ns1:SyllabusItem ;
    ns1:itemIndex 20 ;
    ns1:syllabusDescription "4.4. Determinación computacional de autovalores, autovectores e identificación de modos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143003013/2025-26/syllabus/21> a ns1:SyllabusItem ;
    ns1:itemIndex 21 ;
    ns1:syllabusDescription "4.5. Análisis computacional de la influencia en la estabilidad y respuesta al mando de los parámetros de diseño y la condición de vuelo. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143003013/2025-26/syllabus/22> a ns1:SyllabusItem ;
    ns1:itemIndex 22 ;
    ns1:syllabusDescription "4.6. Diseño computacional de controladores lineales. Planteamiento en el espacio de estados. Método de colocación de polos. Sistemas de aumento de estabilidad. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143003013/2025-26/syllabus/23> a ns1:SyllabusItem ;
    ns1:itemIndex 23 ;
    ns1:syllabusDescription "4.7. Implementación en Matlab. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143003013/2025-26/syllabus/24> a ns1:SyllabusItem ;
    ns1:itemIndex 24 ;
    ns1:syllabusDescription "5. SIMULACIÓN NO LINEAL DEL VUELO DE MANIOBRA DEL HELICÓPTERO."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143003013/2025-26/syllabus/25> a ns1:SyllabusItem ;
