    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/105000407/2025-26/30AD> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/105000407/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/105000407/2025-26/didactic_resource/2>,
