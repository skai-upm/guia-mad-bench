    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/143005007/2025-26/syllabus> ;
    ns1:inpersonHours "53 horas (51%)"@es ;
    ns1:numberOfCredits 4.0 ;
    ns1:otherInformation """Se recomienda la siguiente bibliografía de conocimientos previos:
Principios de Electrónica, autor Malvino, editorial Mc Graw Hill
Electrónica Integrada, autor Millman editorial Hispano Europea
Análisis de Circuitos I y II, autor López Ferreras"""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "55 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/143005007/2025-26/eventSchedule> ;
    schema:description "Se presentan las bases de los sistemas electrónicos con el objetivo de enlazar con otras asignaturas del segundo semestre, especialmente de la especialidad de Sistemas Aeroespaciales de Tratamiento de Información (SATI), por ejemplo, las Fuentes de alimentación reguladas y conmutadas serán útiles para la asignatura de Sistemas de Potencia Eléctrica en Vehículos Aeroespaciales, y el protocolo ARINC, se desarrollará en la asignatura Arquitectura de Sistemas de Aviónica. Por último, el tema de ruido servirá de base para el mismo tema de la asignatura de Tratamiento de información multisensor."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/josefelix.alonso%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/jesus.mas%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/josefelix.alonso%40upm.es> ;
    schema:name "Sistemas Electronicos Aeroespaciales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005007/2025-26/CE10> a ns1:Competency ;
    ns1:competencyCode "CE10" ;
    ns1:competencyDescription "Comprender la problemática propia de los sistemas electrónicos terrestres y embarcados en los diferentes elementos del Sistema del Transporte Aéreo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005007/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Poseer y comprender conocimientos que aporten una base u oportunidad de ser originales en el desarrollo de nuevos conceptos y técnicas aplicados al Sistema del Transporte Aéreo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005007/2025-26/CG4> a ns1:Competency ;
    ns1:competencyCode "CG4" ;
    ns1:competencyDescription "Comunicar sus conclusiones y los conocimientos y razones últimas que las sustentan a públicos especializados, y no especializados de un modo claro y sin ambigüedades"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005007/2025-26/CG6> a ns1:Competency ;
    ns1:competencyCode "CG6" ;
    ns1:competencyDescription "Que los estudiantes posean las habilidades de aprendizaje que les permitan continuar estudiando de un modo que habrá de ser en gran medida autodirigido o autónomo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005007/2025-26/CT3> a ns1:Competency ;
    ns1:competencyCode "CT3" ;
    ns1:competencyDescription "Gestionar la información, identificando las fuentes necesarias, los principales tipos de documentos técnicos y científicos que son de aplicación en el entorno de los Sistemas del Transporte Aéreo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005007/2025-26/RA12> a ns1:LearningResult ;
    ns1:learningResultCode "RA12" ;
    ns1:learningResultDescription "El alumno conoce los sistemas de alimentación, distribución y cargas eléctricas en aeronaves."@es .

