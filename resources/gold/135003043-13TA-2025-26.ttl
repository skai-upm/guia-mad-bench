    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/135003043/2025-26/eventSchedule> ;
    schema:description """El objetivo de esta asignatura es que , el alumno conozca con detalle la aplicación de los SIG en gestión del territorio, y la introducción del alumno en la programación informática, así como en la Inteligencia Artificial. La asignatura se completa con seminarios sobre temas ambientales punteros
La asignatura tiene como fin estimular el deseo de aumentar el conocimiento y proporcionarle instrumentos que le permitan su actualización continua."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/susana.martin%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/a.martinf%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/alejandra.ezquerra%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/carlos.calderon%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/rosario.contreras.alonso%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/sergio.gonzalez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/susana.martin%40upm.es> ;
    schema:name "Tics en Ingenieria Ambiental"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003043/2025-26/CT18> a ns1:Competency ;
    ns1:competencyCode "CT18" ;
    ns1:competencyDescription "Habilidad para usar las técnicas, destrezas y herramientas ingenieriles modernas necesarias para la práctica de la ingeniería"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003043/2025-26/RA103> a ns1:LearningResult ;
    ns1:learningResultCode "RA103" ;
    ns1:learningResultDescription "Conocer los Fundamentos para la Gestión Digital de la Información Ambiental"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003043/2025-26/RA28> a ns1:LearningResult ;
    ns1:learningResultCode "RA28" ;
    ns1:learningResultDescription "Identificar aplicaciones y procesos característicos de la Ingeniería Ambiental."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003043/2025-26/RA49> a ns1:LearningResult ;
    ns1:learningResultCode "RA49" ;
    ns1:learningResultDescription "Ser capaces de diseñar y programar aplicaciones sencillas que simulen procesos ambientales, en base a los datos suministrados por la observación de la realidad"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003043/2025-26/RA84> a ns1:LearningResult ;
    ns1:learningResultCode "RA84" ;
    ns1:learningResultDescription "Complementar los conocimientos adquiridos en las asignaturas básicas y obligatorias en el área de la obra civil transporte y urbanismo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003043/2025-26/RA93> a ns1:LearningResult ;
    ns1:learningResultCode "RA93" ;
    ns1:learningResultDescription "Complementar los conocimientos adquiridos en las asignaturas básicas y obligatorias en el área de la recuperación de recursos renovables"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003043/2025-26/RA94> a ns1:LearningResult ;
