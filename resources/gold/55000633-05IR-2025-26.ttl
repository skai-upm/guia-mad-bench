<https://guia-kg.skai.etsisi.upm.es/resource/55000633/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Termodinámica I"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000633/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Sistema termodinámico y entorno. Equilibrio termodinámico. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000633/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "2.3. Máquinas térmicas. Ciclos directo (térmico) e inverso (frigorífico). Eficiencias. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000633/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "2.4. Segundo principio de la Termodinámica. Reversibilidad de los procesos termodinámicos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000633/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "2.5. Ciclo de Carnot. Eficiencia máxima de las máquinas térmicas. Cálculo de la eficiencia para el caso de un gas ideal. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000633/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "2.6. Entropía en procesos termodinámicos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000633/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "3. Campo eléctrico I"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000633/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "3.1. Carga eléctrica. Naturaleza y unidades. Materiales conductores y aislantes. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000633/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "3.2. Fuerzas electrostáticas. Ley de Coulomb. Campo eléctrico: Definición y unidades. Campo eléctrico originado por cargas puntuales. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000633/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "3.3. Campo eléctrico originado por distribuciones de carga. Flujo electrostático. Aplicación del teorema de Gauss a la determinación de campos electrostáticos en configuraciones típicas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000633/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "3.4. Trabajo de la fuerza electrostática. Energía potencial electrostática. Potencial eléctrico: Definición y unidades. Superficies equipotenciales. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000633/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "3.5. Potencial eléctrico originado por cargas puntuales o distribuciones de carga. Campo eléctrico y potencial en conductores y aislantes. Caso de configuraciones típicas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000633/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Temperatura y equilibrio térmico. Principio cero de la Termodinámica. Termómetros y escalas de temperatura. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000633/2025-26/syllabus/20> a ns1:SyllabusItem ;
    ns1:itemIndex 20 ;
    ns1:syllabusDescription "4. Campo eléctrico II"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000633/2025-26/syllabus/21> a ns1:SyllabusItem ;
    ns1:itemIndex 21 ;
    ns1:syllabusDescription "4.1. Vectores campo eléctrico, polarización y desplazamiento eléctrico. Permitividad relativa. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000633/2025-26/syllabus/22> a ns1:SyllabusItem ;
    ns1:itemIndex 22 ;
    ns1:syllabusDescription "4.2. Capacidad electrostática. Definición y unidades. Condensadores. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000633/2025-26/syllabus/23> a ns1:SyllabusItem ;
    ns1:itemIndex 23 ;
    ns1:syllabusDescription "4.3. Capacidad de condensadores. Análisis particular de los casos plano, cilíndrico y esférico. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000633/2025-26/syllabus/24> a ns1:SyllabusItem ;
    ns1:itemIndex 24 ;
    ns1:syllabusDescription "4.4. Energía electrostática. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000633/2025-26/syllabus/25> a ns1:SyllabusItem ;
    ns1:itemIndex 25 ;
    ns1:syllabusDescription "5. Corriente eléctrica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000633/2025-26/syllabus/26> a ns1:SyllabusItem ;
    ns1:itemIndex 26 ;
    ns1:syllabusDescription "5.1. Transporte de cargas bajo diferencias de potencial. Intensidad y densidad de corriente. Definición y unidades. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000633/2025-26/syllabus/27> a ns1:SyllabusItem ;
    ns1:itemIndex 27 ;
    ns1:syllabusDescription "5.2. Conductividad y resistividad. Conductancia y resistencia. Definición y unidades. Ley de Ohm. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000633/2025-26/syllabus/28> a ns1:SyllabusItem ;
    ns1:itemIndex 28 ;
    ns1:syllabusDescription "5.3. Fuerza electromotriz y circuitos. Leyes de Kirchhoff en circuitos resistivos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000633/2025-26/syllabus/29> a ns1:SyllabusItem ;
    ns1:itemIndex 29 ;
    ns1:syllabusDescription "5.4. Energía y potencia en circuitos eléctricos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000633/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "1.3. Leyes de los gases. Ecuación de estado del gas ideal. Ecuación de Van der Waals. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000633/2025-26/syllabus/30> a ns1:SyllabusItem ;
    ns1:itemIndex 30 ;
    ns1:syllabusDescription "6. Campo magnético I"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000633/2025-26/syllabus/31> a ns1:SyllabusItem ;
    ns1:itemIndex 31 ;
    ns1:syllabusDescription "6.1. Introducción al magnetismo. Magnetismo natural. Experiencia de Oersted. Fuerza de Lorentz. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000633/2025-26/syllabus/32> a ns1:SyllabusItem ;
    ns1:itemIndex 32 ;
    ns1:syllabusDescription "6.2. Análisis de casos particulares de movimiento de cargas en campos magnéticos. Aplicaciones Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000633/2025-26/syllabus/33> a ns1:SyllabusItem ;
    ns1:itemIndex 33 ;
    ns1:syllabusDescription "6.3. Fuerza magnética sobre conductores que transportan corrientes. Momento de fuerzas sobre espiras de corriente. Momento magnético dipolar de una espira. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000633/2025-26/syllabus/34> a ns1:SyllabusItem ;
    ns1:itemIndex 34 ;
    ns1:syllabusDescription "6.4. Aplicaciones: Motor de corriente continua y efecto Hall. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000633/2025-26/syllabus/35> a ns1:SyllabusItem ;
    ns1:itemIndex 35 ;
    ns1:syllabusDescription "7. Campo magnético II"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000633/2025-26/syllabus/36> a ns1:SyllabusItem ;
    ns1:itemIndex 36 ;
    ns1:syllabusDescription "7.1. Fuentes del campo magnético. Campo de inducción magnética originado por una carga en movimiento y un elemento de corriente. Ley de Biot-Savart. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000633/2025-26/syllabus/37> a ns1:SyllabusItem ;
    ns1:itemIndex 37 ;
    ns1:syllabusDescription "7.2. Cálculo del campo de inducción magnética originado por configuraciones sencillas de corriente: Conductor rectilíneo de gran longitud a una distancia dada y espira circular de corriente en los puntos de su eje. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000633/2025-26/syllabus/38> a ns1:SyllabusItem ;
    ns1:itemIndex 38 ;
    ns1:syllabusDescription "7.3. Fuerza mutua entre conductores rectilíneos paralelos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000633/2025-26/syllabus/39> a ns1:SyllabusItem ;
    ns1:itemIndex 39 ;
    ns1:syllabusDescription "7.4. Ley de Ampère. Aplicaciones: Solenoide muy largo y solenoide toroidal. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000633/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "1.4. Energía en sistemas de muchas partículas. Interpretación cinética clásica de la temperatura y la presión. Energía interna de un sistema. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000633/2025-26/syllabus/40> a ns1:SyllabusItem ;
    ns1:itemIndex 40 ;
    ns1:syllabusDescription "7.5. Campos magnéticos en medios materiales. Susceptibilidad magnética y vectores magnetización e intensidad de campo magnético. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000633/2025-26/syllabus/41> a ns1:SyllabusItem ;
    ns1:itemIndex 41 ;
    ns1:syllabusDescription "7.6. Distintos tipos de materiales atendiendo al valor de su susceptibilidad magnética. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000633/2025-26/syllabus/42> a ns1:SyllabusItem ;
    ns1:itemIndex 42 ;
    ns1:syllabusDescription "8. Inducción electromagnética"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000633/2025-26/syllabus/43> a ns1:SyllabusItem ;
    ns1:itemIndex 43 ;
    ns1:syllabusDescription "8.1. Fuerza electromotriz inducida por variaciones del flujo de campo magnético. Introducción experimental. Ley de inducción de Faraday-Henry y ley de Lenz. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000633/2025-26/syllabus/44> a ns1:SyllabusItem ;
    ns1:itemIndex 44 ;
    ns1:syllabusDescription "8.2. Fuerza electromotriz inducida por el movimiento de corrientes en el seno de campos magnéticos. Aplicaciones: Dinamos y alternadores. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000633/2025-26/syllabus/45> a ns1:SyllabusItem ;
    ns1:itemIndex 45 ;
    ns1:syllabusDescription "8.3. Inducción mutua entre espiras. Autoinducción. Coeficientes de autoinducción e inducción mutua. Unidades. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000633/2025-26/syllabus/46> a ns1:SyllabusItem ;
    ns1:itemIndex 46 ;
    ns1:syllabusDescription "8.4. Energía almacenada por el campo magnético. Formulación en términos de flujos magnéticos e intensidades. Aplicaciones. Corriente de desplazamiento. Ecuaciones de Maxwell. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000633/2025-26/syllabus/47> a ns1:SyllabusItem ;
    ns1:itemIndex 47 ;
    ns1:syllabusDescription "9. Corriente alterna"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000633/2025-26/syllabus/48> a ns1:SyllabusItem ;
    ns1:itemIndex 48 ;
    ns1:syllabusDescription "9.1. Circuitos eléctricos con autoinducciones. Cálculo de tensiones e intensidades en circuitos RC y RL. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000633/2025-26/syllabus/49> a ns1:SyllabusItem ;
    ns1:itemIndex 49 ;
    ns1:syllabusDescription "9.2. Generación de corrientes alternas. Respuesta de los distintos tipos de elementos (R,L,C) a una excitación alterna. Resistencia, Reactancias e Impedancia. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000633/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "1.5. Calores específicos. Capacidad calorífica y teoría cinético-molecular. Calores latentes de cambio de estado. Diagramas de fase. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000633/2025-26/syllabus/50> a ns1:SyllabusItem ;
    ns1:itemIndex 50 ;
    ns1:syllabusDescription "9.3. Determinación de tensiones e intensidades en circuitos de corriente alterna. Método de fasores en el plano complejo. Condición de resonancia. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000633/2025-26/syllabus/51> a ns1:SyllabusItem ;
    ns1:itemIndex 51 ;
    ns1:syllabusDescription "9.4. Energía y potencia en circuitos de corriente alterna. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000633/2025-26/syllabus/52> a ns1:SyllabusItem ;
    ns1:itemIndex 52 ;
    ns1:syllabusDescription "10. Ondas mecánicas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000633/2025-26/syllabus/53> a ns1:SyllabusItem ;
    ns1:itemIndex 53 ;
    ns1:syllabusDescription "10.1. Ondas. Definición y elementos característicos. Ondas longitudinales y transversales. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000633/2025-26/syllabus/54> a ns1:SyllabusItem ;
    ns1:itemIndex 54 ;
    ns1:syllabusDescription "10.2. Ecuación de onda. Velocidad de propagación. (solo caso de ondas armónicas) Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000633/2025-26/syllabus/55> a ns1:SyllabusItem ;
    ns1:itemIndex 55 ;
    ns1:syllabusDescription "10.3. Ondas sonoras. Efecto Doppler. Ondas subsónicas y supersónicas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000633/2025-26/syllabus/56> a ns1:SyllabusItem ;
    ns1:itemIndex 56 ;
    ns1:syllabusDescription "10.4. Energía e intensidad de las ondas. Caso de ondas sonoras. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000633/2025-26/syllabus/57> a ns1:SyllabusItem ;
    ns1:itemIndex 57 ;
    ns1:syllabusDescription "10.5. Superposición de ondas. Interferencia de ondas armónicas. Pulsaciones. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000633/2025-26/syllabus/58> a ns1:SyllabusItem ;
    ns1:itemIndex 58 ;
    ns1:syllabusDescription "10.6. Ondas estacionarias. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000633/2025-26/syllabus/59> a ns1:SyllabusItem ;
    ns1:itemIndex 59 ;
    ns1:syllabusDescription "11. Ecuaciones de Maxwell y ondas electromagnéticas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000633/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "1.6. Mecanismos de transferencia de calor. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000633/2025-26/syllabus/60> a ns1:SyllabusItem ;
    ns1:itemIndex 60 ;
    ns1:syllabusDescription "11.1. Corriente de desplazamiento. Ecuaciones de Maxwell Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000633/2025-26/syllabus/61> a ns1:SyllabusItem ;
    ns1:itemIndex 61 ;
    ns1:syllabusDescription "11.2. Ondas electromagnéticas. Energía y cantidad de movimiento en las ondas electromagnéticas. Vector de Poynting. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000633/2025-26/syllabus/62> a ns1:SyllabusItem ;
    ns1:itemIndex 62 ;
    ns1:syllabusDescription "11.3. Espectro electromagnético. La luz como onda electromagnética en la zona visible del espectro. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000633/2025-26/syllabus/63> a ns1:SyllabusItem ;
    ns1:itemIndex 63 ;
    ns1:syllabusDescription "12. Óptica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000633/2025-26/syllabus/64> a ns1:SyllabusItem ;
    ns1:itemIndex 64 ;
    ns1:syllabusDescription "12.1. Refracción por prismas ópticos. Análisis espectral de la luz. Aplicaciones Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000633/2025-26/syllabus/65> a ns1:SyllabusItem ;
    ns1:itemIndex 65 ;
    ns1:syllabusDescription "12.2. Principio de Huygens. Reflexión y refracción en superficies planas. Angulo límite. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000633/2025-26/syllabus/66> a ns1:SyllabusItem ;
    ns1:itemIndex 66 ;
    ns1:syllabusDescription "12.3. Reflexión en espejos planos y esféricos. Métodos analíticos y gráficos de determinación de imágenes. Imágenes reales y virtuales. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000633/2025-26/syllabus/67> a ns1:SyllabusItem ;
    ns1:itemIndex 67 ;
    ns1:syllabusDescription "12.4. Dioptrio esférico. Lentes delgadas. Potencia de lentes. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000633/2025-26/syllabus/68> a ns1:SyllabusItem ;
    ns1:itemIndex 68 ;
    ns1:syllabusDescription "12.5. Polarización de la luz. Polarizadores. Ley de Malus. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000633/2025-26/syllabus/69> a ns1:SyllabusItem ;
    ns1:itemIndex 69 ;
    ns1:syllabusDescription "12.6. Interferencias ópticas. Franjas de interferencia. Experimento de Young Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000633/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "2. Termodinámica II"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000633/2025-26/syllabus/70> a ns1:SyllabusItem ;
    ns1:itemIndex 70 ;
    ns1:syllabusDescription "12.7. Fenómenos de difracción. Descripción cualitativa. Difracción de Fresnel y difracción de Fraunhofer. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000633/2025-26/syllabus/71> a ns1:SyllabusItem ;
    ns1:itemIndex 71 ;
    ns1:syllabusDescription "12.8. Difracción por rendijas. Redes de difracción Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000633/2025-26/syllabus/72> a ns1:SyllabusItem ;
    ns1:itemIndex 72 ;
    ns1:syllabusDescription "12.9. Difracción de rayos X. Experimento de Laue. Ley de Bragg. Aplicaciones. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000633/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "2.1. Calor y trabajo en sistemas termodinámicos. Variación de la energía interna. Primer principio de la Termodinámica. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000633/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "2.2. Transformaciones en sistemas termodinámicos. Ciclos termodinámicos. Variaciones de energía interna y entalpía. Aplicación a gases ideales. Sin subniveles"@es .

