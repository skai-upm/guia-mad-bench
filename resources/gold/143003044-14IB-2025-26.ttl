<https://guia-kg.skai.etsisi.upm.es/resource/143003044/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. GESTIÓN Y CULTURA DE SEGURIDAD."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143003044/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. 1.1. El concepto de seguridad. 1.2. Cultura de organización. 1.3. El estereotipo de la seguridad operacional y el dilema gerencial. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143003044/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "4.1. 4.1. Causalidad de los accidentes. 4.2. El accidente de organización Modelo de Reason. 4.3. Las personas, el contexto y la seguridad operacional ? El modelo Shell. 4.4. Errores y violaciones. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143003044/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "5. MÉTODOS PARA LA IDENTIFICACIÓN DE AMENAZAS Y EVALUACIÓN DE RIESGOS DE SEGURIDAD, DETERMINACIÓN DE OBJETIVOS Y REQUISITOS DE SEGURIDAD, Y GARANTÍA DE LOS NIVELES DE SEGURIDAD."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143003044/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "5.1. 5.1. Metodología de análisis de riesgos. 5.2. FHA, PSSA, SSA. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143003044/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "6. NGENIERÍA DE SEGURIDAD EN SISTEMAS COMPLEJOS (SAFETY GUIDE DESIGN)"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143003044/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "6.1. 6.1. Peligros y riesgos: Identificación, comprensión, análisis y documentación de los peligros. 6.2. Probabilidad de los riesgos de seguridad operacional. 6.3. Gravedad de los riesgos de seguridad operacional. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143003044/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "6.2. .4. Tolerabilidad de los riesgos de seguridad operacional. 6.5. Control/mitigación de los riesgos de seguridad operacional. 6.6. Requisitos de gestión de la seguridad operacional. 6.7 Evaluación y gestión de los riesgos de seguridad operacional. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143003044/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "7. PROGRAMA ESTATAL DE SEGURIDAD OPERACIONAL."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143003044/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "7.1. 7.1 Objetivo y contenido. 7.2. Componentes y elementos de un SSP. 7.3. El marco para SSP de la OACI. 7.4. Elaboración de un SSP. 7.5. Implantación del SSP. 7.6. Función del SSP en apoyo de la implantación del SMS. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143003044/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. 1.4. Necesidad de la gestión de la seguridad operacional. 1.5. Estrategias para la gestión de la seguridad operacional Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143003044/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "2. NORMATIVA DE APLICACIÓN EN SEGURIDAD OPERACIONAL EN EL TRANSPORTE AÉREO."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143003044/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "2.1. 2.1.- OACI. 2.2. Eurocontrol. 2.3. Unión europea. 2.4. EASA. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143003044/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "3. SISTEMAS REACTIVOS, PROACTIVOS Y PREDICTIVOS DE ANÁLISIS DE INFORMACIÓN DE SEGURIDAD OPERACIONAL."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143003044/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "3.1. Enfoques para la gestión de la seguridad operacional: Reactivo, proactivo, predictivo. Sistemas reactivos de recolección y análisis de datos de seguridad operacional: Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143003044/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "3.2. Sistemas proactivos de recolección y análisis de datos de seguridad operacional: ASR; Encuestas y auditorias de seguridad operacional. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143003044/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "3.3. Sistemas predictivos de recolección y análisis de datos de seguridad operacional: FDA, FOQA, MOQA. Registradores de voz y datos en el transporte Aéreo Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143003044/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "4. MODELOS CAUSALES DE ACCIDENTES E INCIDENCIAS DE SEGURIDAD."@es .

