        <https://guia-kg.skai.etsisi.upm.es/resource/105000134/2025-26/didactic_resource/3> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/105000134/2025-26/evaluation> ;
