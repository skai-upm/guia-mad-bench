<https://guia-kg.skai.etsisi.upm.es/resource/105000134/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/105000134/2025-26/C12>,
        <https://guia-kg.skai.etsisi.upm.es/resource/105000134/2025-26/C19>,
        <https://guia-kg.skai.etsisi.upm.es/resource/105000134/2025-26/C2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/105000134/2025-26/C3>,
        <https://guia-kg.skai.etsisi.upm.es/resource/105000134/2025-26/C4>,
        <https://guia-kg.skai.etsisi.upm.es/resource/105000134/2025-26/C5>,
        <https://guia-kg.skai.etsisi.upm.es/resource/105000134/2025-26/C6>,
