    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/45000246/2025-26/eventSchedule> ;
    schema:description """La asignatura es una introducción a la Economía Aplicada, proporcionando instrumentos para la medición y la interpretación de la realidad económica. La mayoría de los ejercicios se refieren a casos económicos reales. La primera parte del programa (lecciones 1 a 6) desarrolla unas herramientas que se aplican, al mismo tiempo, a presentar la Economía Española, incluyendo diferencias regionales. La perspectiva es macroeconómica: Contabilidad nacional y principales macromagnitudes, incluyendo las relaciones exteriores (Balanza de pagos y tipos de cambio). Específicamente un análisis regional es objeto de trabajo de curso en grupo.
Las lecciones 7 a 12 presentan una introducción a la Economía Mundial, con los problemas de desarrollo y convergencia económica; aspectos demográficos, problemas ambientales e integración económica. Al igual que en la primera parte, se combina el desarrollo de técnicas de análisis con otros aspectos teóricos."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/jose.balibrea%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/antonio.sanchezso%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/jose.balibrea%40upm.es> ;
    schema:name "Economía Mundial, Española y Regional"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000246/2025-26/30AD.%20E15> a ns1:Competency ;
    ns1:competencyCode "30AD. E15" ;
    ns1:competencyDescription "Entender el funcionamiento de los mercados financieros nacionales e internacionales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000246/2025-26/30AD.%20E16> a ns1:Competency ;
    ns1:competencyCode "30AD. E16" ;
    ns1:competencyDescription "Conocer las principales teorías sobre el comportamiento de la economía tanto a nivel individual como agregado."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000246/2025-26/30AD.%20E17> a ns1:Competency ;
    ns1:competencyCode "30AD. E17" ;
    ns1:competencyDescription "Comprender las bases que configuran la actual estructura de la economía mundial y española."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000246/2025-26/30AD.%20E18> a ns1:Competency ;
    ns1:competencyCode "30AD. E18" ;
    ns1:competencyDescription "Conocer la determinación de los principales indicadores y agregados económicos, así como su impacto sobre las decisiones de la empresa."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000246/2025-26/30AD.%20E19> a ns1:Competency ;
    ns1:competencyCode "30AD. E19" ;
    ns1:competencyDescription "Comprender las variables e indicadores que caracterizan la política macroeconómica de un sector y un entorno geográfico."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000246/2025-26/30AD.%20E20> a ns1:Competency ;
    ns1:competencyCode "30AD. E20" ;
    ns1:competencyDescription "Comprender el contexto económico, regional, nacional e internacional que rodea a la empresa así como interpretar su impacto en la misma."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000246/2025-26/30AD.%20G01> a ns1:Competency ;
    ns1:competencyCode "30AD. G01" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de comprender, interpretar, sintetizar y evaluar de forma crítica información proveniente de fuentes diversas en el ámbito de la administración y dirección de empresas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000246/2025-26/30AD.%20G06> a ns1:Competency ;
    ns1:competencyCode "30AD. G06" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de trabajar en equipos multidisciplinares, aplicando los conocimientos adquiridos en el ámbito de la administración y dirección de empresas, fomentando el espíritu de equipo y la coordinación en las tareas de los diversos miembros."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000246/2025-26/30AD.%20G07> a ns1:Competency ;
    ns1:competencyCode "30AD. G07" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de trabajar en entornos diversos, comprendiendo y adaptándose a situaciones nuevas en el ámbito de la administración y dirección de empresas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000246/2025-26/30AD.%20G09> a ns1:Competency ;
    ns1:competencyCode "30AD. G09" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de trabajar en el ámbito de la administración y dirección de empresas aplicando criterios de calidad y sostenibilidad."@es .

