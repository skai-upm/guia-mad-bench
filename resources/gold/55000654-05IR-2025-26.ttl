<https://guia-kg.skai.etsisi.upm.es/resource/55000654/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/55000654/2025-26/CE17>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55000654/2025-26/CG3>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55000654/2025-26/CG4>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55000654/2025-26/CG5>,
