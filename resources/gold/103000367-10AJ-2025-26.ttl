        <https://guia-kg.skai.etsisi.upm.es/resource/103000367/2025-26/didactic_resource/4>,
        <https://guia-kg.skai.etsisi.upm.es/resource/103000367/2025-26/didactic_resource/5>,
        <https://guia-kg.skai.etsisi.upm.es/resource/103000367/2025-26/didactic_resource/6> ;
