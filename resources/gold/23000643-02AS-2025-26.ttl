<https://guia-kg.skai.etsisi.upm.es/resource/23000643/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. ORGANISMOS CAUSANTES DE PÉRDIDAS EN LA PRODUCCIÓN VEGETAL"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000643/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Importancia de las enfermedades Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000643/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "3.2. Herramientas moleculares utilizadas para diseccionar mecanismos patogénicos en organismos filamentosos: genómica comparativa y funcional. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000643/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "4. CICLOS DE VIDA Y MECANISMOS DE VIRULENCIA DE LAS BACTERIAS"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000643/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "4.1. Estilos patogénicos de bacterias fitopatógenas. Etapas de la infección. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000643/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "4.2. Factores de virulencia y mecanismos de evasión y manipulación de la defensa del huésped. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000643/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "4.3. Mecanismos de resistencia y adaptación a las condiciones del huésped. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000643/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "5. GENERACIÓN DE VARIABILIDAD GENÉTICA EN PATÓGENOS"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000643/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "5.1. Variabilidad genética y evolución de la virulencia Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000643/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "5.2. Estructuras genómicas, redundancia genética, y costes biológicos de la evolución de la virulencia Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000643/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Organismos causantes de enfermedades Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000643/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "1.3. Conceptos fundamentales en la interacción entre las plantas y los organismos perjudiciales Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000643/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "2. CICLOS DE VIDA Y MECANISMOS DE VIRULENCIA DE LOS VIRUS"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000643/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "2.1. Infección, colonización y dispersión de los virus fitopatógenos Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000643/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "2.2. Manipulación de los procesos celulares de las plantas durante la replicación y expresión de los genomas virales Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000643/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "2.3. Desregulación de la expresión génica del huésped Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000643/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "3. CICLOS DE VIDA Y MECANISMOS DE VIRULENCIA DE LOS HONGOS Y OOMICETOS"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000643/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "3.1. Bases moleculares del proceso de infección Sin subniveles"@es .

