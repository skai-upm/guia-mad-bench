    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/45001211/2025-26/eventSchedule> ;
    schema:description """La Resistencia de Materiales proporciona los fundamentos de la ingeniería estructural. Además, forma la base para la comprensión de los conceptos de estabilidad, equilibrio y resistencia de construcciones como puentes, presas, túneles, obras de contención, edificos, torres o depósitos.
La Resistencia de Materiales aborda la respuesta en rango elástico y lineal, en términos de reacciones, esfuerzos, tensiones, deformaciones y movimientos, de estructuras isostáticas e hiperestáticas formadas por elementos prismáticos (vigas y columnas), con directriz recta (vigas continuas o pórticos) o curva (arcos), incluyendo el estudio tenso-deformacional de la sección transversal sometida a esfuerzos axil, cortante, momento flector y momento torsor. Como método de resolución estructural, se emplea fundamentalmente el método de flexibilidad o de las fuerzas.
Además de los contenidos anteriores enmarcados en el ámbito de la linealidad material y geométrica, se estudian los conceptos básicos del análisis con material elasto-plástico y de la inestabilidad de soportes esbeltos."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/carlos.zanuy%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/alberto.sanzr%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/antoniojose.madrid%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/carlos.martindelaconcha%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/carlos.zanuy%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/david.fernandez.montes%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/ivan.munoz%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/jm.soria%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/juancarlos.mosquera%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/luis.plaza.beltran%40upm.es> ;
    schema:name "Resistencia de Materiales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001211/2025-26/CM20.1> a ns1:Competency ;
    ns1:competencyCode "CM20.1" ;
    ns1:competencyDescription "Capacidad para analizar y comprender cómo las características de las estructuras influyen en su comportamiento. Capacidad para aplicar los conocimientos sobre el funcionamiento resistente de las estructuras para dimensionarlas siguiendo las normativas existentes y utilizando métodos de cálculo analíticos y numéricos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001211/2025-26/CM20.2> a ns1:Competency ;
    ns1:competencyCode "CM20.2" ;
    ns1:competencyDescription "Capacidad de cálculo de elementos estructurales a partir de modelos analíticos de comportamiento mecánico y fallo estructural anelásticos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001211/2025-26/CT5> a ns1:Competency ;
    ns1:competencyCode "CT5" ;
    ns1:competencyDescription "Polivalencia y capacidad de aprendizaje autónomo. Desarrolla la competencia transversal 5ª del real decreto."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001211/2025-26/RA81> a ns1:LearningResult ;
    ns1:learningResultCode "RA81" ;
    ns1:learningResultDescription "Explica el comportamiento mecánico y resistente de las estructuras a partir de sus características."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001211/2025-26/RA82> a ns1:LearningResult ;
    ns1:learningResultCode "RA82" ;
    ns1:learningResultDescription "Dimensiona estructuras con métodos de cálculo analíticos y numéricos según la normativa existente."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001211/2025-26/RA83> a ns1:LearningResult ;
