    ns1:semester "Séptimo semestre"@es ;
    schema:courseCode 545000047 ;
    schema:hasCourseInstance <https://guia-kg.skai.etsisi.upm.es/resource/545000047/2025-26> ;
    schema:name "English Oral Skills For Building Engineers"@en,
        "Destrezas Orales para el Inglés de la Edificacion"@es ;
    schema:numberOfCredits 3.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/545000047/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/545000047/2025-26/CG13>,
        <https://guia-kg.skai.etsisi.upm.es/resource/545000047/2025-26/CT01>,
        <https://guia-kg.skai.etsisi.upm.es/resource/545000047/2025-26/CT02>,
        <https://guia-kg.skai.etsisi.upm.es/resource/545000047/2025-26/CT08> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/545000047/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/545000047/2025-26/RA233> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/545000047/2025-26/syllabus> ;
    ns1:inpersonHours "28 horas (35.9%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation "Se recomiena tener un nivel de acreditación de inglés B2 o superior."@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "28 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/545000047/2025-26/eventSchedule> ;
    schema:description "La asignatura Destrezas Orales para el Inglés de la Edificación está orientada a la ampliación del uso de la lengua inglesa por alumnos con un nivel intermedio-alto/avanzado, especialmente al desarrollo y refuerzo de las destrezas orales de recepción y producción."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/joaquin.santiago%40upm.es> ;
    schema:inLanguage "Inglés"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/joaquin.santiago%40upm.es> ;
    schema:name "Destrezas Orales para el Inglés de la Edificacion"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000047/2025-26/CG13> a ns1:Competency ;
    ns1:competencyCode "CG13" ;
    ns1:competencyDescription "Uso de la lengua inglesa en el ámbito de la edificación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000047/2025-26/CT01> a ns1:Competency ;
    ns1:competencyCode "CT01" ;
    ns1:competencyDescription "Trabajo en equipo. Equipos interdisciplinares"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000047/2025-26/CT02> a ns1:Competency ;
    ns1:competencyCode "CT02" ;
    ns1:competencyDescription "Comunicación oral y escrita. Capacidad de análisis y síntesis y de discusión de ideas propias. Capacidad de comunicación a través de la palabra y la imagen."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000047/2025-26/CT08> a ns1:Competency ;
    ns1:competencyCode "CT08" ;
    ns1:competencyDescription "Uso de la lengua inglesa"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000047/2025-26/RA233> a ns1:LearningResult ;
    ns1:learningResultCode "RA233" ;
    ns1:learningResultDescription "RA01. Identify main and secondary ideas in a text, and draw up an outline. RA02. Identify the parts and structure of a text. RA03. Identify specific details in a text. RA04. Assess the relevance of ideas presented in a text & draw conclusions. RA05. Express point of view orally in a coherent way. RA06. Reduce affective filters in oral communication. RA07. Present projects and technical reports orally. RA08. Participate in oral discussions using the appropriate linguistic conventions. RA09. Understand academic and professional discourse. RA10. Predict discourse strategies in oral communication. RA11. Identify parts and structure in a lecture. RA12. Understand specialized discourse based on audiovisual sources. RA13. Identify the main differences between oral and written communication. RA14. Write texts following the conventions used in different types of specialized documents. RA15. Take notes from lectures. RA16. Write up paragraphs following different text structures."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000047/2025-26/evaluation> a ns1:EvaluationSystem ;
    ns1:evaluationDescription "Los alumnos que no aprueben siguiendo el procedimiento de evaluación continua deberán optar por la modadlidad de evaluación global. Siendo una asignatura impartida en el primer semestre, los alumnos que opten por la evaluación global podran realizar la prueba en la convocatoria ordinaria (enero-febrero) o bien en la extraordinaria (julio)."@es .

