<https://guia-kg.skai.etsisi.upm.es/resource/43000430/2025-26/CB7> a ns1:Competency ;
    ns1:competencyCode "CB7" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en entornos nuevos o poco conocidos dentro de contextos más amplios (o multidisciplinares) relacionados con su área de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000430/2025-26/CB8> a ns1:Competency ;
    ns1:competencyCode "CB8" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de integrar conocimientos y enfrentarse a la complejidad de formular juicios a partir de una información que, siendo incompleta o limitada, incluya reflexiones sobre las responsabilidades sociales y éticas vinculadas a la aplicación de sus conocimientos y juicios"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000430/2025-26/CB9> a ns1:Competency ;
    ns1:competencyCode "CB9" ;
    ns1:competencyDescription "Que los estudiantes sepan comunicar sus conclusiones y los conocimientos y razones últimas que las sustentan a públicos especializados y no especializados de un modo claro y sin ambigüedades"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000430/2025-26/CE4> a ns1:Competency ;
    ns1:competencyCode "CE4" ;
    ns1:competencyDescription "Capacidad para la resolución de problemas de proyecto, construcción, conservación y evaluación técnica de infraestructuras que requieran el uso de hormigones especiales o materiales de refuerzo y se planteen en contextos globalizados."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000430/2025-26/CG2> a ns1:Competency ;
    ns1:competencyCode "CG2" ;
    ns1:competencyDescription "Capacidad de ejercer las funciones de proyecto, construcción, conservación y evaluación técnica mediante el uso de normativa europea e internacional."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000430/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Capacidad de diseñar, analizar e interpretar experimentos relevantes en Ingeniería Estructural, Geotécnica y de Materiales Estructurales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000430/2025-26/RA1> a ns1:LearningResult ;
    ns1:learningResultCode "RA1" ;
    ns1:learningResultDescription "Utiliza con eficacia, autonomía y polivalencia recursos de modelización predictiva en la temática de la materia"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000430/2025-26/RA15> a ns1:LearningResult ;
    ns1:learningResultCode "RA15" ;
    ns1:learningResultDescription "Aplica normativa europea e internacional de ingeniería estructural, geotécnica y de materiales estructurales en proyecto, construcción, conservación y evaluación técnica Interioriza los principios de deontología profesional de ingeniería civil"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000430/2025-26/RA59> a ns1:LearningResult ;
    ns1:learningResultCode "RA59" ;
    ns1:learningResultDescription "Identifica las propiedades de los materiales de construcción en función del uso y condiciones ambientales y selecciona los apropiados"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000430/2025-26/RA60> a ns1:LearningResult ;
    ns1:learningResultCode "RA60" ;
    ns1:learningResultDescription "Aplica la normativa de control y calidad de los materiales de construcción a partir de sus fundamentos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000430/2025-26/RA61> a ns1:LearningResult ;
    ns1:learningResultCode "RA61" ;
    ns1:learningResultDescription "Establece las necesidades de materiales de construcción y de sistemas estructurales en distintas condiciones ambientales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000430/2025-26/RA62> a ns1:LearningResult ;
    ns1:learningResultCode "RA62" ;
    ns1:learningResultDescription "Identifica los mecanismos físico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000430/2025-26/RA63> a ns1:LearningResult ;
    ns1:learningResultCode "RA63" ;
    ns1:learningResultDescription "Aplica técnicas de elaboración y caracterización de materiales de construcción."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000430/2025-26/RA64> a ns1:LearningResult ;
    ns1:learningResultCode "RA64" ;
    ns1:learningResultDescription "Identifica los requerimientos resistentes de materiales de construcción en función de la tipología estructural a partir de los fundamentos de su comportamiento mecánico y resistente y elige entre los hormigones especiales el más adecuado para cada caso."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000430/2025-26/RA65> a ns1:LearningResult ;
    ns1:learningResultCode "RA65" ;
    ns1:learningResultDescription "Aplica la normativa de hormigón con fibras y distingue entre las tipologías existentes de fibras. Distingue el uso estructural del hormigón con fibras y conoce los criterios de selección y dosificación del material."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000430/2025-26/RA66> a ns1:LearningResult ;
    ns1:learningResultCode "RA66" ;
    ns1:learningResultDescription "Aplica la normativa existente sobre el uso de hormigones especiales"@es .

