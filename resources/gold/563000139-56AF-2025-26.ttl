    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/563000139/2025-26/eventSchedule> ;
    schema:description "La asignatura pretende dotar al alumnado, por lo general de procedencia heterogénea, de una visión general de las fases del proceso de diseño y desarrollo de productos, así como técnicas y herramientas para llevar a cabo las distintas fases, desde un punto de vista práctico."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/juandavid.cano%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/alvaro.rodriguez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/juandavid.cano%40upm.es> ;
    schema:name "Diseño y Desarrollo de Productos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000139/2025-26/CB06> a ns1:Competency ;
    ns1:competencyCode "CB06" ;
    ns1:competencyDescription "Poseer y comprender conocimientos que aporten una base u oportunidad de ser originales en el desarrollo y/o aplicación de ideas, a menudo en un contexto de investigación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000139/2025-26/CB07> a ns1:Competency ;
    ns1:competencyCode "CB07" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en entornos nuevos o poco conocidos dentro de contextos más amplios (o multidisciplinares) relacionados con su área de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000139/2025-26/CB08> a ns1:Competency ;
    ns1:competencyCode "CB08" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de integrar conocimientos y enfrentarse a la complejidad de formular juicios a partir de una información que, siendo incompleta o limitada, incluya reflexiones sobre las responsabilidades sociales y éticas vinculadas a la aplicación de sus conocimientos y juicios"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000139/2025-26/CB09> a ns1:Competency ;
    ns1:competencyCode "CB09" ;
    ns1:competencyDescription "Que los estudiantes sepan comunicar sus conclusiones y los conocimientos y razones últimas que las sustentan a públicos especializados y no especializados de un modo claro y sin ambigüedades"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000139/2025-26/CB10> a ns1:Competency ;
    ns1:competencyCode "CB10" ;
    ns1:competencyDescription "Que los estudiantes posean las habilidades de aprendizaje que les permitan continuar estudiando de un modo que habrá de ser en gran medida autodirigido o autónomo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000139/2025-26/CEC01> a ns1:Competency ;
    ns1:competencyCode "CEC01" ;
    ns1:competencyDescription "Capacidad para proyectar, calcular y diseñar productos, procesos e instalaciones en todos los ámbitos de la ingeniería de producción."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000139/2025-26/CEC03> a ns1:Competency ;
    ns1:competencyCode "CEC03" ;
    ns1:competencyDescription "Capacidad para el modelado matemático, cálculo y simulación de productos, sistemas y procesos en centros tecnológicos y de ingeniería"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000139/2025-26/CEC04> a ns1:Competency ;
    ns1:competencyCode "CEC04" ;
    ns1:competencyDescription "Capacidad de desarrollo e innovación en todos los ámbitos relacionados con la ingeniería de producción y campos multidisciplinares afines."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000139/2025-26/CEC06> a ns1:Competency ;
    ns1:competencyCode "CEC06" ;
    ns1:competencyDescription "Capacidad para comprender la responsabilidad ética y la deontología profesional en el ámbito de la ingeniería de producción"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000139/2025-26/CEI01> a ns1:Competency ;
    ns1:competencyCode "CEI01" ;
    ns1:competencyDescription "Capacidad de realizar proyectos de ingeniería de producción sobre sistemas de producción"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000139/2025-26/CEI03> a ns1:Competency ;
    ns1:competencyCode "CEI03" ;
    ns1:competencyDescription "Desarrollar capacidades de aplicación de los conocimientos adquiridos al diseño de procesos industriales, en función de las características de los elementos a producir, con criterios de máxima calidad, productividad, seguridad y respeto al medio ambiente"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000139/2025-26/CEI16> a ns1:Competency ;
    ns1:competencyCode "CEI16" ;
    ns1:competencyDescription "Capacidad de comunicar con sus colegas, con la comunidad académica en su conjunto y con la sociedad en general acerca de sus áreas de conocimiento"@es .

