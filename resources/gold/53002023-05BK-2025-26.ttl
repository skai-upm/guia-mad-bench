    schema:courseCode 53002023 ;
    schema:hasCourseInstance <https://guia-kg.skai.etsisi.upm.es/resource/53002023/2025-26> ;
    schema:name "Marine And Small Hydraulic Energies"@en,
        "Energía Minihidraúlica y Marina"@es ;
    schema:numberOfCredits 3.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/53002023/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/53002023/2025-26/CB7>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53002023/2025-26/CE10>,
