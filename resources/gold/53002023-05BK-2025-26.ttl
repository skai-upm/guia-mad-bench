    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/53002023/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53002023/2025-26/didactic_resource/2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53002023/2025-26/didactic_resource/3>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53002023/2025-26/didactic_resource/4> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/53002023/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/53002023/2025-26/RA37>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53002023/2025-26/RA38>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53002023/2025-26/RA39> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/53002023/2025-26/syllabus> ;
    ns1:inpersonHours "60 horas (74.1%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation """Bibliografía
Mecánica de Fluidos, Crespo, A., Editorial Thomson, 2006
Hydrodynamics of Pumps, Brennen, C. E., Editorial Oxford Science Publications, 1994
Teoría y Problemas de Máquinas Hidráulicas, Viedma Robles, A. , Zamora Parra, B. 2002
Turbomáquinas Hidráulicas, Mataix, C., Editorial ICAI, 2011
Problemas de Mecánica de Fluidos y Máquinas Hidráulicas, Hernández, J., Crespo A., Editorial UNED, 1996
Hydraulic Machines: Turbines and Pumps, Krivechenko G., Editorial CRC Press, 1994
Turbomáquinas Hidráulicas, Mataix, C., Editorial ICAI, 2011"""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "63 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/53002023/2025-26/eventSchedule> ;
    schema:description "En esta asignatura se abordan los aspectos más destacados de la generación de energía minihidráulica y marina, indicando ventajas e inconvenientes y situándola en el contexto energético global. Se describen los diferentes elementos de las minicentrales hidráulicas y marinas (principalmente, mareomotrices y undimotrices). Se estudian los diferentes tipos de turbina aplicadas en minihidráulica y energía oceánica."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/javier.garciag%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/javier.garciag%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/marta.cruz%40upm.es> ;
    schema:name "Energía Minihidraúlica y Marina"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002023/2025-26/CB7> a ns1:Competency ;
    ns1:competencyCode "CB7" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en entornos nuevos o poco conocidos dentro de contextos más amplios (o multidisciplinares) relacionados con su área de estudio/ Students are capable of applying their knowledge, understanding, and problem"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002023/2025-26/CE10> a ns1:Competency ;
    ns1:competencyCode "CE10" ;
    ns1:competencyDescription "Evaluar el potencial energético de las fuentes de energía renovable: radiación solar, recurso eólico, recurso hidráulico, potencial energético de la biomasa, recurso energético marino, geotérmico, etc.; a partir de las bases de datos meteorológicas y recursos naturales./ Evaluate the energy potential of renewable energy sources: solar radiation, wind resource, hydraulic resource, energy potential of biomass, marine energy resource, geothermal, etc .; from meteorological databases and natural resources."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002023/2025-26/CE11> a ns1:Competency ;
    ns1:competencyCode "CE11" ;
    ns1:competencyDescription "Analizar el comportamiento energético y control de los sistemas de energías renovables determinando y aplicando criterios innovadores de optimización energética, económica y ambiental, aplicando metodologías de diseño, simulación y análisis de los componentes y sistemas de energías renovables: solares, eólicos, hidráulicos, de biomasa, de energías marinas, geotérmicas y otras energías renovables; para contribuir a su desarrollo tecnológico y a su competitividad con otras tecnologías energéticas./ Analyze the energy behavior and control of renewable energy systems determining and applying innovative criteria for energy, economic and environmental optimization, applying design methodologies, simulation and analysis of renewable energy components and systems: solar, wind, hydraulic, biomass of marine, geothermal and other renewable energies; to contribute to its technological development and its competitiveness with other energy technologies."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002023/2025-26/CE3> a ns1:Competency ;
    ns1:competencyCode "CE3" ;
    ns1:competencyDescription "Utilizar las herramientas necesarias para el diseño y análisis de sistemas de generación, trasformación, almacenamiento y utilización de energías nucleares, mecánicas, eléctricas, térmicas e hidráulicas./ Use the necessary tools for the design and analysis of systems for the generation, transformation, storage and use of nuclear, mechanical, electrical, thermal and hydraulic energies."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002023/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Aplicar conocimientos de ciencias y tecnologías avanzadas a la práctica profesional o investigadora de la Ingeniería Energética./ Apply knowledge of advanced science and technology to the professional or research practice of Energy Engineering."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002023/2025-26/CG2> a ns1:Competency ;
    ns1:competencyCode "CG2" ;
    ns1:competencyDescription "Poseer capacidad para diseñar, desarrollar, implementar, gestionar y mejorar productos, sistemas y procesos en los distintos ámbitos energéticos, usando técnicas analíticas, computacionales o experimentales avanzadas./ Ability to design, develop, implement, manage and improve products, systems and processes in the different energy fields, using advanced analytical, computational or experimental techniques."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002023/2025-26/CG8> a ns1:Competency ;
    ns1:competencyCode "CG8" ;
    ns1:competencyDescription "Incorporar nuevas tecnologías y herramientas avanzadas de la Ingeniería Energética en sus actividades profesionales o investigadoras./ Incorporate new technologies and advanced tools of Energy Engineering in their professional or research activities."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002023/2025-26/CT1> a ns1:Competency ;
    ns1:competencyCode "CT1" ;
    ns1:competencyDescription "Aplica. Habilidad para aplicar conocimientos científicos, matemáticos y tecnológicos en sistemas relacionados con la práctica de la ingeniería./ Apply. Ability to apply scientific, mathematical and technological knowledge in systems related to the practice of engineering."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002023/2025-26/CT11> a ns1:Competency ;
    ns1:competencyCode "CT11" ;
    ns1:competencyDescription "Usa herramientas. Habilidad para usar las técnicas, destrezas y herramientas ingenieriles modernas necesarias para la práctica de la ingeniería./ Use tools. Ability to use modern engineering techniques, skills, and tools necessary for engineering practice."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002023/2025-26/CT3> a ns1:Competency ;
    ns1:competencyCode "CT3" ;
    ns1:competencyDescription "Diseña. Habilidad para diseñar un sistema, componente o proceso que alcance los requisitos deseados teniendo en cuenta restricciones realistas tales como las económicas, medioambientales, sociales, políticas, éticas, de salud y seguridad, de fabricación y de sostenibilidad./ Design. Ability to design a system, component or process that meets the desired requirements taking into account realistic constraints such as economic, environmental, social, political, ethical, health and safety, manufacturing and sustainability."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002023/2025-26/CT5> a ns1:Competency ;
    ns1:competencyCode "CT5" ;
    ns1:competencyDescription "Resuelve. Habilidad para identificar, formular y resolver problemas de ingeniería./ Solve. Ability to identify, formulate and solve engineering problems."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002023/2025-26/RA37> a ns1:LearningResult ;
    ns1:learningResultCode "RA37" ;
    ns1:learningResultDescription "Comprensión de los fundamentos de la generación de energía minihidráulica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002023/2025-26/RA38> a ns1:LearningResult ;
    ns1:learningResultCode "RA38" ;
    ns1:learningResultDescription "Conocimiento de las diferentes formas de obtención de energía marina"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002023/2025-26/RA39> a ns1:LearningResult ;
    ns1:learningResultCode "RA39" ;
    ns1:learningResultDescription "Descripción y análisis energético de las centrales minihidráulicas y marinas"@es .

