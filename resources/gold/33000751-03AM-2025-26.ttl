<https://guia-kg.skai.etsisi.upm.es/resource/33000751/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Modelización Matemática. Aplicaciones a la Arquitectura Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000751/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "2. Interpolación. Interpolación Polinómica. Interpolación de Lagrange. Polinomios de base. Interpolación por tramos. Aplicación al tratamiento de datos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000751/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "3. Derivación Numérica. Integración numérica. Estimación del error. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000751/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "4. Métodos de resolución aproximada de modelos en ecuaciones diferenciales. Método de diferencias finitas. Aplicaciones. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000751/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "5. Métodos de resolución aproximada de modelos en ecuaciones en derivadas parciales. Método de diferencias finitas. Estabilidad. Aplicación a fenómenos de transferencia de calor"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000751/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "5.1. Balance de Energía. Cubierta vegetal. Sin subniveles"@es .

