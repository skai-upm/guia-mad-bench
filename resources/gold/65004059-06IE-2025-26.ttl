    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/65004059/2025-26/eventSchedule> ;
    schema:description """La asignatura de Termodinámica Técnica se puede considerar una Termodinámica avanzada ya que complementa los conocimientos de Termodinámica profundizando en:
* Evaluación de los balances de energía en diversos procesos (Primer Principio) y la calidad de los flujos de energía ( Segundo Principio) utilizando el análisis exergético.
* El cálculo de propiedades en sistemas mas complejos: multicomponentes incluyendo equilibrios líquido-líquido y líquido-vapor
* Los sistemas reactivos, heterogéneos y multireactivos y en especial las reacciones de combustión.
* La exergía química, variable fundamental en los sitemas con cambio de composición."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/javier.rodriguez.martin%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/javier.rodriguez.martin%40upm.es> ;
    schema:name "Termodinamica Tecnica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004059/2025-26/CE20> a ns1:Competency ;
    ns1:competencyCode "CE20" ;
    ns1:competencyDescription "Comprender los conceptos de la termodinámica y aplicarlos en la Ingeniería de la Energía."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004059/2025-26/CE5> a ns1:Competency ;
    ns1:competencyCode "CE5" ;
    ns1:competencyDescription "Aplicar los conocimientos generales de química a problemas en Ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004059/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Conocer y aplicar conocimientos de ciencias y tecnologías básicas a la práctica de la Ingeniería de la Energía."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004059/2025-26/CG2> a ns1:Competency ;
    ns1:competencyCode "CG2" ;
    ns1:competencyDescription "Poseer capacidad para diseñar, desarrollar, implementar, gestionar y mejorar productos, sistemas y procesos en los distintos ámbitos energéticos, usando técnicas analíticas, computacionales o experimentales apropiadas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004059/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Aplicar los conocimientos adquiridos para identificar, formular y resolver problemas dentro de contextos amplios y multidisciplinarios, siendo capaces de integrar conocimientos, trabajando en equipos multidisciplinares."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004059/2025-26/CG4> a ns1:Competency ;
    ns1:competencyCode "CG4" ;
    ns1:competencyDescription "Comprender el impacto de la ingeniería energética en el medio ambiente, el desarrollo sostenible de la sociedad y la importancia de trabajar en un entorno profesional y responsable."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004059/2025-26/RA199> a ns1:LearningResult ;
    ns1:learningResultCode "RA199" ;
    ns1:learningResultDescription "Determinar propiedades termodinámicas en sistemas multicomponentes y polifásicos, a partir de ecuaciones de estado y correlaciones tabulares."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004059/2025-26/RA200> a ns1:LearningResult ;
    ns1:learningResultCode "RA200" ;
    ns1:learningResultDescription "Seleccionar las más adecuadas a cada caso, como marco previo para diseñar operaciones básicas de ingeniería química y de producción de energía o frío."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004059/2025-26/RA201> a ns1:LearningResult ;
    ns1:learningResultCode "RA201" ;
    ns1:learningResultDescription "Determinar propiedades termoquímicas, composiciones de equilibrio y efectos caloríficos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004059/2025-26/RA202> a ns1:LearningResult ;
    ns1:learningResultCode "RA202" ;
    ns1:learningResultDescription "Identificar y valorar destrucciones exergéticas en sistemas físicos y químicos."@es .

