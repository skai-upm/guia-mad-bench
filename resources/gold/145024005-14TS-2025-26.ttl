    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. MECÁNICA LAGRANGIANA"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145024005/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Ligaduras. Clasificación de fuerzas. Objetivos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145024005/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "1.10. Obtención de los términos P a partir de la expresión de la energía cinética. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145024005/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "1.11. Indicaciones para la determinación de los términos Q. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145024005/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "1.12. Sistemas holónomos sometidos a fuerzas potenciales. Función lagrangiana. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145024005/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "1.13. Ecuación de la energía para un sistema holónomo. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145024005/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "2. TRATAMIENTO ANALÍTICO DE LA DINÁMICA IMPULSIVA"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145024005/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "2.1. Percusiones directamente aplicadas sobre un sistema holónomo. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145024005/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "2.2. Percusiones directamente aplicadas sobre un sistema no holónomo. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145024005/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "2.3. Introducción brusca de ligaduras persistentes. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145024005/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "3. MECÁNICA HAMILTONIANA"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145024005/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "3.1. Transformación de las ecuaciones de Lagrange en las ecuaciones canónicas de Hamilton. Teorema de Donkin. Momentos generalizados. Espacio de fases. Variables simplécticas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145024005/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Tipos de ligaduras. Clasificación de los sistemas según las ligaduras. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145024005/2025-26/syllabus/20> a ns1:SyllabusItem ;
    ns1:itemIndex 20 ;
    ns1:syllabusDescription "3.2. Derivada de una función según el flujo hamiltoniano. Corchetes de Poisson. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145024005/2025-26/syllabus/21> a ns1:SyllabusItem ;
    ns1:itemIndex 21 ;
    ns1:syllabusDescription "3.3. Transformaciones canónicas. Paréntesis de Lagrange. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145024005/2025-26/syllabus/22> a ns1:SyllabusItem ;
    ns1:itemIndex 22 ;
    ns1:syllabusDescription "3.4. Invarianza de los corchetes de Poisson respecto a las transformaciones canónicas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145024005/2025-26/syllabus/23> a ns1:SyllabusItem ;
    ns1:itemIndex 23 ;
    ns1:syllabusDescription "3.5. Canonicidad de la transformación debido al flujo hamiltoniano. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145024005/2025-26/syllabus/24> a ns1:SyllabusItem ;
    ns1:itemIndex 24 ;
    ns1:syllabusDescription "3.6. Método de Hamilton-Jacobi. Función generatriz de una transformación canónica. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145024005/2025-26/syllabus/25> a ns1:SyllabusItem ;
    ns1:itemIndex 25 ;
    ns1:syllabusDescription "3.7. Aplicación del método de Hamilton-Jacobi al caso de fuerza central kepleriana. Variables de Delaunay. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145024005/2025-26/syllabus/26> a ns1:SyllabusItem ;
    ns1:itemIndex 26 ;
    ns1:syllabusDescription "3.8. Método de Hamilton-Jacobi aplicado a la teoría de perturbaciones. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145024005/2025-26/syllabus/27> a ns1:SyllabusItem ;
    ns1:itemIndex 27 ;
    ns1:syllabusDescription "4. TEMAS AVANZADOS"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145024005/2025-26/syllabus/28> a ns1:SyllabusItem ;
    ns1:itemIndex 28 ;
    ns1:syllabusDescription "4.1. Principio variacional de Hamilton. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145024005/2025-26/syllabus/29> a ns1:SyllabusItem ;
    ns1:itemIndex 29 ;
    ns1:syllabusDescription "4.2. Integrabilidad completa de una función hamiltoniana. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145024005/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "1.3. Desplazamientos posibles. Desplazamientos virtuales compatibles con las ligaduras. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145024005/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "1.4. Desplazamientos virtuales compatibles con las ligaduras para sistemas holónomos. Coordenadas generalizadas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145024005/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "1.5. Desplazamientos virtuales compatibles con las ligaduras para sistemas no holónomos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145024005/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "1.6. Ligaduras ideales. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145024005/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "1.7. Ecuación general de la dinámica para sistemas sometidos a ligaduras ideales. Principio de los trabajos virtuales. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145024005/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "1.8. Aplicación de la ecuación general de la dinámica a un sistema holónomo sometido a ligaduras ideales. Ecuaciones de Lagrange. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145024005/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "1.9. Aplicación de la ecuación general de la dinámica a un sistema no holónomo sometido a ligaduras ideales. Sin subniveles"@es .

