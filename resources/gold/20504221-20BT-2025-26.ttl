        <https://guia-kg.skai.etsisi.upm.es/resource/javier.modrego%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/luis.garceso%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/margarita.perez%40upm.es> ;
    schema:name "Fisiología de Sistemas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504221/2025-26/CB02> a ns1:Competency ;
    ns1:competencyCode "CB02" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar sus conocimientos a su trabajo o vocación de una forma profesional y posean las competencias que suelen demostrarse por medio de la elaboración y defensa de argumentos y la resolución de problemas dentro de su área de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504221/2025-26/CE30> a ns1:Competency ;
    ns1:competencyCode "CE30" ;
    ns1:competencyDescription "Ser capaz de integrar y explicar los conceptos adquiridos durante el estudio de la fisiología en animales, así como la relación entre la estructura y la función, y en particular, las interacciones entre los diferentes sistemas y sus mecanismos de regulación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504221/2025-26/CG01> a ns1:Competency ;
    ns1:competencyCode "CG01" ;
    ns1:competencyDescription "Ser capaz de evaluar y discernir los diferentes mecanismos moleculares y celulares responsables de las transformaciones que llevan a cabo los seres vivos, así como poder desarrollar soluciones alternativas y novedosas frente a problemas biológicos conocidos y/o emergentes."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504221/2025-26/CG03> a ns1:Competency ;
    ns1:competencyCode "CG03" ;
    ns1:competencyDescription "Ser capaz de realizar su actividad de forma coordinada con otros profesionales en grupos multidisciplinares así como comunicar aspectos fundamentales de su actividad profesional a otros de su área, de áreas afines y a un público no especializado."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504221/2025-26/CT09> a ns1:Competency ;
    ns1:competencyCode "CT09" ;
    ns1:competencyDescription "Tener capacidad de análisis y síntesis para interpretar datos relevantes y abordar los problemas desde diferentes perspectivas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504221/2025-26/RA117> a ns1:LearningResult ;
    ns1:learningResultCode "RA117" ;
    ns1:learningResultDescription "Describir la estructura y función de los principales órganos, sistemas y aparatos de animales, incidiendo en los aspectos evolutivos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504221/2025-26/RA220> a ns1:LearningResult ;
    ns1:learningResultCode "RA220" ;
    ns1:learningResultDescription "Tener una visión integrada de la capacidad de los organismos para adaptarse a los cambios del medio interno o externo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504221/2025-26/RA221> a ns1:LearningResult ;
    ns1:learningResultCode "RA221" ;
    ns1:learningResultDescription "Conocer el funcionamiento de los diferentes sistemas y aparatos que componen los organismos animales, así como su regulación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504221/2025-26/RA222> a ns1:LearningResult ;
    ns1:learningResultCode "RA222" ;
    ns1:learningResultDescription "Aplicar el conocimiento de la fisiología de los organismos para explicar las causas de enfermedad."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504221/2025-26/RA88> a ns1:LearningResult ;
    ns1:learningResultCode "RA88" ;
    ns1:learningResultDescription "RA40"@es .

