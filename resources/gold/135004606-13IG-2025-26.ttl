    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/135004606/2025-26/syllabus> ;
    ns1:inpersonHours "62 horas (57.4%)"@es ;
    ns1:numberOfCredits 4.0 ;
    ns1:otherInformation """LAS COMPETENCIAS Y LOS RESULTADOS DE APRENDIZAJE DE ESTA ASIGNATURA SON CONFORMES CON LA MEMORIA VERIFICA DEL TÍTULO

Esta asignatura está relacionada con Objetivo 15 de Desarrollo sostenible (ODS15): Gestionar sosteniblemente los bosques, luchar contra la desertificación, detener e invertir la degradación de las tierras, detener la pérdida de biodiversidad"""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "62 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/135004606/2025-26/eventSchedule> ;
    schema:description "La asignatura busca proporcionar a los alumnos capacidades que le permitan evaluar el riesgo de incendios de un territorio, conocer las técnicas de prevención, restauración y lucha contra incendios forestales para poder determinar las medidas preventivas mas adecuadas a ese territorio. El alumno también tiene que desarrollar capacidades para la determinación de la inversión optima, que minimice los daños provocados por los incendios forestales con los gastos de prevención y extinción."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/javier.gonzalezr%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/javier.gonzalezr%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/javier.madrigal%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/ruben.laina%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/yolanda.ambrosio%40upm.es> ;
    schema:name "Incendios Forestales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004606/2025-26/CG03> a ns1:Competency ;
    ns1:competencyCode "CG03" ;
    ns1:competencyDescription "Conocimiento de los procesos de degradación que afecten a los sistemas y recursos forestales (contaminación, plagas y enfermedades, incendios, etc.) y capacidad para el uso de las técnicas de protección del medio forestal, de restauración hidrológico forestal y de conservación de la biodiversidad."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004606/2025-26/CT2> a ns1:Competency ;
    ns1:competencyCode "CT2" ;
    ns1:competencyDescription "Resolución de Problemas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004606/2025-26/RA101> a ns1:LearningResult ;
    ns1:learningResultCode "RA101" ;
    ns1:learningResultDescription "RA124 Calcular en una determinada zona, de acuerdo con la vegetación existente, la topografía y la climatología el riesgo de incendios de la zona"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004606/2025-26/RA102> a ns1:LearningResult ;
    ns1:learningResultCode "RA102" ;
    ns1:learningResultDescription "RA125 Evaluar y valorarr los daños directos e indirectos que puede causar un incendio forestal"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004606/2025-26/RA103> a ns1:LearningResult ;
    ns1:learningResultCode "RA103" ;
    ns1:learningResultDescription "RA227 Conocer los riesgos inherentes al fenómenos de los incendios forestales,así como los protocolos y normas de seguridad que deben tenerse en cuentas para salvaguardar la seguridad y la salud del personal interviniente en las labores de extinción"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004606/2025-26/RA104> a ns1:LearningResult ;
    ns1:learningResultCode "RA104" ;
    ns1:learningResultDescription "RA210 Utilizar redes y servicios de comunicación de una infraestructura de Tecnología de Información.ómenos de los incendios forestales,así como los protocolos y normas de seguridad que deben tenerse en cuentas para salvaguardar la seguridad y la salud del personal interviniente en las labores de extinción"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004606/2025-26/RA105> a ns1:LearningResult ;
    ns1:learningResultCode "RA105" ;
    ns1:learningResultDescription "RA226 Conocer los medios y materiales que se utilizan en la extinción de un incendio."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004606/2025-26/RA106> a ns1:LearningResult ;
    ns1:learningResultCode "RA106" ;
    ns1:learningResultDescription "RA221 Saber seleccionar las herramientas o aplicaciones adecuadas a los trabajos realizados en cada momento de acuerdo a la materia docente, integrando conocimientos de otras materias y de otros compañeros."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004606/2025-26/RA107> a ns1:LearningResult ;
    ns1:learningResultCode "RA107" ;
    ns1:learningResultDescription "RA222 Conocer y utilizar correctamente la terminología empleada en los incendios forestales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004606/2025-26/RA108> a ns1:LearningResult ;
    ns1:learningResultCode "RA108" ;
    ns1:learningResultDescription "RA228 Conocer las distintas estructuras organizativas responsables de la defensa de los montes frente a los incendios forestales en la Administración española (a nivel estatal y autonómico), asi como los principales organismos internacionales relacionados con esta temática."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004606/2025-26/RA109> a ns1:LearningResult ;
    ns1:learningResultCode "RA109" ;
    ns1:learningResultDescription "RA224 Diseñar un plan de prevención y lucha contra incendios de una determinada comarca o monte, de acuerdo con el riesgo de incendios, la probabilidad y el peligro de estos, el valor del monte, que optimice los recursos disponiblesConocer las distintas estructuras organizativas responsables de la defensa de los montes frente a los incendios forestales en la Administración española (a nivel estatal y autonómico), asi como los principales organismos internacionales relacionados con esta temática."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004606/2025-26/RA110> a ns1:LearningResult ;
    ns1:learningResultCode "RA110" ;
    ns1:learningResultDescription "RA225 Conocer las etapas del combate en un incendio forestal y las tácticas y las estrategias."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004606/2025-26/RA464> a ns1:LearningResult ;
    ns1:learningResultCode "RA464" ;
    ns1:learningResultDescription "Evaluar en una determinada zona, de acuerdo a las estadísticas de incendios y sus valores medioambientales, el riesgo y el peligro de incendios existente, calificándolo en relación con otras zonas de España, así como evaluar la problemática de éstos en dicha zona"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004606/2025-26/RA465> a ns1:LearningResult ;
    ns1:learningResultCode "RA465" ;
    ns1:learningResultDescription ""@es .

