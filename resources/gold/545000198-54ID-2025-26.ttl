    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/545000198/2025-26/eventSchedule> ;
    schema:description "Esta asignatura pretende profundizar en los contenidos relativos a Ergonomía, Psicosociología e Higiene presentes en los puestos de trabajo, con el fin de adaptar el trabajo a la persona, mejorando sus condiciones laborales con el objetivo de eliminar los daños producidos a su salud dentro de este ámbito. Todo ello teniendo presente la figura del empresario, como garante de la seguridad del trabajador."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/mariadelasnieves.gonzalez%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/aj.carpio%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/mariadelasnieves.gonzalez%40upm.es> ;
    schema:name "Evaluación y Prevención de Riesgos Ergonómicos, Psicosociales e Higienicos en la Empresa"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000198/2025-26/CB02> a ns1:Competency ;
    ns1:competencyCode "CB02" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar sus conocimientos a su trabajo o vocación de una forma profesional y posean las competencias que suelen demostrarse por medio de la elaboración y defensa de argumentos y la resolución de problemas dentro de su área de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000198/2025-26/CB03> a ns1:Competency ;
    ns1:competencyCode "CB03" ;
    ns1:competencyDescription "Que los estudiantes tengan la capacidad de reunir e interpretar datos relevantes (normalmente dentro de su área de estudio) para emitir juicios que incluyan una reflexión sobre temas relevantes de índole social, científica o ética"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000198/2025-26/CB04> a ns1:Competency ;
    ns1:competencyCode "CB04" ;
    ns1:competencyDescription "Que los estudiantes puedan transmitir información, ideas, problemas y soluciones a un público tanto especializado como no especializado"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000198/2025-26/CB05> a ns1:Competency ;
    ns1:competencyCode "CB05" ;
    ns1:competencyDescription "Que los estudiantes hayan desarrollado aquellas habilidades de aprendizaje necesarias para emprender estudios posteriores con un alto grado de autonomía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000198/2025-26/CE03> a ns1:Competency ;
    ns1:competencyCode "CE03" ;
    ns1:competencyDescription "Capacidad para aplicar los sistemas de representación espacial, el desarrollo del croquis, la proporcionalidad, el lenguaje y las técnicas de la representación gráfica de los elementos y procesos constructivos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000198/2025-26/CE05> a ns1:Competency ;
    ns1:competencyCode "CE05" ;
    ns1:competencyDescription "Conocimiento de los fundamentos teóricos y principios básicos aplicados a la edificación, de la mecánica de fluidos, la hidráulica, la electricidad y el electromagnetismo, la calorimetría e higrotermia, y la acústica."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000198/2025-26/CE27> a ns1:Competency ;
    ns1:competencyCode "CE27" ;
    ns1:competencyDescription "Aptitud para redactar estudios, estudios básicos y planes de seguridad y salud laboral, y coordinar la seguridad en fase de proyecto o en fase de ejecución de obra."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000198/2025-26/CG21> a ns1:Competency ;
    ns1:competencyCode "CG21" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de aprender de forma autónoma, fijándose unos objetivos, identificando los procedimientos y recursos con los que cuentan y evaluando sus propios procesos de aprendizaje en el ámbito de la administración y dirección de empresas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000198/2025-26/CG23> a ns1:Competency ;
    ns1:competencyCode "CG23" ;
    ns1:competencyDescription "Que los estudiantes adquieran un compromiso ético en su trabajo en el ámbito de la administración y dirección de empresas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000198/2025-26/CT02> a ns1:Competency ;
    ns1:competencyCode "CT02" ;
    ns1:competencyDescription "Comunicación oral y escrita. Capacidad de análisis y síntesis y de discusión de ideas propias. Capacidad de comunicación a través de la palabra y la imagen."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000198/2025-26/CT07> a ns1:Competency ;
    ns1:competencyCode "CT07" ;
    ns1:competencyDescription "Capacidad de búsqueda, análisis y selección de información."@es .

