    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/20504325/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/20504325/2025-26/RA103>,
        <https://guia-kg.skai.etsisi.upm.es/resource/20504325/2025-26/RA104>,
        <https://guia-kg.skai.etsisi.upm.es/resource/20504325/2025-26/RA105>,
        <https://guia-kg.skai.etsisi.upm.es/resource/20504325/2025-26/RA71> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/20504325/2025-26/syllabus> ;
    ns1:inpersonHours "41 horas y 30 minutos (51.2%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation """La Comisión de Calidad del Centro en su reunión de 29 de mayo de 2023 acordó aprobar la propuesta de reasignación de competencias transversales en las asignaturas de los Grados en Biotecnología, Ingeniería Alimentaria, Ingeniería Agrícola, Ingeniería Agroambiental, Ciencias Agrarias y Bioeconomía, y en el Máster Universitario en Ingeniería Agronómica. En virtud de dicho acuerdo esta asignatura ha sido designada como "Asignatura NO Punto Control". Esto significa que si bien puede seguir trabajando una o varias competencias transversales que se abordan en distintos puntos y aspectos de la asignatura, dicha formación y evaluación no será objeto de recopilación de evidencias por los sistemas de acreditación de la calidad del Centro.
La asignatura se relaciona con el Objetivo de Desarrollo Sostenible ODS 2: Poner fin al hambre, lograr la seguridad alimentaria y la mejora de la nutrición y promover la agricultura sostenible."""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "43 horas y 30 minutos"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/20504325/2025-26/eventSchedule> ;
    schema:description """El curso tiene como objetivo general que el alumno conozca los principales retos de la producción de cultivos. Dado que los alumnos han cursado la asignatura de Fundamentos de la Producción Vegetal, se entronca con los conocimientos adquiridos para mostrar las mejoras agronómicas y biotecnológicas que se consideran en la actualidad. Para ello, los cultivos se agrupan en tres categorías: herbáceos, hortícolas y leñosos y los objetivos específicos se centran entonces en los retos asociados a cada uno de ellos. Se considerarán cultivos tipo para ilustrar concretamente cada grupo de cultivos, así como logros obtenidos ante tales desafíos. En la última parte del curso se abordarán cultivos no cubiertos formalmente con anterioridad.
La superación de esta asignatura permite al alumno adquirir las siguientes competencias específicas de itinerario: CEI1.2.- Conocimientos básicos de los retos para la mejora de los cultivos agrícolas que puedan tener una aproximación biotecnológica."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/miguel.quemada%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/david.perezl%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/jon.lizaso%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/jose.nolasco%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/miguel.quemada%40upm.es> ;
    schema:name "Retos en los Cultivos Agrícolas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504325/2025-26/CB02> a ns1:Competency ;
    ns1:competencyCode "CB02" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar sus conocimientos a su trabajo o vocación de una forma profesional y posean las competencias que suelen demostrarse por medio de la elaboración y defensa de argumentos y la resolución de problemas dentro de su área de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504325/2025-26/CB03> a ns1:Competency ;
    ns1:competencyCode "CB03" ;
    ns1:competencyDescription "Que los estudiantes tengan la capacidad de reunir e interpretar datos relevantes (normalmente dentro de su área de estudio) para emitir juicios que incluyan una reflexión sobre temas relevantes de índole social, científica o ética"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504325/2025-26/CB04> a ns1:Competency ;
    ns1:competencyCode "CB04" ;
    ns1:competencyDescription "Que los estudiantes puedan transmitir información, ideas, problemas y soluciones a un público tanto especializado como no especializado"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504325/2025-26/RA103> a ns1:LearningResult ;
    ns1:learningResultCode "RA103" ;
    ns1:learningResultDescription "Conocer las técnicas de la producción agrícola intensiva que permiten modificar la climatología y el suelo en los cultivos en invernadero.."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504325/2025-26/RA104> a ns1:LearningResult ;
    ns1:learningResultCode "RA104" ;
    ns1:learningResultDescription "Conocer los fundamentos de la producción agrícola de cultivos herbáceos, hortícolas y leñosos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504325/2025-26/RA105> a ns1:LearningResult ;
    ns1:learningResultCode "RA105" ;
    ns1:learningResultDescription "Examinar casos del papel de la biotecnología al encarar retos de la producción agrícola"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504325/2025-26/RA71> a ns1:LearningResult ;
    ns1:learningResultCode "RA71" ;
    ns1:learningResultDescription "Conocer las técnicas agronómicas aplicables a la producción vegetal"@es .

