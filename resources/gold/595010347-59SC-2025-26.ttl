    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/595010347/2025-26/RA575>,
        <https://guia-kg.skai.etsisi.upm.es/resource/595010347/2025-26/RA576>,
        <https://guia-kg.skai.etsisi.upm.es/resource/595010347/2025-26/RA577> ;
