    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/143000128/2025-26/eventSchedule> ;
    schema:description """El objetivo de la asignatura es que el estudiante conozca las actividades de ensamblaje, integración y ensayos de un vehículo y/o equipo espacial, para así poder, conforme a las competencias que se indican posteriormente, gestionar y llevar a cabo dichas actividades.
La metodología de enseñanza y aprendizaje está articulada en torno al desarrollo de clases de presentación de contenidos, complementadas con clases prácticas guiadas. El peso asignado a las distintas actividades formativas es el siguiente: Clases de presentación de contenidos (1.5 ECTS), clases prácticas guiadas (2.5 ECTS)."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/elena.roibas%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/alejandrojose.fernandez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/andres.garcia.perez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/blanca.boado.cuartero%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/elena.roibas%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/javier.perez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/javier.piqueras%40upm.es> ;
    schema:name "Integración y Ensayos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000128/2025-26/E03> a ns1:Competency ;
    ns1:competencyCode "E03" ;
    ns1:competencyDescription "Conocer y comprender el entorno espacial y planetario, y su efecto en la operación de los vehículos aeroespaciales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000128/2025-26/E06> a ns1:Competency ;
    ns1:competencyCode "E06" ;
    ns1:competencyDescription "Conocer las etapas y procedimientos propios en el desarrollo de un programa espacial, así como las metodologías empleadas en la integración y operación de sistemas espaciales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000128/2025-26/E07> a ns1:Competency ;
    ns1:competencyCode "E07" ;
    ns1:competencyDescription "Conocer las fases de diseño, desarrollo, integración, ensayos, lanzamiento y operación en órbita de un vehículo espacial."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000128/2025-26/E09> a ns1:Competency ;
    ns1:competencyCode "E09" ;
    ns1:competencyDescription "Analizar los requisitos de una misión o vehículo espacial y extraer especificaciones de diseño para los diferentes subsistemas a partir de dichos requisitos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000128/2025-26/E10> a ns1:Competency ;
    ns1:competencyCode "E10" ;
    ns1:competencyDescription "Conocer los diferentes tipos de configuraciones de subsistemas y su relación con los distintos tipos de misión y los correspondientes requisitos, así como las relaciones entre diferentes subsistemas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000128/2025-26/E11> a ns1:Competency ;
    ns1:competencyCode "E11" ;
    ns1:competencyDescription "Establecer, diseñar, poner en práctica y adoptar un proceso de desarrollo de un subsistema de un vehículo espacial, y también del sistema completo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000128/2025-26/E14> a ns1:Competency ;
    ns1:competencyCode "E14" ;
    ns1:competencyDescription "Conocer los distintos tipos de ensayos ambientales, de radiación, estructurales y térmicos necesarios para verificar el diseño de una nave espacial"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000128/2025-26/E15> a ns1:Competency ;
    ns1:competencyCode "E15" ;
    ns1:competencyDescription "Desarrollar pruebas y experimentos para valorar y validar los resultados teóricos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000128/2025-26/E16> a ns1:Competency ;
    ns1:competencyCode "E16" ;
    ns1:competencyDescription "Planear, especificar, realizar y documentar un ensayo sobre un determinado subsistema espacial."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000128/2025-26/E17> a ns1:Competency ;
    ns1:competencyCode "E17" ;
    ns1:competencyDescription "Validar los modelos matemáticos a partir de los resultados de los correspondientes ensayos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000128/2025-26/E18> a ns1:Competency ;
    ns1:competencyCode "E18" ;
    ns1:competencyDescription "Integrar los diferentes subsistemas para conformar un sistema espacial"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000128/2025-26/E23> a ns1:Competency ;
    ns1:competencyCode "E23" ;
    ns1:competencyDescription "Desarrollar un trabajo de diseño de un producto propio de la ingeniería aeroespacial, utilizando eficazmente los recursos modernos de información y tecnologías, así como los recursos e infraestructuras disponibles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000128/2025-26/E24> a ns1:Competency ;
    ns1:competencyCode "E24" ;
    ns1:competencyDescription "Evaluar la bondad de un determinado diseño para satisfacer los requisitos de misión"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000128/2025-26/RA10> a ns1:LearningResult ;
    ns1:learningResultCode "RA10" ;
    ns1:learningResultDescription "RA10"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000128/2025-26/RA17> a ns1:LearningResult ;
    ns1:learningResultCode "RA17" ;
    ns1:learningResultDescription "Utiliza herramientas analíticas y numéricas que son objeto de otras asignaturas del plan de estudios."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000128/2025-26/RA18> a ns1:LearningResult ;
    ns1:learningResultCode "RA18" ;
    ns1:learningResultDescription "Identifica y resuelve problemas aplicando los conocimientos adquiridos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000128/2025-26/RA19> a ns1:LearningResult ;
    ns1:learningResultCode "RA19" ;
    ns1:learningResultDescription "Se integra y forma parte activa de equipos de trabajo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000128/2025-26/RA20> a ns1:LearningResult ;
    ns1:learningResultCode "RA20" ;
    ns1:learningResultDescription "Razona críticamente y de forma asociativa"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000128/2025-26/RA21> a ns1:LearningResult ;
    ns1:learningResultCode "RA21" ;
    ns1:learningResultDescription "Se comunica correctamente de forma oral y escrita"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000128/2025-26/RA25> a ns1:LearningResult ;
    ns1:learningResultCode "RA25" ;
    ns1:learningResultDescription "Es capaz de analizar unos requisitos de misión y evaluar la bondad de un diseño de subsistema para satisfacerlos."@es .

