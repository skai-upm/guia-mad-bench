<https://guia-kg.skai.etsisi.upm.es/resource/25001108/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/25001108/2025-26/CE3>,
        <https://guia-kg.skai.etsisi.upm.es/resource/25001108/2025-26/CG2>,
