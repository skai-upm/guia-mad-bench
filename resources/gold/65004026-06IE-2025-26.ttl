<https://guia-kg.skai.etsisi.upm.es/resource/65004026/2025-26/CE32> a ns1:Competency ;
    ns1:competencyCode "CE32" ;
    ns1:competencyDescription "Conocer y aplicar las técnicas de gestión Ambiental"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004026/2025-26/CE53> a ns1:Competency ;
    ns1:competencyCode "CE53" ;
    ns1:competencyDescription "Aplicar los principios de la tecnología ambiental a la evaluación de impactos, al tratamiento de residuos y a la sostenibilidad."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004026/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Conocer y aplicar conocimientos de ciencias y tecnologías básicas a la práctica de la Ingeniería de la Energía."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004026/2025-26/CG2> a ns1:Competency ;
    ns1:competencyCode "CG2" ;
    ns1:competencyDescription "Poseer capacidad para diseñar, desarrollar, implementar, gestionar y mejorar productos, sistemas y procesos en los distintos ámbitos energéticos, usando técnicas analíticas, computacionales o experimentales apropiadas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004026/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Aplicar los conocimientos adquiridos para identificar, formular y resolver problemas dentro de contextos amplios y multidisciplinarios, siendo capaces de integrar conocimientos, trabajando en equipos multidisciplinares."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004026/2025-26/CG6> a ns1:Competency ;
    ns1:competencyCode "CG6" ;
    ns1:competencyDescription "Poseer habilidades de aprendizaje que permitan continuar estudiando a lo largo de la vida para su adecuado desarrollo profesional."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004026/2025-26/RA135> a ns1:LearningResult ;
    ns1:learningResultCode "RA135" ;
    ns1:learningResultDescription "Comprender los fundamentos generales de la gestión del medio ambiente en la empresa, de la evaluación de impacto ambiental y de las técnicas correctoras para la minimización de impactos ambientales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004026/2025-26/RA136> a ns1:LearningResult ;
    ns1:learningResultCode "RA136" ;
    ns1:learningResultDescription "Comprender el impacto ambiental de la producción y uso de la energía."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004026/2025-26/RA137> a ns1:LearningResult ;
    ns1:learningResultCode "RA137" ;
    ns1:learningResultDescription "Comprender el concepto de análisis de ciclo de vida de los sistemas energéticos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004026/2025-26/RA138> a ns1:LearningResult ;
    ns1:learningResultCode "RA138" ;
    ns1:learningResultDescription "Aplicar los resultados del análisis de ciclo de vida a la comparación de diferentes alternativas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004026/2025-26/RA139> a ns1:LearningResult ;
    ns1:learningResultCode "RA139" ;
    ns1:learningResultDescription "Conocer la importancia relativa de las diferentes tecnologías medioambientales, su tendencia y su incidencia en el resultado global."@es .

