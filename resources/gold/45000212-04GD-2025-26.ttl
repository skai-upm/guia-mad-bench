<https://guia-kg.skai.etsisi.upm.es/resource/45000212/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Álgebra tensorial"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000212/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Álgebra vectorial. Producto escalar, producto vectorial y producto mixto. Notación indicial. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000212/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "2.4. Introducción a los campos tensoriales: campos escalares, vectoriales y tensoriales de segundo orden. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000212/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "2.5. Campos escalares. Superficies equipotenciales. Gradiente. Propiedades. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000212/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "2.6. Campos vectoriales. Líneas de campo. Símbolos de Christoffel. Derivada covariante. Gradiente. Propiedades. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000212/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "2.7. Operadores diferenciales: Divergencia y rotacional de un campo vectorial. Expresión en componentes cartesianas y curvilíneas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000212/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "2.8. Laplaciano de un campo escalar. Ecuaciones de Poisson y Laplace. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000212/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "2.9. Algunas identidades útiles del cálculo vectorial. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000212/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "3. Teoremas integrales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000212/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "3.1. Parametrización de superficies. Base natural. Vector normal. Tensor métrico de superficie y Primera Forma Fundamental. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000212/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "3.2. Curvas sobre una superficie regular. Curvatura normal y geodésica. Segunda forma fundamental. Curvatura de Gauss y media. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000212/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "3.3. Integración de campos escalares sobre curvas y superficies. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000212/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Concepto de tensor. Tensores de primer orden. Formas lineales. Tensores de segundo orden. Diadas y formas diádicas. Tensor métrico, tensor axial. Estructura de espacio vectorial. Producto contraído y producto escalar. Tensores de orden superior. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000212/2025-26/syllabus/20> a ns1:SyllabusItem ;
    ns1:itemIndex 20 ;
    ns1:syllabusDescription "3.4. Orientación de curvas y superficies. Integración de campos vectoriales. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000212/2025-26/syllabus/21> a ns1:SyllabusItem ;
    ns1:itemIndex 21 ;
    ns1:syllabusDescription "3.5. Teorema de Green. Aplicaciones. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000212/2025-26/syllabus/22> a ns1:SyllabusItem ;
    ns1:itemIndex 22 ;
    ns1:syllabusDescription "3.6. Teorema de Stokes o del rotacional. Aplicaciones. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000212/2025-26/syllabus/23> a ns1:SyllabusItem ;
    ns1:itemIndex 23 ;
    ns1:syllabusDescription "3.7. Teorema de Gauss o de la divergencia. Aplicaciones. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000212/2025-26/syllabus/24> a ns1:SyllabusItem ;
    ns1:itemIndex 24 ;
    ns1:syllabusDescription "4. Teoría del potencial"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000212/2025-26/syllabus/25> a ns1:SyllabusItem ;
    ns1:itemIndex 25 ;
    ns1:syllabusDescription "4.1. Teoría del potencial escalar. Existencia y cálculo. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000212/2025-26/syllabus/26> a ns1:SyllabusItem ;
    ns1:itemIndex 26 ;
    ns1:syllabusDescription "4.2. Teoría del potencial vector en el plano. Función de corriente. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000212/2025-26/syllabus/27> a ns1:SyllabusItem ;
    ns1:itemIndex 27 ;
    ns1:syllabusDescription "4.3. Potencial vector de algunos campos vectoriales en el espacio. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000212/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "1.3. Bases y componentes tensoriales. Algebra tensorial en componentes. Estructura matricial de las componentes de un tensor de orden 2. Algoritmos matriciales. Cambios de base. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000212/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "1.4. Estudio particular de los tensores de segundo orden. Tensores regulares y tensor inverso. Tensor traspuesto, tensores simétricos y antisimétricos. Autovalores y autovectores. Invariantes. Descomposición espectral de un tensor simétrico. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000212/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "1.5. Tensores ortogonales. Simetrías especulares y rotaciones. Expresión en términos de sus elementos geométricos. Descomposición polar. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000212/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "2. Campos tensoriales y operadores diferenciales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000212/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "2.1. Parametrización de curvas. El parámetro arco. Longitud. Vector tangente. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000212/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "2.2. Triedro de Frenet. Fórmulas de Frenet: curvatura y torsión. Vector de Darboux. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000212/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "2.3. Sistemas de coordenadas ortogonales. Coordenadas cartesianas, cilíndricas y esféricas. Líneas coordenadas. Base natural. Cambio de sistema de coordenadas. Sin subniveles"@es .

