<https://guia-kg.skai.etsisi.upm.es/resource/93000889/2025-26/CE1> a ns1:Competency ;
    ns1:competencyCode "CE1" ;
    ns1:competencyDescription "Adquisición de una formación sólida y rigurosa en temas avanzados de Estadística, Matemática computacional, Modelos estocásticos y Metodología de la toma de Decisiones aplicadas al tratamiento de la Información."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000889/2025-26/CE2> a ns1:Competency ;
    ns1:competencyCode "CE2" ;
    ns1:competencyDescription "Capacidad para planificar la resolución de un problema en función de las herramientas de que se disponga y, en su caso, de las restricciones de tiempo y recursos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000889/2025-26/CE3> a ns1:Competency ;
    ns1:competencyCode "CE3" ;
    ns1:competencyDescription "Capacidad para utilizar aplicaciones informáticas estadísticas, de cálculo numérico y simbólico, visualización gráfica, optimización u otras para resolver problemas con un elevado grado de complejidad"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000889/2025-26/CE4> a ns1:Competency ;
    ns1:competencyCode "CE4" ;
    ns1:competencyDescription "Desarrollar habilidades de aprendizaje en Estadística Computacional y Matemáticas, así como en sus respectivas aplicaciones, que permitan al alumno continuar estudiando y profundizando en la materia de modo autónomo, así como el desarrollo profesional con un alto grado de independencia."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000889/2025-26/CE5> a ns1:Competency ;
    ns1:competencyCode "CE5" ;
    ns1:competencyDescription "Resolver problemas y casos reales planteados en el tratamiento estadístico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000889/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Aprender a aplicar los conocimientos adquiridos y a explotar su potencial para la resolución de problemas en entornos nuevos o poco conocidos dentro de contextos más amplios (o multidisciplinares) en el tratamiento estadístico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000889/2025-26/CG2> a ns1:Competency ;
    ns1:competencyCode "CG2" ;
    ns1:competencyDescription "Elaborar adecuadamente y con originalidad argumentos motivados y proyectos de trabajo, redactar planes, así como formular hipótesis y conjeturas razonables en su área de especialización."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000889/2025-26/CG4> a ns1:Competency ;
    ns1:competencyCode "CG4" ;
    ns1:competencyDescription "Comunicar y presentar públicamente ideas, procedimientos o informes de investigación, así como asesorar a personas u organizaciones en el tratamiento estadístico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000889/2025-26/CG5> a ns1:Competency ;
    ns1:competencyCode "CG5" ;
    ns1:competencyDescription "Comprender y utilizar el lenguaje y las herramientas matemáticas para modelizar y resolver problemas complejos, reconociendo y valorando las situaciones y problemas susceptibles de ser tratados matemáticamente."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000889/2025-26/CG7> a ns1:Competency ;
    ns1:competencyCode "CG7" ;
    ns1:competencyDescription "Saber abstraer en un modelo matemático las propiedades y características esenciales de un problema real reconociendo su rango de aplicabilidad y limitaciones"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000889/2025-26/CT1> a ns1:Competency ;
    ns1:competencyCode "CT1" ;
    ns1:competencyDescription "Saber aplicar sus conocimientos a su trabajo o vocación de una forma profesional y poseer las competencias que suelen demostrarse por medio de la elaboración y defensa de argumentos y en la resolución de problemas y estudio de casos. Esto implica, más concretamente: Integrar creativamente conocimientos y aplicarlos a la resolución de problemas complejos, perseguir objetivos de calidad en el desarrollo de su actividad profesional, adquirir capacidad para la toma de decisiones y de dirección de recursos humanos, ser capaz de mostrar creatividad, iniciativa y espíritu emprendedor para afrontar los retos de su actividad, valorar la importancia de los métodos estadístico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000889/2025-26/CT2> a ns1:Competency ;
    ns1:competencyCode "CT2" ;
    ns1:competencyDescription "Tener la capacidad de reunir e interpretar datos relevantes para emitir juicios que incluyan una reflexión sobre temas relevantes de índole científica, tecnológica y empresarial. Demostrar razonamiento crítico y gestionar información científica y técnica de calidad, bibliografía, bases de datos especializadas y recursos accesibles a través de Internet."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000889/2025-26/RA16> a ns1:LearningResult ;
    ns1:learningResultCode "RA16" ;
    ns1:learningResultDescription "Conocimiento de Matlab y de algún lenguaje de cálculo simbólico (Derive o Maple)"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000889/2025-26/RA31> a ns1:LearningResult ;
    ns1:learningResultCode "RA31" ;
    ns1:learningResultDescription "Serán capaces de resolver problemas colaborando con compañeros, y de exponer sus resultados"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000889/2025-26/RA46> a ns1:LearningResult ;
    ns1:learningResultCode "RA46" ;
    ns1:learningResultDescription "Serán capaces de plantear problemas de tratamiento de señales temporales e imágenes en lenguaje matemático."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000889/2025-26/RA47> a ns1:LearningResult ;
    ns1:learningResultCode "RA47" ;
    ns1:learningResultDescription "Serán capaces de resolver problemas relativos al tratamiento de señales utilizando técnicas del Análisis Funcional y la teoría Wavelet"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000889/2025-26/RA48> a ns1:LearningResult ;
    ns1:learningResultCode "RA48" ;
    ns1:learningResultDescription "Sabrán comunicar oralmente y por escrito resultados avanzados en estos ámbitos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000889/2025-26/RA49> a ns1:LearningResult ;
    ns1:learningResultCode "RA49" ;
    ns1:learningResultDescription "Serán capaces de emplear los métodos y modelos de estas disciplinas en su futura actividad investigadora"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000889/2025-26/RA7> a ns1:LearningResult ;
    ns1:learningResultCode "RA7" ;
    ns1:learningResultDescription "Sabrán comunicar oralmente y por escrito resultados avanzados en estos ámbitos"@es .

