<https://guia-kg.skai.etsisi.upm.es/resource/93000889/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. La Transformada Discreta de Fourier (DFT) para señales finitas unidimensionales y el principio de incertidumbre. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000889/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "2. La Transformada Rápida de Fourier (FFT). Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000889/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "3. Localización en tiempo y en frecuencia: la Transformada de Fourier en Tiempo Corto (STFT). Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000889/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "4. Wavelets para señales finitas unidimensionales y la Transformada Wavelet Discreta (DWT). Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000889/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "5. Señales bidimensionales (imágenes): operaciones puntuales (píxel a píxel), filtros y Transformada Discreta de Fourier bidimensional. Sin subniveles"@es .

