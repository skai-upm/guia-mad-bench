    ns1:bibliographyType "Otros"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35001103/2025-26/didactic_resource/3> a ns1:DidacticResource ;
    ns1:bibliographyDescription "Software libre útil y de fácil utilización para la visualización de conceptos relacionados con espacios vectoriales, espacios afines, movimientos en el plano y cónicas."@es ;
    ns1:bibliographyTitle "GeoGebra"@es ;
    ns1:bibliographyType "Recursos web"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35001103/2025-26/didactic_resource/4> a ns1:DidacticResource ;
    ns1:bibliographyDescription "Libro reciente escrito por uno de los profesores del departamento. Se ajusta muy bien al temario actual de la asignatura"@es ;
