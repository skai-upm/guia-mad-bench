        <https://guia-kg.skai.etsisi.upm.es/resource/m.barbero%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/mariadelcarmen.cerezo%40upm.es> ;
    schema:name "Geometria Afin y Proyectiva"@es .

