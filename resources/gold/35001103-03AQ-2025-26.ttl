    schema:inLanguage "Inglés/Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/df.mtorres%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/eugenia.rosado%40upm.es>,
