<https://guia-kg.skai.etsisi.upm.es/resource/25001405/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/25001405/2025-26/CE42>,
        <https://guia-kg.skai.etsisi.upm.es/resource/25001405/2025-26/CG14>,
        <https://guia-kg.skai.etsisi.upm.es/resource/25001405/2025-26/CG15>,
        <https://guia-kg.skai.etsisi.upm.es/resource/25001405/2025-26/CG16>,
        <https://guia-kg.skai.etsisi.upm.es/resource/25001405/2025-26/CG5> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/25001405/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/25001405/2025-26/didactic_resource/2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/25001405/2025-26/didactic_resource/3>,
