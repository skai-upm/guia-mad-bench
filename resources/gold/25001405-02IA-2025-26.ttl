    ns1:itemIndex 4 ;
    ns1:syllabusDescription "4. LA TRANSPIRACIÓN Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001405/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "5. TRANSPORTE POR EL FLOEMA"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001405/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "5.1. Transporte por el floema. Composición del contenido floemático. Fuentes y sumideros. Modelos de transporte por el floema: Hipótesis de Münch. El transporte a corta distancia: carga y descarga del floema. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001405/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "6. CONCEPTOS BÁSICOS DE LA NUTRICIÓN MINERAL. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001405/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "7. MORFOGÉNESIS VEGETAL. Sin subniveles"@es .

