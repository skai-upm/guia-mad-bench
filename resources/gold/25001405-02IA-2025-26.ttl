    ns1:itemIndex 25 ;
    ns1:syllabusDescription "18. MOVIMIENTOS DE LAS PLANTAS Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001405/2025-26/syllabus/26> a ns1:SyllabusItem ;
    ns1:itemIndex 26 ;
    ns1:syllabusDescription "19. LAS PLANTAS EN CONDICIONES ADVERSAS"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001405/2025-26/syllabus/27> a ns1:SyllabusItem ;
    ns1:itemIndex 27 ;
    ns1:syllabusDescription "19.1. Estrés hídrico. Temperaturas extremas. Salinidad. Contaminantes químicos. Otras situaciones desfavorables: Enfermedades, herbívoros y parásitos. Alelopatías. Sin subniveles"@es .

