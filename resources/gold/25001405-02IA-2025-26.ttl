        <https://guia-kg.skai.etsisi.upm.es/resource/25001405/2025-26/didactic_resource/6>,
        <https://guia-kg.skai.etsisi.upm.es/resource/25001405/2025-26/didactic_resource/7> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/25001405/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/25001405/2025-26/RA255>,
        <https://guia-kg.skai.etsisi.upm.es/resource/25001405/2025-26/RA256>,
        <https://guia-kg.skai.etsisi.upm.es/resource/25001405/2025-26/RA257>,
        <https://guia-kg.skai.etsisi.upm.es/resource/25001405/2025-26/RA258>,
        <https://guia-kg.skai.etsisi.upm.es/resource/25001405/2025-26/RA259> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/25001405/2025-26/syllabus> ;
    ns1:inpersonHours "48 horas (46.2%)"@es ;
    ns1:numberOfCredits 4.0 ;
    ns1:otherInformation """En esta asignatura se imparten los conocimientos básicos de la fisiología de las plantas. El aprendizaje de estos conocimientos otorga capacidades y competencias al estudiante para entender, seleccionar y aplicar las metas que se establecen en los ODS2, ODS12,ODS13 Y ODS15.
La Comisión de Calidad del Centro en su reunión de 29 de mayo de 2023 acordó aprobar la propuesta de reasignación de competencias transversales en las asignaturas de los Grados en Biotecnología, Ingeniería Alimentaria, Ingeniería Agrícola, Ingeniería Agroambiental, Ciencias Agrarias y Bioeconomía, y en el Máster Universitario en Ingeniería Agronómica. En virtud de dicho acuerdo esta asignatura ha sido designada como ?Asignatura NO Punto Control*?. Esto significa que si bien puede seguir trabajando una o varias competencias transversales que se abordan en distintos puntos y aspectos de la asignatura, dicha formación y evaluación no será objeto de recopilación de evidencias por los sistemas de acreditación de la calidad del Centro?.*Asignatura punto control (APC): aquella asignatura en la que se verificará la formación y evaluación de la competencia transversal que le corresponda"""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "48 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/25001405/2025-26/eventSchedule> ;
    schema:description """El agua en la planta y los factores que determinan elmovimiento de la misma en el continuo suelo-planta-atmósfera.
Cómo las plantas obtienen sus nutrientes orgánicos e inorgánicos.
Fisiología del desarrollo de la planta y su regulación tanto por las hormonasvegetales como por factores ambientales.
Respuestas que presentan las plantas en situaciones de estrés abiótico ybiótico y sus mecanismos de defensa."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/elena.carrio%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/elena.carrio%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/sara.mira%40upm.es> ;
    schema:name "Fisiologia Vegetal"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001405/2025-26/CE42> a ns1:Competency ;
    ns1:competencyCode "CE42" ;
    ns1:competencyDescription "Conocimiento de los órganos y funciones en los vegetales. Descripción de la fisiología de la nutrición, transporte, crecimiento y reproducción de los vegetales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001405/2025-26/CG14> a ns1:Competency ;
    ns1:competencyCode "CG14" ;
    ns1:competencyDescription "Análisis y síntesis, razonamiento crítico y resolución de problemas científicos y técnicos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001405/2025-26/CG15> a ns1:Competency ;
    ns1:competencyCode "CG15" ;
    ns1:competencyDescription "Adaptación a cambios tecnológicos y motivación por la calidad"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001405/2025-26/CG16> a ns1:Competency ;
    ns1:competencyCode "CG16" ;
    ns1:competencyDescription "Aplicar conocimientos adquiridos a la práctica de la ingeniería agraria"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001405/2025-26/CG5> a ns1:Competency ;
    ns1:competencyCode "CG5" ;
    ns1:competencyDescription "Que los estudiantes hayan desarrollado aquellas habilidades de aprendizaje necesarias para emprender estudios posteriores con un alto grado de autonomía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001405/2025-26/RA255> a ns1:LearningResult ;
    ns1:learningResultCode "RA255" ;
    ns1:learningResultDescription "Conoce profundamente los procesos fisiológicos, así como su integración espacial y temporal en la planta."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001405/2025-26/RA256> a ns1:LearningResult ;
    ns1:learningResultCode "RA256" ;
    ns1:learningResultDescription "Es capaz para solucionar aquellos problemas relacionados con la Producción, Mejora y Protección Vegetal que tengan una base fisiológica."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001405/2025-26/RA257> a ns1:LearningResult ;
    ns1:learningResultCode "RA257" ;
    ns1:learningResultDescription "Usa adecuadamente terminología específica."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001405/2025-26/RA258> a ns1:LearningResult ;
    ns1:learningResultCode "RA258" ;
    ns1:learningResultDescription "Es capaz de evaluar la información que les llega bajo distintos enfoques."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001405/2025-26/RA259> a ns1:LearningResult ;
    ns1:learningResultCode "RA259" ;
    ns1:learningResultDescription "Conoce el Método Científico, de forma que sabe enfocar problemas nuevos, manejar la gran cantidad de información a la que hoy en día se tiene acceso, y analizar con profundidad distintos hechos fisiológicos."@es .

