    ns1:competencyDescription "Capacidad de pensamiento creativo con el objetivo de desarrollar enfoques y métodos nuevos y originales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000655/2025-26/CG9> a ns1:Competency ;
    ns1:competencyCode "CG9" ;
    ns1:competencyDescription "Apreciación de los límites del conocimiento actual y de la aplicación práctica de la tecnología más reciente"@es .

