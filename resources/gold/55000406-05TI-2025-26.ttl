<https://guia-kg.skai.etsisi.upm.es/resource/55000406/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Introducción"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000406/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Aspectos generales, Magnitudes, relaciones e hipótesis básicas en problemas termomecánicos. Condiciones de contorno. Simetrías y antisimetrías Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000406/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "3.3. Cálculo matricial. Ensamblaje, condiciones de contorno y cálculo de desplazamientos. Esfuerzos, tensiones y reacciones Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000406/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "3.4. Ejemplos de Elementos Finitos y aplicaciones Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000406/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "4. El método de elementos finitos para problemas de termoelasticidad en sólidos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000406/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "4.1. Introducción . Tipologías y Clasificación. Grados de libertad y esfuerzos Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000406/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "4.2. Elasticidad. Ecuaciones generales. Comportamiento-Compatibilidad-Equilibrio Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000406/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "4.3. Elementos Finitos con sólidos 2D."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000406/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "4.3.1. Elemento de tres nudos. Formulación y ejemplos Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000406/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "4.3.2. Elemento de cuatro nudos. Formulación y ejemplos Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000406/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "4.3.3. Elementos no conformes. Formulación y ejemplos Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000406/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "4.3.4. Reglas generales de mallado. Submodelado Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000406/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Métodos de cálculo. Ejemplos de soluciones numéricas. Programas comerciales. Limitaciones de los modelos lineales y de los métodos numéricos Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000406/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "2. El método de elementos finitos para problemas de transferencia de calor"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000406/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "2.1. Formulación fuerte. Conservación de energía y Ley de Fourier. Condiciones de contorno esenciales y naturales. Problemas de transferencia de calor Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000406/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "2.2. Formulación débil. Minimización de energía . El método de elementos finitos en problemas de Calor. Funciones de forma. Vector de fuerzas y matriz de rigidez Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000406/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "2.3. Ejemplos Elementos Finitos y aplicaciones Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000406/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "3. El método de elementos finitos para problemas de elasticidad en barras"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000406/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "3.1. Formulación fuerte. Ecuación de campo de la barra . Repaso de elasticidad. Condiciones de contorno esenciales y naturales. Problemas de vigas Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000406/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "3.2. Formulación débil. Minimización de energía . El método de elementos finitos en problemas de Elasticidad. Funciones de forma. Matrices de rigidez y vector de cargas. Sin subniveles"@es .

