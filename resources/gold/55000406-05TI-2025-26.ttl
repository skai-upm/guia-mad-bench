    ns1:competencyDescription "Conocimientos y capacidad para el cálculo y diseño de estructuras y construcciones industriales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000406/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Conocer y aplicar conocimientos de ciencias y tecnologías básicas a la práctica de la Ingeniería Industrial."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000406/2025-26/CG10> a ns1:Competency ;
    ns1:competencyCode "CG10" ;
