<https://guia-kg.skai.etsisi.upm.es/resource/143005006/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. INTRODUCION."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005006/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. 1.1. El concepto de seguridad. 1.2. Normativa de aplicación en seguridad operacional en el transporte aéreo. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005006/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "5. PILARES Y RESPONSABILIDADES PARA GESTIONAR LA SEGURIDAD."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005006/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "5.1. 5.1. Gestión de la seguridad operacional ? Ocho pilares básicos. 5.2. Cuatro responsabilidades para gestionar la seguridad operacional. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005006/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "6. EL PROCESO DE LA GESTIÓN Y MITIGACIÓN DE LOS RIESGOS DE SEGURIDAD OPERACIONAL."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005006/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "6.1. 6.1. Peligros y riesgos: Identificación, comprensión, análisis y documentación de los peligros. 6.2. Probabilidad de los riesgos de seguridad operacional. 6.3. Gravedad de los riesgos de seguridad operacional. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005006/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "6.2. .4. Tolerabilidad de los riesgos de seguridad operacional. 6.5. Control/mitigación de los riesgos de seguridad operacional. 6.6. Requisitos de gestión de la seguridad operacional. 6.7 Evaluación y gestión de los riesgos de seguridad operacional. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005006/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "7. PROGRAMA ESTATAL DE SEGURIDAD OPERACIONAL."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005006/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "7.1. 7.1 Objetivo y contenido. 7.2. Componentes y elementos de un SSP. 7.3. El marco para SSP de la OACI. 7.4. Elaboración de un SSP. 7.5. Implantación del SSP. 7.6. Función del SSP en apoyo de la implantación del SMS. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005006/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "2. EVOLUCIÓN DEL PENSAMIENTO SOBRE SEGURIDAD."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005006/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "2.1. 2.1. Causalidad de los accidentes. 2.2 El accidente de organización Modelo de Reason. 2.3. Las personas, el contexto y la seguridad operacional ? El modelo Shell. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005006/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "2.2. 2.4. Errores y violaciones. 2.5 Cultura de organización. 2.6. El estereotipo de la seguridad operacional y el dilema gerencial. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005006/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "3. NECESIDAD Y ESTRATEGIAS PARA LA GESTIÓN DE LA SEGURIDAD OPERACIONAL."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005006/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "3.1. 3.1. Necesidad de la gestión de la seguridad operacional. 3.2. Estrategias para la gestión de la seguridad operacional. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005006/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "4. SARPS DE LA OACI SOBRE GESTIÓN DE LA SEGURIDAD OPERACIONAL."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005006/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "4.1. 4.1 Programa estatal de seguridad operacional (SSP). 4.2. Nivel aceptable de seguridad operacional (ALoS). 4.3 Sistema de gestión de la seguridad operacional (SMS). Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005006/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "4.2. 4.4 Eficacia de la seguridad operacional del SMS. 4.5. Responsabilidad y rendición de cuentas de la administración. 4.6. Relación entre un SSP y un SMS Cumplimiento y eficacia. Sin subniveles"@es .

