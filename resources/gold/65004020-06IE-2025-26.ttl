    ns1:learningResultCode "RA103" ;
    ns1:learningResultDescription "Comprensión y dominio de los conceptos básicos sobre transferencia de calor y materia y su aplicación para la resolución de problemas de la ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004020/2025-26/RA104> a ns1:LearningResult ;
