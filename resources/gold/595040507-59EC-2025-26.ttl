<https://guia-kg.skai.etsisi.upm.es/resource/595040507/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/595040507/2025-26/CE%20B1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/595040507/2025-26/CG%2002>,
