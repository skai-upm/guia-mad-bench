        <https://guia-kg.skai.etsisi.upm.es/resource/203000105/2025-26/CG08>,
        <https://guia-kg.skai.etsisi.upm.es/resource/203000105/2025-26/CT01>,
        <https://guia-kg.skai.etsisi.upm.es/resource/203000105/2025-26/CT02>,
        <https://guia-kg.skai.etsisi.upm.es/resource/203000105/2025-26/CT04>,
        <https://guia-kg.skai.etsisi.upm.es/resource/203000105/2025-26/CT06>,
        <https://guia-kg.skai.etsisi.upm.es/resource/203000105/2025-26/CT07> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/203000105/2025-26/didactic_resource/1> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/203000105/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/203000105/2025-26/RA12>,
        <https://guia-kg.skai.etsisi.upm.es/resource/203000105/2025-26/RA51> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/203000105/2025-26/syllabus> ;
    ns1:inpersonHours "24 horas y 30 minutos (37.7%)"@es ;
    ns1:numberOfCredits 2.5 ;
    ns1:otherInformation "La asignatura se relaciona con el ODS11 \"Ciudades y comunidades sostenibles\" y ODS12 \"Producción y Consumo responsables\""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "24 horas y 30 minutos"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/203000105/2025-26/eventSchedule> ;
    schema:description """La asignatura optativa Cadena de Valor Agroalimentaria pretende aportar una visión global de los productos agroalimentarios, el proceso que siguen desde la producción al consumidor, es decir, los eslabones que conforman la cadena de valor y la relaciones funcionales entre los diversos eslabones.
Los mercados alimentarios vienen experimentando desde hace décadas fuertes cambios, lo que ocasiona serios problemas de abastecimiento a la población y todo lo que eso conlleva. Por ello, se considera necesario realizar estudios objetivos para un diagnóstico correcto y poder mejorar la situacion. En esta asignatura se estudiará la cadena de valor desde distintos enfoques y se expondrán casos prácticos reales tanto en áreas desarrolladas como en desarrollo."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/teresa.briz%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/teresa.briz%40upm.es> ;
    schema:name "Cadena de Valor Agroalimentaria"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000105/2025-26/CB09> a ns1:Competency ;
    ns1:competencyCode "CB09" ;
    ns1:competencyDescription "Que los estudiantes sepan comunicar sus conclusiones y los conocimientos y razones últimas que las sustentan a públicos especializados y no especializados de un modo claro y sin ambigüedades"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000105/2025-26/CE01> a ns1:Competency ;
    ns1:competencyCode "CE01" ;
    ns1:competencyDescription "Comprensión de la evolución histórica de las teorías sobre el desarrollo y la desigualdad así como de la evolución de las formas de cooperación internacional."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000105/2025-26/CE02> a ns1:Competency ;
    ns1:competencyCode "CE02" ;
    ns1:competencyDescription "Comprensión de los enfoques actuales del desarrollo humano y desarrollo sostenible."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000105/2025-26/CE04> a ns1:Competency ;
    ns1:competencyCode "CE04" ;
    ns1:competencyDescription "Conocimiento de las organizaciones y de las instituciones legales, técnicas y financieras del sistema de ayuda al desarrollo, tanto nacionales como multilaterales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000105/2025-26/CE05> a ns1:Competency ;
    ns1:competencyCode "CE05" ;
    ns1:competencyDescription "Conocimiento de los actores de la lucha contra la pobreza y la exclusión social y sus estrategias y modalidades específicas de acción."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000105/2025-26/CE06> a ns1:Competency ;
    ns1:competencyCode "CE06" ;
    ns1:competencyDescription "Capacidad para aplicar métodos de trabajo en asociación y en red apropiados para las organizaciones que luchan contra la pobreza y la exclusión social."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000105/2025-26/CE08> a ns1:Competency ;
    ns1:competencyCode "CE08" ;
    ns1:competencyDescription "Conocimiento de los métodos y herramientas aplicables a la identificación, planificación, gestión, ejecución y evaluación de políticas, programas y proyectos de desarrollo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000105/2025-26/CE09> a ns1:Competency ;
    ns1:competencyCode "CE09" ;
    ns1:competencyDescription "Capacidad de aplicación de los métodos y herramientas apropiados para el análisis, la planificación, la gestión, la ejecución y la evaluación de proyectos, programas y políticas de desarrollo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000105/2025-26/CE13> a ns1:Competency ;
    ns1:competencyCode "CE13" ;
    ns1:competencyDescription "Capacidad de aplicación de las técnicas apropiadas disponibles en la lucha contra la pobreza y la exclusión en procesos que correspondan al área de especialización profesional del alumno."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000105/2025-26/CE14> a ns1:Competency ;
    ns1:competencyCode "CE14" ;
    ns1:competencyDescription "Capacidad para desarrollar programas de acción y programas formativos destinados a los agentes o a la población objetivo, correspondientes al área de especialización profesional del alumno, en el marco de las acciones de desarrollo y cooperación internacional."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000105/2025-26/CE15> a ns1:Competency ;
    ns1:competencyCode "CE15" ;
    ns1:competencyDescription "Capacidad para incorporar elementos de innovación y mejora permanente en el área de especialización profesional del alumno."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000105/2025-26/CE16> a ns1:Competency ;
    ns1:competencyCode "CE16" ;
    ns1:competencyDescription "Capacidad de manejo de las herramientas específicas para la gestión de la información en programas y proyectos de desarrollo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000105/2025-26/CG04> a ns1:Competency ;
    ns1:competencyCode "CG04" ;
    ns1:competencyDescription "Habilidades de investigación e innovación: Capacidad para identificar y formular hipótesis o ideas innovadoras en los ámbitos técnico y organizacional y someterlas a prueba de objetividad, de coherencia y de sostenibilidad, adaptada a los contextos de zonas desfavorecidas y por tanto con carencias tanto de infraestructuras, como de alta cualificación en las capacidades humanas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000105/2025-26/CG07> a ns1:Competency ;
    ns1:competencyCode "CG07" ;
    ns1:competencyDescription "Conocimiento de las relaciones entre sociedad, ciencia y técnica, y capacidad para comprender y evaluar el impacto social de las transformaciones técnicas y su asimilación,en los contextos propios a las sociedades en desarrollo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000105/2025-26/CG08> a ns1:Competency ;
    ns1:competencyCode "CG08" ;
    ns1:competencyDescription "Comprensión de la responsabilidad ética y profesional, que comprende la capacidad para tomar decisiones éticas informadas, conocimiento de los códigos de conducta profesional, evaluación de la dimensión ética de la práctica profesional y comportamiento ético visible, aplicadas a los contextos de actividad propios a las sociedades menos desarrolladas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000105/2025-26/CT01> a ns1:Competency ;
    ns1:competencyCode "CT01" ;
    ns1:competencyDescription "Capacidad de comunicación verbal y escrita en lengua inglesa."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000105/2025-26/CT02> a ns1:Competency ;
    ns1:competencyCode "CT02" ;
    ns1:competencyDescription "Capacidad de trabajo en equipo o su liderazgo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000105/2025-26/CT04> a ns1:Competency ;
    ns1:competencyCode "CT04" ;
    ns1:competencyDescription "Organización y planificación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000105/2025-26/CT06> a ns1:Competency ;
    ns1:competencyCode "CT06" ;
    ns1:competencyDescription "Gestión económica y administrativa."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000105/2025-26/CT07> a ns1:Competency ;
