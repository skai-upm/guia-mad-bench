    schema:name "Sistemas y Servicios Multimedia"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000794/2025-26/CE1> a ns1:Competency ;
    ns1:competencyCode "CE1" ;
    ns1:competencyDescription "Capacidad para aplicar métodos de la teoría de la información, la modulación adaptativa y codificación de canal, así como técnicas avanzadas de procesado digital de señal a los sistemas de comunicaciones y audiovisuales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000794/2025-26/CE15> a ns1:Competency ;
    ns1:competencyCode "CE15" ;
    ns1:competencyDescription "Capacidad para la integración de tecnologías y sistemas propios de la Ingeniería de Telecomunicación, con carácter generalista, y en contextos más amplios y multidisciplinares como por ejemplo en bioingeniería, conversión fotovoltaica, nanotecnología, telemedicina."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000794/2025-26/CE16> a ns1:Competency ;
    ns1:competencyCode "CE16" ;
    ns1:competencyDescription "Capacidad para la elaboración, dirección, coordinación, y gestión técnica y económica de proyectos sobre: sistemas, redes, infraestructuras y servicios de telecomunicación, incluyendo la supervisión y coordinación de los proyectos parciales de su obra aneja; infraestructuras comunes de telecomunicación en edificios o núcleos residenciales, incluyendo los proyectos sobre hogar digital; infraestructuras de telecomunicación en transporte y medio ambiente; con sus correspondientes instalaciones de suministro de energía y evaluación de las emisiones electromagnéticas y compatibilidad electromagnética."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000794/2025-26/CE4> a ns1:Competency ;
    ns1:competencyCode "CE4" ;
    ns1:competencyDescription "Capacidad para diseñar y dimensionar redes de transporte, difusión y distribución de señales multimedia."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000794/2025-26/CE6> a ns1:Competency ;
    ns1:competencyCode "CE6" ;
    ns1:competencyDescription "Capacidad para modelar, diseñar, implantar, gestionar, operar, administrar y mantener redes, servicios y contenidos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000794/2025-26/CE9> a ns1:Competency ;
    ns1:competencyCode "CE9" ;
    ns1:competencyDescription "Capacidad para resolver la convergencia, interoperabilidad y diseño de redes heterogéneas con redes locales, de acceso y troncales, así como la integración de servicios de telefonía, datos, televisión e interactivos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000794/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Poseer y comprender conocimientos que aporten una base u oportunidad de ser originales en el desarrollo y/o aplicación de ideas, a menudo en un contexto de investigación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000794/2025-26/CG2> a ns1:Competency ;
    ns1:competencyCode "CG2" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en entornos nuevos o poco conocidos dentro de contextos más amplios (o multidisciplinares) relacionados con su área de estudio."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000794/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de integrar conocimientos y enfrentarse a la complejidad de formular juicios a partir de una información que, siendo incompleta o limitada, incluya reflexiones sobre las responsabilidades sociales y éticas vinculadas a la aplicación de sus conocimientos y juicios."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000794/2025-26/CG4> a ns1:Competency ;
    ns1:competencyCode "CG4" ;
    ns1:competencyDescription "Que los estudiantes sepan comunicar sus conclusiones ?y los conocimientos y razones últimas que las sustentan? a públicos especializados y no especializados de un modo claro y sin ambigüedades."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000794/2025-26/CG5> a ns1:Competency ;
    ns1:competencyCode "CG5" ;
    ns1:competencyDescription "Que los estudiantes posean las habilidades de aprendizaje que les permitan continuar estudiando de un modo que habrá de ser en gran medida autodirigido o autónomo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000794/2025-26/CT1> a ns1:Competency ;
    ns1:competencyCode "CT1" ;
    ns1:competencyDescription "Capacidad para comprender los contenidos de clases magistrales, conferencias y seminarios en lengua inglesa."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000794/2025-26/CT2> a ns1:Competency ;
