<https://guia-kg.skai.etsisi.upm.es/resource/125000403/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Trigonometría Esférica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125000403/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Geometría sobre la superficie esférica. Triángulos esféricos y propiedades. Triángulo polar. Área de triángulos y polígonos esféricos Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125000403/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "3.1. Espacio vectorial. Propiedades Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125000403/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "3.2. Subespacio vectorial: Definición. Caracterización. Generación de subespacios Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125000403/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "3.3. Dependencia e independencia lineal . Bases de un espacio vectorial. Dimensión. Coordenadas Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125000403/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "3.4. Base de un espacio vectorial.Coordenadas de un vector. Dimensión Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125000403/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "3.5. Ecuaciones de cambio de base Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125000403/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "3.6. Intersección y suma de subespacios vectoriales. Fórmula de Grassman Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125000403/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "4. Aplicaciones Lineales. Diagonalización"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125000403/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "4.1. Definición de aplicación lineal. Núcleo e imagen.Propiedades de las aplicaciones lineales. Clasificación Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125000403/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "4.2. Ecuación y matriz de una transformación lineal o endomorfismo. Composición de endomorfismos. Cambio de base Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125000403/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "4.3. Valores y vectores propios. Definición y propiedades Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125000403/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Resolución de triángulos esféricos. Fórmulas de Bessel. Analogías de Neper. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125000403/2025-26/syllabus/20> a ns1:SyllabusItem ;
    ns1:itemIndex 20 ;
    ns1:syllabusDescription "4.4. Caracterización de las matrices diagonalizables Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125000403/2025-26/syllabus/21> a ns1:SyllabusItem ;
    ns1:itemIndex 21 ;
    ns1:syllabusDescription "5. Espacio euclídeo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125000403/2025-26/syllabus/22> a ns1:SyllabusItem ;
    ns1:itemIndex 22 ;
    ns1:syllabusDescription "5.1. Espacio euclídeo. Subespacios. Ortogonalidad de subespacios. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125000403/2025-26/syllabus/23> a ns1:SyllabusItem ;
    ns1:itemIndex 23 ;
    ns1:syllabusDescription "5.2. Espacio Afín. Cambio de sistema de referencia en un espacio afín Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125000403/2025-26/syllabus/24> a ns1:SyllabusItem ;
    ns1:itemIndex 24 ;
    ns1:syllabusDescription "6. Transformaciones geométricas del espacio euclídeo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125000403/2025-26/syllabus/25> a ns1:SyllabusItem ;
    ns1:itemIndex 25 ;
    ns1:syllabusDescription "6.1. Transformaciones ortogonales, propiedades y ecuaciones Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125000403/2025-26/syllabus/26> a ns1:SyllabusItem ;
    ns1:itemIndex 26 ;
    ns1:syllabusDescription "6.2. Clasificación de las transformaciones ortogonales del plano y del espacio. Ecuaciones y elementos característicos Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125000403/2025-26/syllabus/27> a ns1:SyllabusItem ;
    ns1:itemIndex 27 ;
    ns1:syllabusDescription "6.3. Isometrías del plano: clasificación, ecuaciones y elementos característicos Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125000403/2025-26/syllabus/28> a ns1:SyllabusItem ;
    ns1:itemIndex 28 ;
    ns1:syllabusDescription "6.4. Isometrías del espacio: clasificación, ecuaciones y elementos característicos Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125000403/2025-26/syllabus/29> a ns1:SyllabusItem ;
    ns1:itemIndex 29 ;
    ns1:syllabusDescription "6.5. Homotecias del plano y del espacio euclídeo: definición propiedades y ecuaciones Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125000403/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "1.3. Triángulos esféricos rectángulos. Pentágono de Neper Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125000403/2025-26/syllabus/30> a ns1:SyllabusItem ;
    ns1:itemIndex 30 ;
    ns1:syllabusDescription "6.6. Semejanzas del plano y del espacio euclídeo: propiedades, ecuaciones y elementos característicos Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125000403/2025-26/syllabus/31> a ns1:SyllabusItem ;
    ns1:itemIndex 31 ;
    ns1:syllabusDescription "7. Cónicas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125000403/2025-26/syllabus/32> a ns1:SyllabusItem ;
    ns1:itemIndex 32 ;
    ns1:syllabusDescription "7.1. Definición de Cónicas. Ecuaciones. Tipos de cónicas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125000403/2025-26/syllabus/33> a ns1:SyllabusItem ;
    ns1:itemIndex 33 ;
    ns1:syllabusDescription "7.2. Reducción de la ecuación general de una cónica. Invariantes de una cónica. Clasificación de las cónicas Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125000403/2025-26/syllabus/34> a ns1:SyllabusItem ;
    ns1:itemIndex 34 ;
    ns1:syllabusDescription "7.3. Cálculo de los coeficientes de la ecuación canónica de una cónica, excentricidad y parámetro de una cónica Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125000403/2025-26/syllabus/35> a ns1:SyllabusItem ;
    ns1:itemIndex 35 ;
    ns1:syllabusDescription "7.4. Determinación del centro y ejes de una cónica con centro. Determinación del vértice y eje de una parábola Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125000403/2025-26/syllabus/36> a ns1:SyllabusItem ;
    ns1:itemIndex 36 ;
    ns1:syllabusDescription "7.5. Determinación de las asíntotas de una hipérbola. Rectas tangente y normal a una cónica Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125000403/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "1.4. Coordenadas geográficas. Distancia esférica entre dos puntos Sin subniveles"@es .

