    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/205000261/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/205000261/2025-26/RA89>,
        <https://guia-kg.skai.etsisi.upm.es/resource/205000261/2025-26/RA90>,
        <https://guia-kg.skai.etsisi.upm.es/resource/205000261/2025-26/RA92> ;
