<https://guia-kg.skai.etsisi.upm.es/resource/113000032/2025-26/RA22> a ns1:LearningResult ;
    ns1:learningResultCode "RA22" ;
    ns1:learningResultDescription "Conocer las caracteri?sticas de los diferentes diseños cualitativos y sus peculiaridades metodolo?gicas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000032/2025-26/RA24> a ns1:LearningResult ;
    ns1:learningResultCode "RA24" ;
    ns1:learningResultDescription "Manejar las diferentes técnicas de investigacio?n cualitativa y los métodos que le son afines."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000032/2025-26/RA25> a ns1:LearningResult ;
