<https://guia-kg.skai.etsisi.upm.es/resource/113000032/2025-26/syllabus> a ns1:Syllabus ;
    ns1:hasItem <https://guia-kg.skai.etsisi.upm.es/resource/113000032/2025-26/syllabus/0>,
        <https://guia-kg.skai.etsisi.upm.es/resource/113000032/2025-26/syllabus/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/113000032/2025-26/syllabus/2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/113000032/2025-26/syllabus/3>,
        <https://guia-kg.skai.etsisi.upm.es/resource/113000032/2025-26/syllabus/4>,
        <https://guia-kg.skai.etsisi.upm.es/resource/113000032/2025-26/syllabus/5>,
        <https://guia-kg.skai.etsisi.upm.es/resource/113000032/2025-26/syllabus/6> .

<https://guia-kg.skai.etsisi.upm.es/resource/113000032/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Bases teóricas de la investigación cualitativa. El paradigma investigador. Breve recorrido histórico. Campos de intervención. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000032/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "2. El diseño de investigación cualitativo. Estructura y componentes fundamentales. El problema de investigación. Fase preparatoria. El trabajo de campo. El análisis de datos. Informe de investigación. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000032/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "3. Tipología de los estudios. Estudios etnográficos. La investigación-acción. Investigación documental. Herramientas para recogida de información. La entrevista. El grupo de discusión. La observación. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000032/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "4. El análisis de datos cualitativos. Preparación del material. Proceso y tipos de codificación. Sistemas de categorización. Elaboración de mapas conceptuales. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000032/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "5. El informe de investigación. Consideraciones generales. Características y estructura. Pautas de redacción. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000032/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "6. Criterios de calidad en investigación cualitativa. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000032/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "7. Los métodos mixtos: integración de los paradigmas de investigación Sin subniveles"@es .

