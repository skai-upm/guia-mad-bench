<https://guia-kg.skai.etsisi.upm.es/resource/135004509/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/135004509/2025-26/CG03>,
        <https://guia-kg.skai.etsisi.upm.es/resource/135004509/2025-26/CG11>,
