<https://guia-kg.skai.etsisi.upm.es/resource/55000628/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. La recta real."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000628/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Introducción. Conjuntos. Notación matemática. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000628/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "3.1. Derivada. Interpretación geométrica. Propiedades y reglas de cálculo. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000628/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "3.2. Regla de la cadena. Derivada de la función inversa. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000628/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "3.3. Estudio local de una función. Extremos relativos. Teorema de Rolle. Teorema del valor medio. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000628/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "3.4. Regla de L'Hopital. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000628/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "3.5. Teorema de Taylor. Aplicación a la resolución de indeterminaciones y al estudio local de funciones. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000628/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "3.6. Funciones elementales: polinómicas, exponenciales, logarítmicas, trigonométricas e hiperbólicas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000628/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "4. Integral de Riemann."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000628/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "4.1. Construcción y propiedades generales. Teorema de la media. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000628/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "4.2. Teorema fundamental del cálculo. Regla de Barrow. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000628/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "5. Cálculo de primitivas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000628/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Implicaciones. Cuantificadores. Tipos de demostraciones. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000628/2025-26/syllabus/20> a ns1:SyllabusItem ;
    ns1:itemIndex 20 ;
    ns1:syllabusDescription "5.1. Integral indefinida. Integración por partes y cambio de variable. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000628/2025-26/syllabus/21> a ns1:SyllabusItem ;
    ns1:itemIndex 21 ;
    ns1:syllabusDescription "5.2. Integración de funciones racionales. Descomposición en fracciones simples. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000628/2025-26/syllabus/22> a ns1:SyllabusItem ;
    ns1:itemIndex 22 ;
    ns1:syllabusDescription "5.3. Integrables reducibles a las de fracciones racionales. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000628/2025-26/syllabus/23> a ns1:SyllabusItem ;
    ns1:itemIndex 23 ;
    ns1:syllabusDescription "6. Funciones de varias variables reales. Límites y continuidad."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000628/2025-26/syllabus/24> a ns1:SyllabusItem ;
    ns1:itemIndex 24 ;
    ns1:syllabusDescription "6.1. El espacio euclídeo y su topología. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000628/2025-26/syllabus/25> a ns1:SyllabusItem ;
    ns1:itemIndex 25 ;
    ns1:syllabusDescription "6.2. Límites y continuidad. Propiedades y resultados fundamentales. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000628/2025-26/syllabus/26> a ns1:SyllabusItem ;
    ns1:itemIndex 26 ;
    ns1:syllabusDescription "7. Diferenciación de funciones de varias variables."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000628/2025-26/syllabus/27> a ns1:SyllabusItem ;
    ns1:itemIndex 27 ;
    ns1:syllabusDescription "7.1. Derivadas parciales. Derivadas direccionales. Vector gradiente. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000628/2025-26/syllabus/28> a ns1:SyllabusItem ;
    ns1:itemIndex 28 ;
    ns1:syllabusDescription "7.2. Diferenciabilidad. Propiedades. Matriz jacobiana. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000628/2025-26/syllabus/29> a ns1:SyllabusItem ;
    ns1:itemIndex 29 ;
    ns1:syllabusDescription "7.3. Regla de la cadena. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000628/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "1.3. Propiedades básicas de los números reales. La recta real, ecuaciones, inecuaciones, intervalos, distancia. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000628/2025-26/syllabus/30> a ns1:SyllabusItem ;
    ns1:itemIndex 30 ;
    ns1:syllabusDescription "7.4. Derivadas de orden superior. Fórmula de Taylor. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000628/2025-26/syllabus/31> a ns1:SyllabusItem ;
    ns1:itemIndex 31 ;
    ns1:syllabusDescription "7.5. Extremos libres. Condiciones necesarias y suficientes. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000628/2025-26/syllabus/32> a ns1:SyllabusItem ;
    ns1:itemIndex 32 ;
    ns1:syllabusDescription "7.6. Extremos condicionados. Teorema de los multiplicadores de Lagrange. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000628/2025-26/syllabus/33> a ns1:SyllabusItem ;
    ns1:itemIndex 33 ;
    ns1:syllabusDescription "8. Integración múltiple."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000628/2025-26/syllabus/34> a ns1:SyllabusItem ;
    ns1:itemIndex 34 ;
    ns1:syllabusDescription "8.1. Integración doble sobre rectángulos y triples en paralelepípedos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000628/2025-26/syllabus/35> a ns1:SyllabusItem ;
    ns1:itemIndex 35 ;
    ns1:syllabusDescription "8.2. Integración reiterada. Teorema de Fubini. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000628/2025-26/syllabus/36> a ns1:SyllabusItem ;
    ns1:itemIndex 36 ;
    ns1:syllabusDescription "8.3. Cambio de variables. Coordenadas polares en el plano, esféricas y cilíndricas en el espacio. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000628/2025-26/syllabus/37> a ns1:SyllabusItem ;
    ns1:itemIndex 37 ;
    ns1:syllabusDescription "8.4. Aplicaciones geométricas y físicas de la integral múltiple. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000628/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "2. Límites y continuidad de funciones reales de variable real."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000628/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "2.1. Noción de función. Tipos de funciones. Operaciones algebraicas. Composición de funciones. Función inversa. Funciones elementales. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000628/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "2.2. Límites finitos e infinitos. Propiedades. Indeterminaciones. Infinitésimos equivalentes. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000628/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "2.3. Continuidad. Propiedades. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000628/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "2.4. Teoremas fundamentales sobre funciones continuas en intervalos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000628/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "3. Diferenciación de funciones reales de variable real."@es .

