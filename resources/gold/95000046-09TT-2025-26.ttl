    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/95000046/2025-26/eventSchedule> ;
    schema:description "El objetivo de esta asignatura es que el alumno, una vez completada, obtenga los conocimientos necesarios para abordar la realización completa (diseño técnico, evaluación económica,..) de proyectos de telecomunicación, en las distintas alternativas tecnológicas de los mismos y para la provisión de diferentes servicios multimedia. A estos efectos, se tendrán en cuenta todos los tipos de viabilidad necesarios en cada proyecto (técnica, marco legal, económica, medioambiental, logística, estándares, etc.)."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/federico.alvarez%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/alberto.belmonte%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/federico.alvarez%40upm.es> ;
    schema:name "Sistemas de Telecomunicacion"@es .

