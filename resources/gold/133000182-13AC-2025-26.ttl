<https://guia-kg.skai.etsisi.upm.es/resource/133000182> a ns1:Course ;
    ns1:courseType "Obligatoria"@es ;
    ns1:courseYear 1 ;
    ns1:semester "Segundo semestre"@es ;
    schema:courseCode 133000182 ;
    schema:hasCourseInstance <https://guia-kg.skai.etsisi.upm.es/resource/133000182/2025-26> ;
    schema:name "Circular Economy Models"@en,
        "Modelos de Economia Circular"@es ;
    schema:numberOfCredits 3.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/133000182/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/133000182/2025-26/CB07> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/133000182/2025-26/didactic_resource/1> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/133000182/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/133000182/2025-26/RA22> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/133000182/2025-26/syllabus> ;
    ns1:inpersonHours "28 horas y 30 minutos (36.5%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation """Esta asignatura empieza su impartición en el segundo semestre con un esquema de presencialidad definido. En el caso de un cambio en las condiciones sanitarias que obligaran a un confinamiento total o parcial, habría que hacer una replanificación con las correspondientes adendas
ODS que abarca esta asignatira:3, 5, 7, 9, 11, 12, 13
LAS COMPETENCIAS Y LOS RESULTADOS DE APRENDIZAJE DE ESTA ASIGNATURA SON LOS ACORDES CON LA MEMORIA VERIFICA DEL TÍTULO"""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "37 horas y 30 minutos"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/133000182/2025-26/eventSchedule> ;
    schema:description "La asignatura tiene como objetivo introducir al alumno en la complejidad de la Economía Circular en el ámbito económico, social y tecnológico, mediante el análisis de los diferentes campos de innovación en los que puede desarrollarse esta materia y en los nuevos modelos de pensamiento medio ambiental."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/sigfredo.ortuno%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/a.martinf%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/belen.vazquezdequevedo%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/jv.lopez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/miguel.aguilar%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/sigfredo.ortuno%40upm.es> ;
    schema:name "Modelos de Economia Circular"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000182/2025-26/CB07> a ns1:Competency ;
    ns1:competencyCode "CB07" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en entornos nuevos o poco conocidos dentro de contextos más amplios (o multidisciplinares) relacionados con su área de estudio"@es .

