    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/53001222/2025-26/eventSchedule> ;
    schema:description """La asignatura de Ingeniería del Transporte pretende ofrecer una visión global sobre algunos de los aspectos más relevantes concernientes al transporte y la movilidad. Así, se describen las características principales de los modos, se presentan los medios de manutención industrial, se trabaja con los modelos de flujo de tráfico y demanda de transporte y se analizan los principales impactos del transporte sobre la seguridad y el medio ambiente.
Se combinan aspectos más teóricos con la aplicación práctica de modelos a casos reales."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/felipe.jimenez%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/blanca.arenas%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/enrique.alcala%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/felipe.jimenez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/josemaria.lopez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/luis.martinez%40upm.es> ;
    schema:name "Ingenieria del Transporte"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001222/2025-26/%28a%29> a ns1:Competency ;
    ns1:competencyCode "(a)" ;
    ns1:competencyDescription "APLICA. Habilidad para aplicar conocimientos científicos, matemáticos y tecnológicos en sistemas relacionados con la práctica de la ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001222/2025-26/%28e%29> a ns1:Competency ;
    ns1:competencyCode "(e)" ;
    ns1:competencyDescription "RESUELVE. Habilidad para identificar, formular y resolver problemas de ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001222/2025-26/%28h%29> a ns1:Competency ;
    ns1:competencyCode "(h)" ;
    ns1:competencyDescription "ENTIENDE LOS IMPACTOS. Educación amplia necesaria para entender el impacto de las soluciones ingenieriles en un contexto social global."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001222/2025-26/%28i%29> a ns1:Competency ;
    ns1:competencyCode "(i)" ;
    ns1:competencyDescription "SE ACTUALIZA. Reconocimiento de la necesidad y la habilidad para comprometerse al aprendizaje continuo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001222/2025-26/%28j%29> a ns1:Competency ;
    ns1:competencyCode "(j)" ;
    ns1:competencyDescription "CONOCE. Conocimiento de los temas contemporáneos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001222/2025-26/%28k%29> a ns1:Competency ;
    ns1:competencyCode "(k)" ;
    ns1:competencyDescription "USA HERRAMIENTAS. Habilidad para usar las técnicas, destrezas y herramientas ingenieriles modernas necesarias para la práctica de la ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001222/2025-26/%28m%29> a ns1:Competency ;
    ns1:competencyCode "(m)" ;
    ns1:competencyDescription "PLANIFICA. Organización y planificación en el ámbito de la empresa, y otras instituciones y organizaciones de proyectos y equipos humanos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001222/2025-26/CB06> a ns1:Competency ;
    ns1:competencyCode "CB06" ;
    ns1:competencyDescription "Poseer y comprender conocimientos que aporten una base u oportunidad de ser originales en el desarrollo y/o aplicación de ideas, a menudo en un contexto de investigación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001222/2025-26/CB07> a ns1:Competency ;
    ns1:competencyCode "CB07" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en entornos nuevos o poco conocidos dentro de contextos más amplios"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001222/2025-26/CB08> a ns1:Competency ;
    ns1:competencyCode "CB08" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de integrar conocimientos y enfrentarse a la complejidad de formular juicios a partir de una información que, siendo incompleta o limitada, incluya reflexiones sobre las responsabilidades sociales y éticas vinculadas a la aplicación de sus conocimientos y juicios"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001222/2025-26/CB10> a ns1:Competency ;
    ns1:competencyCode "CB10" ;
    ns1:competencyDescription "Que los estudiantes posean las habilidades de aprendizaje que les permitan continuar estudiando de un modo que habrá de ser en gran medida autodirigido o autónomo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001222/2025-26/CE21> a ns1:Competency ;
    ns1:competencyCode "CE21" ;
    ns1:competencyDescription "Conocimientos sobre métodos y técnicas del transporte y manutención industrial."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001222/2025-26/CG01> a ns1:Competency ;
    ns1:competencyCode "CG01" ;
    ns1:competencyDescription "Tener conocimientos adecuados de los aspectos científicos y tecnológicos de: métodos matemáticos, analíticos y numéricos en la ingeniería, ingeniería eléctrica, ingeniería energética, ingeniería química, ingeniería mecánica, mecánica de medios continuos, electrónica industrial, automática, fabricación, materiales, métodos cuantitativos de gestión, informática industrial, urbanismo, infraestructuras, etc."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001222/2025-26/CG05> a ns1:Competency ;
    ns1:competencyCode "CG05" ;
    ns1:competencyDescription "Realizar la planificación estratégica y aplicarla a sistemas tanto constructivos como de producción, de calidad y de gestión medioambiental."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001222/2025-26/CG08> a ns1:Competency ;
    ns1:competencyCode "CG08" ;
    ns1:competencyDescription "Aplicar los conocimientos adquiridos y resolver problemas en entornos nuevos o poco conocidos dentro de contextos más amplios y multidisciplinares."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001222/2025-26/CG09> a ns1:Competency ;
    ns1:competencyCode "CG09" ;
    ns1:competencyDescription "Ser capaz de integrar conocimientos y enfrentarse a la complejidad de formular juicios a partir de una información que, siendo incompleta o limitada, incluya reflexiones sobre las responsabilidades sociales y éticas vinculadas a la aplicación de sus conocimientos y juicios."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001222/2025-26/CG11> a ns1:Competency ;
    ns1:competencyCode "CG11" ;
    ns1:competencyDescription "Poseer las habilidades de aprendizaje que permitan continuar estudiando de un modo autodirigido o autónomo."@es .

