<https://guia-kg.skai.etsisi.upm.es/resource/565000254/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Tema 1: Régimen transitorio de los circuitos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000254/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Introducción. Condiciones de continuidad. Condensador. Bobina. Bobinas acopladas magnéticamente. Circuitos equivalentes con condiciones iniciales nulas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000254/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "1.4.4. Transformada de Laplace de una función periódica Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000254/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "1.5. Función de transferencia. Polos y ceros. Análisis básico del comportamiento a partir de la posición de polos y ceros. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000254/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "1.6. Análisis en variables de estado."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000254/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "1.6.1. Concepto de estado de un sistema. Variables y ecuaciones de estado. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000254/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "1.6.2. Ecuaciones de estado en circuitos. Redes propias e impropias. Complejidad de una red. Elección de árbol en una red propia. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000254/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "1.6.3. Constitución sistemática de ecuaciones para redes propias. Análisis de redes impropias. Aplicación a sistemas no lineales. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000254/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "1.6.4. Resolución analítica. Resolución Discreta. Resolución por transformada de Laplace. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000254/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "2. Tema 2: Análisis en frecuencia. Resonancia."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000254/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "2.1. Función de transferencia. Aplicación a la respuesta al estado estacionario sinusoidal. Lugares geométricos complejos. Gráficas de magnitud y fase. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000254/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "2.2. Diagramas de Bode. Factores de primer orden. Análisis de magnitud y fase. Factores de segundo orden. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000254/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. 1.2. Repaso de Análisis en el dominio del tiempo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000254/2025-26/syllabus/20> a ns1:SyllabusItem ;
    ns1:itemIndex 20 ;
    ns1:syllabusDescription "2.3. Criterio de Nyquist. Margen de fase y margen de ganancia. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000254/2025-26/syllabus/21> a ns1:SyllabusItem ;
    ns1:itemIndex 21 ;
    ns1:syllabusDescription "2.4. Factor de calidad. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000254/2025-26/syllabus/22> a ns1:SyllabusItem ;
    ns1:itemIndex 22 ;
    ns1:syllabusDescription "2.5. Fenómeno de la resonancia: frecuencia de resonancia. Resonancia del circuito serie. Frecuencia de resonancia. Factor de sobretensión. Admitancia: curva universal de resonancia. Banda de paso y ancho de banda. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000254/2025-26/syllabus/23> a ns1:SyllabusItem ;
    ns1:itemIndex 23 ;
    ns1:syllabusDescription "2.6. Resonancia del circuito paralelo ideal: frecuencia de resonancia. Factor de sobreintensidad. Impedancia: curva universal de resonancia. Circuito antirresonante práctico. Lugares geométricos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000254/2025-26/syllabus/24> a ns1:SyllabusItem ;
    ns1:itemIndex 24 ;
    ns1:syllabusDescription "3. Tema 3: Cuadripolos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000254/2025-26/syllabus/25> a ns1:SyllabusItem ;
    ns1:itemIndex 25 ;
    ns1:syllabusDescription "3.1. Ecuaciones generales de un cuadripolo. Parámetros impedancia «z». Parámetros admitancia «y». Parámetros híbridos «h». Parámetros híbridos «g». Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000254/2025-26/syllabus/26> a ns1:SyllabusItem ;
    ns1:itemIndex 26 ;
    ns1:syllabusDescription "3.2. Parámetros de transmisión directa y de transmisión inversa. Relación entre las diferentes familias de parámetros. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000254/2025-26/syllabus/27> a ns1:SyllabusItem ;
    ns1:itemIndex 27 ;
    ns1:syllabusDescription "3.3. Asociación de cuadripolos: Asociación serie-serie. Asociación paralelo-paralelo. Asociación serie-paralelo. Asociación paralelo-serie. Asociación en cascada. Prueba de Brune. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000254/2025-26/syllabus/28> a ns1:SyllabusItem ;
    ns1:itemIndex 28 ;
    ns1:syllabusDescription "3.4. Cuadripolos elementales: Dipolos serie y paralelo. Cuadripolos en L y en L invertida. Cuadripolos en ? y en T. Cuadripolos en celosía. Cuadripolos en T puenteada y en doble T. Teorema de Bartlett. Células equivalentes en T o en \"pi\" de un cuadripolo. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000254/2025-26/syllabus/29> a ns1:SyllabusItem ;
    ns1:itemIndex 29 ;
    ns1:syllabusDescription "3.5. Parámetros imagen. Potencia y diagramas de los cuadripolos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000254/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "1.2.1. Circuitos de primer orden. Carga de un condensador. Respuesta de un circuito R-C a un pulso rectangular. Respuesta de un circuito R-L a un pulso rectangular. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000254/2025-26/syllabus/30> a ns1:SyllabusItem ;
    ns1:itemIndex 30 ;
    ns1:syllabusDescription "4. Prácticas de laboratorio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000254/2025-26/syllabus/31> a ns1:SyllabusItem ;
    ns1:itemIndex 31 ;
    ns1:syllabusDescription "4.1. Práctica 1: Introducción al software QUCS y manejo de osciloscopio digital. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000254/2025-26/syllabus/32> a ns1:SyllabusItem ;
    ns1:itemIndex 32 ;
    ns1:syllabusDescription "4.2. Práctica 2: Análisis de transitorios de primer orden. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000254/2025-26/syllabus/33> a ns1:SyllabusItem ;
    ns1:itemIndex 33 ;
    ns1:syllabusDescription "4.3. Práctica 3: Análisis de transitorios de segundo orden. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000254/2025-26/syllabus/34> a ns1:SyllabusItem ;
    ns1:itemIndex 34 ;
    ns1:syllabusDescription "4.4. Práctica 4: Análisis de resonancia serie y paralelo. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000254/2025-26/syllabus/35> a ns1:SyllabusItem ;
    ns1:itemIndex 35 ;
    ns1:syllabusDescription "4.5. Práctica 5: Respuesta en frecuencia. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000254/2025-26/syllabus/36> a ns1:SyllabusItem ;
    ns1:itemIndex 36 ;
    ns1:syllabusDescription "4.6. Práctica 6: Caracterización de cuadripolos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000254/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "1.2.2. Circuitos de segundo orden. Parámetros que definen un sistema de segundo orden. Clasificación de los sistemas de segundo orden. Respuesta a entrada cero del circuito serie R-L-C. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000254/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "1.3. 1.3. Respuesta a un escalón: Integral de Duhamel. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000254/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "1.4. 1.4. Aplicación de la transformada de Laplace al análisis de circuitos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000254/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "1.4.1. Definiciones, propiedades y teoremas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000254/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "1.4.2. Transformada Inversa de Laplace: Descomposición en fracciones Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000254/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "1.4.3. Circuitos en el dominio de la variable de Laplace. Sin subniveles"@es .

