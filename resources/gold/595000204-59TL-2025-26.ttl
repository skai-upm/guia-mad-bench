    ns1:bibliographyTitle "Espacio moodle de la asignatura"@es ;
    ns1:bibliographyType "Recursos web"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000204/2025-26/didactic_resource/9> a ns1:DidacticResource ;
