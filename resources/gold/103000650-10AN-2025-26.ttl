    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/103000650/2025-26/eventSchedule> ;
    schema:description "La computación social ha adquirido una gran importancia durante los últimos años permitiendo la construcción de máquinas sociales en las que humanos y ordenadores colaboran para resolver un problema de carácter social. Actualmente el diseño de máquinas sociales requiere de soluciones de inteligencia artificial distribuida que permitan construir sociedades artificiales de forma efectiva. En esta asignatura se revisan las principales características de las máquinas sociales y se propone la utilización de sistemas multi-agente para la construcción de máquinas sociales."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/javier.bajo%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/damiano.zanardini%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/jacinto.gonzalez.pachon%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/javier.bajo%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/josefaz.hernandez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/nik.swoboda%40upm.es> ;
    schema:name "Computacion Social y Sistemas Multiagente"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000650/2025-26/CB7> a ns1:Competency ;
    ns1:competencyCode "CB7" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en entornos nuevos o poco conocidos dentro de contextos más amplios (o multidisciplinares) relacionados con su área de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000650/2025-26/CE1> a ns1:Competency ;
    ns1:competencyCode "CE1" ;
    ns1:competencyDescription "Capacidad para la integración de tecnologías, aplicaciones, servicios y sistemas propios de la Ingeniería Informática, con carácter generalista, y en contextos más amplios y multidisciplinares."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000650/2025-26/CE8> a ns1:Competency ;
    ns1:competencyCode "CE8" ;
    ns1:competencyDescription "Capacidad para analizar las necesidades de información que se plantean en un entorno y llevar a cabo en todas sus etapas el proceso de construcción de un sistema de información."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000650/2025-26/CG11> a ns1:Competency ;
    ns1:competencyCode "CG11" ;
    ns1:competencyDescription "Capacidad para contribuir al desarrollo futuro de la informática"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000650/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Especificación y realización de tareas informáticas complejas, poco definidas o no familiares"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000650/2025-26/CG4> a ns1:Competency ;
    ns1:competencyCode "CG4" ;
    ns1:competencyDescription "Capacidad para la aplicación de los conocimientos adquiridos y de resolver problemas en entornos nuevos o poco conocidos dentro de contextos más amplios y mulitidisciplinares, siendo capaces de integrar estos conocimientos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000650/2025-26/CG5> a ns1:Competency ;
    ns1:competencyCode "CG5" ;
    ns1:competencyDescription "Aplicación de los métodos de resolución de problemas más recientes o innovadores y que puedan implicar el uso de otras disciplinas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000650/2025-26/CG6> a ns1:Competency ;
    ns1:competencyCode "CG6" ;
    ns1:competencyDescription "Capacidad de pensamiento creativo con el objetivo de desarrollar enfoques y métodos nuevos y originales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000650/2025-26/CG7> a ns1:Competency ;
    ns1:competencyCode "CG7" ;
    ns1:competencyDescription "Integración del conocimiento a partir de disciplinas diferentes, así como el manejo de la complejidad"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000650/2025-26/CG8> a ns1:Competency ;
    ns1:competencyCode "CG8" ;
    ns1:competencyDescription "Comprensión amplia de las técnicas y métodos aplicables en una especialización concreta, así como de sus límites"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000650/2025-26/CG9> a ns1:Competency ;
    ns1:competencyCode "CG9" ;
    ns1:competencyDescription "Apreciación de los límites del conocimiento actual y de la aplicación práctica de la tecnología más reciente"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000650/2025-26/RA71> a ns1:LearningResult ;
    ns1:learningResultCode "RA71" ;
    ns1:learningResultDescription "Ser capaz de entender el comportamiento y auto"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000650/2025-26/RA72> a ns1:LearningResult ;
    ns1:learningResultCode "RA72" ;
    ns1:learningResultDescription "Ser capaz de analizar y diseñar sociedades de agentes que simulen comportamientos inteligentes"@es .

