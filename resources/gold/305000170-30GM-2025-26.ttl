    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/305000170/2025-26/eventSchedule> ;
    schema:description "Este curso pretende introducir al estudiante en los principales métodos de aproximación de soluciones para modelos de ecuaciones en derivadas parciales, su aplicación y resultados de convergencia. Con ello se pretende dar una idea panorámica de las opciones disponibles para resolver un problema dado, fomentando el espíritu crítico para saber en qué situaciones es mejor usar uno u otro método. También se hará énfasis en la programación y las herramientas de visualización y validación mediante el análisis de errores."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/carlos.castro%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/carlos.castro%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/marialuisa.rapun%40upm.es> ;
    schema:name "Métodos Numéricos en Ecuaciones en Derivadas Parciales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000170/2025-26/CB5> a ns1:Competency ;
    ns1:competencyCode "CB5" ;
    ns1:competencyDescription "Que los estudiantes hayan desarrollado aquellas habilidades de aprendizaje necesarias para emprender estudios posteriores con un alto grado de autonomía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000170/2025-26/CE1> a ns1:Competency ;
    ns1:competencyCode "CE1" ;
    ns1:competencyDescription "Comprender y utilizar el lenguaje matemático. Adquirir la capacidad para enunciar propiedades en distintos campos de la Matemática, para construir argumentaciones, elaborar cálculos y para transmitir los conocimientos matemáticos adquiridos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000170/2025-26/CE2> a ns1:Competency ;
    ns1:competencyCode "CE2" ;
    ns1:competencyDescription "Conocer y comprender demostraciones rigurosas de los principales teoremas de cada área de la Matemática y extraer de ellos corolarios mediante la particularización a casos concretos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000170/2025-26/CE3> a ns1:Competency ;
    ns1:competencyCode "CE3" ;
    ns1:competencyDescription "Asimilar la definición de un nuevo objeto matemático, en términos de otros ya conocidos, y ser capaz de utilizar este objeto en diferentes contextos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000170/2025-26/CE4> a ns1:Competency ;
    ns1:competencyCode "CE4" ;
    ns1:competencyDescription "Abstraer las propiedades estructurales de objetos matemáticos, de la realidad observada o de otros ámbitos distinguiéndolas de aquellas puramente ocasionales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000170/2025-26/CE5> a ns1:Competency ;
    ns1:competencyCode "CE5" ;
    ns1:competencyDescription "Comprobar con demostraciones hipótesis sobre un objeto matemático o refutarlas con contraejemplos, así como identificar errores en razonamientos incorrectos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000170/2025-26/CE7> a ns1:Competency ;
    ns1:competencyCode "CE7" ;
    ns1:competencyDescription "Resolver problemas de Matemáticas, mediante habilidades de cálculo básico y tecnologías de computación, planificando su resolución en función de las herramientas de que se disponga y de las restricciones de tiempo y recursos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000170/2025-26/CE8> a ns1:Competency ;
    ns1:competencyCode "CE8" ;
    ns1:competencyDescription "Utilizar aplicaciones informáticas de análisis estadístico, cálculo numérico y simbólico, visualización gráfica, optimización u otras para experimentar en Matemáticas, buscar soluciones y resolver modelos matemáticos de sistemas reales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000170/2025-26/CE9> a ns1:Competency ;
    ns1:competencyCode "CE9" ;
    ns1:competencyDescription "Desarrollar programas que ejecuten algoritmos de resolución de modelos matemáticos o aproximación numérica a la solución utilizando para cada caso el entorno computacional adecuado."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000170/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Utilizar las capacidades analíticas y de abstracción, la intuición y el pensamiento lógico y riguroso desarrolladas a través del estudio de la Matemática en contextos tanto matemáticos como no matemáticos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000170/2025-26/CG4> a ns1:Competency ;
    ns1:competencyCode "CG4" ;
    ns1:competencyDescription "Utilizar los conocimientos teóricos y prácticos adquiridos en la definición y planteamiento de problemas y en la búsqueda de sus soluciones tanto en contextos académicos como profesionales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000170/2025-26/CG5> a ns1:Competency ;
    ns1:competencyCode "CG5" ;
    ns1:competencyDescription "Sintetizar conocimientos y habilidades adquiridas en el campo de la matemática en diferentes materias del plan de estudios para enfocarlas en posteriores estudios especializados, tanto en una disciplina matemática como en cualquiera de las ciencias que requieran buenos fundamentos matemáticos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000170/2025-26/CT4> a ns1:Competency ;
    ns1:competencyCode "CT4" ;
    ns1:competencyDescription "Mostrar capacidad para innovar y encontrar soluciones creativas en situaciones complejas o de incertidumbre."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000170/2025-26/RA165> a ns1:LearningResult ;
    ns1:learningResultCode "RA165" ;
    ns1:learningResultDescription "Conocer los modelos más habituales basados en ecuaciones en derivadas parciales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000170/2025-26/RA167> a ns1:LearningResult ;
    ns1:learningResultCode "RA167" ;
    ns1:learningResultDescription "Interpretar adecuadamente las condiciones de contorno e iniciales en una EDP"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000170/2025-26/RA236> a ns1:LearningResult ;
    ns1:learningResultCode "RA236" ;
    ns1:learningResultDescription "Conocer el método de elementos finitos para resolver ecuaciones elípticas y programarlo en problemas académicos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000170/2025-26/RA237> a ns1:LearningResult ;
    ns1:learningResultCode "RA237" ;
    ns1:learningResultDescription "Conocer el método de diferencias finitas para resolver ecuaciones elípticas y programarlo en problemas académicos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000170/2025-26/RA238> a ns1:LearningResult ;
    ns1:learningResultCode "RA238" ;
    ns1:learningResultDescription "Conocer los métodos espectrales para resolver ecuaciones elípticas y programarlo en problemas académicos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000170/2025-26/RA239> a ns1:LearningResult ;
    ns1:learningResultCode "RA239" ;
    ns1:learningResultDescription "Conocer los métodos de diferencias finitas para EDP evolutivas y programarlos en problemas académicos"@es .

