    ns1:itemIndex 37 ;
    ns1:syllabusDescription "5.3.1. Poliedros regulares: Tetraedro, cubo y octaedro. Esferas inscritas, circunscritas y tangente a las aristas. Representación y secciones.Triedro trirectángulo Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85004115/2025-26/syllabus/38> a ns1:SyllabusItem ;
    ns1:itemIndex 38 ;
    ns1:syllabusDescription "5.3.2. Prismas y Pirámides. Contornos aparentes. Desarrollos y secciones Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85004115/2025-26/syllabus/39> a ns1:SyllabusItem ;
    ns1:itemIndex 39 ;
    ns1:syllabusDescription "5.3.3. Representación de circunferencia y esfera. Planos tangentes, secciones planas, intersección con recta Sin subniveles"@es .

