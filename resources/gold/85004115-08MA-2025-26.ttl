    ns1:itemIndex 35 ;
    ns1:syllabusDescription "5.2.1. Cambios de plano. Giros de puntos, rectas y planos. Aplicaciones a los problemas métricos y a las distancias o mínimas distancias Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85004115/2025-26/syllabus/36> a ns1:SyllabusItem ;
    ns1:itemIndex 36 ;
