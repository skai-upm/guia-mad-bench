    ns1:syllabusDescription "5.3.4. Superficies. Conos y cilindros cuádricos y de revolución. Planos tangentes. Secciones y desarrollos. Contornos aparentes. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85004115/2025-26/syllabus/41> a ns1:SyllabusItem ;
    ns1:itemIndex 41 ;
    ns1:syllabusDescription "5.3.5. Intersecciones de superficies. Aplicaciones a la calderería y a los trazados de tuberías Sin subniveles"@es .

