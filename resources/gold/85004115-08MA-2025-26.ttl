<https://guia-kg.skai.etsisi.upm.es/resource/85004115/2025-26/CB1> a ns1:Competency ;
    ns1:competencyCode "CB1" ;
    ns1:competencyDescription "Que los estudiantes hayan demostrado poseer y comprender conocimientos en un área de estudio que parte de la base de la educación secundaria general, y se suele encontrar a un nivel que, si bien se apoya en libros de texto avanzados, incluye también algunos aspectos que implican conocimientos procedentes de la vanguardia de su campo de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85004115/2025-26/CB5> a ns1:Competency ;
    ns1:competencyCode "CB5" ;
    ns1:competencyDescription "Que los estudiantes hayan desarrollado aquellas habilidades de aprendizaje necesarias para emprender estudios posteriores con un alto grado de autonomía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85004115/2025-26/CE5> a ns1:Competency ;
    ns1:competencyCode "CE5" ;
    ns1:competencyDescription "Capacidad de visión espacial y conocimiento de las técnicas de representación gráfica, tanto por métodos tradicionales de geometría métrica y geometría descriptiva, como mediante las aplicaciones de diseño asistido por ordenador."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85004115/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Capacidad para el aprendizaje de nuevos métodos y teorías, y en la versatilidad para adaptarse a nuevas situaciones basándose en los conocimientos adquiridos en materias básicas y tecnológicas propias de la Ingeniería Marítima."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85004115/2025-26/RA48> a ns1:LearningResult ;
    ns1:learningResultCode "RA48" ;
    ns1:learningResultDescription "Manejar las formas geométricas y sus transformaciones"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85004115/2025-26/RA49> a ns1:LearningResult ;
    ns1:learningResultCode "RA49" ;
    ns1:learningResultDescription "Conocer y aplicar los criterios de normalización y acotación en croquis y representaciones gráficas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85004115/2025-26/RA50> a ns1:LearningResult ;
    ns1:learningResultCode "RA50" ;
    ns1:learningResultDescription "Conocer y manejar los elementos básicos en los sistemas diédrico y axonométrico."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85004115/2025-26/RA51> a ns1:LearningResult ;
    ns1:learningResultCode "RA51" ;
    ns1:learningResultDescription "Manejar la representación de poliedros y superficies básicas en axonométrica y diédrica."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85004115/2025-26/RA88> a ns1:LearningResult ;
    ns1:learningResultCode "RA88" ;
    ns1:learningResultDescription "Representar un conjunto de datos de forma gráfica"@es .

