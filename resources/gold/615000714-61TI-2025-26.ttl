<https://guia-kg.skai.etsisi.upm.es/resource/615000714/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/615000714/2025-26/CC07>,
        <https://guia-kg.skai.etsisi.upm.es/resource/615000714/2025-26/CC12>,
