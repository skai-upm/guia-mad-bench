        <https://guia-kg.skai.etsisi.upm.es/resource/203000153/2025-26/RA28>,
        <https://guia-kg.skai.etsisi.upm.es/resource/203000153/2025-26/RA3>,
        <https://guia-kg.skai.etsisi.upm.es/resource/203000153/2025-26/RA5> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/203000153/2025-26/syllabus> ;
    ns1:inpersonHours "25 horas y 30 minutos (32.7%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation """ODS 3, 8, 9
Salud y bienestar. Elaboración de aceites y grasas más saludables.
Empleo decente. Formación y creación de puestos cualificados en la IA
Innovación. Desarrollo e innovación en el sector oleícola y de aceites vegetales ."""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "27 horas y 30 minutos"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/203000153/2025-26/eventSchedule> ;
    schema:description "La asignatura pretende dar una perspectiva general de la elaboración de aceites. Una vez el alumno conozca los fundamentos básicos, la asignatura profundizará en las diferentes innovaciones sobre los diferentes sectores estudiados, así como en otras innovaciones para la obtención de nuevos productos."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/juanmanuel.delfresno%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/felipe.palomero%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/juanmanuel.delfresno%40upm.es> ;
    schema:name "Aplicaciones Recientes de Grasas en la Industria Alimentaria"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000153/2025-26/CB9> a ns1:Competency ;
    ns1:competencyCode "CB9" ;
    ns1:competencyDescription "Que los estudiantes sepan comunicar sus conclusiones y los conocimientos y razones últimas que las sustentan a públicos especializados y no especializados de un modo claro y sin ambigüedades"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000153/2025-26/CE%2017> a ns1:Competency ;
    ns1:competencyCode "CE 17" ;
    ns1:competencyDescription "Conocer la evolución de las técnicas analíticas para su aplicación en la detección de fraudes y analizar el fundamento de la elaboración de prebióticos y evaluar su papel en el binomio alimentación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000153/2025-26/CG4> a ns1:Competency ;
    ns1:competencyCode "CG4" ;
    ns1:competencyDescription "Capacidad de integración de resultados experimentales en modelos y herramientas de gestión en la elaboración e industrialización de alimentos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000153/2025-26/CG6> a ns1:Competency ;
    ns1:competencyCode "CG6" ;
    ns1:competencyDescription "Capacidad de innovación, resolución de problemas, toma de decisiones, discusión y conclusiones científicas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000153/2025-26/CG7> a ns1:Competency ;
    ns1:competencyCode "CG7" ;
    ns1:competencyDescription "Desarrollo de habilidades para la comunicación y presentación de ideas favoreciendo la accesibilidad, información y consumo de alimentos sanos."@es .

