        <https://guia-kg.skai.etsisi.upm.es/resource/205000018/2025-26/RA144> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/205000018/2025-26/syllabus> ;
    ns1:inpersonHours "63 horas (48.5%)"@es ;
    ns1:numberOfCredits 5.0 ;
    ns1:otherInformation ""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "63 horas"@es ;
    schema:activitiesWorkload "90%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/205000018/2025-26/eventSchedule> ;
    schema:description """Los objetivo de la asignatura son los siguientes:
Que los alumnos conozcan los principios básicos del diseño de experimentos, sean capaces de diseñar y analizar experimentos adecuados para los objetivos del estudio y presentar de forma clara y precisa los resultados mediante tablas y gráficos.
Que conozacan y manejar las técnicas de análisis multivariantes más habituales: el análisis de regresión lineal múltiple, el análisis de componentes principales y la clasificacación no supervisada.
Para ello la asignatura se apoya en la resolución de casos prácticos resueltos con la utilización de software estadístico."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/miguel.ibanez%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/miguel.ibanez%40upm.es> ;
    schema:name "Métodos Estadísticos Aplicados a las Ciencias Agrarias"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000018/2025-26/CB02> a ns1:Competency ;
    ns1:competencyCode "CB02" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar sus conocimientos a su trabajo o vocación de una forma profesional y posean las competencias que suelen demostrarse por medio de la elaboración y defensa de argumentos y la resolución de problemas dentro de su área de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000018/2025-26/CE03> a ns1:Competency ;
    ns1:competencyCode "CE03" ;
    ns1:competencyDescription "Capacidad para realizar análisis bioestadístico, así como utilizar herramientas informáticas para la resolución de problemas matemáticos y estadísticos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000018/2025-26/CG03> a ns1:Competency ;
    ns1:competencyCode "CG03" ;
    ns1:competencyDescription "Familiarizarse con el trabajo y los métodos experimentales en condiciones reales, adquiriendo la capacidad de realizar experimentos y/o diseñar aplicaciones de forma independiente y describir, cuantificar, analizar y evaluar críticamente los resultados obtenidos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000018/2025-26/CT02> a ns1:Competency ;
    ns1:competencyCode "CT02" ;
    ns1:competencyDescription "Capacidad para aplicar el método científico para la resolución de problemas de forma efectiva y creativa."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000018/2025-26/RA140> a ns1:LearningResult ;
    ns1:learningResultCode "RA140" ;
    ns1:learningResultDescription "Comprender y manejar los conceptos relacionados con el diseño y análisis estadístico de experimentos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000018/2025-26/RA141> a ns1:LearningResult ;
    ns1:learningResultCode "RA141" ;
    ns1:learningResultDescription "Comprender y manejar los diseños de experimentos en bloques completos y con covariables."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000018/2025-26/RA142> a ns1:LearningResult ;
    ns1:learningResultCode "RA142" ;
    ns1:learningResultDescription "Comprender y manejar los conceptos relacionados con la regresión lineal simple y múltiple."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000018/2025-26/RA143> a ns1:LearningResult ;
    ns1:learningResultCode "RA143" ;
    ns1:learningResultDescription "Comprender y manejar los conceptos relacionados con el análisis de componentes principales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000018/2025-26/RA144> a ns1:LearningResult ;
    ns1:learningResultCode "RA144" ;
    ns1:learningResultDescription "Comprender y manejar los conceptos relacionados con la clasificación no supervisada."@es .

