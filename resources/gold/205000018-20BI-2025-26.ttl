        "Métodos Estadísticos Aplicados a las Ciencias Agrarias"@es ;
    schema:numberOfCredits 5.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/205000018/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/205000018/2025-26/CB02>,
