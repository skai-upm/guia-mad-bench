    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Planteamiento general del problema"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000470/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. El contexto general de la actividad del ingeniero dedicado a las construcciones históricas Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000470/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "3.2. Procedimientos basados en la construcción de la línea de empujes y comprobación seccional Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000470/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "3.3. Posibilidades futuras para los procedimientos de análisis estructural Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000470/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "4. Puentes bóveda de fábrica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000470/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "4.1. Tipologías. Clasificación geométrica e histórica. Identificación de elementos estructurales, su funcionamiento e importancia. Procesos constructivos. Daños más frecuentes y modos de colapso. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000470/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "4.2. Proyecto y construcción de puentes de fábrica Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000470/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "4.3. Metodología para el análisis estructural de comprobación y de proyecto de refuerzos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000470/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "5. Iglesias y catedrales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000470/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "5.1. Comprobación de la sección transversal típica. Importancia de los rellenos en el trasdós de las bóvedas de puentes y edificios Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000470/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "5.2. Recorrido cronológico de tipologías constructivas y significados Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000470/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "6. Sistemas de gestión"@es .

