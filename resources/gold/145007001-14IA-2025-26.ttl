    ns1:inpersonHours "45 horas (38.5%)"@es ;
    ns1:numberOfCredits 4.5 ;
    ns1:otherInformation """La asignatura cubre un espectro amplio de los conocimientos empresariales y por ello tiene mucha implicación con los Objetivos de Desarrollo Sostenible, de hecho el último tema de asignatura es Medio ambiente. La asignatura está relacionada con los siguientes ODS:
ODS 8: Trabajó decente y crecimiento económico
ODS 9. Industrial, innovación e infraestructuras
ODS 12. Producción y consumos responsables"""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "48 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/145007001/2025-26/eventSchedule> ;
    schema:description "Esta asignatura tiene por objeto introducir a los estudiantes de 4º en como dirigir una empresa, como gestionar los distintos departamentos que tiene una empresa, haciendo especial énfasis en la gestión económica y financiera. Otro objetivo es familiarizar a los estudiantes con la gestión de proyectos de ingeniería, viendo en detalle la gestión de cada tipo y sus partes. Finalmente una pequeña introducción al impacto ambiental del sector aeroespacial"@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/rafaeleugenio.gonzalez%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/alberto.sanchezr%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/antoniomartinez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/danielfernando.gallego%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/javier.espina%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/juanjose.morillas%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/rafaeleugenio.gonzalez%40upm.es> ;
    schema:name "Gestion de Empresas y Proyectos"@es .

