<https://guia-kg.skai.etsisi.upm.es/resource/595400205/2025-26/RA54> a ns1:LearningResult ;
    ns1:learningResultCode "RA54" ;
    ns1:learningResultDescription "Analizar y diseñar sistemas para la recolección de energía"@es .

