    ns1:learningResultDescription "Manejar las herramientas y entornos de trabajo más actuales en el ámbito del aprendizaje automático"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595400205/2025-26/RA60> a ns1:LearningResult ;
    ns1:learningResultCode "RA60" ;
