    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/45000114/2025-26/eventSchedule> ;
    schema:description """El objetivo fundamental de la asignatura es proporcionar al alumno los conocimientos necesarios en el campo del comportamiento elástico de los materiales, la Teoría de la Elasticidad y su aplicación práctica sólidos de forma prismática o Resistencia de Materiales.
Objetivo 1. Conocer los modelos macroscópicos basados en la mecánica de los medios continuos que permitan describir matemáticamente el comportamiento elástico de los materiales
Objetivo 2. Plantear los fundamentos de la Resistencia de Materiales como caso particular de la teoría de la elasticidad para sólidos con forma prismática.
Objetivo 3. Aplicación de los conocimientos adquiridos a casos prácticos en el diseño y cálculo estructural de sistemas de barras y vigas."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/c.gonzalez%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/c.gonzalez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/javier.segurado%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/v.rey%40upm.es> ;
    schema:name "Mecánica de Materiales II"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000114/2025-26/CE%202.> a ns1:Competency ;
    ns1:competencyCode "CE 2." ;
    ns1:competencyDescription "Saber modelizar el comportamiento (mecánico, electrónico, químico o biológico) de los materiales y su integración en componentes y dispositivos./ Know how to model the behavior (mechanical, electronic, chemical or biological) of materials and their integration into components and devices."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000114/2025-26/CE%205.> a ns1:Competency ;
    ns1:competencyCode "CE 5." ;
    ns1:competencyDescription "Capacitar para el aprendizaje autÃ³nomo de nuevos conocimientos y tÃ©cnicas / Train for autonomous learning of new knowledge and techniques"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000114/2025-26/CG%203> a ns1:Competency ;
    ns1:competencyCode "CG 3" ;
    ns1:competencyDescription "Comunicación oral y escrita"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000114/2025-26/RA23> a ns1:LearningResult ;
    ns1:learningResultCode "RA23" ;
    ns1:learningResultDescription "Entender, asimilar y manejar los conceptos y métodos básicos del comportamiento mecánico de los materiales, incluyendo la influencia del tiempo ( fenómenos diferidos) , la temperatura ( fenómenos termomecánicos) y la presencia de ambiente agresivos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000114/2025-26/RA24> a ns1:LearningResult ;
    ns1:learningResultCode "RA24" ;
    ns1:learningResultDescription "Conocer las teorías y modelos matemáticos más relevantes en relación con la respuesta mecánica de los materiales y sus mecanismos de deformación y rotura."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000114/2025-26/RA25> a ns1:LearningResult ;
    ns1:learningResultCode "RA25" ;
    ns1:learningResultDescription "Saber aplicar de forma práctica las teorías de comportamiento mecánico a los diferentes tipos de materiales (metálicos, cerámicos, polímeros y materiales biológicos)."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000114/2025-26/RA26> a ns1:LearningResult ;
    ns1:learningResultCode "RA26" ;
    ns1:learningResultDescription "Saber diseñar y experimentar con componentes estructurales sencillos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000114/2025-26/RA27> a ns1:LearningResult ;
    ns1:learningResultCode "RA27" ;
    ns1:learningResultDescription "Utilizar con soltura la comunicación oral y escrita en lengua española e inglesa"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000114/2025-26/RA28> a ns1:LearningResult ;
    ns1:learningResultCode "RA28" ;
    ns1:learningResultDescription "Saber trabajar en equipo. Ejecutar el trabajo con responsabilidad y respeto a los demás."@es .

