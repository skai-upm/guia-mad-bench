<https://guia-kg.skai.etsisi.upm.es/resource/33000887/2025-26/RA1> a ns1:LearningResult ;
    ns1:learningResultCode "RA1" ;
    ns1:learningResultDescription "Los alumnos aprenderán a realizar la captura, almacenamiento, tratamiento y análisis de información requerida para los proyectos de la investigación en materiales de construcción, sistemas constructivos,"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000887/2025-26/RA2> a ns1:LearningResult ;
    ns1:learningResultCode "RA2" ;
    ns1:learningResultDescription "Aprenderán también métodos de toma de decisiones aplicables en el campo de la investigación en materiales de construcción, sistemas constructivos y técnicas arquitectónicas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000887/2025-26/RA3> a ns1:LearningResult ;
    ns1:learningResultCode "RA3" ;
    ns1:learningResultDescription "Diagnosticar los problemas patológicos de la edificación más frecuentes"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000887/2025-26/RA4> a ns1:LearningResult ;
    ns1:learningResultCode "RA4" ;
    ns1:learningResultDescription "Conocer las técnicas de reparación de los daños de la edificación que pueden aparecer con mayor frecuencia"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000887/2025-26/RA5> a ns1:LearningResult ;
    ns1:learningResultCode "RA5" ;
    ns1:learningResultDescription "Análisis de los diversos sistemas constructivos. Sistemas de estructuras. Tecnología de los cerramientos. Sistemas de anclaje. Estructuras soporte."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000887/2025-26/RA6> a ns1:LearningResult ;
    ns1:learningResultCode "RA6" ;
    ns1:learningResultDescription "Capacidad de análisis inmobiliarios, gestión de plazos, riesgos y gestión BIM del porceso"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000887/2025-26/RA7> a ns1:LearningResult ;
    ns1:learningResultCode "RA7" ;
    ns1:learningResultDescription "Capacidad para realizar un análisis crítico, evaluación y síntesis de ideas nuevas y complejas dentro del campo de investigación elegido"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000887/2025-26/RA8> a ns1:LearningResult ;
