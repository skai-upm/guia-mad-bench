<https://guia-kg.skai.etsisi.upm.es/resource/65005020/2025-26/C15> a ns1:Competency ;
    ns1:competencyCode "C15" ;
    ns1:competencyDescription "Capacidad para organizar y planificar en el ámbito de la empresa, y otras instituciones y organizaciones de proyectos y equipos humanos. TIPO: Competencias"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65005020/2025-26/CON13> a ns1:Competency ;
    ns1:competencyCode "CON13" ;
    ns1:competencyDescription "Conocer y comprender la metodología, gestión y organización de proyectos. TIPO: Conocimientos o contenidos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65005020/2025-26/CON3> a ns1:Competency ;
    ns1:competencyCode "CON3" ;
    ns1:competencyDescription "Conocer y comprender el concepto de empresa, marco institucional y jurídico de la empresa. Organización y gestión de empresas. TIPO: Conocimientos o contenidos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65005020/2025-26/HAB11> a ns1:Competency ;
    ns1:competencyCode "HAB11" ;
    ns1:competencyDescription "Utilizar la creatividad para resolver problemas de ingeniería. TIPO: Habilidades o destrezas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65005020/2025-26/HAB12> a ns1:Competency ;
    ns1:competencyCode "HAB12" ;
    ns1:competencyDescription "Capacidad para comprender y aplicar los principios de los conocimientos básicos de la química general, química orgánica e inorgánica, y sus aplicaciones en la ingeniería. TIPO: Habilidades o destrezas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65005020/2025-26/HAB5> a ns1:Competency ;
    ns1:competencyCode "HAB5" ;
    ns1:competencyDescription "Capacidad de análisis de la problemática de la seguridad y salud en los proyectos, plantas o instalaciones. TIPO: Habilidades o destrezas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65005020/2025-26/HAB6> a ns1:Competency ;
    ns1:competencyCode "HAB6" ;
    ns1:competencyDescription "Capacidad para aplicar metodologías de estudios y evaluaciones de impacto ambiental y, en general, de tecnologías ambientales, sostenibilidad y tratamiento de residuos. TIPO: Habilidades o destrezas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65005020/2025-26/HAB7> a ns1:Competency ;
    ns1:competencyCode "HAB7" ;
    ns1:competencyDescription "Capacidad para la planificación y gestión integral de obras, mediciones, replanteos, control y seguimiento. TIPO: Habilidades o destrezas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65005020/2025-26/HAB9> a ns1:Competency ;
    ns1:competencyCode "HAB9" ;
    ns1:competencyDescription "Saber comunicar los conocimientos y conclusiones, tanto de forma oral, escrita y gráfica, a públicos especializados y no especializados de un modo claro y sin ambigüedades. TIPO: Habilidades o destrezas"@es .

