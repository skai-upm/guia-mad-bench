    ns1:otherInformation "La asignatura se alinea con los OBJETIVOS DE DESARROLLO SOSTENIBLE nº 9. Industria, innovación e infraestructura y nº 12. Producción y consumo responsable."@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
