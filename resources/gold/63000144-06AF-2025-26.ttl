    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/63000144/2025-26/eventSchedule> ;
    schema:description """Conocer, comprender y aplicar los conceptos siguientes:
Modelos matemáticos: ecuaciones, condiciones de contorno, condiciones iniciales.
Esquemas de resolución de problemas de ecuaciones diferenciales y en derivadas parciales de tipo elíptico, parabólico e hiperbólico mediante el método de elementos finitos (MEF).
Conocer las herramientas del álgebra y del cálculo numérico.
Aplicar los métodos en diferencias para resolución aproximada de problemas evolutivos.
Modelizar mediante el MEF un problema modelo propuesto."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/luisjavier.perez%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/luisjavier.perez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/santiago.devicente%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/tasio.santos%40upm.es> ;
    schema:name "Simulacion Numerica I: Formulacion y Metodos de Resolucion"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000144/2025-26/CE01> a ns1:Competency ;
    ns1:competencyCode "CE01" ;
    ns1:competencyDescription "Capacidad para abordar y resolver problemas matemáticos avanzados de ingeniería, desde el planteamiento del problema hasta el desarrollo de la formulación y su implementación en un programa de ordenador. En particular, capacidad para formular, programar y aplicar modelos analíticos y numéricos avanzados de cálculo, proyectos, planificación y gestión, así como capacidad para la interpretación de los resultados obtenidos, en el contexto de la ingeniería de minas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000144/2025-26/CG18> a ns1:Competency ;
    ns1:competencyCode "CG18" ;
    ns1:competencyDescription "Conocimientos adecuados de los aspectos científicos y tecnológicos de métodos matemáticos, analíticos y numéricos de la ingeniería, mecánica de fluidos, mecánica de medios continuos, cálculo de estructuras, carboquímica, petroquímica y geotecnia"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000144/2025-26/CT04> a ns1:Competency ;
    ns1:competencyCode "CT04" ;
    ns1:competencyDescription "Capacidad para trabajar de forma efectiva como individuo, organizando y planificando su propio trabajo, de forma independiente o como miembro de un equipo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000144/2025-26/RA110> a ns1:LearningResult ;
    ns1:learningResultCode "RA110" ;
    ns1:learningResultDescription "Aplicar la simulación numérica, a través de herramientas informáticas empleadas por la industria, a distintos casos reales de producción y almacenamiento"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000144/2025-26/RA111> a ns1:LearningResult ;
    ns1:learningResultCode "RA111" ;
    ns1:learningResultDescription "Capacidad para realizar profesionalmente las actividades propias del Ingeniero de Minas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000144/2025-26/RA135> a ns1:LearningResult ;
    ns1:learningResultCode "RA135" ;
    ns1:learningResultDescription "Capacidad para seleccionar, integrar y utilizar en ingeniería, las herramientas informáticas más adecuadas al caso concreto que aborda el proyecto de diseño."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000144/2025-26/RA188> a ns1:LearningResult ;
    ns1:learningResultCode "RA188" ;
    ns1:learningResultDescription "CE01"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000144/2025-26/RA191> a ns1:LearningResult ;
    ns1:learningResultCode "RA191" ;
    ns1:learningResultDescription "Aplicar métodos numéricos de aproximación en la resolución de problemas en derivadas parciales de la Ingeniería"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000144/2025-26/RA192> a ns1:LearningResult ;
    ns1:learningResultCode "RA192" ;
    ns1:learningResultDescription "Utilizar códigos numéricos profesionales para la simulación numérica y optimización de problemas industriales en Ingeniería"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000144/2025-26/RA55> a ns1:LearningResult ;
    ns1:learningResultCode "RA55" ;
    ns1:learningResultDescription "Plantear y resolver problemas matemáticos avanzados en el contexto de la Ingeniería de Minas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000144/2025-26/RA56> a ns1:LearningResult ;
    ns1:learningResultCode "RA56" ;
    ns1:learningResultDescription "Aplicar modelos analíticos y numéricos avanzados de cálculo, proyecto, planificación y gestión"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000144/2025-26/RA57> a ns1:LearningResult ;
