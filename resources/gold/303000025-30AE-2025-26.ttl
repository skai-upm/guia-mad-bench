    ns1:courseType "Optativa"@es ;
    ns1:courseYear 1 ;
    ns1:semester "Primer semestre"@es ;
    schema:courseCode 303000025 ;
    schema:hasCourseInstance <https://guia-kg.skai.etsisi.upm.es/resource/303000025/2025-26> ;
    schema:name "Written And Oral English For Educational Environments"@en,
        "Inglés Oral y Escrito para Entornos Educativos"@es ;
    schema:numberOfCredits 3.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/303000025/2025-26> a ns1:CourseGuide ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/303000025/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/303000025/2025-26/didactic_resource/2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/303000025/2025-26/didactic_resource/3> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/303000025/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/303000025/2025-26/RA31> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/303000025/2025-26/syllabus> ;
    ns1:inpersonHours "43 horas (53.1%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation """For any doubts or queries, send an email from Monday to Friday (9.30 a.m. to 6.00 p.m.). The subject is related to other subjects in this Master if students submit their papers or tasks in English.
This subject is linked to SDGs 1 to 15 included."""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "48 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/303000025/2025-26/eventSchedule> ;
    schema:description "El objetivo principal de la asignatura es reflexionar sobre el Aprendizaje Integrado de Contenido y Lengua y sobre la metodología que caracteriza AICLE. Durante el curso se persigue mejorar la competencia comunicativa del estudiante para impartir clases de distintas materias del área tecnológica en lengua inglesa y las estrategias de enseñanza. En concreto, se abordarán aspectos relacionados con el lenguaje oral (inglés como lengua internacional, pronunciación, comprensión oral, interacción en el aula, clases magistrales, etc.) y del lenguaje escrito (terminología, gramática, características del discurso académico, instrucciones, etc.) Se integrarán las destrezas orales y escritas aprendidas en el diseño de unidades docentes."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/silvia.molina%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/samira.allani%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/silvia.molina%40upm.es> ;
    schema:name "Inglés Oral y Escrito para Entornos Educativos"@es .

