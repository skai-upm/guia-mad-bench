        <https://guia-kg.skai.etsisi.upm.es/resource/583000050/2025-26/didactic_resource/4>,
        <https://guia-kg.skai.etsisi.upm.es/resource/583000050/2025-26/didactic_resource/5>,
        <https://guia-kg.skai.etsisi.upm.es/resource/583000050/2025-26/didactic_resource/6>,
        <https://guia-kg.skai.etsisi.upm.es/resource/583000050/2025-26/didactic_resource/7> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/583000050/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/583000050/2025-26/RA18>,
        <https://guia-kg.skai.etsisi.upm.es/resource/583000050/2025-26/RA77>,
        <https://guia-kg.skai.etsisi.upm.es/resource/583000050/2025-26/RA79>,
