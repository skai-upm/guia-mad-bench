        <https://guia-kg.skai.etsisi.upm.es/resource/145006403/2025-26/syllabus/8>,
        <https://guia-kg.skai.etsisi.upm.es/resource/145006403/2025-26/syllabus/9> .

<https://guia-kg.skai.etsisi.upm.es/resource/145006403/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. ACCIONES EN LA EDIFICACIÓN"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145006403/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Introducción: fases en el cálculo de una estructura. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145006403/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "2.3. Cálculo y comprobación de estructuras: situaciones de proyecto. Combinación de acciones en función de la situación y el estado límite de comprobación. Normativa. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145006403/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "2.4. Proyecto y análisis global de las estructuras metálicas. Normativa. Comportamiento de las secciones transversales. Clases de secciones según normativa. Imperfecciones. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145006403/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "3. CÁLCULO DE BARRAS SOMETIDAS A FLEXIÓN"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145006403/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "3.1. Comprobación de secciones a estado límite último. Tensiones normales y tangenciales: comprobaciones según normativa. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145006403/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "3.2. Comprobación de barras a estado límite último. Pandeo lateral, abolladura del alma y pandeo del alma bajo cargas concentradas: comprobaciones según normativa. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145006403/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "3.3. Comprobación de barras a estado límite de servicio. Limitación de flecha según normativa. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145006403/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "4. CÁLCULO DE BARRAS SOMETIDAS A COMPRESIÓN"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145006403/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "4.1. Comprobación de secciones y de barras. Inestabilidad, pandeo y carga crítica. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145006403/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "4.2. Bases de cálculo de barras comprimidas. Pandeo por flexión y torsión. Barra ideal y barra real. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145006403/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "4.3. El método de cálculo de barras comprimidas por uso de coeficientes de reducción por pandeo. Longitud de pandeo y esbeltez reducida. Normativa. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145006403/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Acciones en la edificación: clasificación, tipos y características. Normativa de aplicación para su determinación. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145006403/2025-26/syllabus/20> a ns1:SyllabusItem ;
    ns1:itemIndex 20 ;
    ns1:syllabusDescription "4.4. Soportes simples sometidos a compresión centrada y a compresión excéntrica: comprobaciones según normativa. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145006403/2025-26/syllabus/21> a ns1:SyllabusItem ;
    ns1:itemIndex 21 ;
    ns1:syllabusDescription "5. CÁLCULO DE BARRAS SOMETIDAS A TRACCIÓN"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145006403/2025-26/syllabus/22> a ns1:SyllabusItem ;
    ns1:itemIndex 22 ;
    ns1:syllabusDescription "5.1. Barras sometidas a tracción centrada y excéntrica: comprobaciones según normativa. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145006403/2025-26/syllabus/23> a ns1:SyllabusItem ;
    ns1:itemIndex 23 ;
    ns1:syllabusDescription "6. UNIONES Y BASES DE CIMENTACIÓN"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145006403/2025-26/syllabus/24> a ns1:SyllabusItem ;
    ns1:itemIndex 24 ;
    ns1:syllabusDescription "6.1. Clasificación de las uniones en función de su rigidez. Uniones soldadas y atornilladas: criterios generales de cálculo. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145006403/2025-26/syllabus/25> a ns1:SyllabusItem ;
    ns1:itemIndex 25 ;
    ns1:syllabusDescription "6.2. Bases de cimentación. Soportes sometidos a compresión simple. Soportes sometidos a compresión compuesta: casos de pequeña y gran excentricidad. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145006403/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "1.3. Acciones permanentes: tipos y características. Normativa. Determinación de las mismas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145006403/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "1.4. Acciones variables: tipos y características. Normativa. Determinación de las mismas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145006403/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "1.5. Acciones accidentales: tipos y características. Normativa. Consideración de la seguridad en caso de incendio y frente a impacto de vehículos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145006403/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "1.6. Acciones accidentales de sismo: efectos del sismo, normativa. Método simplificado de cálculo de la NCSE. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145006403/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "2. LA SEGURIDAD EN EL CÁLCULO DE ESTRUCTURAS"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145006403/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "2.1. Bases de cálculo: el método de los estados límites. Estados límites Últimos y de Servicio. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145006403/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "2.2. Valor característico y valor de cálculo de acciones y resistencias. Valor representativo de las acciones. Coeficientes de seguridad y simultaneidad según normativa. Sin subniveles"@es .

