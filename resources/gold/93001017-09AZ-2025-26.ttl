<https://guia-kg.skai.etsisi.upm.es/resource/93001017/2025-26/CE01> a ns1:Competency ;
    ns1:competencyCode "CE01" ;
    ns1:competencyDescription "Capacidad para evaluar las ventajas e inconvenientes de las alternativas tecnológicas en el diseño o fabricación de sistemas electrónicos analógicos, digitales, centrales o distribuidos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93001017/2025-26/CE02> a ns1:Competency ;
    ns1:competencyCode "CE02" ;
    ns1:competencyDescription "Capacidad para aplicar herramientas, técnicas y metodologías avanzadas de diseño de sistemas o subsistemas electrónicos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93001017/2025-26/CE04> a ns1:Competency ;
    ns1:competencyCode "CE04" ;
    ns1:competencyDescription "Capacidad para diseñar un dispositivo, sistema, aplicación o servicio que cumpla unas especificaciones dadas, empleando un enfoque sistémico y multidisciplinar e integrando los módulos y herramientas avanzadas disponibles en el campo de la Ingeniería Electrónica."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93001017/2025-26/CG01> a ns1:Competency ;
    ns1:competencyCode "CG01" ;
    ns1:competencyDescription "Uso de la lengua inglesa: comprender los contenidos de clases magistrales, conferencias y seminarios en lengua inglesa; redactar en inglés informes y artículos científicos o técnicos usando herramientas informáticas; realizar exposiciones públicas en inglés de trabajos, resultados y conclusiones, por ejemplo, en las asignaturas del máster, todo ello con la ayuda de medios informáticos audiovisuales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93001017/2025-26/CG02> a ns1:Competency ;
    ns1:competencyCode "CG02" ;
    ns1:competencyDescription "Liderazgo de equipos: realizar trabajos en equipo (como los de algunas de las actividades de evaluación de las asignaturas), integrarse en un grupo participando activamente en sus reuniones, colaborando con iniciativa propia en trabajos o proyectos de I+D +i; interaccionar con efectividad con los miembros del equipo de trabajo multidisciplinar"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93001017/2025-26/CG03> a ns1:Competency ;
    ns1:competencyCode "CG03" ;
    ns1:competencyDescription "Creatividad: Concebir, desarrollar y validar nuevos sistemas y servicios que puedan aumentar la calidad de vida de las personas; Realizar, en contextos académicos y profesionales, innovaciones o avances."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93001017/2025-26/CG04> a ns1:Competency ;
    ns1:competencyCode "CG04" ;
    ns1:competencyDescription "Organización y planificación: Organizar, planificar y gestionar proyectos complejos y multidisciplinares que involucren no una sino varias de las tecnologías avanzadas tratadas en el Máster."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93001017/2025-26/CG05> a ns1:Competency ;
    ns1:competencyCode "CG05" ;
    ns1:competencyDescription "Gestión de la información: buscar y gestionar recursos bibliográficos adecuados con eficiencia, aprender a continuar los estudios de manera ampliamente autónoma."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93001017/2025-26/CG08> a ns1:Competency ;
    ns1:competencyCode "CG08" ;
    ns1:competencyDescription "Aplicar metodologías, procedimientos, herramientas y normas del estado del arte para la creación de nuevos componentes tecnológicos; construir nuevas hipótesis y modelos, evaluarlos y aplicarlos a la resolución de problemas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93001017/2025-26/CG09> a ns1:Competency ;
    ns1:competencyCode "CG09" ;
    ns1:competencyDescription "Comunicar juicios, y conocimientos a audiencias especializadas y no especializadas, de una manera razonada, clara y sin ambigüedades."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93001017/2025-26/RA1> a ns1:LearningResult ;
    ns1:learningResultCode "RA1" ;
    ns1:learningResultDescription "Conocimientos cualitativos y cuantitativos para la selección e interconexión de subsistemas en el diseño de sistemas electrónicos analógicos o digitales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93001017/2025-26/RA2> a ns1:LearningResult ;
    ns1:learningResultCode "RA2" ;
    ns1:learningResultDescription "Capacidad para diseñar, implementar y probar sistemas electrónicos avanzados, analógicos o digitales, de acuerdo con unas especificaciones imperfectas de carácter multidisciplinar."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93001017/2025-26/RA3> a ns1:LearningResult ;
    ns1:learningResultCode "RA3" ;
    ns1:learningResultDescription "Conocimiento de los subsistemas electrónicos disponibles en el estado del arte."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93001017/2025-26/RA4> a ns1:LearningResult ;
    ns1:learningResultCode "RA4" ;
    ns1:learningResultDescription "Conocimiento de los principales estándares y normativas empleados en la ingeniería de sistemas electrónicos"@es .

