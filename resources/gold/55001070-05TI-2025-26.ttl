    ns1:learningResultDescription "Uso del computador como herramienta de diseño."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001070/2025-26/RA33> a ns1:LearningResult ;
    ns1:learningResultCode "RA33" ;
    ns1:learningResultDescription "Conocer los fundamentos y métodos de resolución de problemas dinámicos estructurales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001070/2025-26/RA592> a ns1:LearningResult ;
    ns1:learningResultCode "RA592" ;
    ns1:learningResultDescription "Capacidad de comprender y utilizar en la práctica métodos para obtener la respuesta dinámica de estructuras."@es .

