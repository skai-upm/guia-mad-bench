<https://guia-kg.skai.etsisi.upm.es/resource/55001070/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/55001070/2025-26/CG1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55001070/2025-26/CG2>,
