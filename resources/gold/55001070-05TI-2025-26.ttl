    ns1:learningResultCode "RA10" ;
    ns1:learningResultDescription "Dinámica de sistemas discretos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001070/2025-26/RA12> a ns1:LearningResult ;
