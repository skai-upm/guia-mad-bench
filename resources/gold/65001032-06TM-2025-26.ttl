<https://guia-kg.skai.etsisi.upm.es/resource/65001032/2025-26/CG%201> a ns1:Competency ;
    ns1:competencyCode "CG 1" ;
    ns1:competencyDescription "Conocer y aplicar conocimientos de ciencias y tecnologías básicas a la práctica de la Tecnología Minera."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001032/2025-26/CG%202> a ns1:Competency ;
    ns1:competencyCode "CG 2" ;
    ns1:competencyDescription "Poseer capacidad para diseñar, analizar, calcular, proyectar, construir, mantener, conservar, explotar, desarrollar, implementar, gestionar y mejorar productos, sistemas y procesos en los distintos ámbitos de las Tecnologías Mineras, usando técnicas analíticas, computacionales o experimentales apropiadas, incluyendo la función de asesoría en estos campos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001032/2025-26/CG%203> a ns1:Competency ;
    ns1:competencyCode "CG 3" ;
    ns1:competencyDescription "Aplicar los conocimientos adquiridos para identificar, formular y resolver problemas dentro de contextos amplios y multidisciplinarios, siendo capaces de integrar conocimientos, trabajando en equipos multidisciplinares."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001032/2025-26/CG%206> a ns1:Competency ;
    ns1:competencyCode "CG 6" ;
    ns1:competencyDescription "Poseer habilidades de aprendizaje que permitan continuar estudiando a lo largo de la vida para su adecuado desarrollo profesional"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001032/2025-26/CG%207> a ns1:Competency ;
    ns1:competencyCode "CG 7" ;
    ns1:competencyDescription "Incorporar nuevas tecnologías y herramientas de la ingeniería en tecnología minera en sus actividades profesionales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001032/2025-26/CG%209> a ns1:Competency ;
    ns1:competencyCode "CG 9" ;
    ns1:competencyDescription "Organización y planificación en el ámbito de la empresa, y otras instituciones y organizaciones de proyectos y equipos humanos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001032/2025-26/F32> a ns1:Competency ;
    ns1:competencyCode "F32" ;
    ns1:competencyDescription "Diseño, operación y mantenimiento de plantas de preparación y tratamiento de minerales, rocas industriales, rocas ornamentales y residuos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001032/2025-26/F37> a ns1:Competency ;
    ns1:competencyCode "F37" ;
    ns1:competencyDescription "Metalurgia y tratamiento de concentrados minerales, metales y aleaciones: Industria metalurgia férrea y no férrea, aleaciones especiales, ensayos metalotécnicos, etc"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001032/2025-26/RA166> a ns1:LearningResult ;
    ns1:learningResultCode "RA166" ;
    ns1:learningResultDescription "Comprender los sistemas de transporte de graneles y almacenamiento de graneles."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001032/2025-26/RA167> a ns1:LearningResult ;
    ns1:learningResultCode "RA167" ;
    ns1:learningResultDescription "Seleccionar un sistema de almacenamiento y transporte adecuado."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001032/2025-26/RA168> a ns1:LearningResult ;
    ns1:learningResultCode "RA168" ;
    ns1:learningResultDescription "Concebir y optimizar un sistema de transporte y almacenamiento realizando su anteproyecto."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001032/2025-26/RA169> a ns1:LearningResult ;
    ns1:learningResultCode "RA169" ;
    ns1:learningResultDescription "Capacidad para diseñar, redactar y planificar proyectos de instalaciones de transporte y almacenamiento para materiales sólidos, líquidos o gaseosos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001032/2025-26/RA378> a ns1:LearningResult ;
    ns1:learningResultCode "RA378" ;
    ns1:learningResultDescription "Conocer las propiedades de los graneles minerales desde el punto de vista de su transporte y almacenamiento"@es .

