<https://guia-kg.skai.etsisi.upm.es/resource/93000805/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Session 1: Vector Network Analyzer: Calibration techniques. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000805/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "2. Session 2: Vector Network Analyzer. Time domain Techniques. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000805/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "3. Session 3: Active Components Characterization with complex wave forms. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000805/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "4. Session 4: Antenna Measurements 1. Antenna test set-up. Anechoic Chambers. Far and Near Field Techniques. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000805/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "5. Session 5: Antenna Measurements 2. Error diagnosis in antenna measurements. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000805/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "6. Session 6: Characterization of electrical properties of material through waveguide techniques. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000805/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "7. Session 7: RADAR System characterization. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000805/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "8. Session 8: Characterization of dielectric properties of materials using Free-Space Methods Sin subniveles"@es .

