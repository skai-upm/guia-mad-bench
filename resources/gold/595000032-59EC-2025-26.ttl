    ns1:competencyCode "CE EC05" ;
    ns1:competencyDescription "Capacidad de diseñar circuitos de electrónica analógica y digital, de conversión analógico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000032/2025-26/CG%2004> a ns1:Competency ;
    ns1:competencyCode "CG 04" ;
    ns1:competencyDescription "Capacidad de abstracción, de análisis y de síntesis y de resolución de problemas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000032/2025-26/CG%2011> a ns1:Competency ;
    ns1:competencyCode "CG 11" ;
    ns1:competencyDescription "Habilidades para la utilización de las Tecnologías de la Información y las Comunicaciones."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000032/2025-26/RA419> a ns1:LearningResult ;
    ns1:learningResultCode "RA419" ;
    ns1:learningResultDescription "Aplicar la teoría de circuitos realimentados para la identificación de realimentación positiva o negativa en circuitos construidos con amplificador operacional"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000032/2025-26/RA420> a ns1:LearningResult ;
    ns1:learningResultCode "RA420" ;
    ns1:learningResultDescription "Aplicar la teoría de circuitos realimentados al cálculo de la ganancia y resistencias terminales de un amplificador realimentado negativamente y construido con amplificador operacional"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000032/2025-26/RA421> a ns1:LearningResult ;
    ns1:learningResultCode "RA421" ;
    ns1:learningResultDescription "Conocer las ventajas y los inconvenientes que produce la realimentación negativa en el comportamiento de un amplificador"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000032/2025-26/RA422> a ns1:LearningResult ;
    ns1:learningResultCode "RA422" ;
    ns1:learningResultDescription "Aplicar un procedimiento de cálculo para la obtención de la función de red de un amplificador construido en torno al amplificador operacional"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000032/2025-26/RA423> a ns1:LearningResult ;
    ns1:learningResultCode "RA423" ;
    ns1:learningResultDescription "Representar e interpretar, mediante los diagramas de Bode, la respuesta en frecuencia de la ganancia de un amplificador construido con amplificador operacional"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000032/2025-26/RA424> a ns1:LearningResult ;
    ns1:learningResultCode "RA424" ;
    ns1:learningResultDescription "Calcular, de forma aproximada y rápida, el ancho de banda de un amplificador construido con amplificador operacional compensado en frecuencia. Se consideran los parámetros: Gain Bandwith Product y Slew Rate"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000032/2025-26/RA425> a ns1:LearningResult ;
    ns1:learningResultCode "RA425" ;
    ns1:learningResultDescription "Evaluar el grado de estabilidad de un amplificador realimentado construido con amplificador operacional"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000032/2025-26/RA426> a ns1:LearningResult ;
    ns1:learningResultCode "RA426" ;
    ns1:learningResultDescription "Conocer y aplicar algunos de los métodos más básicos de compensación de circuitos realimentados construidos con amplificadores operacionales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000032/2025-26/RA427> a ns1:LearningResult ;
    ns1:learningResultCode "RA427" ;
    ns1:learningResultDescription "Diseñar filtros activos de paso bajo y alto de cualquier orden"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000032/2025-26/RA428> a ns1:LearningResult ;
    ns1:learningResultCode "RA428" ;
    ns1:learningResultDescription "Calcular la potencia media disipada por un amplificador operacional en un circuito"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000032/2025-26/RA429> a ns1:LearningResult ;
    ns1:learningResultCode "RA429" ;
    ns1:learningResultDescription "Calcular el error de continua, en la salida de un circuito, debido a los errores de offset de los amplificadores utilizados"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000032/2025-26/RA430> a ns1:LearningResult ;
    ns1:learningResultCode "RA430" ;
    ns1:learningResultDescription "Calcular la potencia de ruido electrónico en la salida de un amplificador sencillo construido con amplificador operacional"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000032/2025-26/RA431> a ns1:LearningResult ;
    ns1:learningResultCode "RA431" ;
    ns1:learningResultDescription "Comprender e interpretar las especificaciones y parámetros de un amplificador operacional a partir de las hojas de características del fabricante"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000032/2025-26/RA432> a ns1:LearningResult ;
    ns1:learningResultCode "RA432" ;
    ns1:learningResultDescription "Construir, poner a punto y caracterizar, mediante las medidas oportunas en el laboratorio, diferentes circuitos analógicos de mediana complejidad diseñados con amplificador operacional"@es .

