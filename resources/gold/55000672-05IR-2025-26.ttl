    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/55000672/2025-26/syllabus> ;
    ns1:inpersonHours "30 horas y 30 minutos (39.1%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation "A lo largo de esta asignatura se potenciarán las competencias y capacidades de los Ingenieros de la Organización relacionadas con el diseño de procesos que permitan una producción y consumo de materias primas y energía responsable. En concreto, la asignatura se relaciona con el ODS 9 \"Industria, innovación e infraestructuras\" y el ODS 12 \"Producción y consumo responsables\"."@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "30 horas y 30 minutos"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/55000672/2025-26/eventSchedule> ;
    schema:description "Introducción al campo de la Tecnología Química, en especial en el ámbito de los procesos de la industria química. Se aborda la resolución de balances de materia y energía, y los fundamentos básicos de las principales operaciones de la tecnología química."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/salvador.leon%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/salvador.leon%40upm.es> ;
    schema:name "Tecnología Química"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000672/2025-26/CE21> a ns1:Competency ;
    ns1:competencyCode "CE21" ;
    ns1:competencyDescription "IIntroducción a la ingeniería química. Balances de materia y energía. Propiedades de sólidos y fluídos. Almacenamiento, transporte y modificación de tamaño. Seguridad. Técnicas de separación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000672/2025-26/CG6> a ns1:Competency ;
    ns1:competencyCode "CG6" ;
    ns1:competencyDescription "Poseer habilidades de aprendizaje que permitan continuar estudiando a lo largo de la vida para su adecuado desarrollo profesional"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000672/2025-26/RA116> a ns1:LearningResult ;
    ns1:learningResultCode "RA116" ;
    ns1:learningResultDescription "Comprender y aplicar los métodos de cálculo para el desarrollo del proyecto de un proceso químico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000672/2025-26/RA117> a ns1:LearningResult ;
    ns1:learningResultCode "RA117" ;
    ns1:learningResultDescription "Conocer y comprender los diversos tipos de procesos industriales y sus principales aplicaciones"@es .

