    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/95000347/2025-26/eventSchedule> ;
    schema:description "Esta asignatura amplía los conocimientos adquiridos en la asignatura Imágenes Biomédicas en dos temas de gran actualidad como son la imagen óptica y la imagen por resonancia magnética. Se estudiará la microscopía óptica, sus características, instrumentación y aplicaciones en medicina y biología, considerando desde la microscopía óptica convencional y la microscopía con marcadores fluorescentes hasta las nuevas técnicas de superresolución. También se estudiará la tomografía óptica, tanto coherente como difusa, y la tomografía fotoacústica. La segunda parte de la asignatura ampliará los conocimientos adquiridos en el curso anterior en imagen de resonancia magnética. Se presentarán procedimientos de adquisición rápidos y muy rápidos, así como técnicas para ver espines en movimiento. Se prestará especial atención a la utilidad de estas técnicas en aplicaciones clínicas y, en particular, en dos de las más importantes: la imagen cardiovascular y la neuroimagen."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/andres.santos%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/andres.santos%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/juanjo.gomez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/lucilio.cordero%40upm.es> ;
    schema:name "Imágenes Biomédicas Avanzadas I"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000347/2025-26/CE12> a ns1:Competency ;
    ns1:competencyCode "CE12" ;
    ns1:competencyDescription "Saber buscar, obtener e interpretar la información de las principales bases de datos biomédicas y bibliográficos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000347/2025-26/CE38> a ns1:Competency ;
    ns1:competencyCode "CE38" ;
    ns1:competencyDescription "Conocer los principios y las técnicas de medida de las magnitudes más relevantes en Ingeniería Biomédica."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000347/2025-26/CE42> a ns1:Competency ;
    ns1:competencyCode "CE42" ;
    ns1:competencyDescription "Conocer técnicas de muestreo y procesado de señales e imágenes para diversas aplicaciones en relación con la Ingeniería Biomédica."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000347/2025-26/CE43> a ns1:Competency ;
    ns1:competencyCode "CE43" ;
    ns1:competencyDescription "Capacidad de análisis e interpretación de señales e imágenes biomédicas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000347/2025-26/CG01> a ns1:Competency ;
    ns1:competencyCode "CG01" ;
    ns1:competencyDescription "Desarrollar las habilidades de aprendizaje necesarias para emprender actividades o estudios posteriores de forma autónoma y con confianza."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000347/2025-26/CG06> a ns1:Competency ;
    ns1:competencyCode "CG06" ;
    ns1:competencyDescription "Adoptar una actitud ante los problemas de su competencia que considere que su papel no es exclusivamente aportar soluciones sino, siempre que sea posible, participar además en la propia identificación u definición de dichos problemas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000347/2025-26/CG12> a ns1:Competency ;
    ns1:competencyCode "CG12" ;
    ns1:competencyDescription "Tener capacidad de iniciativa, integración, colaboración y potenciación de la discusión crítica en el ámbito del trabajo en equipo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000347/2025-26/CG15> a ns1:Competency ;
    ns1:competencyCode "CG15" ;
    ns1:competencyDescription "Transmitir la información adquirida, las ideas, los problemas y las soluciones de forma oral y escrita en castellano e inglés."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000347/2025-26/RA105> a ns1:LearningResult ;
    ns1:learningResultCode "RA105" ;
    ns1:learningResultDescription "Comprender las características básicas de la propagación de la luz y su interacción con la materia, así como los fenómenos de fluorescencia"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000347/2025-26/RA106> a ns1:LearningResult ;
    ns1:learningResultCode "RA106" ;
    ns1:learningResultDescription "Comprender el funcionamiento básico del microscopio óptico y valorar sus posibilidades y limitaciones"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000347/2025-26/RA107> a ns1:LearningResult ;
    ns1:learningResultCode "RA107" ;
    ns1:learningResultDescription "Comprender el funcionamiento del microscopio confocal y valorar sus posibilidades y limitaciones"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000347/2025-26/RA108> a ns1:LearningResult ;
    ns1:learningResultCode "RA108" ;
    ns1:learningResultDescription "Conocer el funcionamiento de algunos microscopios avanzados, sus posibilidades y limitaciones"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000347/2025-26/RA109> a ns1:LearningResult ;
    ns1:learningResultCode "RA109" ;
    ns1:learningResultDescription "Conocer y comprender la tomografía óptica coherente (OCT)"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000347/2025-26/RA110> a ns1:LearningResult ;
    ns1:learningResultCode "RA110" ;
    ns1:learningResultDescription "Conocer y comprender los mecanismos de formación de imagen y las técnicas de reconstrucción en resonancia magnética"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000347/2025-26/RA111> a ns1:LearningResult ;
    ns1:learningResultCode "RA111" ;
    ns1:learningResultDescription "Conocer y comprender el funcionamiento de técnicas de adquisición rápida y de obtención de imagen con espines en movimiento en resonancia magnética"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000347/2025-26/RA112> a ns1:LearningResult ;
    ns1:learningResultCode "RA112" ;
    ns1:learningResultDescription "Conocer y comprender las técnicas de obtención de imágenes cardiovasculares y sus aplicaciones"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000347/2025-26/RA113> a ns1:LearningResult ;
    ns1:learningResultCode "RA113" ;
    ns1:learningResultDescription "Conocer y comprender técnicas de obtención de imágenes cerebrales y sus aplicaciones"@es .

