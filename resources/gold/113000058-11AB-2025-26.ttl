    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/113000058/2025-26/eventSchedule> ;
    schema:description """OBJETIVOS: CONOCIMIENTOS Y CAPACIDADES

Ofrecer contenidos teóricos, prácticos y metodológicos para que los alumnos posean una competencia sustantiva, dando respuestas claras y contundentes, a las exigencias de su ámbito de actuación en el entrenamiento y la competición en el deporte de rendimiento.

OBJETIVOS ESPECÍFICOS DEL 1er BLOQUE (Temas 1, 2 y 3)

Conocimiento de las fases de acción de juego.

OBJETIVOS ESPECÍFICOS DEL 2º BLOQUE (Tema 4)

Conocer la técnica, táctica y estrategia del entrenamiento y la competición.
Conocer la base epistemológica de la transferencia del entrenamiento a la competición.
Conocer los medios y métodos de análisis y evaluación de las acciones de juego.



OBJETIVOS ESPECÍFICOS DEL 3er BLOQUE (Temas 5, 6 y 7)

Conocer y diferenciar la fundamentación de la planificación de la técnica, táctica y estrategia
Visión actual de los distintos diseños de la planificación. La planificación actual contemporanea.
Conocer la valoración del resultado de la planificación. Conjugar los indicadores y variables de rendimiento. Aplicación de la tecnología en el conocimiento de los resultados."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/ignacio.refoyo%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/diego.muriarte%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/ignacio.refoyo%40upm.es> ;
    schema:name "Fundamentos de Tactica Deportiva"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000058/2025-26/CB10> a ns1:Competency ;
    ns1:competencyCode "CB10" ;
    ns1:competencyDescription "Que los estudiantes posean las habilidades de aprendizaje que les permitan continuar estudiando de un modo que habrá de ser en gran medida autodirigido o autónomo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000058/2025-26/CB6> a ns1:Competency ;
    ns1:competencyCode "CB6" ;
    ns1:competencyDescription "Poseer y comprender conocimientos que aporten una base u oportunidad de ser originales en el desarrollo y/o aplicación de ideas, a menudo en un contexto de investigación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000058/2025-26/CB7> a ns1:Competency ;
    ns1:competencyCode "CB7" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en entornos nuevos o poco conocidos dentro de contextos más amplios (o multidisciplinares) relacionados con su área de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000058/2025-26/CB8> a ns1:Competency ;
    ns1:competencyCode "CB8" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de integrar conocimientos y enfrentarse a la complejidad de formular juicios a partir de una información que, siendo incompleta o limitada, incluya reflexiones sobre las responsabilidades sociales y éticas vinculadas a la aplicación de sus conocimientos y juicios"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000058/2025-26/CB9> a ns1:Competency ;
    ns1:competencyCode "CB9" ;
    ns1:competencyDescription "Que los estudiantes sepan comunicar sus conclusiones y los conocimientos y razones últimas que las sustentan a públicos especializados y no especializados de un modo claro y sin ambigüedades"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000058/2025-26/CE1> a ns1:Competency ;
    ns1:competencyCode "CE1" ;
    ns1:competencyDescription "Conocimiento de los aspectos más relevantes del conocimiento científico y su relación con las CC de la Actividad Física y del Deporte."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000058/2025-26/CE3> a ns1:Competency ;
    ns1:competencyCode "CE3" ;
    ns1:competencyDescription "Capacidad para la búsqueda, recuperación y análisis de información y documentación científica a través del conocimiento de los sistemas, procesos y recursos de información en Ciencias de la Actividad Física y del Deporte."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000058/2025-26/CE4> a ns1:Competency ;
    ns1:competencyCode "CE4" ;
    ns1:competencyDescription "Conocimiento de los fundamentos estadísticos para el análisis de datos propios del mundo del Deporte."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000058/2025-26/CE6> a ns1:Competency ;
    ns1:competencyCode "CE6" ;
    ns1:competencyDescription "Conocer las diferentes posibilidades de investigación de manera específica en cada uno de los diferentes ámbitos de las Ciencias de la Actividad Física y del Deporte."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000058/2025-26/CE8> a ns1:Competency ;
    ns1:competencyCode "CE8" ;
    ns1:competencyDescription "Ser capaz realizar proyectos de investigación desde el punto de vista metodológico y procedimental."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000058/2025-26/CG2> a ns1:Competency ;
    ns1:competencyCode "CG2" ;
    ns1:competencyDescription "Desarrollo de las habilidades instrumentales básicas para la comunicación oral y escrita en un marco científico, siendo capaces de exponer reflexiones, ideas y conclusiones de manera sintética y ante diversos públicos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000058/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Capacidad para aplicar los conocimientos adquiridos y para resolver problemas en diferentes entornos relacionados con el ámbito de la actividad física y los deportes."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000058/2025-26/RA1> a ns1:LearningResult ;
    ns1:learningResultCode "RA1" ;
    ns1:learningResultDescription "Conocer los aspectos más relevantes del conocimiento científico y las bases de la investigación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000058/2025-26/RA10> a ns1:LearningResult ;
    ns1:learningResultCode "RA10" ;
    ns1:learningResultDescription "Conocimiento de los fundamentos estadísticos para el análisis de datos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000058/2025-26/RA11> a ns1:LearningResult ;
    ns1:learningResultCode "RA11" ;
    ns1:learningResultDescription "Procedimientos de tomas de datos.: diseño de experimentos, muestreos aleatorios. Detección de errores en muestras mal recogidas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000058/2025-26/RA12> a ns1:LearningResult ;
    ns1:learningResultCode "RA12" ;
    ns1:learningResultDescription "Utilización de los modelos estadísticos básicos con ayuda de un programa informático (SPSS o Statgraphics). Interpretación y crítica de resultados estadísticos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000058/2025-26/RA13> a ns1:LearningResult ;
    ns1:learningResultCode "RA13" ;
    ns1:learningResultDescription "Conocer los sistemas de información en ciencias de la actividad física y el deporte y los canales por donde circulan."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000058/2025-26/RA14> a ns1:LearningResult ;
    ns1:learningResultCode "RA14" ;
    ns1:learningResultDescription "Conocer los recursos de información existentes, documentales e institucionales, y los mecanismos de acceso a la información."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000058/2025-26/RA15> a ns1:LearningResult ;
    ns1:learningResultCode "RA15" ;
    ns1:learningResultDescription "Adquirir las técnicas para evaluar adecuadamente los recursos de información."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000058/2025-26/RA16> a ns1:LearningResult ;
    ns1:learningResultCode "RA16" ;
    ns1:learningResultDescription "Desarrollar una metodología sistematizada y un criterio científico a la hora de realizar la búsqueda y recuperación de información con eficientes estrategias de búsqueda en relación al proyecto de investigación elegido."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000058/2025-26/RA17> a ns1:LearningResult ;
    ns1:learningResultCode "RA17" ;
    ns1:learningResultDescription "Ejercitarse en el uso de las herramientas electrónicas y de las posibilidades de los recursos de información ofrecidos por las universidades, y aproximarse a los repositorios como nuevas formas de gestionar, acceder y comunicar la información científica."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000058/2025-26/RA18> a ns1:LearningResult ;
    ns1:learningResultCode "RA18" ;
    ns1:learningResultDescription "Adquirir los conocimientos y mecanismos adecuados para organizar, sistematizar y difundir la información científica."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000058/2025-26/RA19> a ns1:LearningResult ;
    ns1:learningResultCode "RA19" ;
    ns1:learningResultDescription "El objetivo principal del curso es dotar al estudiante de las herramientas y estrategias necesarias para afrontar de forma autónoma y satisfactoria la redacción de artículos de investigación en inglés. Subsidiariamente se pretende también familiarizar al discente con las técnicas básicas de organización de ideas, con los patrones de información más frecuentes en la literatura científicas, con el mejo y utilización de fuentes, la recogida de información y todas aquellas otras microhabilidades que coadyuven en el objetivo principal."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000058/2025-26/RA2> a ns1:LearningResult ;
    ns1:learningResultCode "RA2" ;
    ns1:learningResultDescription "Saber los fundamentos metodológicos de la investigación y sus procesos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000058/2025-26/RA22> a ns1:LearningResult ;
    ns1:learningResultCode "RA22" ;
    ns1:learningResultDescription "Conocer las caracteri?sticas de los diferentes diseños cualitativos y sus peculiaridades metodolo?gicas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000058/2025-26/RA23> a ns1:LearningResult ;
    ns1:learningResultCode "RA23" ;
    ns1:learningResultDescription "Identificar los problemas que son susceptibles de abordarse desde la investigacio?n cualitativa."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000058/2025-26/RA24> a ns1:LearningResult ;
    ns1:learningResultCode "RA24" ;
    ns1:learningResultDescription "Manejar las diferentes técnicas de investigacio?n cualitativa y los métodos que le son afines."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000058/2025-26/RA25> a ns1:LearningResult ;
    ns1:learningResultCode "RA25" ;
    ns1:learningResultDescription "Identificar las áreas y los contextos prioritarios donde aplicar los estudios cualitativos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000058/2025-26/RA26> a ns1:LearningResult ;
    ns1:learningResultCode "RA26" ;
    ns1:learningResultDescription "Demuestren unos conocimientos asociados al postgrado y que les proporcionen una base o una oportunidad para la originalidad en el desarrollo y/o aplicación de ideas en el contexto de la investigación propia de las ciencias de la actividad física y del deporte."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000058/2025-26/RA27> a ns1:LearningResult ;
    ns1:learningResultCode "RA27" ;
    ns1:learningResultDescription "Sean capaces de aplicar sus conocimientos y su comprensión, así como sus habilidades para resolver problemas, en entornos nuevos o no familiares y en contextos amplios (multidisciplinarios) relativos a los diferentes ámbitos de las ciencias de la actividad física y del deporte."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000058/2025-26/RA28> a ns1:LearningResult ;
    ns1:learningResultCode "RA28" ;
    ns1:learningResultDescription "Tengan la capacidad de integrar conocimientos de distintas áreas para poder formular juicios a partir de la reflexión."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000058/2025-26/RA29> a ns1:LearningResult ;
    ns1:learningResultCode "RA29" ;
    ns1:learningResultDescription "Sean capaces de comunicar sus conclusiones, y los conocimientos y el marco conceptual en que se basan, tanto a audiencias expertas como no expertas y de manera clara y sin ambigüedades."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000058/2025-26/RA3> a ns1:LearningResult ;
    ns1:learningResultCode "RA3" ;
    ns1:learningResultDescription "Aprender las técnicas para organizar, buscar y recuperar información científica y técnica."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000058/2025-26/RA30> a ns1:LearningResult ;
    ns1:learningResultCode "RA30" ;
    ns1:learningResultDescription "Haber desarrollado habilidades de aprendizaje que les permitan continuar los estudios de manera ampliamente autodirigida o autónoma."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000058/2025-26/RA32> a ns1:LearningResult ;
    ns1:learningResultCode "RA32" ;
    ns1:learningResultDescription "Desarrollo de las habilidades instrumentales básicas para la comunicación oral y escrita en un marco científico, siendo capaces de exponer reflexiones, ideas y conclusiones de manera sintética y ante diversos públicos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000058/2025-26/RA33> a ns1:LearningResult ;
    ns1:learningResultCode "RA33" ;
    ns1:learningResultDescription "Capacidad para aplicar los conocimientos adquiridos y para resolver problemas en diferentes entornos relacionados con las Ciencias Sociales que participan en la actividad física y deportiva."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000058/2025-26/RA34> a ns1:LearningResult ;
    ns1:learningResultCode "RA34" ;
    ns1:learningResultDescription "Capacidad para integrar conocimientos y enfrentarse a la complejidad de formular juicios a partir de información que, siendo compleja o limitada, incluya reflexiones sobre las responsabilidades sociales y éticas vinculadas al ámbito de la actividad física y los deportes."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000058/2025-26/RA35> a ns1:LearningResult ;
    ns1:learningResultCode "RA35" ;
    ns1:learningResultDescription "Desarrollo de las habilidades humanas necesarias para el trabajo en equipo y de ese modo asumir el compromiso de la investigación científica con valores humanos que favorezcan la sana convivencia."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000058/2025-26/RA36> a ns1:LearningResult ;
    ns1:learningResultCode "RA36" ;
    ns1:learningResultDescription "Tengan la capacidad de integrar conocimientos de distintas áreas y poder formular juicios a partir de la aportación de expertos externos de reconocido prestigio en un ámbito determinado de las ciencias de la actividad física y del deporte."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000058/2025-26/RA37> a ns1:LearningResult ;
    ns1:learningResultCode "RA37" ;
    ns1:learningResultDescription "Sean capaces de realizar proyectos de investigación a partir de una correcta metodología y a través de los procedimientos más eficientes que permitan conseguir los objetivos propuestos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000058/2025-26/RA38> a ns1:LearningResult ;
    ns1:learningResultCode "RA38" ;
    ns1:learningResultDescription "Sean capaces de recabar la información mediante la revisión bibliográfica de diversas fuentes, necesaria para contextualizar los proyectos de investigación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000058/2025-26/RA39> a ns1:LearningResult ;
    ns1:learningResultCode "RA39" ;
    ns1:learningResultDescription "Sean capaces de comunicar sus conclusiones, y los conocimientos y el marco conceptual en que se basan tanto a audiencias expertas como no expertas y de manera clara y sin ambigüedades."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000058/2025-26/RA4> a ns1:LearningResult ;
    ns1:learningResultCode "RA4" ;
    ns1:learningResultDescription "Dominar las bases conceptuales y técnicas para la realización de una tesis doctoral."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000058/2025-26/RA40> a ns1:LearningResult ;
    ns1:learningResultCode "RA40" ;
    ns1:learningResultDescription "Conocer la importancia del Análisis notacional como procedimiento de investigación en CC del Deporte mediante diferentes métodos y procedimientos de análisis de datos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000058/2025-26/RA41> a ns1:LearningResult ;
    ns1:learningResultCode "RA41" ;
    ns1:learningResultDescription "Conocer las líneas de investigación dentro del Análisis notacional en el ámbito escolar, deportivo y profesional."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000058/2025-26/RA42> a ns1:LearningResult ;
    ns1:learningResultCode "RA42" ;
    ns1:learningResultDescription "Desarrollar un proyecto de investigación mediante el análisis y estudio sobre el Análisis notacional en los juegos deportivos tratados en la parte teórica."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000058/2025-26/RA43> a ns1:LearningResult ;
    ns1:learningResultCode "RA43" ;
    ns1:learningResultDescription "Valorar la importancia del Análisis notacional como proceso de toma de datos, reflexión e implementación de la práctica (docente, deportiva y / o profesional)."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000058/2025-26/RA50> a ns1:LearningResult ;
    ns1:learningResultCode "RA50" ;
    ns1:learningResultDescription "Dominar el uso del paquete estadístico SPSS"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000058/2025-26/RA51> a ns1:LearningResult ;
    ns1:learningResultCode "RA51" ;
    ns1:learningResultDescription "Dominar la redacción del apartado de resultados en una publicación periódica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000058/2025-26/RA60> a ns1:LearningResult ;
    ns1:learningResultCode "RA60" ;
    ns1:learningResultDescription "Ser capaz de aplicar una tecnología existente o integrar varias de ellas para la resolución de un problema dentro del ámbito de la actividad física y del deporte"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000058/2025-26/RA68> a ns1:LearningResult ;
    ns1:learningResultCode "RA68" ;
    ns1:learningResultDescription "Fomentar el estudio y análisis de las tomas de decisiones de los diferentes deportes colectivos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000058/2025-26/RA69> a ns1:LearningResult ;
    ns1:learningResultCode "RA69" ;
    ns1:learningResultDescription "Ser capaz de Indagar en las claves que utilizan los deportistas para tomar una decisión u otra durante la competición."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000058/2025-26/RA7> a ns1:LearningResult ;
    ns1:learningResultCode "RA7" ;
    ns1:learningResultDescription "Descripción de las diferentes etapas del proceso de investigación científica."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000058/2025-26/RA70> a ns1:LearningResult ;
    ns1:learningResultCode "RA70" ;
    ns1:learningResultDescription "Fomentar las posibilidades para desarrollar proyectos de investigación relacionados directamente con las tomas de decisión en los deportes colectivos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000058/2025-26/RA8> a ns1:LearningResult ;
    ns1:learningResultCode "RA8" ;
