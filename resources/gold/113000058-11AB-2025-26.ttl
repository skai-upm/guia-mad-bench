<https://guia-kg.skai.etsisi.upm.es/resource/113000058/2025-26/RA9> a ns1:LearningResult ;
    ns1:learningResultCode "RA9" ;
    ns1:learningResultDescription "Elaboración de proyectos de investigación."@es .

