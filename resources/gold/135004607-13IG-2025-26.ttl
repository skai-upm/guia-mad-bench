<https://guia-kg.skai.etsisi.upm.es/resource/135004607/2025-26/RA127> a ns1:LearningResult ;
    ns1:learningResultCode "RA127" ;
    ns1:learningResultDescription "Que los estudiantes puedan transmitir información, ideas, problemas y soluciones sobre los procesos de fabricación de la celulosa y el papel"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004607/2025-26/RA128> a ns1:LearningResult ;
