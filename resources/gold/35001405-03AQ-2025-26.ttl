        <https://guia-kg.skai.etsisi.upm.es/resource/lj.sanchez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/ma.benito%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/mar.barbero%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/soledad.garcia%40upm.es> ;
    schema:name "Construccion 1"@es .

