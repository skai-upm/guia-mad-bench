<https://guia-kg.skai.etsisi.upm.es/resource/23000136/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/23000136/2025-26/CE12>,
        <https://guia-kg.skai.etsisi.upm.es/resource/23000136/2025-26/CG1>,
