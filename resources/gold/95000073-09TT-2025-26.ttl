    ns1:learningResultCode "RA78" ;
    ns1:learningResultDescription "Capacidad de construir, explotar y gestionar servicios y aplicaciones de captación, tratamiento analógico y digital, codificación, transporte, representación, procesado, almacenamiento, reproducción, gestión y presentación de servicios audiovisuales e información multimedia."@es .

