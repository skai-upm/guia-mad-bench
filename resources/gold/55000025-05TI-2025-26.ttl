    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/55000025/2025-26/eventSchedule> ;
    schema:description "La asignatura \"Fundamentos de Electrónica\" aborda el estudio de la electrónica desde sus bases, hasta poder acometer el diseño de un sistema sencillo, con los medios y herramientas que se aprenden en la asignatura. Se trata de la primera asignatura de Electrónica en GITI, disciplina que muchos graduados no volverán a estudiar y otros profundizarán en ella en las asignaturas de especialidad del curso siguiente. La asignatura está dividida en tres bloques temáticos dedicados a la electrónica digital, microprocesadores y electrónica analógica. Se realizan tres prácticas de laboratorio obligatorias y un conjunto pruebas de evaluación progresiva, que ayudan a ir mejor preparado al examen final, que es único. Además, la evaluación progresiva permite complementar la nota del examen, tal y como se explica en el apartado de \"actividades y criterios de evaluación\" de esta guía."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/miroslav.vasic%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/a.delgado%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/alfonso.rodriguezm%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/ja.cobos%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/jaime.senors%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/jorge.portilla%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/miroslav.vasic%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/regina.ramos%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/roberto.prieto%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/yago.torroja%40upm.es> ;
    schema:name "Fundamentos de Electronica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000025/2025-26/CE12> a ns1:Competency ;
    ns1:competencyCode "CE12" ;
    ns1:competencyDescription "Conocimientos de los fundamentos de la electrónica."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000025/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Conocer y aplicar conocimientos de ciencias y tecnologías básicas a la práctica de la Ingeniería Industrial."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000025/2025-26/CG10> a ns1:Competency ;
    ns1:competencyCode "CG10" ;
    ns1:competencyDescription "Capacidad para generar nuevas ideas (Creatividad)."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000025/2025-26/CG2> a ns1:Competency ;
    ns1:competencyCode "CG2" ;
    ns1:competencyDescription "Poseer capacidad para diseñar, desarrollar, implementar, gestionar y mejorar productos, sistemas y procesos en los distintos ámbitos industriales, usando técnicas analíticas, computacionales o experimentales apropiadas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000025/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Aplicar los conocimientos adquiridos para identificar, formular y resolver problemas dentro de contextos amplios y multidisciplinarios, siendo capaces de integrar conocimientos, trabajando en equipos multidisciplinares."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000025/2025-26/CG5> a ns1:Competency ;
    ns1:competencyCode "CG5" ;
    ns1:competencyDescription "Saber comunicar los conocimientos y conclusiones, de forma oral, escrita y gráfica, a públicos especializados y no especializados de un modo claro y sin ambigüedades."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000025/2025-26/CG6> a ns1:Competency ;
    ns1:competencyCode "CG6" ;
    ns1:competencyDescription "Poseer habilidades de aprendizaje que permitan continuar estudiando a lo largo de la vida para su adecuado desarrollo profesional."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000025/2025-26/CG7> a ns1:Competency ;
    ns1:competencyCode "CG7" ;
    ns1:competencyDescription "Incorporar nuevas tecnologías y herramientas de la Ingeniería Industrial en sus actividades profesionales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000025/2025-26/RA72> a ns1:LearningResult ;
    ns1:learningResultCode "RA72" ;
    ns1:learningResultDescription "Capacidad para analizar circuitos digitales sencillos formados por puertas lógicas, y de interpretar su funcionamiento mediante diagramas de estado."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000025/2025-26/RA73> a ns1:LearningResult ;
    ns1:learningResultCode "RA73" ;
    ns1:learningResultDescription "Capacidad para comprender los fundamentos de un sistema microprocesador y de la programación en lenguaje ensamblador."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000025/2025-26/RA74> a ns1:LearningResult ;
    ns1:learningResultCode "RA74" ;
    ns1:learningResultDescription "Capacidad de comprender las características de los circuitos analógicos y resolver circuitos sencillos de forma analítica, en el dominio del tiempo y de la frecuencia."@es .

