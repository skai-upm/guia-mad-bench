    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/55000057/2025-26/eventSchedule> ;
    schema:description "La asignatura se ocupa del estudio de métodos numéricos elementales y de su aplicación a la resolución aproximada de problemas matemáticos que se presentan en la Ingeniería Industrial. El estudio teórico de los temas se complementa con el estudio práctico usando el ordenador, para lo que se utilizará el programa Matlab como herramienta fundamental."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/pablo.gomez.mourelo%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/pablo.gomez.mourelo%40upm.es> ;
    schema:name "Matemáticas de la Especialidad Química y Medio Ambiente"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000057/2025-26/CE1> a ns1:Competency ;
    ns1:competencyCode "CE1" ;
    ns1:competencyDescription "Capacidad para la resolución de los problemas matemáticos que puedan plantearse en la ingeniería. Aptitud para aplicar los conocimientos sobre: álgebra lineal; geometría; geometría diferencial; cálculo diferencial e integral; ecuaciones diferenciales ordinarias y en derivadas parciales; métodos numéricos; algorítmica numérica; optimización"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000057/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Conocer y aplicar conocimientos de ciencias y tecnologías básicas a la práctica de la Ingeniería Industrial."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000057/2025-26/CG10> a ns1:Competency ;
    ns1:competencyCode "CG10" ;
    ns1:competencyDescription "Capacidad para generar nuevas ideas (Creatividad)."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000057/2025-26/CG2> a ns1:Competency ;
    ns1:competencyCode "CG2" ;
    ns1:competencyDescription "Poseer capacidad para diseñar, desarrollar, implementar, gestionar y mejorar productos, sistemas y procesos en los distintos ámbitos industriales, usando técnicas analíticas, computacionales o experimentales apropiadas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000057/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Aplicar los conocimientos adquiridos para identificar, formular y resolver problemas dentro de contextos amplios y multidisciplinarios, siendo capaces de integrar conocimientos, trabajando en equipos multidisciplinares."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000057/2025-26/CG5> a ns1:Competency ;
    ns1:competencyCode "CG5" ;
    ns1:competencyDescription "Saber comunicar los conocimientos y conclusiones, de forma oral, escrita y gráfica, a públicos especializados y no especializados de un modo claro y sin ambigüedades."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000057/2025-26/CG6> a ns1:Competency ;
    ns1:competencyCode "CG6" ;
    ns1:competencyDescription "Poseer habilidades de aprendizaje que permitan continuar estudiando a lo largo de la vida para su adecuado desarrollo profesional."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000057/2025-26/CG7> a ns1:Competency ;
    ns1:competencyCode "CG7" ;
    ns1:competencyDescription "Incorporar nuevas tecnologías y herramientas de la Ingeniería Industrial en sus actividades profesionales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000057/2025-26/RA256> a ns1:LearningResult ;
    ns1:learningResultCode "RA256" ;
    ns1:learningResultDescription "Plantear en términos matemáticos problemas físicos y de ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000057/2025-26/RA257> a ns1:LearningResult ;
    ns1:learningResultCode "RA257" ;
    ns1:learningResultDescription "Resolver numéricamente (de forma aproximada) problemas cuya solución analítica es imposible o demasiado costosa. Evaluar el alcance de las aproximaciones."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000057/2025-26/RA258> a ns1:LearningResult ;
    ns1:learningResultCode "RA258" ;
    ns1:learningResultDescription "Interpretar en términos físicos los resultados obtenidos y ser capaz de extraer consecuencias y de realizar predicciones en base a esos resultados."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000057/2025-26/RA259> a ns1:LearningResult ;
    ns1:learningResultCode "RA259" ;
    ns1:learningResultDescription "Desarrollar una habilidad razonable para manejar Matlab que es una herramienta informática muy útil en todo este tipo de problemas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000057/2025-26/RA605> a ns1:LearningResult ;
    ns1:learningResultCode "RA605" ;
    ns1:learningResultDescription "RA134"@es .

