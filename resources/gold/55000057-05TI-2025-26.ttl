<https://guia-kg.skai.etsisi.upm.es/resource/55000057/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Aritmética de los ordenadores."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000057/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Representación de números en máquinas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000057/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "3.3. Interpolación a trozos por elementos finitos. Partición del intervalo. El espacio de elementos finitos asociado a una partición. Bases elementales y globales. Elemento de referencia. Representación global del polinomio de interpolación a trozos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000057/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "3.4. Representación global del polinomio de interpolación a trozos. Fórmula de error del polinomio de interpolación a trozos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000057/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "4. Integración numérica."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000057/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "4.1. Reglas de cuadratura de Newton-Cotes: regla del trapecio y regla de Simpson. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000057/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "4.2. Reglas de cuadratura de Gauss-Legendre. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000057/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "4.3. Cálculo de error de las reglas de cuadratura. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000057/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "5. Resolución aproximada de ecuaciones diferenciales ordinarias"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000057/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "5.1. Método de Euler. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000057/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "5.2. Métodos de Runge-Kutta. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000057/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "5.3. Métodos multipaso. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000057/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Errores y Condicionamiento. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000057/2025-26/syllabus/20> a ns1:SyllabusItem ;
    ns1:itemIndex 20 ;
    ns1:syllabusDescription "6. Ecuaciones no lineales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000057/2025-26/syllabus/21> a ns1:SyllabusItem ;
    ns1:itemIndex 21 ;
    ns1:syllabusDescription "6.1. Métodos de Bisección, secante, Régula Falsi. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000057/2025-26/syllabus/22> a ns1:SyllabusItem ;
    ns1:itemIndex 22 ;
    ns1:syllabusDescription "6.2. Método de iteración de punto fijo. Método de Newton-Raphson. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000057/2025-26/syllabus/23> a ns1:SyllabusItem ;
    ns1:itemIndex 23 ;
    ns1:syllabusDescription "7. Ecuaciones en Derivadas Parciales lineales de segundo orden."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000057/2025-26/syllabus/24> a ns1:SyllabusItem ;
    ns1:itemIndex 24 ;
    ns1:syllabusDescription "7.1. Problemas elípticos, parabólicos e hiperbólicos: algunos ejemplos en física e ingeniería. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000057/2025-26/syllabus/25> a ns1:SyllabusItem ;
    ns1:itemIndex 25 ;
    ns1:syllabusDescription "7.2. Problemas elípticos. Solución aproximada mediante el uso de métodos numéricos. Estudio de estabilidad Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000057/2025-26/syllabus/26> a ns1:SyllabusItem ;
    ns1:itemIndex 26 ;
    ns1:syllabusDescription "7.3. El problema parabólico modelo: la ecuación del calor. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000057/2025-26/syllabus/27> a ns1:SyllabusItem ;
    ns1:itemIndex 27 ;
    ns1:syllabusDescription "7.4. Resolución numérica de la ecuación del calor. Solución aproximada mediante el uso de métodos numéricos. Estudio de su estabilidad Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000057/2025-26/syllabus/28> a ns1:SyllabusItem ;
    ns1:itemIndex 28 ;
    ns1:syllabusDescription "8. Introducción a la optimización"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000057/2025-26/syllabus/29> a ns1:SyllabusItem ;
    ns1:itemIndex 29 ;
    ns1:syllabusDescription "8.1. Optimización no lineal sin restricciones. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000057/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "2. Álgebra lineal numérica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000057/2025-26/syllabus/30> a ns1:SyllabusItem ;
    ns1:itemIndex 30 ;
    ns1:syllabusDescription "8.2. Optimización no lineal con restricciones. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000057/2025-26/syllabus/31> a ns1:SyllabusItem ;
    ns1:itemIndex 31 ;
    ns1:syllabusDescription "8.3. El caso cuadrático: mínimos cuadrados. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000057/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "2.1. Breve repaso de métodos para resolver sistemas de ecuaciones de forma exacta. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000057/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "2.2. Factorización LU. Factorización de Cholesky. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000057/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "2.3. Métodos iterativos para la resolución de sistemas de ecuaciones lineales. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000057/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "3. Interpolación en un intervalo de la recta real."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000057/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "3.1. El polinomio interpolador de Lagrange. Método matricial. Base de Lagrange por polinomios interpolantes. Fórmula de Newton. Diferencias divididas. Fórmula de error del polinomio interpolador de Lagrange. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000057/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "3.2. Splines Sin subniveles"@es .

