    ns1:totalHours "58 horas y 15 minutos"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/595024234/2025-26/eventSchedule> ;
    schema:description "El objetivo general de la asignatura es analizar la estructura de red, la arquitectura de protocolos y las características y servicios de las redes móviles, realizando un estudio cronológico de las redes con tecnologías 2G (GSM/GPRS/EDGE), 3G (UMTS/HSDPA/HSUPA), 4G (LTE/LTE-Advanced) y 5G (NSA y SA)."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/pedro.castillejo%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/anabelen.garcia%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/ivan.pau%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/mario.sanemeterio%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/pedro.castillejo%40upm.es> ;
    schema:name "Redes de Comunicaciones Móviles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595024234/2025-26/CE%20TL01> a ns1:Competency ;
    ns1:competencyCode "CE TL01" ;
    ns1:competencyDescription "Capacidad de construir, explotar y gestionar las redes, servicios, procesos y aplicaciones de telecomunicaciones, entendidas éstas como sistemas de captación, transporte, representación, procesado, almacenamiento, gestión y presentación de información multimedia, desde el punto de vista de los servicios telemáticos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595024234/2025-26/CE%20TL02> a ns1:Competency ;
    ns1:competencyCode "CE TL02" ;
    ns1:competencyDescription "Capacidad para aplicar las técnicas en que se basan las redes, servicios y aplicaciones telemáticas, tales como sistemas de gestión, señalización y conmutación, encaminamiento y enrutamiento, seguridad (protocolos criptográficos, tunelado, cortafuegos, mecanismos de cobro, de autenticación y de protección de contenidos), ingeniería de tráfico (teoría de grafos, teoría de colas y teletráfico) tarificación y fiabilidad y calidad de servicio, tanto en entornos fijos, móviles, personales, locales o a gran distancia, con diferentes anchos de banda, incluyendo telefonía y datos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595024234/2025-26/CE%20TL04> a ns1:Competency ;
    ns1:competencyCode "CE TL04" ;
    ns1:competencyDescription "Capacidad de describir, programar, validar y optimizar protocolos e interfaces de comunicación en los diferentes niveles de una arquitectura de redes."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595024234/2025-26/CE%20TL05> a ns1:Competency ;
    ns1:competencyCode "CE TL05" ;
    ns1:competencyDescription "Capacidad de seguir el progreso tecnológico de transmisión, conmutación y proceso para mejorar las redes y servicios Telemáticos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595024234/2025-26/CE%20TL08> a ns1:Competency ;
    ns1:competencyCode "CE TL08" ;
    ns1:competencyDescription "Capacidad para realizar proyectos en el ámbito de las tecnologías específicas de la Ingeniería de Telecomunicación, de naturaleza profesional en que se sinteticen e integren las competencias adquiridas en las enseñanzas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595024234/2025-26/CG%2002> a ns1:Competency ;
    ns1:competencyCode "CG 02" ;
    ns1:competencyDescription "Capacidad de búsqueda y selección de información, de razonamiento crítico y de elaboración y defensa de argumentos dentro del área."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595024234/2025-26/CG%2003> a ns1:Competency ;
    ns1:competencyCode "CG 03" ;
    ns1:competencyDescription "Capacidad para expresarse correctamente de forma oral y escrita y transmitir información mediante documentos y exposiciones en público."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595024234/2025-26/CG%2004> a ns1:Competency ;
    ns1:competencyCode "CG 04" ;
    ns1:competencyDescription "Capacidad de abstracción, de análisis y de síntesis y de resolución de problemas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595024234/2025-26/CG%2010> a ns1:Competency ;
    ns1:competencyCode "CG 10" ;
    ns1:competencyDescription "Capacidad para manejar especificaciones, reglamentos y normativas y la aplicación de las mismas en el desarrollo de la profesión."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595024234/2025-26/CG%2011> a ns1:Competency ;
    ns1:competencyCode "CG 11" ;
    ns1:competencyDescription "Habilidades para la utilización de las Tecnologías de la Información y las Comunicaciones."@es .

