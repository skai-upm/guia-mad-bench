    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation "En la asignatura de Redacción Cinetífica, se busca resaltar la contribución de las actividades de investigación al cumplimiento de los ODS establecidos por Naciones Unidas. Una manera muy directa de contribuir es ayudando a investigar en temas que ayuden al cumplimiento de cada uno de ellos."@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "49 horas y 20 minutos"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/23000149/2025-26/eventSchedule> ;
    schema:description "El principal objetivo de esta asignatura es informar a los alumnos acerca de los requerimientos competenciales y conceptuales que requiere la tarea de redacción de una tesis doctoral (así como su defensa pública) y la elaboración de artículos científicos en revistas internacionales de impacto. Se trata de desarrollar las competencias necesarias para esta labor."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/jm.diazpuente%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/jm.diazpuente%40upm.es> ;
    schema:name "Redaccion Cientifica: Elaboracion de la Tesis y Articulos Cientificos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000149/2025-26/CE41> a ns1:Competency ;
    ns1:competencyCode "CE41" ;
    ns1:competencyDescription "Metodologías de investigación científica basadas en la gestión relacional de la información, razonamiento lógico y análisis crítico de documentos, comprensión global y contextual de situaciones complejas y análisis multicriterio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000149/2025-26/CE43> a ns1:Competency ;
    ns1:competencyCode "CE43" ;
    ns1:competencyDescription "Estilos de redacción gramática y sintaxis propios de documentos científicos, técnicos y divulgativos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000149/2025-26/CE44> a ns1:Competency ;
    ns1:competencyCode "CE44" ;
    ns1:competencyDescription "Conocimiento de los procedimientos administrativos de la universidad para la tramitación de la tesis doctoral."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000149/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Habilidades de comunicación escrita y oral: Concluir aportaciones por escrito, desarrollando la capacidad de síntesis y presentación de las ideas propias en un grupo de trabajo y en exposición pública."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000149/2025-26/CG10> a ns1:Competency ;
    ns1:competencyCode "CG10" ;
    ns1:competencyDescription "Valores humanos positivos para la investigación: Respeto a los derechos humanos fundamentales; los principios de igualdad de oportunidades, accesibilidad universal y no discriminación; y los valores propios de una cultura de paz y de valores democráticos. Compromiso con estos derechos, principios y valores, motivación, actitud positiva y entusiasta; ética, integridad y honestidad investigadora"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000149/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Fortalecer conocimiento oral y escrito de idioma inglés"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000149/2025-26/CG4> a ns1:Competency ;
    ns1:competencyCode "CG4" ;
    ns1:competencyDescription "Capacidad crítica para el análisis, síntesis y aprendizaje mediante el intercambio de opiniones, presentando argumentos sólidos y estructurados"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000149/2025-26/CG5> a ns1:Competency ;
    ns1:competencyCode "CG5" ;
    ns1:competencyDescription "Búsqueda bibliográfica y análisis de documentación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000149/2025-26/CG6> a ns1:Competency ;
    ns1:competencyCode "CG6" ;
    ns1:competencyDescription "Capacidad de gestión de la información procedente de diversas fuentes y de su análisis y síntesis aplicándola a la resolución de problemas complejos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000149/2025-26/CG7> a ns1:Competency ;
    ns1:competencyCode "CG7" ;
    ns1:competencyDescription "Capacidad de trabajo en equipo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000149/2025-26/CG8> a ns1:Competency ;
    ns1:competencyCode "CG8" ;
    ns1:competencyDescription "Capacidad de observación, generación de hipótesis y planteamiento de problemas experimentales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000149/2025-26/RA19> a ns1:LearningResult ;
    ns1:learningResultCode "RA19" ;
    ns1:learningResultDescription "Aprender a redactar un artículo científico desde su estructura y redacción hasta la elaboración final que mejore su calidad."@es .

