    ns1:inpersonHours "56 horas y 15 minutos (48.1%)"@es ;
    ns1:numberOfCredits 4.5 ;
    ns1:otherInformation """La asignatura se relaciona con el ODS6 (Agua limpia y saneamiento), el ODS9 (Industria. Innovación e Infraestructura) y el ODS13 (Acción por el clima)

Los casos reales estudiados en los retos se plantean en el marco de la Alianza EELISA y otorgarán Credenciales EELISA."""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "102 horas y 15 minutos"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/43000392/2025-26/eventSchedule> ;
    schema:description "La asignatura de Estructuras de Tierra se centra en los procedimientos de diseño, construcción y control de presas de materiales sueltos y terraplenes de obras lineales, pero también de presas de estériles mineros y de rellenos portuarios. Se pone especial atención a los aspectos conceptuales fundamentales para el adecuado proyecto, diseño y ejecución de estas estructuras, pero también se explican los procedimientos de cálculo más habituales y los marcos normativos más relevantes. En esta asignatura se utilizan metodologías de aprendizaje basado en retos de tal modo que los alumnos han de estudiar problemas reales en presas de tierra mediante métodos numéricos de equilibrio límite y de elementos finitos."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/ignacio.gtejada%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/antonio.soriano.martinez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/enrique.asanza%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/ignacio.gtejada%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/rubenangel.galindo%40upm.es> ;
    schema:name "Estructuras de Tierra"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000392/2025-26/CE1> a ns1:Competency ;
    ns1:competencyCode "CE1" ;
    ns1:competencyDescription "Capacitación científico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000392/2025-26/CE12> a ns1:Competency ;
    ns1:competencyCode "CE12" ;
    ns1:competencyDescription "Capacidad para planificar, diseñar y gestionar infraestructuras, así como su mantenimiento, conservación y explotación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000392/2025-26/CE13> a ns1:Competency ;
    ns1:competencyCode "CE13" ;
    ns1:competencyDescription "Capacidad para planificar, realizar estudios y diseñar captaciones de aguas superficiales o subterráneas (Presas, conducciones, bombeos)."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000392/2025-26/CE18> a ns1:Competency ;
    ns1:competencyCode "CE18" ;
    ns1:competencyDescription "Conocimientos adecuados de los aspectos científicos y tecnológicos de métodos matemáticos, analíticos y numéricos de la ingeniería, mecánica de fluidos, mecánica de medios continuos, cálculo de estructuras, ingeniería del terreno, ingeniería marítima, obras y aprovechamientos hidráulicos y obras lineales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000392/2025-26/CE21> a ns1:Competency ;
    ns1:competencyCode "CE21" ;
    ns1:competencyDescription "Aplicación de los conocimientos de la mecánica de suelos y de las rocas para el desarrollo del estudio, proyecto, construcción y explotación de cimentaciones, desmontes, terraplenes, túneles y demás construcciones realizadas sobre o a través del terreno, cualquiera que sea la naturaleza y el estado de éste, y cualquiera que sea la finalidad de la obra de que se trate."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000392/2025-26/CE22> a ns1:Competency ;
    ns1:competencyCode "CE22" ;
    ns1:competencyDescription "Conocimiento y capacidad para el análisis estructural mediante la aplicación de los métodos y programas de diseño y cálculo avanzado de estructuras, a partir del conocimiento y comprensión de las solicitaciones y su aplicación a las tipologías estructurales de la ingeniería civil. Capacidad para realizar evaluaciones de integridad estructural."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000392/2025-26/CE24> a ns1:Competency ;
    ns1:competencyCode "CE24" ;
    ns1:competencyDescription "Capacidad para proyectar, dimensionar, construir y mantener obras hidráulicas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000392/2025-26/CGP05> a ns1:Competency ;
    ns1:competencyCode "CGP05" ;
    ns1:competencyDescription "Conocimiento de la profesión de Ingeniero de Caminos, Canales y Puertos y de las actividades que se pueden realizar en el ámbito de la ingeniería civil. Incorpora las competencias CB6, CB7 y CB8."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000392/2025-26/CGP13> a ns1:Competency ;
    ns1:competencyCode "CGP13" ;
    ns1:competencyDescription "Capacidad para planificar, realizar estudios y diseñar captaciones de aguas superficiales o subterráneas (Presas, conducciones, bombeos). Incorpora las competencias CB6, CB7 y CB8."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000392/2025-26/RA1> a ns1:LearningResult ;
    ns1:learningResultCode "RA1" ;
    ns1:learningResultDescription "Formula y resuelve problemas matemáticos y numéricos avanzados de ingeniería civil, identificando sus diferentes componentes científicos y técnicos y seleccionando y acoplando con eficacia los métodos de resolución."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000392/2025-26/RA128> a ns1:LearningResult ;
    ns1:learningResultCode "RA128" ;
    ns1:learningResultDescription "Modela y dimensiona elementos continuos y estructurales sometidos a acciones estáticas mediante el método numérico de los Elementos Finitos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000392/2025-26/RA129> a ns1:LearningResult ;
    ns1:learningResultCode "RA129" ;
    ns1:learningResultDescription "Modela y dimensiona elementos continuos y estructurales sometidos a acciones dinámicas mediante métodos analíticos y numéricos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000392/2025-26/RA155> a ns1:LearningResult ;
    ns1:learningResultCode "RA155" ;
    ns1:learningResultDescription "Diseña y proyecta y dirige la construcción de infraestructuras hidráulicas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000392/2025-26/RA175> a ns1:LearningResult ;
    ns1:learningResultCode "RA175" ;
    ns1:learningResultDescription "Planifica, realiza estudios y diseña captaciones de aguas superficiales o subterráneas (Presas, conducciones, bombeos)."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000392/2025-26/RA21> a ns1:LearningResult ;
    ns1:learningResultCode "RA21" ;
    ns1:learningResultDescription "Aplica y evalúa modelos avanzados de ingeniería estructural y geotécnica en proyecto y ejecución de obras."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000392/2025-26/RA210> a ns1:LearningResult ;
    ns1:learningResultCode "RA210" ;
    ns1:learningResultDescription "Conoce y aplica herramientas de cálculo numérico a problemas de ingeniería civil."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000392/2025-26/RA211> a ns1:LearningResult ;
    ns1:learningResultCode "RA211" ;
    ns1:learningResultDescription "Modeliza y predice el comportamiento de problemas en ingeniería civil."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000392/2025-26/RA22> a ns1:LearningResult ;
    ns1:learningResultCode "RA22" ;
    ns1:learningResultDescription "Aplica y evalúa técnicas avanzadas para la construcción y control de obras de ingeniería estructural y geotécnica."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000392/2025-26/RA23> a ns1:LearningResult ;
    ns1:learningResultCode "RA23" ;
    ns1:learningResultDescription "Aplica y evalúa modelos avanzados de comportamiento mecánico y medioambiental de suelos y materiales de construcción."@es .

