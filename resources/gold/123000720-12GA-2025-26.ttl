    schema:courseCode 123000720 ;
    schema:hasCourseInstance <https://guia-kg.skai.etsisi.upm.es/resource/123000720/2025-26> ;
    schema:name "Geospatial Valuations For Sustainable Urban Develpment"@en,
        "Técnicas Geoespaciales para un Desarrollo Urbano Sostenible"@es ;
    schema:numberOfCredits 5.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/123000720/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/123000720/2025-26/CB10>,
        <https://guia-kg.skai.etsisi.upm.es/resource/123000720/2025-26/CG1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/123000720/2025-26/CT4> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/123000720/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/123000720/2025-26/didactic_resource/2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/123000720/2025-26/didactic_resource/3>,
        <https://guia-kg.skai.etsisi.upm.es/resource/123000720/2025-26/didactic_resource/4>,
        <https://guia-kg.skai.etsisi.upm.es/resource/123000720/2025-26/didactic_resource/5>,
        <https://guia-kg.skai.etsisi.upm.es/resource/123000720/2025-26/didactic_resource/6>,
        <https://guia-kg.skai.etsisi.upm.es/resource/123000720/2025-26/didactic_resource/7> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/123000720/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/123000720/2025-26/RA14> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/123000720/2025-26/syllabus> ;
    ns1:inpersonHours "95 horas y 20 minutos (70.6%)"@es ;
    ns1:numberOfCredits 5.0 ;
    ns1:otherInformation "La asignatura tiene un enfoque práctico y aplicado, orientado a resolver problemas reales del entorno urbano mediante el uso combinado de herramientas estadísticas y geoespaciales. Se valorará la participación activa en clase y el trabajo con datos reales, fomentando el análisis crítico y la toma de decisiones informadas para un desarrollo urbano sostenible."@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "101 horas y 20 minutos"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/123000720/2025-26/eventSchedule> ;
    schema:description "Esta asignatura se centra en conocer los métodos y las técnicas adecuadas para abordar problemas ambientales y territoriales complejos. Realizar diagnósticos y formular decisiones de cara al desarrollo sostenible y utilizar para su aplicación los sistemas de información geográfica y análisis estadístico de geodatos."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/mariadelcarmen.morillo%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/cesar.garciaa%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/mariadelcarmen.morillo%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/sandra.mcuevas%40upm.es> ;
    schema:name "Técnicas Geoespaciales para un Desarrollo Urbano Sostenible"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/123000720/2025-26/CB10> a ns1:Competency ;
    ns1:competencyCode "CB10" ;
    ns1:competencyDescription "Que los estudiantes posean las habilidades de aprendizaje que les permitan continuar estudiando de un modo que habrá de ser en gran medida autodirigido o autónomo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/123000720/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Aplicar conocimientos de ciencias de la Tierra y tecnologías de la información geoespacial en Ingeniería y Arquitectura."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/123000720/2025-26/CT4> a ns1:Competency ;
    ns1:competencyCode "CT4" ;
    ns1:competencyDescription "Ser capaz de definir el curso de acción y los procedimientos requeridos para alcanzar los objetivos y metas, estableciendo lo que hay que hacer para llegar al estado final deseado (Organización y planificación)."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/123000720/2025-26/RA14> a ns1:LearningResult ;
    ns1:learningResultCode "RA14" ;
    ns1:learningResultDescription "Conocer las distintas funciones estadísticas, intervalos de confianza y test de hipótesis"@es .

