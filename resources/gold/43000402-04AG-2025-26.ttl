<https://guia-kg.skai.etsisi.upm.es/resource/43000402> a ns1:Course ;
    ns1:courseType "Optativa"@es ;
    ns1:courseYear 2 ;
    ns1:semester "Cuarto semestre"@es ;
    schema:courseCode 43000402 ;
    schema:hasCourseInstance <https://guia-kg.skai.etsisi.upm.es/resource/43000402/2025-26> ;
    schema:name "Control Of Hydraulic Systems"@en,
        "Control de Sistemas Hidraulicos"@es ;
    schema:numberOfCredits 4.5 .

<https://guia-kg.skai.etsisi.upm.es/resource/43000402/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/43000402/2025-26/CE33>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000402/2025-26/CE35>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000402/2025-26/CGP01>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000402/2025-26/CGP06>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000402/2025-26/CT2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000402/2025-26/CT7> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/43000402/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000402/2025-26/didactic_resource/2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000402/2025-26/didactic_resource/3>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000402/2025-26/didactic_resource/4> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/43000402/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/43000402/2025-26/RA24>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000402/2025-26/RA25> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/43000402/2025-26/syllabus> ;
    ns1:inpersonHours "54 horas y 30 minutos (46.6%)"@es ;
    ns1:numberOfCredits 4.5 ;
    ns1:otherInformation "La asignatura se relaciona con el ODS6"@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "56 horas y 10 minutos"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/43000402/2025-26/eventSchedule> ;
    schema:description """La asignatura plantea la modelización de sistemas dinámicos hidráulicos para el estudio de su respuesta temporal y su control.
Para ello se analizan las formas empleadas para representar el comportamiento dinámico de los diferentes componentes de un sistema hidráulico: depósitos, tuberías, válvulas...
Una vez modelados los sistemas se analiza la respuesta tanto en el dominio del tiempo como en el de la frecuencia para plantear el control del sistema."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/joseignacio.sarasua%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/guillermo.martinez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/joseangel.sanchez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/joseignacio.sarasua%40upm.es> ;
    schema:name "Control de Sistemas Hidraulicos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000402/2025-26/CE33> a ns1:Competency ;
    ns1:competencyCode "CE33" ;
    ns1:competencyDescription "Capacidad para aplicar los conocimientos técnicos en actividades de I+D+i dentro del ámbito de la ingeniería civil."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000402/2025-26/CE35> a ns1:Competency ;
    ns1:competencyCode "CE35" ;
    ns1:competencyDescription "Capacidad para integrar y aplicar los conocimientos técnicos en asesoría, análisis, mantenimiento, construcción, evaluación técnica, conservación, explotación y modelización matemática de recursos hidráulicos y energéticos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000402/2025-26/CGP01> a ns1:Competency ;
    ns1:competencyCode "CGP01" ;
    ns1:competencyDescription "Capacitación científico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000402/2025-26/CGP06> a ns1:Competency ;
    ns1:competencyCode "CGP06" ;
    ns1:competencyDescription "Conocimiento para aplicar las capacidades técnicas y gestoras en actividades de I+D+i dentro del ámbito de la ingeniería civil. Incorpora las competencias CB6, CB7 y CB8."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000402/2025-26/CT2> a ns1:Competency ;
    ns1:competencyCode "CT2" ;
    ns1:competencyDescription "Polivalencia y capacidad de aprendizaje autónomo. Desarrolla la competencia transversal 5ª del Real Decreto."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000402/2025-26/CT7> a ns1:Competency ;
    ns1:competencyCode "CT7" ;
    ns1:competencyDescription "Capacidad de utilización de los servicios de información y comunicación para el ejercicio de las funciones profesionales del perfil de egreso. Desarrolla la competencia transversal 3ª de la normativa UPM."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000402/2025-26/RA24> a ns1:LearningResult ;
    ns1:learningResultCode "RA24" ;
    ns1:learningResultDescription "Aplica y evalúa modelos avanzados de ingeniería hidráulica y medioambiental en proyecto y explotación de sistemas hidráulicos y energéticos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000402/2025-26/RA25> a ns1:LearningResult ;
    ns1:learningResultCode "RA25" ;
    ns1:learningResultDescription "Aplica y evalúa técnicas avanzadas para la construcción, control y gestión medioambiental de sistemas hidráulicos y energéticos."@es .

