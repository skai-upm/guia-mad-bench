    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/45000236/2025-26/eventSchedule> ;
    schema:description "Se van a estudiar algunos de los temas más importantes del ámbito geotécnico. Muchos de ellos son de gran aplicación real en la ingeniería civil. Es decir, que muchas cosas de las que vamos a estudiar son de aplicación directa durante su vida profesional. Tenga en cuenta que cualquier obra civil (una carretera, una presa, un puerto, un edificio?) tiene que analizar temas relacionados con el terreno."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/jesus.gonzalezg%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/antonio.soriano.martinez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/enrique.asanza%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/ignacio.gtejada%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/jesus.gonzalezg%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/jg.gutierrez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/mariaisabel.reig%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/rafael.jimenez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/rubenangel.galindo%40upm.es> ;
    schema:name "Geotecnia"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000236/2025-26/04GC.%20CM21.1> a ns1:Competency ;
    ns1:competencyCode "04GC. CM21.1" ;
    ns1:competencyDescription "Conocimientos de geotecnia y mecánica de suelos y de rocas, así como su aplicación en el desarrollo de estudios, proyectos, construcciones y explotaciones donde sea necesario efectuar movimientos de tierras, cimentaciones y estructuras de contención."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000236/2025-26/04GC.%20CM45> a ns1:Competency ;
    ns1:competencyCode "04GC. CM45" ;
    ns1:competencyDescription "Comprensión y asunción de los principios de incertidumbre, riesgo y oportunidad en la aplicación de los métodos y modelos de la ingeniería civil (Desarrolla parcialmente la competencia transversal 3ª del R.D. 1393/2007)."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000236/2025-26/RA30> a ns1:LearningResult ;
    ns1:learningResultCode "RA30" ;
    ns1:learningResultDescription "Asume los principios de incertidumbre y riesgo en la aplicación de los métodos y modelos de geotecnia y mecánica de suelos y de rocas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000236/2025-26/RA32> a ns1:LearningResult ;
    ns1:learningResultCode "RA32" ;
    ns1:learningResultDescription "Aplica los métodos experimentales de Mecánica de suelos y rocas relevantes en ingeniería civil."@es .

