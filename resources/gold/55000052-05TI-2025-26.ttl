<https://guia-kg.skai.etsisi.upm.es/resource/55000052/2025-26/CB02> a ns1:Competency ;
    ns1:competencyCode "CB02" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar sus conocimientos a su trabajo o vocación de una forma profesional y posean las competencias que suelen demostrarse por medio de la elaboración y defensa de argumentos y la resolución de problemas dentro de su área de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000052/2025-26/CE1> a ns1:Competency ;
    ns1:competencyCode "CE1" ;
    ns1:competencyDescription "Capacidad para la resolución de los problemas matemáticos que puedan plantearse en la ingeniería. Aptitud para aplicar los conocimientos sobre: álgebra lineal; geometría; geometría diferencial; cálculo diferencial e integral; ecuaciones diferenciales ordinarias y en derivadas parciales; métodos numéricos; algorítmica numérica; optimización"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000052/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Conocer y aplicar conocimientos de ciencias y tecnologías básicas a la práctica de la Ingeniería Industrial."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000052/2025-26/CG10> a ns1:Competency ;
    ns1:competencyCode "CG10" ;
    ns1:competencyDescription "Capacidad para generar nuevas ideas (Creatividad)."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000052/2025-26/CG2> a ns1:Competency ;
    ns1:competencyCode "CG2" ;
    ns1:competencyDescription "Poseer capacidad para diseñar, desarrollar, implementar, gestionar y mejorar productos, sistemas y procesos en los distintos ámbitos industriales, usando técnicas analíticas, computacionales o experimentales apropiadas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000052/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Aplicar los conocimientos adquiridos para identificar, formular y resolver problemas dentro de contextos amplios y multidisciplinarios, siendo capaces de integrar conocimientos, trabajando en equipos multidisciplinares."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000052/2025-26/CG5> a ns1:Competency ;
    ns1:competencyCode "CG5" ;
    ns1:competencyDescription "Saber comunicar los conocimientos y conclusiones, de forma oral, escrita y gráfica, a públicos especializados y no especializados de un modo claro y sin ambigüedades."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000052/2025-26/CG6> a ns1:Competency ;
    ns1:competencyCode "CG6" ;
    ns1:competencyDescription "Poseer habilidades de aprendizaje que permitan continuar estudiando a lo largo de la vida para su adecuado desarrollo profesional."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000052/2025-26/CG7> a ns1:Competency ;
    ns1:competencyCode "CG7" ;
    ns1:competencyDescription "Incorporar nuevas tecnologías y herramientas de la Ingeniería Industrial en sus actividades profesionales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000052/2025-26/CG9> a ns1:Competency ;
    ns1:competencyCode "CG9" ;
    ns1:competencyDescription "Organización y planificación en el ámbito de la empresa, y otras instituciones y organizaciones de proyectos y equipos humanos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000052/2025-26/RA246> a ns1:LearningResult ;
    ns1:learningResultCode "RA246" ;
    ns1:learningResultDescription "Adquisición de los conocimientos básicos sobre análisis numérico, incluyendo los correspondientes algoritmos y su implementación en una computadora (entorno MatLab)."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000052/2025-26/RA247> a ns1:LearningResult ;
    ns1:learningResultCode "RA247" ;
    ns1:learningResultDescription "Planteamiento y modelización matemática de problemas de ingeniería, con especial atención a los más relevantes en la Especialidad de Ingeniería Eléctrica."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000052/2025-26/RA248> a ns1:LearningResult ;
    ns1:learningResultCode "RA248" ;
    ns1:learningResultDescription "Criterio para la aplicación de procedimientos numéricos a la resolución de problemas cuya solución analítica es imposible o muy costosa."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000052/2025-26/RA249> a ns1:LearningResult ;
    ns1:learningResultCode "RA249" ;
    ns1:learningResultDescription "Programación en entorno Matlab como herramienta computacional a utilizar en la modelización y resolución de problemas.."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000052/2025-26/RA250> a ns1:LearningResult ;
    ns1:learningResultCode "RA250" ;
    ns1:learningResultDescription "Conocimiento de las posibilidades y limitaciones de los métodos numéricos, de la estructura de los modelos y de la forma de abordar su resolución."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000052/2025-26/RA251> a ns1:LearningResult ;
    ns1:learningResultCode "RA251" ;
    ns1:learningResultDescription "Criterio para la evaluación crítica del alcance de los resultados numéricos en base a su relación con los problemas reales."@es .

