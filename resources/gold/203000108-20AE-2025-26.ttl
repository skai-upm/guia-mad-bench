    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/203000108/2025-26/RA5>,
        <https://guia-kg.skai.etsisi.upm.es/resource/203000108/2025-26/RA6>,
        <https://guia-kg.skai.etsisi.upm.es/resource/203000108/2025-26/RA7>,
        <https://guia-kg.skai.etsisi.upm.es/resource/203000108/2025-26/RA8> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/203000108/2025-26/syllabus> ;
    ns1:inpersonHours "24 horas (36.9%)"@es ;
    ns1:numberOfCredits 2.5 ;
    ns1:otherInformation """La asignatura se relaciona con los ODS12 y ODS14.

BIBLIOGRAFÍA BÁSICA
Naylor RL, Hardy RW, Buschmann AH, Bush SR, Cao L, Klinger DH, Little DC, Lubchenco J, Shumway SE, Troell M. A 20-year retrospective review of global aquaculture. Nature. 2021 Mar 25;591(7851):551-63.

Troell M, Costa?Pierce B, Stead S, Cottrell RS, Brugere C, Farmery AK, Little DC, Strand Å, Pullin R, Soto D, Beveridge M. Perspectives on aquaculture's contribution to the Sustainable Development Goals for improved human and planetary health. Journal of the World Aquaculture Society. 2023 Apr;54(2):251-342."""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "24 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/203000108/2025-26/eventSchedule> ;
    schema:description "Esta asignatura recoge los temas siguientes: Introducción a la acuicultura sostenible. La acuicultura como alimento nutritivo que ayuda a combatir la desnutrición y el hambre, contribuyendo a la seguridad alimentaria-nutricional y al desarrollo productivo. Incluye conceptos generales del medio acuático; Ingeniería de sistemas, mecanización y gestión de los distintos sistemas de producción; y Transformación y procesado de productos de acuicultura. Desde el año 2024-25 se introduce el concepto de Retos, Challange based learning, relacionado con la red EELISA. Esto implica la introducción de un agente externo (piscifactoría), siempre que fuera posible, o la redacción de una artículo de divulgación para ayudar a obtener una credencial EELISA. El formato general para el reto se basa en definir una o varias preguntas de base, investigar sobre ello y actuar (presentar los resultados). El reto se define junto con los alumnos. Aparte los alumnos podrán visitar visitar la piscifactoría de Montes."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/morris.villarroel%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/fernando.torrent%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/morris.villarroel%40upm.es> ;
    schema:name "Acuicultura"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000108/2025-26/CB06> a ns1:Competency ;
    ns1:competencyCode "CB06" ;
    ns1:competencyDescription "Poseer y comprender conocimientos que aporten una base u oportunidad de ser originales en el desarrollo y/o aplicación de ideas, a menudo en un contexto de investigación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000108/2025-26/CB09> a ns1:Competency ;
    ns1:competencyCode "CB09" ;
    ns1:competencyDescription "Que los estudiantes sepan comunicar sus conclusiones y los conocimientos y razones últimas que las sustentan a públicos especializados y no especializados de un modo claro y sin ambigüedades"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000108/2025-26/CE13> a ns1:Competency ;
    ns1:competencyCode "CE13" ;
    ns1:competencyDescription "Capacidad de aplicación de las técnicas apropiadas disponibles en la lucha contra la pobreza y la exclusión en procesos que correspondan al área de especialización profesional del alumno."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000108/2025-26/CE14> a ns1:Competency ;
    ns1:competencyCode "CE14" ;
    ns1:competencyDescription "Capacidad para desarrollar programas de acción y programas formativos destinados a los agentes o a la población objetivo, correspondientes al área de especialización profesional del alumno, en el marco de las acciones de desarrollo y cooperación internacional."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000108/2025-26/CG04> a ns1:Competency ;
    ns1:competencyCode "CG04" ;
    ns1:competencyDescription "Habilidades de investigación e innovación: Capacidad para identificar y formular hipótesis o ideas innovadoras en los ámbitos técnico y organizacional y someterlas a prueba de objetividad, de coherencia y de sostenibilidad, adaptada a los contextos de zonas desfavorecidas y por tanto con carencias tanto de infraestructuras, como de alta cualificación en las capacidades humanas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000108/2025-26/CG07> a ns1:Competency ;
    ns1:competencyCode "CG07" ;
    ns1:competencyDescription "Conocimiento de las relaciones entre sociedad, ciencia y técnica, y capacidad para comprender y evaluar el impacto social de las transformaciones técnicas y su asimilación,en los contextos propios a las sociedades en desarrollo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000108/2025-26/CG08> a ns1:Competency ;
    ns1:competencyCode "CG08" ;
    ns1:competencyDescription "Comprensión de la responsabilidad ética y profesional, que comprende la capacidad para tomar decisiones éticas informadas, conocimiento de los códigos de conducta profesional, evaluación de la dimensión ética de la práctica profesional y comportamiento ético visible, aplicadas a los contextos de actividad propios a las sociedades menos desarrolladas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000108/2025-26/CT01> a ns1:Competency ;
    ns1:competencyCode "CT01" ;
    ns1:competencyDescription "Capacidad de comunicación verbal y escrita en lengua inglesa."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000108/2025-26/CT02> a ns1:Competency ;
    ns1:competencyCode "CT02" ;
    ns1:competencyDescription "Capacidad de trabajo en equipo o su liderazgo."@es .

