<https://guia-kg.skai.etsisi.upm.es/resource/63000333/2025-26/RA54> a ns1:LearningResult ;
    ns1:learningResultCode "RA54" ;
    ns1:learningResultDescription "Comprensión de los riesgos que comporta el medio natural, del impacto de los fenómenos naturales sobre el medio ambiente y la sociedad."@es .

