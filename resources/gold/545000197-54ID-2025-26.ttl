    ns1:inpersonHours "68 horas (43.6%)"@es ;
    ns1:numberOfCredits 6.0 ;
    ns1:otherInformation "La asignatura se relación con el ODS 9 de Industria, Innovación e Infraestructura. Además, durante el desarrollo de las sesiones se comentan algunos aspectos relaciones con el ODS 13 (Acción por el Clima) y el ODS 12 (Producción y Consumos Responsable)."@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "98 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/545000197/2025-26/eventSchedule> ;
    schema:description """En esta asignatura, que está dentro de la materia de dirección de operaciones, se pretende que el alumno adquiera la capacidad de:
Identificar diversos tipos de sistemas productivos y los principales problemas de organización de flujos de materiales y de información que en ellos se manifiestan.
Conocer en profundidad diferentes técnicas de organización de los sistemas productivos de bienes y servicios, incluyendo la selección y aplicación para la toma de distintas decisiones.
Conocer en profundidad el ciclo completo de planificación y control de la producción, desde la previsión de necesidades hasta la ejecución en taller."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/javier.mazorra%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/javier.mazorra%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/miguel.ortega.mier%40upm.es> ;
    schema:name "Dirección de Producción"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000197/2025-26/CE69> a ns1:Competency ;
    ns1:competencyCode "CE69" ;
    ns1:competencyDescription "Determinar las decisiones estratégicas y tácticas relacionadas con el área de producción / operaciones."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000197/2025-26/CE70> a ns1:Competency ;
    ns1:competencyCode "CE70" ;
    ns1:competencyDescription "Comprender los procesos de dirección de operaciones y organización de la producción."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000197/2025-26/CG15> a ns1:Competency ;
    ns1:competencyCode "CG15" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de planificar eficientemente los trabajos en el ámbito de la administración y dirección de empresas, priorizando las tareas a desempeñar y evaluando los recursos y el tiempo necesario para llevarlas a cabo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000197/2025-26/CG22> a ns1:Competency ;
    ns1:competencyCode "CG22" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de trabajar en el ámbito de la administración y dirección de empresas aplicando criterios de calidad y sostenibilidad."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000197/2025-26/RA138> a ns1:LearningResult ;
    ns1:learningResultCode "RA138" ;
    ns1:learningResultDescription "Conocer los fundamentos de la organización, planificación y control de la producción."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000197/2025-26/RA141> a ns1:LearningResult ;
    ns1:learningResultCode "RA141" ;
    ns1:learningResultDescription "Abordar situaciones nuevas o complejas en colaboración con otros hasta llegar a diseñar un plan coherente con acciones concretas,"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000197/2025-26/RA142> a ns1:LearningResult ;
    ns1:learningResultCode "RA142" ;
    ns1:learningResultDescription "Participar e integrarse en el desarrollo organizado de un trabajo en grupo, previendo las tareas, tiempos y recursos para conseguir los resultados deseados."@es .

