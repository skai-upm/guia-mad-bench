    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/145006504/2025-26/eventSchedule> ;
    schema:description """Se pretende familiarizar al estudiante con diferentes técnicas de análisis y diseño de sistemas de control, utilizando tanto las técnicas de la teoría de control clásica como de control moderno.
Además, se realiza una introducción a las técnicas de optimización, tanto de algoritmos locales basados en el gradiente como de algoritmos basados en técnicas heurísticas para su aplicación en problemas de diseño."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/jose.m.perales%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/ignacio.delgado%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/ignacio.gomez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/jose.m.perales%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/maria.higuera%40upm.es> ;
    schema:name "Control y Optimizacion"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145006504/2025-26/CE47> a ns1:Competency ;
    ns1:competencyCode "CE47" ;
    ns1:competencyDescription "Conocimiento adecuado y aplicado a la Ingeniería de: Los fenómenos físicos del vuelo de los sistemas aéreos de defensa, sus cualidades y su control, las actuaciones, la estabilidad y los sistemas automáticos de control."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145006504/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Capacidad para identificar y resolver problemas aplicando, con creatividad, los conocimientos adquiridos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145006504/2025-26/CG6> a ns1:Competency ;
    ns1:competencyCode "CG6" ;
    ns1:competencyDescription "Uso de las Tecnologías de la Información y de las Comunicaciones"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145006504/2025-26/CG9> a ns1:Competency ;
    ns1:competencyCode "CG9" ;
    ns1:competencyDescription "Razonamiento crítico y capacidad de asociación que posibiliten el aprendizaje continuo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145006504/2025-26/RA258> a ns1:LearningResult ;
    ns1:learningResultCode "RA258" ;
    ns1:learningResultDescription "Conocimiento, comprensión y aplicación de las teorías matemáticas del control y la optimización."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145006504/2025-26/RA259> a ns1:LearningResult ;
    ns1:learningResultCode "RA259" ;
    ns1:learningResultDescription "Conocimiento, comprensión, aplicación, análisis y síntesis de los sistemas automáticos de control de los vehículos aeroespaciales."@es .

