<https://guia-kg.skai.etsisi.upm.es/resource/53000976> a ns1:Course ;
    ns1:courseType "Optativa"@es ;
    ns1:courseYear 1 ;
    ns1:semester "Primer semestre"@es ;
    schema:courseCode 53000976 ;
    schema:hasCourseInstance <https://guia-kg.skai.etsisi.upm.es/resource/53000976/2025-26> ;
    schema:name "Vehicle Dynamics"@en,
        "Dinamica Vehicular"@es ;
    schema:numberOfCredits 3.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/53000976/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/53000976/2025-26/CE6>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53000976/2025-26/CE7>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53000976/2025-26/CG%201> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/53000976/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53000976/2025-26/didactic_resource/2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53000976/2025-26/didactic_resource/3>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53000976/2025-26/didactic_resource/4> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/53000976/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/53000976/2025-26/RA52>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53000976/2025-26/RA53>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53000976/2025-26/RA54> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/53000976/2025-26/syllabus> ;
    ns1:inpersonHours "30 horas (38.5%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation "La presente asignatura, en el caso de seguimiento mediante evaluación progresiva, está basada en la aplicación de los conocimientos teóricos a la modelización."@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "36 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/53000976/2025-26/eventSchedule> ;
    schema:description """Los objetivos de esta asignatura consisten en:
- Revisar los conceptos teóricos básicos sobre dinámica de los vehículos de carretera.
- Conocer el manejo de alguna de las herramientas informáticas de simulación del comportamiento dinámico de vehículos de carretera, para la aplicación de los conceptos teóricos previos.
- Definir un conjunto de ensayos de evaluación e identificación de parámetros no conocidos de estos vehículos.
- Reproducir dichas maniobras en el programa informático, verificar y validar el modelo de vehículo simulado mediante la utilización de métricas de comparación."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/franciscojavier.paez%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/franciscojavier.paez%40upm.es> ;
    schema:name "Dinamica Vehicular"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000976/2025-26/CE6> a ns1:Competency ;
    ns1:competencyCode "CE6" ;
    ns1:competencyDescription "Analizar, diseñar y modelar los distintos componentes de un sistema en base al dominio físico al que pertenezcan, aplicando distintas técnicas de simulación a modelos realistas y multidominio dentro del área de ingeniería mecánica."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000976/2025-26/CE7> a ns1:Competency ;
    ns1:competencyCode "CE7" ;
    ns1:competencyDescription "Analizar y diseñar vehículos y sistemas vehiculares e interpretar los comportamientos de los principales sistemas vehiculares para su aplicación al diseño y evaluación de sus comportamientos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000976/2025-26/CG%201> a ns1:Competency ;
    ns1:competencyCode "CG 1" ;
    ns1:competencyDescription "Aplicar conocimientos de ciencias y tecnologías avanzadas a la práctica de la Ingeniería Mecánica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000976/2025-26/RA52> a ns1:LearningResult ;
    ns1:learningResultCode "RA52" ;
    ns1:learningResultDescription "Conocer el problema del comportamiento dinámico de los vehículos de carretera"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000976/2025-26/RA53> a ns1:LearningResult ;
    ns1:learningResultCode "RA53" ;
    ns1:learningResultDescription "Aprender herramientas de modelización dinámica de los vehículos de carretera"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000976/2025-26/RA54> a ns1:LearningResult ;
    ns1:learningResultCode "RA54" ;
    ns1:learningResultDescription "Aprender las técnicas de validación experimental de modelos de simulación de vehículos"@es .

