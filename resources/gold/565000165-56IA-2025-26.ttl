<https://guia-kg.skai.etsisi.upm.es/resource/565000165/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Tema 1: INTRODUCCIÓN"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000165/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Introducción a la automatización Industrial. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000165/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "3.2. Funciones con parámetros. Nociones básicas. Uso del entorno de desarrollo. de programación estructurada: bloques de librería reutilizables y autocontenidos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000165/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "3.3. Plantilla de maniobra simple: bit de trabajo, bit de finalización correcta. Implementación en bloques de control FC y FB. Aplicación para macroetapas. Aplicación al tratamiento de señales analógicas. Casos prácticos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000165/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "3.4. Extensión de la plantilla de maniobra simple para la gestión de errores: bit de error explícito. Plantilla ENABLE-ENABLE-OUT para gestión de errores (bit de error implícito). Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000165/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "3.5. Plantilla START-STOP para componentes de control que no tienen eventos de finalización: bit de start y bit de standby. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000165/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "3.6. Casos prácticos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000165/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "4. Tema 4: APLICACIÓN PRÁCTICA DE SENSORES Y ACTUADORES"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000165/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "4.1. Criterios de selección de la tecnología más adecuada de los sensores en función de la aplicación. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000165/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "4.2. Elección de la actuación para cada uno de los sistemas de planta. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000165/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "4.3. Integración en los sistemas de planta. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000165/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "5. Tema 5: DISEÑO DE SISTEMAS DE FABRICACIÓN"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000165/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Repaso de la plantilla de programación de grafcet: sistemas de producción con eventos temporizados y eventos de contaje, acciones limitadas, retardadas, condicionadas etc. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000165/2025-26/syllabus/20> a ns1:SyllabusItem ;
    ns1:itemIndex 20 ;
    ns1:syllabusDescription "5.1. Introducción a las distintas filosofías de diseño de fabricación. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000165/2025-26/syllabus/21> a ns1:SyllabusItem ;
    ns1:itemIndex 21 ;
    ns1:syllabusDescription "5.2. Tipos de modelos con prioridad al volumen o la diversidad de producto. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000165/2025-26/syllabus/22> a ns1:SyllabusItem ;
    ns1:itemIndex 22 ;
    ns1:syllabusDescription "5.3. Etapas en el proceso de diseño. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000165/2025-26/syllabus/23> a ns1:SyllabusItem ;
    ns1:itemIndex 23 ;
    ns1:syllabusDescription "5.4. Integración de los diferentes sistemas: estaciones de trabajo, sistemas de alimentación, carga y descarga, sistemas de transporte. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000165/2025-26/syllabus/24> a ns1:SyllabusItem ;
    ns1:itemIndex 24 ;
    ns1:syllabusDescription "5.5. Introducción a los Sistemas de Fabricación Flexible (FMS). Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000165/2025-26/syllabus/25> a ns1:SyllabusItem ;
    ns1:itemIndex 25 ;
    ns1:syllabusDescription "5.6. Celdas automatizadas de fabricación. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000165/2025-26/syllabus/26> a ns1:SyllabusItem ;
    ns1:itemIndex 26 ;
    ns1:syllabusDescription "5.7. Modelos FMS atendiendo al grado de flexibilidad y topología en planta. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000165/2025-26/syllabus/27> a ns1:SyllabusItem ;
    ns1:itemIndex 27 ;
    ns1:syllabusDescription "5.8. Simulación de procesos de fabricación. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000165/2025-26/syllabus/28> a ns1:SyllabusItem ;
    ns1:itemIndex 28 ;
    ns1:syllabusDescription "6. Tema 6: COMUNICACIONES EN PLANTAS INDUSTRIALES"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000165/2025-26/syllabus/29> a ns1:SyllabusItem ;
    ns1:itemIndex 29 ;
    ns1:syllabusDescription "6.1. Introducción a las redes industriales. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000165/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "2. Tema 2: MODELADO"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000165/2025-26/syllabus/30> a ns1:SyllabusItem ;
    ns1:itemIndex 30 ;
    ns1:syllabusDescription "6.2. Concepto de descentralización de la periferia. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000165/2025-26/syllabus/31> a ns1:SyllabusItem ;
    ns1:itemIndex 31 ;
    ns1:syllabusDescription "6.3. Buses de campo. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000165/2025-26/syllabus/32> a ns1:SyllabusItem ;
    ns1:itemIndex 32 ;
    ns1:syllabusDescription "6.4. Programación de comunicaciones sobre bus de campo. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000165/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "2.1. Coordinación entre grafcets: horizontal y jerárquica. Soluciones de programación. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000165/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "2.2. Encapsulación: macroetapas. Control de flujo de ejecución: saltos dentro de un bloque. Llamadas a funciones. Plantilla de programación con cajas. Solución para implementar macroetapas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000165/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "2.3. Grafcet de modos de marcha y emergencia. Soluciones de programación. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000165/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "2.4. Grafcet de modos de marcha y emergencia. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000165/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "3. Tema 3: PROGRAMACION DEL PLC"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000165/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "3.1. Introducción a la arquitectura de programación: Registros, bloques de organización, bloques de función, funciones y datos. Sin subniveles"@es .

