    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/305000124/2025-26/eventSchedule> ;
    schema:description "Se trata de una asignatura que tiene dos objetivos: El primero de ellos es la modelización de fenómenos continuos que dan lugar a este tipo de ecuaciones (fluidos, elasticidad, medios porosos, finanzas, etc.) reconociendo los elementos necesarios que hacen que el sistema resultante sea un problema matemático bien puesto en el sentido de Hadamard. El segundo objetivo es el desarrollo de herramientas matemáticas para encontrar soluciones y deducir propiedades. En general, estas herramientas son muy diversas y requieren una buena madurez en el cálculo vectorial y el análisis real y complejo. Es importante que los dos objetivos estén bien coordinados porque muchas de las propiedades que se prueban analíticamente surgen de la intuición que nos da la observación y, al mismo tiempo, algunas propiedades que se demuestran matemáticamente permiten comprender mejor la realidad que modelizan."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/carlos.castro%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/carlos.castro%40upm.es> ;
    schema:name "Ecuaciones en Derivadas Parciales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000124/2025-26/CE1> a ns1:Competency ;
    ns1:competencyCode "CE1" ;
    ns1:competencyDescription "Comprender y utilizar el lenguaje matemático. Adquirir la capacidad para enunciar propiedades en distintos campos de la Matemática, para construir argumentaciones, elaborar cálculos y para transmitir los conocimientos matemáticos adquiridos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000124/2025-26/CE2> a ns1:Competency ;
    ns1:competencyCode "CE2" ;
    ns1:competencyDescription "Conocer y comprender demostraciones rigurosas de los principales teoremas de cada área de la Matemática y extraer de ellos corolarios mediante la particularización a casos concretos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000124/2025-26/CE3> a ns1:Competency ;
    ns1:competencyCode "CE3" ;
    ns1:competencyDescription "Asimilar la definición de un nuevo objeto matemático, en términos de otros ya conocidos, y ser capaz de utilizar este objeto en diferentes contextos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000124/2025-26/CE4> a ns1:Competency ;
    ns1:competencyCode "CE4" ;
    ns1:competencyDescription "Abstraer las propiedades estructurales de objetos matemáticos, de la realidad observada o de otros ámbitos distinguiéndolas de aquellas puramente ocasionales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000124/2025-26/CE7> a ns1:Competency ;
    ns1:competencyCode "CE7" ;
    ns1:competencyDescription "Resolver problemas de Matemáticas, mediante habilidades de cálculo básico y tecnologías de computación, planificando su resolución en función de las herramientas de que se disponga y de las restricciones de tiempo y recursos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000124/2025-26/CG5> a ns1:Competency ;
    ns1:competencyCode "CG5" ;
    ns1:competencyDescription "Sintetizar conocimientos y habilidades adquiridas en el campo de la matemática en diferentes materias del plan de estudios para enfocarlas en posteriores estudios especializados, tanto en una disciplina matemática como en cualquiera de las ciencias que requieran buenos fundamentos matemáticos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000124/2025-26/CT4> a ns1:Competency ;
    ns1:competencyCode "CT4" ;
    ns1:competencyDescription "Mostrar capacidad para innovar y encontrar soluciones creativas en situaciones complejas o de incertidumbre."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000124/2025-26/RA165> a ns1:LearningResult ;
    ns1:learningResultCode "RA165" ;
    ns1:learningResultDescription "Conocer los modelos más habituales basados en ecuaciones en derivadas parciales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000124/2025-26/RA167> a ns1:LearningResult ;
    ns1:learningResultCode "RA167" ;
    ns1:learningResultDescription "Interpretar adecuadamente las condiciones de contorno e iniciales en una EDP"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000124/2025-26/RA168> a ns1:LearningResult ;
    ns1:learningResultCode "RA168" ;
    ns1:learningResultDescription "Resolver por el método de separación de variables las EDP más comunes"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000124/2025-26/RA169> a ns1:LearningResult ;
    ns1:learningResultCode "RA169" ;
    ns1:learningResultDescription "Resolver la ecuación del calor a partir de su solución fundamental"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000124/2025-26/RA170> a ns1:LearningResult ;
    ns1:learningResultCode "RA170" ;
    ns1:learningResultDescription "Resolver ecuaciones hiperbólicas mediante el método de las características"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000124/2025-26/RA171> a ns1:LearningResult ;
    ns1:learningResultCode "RA171" ;
    ns1:learningResultDescription "Resolver la ecuación de Laplace y deducir propiedades de sus soluciones"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000124/2025-26/RA172> a ns1:LearningResult ;
    ns1:learningResultCode "RA172" ;
    ns1:learningResultDescription "Identificar un problema bien puesto en el sentido de Hadamard"@es .

