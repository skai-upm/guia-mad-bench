<https://guia-kg.skai.etsisi.upm.es/resource/55000436/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/55000436/2025-26/CG10>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55000436/2025-26/CG5>,
