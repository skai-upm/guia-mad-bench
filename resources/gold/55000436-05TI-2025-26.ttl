        <https://guia-kg.skai.etsisi.upm.es/resource/55000436/2025-26/didactic_resource/5>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55000436/2025-26/didactic_resource/6>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55000436/2025-26/didactic_resource/7> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/55000436/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/55000436/2025-26/RA208>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55000436/2025-26/RA209>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55000436/2025-26/RA210> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/55000436/2025-26/syllabus> ;
    ns1:inpersonHours "35 horas y 30 minutos (45.5%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation """La asignatura se relaciona con los siguientes Objetivos de Desarrollo Sostenible (ODS) establecidos por Naciones Unidas: ODS4, ODS5, ODS8, ODS10 y ODS16.
La plataforma utilizada será MOODLE."""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "37 horas y 30 minutos"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/55000436/2025-26/eventSchedule> ;
    schema:description """La asignatura de Español para Extranjeros II tiene como finalidad capacitar al alumnado para usar el idioma de manera suficiente, receptiva y productivamente, tanto en forma hablada como escrita, así como para mediar entre en situaciones básicas que requieran comprender y producir textos breves que versen sobre aspectos concretos de temas cotidianos y que contengan expresiones, léxico y estructuras de uso muy frecuente.
La asignatura de Español para Extranjeros II presenta las características de los niveles de competencia A2/A2+ según se define en el Marco Común Europeo de Referencia para las Lenguas."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/isabel.lopez%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/isabel.lopez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/josemaria.gonzalezd%40upm.es> ;
    schema:name "Español para Extranjeros II"@es .

