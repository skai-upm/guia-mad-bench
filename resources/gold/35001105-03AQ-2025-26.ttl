<https://guia-kg.skai.etsisi.upm.es/resource/35001105/2025-26/CE%201> a ns1:Competency ;
    ns1:competencyCode "CE 1" ;
    ns1:competencyDescription "Aptitud para aplicar los procedimientos gráficos a la representación de espacios y objetos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35001105/2025-26/CE%2010> a ns1:Competency ;
    ns1:competencyCode "CE 10" ;
    ns1:competencyDescription "Conocimiento adecuado y aplicado a la arquitectura y al urbanismo de las bases de topografía, hipsometría y cartografía y las técnicas de modificación del terreno."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35001105/2025-26/CE%2011> a ns1:Competency ;
    ns1:competencyCode "CE 11" ;
    ns1:competencyDescription "Conocimiento aplicado del cálculo numérico, la geometría analítica y diferencial y los métodos algebraicos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35001105/2025-26/CE%202> a ns1:Competency ;
    ns1:competencyCode "CE 2" ;
    ns1:competencyDescription "Aptitud para concebir y representar los atributos visuales de los objetos y dominar la proporción y las técnicas del dibujo, incluidas las informáticas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35001105/2025-26/CE%2024> a ns1:Competency ;
    ns1:competencyCode "CE 24" ;
    ns1:competencyDescription "Conocimiento adecuado de la mecánica de sólidos, de medios continuos y del suelo, así como de las cualidades plásticas, elásticas y de resistencia de los materiales de obra pesada."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35001105/2025-26/CE%203> a ns1:Competency ;
    ns1:competencyCode "CE 3" ;
    ns1:competencyDescription "Conocimiento adecuado y aplicado a la arquitectura y al urbanismo de los sistemas de representación espacial."@es .

