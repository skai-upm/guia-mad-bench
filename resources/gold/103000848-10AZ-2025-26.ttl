    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/103000848/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/103000848/2025-26/RA102>,
        <https://guia-kg.skai.etsisi.upm.es/resource/103000848/2025-26/RA103>,
