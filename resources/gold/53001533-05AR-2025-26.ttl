    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/53001533/2025-26/syllabus> ;
    ns1:inpersonHours "31 horas y 20 minutos (40.2%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation ""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "37 horas y 40 minutos"@es ;
    schema:activitiesWorkload "40%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/53001533/2025-26/eventSchedule> ;
    schema:description "En la asignatura se aplican los métodos de proyecto sismorresistente lineales y no-lineales, aplicados fundamentalmente a las estructuras convencionales. Se abordan desde los métodos tradicionales basados en fuerzas, a los métodos más avanzados basados en desplazamientos y en el balance de energía de Housner-Akiyama. La asignatura se desarrolla a través de la resolución de casos prácticos."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/amadeo.benavent%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/amadeo.benavent%40upm.es> ;
    schema:name "Prácticas Integrales de Proyecto y Cálculo Sísmico"@es .

