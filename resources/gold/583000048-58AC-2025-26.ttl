    ns1:inpersonHours "37 horas y 20 minutos (47.9%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation """Información facilitada a través de internet y en la plataforma moodle de noticias de actualidad sobre infraestructuras portuarias, logísticas y aeroportuarias.
OD 11: Comunicaciones sostenibles"""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "37 horas y 20 minutos"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/583000048/2025-26/eventSchedule> ;
    schema:description """La asignatura aborda la gestión de las infraestructuras portuarias, logisticas asociadas a los puertos y aeroportuaria. Se centra en las principales terminales; contenedores, graneles sólidos y RO-RO, así como puertos secos y plataformas logísticas.
Para ello se analizan los principales aspectos de la gestión, en todas ellas (medioambiente, seguridad, etc) se muestran los diferentes modelos de gestión, y se realizan ejercicios prácticos.."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/david.romero%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/david.romero%40upm.es> ;
    schema:name "Gestión de Infraestructuras Portuarias, Logísticas y Aeroportuarias"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/583000048/2025-26/CE%2001> a ns1:Competency ;
    ns1:competencyCode "CE 01" ;
    ns1:competencyDescription "Capacidad para analizar y calcular aspectos legislativos y financieros en proyectos de infraestructuras, tanto en España como en otros países"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/583000048/2025-26/CE%2002> a ns1:Competency ;
    ns1:competencyCode "CE 02" ;
    ns1:competencyDescription "Capacidad para la gestión, dentro de equipos multidisciplinares, de aspectos relacionados con la planificación, ejecución o explotación de infraestructuras"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/583000048/2025-26/CE%2003> a ns1:Competency ;
    ns1:competencyCode "CE 03" ;
    ns1:competencyDescription "Capacidad para la aplicación de aspectos de seguridad en la ejecución y seguridad en ambientes de riesgo relacionados con la ejecución o explotación de infraestructuras"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/583000048/2025-26/CE%2005> a ns1:Competency ;
    ns1:competencyCode "CE 05" ;
    ns1:competencyDescription "Capacidad para la gestión, dentro de equipos multidisciplinares, en lo relacionado a la planificación estratégica, siguiendo criterios de calidad y medioambientales, de aspectos relacionados con la dirección, coordinación y gestión técnica y económica de proyectos en todos los ámbitos de las infraestructuras"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/583000048/2025-26/CE%2008> a ns1:Competency ;
    ns1:competencyCode "CE 08" ;
    ns1:competencyDescription "Conocimiento, comprensión y capacidad para aplicar la legislación necesaria en el ámbito de las infraestructuras"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/583000048/2025-26/CG%2001> a ns1:Competency ;
    ns1:competencyCode "CG 01" ;
    ns1:competencyDescription "Capacidad para dirigir, planificar y supervisar equipos multidisciplinares"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/583000048/2025-26/CG%2004> a ns1:Competency ;
    ns1:competencyCode "CG 04" ;
    ns1:competencyDescription "Capacidad para el análisis y la toma de decisiones relacionada con la dirección general, dirección técnica y dirección de proyectos, desarrollo e innovación, en empresas y centros tecnológicos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/583000048/2025-26/CG%2005> a ns1:Competency ;
    ns1:competencyCode "CG 05" ;
    ns1:competencyDescription "Capacidad para la puesta en marcha, dirección y gestión de planificación y gestión de infraestructuras, etc., en el ámbito de la ingeniería civil y de infraestructuras con garantía de seguridad para las personas y bienes, con calidad final de las infraestructuras"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/583000048/2025-26/CG%2007> a ns1:Competency ;
    ns1:competencyCode "CG 07" ;
    ns1:competencyDescription "Capacidad para saber comunicar (de forma oral y escrita) las conclusiones y los conocimientos y las razones últimas que sustentan a públicos especializados y no especializados de un modo claro y sin ambigüedades"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/583000048/2025-26/RA2> a ns1:LearningResult ;
    ns1:learningResultCode "RA2" ;
    ns1:learningResultDescription "Conocimiento de las bases de derecho fundamentales para poder desarrollar las actividades de planificado y gestión de infraestructuras."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/583000048/2025-26/RA3> a ns1:LearningResult ;
    ns1:learningResultCode "RA3" ;
    ns1:learningResultDescription "Adquisicion de herramientas y destrezas necesarias para la evaluacion de inversiones en infraestructuras"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/583000048/2025-26/RA4> a ns1:LearningResult ;
    ns1:learningResultCode "RA4" ;
    ns1:learningResultDescription "Conocer modelos de planificación aplicados en la actualidad"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/583000048/2025-26/RA5> a ns1:LearningResult ;
    ns1:learningResultCode "RA5" ;
    ns1:learningResultDescription "Adquisicion de destrezas adecuadas para la correcta planificacion de infraestructuras y profundizacion en la genesis y diseño de proyectos de ingenieria."@es .

