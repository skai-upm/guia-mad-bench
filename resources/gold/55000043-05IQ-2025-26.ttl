    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/55000043/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/55000043/2025-26/RA55>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55000043/2025-26/RA56>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55000043/2025-26/RA57> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/55000043/2025-26/syllabus> ;
    ns1:inpersonHours "26 horas (33.3%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation ""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "26 horas"@es ;
    schema:activitiesWorkload "48%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/55000043/2025-26/eventSchedule> ;
    schema:description """La asignatura de Francés II tiene como finalidad capacitar al alumnado para usar el idioma de manera suficiente, receptiva y productivamente, tanto en forma hablada como escrita, así como para mediar entre hablantes de distintas lenguas, en situaciones de ámbito personal o profesional que requieran comprender y producir textos breves, en diversos registros y en lengua estándar, que versen sobre aspectos concretos de temas generales y que contengan expresiones, léxico y estructuras de uso frecuente.
La asignatura de Francés II presenta las características del nivel de competencia A2.2, según se define en el Marco Común Europeo de Referencia para las Lenguas."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/ismael.arinas%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/ismael.arinas%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/josemaria.gonzalezd%40upm.es> ;
    schema:name "Frances II"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000043/2025-26/CG%203> a ns1:Competency ;
    ns1:competencyCode "CG 3" ;
    ns1:competencyDescription "Aplicar los conocimientos adquiridos para identificar, formular y resolver problemas en contextos amplios, siendo capaces de integrar los trabajando en equipos multidisciplinares"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000043/2025-26/CG%204> a ns1:Competency ;
    ns1:competencyCode "CG 4" ;
    ns1:competencyDescription "Comprender el impacto de la ingeniería en el medio ambiente, el desarrollo sostenible de la sociedad y la importancia de trabajar en un entorno profesional y responsable"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000043/2025-26/CG%205> a ns1:Competency ;
    ns1:competencyCode "CG 5" ;
    ns1:competencyDescription "Comunicar conocimientos y conclusiones, tanto de forma oral como escrita, a públicos especializados y no especializados de modo claro y sin ambigüedades"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000043/2025-26/CG%206> a ns1:Competency ;
    ns1:competencyCode "CG 6" ;
    ns1:competencyDescription "Poseer las habilidades de aprendizaje que permitan continuar estudiando a lo largo de toda la vida para un desarrollo profesional adecuado"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000043/2025-26/CG%209> a ns1:Competency ;
    ns1:competencyCode "CG 9" ;
    ns1:competencyDescription "Organización y planificación de proyectos y equipos humanos. Trabajo en equipo y capacidad de liderazgo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000043/2025-26/RA55> a ns1:LearningResult ;
    ns1:learningResultCode "RA55" ;
    ns1:learningResultDescription "Capacidad de utilizar tanto el vocabulario general como el técnico con precisión."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000043/2025-26/RA56> a ns1:LearningResult ;
    ns1:learningResultCode "RA56" ;
    ns1:learningResultDescription "Capacidad de utilizar formatos escritos para comunicaciones de tipo profesional."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000043/2025-26/RA57> a ns1:LearningResult ;
