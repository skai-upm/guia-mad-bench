    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/55000043/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55000043/2025-26/didactic_resource/2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55000043/2025-26/didactic_resource/3>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55000043/2025-26/didactic_resource/4>,
