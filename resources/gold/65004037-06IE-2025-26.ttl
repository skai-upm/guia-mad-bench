        <https://guia-kg.skai.etsisi.upm.es/resource/65004037/2025-26/syllabus/8>,
        <https://guia-kg.skai.etsisi.upm.es/resource/65004037/2025-26/syllabus/9> .

<https://guia-kg.skai.etsisi.upm.es/resource/65004037/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. CARACTERÍSTICAS FUNDAMENTALES DE LAS REDES DE DISTRIBUCIÓN"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004037/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Configuración del sistema eléctrico de potencia. Tensiones normalizadas Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004037/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "2.3. Cálculo de corrientes de cortocircuito asimétricas: monofásicas y bifásicas. Método de componentes simétricas. Impedancias y redes de secuencia: homopolar, directa e inversa. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004037/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "2.4. Reglamentos y Normas aplicables (alta y baja tensión) Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004037/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "3. CANALIZACIONES ELÉCTRICAS"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004037/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "3.1. Cables: Componentes, materiales y comportamiento térmico. Tipología normalizada. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004037/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "3.2. Criterios y cálculo para selección sección optima de cables: aislamiento, corriente admisible, corriente de cortocircuito y caída de tensión. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004037/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "3.3. Condiciones de instalación de los cables: su aparamenta de maniobra/protección, regímenes de servicio y cambios en las condiciones de referencia. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004037/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "3.4. Reglamentación y normativa aplicables. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004037/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "4. APARAMENTA DE MANIOBRA Y PROTECCIÓN: CARACTERÍSTICAS Y ESPECIFICACIONES"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004037/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "4.1. Introducción. Funciones y mecanismos de la aparamenta. Extinción del arco eléctrico. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004037/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "4.2. Funcionamiento, tipos y características nominales de la aparamenta de maniobra y protección: seccionadores, interruptores, contactores, fusibles y pararrayos. Criterios de selección de aparamenta. Circuitos de mando. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004037/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Estructura y configuraciones típicas de las redes de distribución. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004037/2025-26/syllabus/20> a ns1:SyllabusItem ;
    ns1:itemIndex 20 ;
    ns1:syllabusDescription "4.3. Coordinación y combinación de protecciones. Esquemas típicos de protección de redes de distribución e instalaciones industriales y domesticas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004037/2025-26/syllabus/21> a ns1:SyllabusItem ;
    ns1:itemIndex 21 ;
    ns1:syllabusDescription "4.4. Reglamentación y normativa aplicables. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004037/2025-26/syllabus/22> a ns1:SyllabusItem ;
    ns1:itemIndex 22 ;
    ns1:syllabusDescription "5. CONTACTOS INDIRECTOS, REGÍMENES DE NEUTRO Y PUESTAS A TIERRA"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004037/2025-26/syllabus/23> a ns1:SyllabusItem ;
    ns1:itemIndex 23 ;
    ns1:syllabusDescription "5.1. Tipos de contactos eléctricos. Curvas de electrocución. Tensión de paso y de contacto. Prevención frente a la electrocución. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004037/2025-26/syllabus/24> a ns1:SyllabusItem ;
    ns1:itemIndex 24 ;
    ns1:syllabusDescription "5.2. Puestas a tierra. Tipos y partes de un sistema de puesta a tierra. Cálculo de la resistencia de puesta a tierra. Mediciones. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004037/2025-26/syllabus/25> a ns1:SyllabusItem ;
    ns1:itemIndex 25 ;
    ns1:syllabusDescription "5.3. Protección frente a contactos eléctricos. Regímenes de neutro de las instalaciones y dispositivos de corte de los defectos a tierra. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004037/2025-26/syllabus/26> a ns1:SyllabusItem ;
    ns1:itemIndex 26 ;
    ns1:syllabusDescription "5.4. Reglamentación y normativa aplicables. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004037/2025-26/syllabus/27> a ns1:SyllabusItem ;
    ns1:itemIndex 27 ;
    ns1:syllabusDescription "6. FUNDAMENTOS DE MÁQUINAS ELÉCTRICAS"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004037/2025-26/syllabus/28> a ns1:SyllabusItem ;
    ns1:itemIndex 28 ;
    ns1:syllabusDescription "6.1. Introducción a las máquinas eléctricas: generalidades, construcción, principio de funcionamientos, fundamentos electro-magnéticos y generación de campos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004037/2025-26/syllabus/29> a ns1:SyllabusItem ;
    ns1:itemIndex 29 ;
    ns1:syllabusDescription "6.2. Rendimientos: pérdidas y rendimientos, calentamiento. Eficiencia energética. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004037/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "1.3. Condiciones de servicio y calidad de suministro: previsión de cargas, factores de utilización y de simultaneidad. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004037/2025-26/syllabus/30> a ns1:SyllabusItem ;
    ns1:itemIndex 30 ;
    ns1:syllabusDescription "6.3. Características de máquinas eléctricas: asignación de características nominales según el servicio; selección de máquinas eléctricas; estabilidad de funcionamiento; maniobras. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004037/2025-26/syllabus/31> a ns1:SyllabusItem ;
    ns1:itemIndex 31 ;
    ns1:syllabusDescription "7. MOTOR ASÍNCRONO"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004037/2025-26/syllabus/32> a ns1:SyllabusItem ;
    ns1:itemIndex 32 ;
    ns1:syllabusDescription "7.1. Constitución, principio de funcionamiento del motor asíncrono y circuito equivalente. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004037/2025-26/syllabus/33> a ns1:SyllabusItem ;
    ns1:itemIndex 33 ;
    ns1:syllabusDescription "7.2. Curvas características. Valores asignados y características nominales. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004037/2025-26/syllabus/34> a ns1:SyllabusItem ;
    ns1:itemIndex 34 ;
    ns1:syllabusDescription "7.3. Criterios de selección del motor asíncrono: cargas mecánicas típicas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004037/2025-26/syllabus/35> a ns1:SyllabusItem ;
    ns1:itemIndex 35 ;
    ns1:syllabusDescription "7.4. Maniobra y protección. Arranque y frenado. Uso de la máquina asíncrona como generador. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004037/2025-26/syllabus/36> a ns1:SyllabusItem ;
    ns1:itemIndex 36 ;
    ns1:syllabusDescription "7.5. Motores monofásicos: constitución y características; particularidades del arranque. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004037/2025-26/syllabus/37> a ns1:SyllabusItem ;
    ns1:itemIndex 37 ;
    ns1:syllabusDescription "7.6. Reglamentación y normativa aplicables. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004037/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "1.4. Aislamiento eléctrico: tipos de aislantes, características y comportamiento, Sobretensiones: causas y tipos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004037/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "1.5. Caídas de tensión: cálculo. Tomas de regulación de transformadores para minimizarlas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004037/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "1.6. Reglamentos y Normas aplicables (alta y baja tensión) Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004037/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "2. CORTOCIRCUITOS ELÉCTRICOS Y SUS EFECTOS EN LAS INSTALACIONES ELÉCTRICAS"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004037/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "2.1. Cortocircuitos: tipos, causas y efectos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004037/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "2.2. Calculo de corrientes de cortocircuito trifásicas o simétricas. Sin subniveles"@es .

