    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/95000327/2025-26/eventSchedule> ;
    schema:description "El objetivo de la asignatura es proporcionar al alumno un conocimiento teórico y práctico sobre entornos de trabajo de imagen biomédica, física de las imágenes médicas (interacción materia-energía, detectores, fuentes, dosimetría, radiación, protección), física de los sistema de radiología diagnóstica (radiografía, tomografía computerizada, medicina nuclear, PET, resonancia magnética nuclear, ultrasonidos), estándares en imagen biomédica, y conceptos básicos de procesamiento de imagen médica."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/enriquejavier.gomez%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/ap.seiffert%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/enriquejavier.gomez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/lucilio.cordero%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/mariaelena.hernando%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/mj.ledesma%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/p.sanchez%40upm.es> ;
    schema:name "Imágenes Biomédicas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000327/2025-26/CE12> a ns1:Competency ;
    ns1:competencyCode "CE12" ;
    ns1:competencyDescription "Saber buscar, obtener e interpretar la información de las principales bases de datos biomédicas y bibliográficos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000327/2025-26/CE38> a ns1:Competency ;
    ns1:competencyCode "CE38" ;
    ns1:competencyDescription "Conocer los principios y las técnicas de medida de las magnitudes más relevantes en Ingeniería Biomédica."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000327/2025-26/CE42> a ns1:Competency ;
    ns1:competencyCode "CE42" ;
    ns1:competencyDescription "Conocer técnicas de muestreo y procesado de señales e imágenes para diversas aplicaciones en relación con la Ingeniería Biomédica."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000327/2025-26/CE43> a ns1:Competency ;
    ns1:competencyCode "CE43" ;
    ns1:competencyDescription "Capacidad de análisis e interpretación de señales e imágenes biomédicas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000327/2025-26/CG15> a ns1:Competency ;
    ns1:competencyCode "CG15" ;
    ns1:competencyDescription "Transmitir la información adquirida, las ideas, los problemas y las soluciones de forma oral y escrita en castellano e inglés."@es .

