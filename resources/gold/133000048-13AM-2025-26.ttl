    ns1:competencyDescription "Participar en proyectos o colaboraciones científicas/tecnológicas en contextos interdisciplinares y multiculturales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000048/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Capacidad para proponer, dirigir y realizar estudios para la caracterización del estado ecológico de masas de agua, así como de las acciones y obras encaminadas a su rehabilitación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000048/2025-26/CT4> a ns1:Competency ;
