<https://guia-kg.skai.etsisi.upm.es/resource/33000847/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Introducción la Gestión de Proyectos. Planificación Estratégica de Proyectos Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000847/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "2. Planificación Estratégica y control del Plazo Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000847/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "3. La gestión de proyectos territoriales. El lugar y el territorio. La adscripción de significados al lugar. Paisaje y sentido de lo construido. Paisaje Cultural. Gestión de proyectos de ingeniería y obras públicas Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000847/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "4. Planificación estratégica y control del Coste Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000847/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "5. La Evaluación Ambiental herramienta para la conservación del Patrimonio Cultural Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000847/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "6. El \"paisaje cultural\" como Patrimonio Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000847/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "7. La construcción del paisaje. Metodologías actuales de documentación e intervención en los paisajes culturales Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000847/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "8. Planificación estratégica y control del Riesgo Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000847/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "9. La Evaluación de Impacto Ambiental en los proyectos de Patrimonio Cultural. Sostenibilidad de las actuaciones Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000847/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "10. Aplicaciones y nuevas tecnologías para la gestión de proyectos territoriales. Sistemas de gestión georreferenciados. Usos de dispositivos móviles. Aplicaciones prácticas de proyectos de gestión de patrimonio cultural en curso Sin subniveles"@es .

