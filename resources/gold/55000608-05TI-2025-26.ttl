<https://guia-kg.skai.etsisi.upm.es/resource/55000608> a ns1:Course ;
    ns1:courseType "Optativa"@es ;
    ns1:courseYear 4 ;
    ns1:semester "Octavo semestre"@es ;
    schema:courseCode 55000608 ;
    schema:hasCourseInstance <https://guia-kg.skai.etsisi.upm.es/resource/55000608/2025-26> ;
    schema:name "Marketing Research"@en,
        "Investigacion de Mercados"@es ;
    schema:numberOfCredits 3.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/55000608/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/55000608/2025-26/CE28F>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55000608/2025-26/CG10>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55000608/2025-26/CG3>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55000608/2025-26/CG4>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55000608/2025-26/CG5>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55000608/2025-26/CG6> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/55000608/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55000608/2025-26/didactic_resource/2> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/55000608/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/55000608/2025-26/RA332>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55000608/2025-26/RA333>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55000608/2025-26/RA334>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55000608/2025-26/RA335> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/55000608/2025-26/syllabus> ;
    ns1:inpersonHours "32 horas y 30 minutos (41.7%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation """Los recursos didácticos, se van actualizando permanentemente durante el desarrollo del curso académico. Se utilizan muchos vídeos de las nuevas técnicas de investigación de mercados: Big Data, Redes Sociales. Casos y artículos actuales.
Las herramientas de análisis estratégico implica una consideración transversal de los ODS como condicionantes o metas de las empresas, con relación más directa con los de contenido económico como son el ODS8, ODS9, ODS10 y ODS12."""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "32 horas y 30 minutos"@es ;
    schema:activitiesWorkload "90%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/55000608/2025-26/eventSchedule> ;
    schema:description "Es una asignatura basada en el aprendizaje de las distintas herramientas de investigación de mercados que se utilizan para la obtención y análisis de los datos del mundo empresarial. Se aplican técnicas cualitativas y cuantitativas que mejor se ajusten al tipo de investigación que necesita la empresa. La metodología principal de aprendizaje es la resolución de un problema del mercado o de una empresa (escogido desde el principio de la asignatura) utilizando las técnicas impartidas en clase y analizando la información obtenida de la aplicación de cada una de las herramientas."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/teresa.sanchez%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/fernando.onrubia%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/miguelangel.pelaez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/teresa.sanchez%40upm.es> ;
    schema:name "Investigacion de Mercados"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000608/2025-26/CE28F> a ns1:Competency ;
    ns1:competencyCode "CE28F" ;
    ns1:competencyDescription "Conocimiento de la metodología y métodos cuantitativos de diseño de estrategias comerciales, seguimiento de las mismas y medidas de efectividad."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000608/2025-26/CG10> a ns1:Competency ;
    ns1:competencyCode "CG10" ;
    ns1:competencyDescription "Capacidad para generar nuevas ideas (Creatividad)."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000608/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Aplicar los conocimientos adquiridos para identificar, formular y resolver problemas dentro de contextos amplios y multidisciplinarios, siendo capaces de integrar conocimientos, trabajando en equipos multidisciplinares."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000608/2025-26/CG4> a ns1:Competency ;
    ns1:competencyCode "CG4" ;
    ns1:competencyDescription "Comprender el impacto de la ingeniería industrial en el medio ambiente, el desarrollo sostenible de la sociedad y la importancia de trabajar en un entorno profesional y responsable."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000608/2025-26/CG5> a ns1:Competency ;
    ns1:competencyCode "CG5" ;
    ns1:competencyDescription "Saber comunicar los conocimientos y conclusiones, de forma oral, escrita y gráfica, a públicos especializados y no especializados de un modo claro y sin ambigüedades."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000608/2025-26/CG6> a ns1:Competency ;
    ns1:competencyCode "CG6" ;
    ns1:competencyDescription "Poseer habilidades de aprendizaje que permitan continuar estudiando a lo largo de la vida para su adecuado desarrollo profesional."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000608/2025-26/RA332> a ns1:LearningResult ;
    ns1:learningResultCode "RA332" ;
    ns1:learningResultDescription "Investigación de mercados: Aprender a diseñar un proyecto de Investigación de Mercados."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000608/2025-26/RA333> a ns1:LearningResult ;
    ns1:learningResultCode "RA333" ;
    ns1:learningResultDescription "Conocer las principales técnicas y sus fundamentos así como casos claros de aplicación de las mismas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000608/2025-26/RA334> a ns1:LearningResult ;
    ns1:learningResultCode "RA334" ;
    ns1:learningResultDescription "Interpretar y analizar la información obtenida de los estudios."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000608/2025-26/RA335> a ns1:LearningResult ;
    ns1:learningResultCode "RA335" ;
    ns1:learningResultDescription "Conocer los Estudios estandar más comúnmente empleados disponibles en el mercado..."@es .

