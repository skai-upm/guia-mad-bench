<https://guia-kg.skai.etsisi.upm.es/resource/205000082/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Tema 1. Conceptos básicos de la protección de cultivos."@es .

