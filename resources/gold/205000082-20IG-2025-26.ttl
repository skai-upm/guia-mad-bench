    ns1:itemIndex 12 ;
    ns1:syllabusDescription "3.3. Edopterygota: Coleoptera, Lepidoptera, Diptera, Hymenoptera y Neuroptera. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000082/2025-26/syllabus/13> a ns1:SyllabusItem ;
