<https://guia-kg.skai.etsisi.upm.es/resource/43000397> a ns1:Course ;
    ns1:courseType "Optativa"@es ;
    ns1:courseYear 2 ;
    ns1:semester "Cuarto semestre"@es ;
    schema:courseCode 43000397 ;
    schema:hasCourseInstance <https://guia-kg.skai.etsisi.upm.es/resource/43000397/2025-26> ;
    schema:name "Structural Composite Materials"@en,
        "Materiales Compuestos Estructurales"@es ;
    schema:numberOfCredits 4.5 .

<https://guia-kg.skai.etsisi.upm.es/resource/43000397/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/43000397/2025-26/CE20>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000397/2025-26/CE23> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/43000397/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000397/2025-26/didactic_resource/2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000397/2025-26/didactic_resource/3>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000397/2025-26/didactic_resource/4> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/43000397/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/43000397/2025-26/RA86> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/43000397/2025-26/syllabus> ;
    ns1:inpersonHours "45 horas (38.5%)"@es ;
    ns1:numberOfCredits 4.5 ;
    ns1:otherInformation "En caso de necesidad por razones sanitarias, las actividades docentes y de evaluación pasarán a tener lugar en modalidad telemática."@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "49 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/43000397/2025-26/eventSchedule> ;
    schema:description "El objetivo de este curso es proporcionar a los estudiantes una visión general del campo de los materiales compuestos, incluyendo las técnicas de fabricación, las relaciones estructura-propiedades, el diseño mecánico de laminados y el comportamiento en condiciones de servicio"@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/javier.llorca%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/alvaro.ridruejo%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/c.gonzalez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/javier.llorca%40upm.es> ;
    schema:name "Materiales Compuestos Estructurales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000397/2025-26/CE20> a ns1:Competency ;
    ns1:competencyCode "CE20" ;
    ns1:competencyDescription "Comprensión y dominio de las leyes de la termomecánica de los medios continuos y capacidad para su aplicación en ámbitos propios de la ingeniería como son la mecánica de fluidos, la mecánica de materiales, la teoría de estructuras, etc."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000397/2025-26/CE23> a ns1:Competency ;
    ns1:competencyCode "CE23" ;
    ns1:competencyDescription "Conocimiento de todo tipo de estructuras y sus materiales, y capacidad para diseñar, proyectar, ejecutar y mantener las estructuras y edificaciones de obra civil."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000397/2025-26/RA86> a ns1:LearningResult ;
    ns1:learningResultCode "RA86" ;
    ns1:learningResultDescription "Diseña y calcula estructuras con materiales compuestos"@es .

