<https://guia-kg.skai.etsisi.upm.es/resource/143005027/2025-26/CE10> a ns1:Competency ;
    ns1:competencyCode "CE10" ;
    ns1:competencyDescription "Comprender la problemática propia de los sistemas electrónicos terrestres y embarcados en los diferentes elementos del Sistema del Transporte Aéreo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005027/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Poseer y comprender conocimientos que aporten una base u oportunidad de ser originales en el desarrollo de nuevos conceptos y técnicas aplicados al Sistema del Transporte Aéreo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005027/2025-26/CG5> a ns1:Competency ;
    ns1:competencyCode "CG5" ;
    ns1:competencyDescription "Comprender la importancia de los efectos sobre el medio ambiente en el desarrollo de la actividad de diseño a operación de los Sistemas del Transporte Aéreo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005027/2025-26/CG6> a ns1:Competency ;
    ns1:competencyCode "CG6" ;
    ns1:competencyDescription "Que los estudiantes posean las habilidades de aprendizaje que les permitan continuar estudiando de un modo que habrá de ser en gran medida autodirigido o autónomo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005027/2025-26/CT3> a ns1:Competency ;
    ns1:competencyCode "CT3" ;
    ns1:competencyDescription "Gestionar la información, identificando las fuentes necesarias, los principales tipos de documentos técnicos y científicos que son de aplicación en el entorno de los Sistemas del Transporte Aéreo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005027/2025-26/RA66> a ns1:LearningResult ;
    ns1:learningResultCode "RA66" ;
    ns1:learningResultDescription "El/La alumno/a aprende las características generales de la energía eléctrica a bordo y las partes y los equipos principales del sistema eléctrico de las aeronaves y sistemas espaciales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005027/2025-26/RA67> a ns1:LearningResult ;
    ns1:learningResultCode "RA67" ;
    ns1:learningResultDescription "El/La alumno/a aprende cuáles son los consumidores de energía eléctrica, sus valores característicos más relevantes y a realizar un análisis de cargas y elección de fuentes"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005027/2025-26/RA68> a ns1:LearningResult ;
    ns1:learningResultCode "RA68" ;
    ns1:learningResultDescription "El/La alumno/a aprende las principales características funcionales de las fuentes de potencia eléctrica, tanto primarias como secundarias en las aeronaves y los sistemas espaciales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005027/2025-26/RA69> a ns1:LearningResult ;
    ns1:learningResultCode "RA69" ;
    ns1:learningResultDescription "El/La alumno/a aprende las misiones y principales componentes de los subsistemas de distribución, mando, protección y señalización"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005027/2025-26/RA70> a ns1:LearningResult ;
    ns1:learningResultCode "RA70" ;
    ns1:learningResultDescription "El/La alumno/a aprende de forma general los procesos de integración y ensayos de los sistemas de generación y gestión de potencia eléctrica, su normativa, y la certificación de los mismos"@es .

