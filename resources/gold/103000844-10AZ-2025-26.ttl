    ns1:numberOfCredits 5.0 ;
    ns1:otherInformation """This course covers topics such as leadership, business development, business finance, marketing, innovation management, intellectual property, and/or market research.
You will need to choose one course from a selection of 2-3 electives. Information about which electives will be offered this year will be updated a few months before the course begins."""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "59 horas y 45 minutos"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/103000844/2025-26/eventSchedule> ;
    schema:description "Several elective I&E seminars/courses will be offered covering advanced topics on any of the following: business development, business finance, marketing, innovation management, intellectual property and market research."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/javier.segovia%40upm.es> ;
    schema:inLanguage "Inglés"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/claudio.feijoo%40upm.es>,
