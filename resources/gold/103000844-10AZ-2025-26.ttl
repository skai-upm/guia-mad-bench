<https://guia-kg.skai.etsisi.upm.es/resource/103000844/2025-26/CG03> a ns1:Competency ;
    ns1:competencyCode "CG03" ;
    ns1:competencyDescription "La capacidad de usar la lengua inglesa de manera competente, es decir, con capacitación para tareas complejas de trabajo y estudio/ The ability to use the English language in a competent way, i.e., with training for work and study complex tasks."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000844/2025-26/CG07> a ns1:Competency ;
    ns1:competencyCode "CG07" ;
    ns1:competencyDescription "Capacidad de trabajar y comunicarse también en contextos internacionales/ To be able to communicate and work in international contexts."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000844/2025-26/CG08> a ns1:Competency ;
    ns1:competencyCode "CG08" ;
    ns1:competencyDescription "La capacidad de traducir innovaciones en soluciones comerciales factibles/ To be able to translate innovations into feasible business solutions."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000844/2025-26/RA78> a ns1:LearningResult ;
    ns1:learningResultCode "RA78" ;
    ns1:learningResultDescription "Understand global/market trends, innovation routes, industry value networks in a thematic area and recognize their relative importance for product/service and business development"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000844/2025-26/RA79> a ns1:LearningResult ;
    ns1:learningResultCode "RA79" ;
    ns1:learningResultDescription "Identify and assess the impact of ICT technologies and innovations in a thematic area, on its markets and stakeholders (competitors, alliances, networks) and the business opportunities they offer."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000844/2025-26/RA80> a ns1:LearningResult ;
    ns1:learningResultCode "RA80" ;
    ns1:learningResultDescription "Use knowledge, ideas and technology to create new or significantly improved products, services, processes, policies, new business models or jobs in a real environment"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000844/2025-26/RA81> a ns1:LearningResult ;
    ns1:learningResultCode "RA81" ;
    ns1:learningResultDescription "Conduct a business analysis, make decisions and formulate recommendations or justify actions in a real environment"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000844/2025-26/RA82> a ns1:LearningResult ;
    ns1:learningResultCode "RA82" ;
    ns1:learningResultDescription "In depth understanding of product/services design processes, methods and tools"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000844/2025-26/RA83> a ns1:LearningResult ;
    ns1:learningResultCode "RA83" ;
    ns1:learningResultDescription "Apply agile and lean processes for the development of a new product or service concept with a customer/user"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000844/2025-26/RA84> a ns1:LearningResult ;
    ns1:learningResultCode "RA84" ;
    ns1:learningResultDescription "Perform a business solution planning and development process (dynamics of developing the business, organization needed to implement it, go"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000844/2025-26/RA85> a ns1:LearningResult ;
    ns1:learningResultCode "RA85" ;
    ns1:learningResultDescription "Include ethical, societal and sustainability considerations when developing a new product/technology and business concepts and models, and the required implementing organizations"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000844/2025-26/RA86> a ns1:LearningResult ;
    ns1:learningResultCode "RA86" ;
    ns1:learningResultDescription "Recognize, address and suggest means to tackle diverse challenges (maturity, IPR) in the process of leveraging a technology into a business"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000844/2025-26/RA87> a ns1:LearningResult ;
    ns1:learningResultCode "RA87" ;
    ns1:learningResultDescription "Identify and assess the impact of ICT technologies and innovations in a thematic area, on its markets and stakeholders (competitors, alliances, networks) and the business opportunities they offer"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000844/2025-26/RA91> a ns1:LearningResult ;
    ns1:learningResultCode "RA91" ;
    ns1:learningResultDescription "Produce a professional speech and writing on a business analysis topic"@es .

