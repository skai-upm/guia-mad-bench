    ns1:competencyDescription "Conocer los desarrollos teórico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000049/2025-26/CON16.CE20.> a ns1:Competency ;
    ns1:competencyCode "CON16.CE20." ;
    ns1:competencyDescription "Adquirir criterios de selección y elaboración de materiales educativos. TIPO: Conocimientos o contenidos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000049/2025-26/HAB1.CG2.> a ns1:Competency ;
    ns1:competencyCode "HAB1.CG2." ;
    ns1:competencyDescription "Planificar, desarrollar y evaluar el proceso de enseñanza y aprendizaje potenciando procesos educativos que faciliten la adquisición de las competencias propias de las respectivas enseñanzas, atendiendo al nivel y formación previa de los estudiantes, así como la orientación de los mismos, tanto individualmente como en colaboración con otros docentes y profesionales del centro. TIPO: Habilidades o destrezas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000049/2025-26/HAB15.CE19.> a ns1:Competency ;
    ns1:competencyCode "HAB15.CE19." ;
    ns1:competencyDescription "Transformar los currículos en programas de actividades y de trabajo. TIPO: Habilidades o destrezas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000049/2025-26/HAB17.CE22.> a ns1:Competency ;
    ns1:competencyCode "HAB17.CE22." ;
    ns1:competencyDescription "Integrar la formación en comunicación audiovisual y multimedia en el proceso de enseñanza"@es .

