    ns1:itemIndex 8 ;
    ns1:syllabusDescription "1.3.2. Combustibles. Propiedades. Clasificación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000165/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "1.3.2.1. Combustibles fósiles Sin subniveles"@es .

