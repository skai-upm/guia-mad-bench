    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/93000797/2025-26/eventSchedule> ;
    schema:description "Se pretende capacitar a los alumnos para abordar el diseño de redes de comunicaciones, teniendo en cuenta parámetros como los servicios que se deben ofrecer, la calidad de los mismos, las características de las tecnologías de red disponibles, aspectos regulatorios y económicos, así como la tecnológica prevista a medio plazo. El alumno deberá abordar en grupo el diseño y defensa de una red de telecomunicaciones para un determinado escenario orientada al negocio de una operadora de telecomunicaciones."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/joseignacio.moreno%40upm.es> ;
    schema:inLanguage "Inglés/Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/diego.rivera%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/joseignacio.moreno%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/morten.geday%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/p.rhorche%40upm.es> ;
    schema:name "Redes de Comunicaciones"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000797/2025-26/CE4> a ns1:Competency ;
    ns1:competencyCode "CE4" ;
    ns1:competencyDescription "Capacidad para diseñar y dimensionar redes de transporte, difusión y distribución de señales multimedia."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000797/2025-26/CE6> a ns1:Competency ;
    ns1:competencyCode "CE6" ;
    ns1:competencyDescription "Capacidad para modelar, diseñar, implantar, gestionar, operar, administrar y mantener redes, servicios y contenidos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000797/2025-26/CE7> a ns1:Competency ;
    ns1:competencyCode "CE7" ;
    ns1:competencyDescription "Capacidad para realizar la planificación, toma de decisiones y empaquetamiento de redes, servicios y aplicaciones considerando la calidad de servicio, los costes directos y de operación, el plan de implantación, supervisión, los procedimientos de seguridad, el escalado y el mantenimiento, así como gestionar y asegurar la calidad en el proceso de desarrollo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000797/2025-26/CE8> a ns1:Competency ;
    ns1:competencyCode "CE8" ;
    ns1:competencyDescription "Capacidad de comprender y saber aplicar el funcionamiento y organización de Internet, las tecnologías y protocolos de Internet de nueva generación, los modelos de componentes, software intermediario y servicios."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000797/2025-26/CE9> a ns1:Competency ;
    ns1:competencyCode "CE9" ;
    ns1:competencyDescription "Capacidad para resolver la convergencia, interoperabilidad y diseño de redes heterogéneas con redes locales, de acceso y troncales, así como la integración de servicios de telefonía, datos, televisión e interactivos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000797/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Poseer y comprender conocimientos que aporten una base u oportunidad de ser originales en el desarrollo y/o aplicación de ideas, a menudo en un contexto de investigación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000797/2025-26/CG2> a ns1:Competency ;
    ns1:competencyCode "CG2" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en entornos nuevos o poco conocidos dentro de contextos más amplios (o multidisciplinares) relacionados con su área de estudio."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000797/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de integrar conocimientos y enfrentarse a la complejidad de formular juicios a partir de una información que, siendo incompleta o limitada, incluya reflexiones sobre las responsabilidades sociales y éticas vinculadas a la aplicación de sus conocimientos y juicios."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000797/2025-26/CG4> a ns1:Competency ;
    ns1:competencyCode "CG4" ;
    ns1:competencyDescription "Que los estudiantes sepan comunicar sus conclusiones ?y los conocimientos y razones últimas que las sustentan? a públicos especializados y no especializados de un modo claro y sin ambigüedades."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000797/2025-26/CG5> a ns1:Competency ;
    ns1:competencyCode "CG5" ;
    ns1:competencyDescription "Que los estudiantes posean las habilidades de aprendizaje que les permitan continuar estudiando de un modo que habrá de ser en gran medida autodirigido o autónomo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000797/2025-26/CT2> a ns1:Competency ;
    ns1:competencyCode "CT2" ;
    ns1:competencyDescription "Capacidad para dinamizar y liderar equipos de trabajo multidisciplinares."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000797/2025-26/CT3> a ns1:Competency ;
    ns1:competencyCode "CT3" ;
    ns1:competencyDescription "Capacidad para adoptar soluciones creativas que satisfagan adecuadamente las diferentes necesidades planteadas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000797/2025-26/CT4> a ns1:Competency ;
    ns1:competencyCode "CT4" ;
    ns1:competencyDescription "Capacidad para trabajar de forma efectiva como individuo, organizando y planificando su propio trabajo, de forma independiente o como miembro de un equipo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000797/2025-26/CT5> a ns1:Competency ;
    ns1:competencyCode "CT5" ;
    ns1:competencyDescription "Capacidad para gestionar la información, identificando las fuentes necesarias, los principales tipos de documentos técnicos y científicos, de una manera adecuada y eficiente."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000797/2025-26/CT6> a ns1:Competency ;
    ns1:competencyCode "CT6" ;
    ns1:competencyDescription "Capacidad para emitir juicios sobre implicaciones económicas, administrativas, sociales, éticas y medioambientales ligadas a la aplicación de sus conocimientos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000797/2025-26/RA1> a ns1:LearningResult ;
    ns1:learningResultCode "RA1" ;
    ns1:learningResultDescription "Conocer estándares y protocolos utilizados en el desarrollo de aplicaciones orientadas a servicios. Comprender el funcionamiento de aplicaciones software constituidas por un conjunto de servicios interactuando, coordinados por procesos de negocio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000797/2025-26/RA11> a ns1:LearningResult ;
    ns1:learningResultCode "RA11" ;
    ns1:learningResultDescription "El alumno es capaz de conocer la arquitectura de una red de telefonía IP, conocer sus segmentos, elementos constituyentes y órdenes de magnitud de su número y capacidades"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000797/2025-26/RA2> a ns1:LearningResult ;
    ns1:learningResultCode "RA2" ;
    ns1:learningResultDescription "Conocer infraestructuras y herramientas para la provisión de servicios compartiendo recursos, incluyendo tecnologías de virtualización y de computación en la nube"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000797/2025-26/RA251> a ns1:LearningResult ;
    ns1:learningResultCode "RA251" ;
    ns1:learningResultDescription "Habilidad para diseñar y dimensionar un sistema de aplicación completo que integre partes tanto de procesado de señal como de gestión de información, de forma práctica, en grupo y con una orientación profesional al trabajo en una empresa."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000797/2025-26/RA29> a ns1:LearningResult ;
    ns1:learningResultCode "RA29" ;
    ns1:learningResultDescription "Habilidad para diseñar y dimensionar un sistema de comunicaciones que integre partes tanto fijas como móviles, de forma práctica, en grupo y con una orientación profesional al trabajo en una empresa"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000797/2025-26/RA3> a ns1:LearningResult ;
    ns1:learningResultCode "RA3" ;
    ns1:learningResultDescription "Conocer los procesos de desarrollo de aplicaciones y servicios más utilizados en las empresas del sector"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000797/2025-26/RA33> a ns1:LearningResult ;
    ns1:learningResultCode "RA33" ;
    ns1:learningResultDescription "Capacidad para abordar y desarrollar en grupo casos prácticos de análisis, diseño, dimensionamiento, simulación, pruebas y su gestión técnico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000797/2025-26/RA4> a ns1:LearningResult ;
    ns1:learningResultCode "RA4" ;
    ns1:learningResultDescription "Conocer los métodos de ingeniería útiles en el desarrollo y operación de aplicaciones y servicios"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000797/2025-26/RA41> a ns1:LearningResult ;
    ns1:learningResultCode "RA41" ;
    ns1:learningResultDescription "Capacidad de presentar los resultados de lo anterior en grupo de forma oral y escrita"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000797/2025-26/RA5> a ns1:LearningResult ;
    ns1:learningResultCode "RA5" ;
    ns1:learningResultDescription "Comprender los problemas que plantea la gestión con métodos tradicionales de grandes volúmenes de datos, variados y en constante creación, y entender la necesidad de nuevas técnicas para procesar y almacenar este tipo de datos (BigData). Conocer técnicas de procesamiento, gestión y almacenamiento de grandes volúmenes de datos, y plataformas que facilitan estas tareas, incluyendo la experimentación de casos de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000797/2025-26/RA6> a ns1:LearningResult ;
    ns1:learningResultCode "RA6" ;
    ns1:learningResultDescription "Conocer los criterios básicos de calidad, gestión de la identidad y privacidad que deben cumplir las aplicaciones y servicios web y saber cómo aplicarlos al diseño y evaluación de sitios web"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000797/2025-26/RA7> a ns1:LearningResult ;
    ns1:learningResultCode "RA7" ;
    ns1:learningResultDescription "Comprender los distintos modelos y posibilidades de negocio de los servicios y aplicaciones Web y su influencia en la selección de tecnologías"@es .

