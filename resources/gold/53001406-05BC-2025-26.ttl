        <https://guia-kg.skai.etsisi.upm.es/resource/53001406/2025-26/RA161>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001406/2025-26/RA61>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001406/2025-26/RA91>,
