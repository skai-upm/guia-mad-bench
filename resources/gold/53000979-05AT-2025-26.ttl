<https://guia-kg.skai.etsisi.upm.es/resource/53000979> a ns1:Course ;
    ns1:courseType "Optativa"@es ;
    ns1:courseYear 1 ;
    ns1:semester "Primer semestre"@es ;
    schema:courseCode 53000979 ;
    schema:hasCourseInstance <https://guia-kg.skai.etsisi.upm.es/resource/53000979/2025-26> ;
    schema:name "Road Accident Investigation"@en,
        "Investigacion Cientifica de Accidentes"@es ;
    schema:numberOfCredits 3.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/53000979/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/53000979/2025-26/CE7>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53000979/2025-26/CG%201>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53000979/2025-26/CG%204> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/53000979/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53000979/2025-26/didactic_resource/2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53000979/2025-26/didactic_resource/3> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/53000979/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/53000979/2025-26/RA55>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53000979/2025-26/RA56>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53000979/2025-26/RA57>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53000979/2025-26/RA58>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53000979/2025-26/RA59> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/53000979/2025-26/syllabus> ;
    ns1:inpersonHours "31 horas (39.7%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation "Esta asignatura se centra en el ámbito de la seguridad vial, por lo que se trabaja en la misma el Objetivo de Desarrollo Sostenible 11, y más concretamente la meta 11.2 (de aquí a 2030, proporcionar acceso a sistemas de transporte seguros, asequibles, accesibles y sostenibles para todos y mejorar la seguridad vial)"@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "35 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/53000979/2025-26/eventSchedule> ;
    schema:description """La asignatura engloba los dos tipos de metodologías de investigación científica de accidentes:
Investigación de accidentes en profundidad para accidentes individuales (nivel micro).
Modelos estadísticos avanzados para el estudio de accidentes a nivel agregado en un contexto nacional o regional.
En cada uno de los enfoques se presentan los enfoques metodológicos y herramientas (programas informáticos de reconstrucción, equipamiento, etc) más actuales y se proponen ejercicios específicos a los alumnos."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/franciscojavier.paez%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/blanca.arenas%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/franciscojavier.paez%40upm.es> ;
    schema:name "Investigacion Cientifica de Accidentes"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000979/2025-26/CE7> a ns1:Competency ;
    ns1:competencyCode "CE7" ;
    ns1:competencyDescription "Analizar y diseñar vehículos y sistemas vehiculares e interpretar los comportamientos de los principales sistemas vehiculares para su aplicación al diseño y evaluación de sus comportamientos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000979/2025-26/CG%201> a ns1:Competency ;
    ns1:competencyCode "CG 1" ;
    ns1:competencyDescription "Aplicar conocimientos de ciencias y tecnologías avanzadas a la práctica de la Ingeniería Mecánica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000979/2025-26/CG%204> a ns1:Competency ;
    ns1:competencyCode "CG 4" ;
    ns1:competencyDescription "Valorar el impacto de la ingeniería mecánica en el medio ambiente, el desarrollo sostenible de la sociedad y la importancia de trabajar en un entorno profesional y responsable"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000979/2025-26/RA55> a ns1:LearningResult ;
    ns1:learningResultCode "RA55" ;
    ns1:learningResultDescription "Adquirir una visión holística del problema de la accidentalidad en carretera en España"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000979/2025-26/RA56> a ns1:LearningResult ;
    ns1:learningResultCode "RA56" ;
    ns1:learningResultDescription "Conocer los factores de influencia sobre la ocurrencia de accidentes de tráfico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000979/2025-26/RA57> a ns1:LearningResult ;
    ns1:learningResultCode "RA57" ;
    ns1:learningResultDescription "Adquirir un conocimiento de los enfoques micro y macro de la investigación científica de accidentes de tráfico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000979/2025-26/RA58> a ns1:LearningResult ;
    ns1:learningResultCode "RA58" ;
    ns1:learningResultDescription "Conocer metodologías estadísticas avanzadas de la investigación científica de accidentes"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000979/2025-26/RA59> a ns1:LearningResult ;
    ns1:learningResultCode "RA59" ;
    ns1:learningResultDescription "Aprender a manejar programas para la investigación científica de accidentes"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000979/2025-26/didactic_resource/1> a ns1:DidacticResource ;
    ns1:bibliographyDescription """- ACCIDENTES DE TRÁFICO: INTRODUCCIÓN AL ANÁLISIS DE DEFORMACIONES. EDITORIAL PONS, MADRID, 2006, ISBN 978-84-95044 71-6.
- ACCIDENTES DE TRÁFICO: MANUAL BÁSICO DE INVESTIGACIÓN Y RECONSTRUCCIÓN. EDITORIAL PONS, 2005, ISBN 84-95475-21-9."""@es ;
    ns1:bibliographyTitle "Documentación para alumnos"@es ;
