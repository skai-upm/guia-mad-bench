    ns1:learningResultDescription "Interpretar la normativa vigente de acciones en estructuras: CTS, EC, IAP."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000231/2025-26/RA55> a ns1:LearningResult ;
