    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/133000231/2025-26/RA49>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000231/2025-26/RA50>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000231/2025-26/RA52>,
