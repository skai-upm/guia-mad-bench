    ns1:inpersonHours "42 horas y 30 minutos (52.5%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation "La asignatura permite trabajar el ODS 12 sobre producción y consumo responsables (Garantizar modalidades de consumo y producción sostenibles) establecido por Naciones Unidas"@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "42 horas y 30 minutos"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/55001077/2025-26/eventSchedule> ;
    schema:description """La asignatura describe los fundamentos científicos y las aplicaciones de algunas de las principales técnicas instrumentales utilizadas en el análisis y caracterización de materiales.
El objetivo final de la asignatura es que alumno conozca diferentes técnicas instrumentales disponibles en la actualidad para el análisis y caracterización de materiales utilizados en ingeniería y sepa seleccionar las más adecuadas, en función de sus posibilidades y limitaciones.
La asignatura se estructura en 5 módulos, además de uno inicial de información general.
Se utilizará la plataforma de telenseñanza Moodle y de trabajo colaborativo Teams como parte de la metodología docente en apoyo a la enseñanza presencial.
La asignatura incluye la realización de prácticas de laboratorio y la resolución y entrega de cuestiones sobre su contenido durante el desarrollo de las mismas.
Además, el alumno tendrá que elaborar un trabajo escrito relacionado con el contenido de la asignatura que deberá defender oralmente ante el profesor y resto de estudiantes, ayudándose de una presentación en PowerPoint o similar."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/ana.garcia.ruiz%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/ana.garcia.ruiz%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/mohammed.naffakh%40upm.es> ;
    schema:name "Análisis Instrumental"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001077/2025-26/CE27C> a ns1:Competency ;
    ns1:competencyCode "CE27C" ;
    ns1:competencyDescription "Conocimientos y capacidades para la aplicación de la ingeniería de materiales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001077/2025-26/CG2> a ns1:Competency ;
    ns1:competencyCode "CG2" ;
    ns1:competencyDescription "Poseer capacidad para diseñar, desarrollar, implementar, gestionar y mejorar productos, sistemas y procesos en los distintos ámbitos industriales, usando técnicas analíticas, computacionales o experimentales apropiadas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001077/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Aplicar los conocimientos adquiridos para identificar, formular y resolver problemas dentro de contextos amplios y multidisciplinarios, siendo capaces de integrar conocimientos, trabajando en equipos multidisciplinares."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001077/2025-26/CG5> a ns1:Competency ;
    ns1:competencyCode "CG5" ;
    ns1:competencyDescription "Saber comunicar los conocimientos y conclusiones, de forma oral, escrita y gráfica, a públicos especializados y no especializados de un modo claro y sin ambigüedades."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001077/2025-26/CG6> a ns1:Competency ;
    ns1:competencyCode "CG6" ;
    ns1:competencyDescription "Poseer habilidades de aprendizaje que permitan continuar estudiando a lo largo de la vida para su adecuado desarrollo profesional."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001077/2025-26/RA578> a ns1:LearningResult ;
    ns1:learningResultCode "RA578" ;
    ns1:learningResultDescription "Conocer diferentes técnicas instrumentales disponibles en la actualidad para el análisis y caracterización de materiales utilizados en ingeniería"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001077/2025-26/RA579> a ns1:LearningResult ;
