    ns1:competencyCode "CG7" ;
    ns1:competencyDescription "Conocimiento y capacidad para la selección adecuada de fuentes de energía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003022/2025-26/CT13> a ns1:Competency ;
    ns1:competencyCode "CT13" ;
    ns1:competencyDescription "Habilidad para diseñar un sistema, componente o proceso que alcance los requisitos deseados teniendo en cuenta restricciones realistas tales como las económicas, medioambientales, sociales, políticas, éticas, de salud y seguridad, de fabricación y de sostenibilidad"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003022/2025-26/CT6> a ns1:Competency ;
    ns1:competencyCode "CT6" ;
    ns1:competencyDescription "Capacidad de organización y Planificación"@es .

