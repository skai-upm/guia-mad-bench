    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/65004041/2025-26/eventSchedule> ;
    schema:description "La asignatura cuatrimestral obligatoria \"Calor y Frío Industrial\", se imparte en el 5º semestre la titulación Graduado en Ingeniería de la Energía (código 65004041). Tiene una asignación lectiva de 4.5 ECTS, repartidos a lo largo de 14 semanas, con una dedicación de 3 h/semana, por lo tanto su programa es cubierto en un total de 42 horas lectivas, las cuales se reparten equitativamente entre clases de teoría y de problemas."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/javier.munoz.anton%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/javier.munoz.anton%40upm.es> ;
    schema:name "Calor y Frio Industrial"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004041/2025-26/CE20> a ns1:Competency ;
    ns1:competencyCode "CE20" ;
    ns1:competencyDescription "Comprender los conceptos de la termodinámica y aplicarlos en la Ingeniería de la Energía."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004041/2025-26/CE23> a ns1:Competency ;
    ns1:competencyCode "CE23" ;
    ns1:competencyDescription "Aplicar los conceptos básicos de la transferencia de calor y materia en la Ingeniería de la Energía."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004041/2025-26/CE38> a ns1:Competency ;
    ns1:competencyCode "CE38" ;
    ns1:competencyDescription "Aplicar los conocimientos de generación y distribución de calor o frío a instalaciones industriales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004041/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Conocer y aplicar conocimientos de ciencias y tecnologías básicas a la práctica de la Ingeniería de la Energía."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004041/2025-26/CG5> a ns1:Competency ;
    ns1:competencyCode "CG5" ;
    ns1:competencyDescription "Saber comunicar los conocimientos y conclusiones, tanto de forma oral, escrita y gráfica, a públicos especializados y no especializados de un modo claro y sin ambigüedades."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004041/2025-26/CG6> a ns1:Competency ;
    ns1:competencyCode "CG6" ;
    ns1:competencyDescription "Poseer habilidades de aprendizaje que permitan continuar estudiando a lo largo de la vida para su adecuado desarrollo profesional."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004041/2025-26/CG7> a ns1:Competency ;
    ns1:competencyCode "CG7" ;
    ns1:competencyDescription "Incorporar nuevas tecnologías y herramientas de la Ingeniería Energética en sus actividades profesionales."@es .

