        <https://guia-kg.skai.etsisi.upm.es/resource/135003073/2025-26/didactic_resource/8> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/135003073/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/135003073/2025-26/RA210>,
        <https://guia-kg.skai.etsisi.upm.es/resource/135003073/2025-26/RA211>,
        <https://guia-kg.skai.etsisi.upm.es/resource/135003073/2025-26/RA212>,
        <https://guia-kg.skai.etsisi.upm.es/resource/135003073/2025-26/RA213>,
        <https://guia-kg.skai.etsisi.upm.es/resource/135003073/2025-26/RA224> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/135003073/2025-26/syllabus> ;
    ns1:inpersonHours "69 horas (44.2%)"@es ;
    ns1:numberOfCredits 6.0 ;
    ns1:otherInformation "La asignatura está relacionada con el ODS 3.9 (Para 2030, reducir sustancialmente el número de muertes y enfermedades producidas por productos químicos peligrosos y la contaminación del aire, el agua y el suelo) y el ODS 6.3 (De aquí a 2030, mejorar la calidad del agua reduciendo la contaminación, eliminando el vertimiento y minimizando la emisión de productos químicos y materiales peligrosos, reduciendo a la mitad el porcentaje de aguas residuales sin tratar y aumentando considerablemente el reciclado y la reutilización sin riesgos a nivel mundial.)"@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "77 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/135003073/2025-26/eventSchedule> ;
    schema:description "La asignatura proporciona los fundamentos teóricos y prácticos necesarios para la caracterización de emplazamientos potencialmente contaminados. Se abordarán los conceptos esenciales y las principales metodologías empleadas en la investigación de suelos y aguas subterráneas, con el objetivo de identificar, delimitar y evaluar la extensión y naturaleza de la contaminación. Asimismo, se introducirán las herramientas técnicas y normativas aplicables en el contexto de estudios ambientales."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/miguel.izquierdo%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/barbara.biosca%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/miguel.izquierdo%40upm.es> ;
    schema:name "Caracterización de Emplazamientos Contaminados"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003073/2025-26/CT18> a ns1:Competency ;
    ns1:competencyCode "CT18" ;
    ns1:competencyDescription "Habilidad para usar las técnicas, destrezas y herramientas ingenieriles modernas necesarias para la práctica de la ingeniería"@es .

