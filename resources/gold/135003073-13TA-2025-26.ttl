<https://guia-kg.skai.etsisi.upm.es/resource/135003073/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/135003073/2025-26/CT18> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/135003073/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/135003073/2025-26/didactic_resource/2>,
