<https://guia-kg.skai.etsisi.upm.es/resource/45001401/2025-26/RA5> a ns1:LearningResult ;
    ns1:learningResultCode "RA5" ;
    ns1:learningResultDescription "Explica y cuantifica las variables viarias y de tráfico que determinan la seguridad, la calidad y la sostenibilidad de las infraestructuras de transporte por carretera."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001401/2025-26/RA6> a ns1:LearningResult ;
    ns1:learningResultCode "RA6" ;
