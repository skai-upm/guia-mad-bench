        <https://guia-kg.skai.etsisi.upm.es/resource/rafaeleugenio.gonzalez%40upm.es> ;
    schema:name "Economía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145022003/2025-26/CB1> a ns1:Competency ;
    ns1:competencyCode "CB1" ;
    ns1:competencyDescription "Que los estudiantes hayan demostrado poseer y comprender conocimientos en un área de estudio que parte de la base de la educación secundaria general, y se suele encontrar a un nivel que, si bien se apoya en libros de texto avanzados, incluye también algunos aspectos que implican conocimientos procedentes de la vanguardia de su campo de estudio."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145022003/2025-26/CB3> a ns1:Competency ;
    ns1:competencyCode "CB3" ;
    ns1:competencyDescription "Que los estudiantes tengan la capacidad de reunir e interpretar datos relevantes (normalmente dentro de su área de estudio) para emitir juicios que incluyan una reflexión sobre temas relevantes de índole social, científica o ética"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145022003/2025-26/CFB6> a ns1:Competency ;
    ns1:competencyCode "CFB6" ;
    ns1:competencyDescription "Conocimiento adecuado del concepto de empresa, marco institucional y jurídico de la empresa. Organización y gestión de empresas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145022003/2025-26/CT%201> a ns1:Competency ;
    ns1:competencyCode "CT 1" ;
    ns1:competencyDescription "Capacidad de organización y de planificación."@es .

