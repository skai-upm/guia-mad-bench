    schema:name "Bioinformática"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504312/2025-26/CB01> a ns1:Competency ;
    ns1:competencyCode "CB01" ;
    ns1:competencyDescription "Que los estudiantes hayan demostrado poseer y comprender conocimientos en un área de estudio que parte de la base de la educación secundaria general, y se suele encontrar a un nivel que, si bien se apoya en libros de texto avanzados, incluye también algunos aspectos que implican conocimientos procedentes de la vanguardia de su campo de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504312/2025-26/CB04> a ns1:Competency ;
    ns1:competencyCode "CB04" ;
    ns1:competencyDescription "Que los estudiantes puedan transmitir información, ideas, problemas y soluciones a un público tanto especializado como no especializado"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504312/2025-26/CE07> a ns1:Competency ;
    ns1:competencyCode "CE07" ;
    ns1:competencyDescription "Capacidad de conocer y saber aplicar los métodos matemáticos, estadísticos y bioinformáticos básicos para el estudio, análisis y control de experimentos o procesos biotecnológicos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504312/2025-26/CE10> a ns1:Competency ;
    ns1:competencyCode "CE10" ;
    ns1:competencyDescription "Conocimientos básicos de elementos de programación y las bases para elaborar programas informáticos de aplicación en problemas de interés biotecnológico."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504312/2025-26/CE11> a ns1:Competency ;
    ns1:competencyCode "CE11" ;
    ns1:competencyDescription "Habilidad para buscar, obtener e interpretar la información de las principales bases de datos bibliográficos y biológicos (genómicos, transcriptómicos, proteómicos y metabolómicos) y elaborar información a partir de datos experimentales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504312/2025-26/CE12> a ns1:Competency ;
    ns1:competencyCode "CE12" ;
    ns1:competencyDescription "Ser capaz de conocer y aplicar procedimientos computacionales para el análisis de las secuencias biológicas y la construcción de modelos de sistemas biológicos a diferentes niveles de complejidad."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504312/2025-26/CG04> a ns1:Competency ;
    ns1:competencyCode "CG04" ;
    ns1:competencyDescription "Adquirir la formación y habilidades para el desarrollo de la investigación biotecnológica (tecnologías y estrategias frontera), de cara a su posterior aplicación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504312/2025-26/CG05> a ns1:Competency ;
    ns1:competencyCode "CG05" ;
    ns1:competencyDescription "Familiarizarse con los fundamentos de informática necesarios para llevar a cabo una investigación y desarrollo modernos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504312/2025-26/CG07> a ns1:Competency ;
    ns1:competencyCode "CG07" ;
    ns1:competencyDescription "Adquirir la formación profesional para cubrir la demanda de las empresas biotecnológicas y para el acceso a estudios de postgrado del área."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504312/2025-26/CT07> a ns1:Competency ;
    ns1:competencyCode "CT07" ;
    ns1:competencyDescription "Capacidad para liderar y trabajar en equipos multidisciplinares y multiculturales en un contexto internacional."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504312/2025-26/CT08> a ns1:Competency ;
    ns1:competencyCode "CT08" ;
    ns1:competencyDescription "Ser capaz de manejar las tecnologías de la información y comunicación en un contexto profesional."@es .

