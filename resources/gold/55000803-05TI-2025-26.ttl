<https://guia-kg.skai.etsisi.upm.es/resource/55000803/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Conocer y aplicar conocimientos de ciencias y tecnologías básicas a la práctica de la Ingeniería Industrial."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000803/2025-26/CG2> a ns1:Competency ;
    ns1:competencyCode "CG2" ;
    ns1:competencyDescription "Poseer capacidad para diseñar, desarrollar, implementar, gestionar y mejorar productos, sistemas y procesos en los distintos ámbitos industriales, usando técnicas analíticas, computacionales o experimentales apropiadas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000803/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Aplicar los conocimientos adquiridos para identificar, formular y resolver problemas dentro de contextos amplios y multidisciplinarios, siendo capaces de integrar conocimientos, trabajando en equipos multidisciplinares."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000803/2025-26/CG4> a ns1:Competency ;
    ns1:competencyCode "CG4" ;
    ns1:competencyDescription "Comprender el impacto de la ingeniería industrial en el medio ambiente, el desarrollo sostenible de la sociedad y la importancia de trabajar en un entorno profesional y responsable."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000803/2025-26/CG5> a ns1:Competency ;
    ns1:competencyCode "CG5" ;
    ns1:competencyDescription "Saber comunicar los conocimientos y conclusiones, de forma oral, escrita y gráfica, a públicos especializados y no especializados de un modo claro y sin ambigüedades."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000803/2025-26/RA421> a ns1:LearningResult ;
    ns1:learningResultCode "RA421" ;
    ns1:learningResultDescription "Determinar propiedades termodinámicas en sistemas multicomponentes y polifásicos, a partir de ecuaciones de estado y correlaciones tabulares."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000803/2025-26/RA422> a ns1:LearningResult ;
    ns1:learningResultCode "RA422" ;
    ns1:learningResultDescription "Seleccionar las más adecuadas a cada caso, como marco previo para diseñar operaciones básicas de ingeniería química y de producción de energía o frío."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000803/2025-26/RA423> a ns1:LearningResult ;
    ns1:learningResultCode "RA423" ;
    ns1:learningResultDescription "Determinar propiedades termoquímicas, composiciones de equilibrio y efectos caloríficos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000803/2025-26/RA424> a ns1:LearningResult ;
    ns1:learningResultCode "RA424" ;
    ns1:learningResultDescription "Identificar y valorar destrucciones exergéticas en sistemas físicos y químicos."@es .

