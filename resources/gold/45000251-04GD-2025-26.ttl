    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/45000251/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/45000251/2025-26/didactic_resource/2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/45000251/2025-26/didactic_resource/3>,
        <https://guia-kg.skai.etsisi.upm.es/resource/45000251/2025-26/didactic_resource/4>,
        <https://guia-kg.skai.etsisi.upm.es/resource/45000251/2025-26/didactic_resource/5>,
        <https://guia-kg.skai.etsisi.upm.es/resource/45000251/2025-26/didactic_resource/6>,
        <https://guia-kg.skai.etsisi.upm.es/resource/45000251/2025-26/didactic_resource/7>,
        <https://guia-kg.skai.etsisi.upm.es/resource/45000251/2025-26/didactic_resource/8>,
