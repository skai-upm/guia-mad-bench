<https://guia-kg.skai.etsisi.upm.es/resource/53001623/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/53001623/2025-26/MUII.%20%28d%29>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001623/2025-26/MUII.%20%28f%29>,
