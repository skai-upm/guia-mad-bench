    ns1:inpersonHours "45 horas (38.5%)"@es ;
    ns1:numberOfCredits 4.5 ;
    ns1:otherInformation ""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "47 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/63000325/2025-26/eventSchedule> ;
    schema:description """La asignatura está orientada a proporcionar a los alumnos la formación necesaria para abordar el estudio de un problema utilizando técnicas geoquímicas. Se estudia todo el proceso, comenzando por el planteamiento inicial del problema y de las posibles hipótesis, pasando por la selección de los parámetros necesarios para rechazar o aceptar y cuantificar la hipótesis, la elección de los métodos analíticos más adecuados en función de los objetivos y del presupuesto, el diseño de la toma de muestras, la toma, conservación y preparación de las muestras, análisis in situ, la preparación de la base de datos, análisis estadístico de los resultados y preparación de informe.
Para conseguirlo los alumnos tienen tanto clases teóricas, como prácticas de campo y de laboratorio.
El objetivo de la prospección está enfocado tanto a la búsqueda de yacimientos minerales como a la resolución de problemas medioambientales, con una especial insistencia en estos últimos."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/eduardo.demiguel%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/eduardo.demiguel%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/lucia.arevalo%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/yolanda.sanchezpalencia%40upm.es> ;
    schema:name "Prospección Geoquímica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000325/2025-26/CB07> a ns1:Competency ;
    ns1:competencyCode "CB07" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en entornos nuevos o poco conocidos dentro de contextos más amplios (o multidisciplinares) relacionados con su área de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000325/2025-26/CB08> a ns1:Competency ;
    ns1:competencyCode "CB08" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de integrar conocimientos y enfrentarse a la complejidad de formular juicios a partir de una información que, siendo incompleta o limitada, incluya reflexiones sobre las responsabilidades sociales y éticas vinculadas a la aplicación de sus conocimientos y juicios"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000325/2025-26/CB09> a ns1:Competency ;
    ns1:competencyCode "CB09" ;
    ns1:competencyDescription "Que los estudiantes sepan comunicar sus conclusiones y los conocimientos y razones últimas que las sustentan a públicos especializados y no especializados de un modo claro y sin ambigüedades"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000325/2025-26/CB10> a ns1:Competency ;
    ns1:competencyCode "CB10" ;
    ns1:competencyDescription "Que los estudiantes posean las habilidades de aprendizaje que les permitan continuar estudiando de un modo que habrá de ser en gran medida autodirigido o autónomo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000325/2025-26/CE08> a ns1:Competency ;
    ns1:competencyCode "CE08" ;
    ns1:competencyDescription "Estar capacitado para realizar estudios desde un punto de vista de la ingeniería geológica, petrofísica, hidroquímica y recurso no renovable"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000325/2025-26/CE11> a ns1:Competency ;
    ns1:competencyCode "CE11" ;
    ns1:competencyDescription "Comprender el nexo medio físico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000325/2025-26/CG02> a ns1:Competency ;
    ns1:competencyCode "CG02" ;
    ns1:competencyDescription "Capacidad para evaluar, diseñar, desarrollar, implementar, gestionar y mejorar productos, sistemas y procesos en los distintos ámbitos de la Ingeniería Geológica, en relación al medio físico usando técnicas analíticas, computacionales o experimentales avanzadas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000325/2025-26/CG03> a ns1:Competency ;
    ns1:competencyCode "CG03" ;
    ns1:competencyDescription "Capacidad para adquirir habilidades y predisposición para el aprendizaje autónomo o dirigido en Ingeniería Geológica que permitan la formación continua, ya sea en el ámbito de la investigación (Doctorado) o del perfeccionamiento profesional."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000325/2025-26/CG04> a ns1:Competency ;
    ns1:competencyCode "CG04" ;
    ns1:competencyDescription "Capacidad para plantear y dirigir el desarrollo de soluciones de ingeniería en entornos nuevos o poco conocidos, dentro de contextos más amplios o multidisciplinares, siendo capaces de integrar dichos conocimientos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000325/2025-26/CT02> a ns1:Competency ;
    ns1:competencyCode "CT02" ;
    ns1:competencyDescription "Capacidad para el trabajo en grupo y dirigir, organizar y supervisar equipos multidisciplinares"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000325/2025-26/CT03> a ns1:Competency ;
    ns1:competencyCode "CT03" ;
    ns1:competencyDescription "Creatividad, iniciativa y capacidad emprendedora."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000325/2025-26/CT04> a ns1:Competency ;
    ns1:competencyCode "CT04" ;
    ns1:competencyDescription "Capacidad para la elaboración, planificación, coordinación y gestión técnica y económica de proyectos siguiendo criterios éticos, de calidad y medioambientales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000325/2025-26/RA14> a ns1:LearningResult ;
