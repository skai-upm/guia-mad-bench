    ns1:competencyCode "CG04" ;
    ns1:competencyDescription "Conocimiento de la profesión de Ingeniero de Minas y de las actividades que se puedan realizar en el ámbito de la misma"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000156/2025-26/CG05> a ns1:Competency ;
    ns1:competencyCode "CG05" ;
    ns1:competencyDescription "Conocimiento para aplicar las capacidades técnicas y gestoras de actividades de I+D+i dentro de su ámbito"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000156/2025-26/CG08> a ns1:Competency ;
    ns1:competencyCode "CG08" ;
    ns1:competencyDescription "Capacidad para planificar y gestionar recursos energéticos, incluyendo la generación, transporte, distribución y utilización"@es .

