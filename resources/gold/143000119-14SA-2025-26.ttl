    ns1:itemIndex 7 ;
    ns1:syllabusDescription "1.7. Simulación de materiales ortótropos y laminados Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000119/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "1.8. Introducción a los criterios de tolerancia al daño Sin subniveles"@es .

