    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Introducción a las aplicaciones espaciales de materiales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000119/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Características particulares del sector espacio Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000119/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "2.1. Criterios de diseño para estructuras espaciales Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000119/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "2.2. Condiciones de contorno de estructuras espaciales Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000119/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "2.3. Realización de procesos de fabricación y ensayo de estructuras Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000119/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "3. Materiales metálicos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000119/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "3.1. Propiedades de los materiales y su importancia en la selección de materiales. Propiedades mecánicas. Propiedades físicas (térmicas, ópticas, eléctricas, magnéticas). Propiedades químicas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000119/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "3.2. Selección de materiales en entornos espaciales. Normativa para materiales metálicos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000119/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "3.3. Propiedades y aplicaciones de aleaciones ligeras de uso espacial: aluminio, magnesio, berilio, titanio. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000119/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "3.4. Propiedades y aplicaciones de materiales de uso especial para aplicaciones de alta resistencia y/o temperatura elevada: aceros de alta resistencia, aleaciones de níquel, cobalto, cobre, y aleaciones refractarias. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000119/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "3.5. Materiales compuestos de matriz metálica de uso espacial. Propiedades y aplicaciones. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000119/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "3.6. Materiales cerámicos y compuestos de matriz cerámica de aplicación espacial (cerámicos avanzados, laminados). Propiedades y aplicaciones. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000119/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Ambiente espacial Sin subniveles"@es .

