    ns1:syllabusDescription "1.4. Papel de los materiales Compuestos en el espacio. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000119/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "1.5. Ejemplos Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000119/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "1.6. Introducción/ Recordatorio Nastrán/Patran Sin subniveles"@es .

