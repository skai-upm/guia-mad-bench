<https://guia-kg.skai.etsisi.upm.es/resource/615000306/2025-26/CC6> a ns1:Competency ;
    ns1:competencyCode "CC6" ;
    ns1:competencyDescription "Conocimiento y aplicación de los procedimientos algorítmicos básicos de las tecnologías informáticas para diseñar soluciones a problemas, analizando la idoneidad y complejidad de los algoritmos propuestos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000306/2025-26/CC7> a ns1:Competency ;
    ns1:competencyCode "CC7" ;
    ns1:competencyDescription "Conocimiento, diseño y utilización de forma eficiente los tipos y estructuras de datos más adecuados a la resolución de un problema."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000306/2025-26/CC8> a ns1:Competency ;
    ns1:competencyCode "CC8" ;
    ns1:competencyDescription "Capacidad para analizar, diseñar, construir y mantener aplicaciones de forma robusta, segura y eficiente, eligiendo el paradigma y los lenguajes de programación más adecuados."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000306/2025-26/CT1> a ns1:Competency ;
    ns1:competencyCode "CT1" ;
    ns1:competencyDescription "Análisis y síntesis: Descomponer la información en unidades más pequeñas separando los componentes fundamentales de los no relevantes e identificando las relaciones existentes entre ellos. Síntesis: Combinar información para construir un todo a partir de las entidades previamente analizadas"@es .

