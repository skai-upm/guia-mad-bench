    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/53001927/2025-26/eventSchedule> ;
    schema:description "La asignatura Física Nuclear es una introducción a la estructura del núcleo y los procesos relacionados con el núcleo atómico. La asignatura comienza con una introducción a la estructura del núcleo atómico y los modelos que explican las propiedades nucleares. La segunda parte de la asignatura se dedicará a el estudio de las reacciones nucleares. En primer lugar se abordaran las reacciones espontáneas de desintegración que darán lugar a la emisión de radiación. Y después se estudiarán las reacciones nucleares inducidas por otras partículas y en especial las inducidas por neutrones como es la la fisión nuclear. Para finalizar, se estudiará la reacción de fusión nuclear y los rocesos físicos involucrados para el aprovechamiento de la energía de fusión. Los alumnos adquieren los conocimientos básicos sobre la estructura nuclear necesarios para el desarrollo de la Ciencia y la Tecnología Nucleares."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/antonio.rivera%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/antonio.rivera%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/eduardo.oliva%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/manuel.cotelo%40upm.es> ;
    schema:name "Física Nuclear"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001927/2025-26/MUCTN.CB06> a ns1:Competency ;
    ns1:competencyCode "MUCTN.CB06" ;
    ns1:competencyDescription "Poseer y comprender conocimientos que aporten una base u oportunidad de ser originales en el desarrollo y/o aplicación de ideas, a menudo en un contexto de investigación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001927/2025-26/MUCTN.CE01> a ns1:Competency ;
    ns1:competencyCode "MUCTN.CE01" ;
    ns1:competencyDescription "Entiende a fondo las leyes básicas y avanzadas de la física atómica y nuclear y las ciencias de la ingeniería pertinentes aplicables a la tecnología de las plantas de energía nuclear de fisión y/o fusión"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001927/2025-26/MUCTN.CE03> a ns1:Competency ;
    ns1:competencyCode "MUCTN.CE03" ;
    ns1:competencyDescription "Utiliza los datos y sistemas informáticos más empleados tanto en la investigación como en la industria nuclear para los sistemas de fisión y/o fusión"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001927/2025-26/MUCTN.CG01> a ns1:Competency ;
    ns1:competencyCode "MUCTN.CG01" ;
    ns1:competencyDescription "Tener conocimientos avanzados de los aspectos científicos y tecnológicos de la energía nuclear"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001927/2025-26/MUCTN.CT02> a ns1:Competency ;
    ns1:competencyCode "MUCTN.CT02" ;
    ns1:competencyDescription "Experimenta. Habilidad para diseñar y realizar experimentos así como analizar e interpretar datos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001927/2025-26/MUCTN.CT11> a ns1:Competency ;
    ns1:competencyCode "MUCTN.CT11" ;
    ns1:competencyDescription "Usa herramientas. Habilidad para usar las técnicas, destrezas y herramientas ingenieriles modernas necesarias para la práctica de la ingeniería"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001927/2025-26/RA40> a ns1:LearningResult ;
    ns1:learningResultCode "RA40" ;
    ns1:learningResultDescription "Capacidad de realizar balances energéticos de reacciones nucleares y conocer los procesos que permiten el aprovechamiento de esta energía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001927/2025-26/RA41> a ns1:LearningResult ;
    ns1:learningResultCode "RA41" ;
    ns1:learningResultDescription "Conocimiento de las técnicas de medida basadas en las propiedades nucleares"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001927/2025-26/RA42> a ns1:LearningResult ;
    ns1:learningResultCode "RA42" ;
    ns1:learningResultDescription "Aplicación de la Física Nuclear a la interpretación y cálculo de las propiedades de transporte (secciones eficaces de reacciones nucleares) y de las constantes de desintegración de los isótopos inestables."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001927/2025-26/RA43> a ns1:LearningResult ;
    ns1:learningResultCode "RA43" ;
    ns1:learningResultDescription "Conocimiento de los tipos y los procesos físicos asociados a las desintegraciones nucleares y a las reacciones nucleares inducidas"@es .

