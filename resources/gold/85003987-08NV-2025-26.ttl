<https://guia-kg.skai.etsisi.upm.es/resource/85003987/2025-26/CB2> a ns1:Competency ;
    ns1:competencyCode "CB2" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar sus conocimientos a su trabajo o vocación de una forma profesional y posean las competencias que suelen demostrarse por medio de la elaboración y defensa de argumentos y la resolución de problemas dentro de su área de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003987/2025-26/CE%2012> a ns1:Competency ;
    ns1:competencyCode "CE 12" ;
    ns1:competencyDescription "Conocimiento de la elasticidad y resistencia de materiales y capacidad para realizar cálculos de elementos sometidos a solicitaciones diversas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003987/2025-26/CE%2020> a ns1:Competency ;
    ns1:competencyCode "CE 20" ;
    ns1:competencyDescription "Conocimiento de las características de los materiales estructurales navales y de los criterios para su selección"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003987/2025-26/CE%2021> a ns1:Competency ;
    ns1:competencyCode "CE 21" ;
    ns1:competencyDescription "Conocimiento de los procedimientos y sistemas que se emplean para el control de la corrosión marina"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003987/2025-26/CE%2025> a ns1:Competency ;
    ns1:competencyCode "CE 25" ;
    ns1:competencyDescription "Capacidad para la integración a bordo de los sistemas auxiliares teniendo en cuenta su empacho, peso, cargas dinámicas, impacto en la estanqueidad, el espacio necesario para su mantenimiento, etc."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003987/2025-26/CE%2029> a ns1:Competency ;
    ns1:competencyCode "CE 29" ;
    ns1:competencyDescription "Conocimiento de los procesos de construcción naval"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003987/2025-26/CE%208> a ns1:Competency ;
    ns1:competencyCode "CE 8" ;
    ns1:competencyDescription "Conocimiento de la ciencia y tecnología de materiales y capacidad para su selección y para la evaluación de su comportamiento."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003987/2025-26/CG6> a ns1:Competency ;
    ns1:competencyCode "CG6" ;
    ns1:competencyDescription "Capacidad para el manejo de especificaciones, reglamentos y normas de obligado cumplimiento que afectan principalmente a la seguridad, la definición de espacios a bordo, la estructura y la operatividad de buques."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003987/2025-26/RA119> a ns1:LearningResult ;
    ns1:learningResultCode "RA119" ;
    ns1:learningResultDescription "Conocer el proceso de construcción en los astilleros, sus características y evolución"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003987/2025-26/RA120> a ns1:LearningResult ;
    ns1:learningResultCode "RA120" ;
    ns1:learningResultDescription "Conocer las fases, hitos más destacados y etapas del proceso de construcción del buque"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003987/2025-26/RA121> a ns1:LearningResult ;
    ns1:learningResultCode "RA121" ;
    ns1:learningResultDescription "Conocer la documentación, materiales, medios de producción, procesos y tecnologías empleadas en las distintas fases de la construcción"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003987/2025-26/RA122> a ns1:LearningResult ;
    ns1:learningResultCode "RA122" ;
    ns1:learningResultDescription "Conocer los sistemas de puesta a flote y su cálculo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003987/2025-26/RA123> a ns1:LearningResult ;
    ns1:learningResultCode "RA123" ;
    ns1:learningResultDescription "Conocer los procedimientos de inspección, garantía de la calidad y el proceso de pruebas y entrega"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003987/2025-26/RA124> a ns1:LearningResult ;
    ns1:learningResultCode "RA124" ;
    ns1:learningResultDescription "Conocer los distintos sistemas de varada y los procesos aplicados en la reparación y transformación de los buques"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003987/2025-26/RA125> a ns1:LearningResult ;
    ns1:learningResultCode "RA125" ;
    ns1:learningResultDescription "Conocer los métodos más relevantes aplicados en la mejora de los procesos y los modelos de simulación de los procesos constructivos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003987/2025-26/RA127> a ns1:LearningResult ;
    ns1:learningResultCode "RA127" ;
    ns1:learningResultDescription "Conocer los distintos sistemas de protección del buque contra la corrosión en el medio marino y su proceso de aplicación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003987/2025-26/RA53> a ns1:LearningResult ;
    ns1:learningResultCode "RA53" ;
    ns1:learningResultDescription "Conocer los procesos y los agentes intervinientes en la Construcción Naval"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003987/2025-26/RA54> a ns1:LearningResult ;
    ns1:learningResultCode "RA54" ;
    ns1:learningResultDescription "Conocer la normativa aplicable en la Construcción Naval"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003987/2025-26/RA55> a ns1:LearningResult ;
    ns1:learningResultCode "RA55" ;
    ns1:learningResultDescription "Conocer los agentes y autoridades intervinientes en la Construcción Naval"@es .

