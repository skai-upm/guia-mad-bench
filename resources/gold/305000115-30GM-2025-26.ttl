    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/305000115/2025-26/eventSchedule> ;
    schema:description "La asignatura tiene como resultados del aprendizaje, reconocer y manejar el concepto medida y de integral de Lebesgue. Enunciar, demostrar y aplicar los teoremas de la convergencia monótona y dominada en la integración de Lebesgue. Identificar propiedades y características fundamentales de los espacios de Banach y Hilbert. Aplicar las desigualdades propias de los espacios Lp. Aplicar el concepto de sistema ortonormal en un espacio de Hilbert a la resolución de problemas de aproximación óptima. Describir y probar los resultados básicos de la Teoría de operadores lineales acotados. Calcular los coeficientes de Fourier de una función periódica. Utilizar el análisis de las series numéricas para resolver diversidad de problemas. Calcular la transformada de Fourier de una función y relacionar su regularidad y algunas aplicaciones."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/jf.padial%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/jf.padial%40upm.es> ;
    schema:name "Análisis Real"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000115/2025-26/CE1> a ns1:Competency ;
    ns1:competencyCode "CE1" ;
    ns1:competencyDescription "Comprender y utilizar el lenguaje matemático. Adquirir la capacidad para enunciar propiedades en distintos campos de la Matemática, para construir argumentaciones, elaborar cálculos y para transmitir los conocimientos matemáticos adquiridos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000115/2025-26/CE2> a ns1:Competency ;
    ns1:competencyCode "CE2" ;
    ns1:competencyDescription "Conocer y comprender demostraciones rigurosas de los principales teoremas de cada área de la Matemática y extraer de ellos corolarios mediante la particularización a casos concretos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000115/2025-26/CE3> a ns1:Competency ;
    ns1:competencyCode "CE3" ;
    ns1:competencyDescription "Asimilar la definición de un nuevo objeto matemático, en términos de otros ya conocidos, y ser capaz de utilizar este objeto en diferentes contextos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000115/2025-26/CE4> a ns1:Competency ;
    ns1:competencyCode "CE4" ;
    ns1:competencyDescription "Abstraer las propiedades estructurales de objetos matemáticos, de la realidad observada o de otros ámbitos distinguiéndolas de aquellas puramente ocasionales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000115/2025-26/CE5> a ns1:Competency ;
    ns1:competencyCode "CE5" ;
    ns1:competencyDescription "Comprobar con demostraciones hipótesis sobre un objeto matemático o refutarlas con contraejemplos, así como identificar errores en razonamientos incorrectos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000115/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Utilizar las capacidades analíticas y de abstracción, la intuición y el pensamiento lógico y riguroso desarrolladas a través del estudio de la Matemática en contextos tanto matemáticos como no matemáticos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000115/2025-26/RA124> a ns1:LearningResult ;
    ns1:learningResultCode "RA124" ;
    ns1:learningResultDescription "Aplicar las desigualdades propias de los espacios Lp"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000115/2025-26/RA125> a ns1:LearningResult ;
    ns1:learningResultCode "RA125" ;
    ns1:learningResultDescription "Aplicar el concepto de sistema ortonormal en un espacio de Hilbert a la resolución de problemas de aproximación óptima"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000115/2025-26/RA126> a ns1:LearningResult ;
    ns1:learningResultCode "RA126" ;
    ns1:learningResultDescription "Describir y probar los resultados básicos de la Teoría de operadores lineales acotados"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000115/2025-26/RA128> a ns1:LearningResult ;
    ns1:learningResultCode "RA128" ;
    ns1:learningResultDescription "Calcular los coeficientes de Fourier de una función periódica y relacionar el decaimiento de los coeficientes con la regularidad de la función"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000115/2025-26/RA133> a ns1:LearningResult ;
    ns1:learningResultCode "RA133" ;
    ns1:learningResultDescription "Reconocer y manejar el concepto de integral de Lebesgue."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000115/2025-26/RA134> a ns1:LearningResult ;
    ns1:learningResultCode "RA134" ;
    ns1:learningResultDescription "Enunciar, demostrar y aplicar los teoremas de la convergencia monótona y dominada en la integración de Lebesgue."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000115/2025-26/RA135> a ns1:LearningResult ;
    ns1:learningResultCode "RA135" ;
    ns1:learningResultDescription "Identificar propiedades y características fundamentales de los espacios de Banach y Hilbert"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000115/2025-26/RA136> a ns1:LearningResult ;
    ns1:learningResultCode "RA136" ;
    ns1:learningResultDescription "Calcular la transformada de Fourier de una función y relacionar su regularidad y decaimiento con el decaimiento y la regularidad de su transformada"@es .

