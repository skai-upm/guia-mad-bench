    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/55000675/2025-26/eventSchedule> ;
    schema:description """El objetivo general de la asignatura es conocer el proceso de creación y desarrollo de una empresa.
Los objetivos específicos son:
- Conocer el proceso de creación y desarrollo de una empresa, tanto mediante la explicación de los elementos teóricos como la realización de ejercicios prácticos.
- Evaluar las habilidades necesarias para emprender
- Detectar los factores de éxito y fracaso
- Conocer ejemplos reales de prácticas emprendedoras
- Desarrollar una metodología para la redacción de un plan de negocio
- Conocer y aplicar las herramientas para llevar a cabo una iniciativa emprendedora.
- Fomentar la intención emprendedora entre los estudiantes y posicionar esta salida profesional como otra alternativa válida."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/teresa.sanchez%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/joseantonio.blanco%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/teresa.sanchez%40upm.es> ;
    schema:name "Creación de Empresas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000675/2025-26/CE35> a ns1:Competency ;
    ns1:competencyCode "CE35" ;
    ns1:competencyDescription "Conocimiento de las diversas formas societarias y de la regulación que afecta al funcionamiento de las empresas y su relación con el entorno y los empleados."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000675/2025-26/CE39> a ns1:Competency ;
    ns1:competencyCode "CE39" ;
    ns1:competencyDescription "Comprensión de los elementos que configuran un plan de negocio. Conocimiento de las fuentes de capital y los estadíos en la creación de un negocio."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000675/2025-26/CG2> a ns1:Competency ;
    ns1:competencyCode "CG2" ;
    ns1:competencyDescription "Poseer capacidad para diseñar, desarrollar, implementar, gestionar y mejorar productos, sistemas y procesos en los distintos ámbitos industriales, usando técnicas analíticas, computacionales o experimentales apropiadas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000675/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Aplicar los conocimientos adquiridos para identificar, formular y resolver problemas dentro de contextos amplios y multidisciplinarios, siendo capaces de integrar conocimientos, trabajando en equipos multidisciplinarios."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000675/2025-26/CG5> a ns1:Competency ;
    ns1:competencyCode "CG5" ;
    ns1:competencyDescription "Saber comunicar los conocimientos y conclusiones, tanto de forma oral, escrita y gráfica, a públicos especializados y no especializados de un modo claro y sin ambigüedades"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000675/2025-26/CG6> a ns1:Competency ;
    ns1:competencyCode "CG6" ;
    ns1:competencyDescription "Poseer habilidades de aprendizaje que permitan continuar estudiando a lo largo de la vida para su adecuado desarrollo profesional"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000675/2025-26/CG9> a ns1:Competency ;
    ns1:competencyCode "CG9" ;
    ns1:competencyDescription "Organización y planificación en el ámbito de la empresa, y otras instituciones y organizaciones de proyectos y equipos humanos"@es .

