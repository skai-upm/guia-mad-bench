    ns1:inpersonHours "29 horas (37.2%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation """La asignatura se relaciona con el ODS 9 "Industria, innovación e infraestructura", en el ámbito de las TIC.
La modalidad de enseñanza es presencial."""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "29 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/93001098/2025-26/eventSchedule> ;
    schema:description """En la asignatura se plantean proyectos en el área de la ingeniería de redes y servicios telemáticos para ser llevados a cabo en grupos de dos o tres alumnos bajo la supervisión de un profesor tutor en un plazo de siete semanas.
El objetivo es la adquisición de competencias relacionadas con la capacidad para integrarse, colaborar e intervenir en un equipo profesional."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/luis.bellido%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/luis.bellido%40upm.es> ;
    schema:name "Mini-Proyectos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93001098/2025-26/CB07> a ns1:Competency ;
    ns1:competencyCode "CB07" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en entornos nuevos o poco conocidos dentro de contextos más amplios (o multidisciplinares) relacionados con su área de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93001098/2025-26/CB08> a ns1:Competency ;
    ns1:competencyCode "CB08" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de integrar conocimientos y enfrentarse a la complejidad de formular juicios a partir de una información que, siendo incompleta o limitada, incluya reflexiones sobre las responsabilidades sociales y éticas vinculadas a la aplicación de sus conocimientos y juicios"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93001098/2025-26/CG01> a ns1:Competency ;
    ns1:competencyCode "CG01" ;
    ns1:competencyDescription "Capacidad para conocer y practicar las técnicas y metodologías básicas empleadas en las actividades de innovación en el área de la ingeniería de redes y servicios telemáticos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93001098/2025-26/CG03> a ns1:Competency ;
    ns1:competencyCode "CG03" ;
    ns1:competencyDescription "Capacidad para profundizar en la tendencia a la integración de los sistemas telemáticos, englobando aspectos técnicos, de gestión, sociales, económicos, éticos, etc. y para reflexionar sobre todos los aspectos implicados para formular sus juicios."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93001098/2025-26/CG04> a ns1:Competency ;
    ns1:competencyCode "CG04" ;
    ns1:competencyDescription "Capacidad para ir adaptando la aplicación de sus conocimientos a los cambios tecnológicos, metodológicos, normativos, etc. que se producen constantemente en el sector de las redes y servicios telemáticos, donde la innovación es constante y los cambios que se producen cada poco tiempo son profundos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93001098/2025-26/RA69> a ns1:LearningResult ;
    ns1:learningResultCode "RA69" ;
    ns1:learningResultDescription "Capacidad de aplicar los conocimientos adquiridos para resolver problemas en un proyecto, practicando técnicas y metodologías empleadas en las actividades de innovación en el área de la ingeniería de redes y servicios telemáticos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93001098/2025-26/RA70> a ns1:LearningResult ;
    ns1:learningResultCode "RA70" ;
    ns1:learningResultDescription "Capacidad de exponer los resultados de un proyecto en el área de la ingeniería de redes y servicios telemáticos, incluyendo aspectos técnicos, de gestión, sociales, económicos, éticos y medioambientales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93001098/2025-26/RA71> a ns1:LearningResult ;
    ns1:learningResultCode "RA71" ;
    ns1:learningResultDescription "Capacidad de adaptar y aplicar sus conocimientos en un proyecto innovador"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93001098/2025-26/RA73> a ns1:LearningResult ;
    ns1:learningResultCode "RA73" ;
    ns1:learningResultDescription "Capacidad para integrarse, colaborar e intervenir en un equipo profesional del ámbito de la ingeniería de redes y servicios telemáticos"@es .

