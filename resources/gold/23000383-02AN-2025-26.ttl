    ns1:minimumScore "5 / 10"@es ;
    ns1:trialDescription "Evaluación progresiva: Elaboración de un \"cuaderno de campo\" sobre las especies observadas durante las visitas al Arboreto de la Escuela de Ingenieros de Montes y al parque de El Retiro*."@es ;
    ns1:trialType "No Presencial"@es ;
    ns1:trialWeek "9"@es .

