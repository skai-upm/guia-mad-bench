    ns1:evaluationDuration "00:00"@es ;
    ns1:evaluationType "progresiva"@es ;
    ns1:gradePercentage "5%"@es ;
    ns1:hasScheduleEvent <https://guia-kg.skai.etsisi.upm.es/resource/23000383/2025-26/eventSchedule/9> ;
