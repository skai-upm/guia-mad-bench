    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/595000035/2025-26/eventSchedule> ;
    schema:description "Instrumentación Electrónica es una asignatura de séptimo semestre, obligatoria para la titulación de Grado en Ingeniería Electrónica de Comunicaciones. Con esta asignatura el estudiante finaliza su formación obligatoria en el área de la Instrumentación Electrónica y Control, abordando el estudio de los sensores, circuitos acondicionadores de señal y subsistemas de conversión analógico digital."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/i.anton%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/francisco.martinezm%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/i.anton%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/javier.malo%40upm.es> ;
    schema:name "Instrumentacion Electronica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000035/2025-26/CE%20EC01> a ns1:Competency ;
    ns1:competencyCode "CE EC01" ;
    ns1:competencyDescription "Capacidad de construir, explotar y gestionar sistemas de captación, transporte, representación, procesado, almacenamiento, gestión y presentación de información multimedia, desde el punto de vista de los sistemas electrónicos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000035/2025-26/CE%20EC04> a ns1:Competency ;
    ns1:competencyCode "CE EC04" ;
    ns1:competencyDescription "Capacidad para aplicar la electrónica como tecnología de soporte en otros campos y actividades, y no sólo en el ámbito de las Tecnologías de la Información y las Comunicaciones."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000035/2025-26/CE%20EC05> a ns1:Competency ;
    ns1:competencyCode "CE EC05" ;
    ns1:competencyDescription "Capacidad de diseñar circuitos de electrónica analógica y digital, de conversión analógico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000035/2025-26/CE%20EC08> a ns1:Competency ;
    ns1:competencyCode "CE EC08" ;
    ns1:competencyDescription "Capacidad para especificar y utilizar instrumentación electrónica y sistemas de medida."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000035/2025-26/RA240> a ns1:LearningResult ;
    ns1:learningResultCode "RA240" ;
    ns1:learningResultDescription "Conocer transductores que permiten la conversión de variables físicas a eléctricas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000035/2025-26/RA241> a ns1:LearningResult ;
    ns1:learningResultCode "RA241" ;
    ns1:learningResultDescription "Conocer algunas técnicas y circuitos que se emplean para acondicionar las señales procedentes de los transductores en los sistemas de medida"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000035/2025-26/RA242> a ns1:LearningResult ;
    ns1:learningResultCode "RA242" ;
    ns1:learningResultDescription "Comprender la utilidad, funcionamiento eléctrico y especificaciones técnicas de los subsistemas que constituyen la cadena de conversión en un Sistema de Adquisición de Datos Multicanal (Multiplexor analógico, Circuito de muestreo y retención (SH), Particularidades del Convertidor Digital"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000035/2025-26/RA243> a ns1:LearningResult ;
    ns1:learningResultCode "RA243" ;
    ns1:learningResultDescription "Ser capaz de analizar el comportamiento de la cadena de conversión analógico digital y las estructuras utilizadas en los Sistemas de Adquisición de Datos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000035/2025-26/RA244> a ns1:LearningResult ;
    ns1:learningResultCode "RA244" ;
    ns1:learningResultDescription "Caracterizar el error cometido por los subsistemas utilizados en el proceso de medida y el error total del sistema"@es .

