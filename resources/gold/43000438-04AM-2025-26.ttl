<https://guia-kg.skai.etsisi.upm.es/resource/43000438/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Introduction to structural dynamics"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000438/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Single-degree of freedom systems. Damped movement. Resonance. Duhamel's equation. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000438/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "5.1. Vehicle models and pavement irregularities. Analysis methods for wind-vehicle-bridge interaction studies. Driving safety and comfort assessment. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000438/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "6. Pedestrian-induced vibrations in footbridges."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000438/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "6.1. Traditional treatment of the problem. New developments following the problems with the Millenium footbridge. Human-structure interaction. Setra and Nakamura pedestrian models. Crowd loading. Code specifications. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000438/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "7. Seismic actions on bridges."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000438/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "7.1. Description of the seismic action. Multi-modal analysis of the seismic response. Ductility. Capacity design. Pushover method. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000438/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "7.2. Non-linear dynamic analysis. Damping. Performance-based design. Construction details in bridges. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000438/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "7.3. Soil-structure interaction. Seismic effects on abutments. Mononobe-Okabe method. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000438/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "8. Wind effects on bridges."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000438/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "8.1. Fundamentals of wind engineering. Bluff body aerodynamics. Quasi-static, buffeting and aeroelastic effects in bridges. Stochastic response of bridges under turbulent wind. Vortex-induced vibrations. Code treatment of the problem. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000438/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "9. Auxiliary devices for the control of bridge dynamics"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000438/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "2. Dynamics in the time domain"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000438/2025-26/syllabus/20> a ns1:SyllabusItem ;
    ns1:itemIndex 20 ;
    ns1:syllabusDescription "9.1. Active, semi-active and passive devices. Tuned mass dampers. Viscous shock absorbers Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000438/2025-26/syllabus/21> a ns1:SyllabusItem ;
    ns1:itemIndex 21 ;
    ns1:syllabusDescription "9.2. Modified neoprene devices. Yielding metallic dampers. Shock transmission units. Design of auxiliary damping systems for the control of bridges. Application examples Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000438/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "2.1. Multi-degree of freedom systems. Vibration modes. Modal analysis. Damping types. Time integration. Implicit and explicit methods. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000438/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "3. Dynamics in the frequency domain"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000438/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "3.1. Importance of the frequency domain. Auto-correlation function. Fourier analysis. Parseval's identity, Power spectral density. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000438/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "3.2. Single- and multi-degree of freedom systems under random loads. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000438/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "4. Train-induced vibrations in railway bridges"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000438/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "4.1. Description of moving loads in railway bridges. Characteristic velocities. Analysis with moving loads and coupled models. Code treatment of the problem. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000438/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "5. Vehicle-induced vibrations in road bridges."@es .

