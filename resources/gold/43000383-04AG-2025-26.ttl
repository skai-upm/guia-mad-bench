<https://guia-kg.skai.etsisi.upm.es/resource/43000383/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Tema 1. Introducción a los puentes Definiciones. Condicionantes en el proyecto del puente. El puente y el paisaje. Génesis del puente. Durabilidad. El puente como símbolo en la Historia. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000383/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "2. Tema 2. Historia de los puentes Puentes de piedra. Puentes metálicos. Puentes de hormigón. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000383/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "7.1. Modelos de cálculo: de viga única, emparrillado, de elementos finitos. Aplicación de cargas exteriores. Aplicación del pretensado. Envolventes de esfuerzos. Definición de estados límite. Comprobación de secciones. Diafragmas de apoyo. Detalles de armado. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000383/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "8. Tema 8. Cálculo de la subestructura de puentes."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000383/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "8.1. Modelos de cálculo. Cálculo de pilas. Consideración de los problemas de segundo orden. Modelos de estribos. Cálculo de estribos. Cálculo de cimentaciones. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000383/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "9. Tema 9. Equipamiento de puentes."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000383/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "9.1. Aparatos de apoyo: tipología, comportamiento, cálculo, dimensionamiento. Juntas de dilatación: tipología, aplicaciones, dimensionamiento. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000383/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "9.2. Impermeabilización. Drenaje: tipología, cálculo. Defensas y barandillas. Aparatos de amortiguación y de transmisión de choque: tipología y aplicaciones. Protección frente a rayos. Iluminación. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000383/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "10. Tema 10. Construcción de puentes de luz reducida."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000383/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "10.1. Cimentaciones. Pilas. Montaje de vigas prefabricadas (doble T y artesa). Construcción de tableros de tipo losa. Colocación de aparatos de apoyo. Colocación de juntas de dilatación. Impermeabilización. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000383/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "3. Tema 3. Morfología de puentes Puentes viga. Puentes pórtico. Puentes arco. Puentes soportados por cables. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000383/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "4. Tema 4. El proyecto del puente Datos de partida."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000383/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "4.1. Condicionantes. Fases del proyecto. Cálculo. Organización del proyecto. Aplicación de la normativa de calidad. Revisión y supervisión. Variaciones a nivel internacional. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000383/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "5. Tema 5. Pre-dimensionamiento del puente de luz reducida."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000383/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "5.1. Concepción. Vigas prefabricadas en doble T. Vigas prefabricadas de tipo artesa. Tableros in-situ. Pilas. Estribos. Cimentaciones. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000383/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "6. Tema 6. Acciones sobre puentes de carretera."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000383/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "6.1. Gestión de la fiabilidad. Vida de proyecto. Clasificación de las acciones. Valores característicos, de combinación, frecuentes y cuasi-permanentes de las acciones. Sobrecargas de uso, ambientales y accidentales. Normativas española, europea y americana Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000383/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "7. Tema 7. Cálculo de la superestructura de puentes de luz reducida."@es .

