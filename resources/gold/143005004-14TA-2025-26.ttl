        <https://guia-kg.skai.etsisi.upm.es/resource/sergio.jimenez%40upm.es> ;
    schema:name "Explotacion del Transporte Aereo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005004/2025-26/CE7> a ns1:Competency ;
    ns1:competencyCode "CE7" ;
    ns1:competencyDescription "Analizar el impacto de la regulación internacional sobre los operadores de Transporte Aéreo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005004/2025-26/CE8> a ns1:Competency ;
    ns1:competencyCode "CE8" ;
    ns1:competencyDescription "Comprender los procesos operativos propios de las empresas de Transporte Aéreo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005004/2025-26/CG2> a ns1:Competency ;
    ns1:competencyCode "CG2" ;
    ns1:competencyDescription "Aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en los entornos de evolución previstos en los Sistemas de Transporte Aéreo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005004/2025-26/CG5> a ns1:Competency ;
    ns1:competencyCode "CG5" ;
    ns1:competencyDescription "Comprender la importancia de los efectos sobre el medio ambiente en el desarrollo de la actividad de diseño a operación de los Sistemas del Transporte Aéreo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005004/2025-26/CT1> a ns1:Competency ;
    ns1:competencyCode "CT1" ;
    ns1:competencyDescription "Liderar equipos de trabajo multidisciplinares en análisis de elementos funcionales del Transporte Aéreo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005004/2025-26/CT4> a ns1:Competency ;
    ns1:competencyCode "CT4" ;
    ns1:competencyDescription "Analizar implicaciones económicas, administrativas, sociales o medioambientales ligadas a la aplicación de nuevos conceptos y técnicas en el Sistema del Transporte Aéreo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005004/2025-26/RA33> a ns1:LearningResult ;
    ns1:learningResultCode "RA33" ;
    ns1:learningResultDescription "Conocer, comprender, analizar y valorar la Organización Aeronáutica nacional e internacional y del funcionamiento de los distintos modos del sistema mundial de transportes, con especial énfasis en el transporte aéreo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005004/2025-26/RA97> a ns1:LearningResult ;
    ns1:learningResultCode "RA97" ;
    ns1:learningResultDescription "Conocimiento adecuado de la Explotación del Transporte Aéreo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005004/2025-26/didactic_resource/1> a ns1:DidacticResource ;
    ns1:bibliographyTitle "JOHN D. ANDERSON. \"Aircraft performance and design\". WCB/McGraw-Hill, 1999, Boston."@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005004/2025-26/didactic_resource/2> a ns1:DidacticResource ;
    ns1:bibliographyTitle "ARTURO BENITO. \"Descubrir las compañías aéreas\". AENA 2ª edición 2008, Madrid."@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005004/2025-26/didactic_resource/3> a ns1:DidacticResource ;
    ns1:bibliographyTitle "ARTURO BENITO Y GUSTAVO ALONSO.- Apuntes de Explotación del Transporte Aéreo. ETSIAE, Madrid, 2013."@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005004/2025-26/didactic_resource/4> a ns1:DidacticResource ;
    ns1:bibliographyTitle "RIGAS DOGANIS. \"El negocio de las compañías aéreas en el siglo XXI\". INECO, 2002, Madrid."@es ;
    ns1:bibliographyType "Bibliografía"@es .

