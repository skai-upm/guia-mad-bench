    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/143005004/2025-26/eventSchedule> ;
    schema:description "La asignatura tiene como objetivo proporcionar a los alumnos un conocimiento adecuado de la Explotación del Transporte Aéreo, así como la comprensión y dominio de la Organización Aeronáutica nacional e internacional y del funcionamiento de los distintos modos del sistema mundial de transportes, con especial énfasis en el transporte aéreo."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/sergio.jimenez%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
