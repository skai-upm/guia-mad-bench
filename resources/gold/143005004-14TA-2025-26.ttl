    ns1:bibliographyTitle "ALEJANDRO GOMEZ ARTIME. \"Costes del transporte aéreo comercial\". Iberia L. A. E., 1988, Madrid."@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005004/2025-26/didactic_resource/6> a ns1:DidacticResource ;
    ns1:bibliographyTitle "STEPHEN HOLLOWAY. \"Straight and level: practical airline economics\". Ashgate, 3ª Edición 2008, Aldershot."@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005004/2025-26/didactic_resource/7> a ns1:DidacticResource ;
    ns1:bibliographyTitle "ORGANIZACIÓN DE AVIACIÓN CIVIL INTERNACIONAL. \"Convenio sobre la Aviación Civil Internacional\", 1944, Chicago."@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005004/2025-26/didactic_resource/8> a ns1:DidacticResource ;
    ns1:bibliographyTitle "ORGANIZACIÓN DE AVIACIÓN CIVIL INTERNACIONAL. \"Anexos Técnicos al Convenio de Chicago 1 a 19\", diversas fechas, Montreal"@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005004/2025-26/didactic_resource/9> a ns1:DidacticResource ;
