<https://guia-kg.skai.etsisi.upm.es/resource/45000201/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Sistemas de ecuaciones lineales. Matrices y determinantes."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000201/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Operaciones elementales en sistemas. Teorema de Rouché-Frobenius. Introducción a métodos numéricos de resolución. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000201/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "4.1. Producto escalar. Desigualdad de Cauchy-Schwarz. Desigualdad triangular. Ortogonalidad. Método de Gram-Schmidt. Bases ortonormales. Proyección ortogonal sobre un subespacio. Ajuste por mínimos cuadrados. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000201/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "4.2. Aplicaciones y matrices ortogonales. Clasificación de aplicaciones ortogonales en dimensiones 2 y 3. Diagonalización de matrices por semejanza ortogonal. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000201/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "5. Formas bilineales y cuadráticas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000201/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "5.1. Formas bilineales. Simetría. Formas cuadráticas. Expresión matricial. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000201/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "5.2. Matrices congruentes. Diagonalización de formas cuadráticas. Rango y signatura. Ley de inercia. Clasificación de formas cuadráticas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000201/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "6. Cónicas y cuádricas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000201/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "6.1. Cónicas. Ecuación reducida. Tipos de cónicas. Cónicas degeneradas. Elementos destacados: centro, ejes, focos, directrices. Invariantes de una cónica. Parametrización de cónicas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000201/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "6.2. Cuádricas. Ecuación reducida. Centro y ejes. Algunas cuádricas destacadas. Parametrización de cuádricas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000201/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Operaciones con matrices: suma, producto por escalares, producto, transposición. Rango de una matriz. Matrices regulares. Inversa de una matriz. Cálculo de determinantes. Conjuntos y aplicaciones. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000201/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "2. Espacios vectoriales y aplicaciones lineales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000201/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "2.1. Espacios vectoriales. Subespacios. Bases. Dimensión. Coordenadas. Cambio de base. Matriz de un cambio de base. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000201/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "2.2. Aplicaciones lineales: tipología. Núcleo e imagen. Relación entre sus dimensiones. Matriz de una aplicación lineal. Equivalencia de matrices. Matriz de un endomorfismo. Semejanza de matrices. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000201/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "3. Valores y vectores propios."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000201/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "3.1. Polinomio característico. Autovalores, autovectores y autoespacios. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000201/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "3.2. Diagonalización de matrices. Teorema de Cayley-Hamilton. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000201/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "4. Espacio vectorial euclídeo."@es .

