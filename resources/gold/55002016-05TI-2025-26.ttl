<https://guia-kg.skai.etsisi.upm.es/resource/55002016/2025-26/didactic_resource/1> a ns1:DidacticResource ;
    ns1:bibliographyDescription "es el libro más recomendado sobre computación cuántica."@es ;
    ns1:bibliographyTitle "Michael A. Nielsen, Isaac L. Chuang, \"Quantum Computation and Quantum Information\". Cambridge University Press (2011)."@es ;
    ns1:bibliographyType "Bibliografía"@es .

