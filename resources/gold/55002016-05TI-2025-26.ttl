<https://guia-kg.skai.etsisi.upm.es/resource/55002016/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/55002016/2025-26/CB01>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55002016/2025-26/CE1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55002016/2025-26/CE2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55002016/2025-26/CE21F>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55002016/2025-26/CE3>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55002016/2025-26/CG1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55002016/2025-26/CG10> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/55002016/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55002016/2025-26/didactic_resource/2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55002016/2025-26/didactic_resource/3> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/55002016/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/55002016/2025-26/RA124>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55002016/2025-26/RA126>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55002016/2025-26/RA127>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55002016/2025-26/RA406> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/55002016/2025-26/syllabus> ;
    ns1:inpersonHours "30 horas (38.5%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation ""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "30 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/55002016/2025-26/eventSchedule> ;
    schema:description """Los ordenadores cuánticos son una realidad que permite resolver problemas de ingeniería. Se estima que en los próximos 5 años superen claramente a los clásicos y revolucionen el mundo de la programación, tanto la desarrollada por ingenieros como por sistemas de Inteligencia Artificial.
El contenido de la asignatura está organizado para la obtención de las siguientes capacidades:
razonar sobre los qubits o bits cuánticos y
programar los ordenadores que los usan (ordenadores cuánticos).
La metodología empleada consiste en dividir las sesiones en:
exposición de los conceptos
realización de ejercicios para aclarar su significado, los cuales irán progresivamente convirtiéndose en ejercicios de programación."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/jose.diazdelacruz%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/jose.diazdelacruz%40upm.es> ;
    schema:name "Computación y Programación Cuánticas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55002016/2025-26/CB01> a ns1:Competency ;
    ns1:competencyCode "CB01" ;
    ns1:competencyDescription "Que los estudiantes hayan demostrado poseer y comprender conocimientos en un área de estudio que parte de la base de la educación secundaria general, y se suele encontrar a un nivel que, si bien se apoya en libros de texto avanzados, incluye también algunos aspectos que implican conocimientos procedentes de la vanguardia de su campo de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55002016/2025-26/CE1> a ns1:Competency ;
    ns1:competencyCode "CE1" ;
    ns1:competencyDescription "Capacidad para la resolución de los problemas matemáticos que puedan plantearse en la ingeniería. Aptitud para aplicar los conocimientos sobre: álgebra lineal; geometría; geometría diferencial; cálculo diferencial e integral; ecuaciones diferenciales ordinarias y en derivadas parciales; métodos numéricos; algorítmica numérica; optimización"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55002016/2025-26/CE2> a ns1:Competency ;
    ns1:competencyCode "CE2" ;
    ns1:competencyDescription "Comprensión y dominio de los conceptos básicos sobre las leyes generales de la mecánica, termodinámica, campos y ondas y electromagnetismo y su aplicación para la resolución de problemas propios de la ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55002016/2025-26/CE21F> a ns1:Competency ;
    ns1:competencyCode "CE21F" ;
    ns1:competencyDescription "Capacidad para plantear modelos de optimizaciÃ³n lineales correspondientes a problemas relevantes en ingenierÃ­a de organizaciÃ³n. Conocimiento de las tÃ©cnicas de resoluciÃ³n apropiadas y aptitud para utilizar software profesional. Capacidad para comprender y utilizar los resultados obtenidos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55002016/2025-26/CE3> a ns1:Competency ;
    ns1:competencyCode "CE3" ;
    ns1:competencyDescription "Conocimientos básicos sobre el uso y programación de los ordenadores, sistemas operativos, bases de datos y programas informáticos con aplicación en ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55002016/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Conocer y aplicar conocimientos de ciencias y tecnologías básicas a la práctica de la Ingeniería Industrial."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55002016/2025-26/CG10> a ns1:Competency ;
    ns1:competencyCode "CG10" ;
    ns1:competencyDescription "Capacidad para generar nuevas ideas (Creatividad)."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55002016/2025-26/RA124> a ns1:LearningResult ;
    ns1:learningResultCode "RA124" ;
    ns1:learningResultDescription "Describir los elementos básicos de programación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55002016/2025-26/RA126> a ns1:LearningResult ;
