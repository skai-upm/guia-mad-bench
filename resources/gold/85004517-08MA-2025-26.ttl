    ns1:itemIndex 27 ;
    ns1:syllabusDescription "4.1. Sistemas de Agua Sanitaria"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85004517/2025-26/syllabus/28> a ns1:SyllabusItem ;
    ns1:itemIndex 28 ;
    ns1:syllabusDescription "4.1.1. Lección 6.1.1. Sistema de agua sanitaria. Subsistema de agua sanitaria fría. Subsistema de agua sanitaria caliente. Tratamiento de agua sanitaira (T). Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85004517/2025-26/syllabus/29> a ns1:SyllabusItem ;
    ns1:itemIndex 29 ;
    ns1:syllabusDescription "4.2. Sistema de Agua Residual"@es .

