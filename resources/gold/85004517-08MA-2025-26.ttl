<https://guia-kg.skai.etsisi.upm.es/resource/85004517/2025-26/CB2> a ns1:Competency ;
    ns1:competencyCode "CB2" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar sus conocimientos a su trabajo o vocación de una forma profesional y posean las competencias que suelen demostrarse por medio de la elaboración y defensa de argumentos y la resolución de problemas dentro de su área de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85004517/2025-26/CB5> a ns1:Competency ;
    ns1:competencyCode "CB5" ;
    ns1:competencyDescription "Que los estudiantes hayan desarrollado aquellas habilidades de aprendizaje necesarias para emprender estudios posteriores con un alto grado de autonomía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85004517/2025-26/CE11> a ns1:Competency ;
    ns1:competencyCode "CE11" ;
    ns1:competencyDescription "Conocimiento de las características de los componentes y sistemas electrónicos y de su aplicación a bordo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85004517/2025-26/CE15> a ns1:Competency ;
    ns1:competencyCode "CE15" ;
    ns1:competencyDescription "Conocimiento de las características de los sistemas de propulsión naval"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85004517/2025-26/CE18> a ns1:Competency ;
    ns1:competencyCode "CE18" ;
    ns1:competencyDescription "Conocimiento de los materiales específicos para máquinas, equipos y sistemas navales y de los criterios para su selección"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85004517/2025-26/CE20> a ns1:Competency ;
    ns1:competencyCode "CE20" ;
    ns1:competencyDescription "Conocimiento de los equipos y sistemas auxiliares navales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85004517/2025-26/CE22> a ns1:Competency ;
    ns1:competencyCode "CE22" ;
    ns1:competencyDescription "Capacidad para proyectar sistemas hidráulicos y neumáticos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85004517/2025-26/CE24> a ns1:Competency ;
    ns1:competencyCode "CE24" ;
    ns1:competencyDescription "Conocimiento de los métodos de proyecto de los sistemas auxiliares de los buques y artefactos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85004517/2025-26/CE5> a ns1:Competency ;
    ns1:competencyCode "CE5" ;
    ns1:competencyDescription "Capacidad de visión espacial y conocimiento de las técnicas de representación gráfica, tanto por métodos tradicionales de geometría métrica y geometría descriptiva, como mediante las aplicaciones de diseño asistido por ordenador."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85004517/2025-26/CE7> a ns1:Competency ;
    ns1:competencyCode "CE7" ;
    ns1:competencyDescription "Conocimiento de los conceptos fundamentales de la mecánica de fluidos y de su aplicación a las carenas de buques y artefactos, y a las máquinas, equipos y sistemas navales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85004517/2025-26/CE8> a ns1:Competency ;
    ns1:competencyCode "CE8" ;
    ns1:competencyDescription "Conocimiento de la ciencia y tecnología de materiales y capacidad para su selección y para la evaluación de su comportamiento."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85004517/2025-26/CG6> a ns1:Competency ;
    ns1:competencyCode "CG6" ;
    ns1:competencyDescription "Capacidad para el manejo de especificaciones, reglamentos y normas de obligado cumplimiento que afectan principalmente al proyecto de sistemas marinos y de su instalación a bordo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85004517/2025-26/CG7> a ns1:Competency ;
    ns1:competencyCode "CG7" ;
    ns1:competencyDescription "Capacidad para analizar y valorar el impacto social y ambiental de las soluciones técnicas navales."@es .

