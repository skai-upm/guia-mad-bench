        <https://guia-kg.skai.etsisi.upm.es/resource/45000115/2025-26/RA29>,
        <https://guia-kg.skai.etsisi.upm.es/resource/45000115/2025-26/RA30>,
        <https://guia-kg.skai.etsisi.upm.es/resource/45000115/2025-26/RA31> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/45000115/2025-26/syllabus> ;
    ns1:inpersonHours "61 horas (46.9%)"@es ;
    ns1:numberOfCredits 5.0 ;
    ns1:otherInformation "Esta asignatura trata específicamente algunos de los objetivos de desarrollo sostenible (ODS). En concreto, se abordan dispositivos esenciales (célula solar) para el desarrollo de energías renovables (ODS-3) y materiales electrónicos usados en todo tipos de dispositivos relacionados con ODS-3, ODS-9 y ODS-11."@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "61 horas"@es ;
    schema:activitiesWorkload "100.02%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/45000115/2025-26/eventSchedule> ;
    schema:description """El objetivo de la asignatura es que los estudiantes adquieran un conocimiento básico de los fundamentos de la física del estado sólido aplicados a materiales electrónicos, principalmente metales y semiconductores, y de sus propiedades electrónicas y ópticas. La asignatura culmina con la aplicación de dichas propiedades a distintos dispositivos micro y optoelectrónicos, con énfasis en los aspectos del material.
Esta asignatura resulta fundamental para los siguientes objetivos del título:
Obj 1. Conocer y comprender los fundamentos científicos del mundo de los materiales y sus interrelaciones entre la estructura, propiedades, procesado y aplicaciones.
Obj 3. Conocer el comportamiento mecánico, electrónico, químico y biológico de los materiales y saber aplicarlo al diseño, cálculo y modelización de los aspectos de elementos, componentes y equipos."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/j.pedros%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/adrian.hierro%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/alberto.bosca%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/j.pedros%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/jl.garcia.pomar%40upm.es> ;
    schema:name "Propiedades de Materiales I"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000115/2025-26/CE%202.> a ns1:Competency ;
    ns1:competencyCode "CE 2." ;
    ns1:competencyDescription "Saber modelizar el comportamiento (mecánico, electrónico, químico o biológico) de los materiales y su integración en componentes y dispositivos./ Know how to model the behavior (mechanical, electronic, chemical or biological) of materials and their integration into components and devices."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000115/2025-26/CE%205.> a ns1:Competency ;
    ns1:competencyCode "CE 5." ;
    ns1:competencyDescription "Capacitar para el aprendizaje autÃ³nomo de nuevos conocimientos y tÃ©cnicas / Train for autonomous learning of new knowledge and techniques"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000115/2025-26/CG%203> a ns1:Competency ;
    ns1:competencyCode "CG 3" ;
    ns1:competencyDescription "Comunicación oral y escrita"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000115/2025-26/RA27> a ns1:LearningResult ;
    ns1:learningResultCode "RA27" ;
    ns1:learningResultDescription "Utilizar con soltura la comunicación oral y escrita en lengua española e inglesa"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000115/2025-26/RA29> a ns1:LearningResult ;
    ns1:learningResultCode "RA29" ;
    ns1:learningResultDescription "Entender, asimilar y manejar los conceptos básicos que describen el comportamiento electrónico, magnético, térmico y óptico de los materiales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000115/2025-26/RA30> a ns1:LearningResult ;
    ns1:learningResultCode "RA30" ;
    ns1:learningResultDescription "Conocer y saber relacionar dicho comportamiento con la estructura del material a nivel atómico, molecular y macroscópico."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000115/2025-26/RA31> a ns1:LearningResult ;
    ns1:learningResultCode "RA31" ;
    ns1:learningResultDescription "Conocer y saber calcular mediante las teorías más relevantes la respuesta electrónica, magnética, térmica y óptica de los materiales."@es .

