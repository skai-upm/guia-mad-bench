<https://guia-kg.skai.etsisi.upm.es/resource/45000115/2025-26/syllabus> a ns1:Syllabus ;
    ns1:hasItem <https://guia-kg.skai.etsisi.upm.es/resource/45000115/2025-26/syllabus/0>,
        <https://guia-kg.skai.etsisi.upm.es/resource/45000115/2025-26/syllabus/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/45000115/2025-26/syllabus/2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/45000115/2025-26/syllabus/3>,
        <https://guia-kg.skai.etsisi.upm.es/resource/45000115/2025-26/syllabus/4>,
        <https://guia-kg.skai.etsisi.upm.es/resource/45000115/2025-26/syllabus/5> .

<https://guia-kg.skai.etsisi.upm.es/resource/45000115/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Tema 0: Introducción. Horarios, normas, evaluación. Presentación del temario de la asignatura. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000115/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "2. Tema 1: Conceptos básicos de la ciencia de materiales: Estructura atómica. Tipos de enlaces en sólidos. Teoría cinética molecular. Distribución de energía y velocidad. Estructura cristalina y defectos cristalinos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000115/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "3. Tema 2: Conducción Eléctrica en Sólidos. Teoría clásica: modelo de Drude y resistividad. Regla de Matthiessen. Efecto Hall. Resistividad de películas delgadas metálicas. Interconexiones en microelectrónica. Conductividad eléctrica de no-metales. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000115/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "4. Tema 3. Teoría de Sólidos. Orbitales moleculares y teoría de bandas. Densidad de estados. Estadísticas de partículas. Teoría cuántica de metales. Energía de Fermi. Emisión termoiónica, efecto Schottky y emisión de campo. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000115/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "5. Tema 4. Materiales Semiconductores. Semiconductores intrínsecos y extrínsecos. Dopaje. Conductividad y temperatura. Recombinación de portadores. Ecuaciones de conducción y difusión. Ecuación de continuidad. Absorción óptica. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000115/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "6. Tema 5. Dispositivos Semiconductores. Contactos óhmicos y Schottky. La unión p-n en equilibrio, polarización en directa e inversa. Ejemplos de dispositivos electrónicos y optoelectrónicos: transistor JFET y célula solar. Sin subniveles"@es .

