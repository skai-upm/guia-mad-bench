    schema:name "Matemáticas I"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000627/2025-26/CE1> a ns1:Competency ;
    ns1:competencyCode "CE1" ;
    ns1:competencyDescription "Capacidad para conocer, entender y utilizar los principios de Álgebra lineal, cálculo diferencial e integral, ecuaciones diferenciales y métodos y algorítmica numérica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000627/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Conocer y aplicar conocimientos de ciencias y tecnologías básicas a la práctica de la Ingeniería de organización"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000627/2025-26/CG5> a ns1:Competency ;
    ns1:competencyCode "CG5" ;
    ns1:competencyDescription "Saber comunicar los conocimientos y conclusiones, tanto de forma oral, escrita y gráfica, a públicos especializados y no especializados de un modo claro y sin ambigüedades"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000627/2025-26/CG6> a ns1:Competency ;
    ns1:competencyCode "CG6" ;
    ns1:competencyDescription "Poseer habilidades de aprendizaje que permitan continuar estudiando a lo largo de la vida para su adecuado desarrollo profesional"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000627/2025-26/RA1> a ns1:LearningResult ;
    ns1:learningResultCode "RA1" ;
    ns1:learningResultDescription "Comprender los conceptos básicos del álgebra lineal y conocimiento de los algoritmos esenciales de la misma."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000627/2025-26/RA15> a ns1:LearningResult ;
    ns1:learningResultCode "RA15" ;
    ns1:learningResultDescription "Utilizar todos los conceptos introducidos para construir modelos de algunos problemas reales sencillos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000627/2025-26/RA2> a ns1:LearningResult ;
    ns1:learningResultCode "RA2" ;
    ns1:learningResultDescription "Comprender del significado e importancia de la linealidad como metodología para la formulación de problemas de ingeniería"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000627/2025-26/RA3> a ns1:LearningResult ;
    ns1:learningResultCode "RA3" ;
    ns1:learningResultDescription "Adquirir perspectiva introductoria a las diversas aplicaciones del álgebra lineal a los problemas de optimización, elaboración de modelos lineales y representación de las soluciones de las ecuaciones lineales en el sentido más amplio del término"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000627/2025-26/RA8> a ns1:LearningResult ;
    ns1:learningResultCode "RA8" ;
    ns1:learningResultDescription "Utilizar estos conceptos para construir modelos de algunos problemas reales sencillos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000627/2025-26/RA9> a ns1:LearningResult ;
    ns1:learningResultCode "RA9" ;
    ns1:learningResultDescription "Distinguir cuando los modelos se pueden resolver mediante las técnicas introducidas y, en tales casos, capacidad para obtener la solución"@es .

