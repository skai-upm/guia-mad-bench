    ns1:itemIndex 3 ;
    ns1:syllabusDescription "4. Recursos hídricos convencionales y no convencionales. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65003030/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "5. El agua superficial: morfología de las cuencas. Sin subniveles"@es .

