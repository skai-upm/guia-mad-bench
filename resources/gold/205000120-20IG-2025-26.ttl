    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. ELEMENTOS DE EDIFICACIÓN AGRARIA: Cubiertas; cerramientos de fachada y tabiquería; solados; elementos prefabricados de hormigón. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000120/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "2. CÁLCULO DE ACCIONES Sin subniveles"@es .

