    ns1:itemIndex 2 ;
    ns1:syllabusDescription "3. ESTRUCTURAS DE HORMIGÓN: Componentes y propiedades; Durabilidad, puesta en obra y control de calidad; E.L.U. solicitaciones normales y cortantes. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000120/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "4. CÁLCULO DE ZAPATAS AISLADAS: Comprobaciones de estabilidad; comprobaciones de resistencia. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000120/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "5. ESTRUCTURAS DE ACERO: Propiedades del material; sistemas estructurales; E.L.U. resistencia de secciones; E.L.U. resistencia de barras; E.L.S. flechas y desplomes. Sin subniveles"@es .

