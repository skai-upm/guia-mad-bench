    schema:hasCourseInstance <https://guia-kg.skai.etsisi.upm.es/resource/33000882/2025-26> ;
    schema:name "Constructive Analysis Of Singular Buildings"@en,
        "Análisis Constructivo de Edificios Singulares"@es ;
    schema:numberOfCredits 3.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/33000882/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/33000882/2025-26/CB08>,
        <https://guia-kg.skai.etsisi.upm.es/resource/33000882/2025-26/CB09>,
        <https://guia-kg.skai.etsisi.upm.es/resource/33000882/2025-26/CE01>,
        <https://guia-kg.skai.etsisi.upm.es/resource/33000882/2025-26/CG01>,
        <https://guia-kg.skai.etsisi.upm.es/resource/33000882/2025-26/CG02> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/33000882/2025-26/didactic_resource/1> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/33000882/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/33000882/2025-26/RA1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/33000882/2025-26/RA2> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/33000882/2025-26/syllabus> ;
    ns1:inpersonHours "40 horas y 20 minutos (51.7%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation ""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "40 horas y 20 minutos"@es ;
    schema:activitiesWorkload "80%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/33000882/2025-26/eventSchedule> ;
    schema:description """En esta asignatura se estudiarán diversos casos prácticos de edificios, referidos a las diferentes tipologías estudiadas en la asignatura de Introducción a las Tipologías. Se tratará siempre de edificios importantes o significativos, caracterizados por sus soluciones constructivas y aspectos innovadores. Se tratará de descripciones intensivas, considerando los aspectos más relevantes o diferenciales del diseño: sistemas constructivos, diseño estructural, acondicionamiento ambiental principalmente, pero también aspectos organizativos o funcionales, etc.
La asignatura tiene un doble objetivo: en primer lugar, recuperar el estudio de los sistemas constructivos contemporáneos, pero estudiándolos siempre en relación al diseño arquitectónico, buscando siempre un enfoque integral hacia el edificio como un todo. Por otra parte la asignatura complementa a la asignatura de Introducción, aportando nuevos casos de análisis.

Bibliografía Básica

Araujo.R- Construir en altura. La arquitectura como técnica 2. Reverté Madrid 2012
Araujo.R- Superficies. La arquitectura como técnica 1. ATC Ed. Madrid 2007.
Araujo,R- Técnicas y Sistemas. La arquitectura como técnica 3. Archivo digital UPM"""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/ramon.araujo%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/ramon.araujo%40upm.es> ;
    schema:name "Análisis Constructivo de Edificios Singulares"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000882/2025-26/CB08> a ns1:Competency ;
    ns1:competencyCode "CB08" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de integrar conocimientos y enfrentarse a la complejidad de formular juicios a partir de una información que, siendo incompleta o limitada, incluya reflexiones sobre las responsabilidades sociales y éticas vinculadas a la aplicación de sus conocimientos y juicios"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000882/2025-26/CB09> a ns1:Competency ;
    ns1:competencyCode "CB09" ;
    ns1:competencyDescription "Que los estudiantes sepan comunicar sus conclusiones y los conocimientos y razones últimas que las sustentan a públicos especializados y no especializados de un modo claro y sin ambigüedades"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000882/2025-26/CE01> a ns1:Competency ;
    ns1:competencyCode "CE01" ;
    ns1:competencyDescription "Criterios de base científica para el proyecto del edificio. Adquisición de conocimientos básicos avanzados en relación a las nuevas tecnologías en construcción y de control ambiental. Introducción a las tipologías arquitectónicas y constructivas. Adquisición de conocimientos y criterios básicos para la integración en el diseño de las diferentes tecnologías arquitectónicas y su aplicación específica a las diferentes tipologías arquitectónicas y constructivas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000882/2025-26/CG01> a ns1:Competency ;
    ns1:competencyCode "CG01" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en entornos nuevos o poco conocidos dentro de contextos más amplios (o multidisciplinares) relacionados con su área de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000882/2025-26/CG02> a ns1:Competency ;
    ns1:competencyCode "CG02" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de integrar conocimientos y enfrentarse a la complejidad de formular juicios a partir de una información que, siendo incompleta o limitada, incluya reflexiones sobre las responsabilidades sociales y éticas vinculadas a la aplicación de sus conocimientos y juicios"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000882/2025-26/RA1> a ns1:LearningResult ;
    ns1:learningResultCode "RA1" ;
    ns1:learningResultDescription "Los alumnos aprenderán a realizar la captura, almacenamiento, tratamiento y análisis de información requerida para los proyectos de la investigación en materiales de construcción, sistemas constructivos,"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000882/2025-26/RA2> a ns1:LearningResult ;
    ns1:learningResultCode "RA2" ;
    ns1:learningResultDescription "Aprenderán también métodos de toma de decisiones aplicables en el campo de la investigación en materiales de construcción, sistemas constructivos y técnicas arquitectónicas"@es .

