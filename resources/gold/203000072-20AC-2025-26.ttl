<https://guia-kg.skai.etsisi.upm.es/resource/203000072/2025-26/RA56> a ns1:LearningResult ;
    ns1:learningResultCode "RA56" ;
    ns1:learningResultDescription "Conocer los aspectos más relevantes del control y prevención de estas enfermedades y poder determinar la estrategia de lucha más adecuada."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000072/2025-26/RA57> a ns1:LearningResult ;
    ns1:learningResultCode "RA57" ;
    ns1:learningResultDescription "Saber buscar las fuentes de información existentes en relación al conocimiento científico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000072/2025-26/RA58> a ns1:LearningResult ;
    ns1:learningResultCode "RA58" ;
    ns1:learningResultDescription "Saber aplicar la legislación existente sobre Sanidad Animal en porcino."@es .

