<https://guia-kg.skai.etsisi.upm.es/resource/565000484/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "2.1.3. Cuantificación de los estados de energía: espectros y el átomo de Bohr-Sommerfeld. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000484/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "2.1.4. Ondas de materia. Hipótesis de de Broglie. Paquetes de ondas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000484/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "2.2. Postulados de la Física Cuántica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000484/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "2.2.1. El experimento de la doble rendija. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000484/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "2.2.2. Principio de Indeterminación de Heisenberg. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000484/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "2.2.3. Ecuación de Schrödinger. Potenciales separables. Evolución temporal y estados estacionarios. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000484/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "2.2.4. Formalismo de la Mecánica cuántica. Interpretación probabilística. Cálculo de observables. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000484/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "3. MODELOS CUÁNTICOS UNIDIMENSIONALES"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000484/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. El origen de la Relatividad: Transformaciones de coordenadas y principios de invariancia. Referenciales inerciales Galileanos en Mecánica. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000484/2025-26/syllabus/20> a ns1:SyllabusItem ;
    ns1:itemIndex 20 ;
    ns1:syllabusDescription "3.1. Los pozos de potencial. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000484/2025-26/syllabus/21> a ns1:SyllabusItem ;
    ns1:itemIndex 21 ;
    ns1:syllabusDescription "3.2. Barreras de potencial y efecto túnel. El Microscopio de barrido de Efecto Túnel. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000484/2025-26/syllabus/22> a ns1:SyllabusItem ;
    ns1:itemIndex 22 ;
    ns1:syllabusDescription "3.3. El oscilador armónico. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000484/2025-26/syllabus/23> a ns1:SyllabusItem ;
    ns1:itemIndex 23 ;
    ns1:syllabusDescription "4. APLICACIONES DE LA FÍSICA CUÁNTICA"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000484/2025-26/syllabus/24> a ns1:SyllabusItem ;
    ns1:itemIndex 24 ;
    ns1:syllabusDescription "4.1. Física del Estado Sólido: Tipos de sólidos. Estadística de Fermi. Electrones en metales. Potenciales periódicos. Teoría de bandas. Semiconductores. Uniones p-n. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000484/2025-26/syllabus/25> a ns1:SyllabusItem ;
    ns1:itemIndex 25 ;
    ns1:syllabusDescription "4.2. Estadística de Bose-Einstein. Emisión estimulada.Láseres. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000484/2025-26/syllabus/26> a ns1:SyllabusItem ;
    ns1:itemIndex 26 ;
    ns1:syllabusDescription "4.3. Física Nuclear: Propiedades de los núcleos. Fuerzas nucleares. Radiactividad, tipos de radiación y dosimetría. Aplicaciones en radioterapia y radiodiagnóstico (PET, RMN) Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000484/2025-26/syllabus/27> a ns1:SyllabusItem ;
    ns1:itemIndex 27 ;
    ns1:syllabusDescription "4.4. Reacciones nucleares: Fisión Nuclear y Fusión Nuclear. Reacción en cadena. Reactores nucleares. ¿Qué ocurrió en Chernóbil y Fukushima? El futuro de la energía de fusión: el ITER. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000484/2025-26/syllabus/28> a ns1:SyllabusItem ;
    ns1:itemIndex 28 ;
    ns1:syllabusDescription "4.5. Introducción a la Computation Cuántica: propiedades de los qbits, puertas y circuitos cuánticos, algoritmo de Grover, computadores cuánticos y aplicaciones de la computación cuántica. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000484/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "1.3. Relatividad y Electromagnetismo: la hipótesis del éter. El experimento de Michelson-Morley Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000484/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "1.4. Principios de la relatividad especial: Los postulados de Einstein y el concepto de tiempo. Relatividad de la simultaneidad y sus consecuencias. Relojes en movimiento relativo. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000484/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "1.5. Cinemática relativista I: Deducción de las transformaciones de Lorentz. Ley de composicion de velocidades. Diagramas espacio-temporales, conos de luz, invariantes, Interpretacion grafica de simultaneidad y causalidad. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000484/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "1.6. Cinemática relativista II: Dilatación temporal y tiempo propio. Contracción de longitudes y longitud propia. Aplicación al caso de los muones atmosféricos. La paradoja de los gemelos. Aplicación al GPS. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000484/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "1.7. Dinámica relativista básica: Métrica en Minkowsky, cuadrivectores, cuadri-velocidad y cuadri-momento. Relación entre energía y momento relativista. Equivalencia masa-energía, creación de pares, energía nuclear. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000484/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "2. FUNDAMENTOS DE LA FÍSICA CUÁNTICA"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000484/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "2.1. Los orígenes de la Física Cuántica"@es .

