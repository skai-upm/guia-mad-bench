    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/145016003/2025-26/syllabus> ;
    ns1:inpersonHours "40 horas y 30 minutos (31.2%)"@es ;
    ns1:numberOfCredits 5.0 ;
    ns1:otherInformation "La asignatura se relaciona con el ODS7 y más concretamente con la reducción de emisiones de gases de efecto invernadero."@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "48 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/145016003/2025-26/eventSchedule> ;
    schema:description """Planificación de Vuelo es una asignatura que se basa para su profundo y correcto desarrollo en otras asignaturas, tales como Derecho Aeronáutico, Aerodinámica y Mecánica del Vuelo, Actuaciones del avión, Navegación Aérea y Cartografía, Meteorología, Gestión del Tránsito Aéreo (ATM). Aglutina los conocimiento de todas estas áreas para llevar a cabo una planificación del vuelo de manera que este se realice de acuerdo a la norma, de la manera más segura y eficiente posible.

El desarrollo se adapta al contenido de la normativa europea siguiente: REGLAMENTO (UE) No 1178/2011 DE LA COMISIÓN de 3 de noviembre de 2011 por el que se establecen requisitos técnicos y procedimientos administrativos relacionados con el personal de vuelo de la aviación civil en virtud del Reglamento (CE) no 216/2008 del Parlamento Europeo y del Consejo. Más concretamente su anexo I Parte FCL, Temas 031 y 033."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/josefelix.alonso%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/jl.munoz%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/josefelix.alonso%40upm.es> ;
    schema:name "Planificación del Vuelo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145016003/2025-26/CE15> a ns1:Competency ;
    ns1:competencyCode "CE15" ;
    ns1:competencyDescription "Conocimiento adecuado de las operaciones de vuelo en sus diferentes aspectos organizativos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145016003/2025-26/CG01> a ns1:Competency ;
    ns1:competencyCode "CG01" ;
    ns1:competencyDescription "Capacidad para llevar a cabo actividades de proyección, de dirección técnica, de redacción de informes, y de asesoramiento técnico en tareas relativas a la industria del Transporte Aéreo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145016003/2025-26/CT01> a ns1:Competency ;
    ns1:competencyCode "CT01" ;
    ns1:competencyDescription "Capacidad de Organización y de Planificación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145016003/2025-26/CT03> a ns1:Competency ;
    ns1:competencyCode "CT03" ;
    ns1:competencyDescription "Capacidad para identificar y resolver problemas aplicando, con creatividad, los conocimientos adquiridos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145016003/2025-26/RA18> a ns1:LearningResult ;
    ns1:learningResultCode "RA18" ;
    ns1:learningResultDescription "Es capaz de interpretar la normativa específica de aeropuertos y Navegación Aérea y el funcionamiento y la gestión del aeropuerto y el transporte aéreo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145016003/2025-26/RA20> a ns1:LearningResult ;
    ns1:learningResultCode "RA20" ;
    ns1:learningResultDescription "Es capaz de analizar la necesidad de instalación de equipos de control en función del tipo de aeronave."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145016003/2025-26/RA21> a ns1:LearningResult ;
    ns1:learningResultCode "RA21" ;
    ns1:learningResultDescription "Interpreta las particularidades operativas en los servicios ATS en función de las características de las aeronaves."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145016003/2025-26/RA23> a ns1:LearningResult ;
    ns1:learningResultCode "RA23" ;
    ns1:learningResultDescription "Analiza la operación de la aeronave desde el punto de vista de la explotación de la compañía aérea"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145016003/2025-26/RA24> a ns1:LearningResult ;
    ns1:learningResultCode "RA24" ;
    ns1:learningResultDescription "Organiza y valora de prácticas operativas en compañías aéreas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145016003/2025-26/RA33> a ns1:LearningResult ;
    ns1:learningResultCode "RA33" ;
    ns1:learningResultDescription "Reconoce el impacto de la meteorología en la operación de la aeronave."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145016003/2025-26/RA40> a ns1:LearningResult ;
    ns1:learningResultCode "RA40" ;
    ns1:learningResultDescription "Comprende los conceptos básicos de la Navegación y Circulación Aérea y su aplicación en la operación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145016003/2025-26/RA91> a ns1:LearningResult ;
    ns1:learningResultCode "RA91" ;
    ns1:learningResultDescription "Aplica los aspectos más destacados del vuelo para su aplicación a la navegación aérea"@es .

