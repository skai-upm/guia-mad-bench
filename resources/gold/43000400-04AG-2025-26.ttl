<https://guia-kg.skai.etsisi.upm.es/resource/43000400/2025-26/CGP06> a ns1:Competency ;
    ns1:competencyCode "CGP06" ;
    ns1:competencyDescription "Conocimiento para aplicar las capacidades técnicas y gestoras en actividades de I+D+i dentro del ámbito de la ingeniería civil. Incorpora las competencias CB6, CB7 y CB8."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000400/2025-26/CT1> a ns1:Competency ;
    ns1:competencyCode "CT1" ;
    ns1:competencyDescription "Capacidad de preparar y presentar comunicaciones orales, escritas y gráficas, estructurada y argumentadamente. Desarrolla la competencia transversal 4ª del Real Decreto."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000400/2025-26/CT2> a ns1:Competency ;
    ns1:competencyCode "CT2" ;
    ns1:competencyDescription "Polivalencia y capacidad de aprendizaje autónomo. Desarrolla la competencia transversal 5ª del Real Decreto."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000400/2025-26/CT4> a ns1:Competency ;
    ns1:competencyCode "CT4" ;
    ns1:competencyDescription "Capacidad de organizar y dirigir los esfuerzos de un equipo. Desarrolla la competencia transversal 5ª de la normativa UPM."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000400/2025-26/CT5> a ns1:Competency ;
    ns1:competencyCode "CT5" ;
    ns1:competencyDescription "Capacidad de ejercer las funciones profesionales de proyecto, cálculo, evaluación técnica, planificación y gestión técnica mediante el uso de normativa europea e internacional. Desarrolla la competencia transversal 7ª de la normativa UPM."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000400/2025-26/CT7> a ns1:Competency ;
    ns1:competencyCode "CT7" ;
    ns1:competencyDescription "Capacidad de utilización de los servicios de información y comunicación para el ejercicio de las funciones profesionales del perfil de egreso. Desarrolla la competencia transversal 3ª de la normativa UPM."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000400/2025-26/CT8> a ns1:Competency ;
    ns1:competencyCode "CT8" ;
    ns1:competencyDescription "Capacidad de diseñar, analizar e interpretar experimentos relevantes en ingeniería civil."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000400/2025-26/RA1> a ns1:LearningResult ;
    ns1:learningResultCode "RA1" ;
    ns1:learningResultDescription "Formula y resuelve problemas matemáticos y numéricos avanzados de ingeniería civil, identificando sus diferentes componentes científicos y técnicos y seleccionando y acoplando con eficacia los métodos de resolución."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000400/2025-26/RA25> a ns1:LearningResult ;
    ns1:learningResultCode "RA25" ;
    ns1:learningResultDescription "Aplica y evalúa técnicas avanzadas para la construcción, control y gestión medioambiental de sistemas hidráulicos y energéticos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000400/2025-26/RA70> a ns1:LearningResult ;
    ns1:learningResultCode "RA70" ;
    ns1:learningResultDescription "Planifica las infraestructuras y la explotación de recursos energéticos, incorporando los condicionantes y efectos económicos y medioambientales"@es .

