<https://guia-kg.skai.etsisi.upm.es/resource/205000075/2025-26/syllabus> a ns1:Syllabus ;
    ns1:hasItem <https://guia-kg.skai.etsisi.upm.es/resource/205000075/2025-26/syllabus/0>,
        <https://guia-kg.skai.etsisi.upm.es/resource/205000075/2025-26/syllabus/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/205000075/2025-26/syllabus/10>,
        <https://guia-kg.skai.etsisi.upm.es/resource/205000075/2025-26/syllabus/11>,
        <https://guia-kg.skai.etsisi.upm.es/resource/205000075/2025-26/syllabus/12>,
        <https://guia-kg.skai.etsisi.upm.es/resource/205000075/2025-26/syllabus/13>,
        <https://guia-kg.skai.etsisi.upm.es/resource/205000075/2025-26/syllabus/14>,
        <https://guia-kg.skai.etsisi.upm.es/resource/205000075/2025-26/syllabus/15>,
        <https://guia-kg.skai.etsisi.upm.es/resource/205000075/2025-26/syllabus/16>,
        <https://guia-kg.skai.etsisi.upm.es/resource/205000075/2025-26/syllabus/17>,
        <https://guia-kg.skai.etsisi.upm.es/resource/205000075/2025-26/syllabus/2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/205000075/2025-26/syllabus/3>,
        <https://guia-kg.skai.etsisi.upm.es/resource/205000075/2025-26/syllabus/4>,
        <https://guia-kg.skai.etsisi.upm.es/resource/205000075/2025-26/syllabus/5>,
        <https://guia-kg.skai.etsisi.upm.es/resource/205000075/2025-26/syllabus/6>,
        <https://guia-kg.skai.etsisi.upm.es/resource/205000075/2025-26/syllabus/7>,
        <https://guia-kg.skai.etsisi.upm.es/resource/205000075/2025-26/syllabus/8>,
        <https://guia-kg.skai.etsisi.upm.es/resource/205000075/2025-26/syllabus/9> .

<https://guia-kg.skai.etsisi.upm.es/resource/205000075/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Principios Generales de la Bioquímica. Composición química de los seres vivos. El agua. Jerarquía y Organización de seres vivos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000075/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "2. Glúcidos. Monosacáridos, disacáridos y polisacáridos. Estructura y funciones. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000075/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "11. Dogma central: del gen a la proteína. Control de la expresión, Transcripción. Traducción. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000075/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "12. Membrana: estructura y función. Transportadores, canales, receptores, bombas, enzimas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000075/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "13. Orgánulos celulares. Estructura y función. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000075/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "14. Matriz extracellular y pared celular. Composición. Funciones. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000075/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "15. Citosqueleto y movilidad celular. Microfilamentos. Microtúbulos. Filamentos intermedios. Proteínas motoras. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000075/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "16. Ciclo celular. Fases. Mitosis. Citocinesis. Fisión binaria. Sistemas de control del ciclo celular. Muerte celular programada. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000075/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "17. Meiosis. Sobrecruzamiento. Fases. Productos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000075/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "18. Niveles de organización celular. Tejidos vegetales y tejidos animales. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000075/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "3. Proteínas. Aminoácidos. Enlace peptídico. Estructura proteica y función. Punto isoeléctrico. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000075/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "4. Lípidos. Propiedades, tipos y funciones. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000075/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "5. Ácidos nucleicos. Propiedades, composición y funciones. ADN y ARN. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000075/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "6. Enzimas. Biocatalizadores. Cinética enzimática. Inhibición y regulación. Aplicación de enzimas a la Ingeniería agrícola. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000075/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "7. Fotosíntesis y taller plantas C3/C4 y plantas CAM. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000075/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "8. Bioenergética. ATP. Rutas catabólicas, anabólicas y anfibólicas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000075/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "9. Introducción a la Biología Celular. ¿Qué es una célula? Tipos de células: procariota y célula eucariota. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000075/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "10. Cromatina, cromosomas y núcleo celular. Organización del ADN. Estructura y dinámica nuclear. Sin subniveles"@es .

