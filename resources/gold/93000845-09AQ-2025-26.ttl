        <https://guia-kg.skai.etsisi.upm.es/resource/93000845/2025-26/RA84> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/93000845/2025-26/syllabus> ;
    ns1:inpersonHours "48 horas (30.8%)"@es ;
    ns1:numberOfCredits 6.0 ;
    ns1:otherInformation """La asignatura se relaciona con los Objetivos de Desarrollo Sostenible de la agenda 2030 de la siguiente forma:
ODS3 sobre salud y bienestar para todos y todas en todas las edades. La asignatura contribuye a la formación en dispositivos que permiten ayudar al diagnóstico de enfermedades, aumentar la calidad de los alimentos y mejorar el medioambiente.

ODS4 sobre educación de calidad, en particular el 4.4, dando una formación de calidad para aumentar el número de personas que adquieren competencias profesionales para acceder a empleos de calidad."""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "48 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/93000845/2025-26/eventSchedule> ;
    schema:description "This course deals with one of the most powerful analytical tools for the detection and measurement of (bio)chemical substances: biosensors. It aims to provide the student with the basic knowledge and latest trends in this field, with emphasis on devices, materials and technological processes associated with the design and manufacture of biosensors. The course has a clear multidisciplinary character; specifically, concepts from Chemistry, Physics, Biology, Materials Science and Micro/Nano-technology will be treated and interrelated."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/carlos.angulo.barrios%40upm.es> ;
    schema:inLanguage "Inglés"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/carlos.angulo.barrios%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/josejavier.serrano%40upm.es> ;
    schema:name "Biosensores"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000845/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Poseer y comprender conocimientos que aporten una base u oportunidad de ser originales en el desarrollo y/o aplicación de ideas, a menudo en un contexto de investigación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000845/2025-26/CG2> a ns1:Competency ;
    ns1:competencyCode "CG2" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en entornos nuevos o poco conocidos dentro de contextos más amplios (o multidisciplinares) relacionados con su área de estudio."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000845/2025-26/CG4> a ns1:Competency ;
    ns1:competencyCode "CG4" ;
    ns1:competencyDescription "Que los estudiantes sepan comunicar sus conclusiones ?y los conocimientos y razones últimas que las sustentan? a públicos especializados y no especializados de un modo claro y sin ambigüedades."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000845/2025-26/CG5> a ns1:Competency ;
    ns1:competencyCode "CG5" ;
    ns1:competencyDescription "Que los estudiantes posean las habilidades de aprendizaje que les permitan continuar estudiando de un modo que habrá de ser en gran medida autodirigido o autónomo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000845/2025-26/RA82> a ns1:LearningResult ;
    ns1:learningResultCode "RA82" ;
    ns1:learningResultDescription "Capacity of analizing and characterizing biosensors"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000845/2025-26/RA84> a ns1:LearningResult ;
    ns1:learningResultCode "RA84" ;
    ns1:learningResultDescription "Knowledge on key technologies in the background of biosensors"@es .

