    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Teoría de la Probabilidad"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000513/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Modelado probabilístico. Concepto de probabilidad. Espacio de probabilidad. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000513/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "3.1. Concepto. Representación vectorial. Caso bidimensional. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000513/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "3.2. Funciones de distribución y densidad. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000513/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "3.3. Distribuciones condicionales. Independencia. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000513/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "3.4. Esperanzas matemáticas. Momentos conjuntos. Incorrelación y ortogonalidad. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000513/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "3.5. Regresión. Sin subniveles"@es .

