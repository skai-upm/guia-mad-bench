    ns1:itemIndex 15 ;
    ns1:syllabusDescription "3.6. Funciones de variables aleatorias. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000513/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "3.7. Secuencias de variables aleatorias. Teoremas asintóticos. Sin subniveles"@es .

