    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/93001014/2025-26/eventSchedule> ;
    schema:description """El contenido de la asignatura se centra en los siguientes temas:

- Introducción a la Seguridad Física.: Objetivos, Legislación, LDirectiva de Resiliencias, Directiva NIS2, Funciones, Roles y Organización, Convergencia
- Objetivos de control y controles de la Seguridad Física.
- Seguridad Convergente en CPDs
- Experiencias del entorno empresarial y Gobierno
- Gestión de Incidentes de Seguridad: Gestión y comunicación
- Casos de Estudio por parte del alumno"""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/victor.villagra%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/ff.lazaro%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/victor.villagra%40upm.es> ;
    schema:name "Seguridad Física y Convergencia"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93001014/2025-26/CB07> a ns1:Competency ;
    ns1:competencyCode "CB07" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en entornos nuevos o poco conocidos dentro de contextos más amplios (o multidisciplinares) relacionados con su área de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93001014/2025-26/CB09> a ns1:Competency ;
    ns1:competencyCode "CB09" ;
    ns1:competencyDescription "Que los estudiantes sepan comunicar sus conclusiones y los conocimientos y razones últimas que las sustentan a públicos especializados y no especializados de un modo claro y sin ambigüedades"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93001014/2025-26/CE02> a ns1:Competency ;
    ns1:competencyCode "CE02" ;
    ns1:competencyDescription "Capacidad para diseñar estrategias, políticas y normativas de ciberseguridad corporativa"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93001014/2025-26/CE07> a ns1:Competency ;
    ns1:competencyCode "CE07" ;
    ns1:competencyDescription ""@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93001014/2025-26/CG01> a ns1:Competency ;
    ns1:competencyCode "CG01" ;
    ns1:competencyDescription "Proporcionar al alumno los conceptos y tecnologías utilizadas en la implantación de la Ciberseguridad en una organización, dotándole de la capacidad para definir estrategias, políticas y normas para la seguridad corporativa"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93001014/2025-26/CG02> a ns1:Competency ;
    ns1:competencyCode "CG02" ;
    ns1:competencyDescription "Dotar al alumno del conocimiento de los distintos tipos de amenazas que pueden afectar a una organización y sus consecuencias en diferentes escenarios sociales, económicos e industriales y dotarle de la capacidad de aplicar las técnicas de análisis y gestión de todo tipo de riesgos para definir e implantar las salvaguardas necesarias para mitigar o eliminar sus impactos hacer resiliente a la organización"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93001014/2025-26/CT04> a ns1:Competency ;
    ns1:competencyCode "CT04" ;
    ns1:competencyDescription "Organización y planificación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93001014/2025-26/RA21> a ns1:LearningResult ;
    ns1:learningResultCode "RA21" ;
    ns1:learningResultDescription "Conocer las distintas aproximaciones a la Seguridad Física de las Organizaciones, siendo capaz de adoptar un diseño convergente de la seguridad física y lógica, en un marco de seguridad integral"@es .

