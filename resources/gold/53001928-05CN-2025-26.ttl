    schema:courseCode 53001928 ;
    schema:hasCourseInstance <https://guia-kg.skai.etsisi.upm.es/resource/53001928/2025-26> ;
    schema:name "Advanced Technologies For Nuclear Reactors"@en,
        "Tecnologías Avanzadas en Reactores Nucleares"@es ;
    schema:numberOfCredits 3.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/53001928/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/53001928/2025-26/MUII.%20%28a%29>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001928/2025-26/MUII.%20%28g%29>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001928/2025-26/MUII.%20%28j%29>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001928/2025-26/MUII.%20%28l%29>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001928/2025-26/MUII.CE01>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001928/2025-26/MUII.CG04>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001928/2025-26/MUII.CG11> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/53001928/2025-26/didactic_resource/1> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/53001928/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/53001928/2025-26/RA10>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001928/2025-26/RA8>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001928/2025-26/RA9> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/53001928/2025-26/syllabus> ;
    ns1:inpersonHours "64 horas (79%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation """En caso de tener que recurrir a la telenseñanza por medidas de confinamiento, las clases se realizarán por vía telemática, preferentemente por Windows Teams.
La comunicación con el profesor también se realizará por esta vía.
La asignatura permite trabajar algunos de los Objetivos de Desarrollo Sostenible como el ODS 7 "Garantizar el acceso a una energía asequible, segura, sostenible y moderna para todos" (tema reactores nucleares avanzados)."""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "66 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/53001928/2025-26/eventSchedule> ;
    schema:description "La asignatura de Tecnologías avanzadas en reactores nucleares pretende dar una visión completa pero a la vez detallada de los reactores nucleares que actualmente están en diseño y construcción en todo el mundo. En una primera parte de la asigntura, se abordan los reactores que están actualmente licenciándose y construyendose en distintos países como EEUU. Francia, Finlandia, China, Reino Unido y Rusia. En la segunda parte, se tratan los reactores de fisión del futuro (Generación IV), que por otra parte cuentan con muchos precedentes experimentales del pasado."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/gonzalo.jimenez%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/emilio.castro%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/gonzalo.jimenez%40upm.es> ;
    schema:name "Tecnologías Avanzadas en Reactores Nucleares"@es .

