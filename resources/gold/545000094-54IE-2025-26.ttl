<https://guia-kg.skai.etsisi.upm.es/resource/545000094/2025-26/RA17> a ns1:LearningResult ;
    ns1:learningResultCode "RA17" ;
    ns1:learningResultDescription "Distinguir las influencias que los factores históricos económicos y sociales han tenido en el desarrollo de los diferentes sistemas constructivos empleados en la construcción popular."@es .

