    ns1:otherInformation """This subject is related with ODS and specially ODS11.
Prof. Pilar Izquierdo and Prof. Mª Aurora Florez participate 50% in the subject "History of Urban Law and Planning of Madrid\""""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
