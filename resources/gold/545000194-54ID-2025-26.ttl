    ns1:numberOfCredits 6.0 ;
    ns1:otherInformation """Las comunicaciones de los profesores a los alumnos se realizará de forma personal.
Otras vías de comunicación son el correo electrónico y la plataforma moodle
Las consultas se atenderán en el periodo de tutoría establecido para cada profesor ,y el periodo de respuesta será
el mas rápido posible.
La asignatura se relaciona con los ODS CE26;CG01;CE08."""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "70 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/545000194/2025-26/eventSchedule> ;
    schema:description "La asignatura pone en valor a través de la aplicación a casos prácticos todos los conocimientos jurídico-organizativos de la empresa dentro del sector inmobiliario. Así en primer lugar se realiza un repaso de los conocimientos adquiridos en otras asignaturas tales como Derecho de Empresa/legislación aplicada, régimen fiscal, y legislación urbanística; en un segundo momento estos conocimientos se ponen en práctica mediante la resolución de casos prácticos a través de trabajos individuales y colectivos que tendrán que ser expuestos mediante presentaciones."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/bc.caro%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/bc.caro%40upm.es> ;
    schema:name "Legislación Aplicada"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000194/2025-26/CB03> a ns1:Competency ;
    ns1:competencyCode "CB03" ;
    ns1:competencyDescription "Que los estudiantes tengan la capacidad de reunir e interpretar datos relevantes (normalmente dentro de su área de estudio) para emitir juicios que incluyan una reflexión sobre temas relevantes de índole social, científica o ética"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000194/2025-26/CB04> a ns1:Competency ;
    ns1:competencyCode "CB04" ;
    ns1:competencyDescription "Que los estudiantes puedan transmitir información, ideas, problemas y soluciones a un público tanto especializado como no especializado"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000194/2025-26/CB05> a ns1:Competency ;
    ns1:competencyCode "CB05" ;
    ns1:competencyDescription "Que los estudiantes hayan desarrollado aquellas habilidades de aprendizaje necesarias para emprender estudios posteriores con un alto grado de autonomía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000194/2025-26/CE06> a ns1:Competency ;
    ns1:competencyCode "CE06" ;
    ns1:competencyDescription "Conocimiento adecuado del concepto de empresa, su marco institucional, modelos de organización, planificación, control y toma de decisiones estratégicas en ambientes de certeza, riesgo e incertidumbre; sistemas de producción, costes, planificación, fuentes de financiación y elaboración de planes financieros y presupuestos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000194/2025-26/CE07> a ns1:Competency ;
    ns1:competencyCode "CE07" ;
    ns1:competencyDescription "Capacidad para organizar pequeñas empresas, y de participar como miembro de equipos multidisciplinares en grandes empresas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000194/2025-26/CE08> a ns1:Competency ;
    ns1:competencyCode "CE08" ;
    ns1:competencyDescription "Conocimientos básicos del régimen jurídico de las Administraciones Públicas y de los procedimientos de contratación administrativa y privada."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000194/2025-26/CE26> a ns1:Competency ;
    ns1:competencyCode "CE26" ;
    ns1:competencyDescription "Conocimiento del derecho de la construcción y de las relaciones contractuales que se producen en las distintas fases del proceso de edificación. Así como de la legislación, reglamentación y normativas específicas de la prevención y coordinación en materia de seguridad y salud laboral en la edificación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000194/2025-26/CE39> a ns1:Competency ;
    ns1:competencyCode "CE39" ;
    ns1:competencyDescription "Conocimiento de las funciones y responsabilidades de los agentes que intervienen en la edificación y de su organización profesional o empresarial. Los procedimientos administrativos, de gestión y tramitación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000194/2025-26/CE40> a ns1:Competency ;
    ns1:competencyCode "CE40" ;
    ns1:competencyDescription "Conocimiento de la organización profesional y las tramitaciones básicas en el campo de la edificación y la promoción."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000194/2025-26/CE41> a ns1:Competency ;
    ns1:competencyCode "CE41" ;
    ns1:competencyDescription "Presentación y defensa ante un tribunal universitario de un proyecto fin de grado, consistente en un ejercicio de integración de los contenidos formativos recibidos y las competencias adquiridas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000194/2025-26/CE64> a ns1:Competency ;
    ns1:competencyCode "CE64" ;
    ns1:competencyDescription "Conocer los principales aspectos de la normativa mercantil y laboral que resultan aplicables en las actividades empresariales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000194/2025-26/CE65> a ns1:Competency ;
    ns1:competencyCode "CE65" ;
    ns1:competencyDescription "Conocer los principales aspectos de la normativa tributaria que resultan aplicables en las actividades empresariales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000194/2025-26/CE66> a ns1:Competency ;
    ns1:competencyCode "CE66" ;
    ns1:competencyDescription "Comprender las diferentes teorías sobre la organización de la empresa."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000194/2025-26/CE67> a ns1:Competency ;
    ns1:competencyCode "CE67" ;
    ns1:competencyDescription "Comprender la organización funcional de la empresa: sus objetivos y técnicas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000194/2025-26/CE68> a ns1:Competency ;
    ns1:competencyCode "CE68" ;
    ns1:competencyDescription "Comprender la misión, visión, valores y estrategia de la empresa."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000194/2025-26/CG16> a ns1:Competency ;
    ns1:competencyCode "CG16" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de comunicar conocimientos y conclusiones del ámbito de la administración y dirección de empresas, tanto de forma oral como escrita, a públicos especializados y no especializados, expresándose de manera fluida y sin ambigüedades."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000194/2025-26/CG18> a ns1:Competency ;
    ns1:competencyCode "CG18" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de aportar soluciones creativas en la resolución de problemas en el ámbito de la administración y dirección de empresas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000194/2025-26/CG19> a ns1:Competency ;
    ns1:competencyCode "CG19" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de trabajar en equipos multidisciplinares, aplicando los conocimientos adquiridos en el ámbito de la administración y dirección de empresas, fomentando el espíritu de equipo y la coordinación en las tareas de los diversos miembros."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000194/2025-26/CG23> a ns1:Competency ;
    ns1:competencyCode "CG23" ;
    ns1:competencyDescription "Que los estudiantes adquieran un compromiso ético en su trabajo en el ámbito de la administración y dirección de empresas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000194/2025-26/CG24> a ns1:Competency ;
    ns1:competencyCode "CG24" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de utilizar las nuevas tecnologías de la información y las comunicaciones aplicándolas al ámbito de la dirección y administración de empresas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000194/2025-26/CT01> a ns1:Competency ;
    ns1:competencyCode "CT01" ;
    ns1:competencyDescription "Trabajo en equipo. Equipos interdisciplinares."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000194/2025-26/CT02> a ns1:Competency ;
    ns1:competencyCode "CT02" ;
    ns1:competencyDescription "Comunicación oral y escrita. Capacidad de análisis y síntesis y de discusión de ideas propias. Capacidad de comunicación a través de la palabra y la imagen."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000194/2025-26/CT07> a ns1:Competency ;
    ns1:competencyCode "CT07" ;
    ns1:competencyDescription "Capacidad de búsqueda, análisis y selección de información."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000194/2025-26/CT09> a ns1:Competency ;
    ns1:competencyCode "CT09" ;
    ns1:competencyDescription "Organización y Planificación. Aprendizaje autónomo. Hábito de estudio y método de trabajo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000194/2025-26/CT10> a ns1:Competency ;
    ns1:competencyCode "CT10" ;
    ns1:competencyDescription "Normas y Reglamentos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000194/2025-26/CT12> a ns1:Competency ;
    ns1:competencyCode "CT12" ;
    ns1:competencyDescription "Negociaciones, Reuniones."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000194/2025-26/CT13> a ns1:Competency ;
    ns1:competencyCode "CT13" ;
    ns1:competencyDescription "Ética y Deontología."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000194/2025-26/CT16> a ns1:Competency ;
    ns1:competencyCode "CT16" ;
    ns1:competencyDescription "Resolución de problemas. Conflictos y crisis. Toma de decisiones."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000194/2025-26/RA100> a ns1:LearningResult ;
    ns1:learningResultCode "RA100" ;
    ns1:learningResultDescription "Poder exponer y comunicar las soluciones a los problemas tanto de forma oral como escrita."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000194/2025-26/RA101> a ns1:LearningResult ;
