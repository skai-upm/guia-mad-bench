    ns1:learningResultDescription "Conocimiento básico del ordenamiento jurídico de las principales instituciones civiles, laborales, mercantiles y tributarias relacionadas con la administración y dirección de empresas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000194/2025-26/RA103> a ns1:LearningResult ;
    ns1:learningResultCode "RA103" ;
    ns1:learningResultDescription "Conocimiento de la configuración jurídica básica de la empresa y del empresario y estudio de las obligaciones y contratos con especial referencia a los contratos básicos del tráfico jurídico empresarial."@es .

