<https://guia-kg.skai.etsisi.upm.es/resource/33000980> a ns1:Course ;
    ns1:courseType "Obligatoria"@es ;
    ns1:courseYear 1 ;
    ns1:semester "Primer semestre"@es ;
    schema:courseCode 33000980 ;
    schema:hasCourseInstance <https://guia-kg.skai.etsisi.upm.es/resource/33000980/2025-26> ;
    schema:name "Architectural Communication"@en,
        "Comunicación Arquitectónica"@es ;
    schema:numberOfCredits 3.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/33000980/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/33000980/2025-26/RA1> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/33000980/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/33000980/2025-26/RA2> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/33000980/2025-26/syllabus> ;
    ns1:inpersonHours "105 horas (129.6%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation ""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "105 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/33000980/2025-26/eventSchedule> ;
    schema:description """La asignatura se desarrolla como un taller horizontal donde el aprendizaje se basa en trabajo de campo y experiencia directa en la realización de un proyecto de comunicación aplicado a un evento real en el ámbito arquitectónico .
Para ello se introducen los conocimientos necesarios que proporcionen una base teórica y los referentes mientras que se llevan a cabo todas las ejercitaciones para llegar a producir un evento real."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/rodrigo.delso%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/atxu.amann%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/rodrigo.delso%40upm.es> ;
    schema:name "Comunicación Arquitectónica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000980/2025-26/RA1> a ns1:Competency ;
    ns1:competencyCode "RA1" ;
    ns1:competencyDescription "Conocer las diferentes teorías sociocomunicativas que abordan la relaciones entre cultura, tecnologías y espacialidad desde perspectivas arquitectónicas y de las ciencias sociales. TIPO: Conocimientos o contenidos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000980/2025-26/RA2> a ns1:LearningResult ;
    ns1:learningResultCode "RA2" ;
    ns1:learningResultDescription "RA22"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000980/2025-26/evaluation> a ns1:EvaluationSystem ;
    ns1:evaluationDescription """-La calificación del alumno se ha establecido sobre la media de la puntuación de tres variables: Asistencia,
Implicación y Resultado
- Aspectos particular que ha considerado el equipo docente:
-Comunicación interna: coordinación, favorecer diálogos, generar feedbacks parciales y totales para todos, incluido
hacia el profesorado
-Comunicación intermediarios: fuentes de financiación, facilitadores, contactos, proveedores
-Comunicación externa: Redes sociales y otros medios de difusión, antes, durante y después del evento, dirigido
al público/asistente
-Desarrollo de ideas: Marco teórico ? conceptual
-Ejecución y seguimiento de fases de proyecto: Marco técnico y práctico"""@es ;
    ns1:hasEvaluationTrial <https://guia-kg.skai.etsisi.upm.es/resource/33000980/2025-26/evaluation/trial1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/33000980/2025-26/evaluation/trial2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/33000980/2025-26/evaluation/trial3>,
        <https://guia-kg.skai.etsisi.upm.es/resource/33000980/2025-26/evaluation/trial4> .

