    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/133000050/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000050/2025-26/didactic_resource/2> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/133000050/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/133000050/2025-26/RA57> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/133000050/2025-26/syllabus> ;
    ns1:inpersonHours "54 horas (66.7%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation """Las prácticas de la asignatura se desarrollarán únicamente en dos días consecutivos en el mes de mayo (viernes y sábado, o sábado y domingo). Esta práctica tiene carácter interdisciplinar con otras materias del máster. El estudiante se tendrá que costear la alimentación, desplazamiento y material específico para la realización de la práctica.
Todo esto se concretará en una reunión previa en la ETSIMFy MN.
Para más información ponerse en contacto con los profesores de la asignatura.
La asignatura se relaciona con los Objetivos de Desarrollo Sostenible (ODS) siguientes:
ODS3. Salud y bienestar.
ODS4. Educación de calidad.
OSD6. Agua Limpia y Saneamiento.
ODS8. Trabajo decente y crecimiento económico.
ODS11. Ciudades y comunidades sostenibles.
ODS13. Acción por el clima.
ODS14. Vida submarina."""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "54 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/133000050/2025-26/eventSchedule> ;
    schema:description "Los contenidos teóricos y prácticos, asi como las experiencias personales y técnico-profesionales que proporciona el desarrollo de la asignatura, se alinean con la agenda 2030 sobre el Desarrollo Sostenible de la ONU. Esta asignatura, y su profesorado, se comprometen a adoptar medidas y promover el cumplimiento de los objetivos de Desarrollo Sostenible números: cuatro (Educación de Calidad), seis (Agua Limpia y Saneamiento), trece (Acción por el Clima), catorce (Vida Submarina) y 17 (Alianzas para lograr los objetivos ODS)"@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/v.gencinas%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/lazaro.mediavilla%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/v.gencinas%40upm.es> ;
    schema:name "Actividades Deportivas Acuaticas en la Naturaleza."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000050/2025-26/CB7> a ns1:Competency ;
    ns1:competencyCode "CB7" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en entornos nuevos o poco conocidos dentro de contextos más amplios (o multidisciplinares) relacionados con su área de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000050/2025-26/CE1> a ns1:Competency ;
    ns1:competencyCode "CE1" ;
    ns1:competencyDescription "Conocer los fundamentos de la Limnología"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000050/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Capacidad para participar en proyectos de investigación, desarrollo e innovación vinculados con el uso sostenible de los recursos hídricos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000050/2025-26/CT6> a ns1:Competency ;
    ns1:competencyCode "CT6" ;
    ns1:competencyDescription "Liderar equipos de trabajo de diversa índole, con actitud proactiva y motivadora, comunicando con claridad los objetivos y las tareas de cada componente del equipo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000050/2025-26/RA57> a ns1:LearningResult ;
    ns1:learningResultCode "RA57" ;
    ns1:learningResultDescription "Desarrollo de un trabajo original en el ámbito del uso y gestión del agua en el medio natural."@es .

