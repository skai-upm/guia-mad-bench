    ns1:semester "Segundo semestre"@es ;
    schema:courseCode 133000050 ;
    schema:hasCourseInstance <https://guia-kg.skai.etsisi.upm.es/resource/133000050/2025-26> ;
    schema:name "Water Sport Activities In Nature"@en,
        "Actividades Deportivas Acuaticas en la Naturaleza."@es ;
    schema:numberOfCredits 3.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/133000050/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/133000050/2025-26/CB7>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000050/2025-26/CE1>,
