    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/63000255/2025-26/RA13>,
        <https://guia-kg.skai.etsisi.upm.es/resource/63000255/2025-26/RA14>,
        <https://guia-kg.skai.etsisi.upm.es/resource/63000255/2025-26/RA22>,
