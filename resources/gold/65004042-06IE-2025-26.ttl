    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/65004042/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/65004042/2025-26/didactic_resource/2> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/65004042/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/65004042/2025-26/RA145> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/65004042/2025-26/syllabus> ;
    ns1:inpersonHours "48 horas (41%)"@es ;
    ns1:numberOfCredits 4.5 ;
    ns1:otherInformation """En caso de tener que recurrir a la telenseñanza por medidas de confinamiento, se adoptarán las siguientes medidas:
Las clases se realizarán por vía telemática, haciendo uso de las herramientas disponibles en la UPM (Windows Teams) o bien se grabarán, se editarán y se subirán a Moodle.
La comunicación con el profesorado se realizará por correo electrónico y Windows Teams.
La asignatura permite trabajar algunos de los Objetivos de Desarrollo Sostenible como el ODS 7 "Garantizar el acceso a una energía asequible, segura, sostenible y moderna para todos" (tema reactores nucleares avanzados)."""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "50 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/65004042/2025-26/eventSchedule> ;
    schema:description "En esta asignatura se adquirirán los conocimientos necesarios para comprender cómo funciona un reactor nuclear de agua a presión (PWR) y un reactor nuclear de agua en ebullición (BWR). También se da una introducción a la seguridad nuclear. Por último, se tratan las principales tecnologías de reactores avanzados."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/gonzalo.jimenez%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/emilio.castro%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/gonzalo.jimenez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/nuria.garcia.herranz%40upm.es> ;
    schema:name "Centrales Nucleares"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004042/2025-26/CE40> a ns1:Competency ;
    ns1:competencyCode "CE40" ;
    ns1:competencyDescription "Comprender el funcionamiento y la operación de las centrales eléctricas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004042/2025-26/CE42> a ns1:Competency ;
    ns1:competencyCode "CE42" ;
    ns1:competencyDescription "Conocer y comprender la física y tecnología de la desintegración radiactiva, la fisión y la fusión nuclear."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004042/2025-26/CE43> a ns1:Competency ;
    ns1:competencyCode "CE43" ;
    ns1:competencyDescription "Aplicar los principios de la ingeniería nuclear y de la protección radiológica."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004042/2025-26/CE45> a ns1:Competency ;
    ns1:competencyCode "CE45" ;
    ns1:competencyDescription "Aplicación de conocimientos de ingeniería al diseño, implantación y puesta en operación de plantas energéticas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004042/2025-26/CE46> a ns1:Competency ;
    ns1:competencyCode "CE46" ;
    ns1:competencyDescription "Comprender la operación y las técnicas de mantenimiento de las máquinas e instalaciones energéticas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004042/2025-26/CE48> a ns1:Competency ;
    ns1:competencyCode "CE48" ;
    ns1:competencyDescription "Comprender el aprovechamiento, transformación y gestión de los recursos energéticos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004042/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Conocer y aplicar conocimientos de ciencias y tecnologías básicas a la práctica de la Ingeniería de la Energía."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004042/2025-26/CG5> a ns1:Competency ;
    ns1:competencyCode "CG5" ;
    ns1:competencyDescription "Saber comunicar los conocimientos y conclusiones, tanto de forma oral, escrita y gráfica, a públicos especializados y no especializados de un modo claro y sin ambigüedades."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004042/2025-26/CG6> a ns1:Competency ;
    ns1:competencyCode "CG6" ;
    ns1:competencyDescription "Poseer habilidades de aprendizaje que permitan continuar estudiando a lo largo de la vida para su adecuado desarrollo profesional."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004042/2025-26/CG7> a ns1:Competency ;
    ns1:competencyCode "CG7" ;
    ns1:competencyDescription "Incorporar nuevas tecnologías y herramientas de la Ingeniería Energética en sus actividades profesionales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004042/2025-26/RA145> a ns1:LearningResult ;
    ns1:learningResultCode "RA145" ;
    ns1:learningResultDescription "Comprender la tecnología de los principales tipos de centrales nucleares y de sus sistemas principales y auxiliares. Comprender los fundamentos en que se basa el control de centrales nucleares. Conocer las principales tendencias en cuanto al diseño de centrales nucleares para el futuro y las ventajas que aportarán con respecto a las actuales"@es .

