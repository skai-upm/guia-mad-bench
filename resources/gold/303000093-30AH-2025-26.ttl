<https://guia-kg.skai.etsisi.upm.es/resource/303000093/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Rings and Ideals."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000093/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Review of ring theory. Prime and maximal ideals. Zero divisors, nilpotents, radical. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000093/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "3.2. Hilbert's basis theorem. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000093/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "4. Finite extensions and integral dependence"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000093/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "4.1. Finite and integral algebras. Integral closure. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000093/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "4.2. Normality. Singularity. Noether's normalization lemma. Weak Hilbert's Nullstellensatz. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000093/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "5. Geometry of the spectrum of a ring"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000093/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "5.1. Correspondence between points and ideals. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000093/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "5.2. Hilbert's Nullstellensatz. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000093/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "5.3. Zariski topology. Algebraic varieties. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000093/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "6. Rings of fractions and localization"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000093/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "6.1. Rings of fractions. Localization in rings. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000093/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Spectrum of a ring. Examples and geometric interpretation. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000093/2025-26/syllabus/20> a ns1:SyllabusItem ;
    ns1:itemIndex 20 ;
    ns1:syllabusDescription "6.2. Modules of fractions. Localization in modules. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000093/2025-26/syllabus/21> a ns1:SyllabusItem ;
    ns1:itemIndex 21 ;
    ns1:syllabusDescription "7. Primary decomposition"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000093/2025-26/syllabus/22> a ns1:SyllabusItem ;
    ns1:itemIndex 22 ;
    ns1:syllabusDescription "7.1. Support. Annihilator. Associated primes. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000093/2025-26/syllabus/23> a ns1:SyllabusItem ;
    ns1:itemIndex 23 ;
    ns1:syllabusDescription "7.2. Primary ideals. Primary decomposition. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000093/2025-26/syllabus/24> a ns1:SyllabusItem ;
    ns1:itemIndex 24 ;
    ns1:syllabusDescription "8. Discrete valuation rings"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000093/2025-26/syllabus/25> a ns1:SyllabusItem ;
    ns1:itemIndex 25 ;
    ns1:syllabusDescription "8.1. Discrete valuation rings. Normal integral domains. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000093/2025-26/syllabus/26> a ns1:SyllabusItem ;
    ns1:itemIndex 26 ;
    ns1:syllabusDescription "8.2. Dedekind domains and uniqueness of factorization. Resolution of singularities. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000093/2025-26/syllabus/27> a ns1:SyllabusItem ;
    ns1:itemIndex 27 ;
    ns1:syllabusDescription "9. Completion"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000093/2025-26/syllabus/28> a ns1:SyllabusItem ;
    ns1:itemIndex 28 ;
    ns1:syllabusDescription "9.1. Topologies and completions. Graded rings and modules. Artin-Rees lemma. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000093/2025-26/syllabus/29> a ns1:SyllabusItem ;
    ns1:itemIndex 29 ;
    ns1:syllabusDescription "10. Dimension theory"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000093/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "1.3. Local rings. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000093/2025-26/syllabus/30> a ns1:SyllabusItem ;
    ns1:itemIndex 30 ;
    ns1:syllabusDescription "10.1. Hilbert functions. Local regular rings. Transcendent dimension. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000093/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "2. Modules"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000093/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "2.1. Definitions. Homomorphisms of modules. Generators. Free modules. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000093/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "2.2. Cayley-Hamilton theorem. Narakama's lemma. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000093/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "2.3. Basics on categories and functors. Exact sequences. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000093/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "3. Noetherian rings and modules"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000093/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "3.1. Ascending chain condition. Noetheriand rings. Noetherian modules. Sin subniveles"@es .

