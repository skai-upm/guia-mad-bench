    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/20504412/2025-26/eventSchedule> ;
    schema:description "Importancia de las pérdidas por causas bióticas en producción vegetal. Naturaleza de la enfermedad en las plantas. Métodos de identificación de los agentes perjudiciales y diagnóstico de la enfermedad. Características generales de los organismos perjudiciales para las plantas (hongos y oomicetos, bacterias, virus, nemátodos, insectos y ácaros). Métodos de control: medidas legislativas, prácticas culturales, control biológico, reguladores del crecimiento y feromonas, control por resistencia genética y control químico. Introducción a la epidemiología. Aplicaciones de la biotecnología a la protección vegetal."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/soledad.sacristan%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/cristina.saez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/pilar.medina%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/soledad.sacristan%40upm.es> ;
    schema:name "Patología y Protección Vegetal"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504412/2025-26/CB01> a ns1:Competency ;
    ns1:competencyCode "CB01" ;
    ns1:competencyDescription "Que los estudiantes hayan demostrado poseer y comprender conocimientos en un área de estudio que parte de la base de la educación secundaria general, y se suele encontrar a un nivel que, si bien se apoya en libros de texto avanzados, incluye también algunos aspectos que implican conocimientos procedentes de la vanguardia de su campo de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504412/2025-26/CB02> a ns1:Competency ;
    ns1:competencyCode "CB02" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar sus conocimientos a su trabajo o vocación de una forma profesional y posean las competencias que suelen demostrarse por medio de la elaboración y defensa de argumentos y la resolución de problemas dentro de su área de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504412/2025-26/CB03> a ns1:Competency ;
    ns1:competencyCode "CB03" ;
    ns1:competencyDescription "Que los estudiantes tengan la capacidad de reunir e interpretar datos relevantes (normalmente dentro de su área de estudio) para emitir juicios que incluyan una reflexión sobre temas relevantes de índole social, científica o ética"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504412/2025-26/CB04> a ns1:Competency ;
    ns1:competencyCode "CB04" ;
    ns1:competencyDescription "Que los estudiantes puedan transmitir información, ideas, problemas y soluciones a un público tanto especializado como no especializado"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504412/2025-26/CE11> a ns1:Competency ;
    ns1:competencyCode "CE11" ;
    ns1:competencyDescription "Habilidad para buscar, obtener e interpretar la información de las principales bases de datos bibliográficos y biológicos (genómicos, transcriptómicos, proteómicos y metabolómicos) y elaborar información a partir de datos experimentales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504412/2025-26/CE31> a ns1:Competency ;
    ns1:competencyCode "CE31" ;
    ns1:competencyDescription "Ser capaz de cultivar células animales y vegetales y conocer los sistemas de cultivo, y sus aplicaciones."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504412/2025-26/CG01> a ns1:Competency ;
    ns1:competencyCode "CG01" ;
    ns1:competencyDescription "Ser capaz de evaluar y discernir los diferentes mecanismos moleculares y celulares responsables de las transformaciones que llevan a cabo los seres vivos, así como poder desarrollar soluciones alternativas y novedosas frente a problemas biológicos conocidos y/o emergentes."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504412/2025-26/CG02> a ns1:Competency ;
    ns1:competencyCode "CG02" ;
    ns1:competencyDescription "Familiarizarse con el trabajo en el laboratorio, la instrumentación y los métodos experimentales. Además, ser capaz de realizar experimentos y/o diseñar aplicaciones de forma independiente y describir, cuantificar, analizar y evaluar críticamente los resultados obtenidos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504412/2025-26/CG04> a ns1:Competency ;
    ns1:competencyCode "CG04" ;
    ns1:competencyDescription "Adquirir la formación y habilidades para el desarrollo de la investigación biotecnológica (tecnologías y estrategias frontera), de cara a su posterior aplicación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504412/2025-26/CG07> a ns1:Competency ;
    ns1:competencyCode "CG07" ;
    ns1:competencyDescription "Adquirir la formación profesional para cubrir la demanda de las empresas biotecnológicas y para el acceso a estudios de postgrado del área."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504412/2025-26/CG10> a ns1:Competency ;
    ns1:competencyCode "CG10" ;
    ns1:competencyDescription "Fomentar la implicación en el trabajo de laboratorio seguro y propiciar el conocimiento de los aspectos éticos y bioéticos del área."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504412/2025-26/CT03> a ns1:Competency ;
    ns1:competencyCode "CT03" ;
    ns1:competencyDescription "Tener compromiso ético y profesional y respeto por el medio ambiente."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504412/2025-26/RA252> a ns1:LearningResult ;
    ns1:learningResultCode "RA252" ;
    ns1:learningResultDescription "Conocer los principales agentes bióticos perjudiciales para las plantas y saber cómo identificarlos y diagnosticar las enfermedades que producen"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504412/2025-26/RA253> a ns1:LearningResult ;
    ns1:learningResultCode "RA253" ;
    ns1:learningResultDescription "Conocer los mecanismos de patogénesis y defensa que llevan a la enfermedad o a la resistencia"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504412/2025-26/RA254> a ns1:LearningResult ;
    ns1:learningResultCode "RA254" ;
    ns1:learningResultDescription "Conocer todos los métodos de control disponibles contra plagas y enfermedades"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504412/2025-26/RA255> a ns1:LearningResult ;
    ns1:learningResultCode "RA255" ;
    ns1:learningResultDescription "Conocer las aplicaciones de la biotecnología en la Protección Vegetal"@es .

