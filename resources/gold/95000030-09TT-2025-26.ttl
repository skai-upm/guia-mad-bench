        <https://guia-kg.skai.etsisi.upm.es/resource/jesus.gutierrez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/julian.cabrera%40upm.es> ;
    schema:name "Sistemas de Transmision"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000030/2025-26/CECT1> a ns1:Competency ;
    ns1:competencyCode "CECT1" ;
    ns1:competencyDescription "Capacidad para aprender de manera autónoma nuevos conocimientos y técnicas adecuados para la concepción, el desarrollo o la explotación de sistemas y servicios de telecomunicación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000030/2025-26/CECT15> a ns1:Competency ;
    ns1:competencyCode "CECT15" ;
    ns1:competencyDescription "Conocimiento de la normativa y la regulación de las telecomunicaciones en los ámbitos nacional, europeo e internacional"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000030/2025-26/CECT4> a ns1:Competency ;
    ns1:competencyCode "CECT4" ;
    ns1:competencyDescription "Capacidad de analizar y especificar los parámetros fundamentales de un sistema de comunicaciones"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000030/2025-26/CECT5> a ns1:Competency ;
    ns1:competencyCode "CECT5" ;
    ns1:competencyDescription "Capacidad para evaluar las ventajas e inconvenientes de diferentes alternativas tecnológicas de despliegue o implementación de sistemas de comunicaciones, desde el punto de vista del espacio de la señal, las perturbaciones y el ruido y los sistemas de modulación analógica y digital"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000030/2025-26/CECT8> a ns1:Competency ;
    ns1:competencyCode "CECT8" ;
    ns1:competencyDescription "Capacidad para comprender los mecanismos de propagación y transmisión de ondas electromagnéticas y acústicas, y sus correspondientes dispositivos emisores y receptores"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000030/2025-26/CG2> a ns1:Competency ;
    ns1:competencyCode "CG2" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar sus conocimientos a su trabajo o vocación de una forma profesional y posean las competencias que suelen demostrarse por medio de la elaboración y defensa de argumentos y la resolución de problemas dentro de su área de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000030/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Que los estudiantes tengan la capacidad de reunir e interpretar datos relevantes (normalmente dentro de su área de estudio) para emitir juicios que incluyan una reflexión sobre temas relevantes de índole social, científica o ética"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000030/2025-26/RA501> a ns1:LearningResult ;
    ns1:learningResultCode "RA501" ;
    ns1:learningResultDescription "Caracterización de los elementos de un sistema de transmisión."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000030/2025-26/RA502> a ns1:LearningResult ;
    ns1:learningResultCode "RA502" ;
    ns1:learningResultDescription "Conocimiento y caracterización de las fuentes de información y la digitalización de las señales analógicas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000030/2025-26/RA503> a ns1:LearningResult ;
    ns1:learningResultCode "RA503" ;
    ns1:learningResultDescription "Formación básica en medios de transmisión: líneas metálicas, fibra óptica y transmisión por radio, que incluye la caracterización de las señales empleadas en los mismos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000030/2025-26/RA504> a ns1:LearningResult ;
    ns1:learningResultCode "RA504" ;
    ns1:learningResultDescription "Metodología para el análisis de las técnicas y medios de transmisión adecuados para la transmisión de señales, y para la especificación de sus parámetros fundamentales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000030/2025-26/RA505> a ns1:LearningResult ;
    ns1:learningResultCode "RA505" ;
    ns1:learningResultDescription "Conocimiento y caracterización de las perturbaciones que afectan a la transmisión de señales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000030/2025-26/RA506> a ns1:LearningResult ;
    ns1:learningResultCode "RA506" ;
    ns1:learningResultDescription "Conocimiento de sistemas de transmisión completos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000030/2025-26/RA507> a ns1:LearningResult ;
    ns1:learningResultCode "RA507" ;
    ns1:learningResultDescription "Adquisición de una visión estructurada de los problemas relacionados con la transmisión que sirva como marco de referencia para la integración de conocimientos relacionados con la telecomunicación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000030/2025-26/RA508> a ns1:LearningResult ;
    ns1:learningResultCode "RA508" ;
    ns1:learningResultDescription "Manejo de recomendaciones y normas, y de volúmenes importantes de datos, gráficas y expresiones requeridos para la resolución de problemas reales."@es .

