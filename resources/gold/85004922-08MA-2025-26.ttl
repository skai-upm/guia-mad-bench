<https://guia-kg.skai.etsisi.upm.es/resource/85004922/2025-26/RA78> a ns1:LearningResult ;
    ns1:learningResultCode "RA78" ;
    ns1:learningResultDescription "Construir superficies de Bézier y spline a partir de mallas de control, nudos y matrices de pesos y usar sus propiedades."@es .

