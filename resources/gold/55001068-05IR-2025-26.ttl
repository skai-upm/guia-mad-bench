<https://guia-kg.skai.etsisi.upm.es/resource/55001068/2025-26/didactic_resource/6> a ns1:DidacticResource ;
    ns1:bibliographyDescription """Das Handbuch Maschinenbau beschreibt in verständlicher und praxisnaher Form die Inhalte für
den Studienbedarf und die Berufspraxis von Ingenieuren und Technikern."""@es ;
    ns1:bibliographyTitle "Handbuch Maschinenbau. Grundlagen und Anwendungen der Maschinenbau-Technik"@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001068/2025-26/didactic_resource/7> a ns1:DidacticResource ;
    ns1:bibliographyDescription """Das vorliegende Springer Lehrbuch Maschinenbau bietet den Studierenden eine hervorragende
Möglichkeit, sich Wissen eigenständig zu erarbeiten, erlerntes Wissen zu vertiefen
bzw. studienbegleitend in Übungen und Seminaren anzuwenden."""@es ;
    ns1:bibliographyTitle "Maschinenbau. Ein Lehrbuch für das ganze Bachelorstudium"@es ;
    ns1:bibliographyType "Bibliografía"@es .

