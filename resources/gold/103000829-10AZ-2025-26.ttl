<https://guia-kg.skai.etsisi.upm.es/resource/103000829/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/103000829/2025-26/CB07>,
        <https://guia-kg.skai.etsisi.upm.es/resource/103000829/2025-26/CB10>,
