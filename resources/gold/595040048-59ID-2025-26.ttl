<https://guia-kg.skai.etsisi.upm.es/resource/595040048/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/595040048/2025-26/CE09>,
        <https://guia-kg.skai.etsisi.upm.es/resource/595040048/2025-26/CE16>,
