        <https://guia-kg.skai.etsisi.upm.es/resource/i.oropesa%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/p.sanchez%40upm.es> ;
    schema:name "Laboratorio de Imágenes Biomédicas"@es .

