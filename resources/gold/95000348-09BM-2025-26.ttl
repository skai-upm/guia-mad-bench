<https://guia-kg.skai.etsisi.upm.es/resource/95000348/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Práctica 1: Introducción al entorno de trabajo MATLAB"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000348/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. - Entorno de trabajo: Matlab - Tipos de imágenes - Lectura de imágenes médicas - Visualización de imágenes médicas - Imágenes por reconstrucción tomográfica Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000348/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "2. Práctica 2: Mejora e intensificación de imágenes biomédicas: procesamiento global"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000348/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "2.1. - Histograma: concepto, cálculo y filtrado - Aplicación en imágenes de TC: segmentación por histograma - Aumento de contraste lineal y no-lineal - Ecualización y ecualización adaptativa del histograma - Aplicación en imágenes de RM cerebral Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000348/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "3. Práctica 3: Mejora e intensificación de imágenes biomédicas: procesamiento local"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000348/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "3.1. - Conceptos de convolución y máscara - Suavizado de imágenes: media, gaussiano y mediana - Detección de bordes: filtro Sobel, Roberts y zerocross - Realce de la imagen: filtro laplaciano - Aplicación en imágenes de retinografía Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000348/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "4. Práctica 4: Operaciones morfológicas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000348/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "4.1. - Elementos estructurantes - Erosión y dilatación - Apertura y cierre - Filtros por reconstrucción - Aplicación práctica Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000348/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "5. Práctica 5: Segmentación de imágenes biomédicas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000348/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "5.1. - Segmentación por umbral: aplicación en imagen de microscopía - Umbrales múltiples - Umbral adaptativo - Método de Otsu: aplicación a angiografía TC abdominal - Crecimiento de regiones: aplicación a RM cerebral Sin subniveles"@es .

