<https://guia-kg.skai.etsisi.upm.es/resource/20504497/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Introducción"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504497/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Nutrición humana e historia. Génesis y desarrollo de la ciencia de la nutrición Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504497/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "4.2. Regulación del gasto energético. Control del peso corporal. Índice de Masa Corporal. Regulación del apetito y del gasto energético. Peso de ajuste. Obesidad y síndrome metabólico. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504497/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "5. Biotecnología nutricional"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504497/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "5.1. Variantes genéticas. Regulación de la expresión génica. Epigenética. Epidemiología. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504497/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "5.2. Herramientas biotecnológicas aplicadas al estudio de la nutrición. Tecnologías Ómicas (transcriptómica, metabolómica, proteómica) aplicadas a biotecnología nutricional Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504497/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "5.3. Bioinformática aplicada a la biotecnología nutricional Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504497/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "6. Nutrigenómica. Efecto de los nutrientes sobre la salud"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504497/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "6.1. Efecto de los nutrientes (hidratos de carbono, lípidos, proteínas, vitaminas y minerales) y otros compuestos que ingerimos en la dieta (alcohol, tóxicos) sobre la regulación de la expresión génica, proteómica y metabólica Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504497/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "6.2. Influencia de los nutrientes en el desarrollo, obesidad, diabetes, dislipidemias, inflamación, enfermedades cardiacas, cáncer y metabolismo óseo Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504497/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "7. Nutrigenética: efecto de las variaciones genéticas en la interacción entre la dieta y la salud."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504497/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "7.1. Enfermedades monogénicas y enfermedades multigénicas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504497/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Evolución de los patrones dietéticos humanos. Factores que condicionan la alimentación humana. La dieta, presente y futuro Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504497/2025-26/syllabus/20> a ns1:SyllabusItem ;
    ns1:itemIndex 20 ;
    ns1:syllabusDescription "7.2. Dietas personalizadas para una alimentación saludable. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504497/2025-26/syllabus/21> a ns1:SyllabusItem ;
    ns1:itemIndex 21 ;
    ns1:syllabusDescription "7.3. Ganancia y perdida de peso. Azúcar y fibra. Grasa saturada e insaturada. Omega 3 y 6. Colesterol. Vitaminas liposolubles e hidrosolubles, cofactores. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504497/2025-26/syllabus/22> a ns1:SyllabusItem ;
    ns1:itemIndex 22 ;
    ns1:syllabusDescription "7.4. Sustancias tóxicas. Envejecimiento. Alergias. Microbiota. Psiconutrición. Cronodieta. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504497/2025-26/syllabus/23> a ns1:SyllabusItem ;
    ns1:itemIndex 23 ;
    ns1:syllabusDescription "8. Biotecnología alimentaria: Integración de datos nutrigenómicos y nutrigenéticos para el diseño de una dieta saludable personalizada y de nuevos alimentos Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504497/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "2. Dieta y salud: una visión preliminar"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504497/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "2.1. Los nutrientes, los hábitos alimentarios y la salud. Recomendaciones dietéticas. Diseño de la dieta. Bases de datos nutricionales. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504497/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "3. Bases bioquímicas de la nutrición"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504497/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "3.1. Nutrientes: macro y micronutrientes. Metabolismo nutricional. Diabetes. Cáncer. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504497/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "3.2. Tipos de alimentos en base al contenido en nutrientes. Química y bioquímica de los alimentos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504497/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "4. Aspectos bioenergéticos de la nutrición humana."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504497/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "4.1. Alimentos y energía, Ley de Hess. Calorimetría directa e indirecta. Cociente respiratorio. Gastos fijos de energía. Consumo Energético en Reposo (CER). Gastos variables. Energía y actividad física. Sin subniveles"@es .

