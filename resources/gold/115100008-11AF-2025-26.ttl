    ns1:competencyCode "CG04" ;
    ns1:competencyDescription "Mostrar disposición y habilidad para el trabajo y el liderazgo en equipo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100008/2025-26/RA110> a ns1:LearningResult ;
    ns1:learningResultCode "RA110" ;
    ns1:learningResultDescription "Utilizar los elementos técnicos y tácticos de las situaciones de 1x1 y 2x2 con el fin de iniciar la construcción del juego de equipo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100008/2025-26/RA111> a ns1:LearningResult ;
    ns1:learningResultCode "RA111" ;
    ns1:learningResultDescription "Ser capaces de planificar, organizar, dirigir y evaluar los recursos humanos de actividad física y deporte (profesionales de actividad física y deporte) en las diferentes organizaciones de actividad física y deporte desde una perspectiva integral, profesional y eficiente"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100008/2025-26/RA112> a ns1:LearningResult ;
    ns1:learningResultCode "RA112" ;
    ns1:learningResultDescription "Conocer y dominar los diferentes conceptos, elementos y estructuras que constituyen la dirección de recursos de actividad física y deporte (profesionales de actividad física y deporte)"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100008/2025-26/RA36> a ns1:LearningResult ;
    ns1:learningResultCode "RA36" ;
    ns1:learningResultDescription "Diseñar tareas y progresiones para la enseñanza de los principios tácticos específicos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100008/2025-26/RA37> a ns1:LearningResult ;
    ns1:learningResultCode "RA37" ;
    ns1:learningResultDescription "Tener un conocimiento específico sobre el Reglamento en fútbol"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100008/2025-26/RA38> a ns1:LearningResult ;
