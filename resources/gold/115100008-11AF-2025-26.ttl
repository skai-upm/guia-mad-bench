        <https://guia-kg.skai.etsisi.upm.es/resource/diego.muriarte%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/moises.mnieto%40upm.es> ;
    schema:name "Fútbol"@es .

