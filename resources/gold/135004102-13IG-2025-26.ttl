<https://guia-kg.skai.etsisi.upm.es/resource/135004102/2025-26/RA309> a ns1:LearningResult ;
    ns1:learningResultCode "RA309" ;
    ns1:learningResultDescription "Comprender y aplicar las leyes fundamentales de la mecánica, la termodinámica, el electromagnetismo y las ondas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004102/2025-26/RA311> a ns1:LearningResult ;
    ns1:learningResultCode "RA311" ;
    ns1:learningResultDescription "Analizar las posibles analogías en casos que son físicamente diferentes y de aplicar soluciones conocidas a nuevos problemas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004102/2025-26/RA312> a ns1:LearningResult ;
    ns1:learningResultCode "RA312" ;
    ns1:learningResultDescription "Identificar los elementos esenciales de un fenómeno físico, construir o modificar un modelo que permita describirlo, realizar predicciones y comprobar la validez del mismo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004102/2025-26/RA313> a ns1:LearningResult ;
    ns1:learningResultCode "RA313" ;
    ns1:learningResultDescription "Realizar experimentos de manera independiente describiendo, analizando y evaluando críticamente los resultados."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004102/2025-26/RA315> a ns1:LearningResult ;
    ns1:learningResultCode "RA315" ;
    ns1:learningResultDescription "Desarrollar actividades de aprendizaje necesarias para emprender estudios posteriores con un alto grado de autonomía"@es .

