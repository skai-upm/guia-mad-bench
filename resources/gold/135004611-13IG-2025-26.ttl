<https://guia-kg.skai.etsisi.upm.es/resource/135004611/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. La Gestión de la Calidad: Norma ISO 9001"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004611/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Introducción y Sistemas de Certificación. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004611/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "3. Análisis del ciclo de vida (ACV) y Huella de Carbono (HC)."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004611/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "3.1. PRÁCTICA 1: Análisis de la Huella de Carbono personal. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004611/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "4. Control de Calidad de Productos Forestales no Madereros Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004611/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "5. Control de calidad de la madera y sus derivados."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004611/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "5.1. Introducción a la calidad. Marco de referencia."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004611/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "5.1.1. Introducción a los sistemas de calidad. Sistemas de gestión, control de proceso y producto acabado, certificación. Mapa conceptual de la gestión de la calidad. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004611/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "5.2. Control de calidad de las industrias de primera transformación de la madera: Madera aserrada y tableros de madera."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004611/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "5.2.1. Caracterización y control de calidad de la madera aserrada. Clasificación de la madera. Métodos de clasificación tradicionales y no destructivos. Los informes técnicos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004611/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "5.2.2. Caracterización y control de calidad de la madera tratada. Conceptos y normas de control de los tratamientos y la madera tratada. Métodos de ensayo. Control en obra y en laboratorio. Informes técnicos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004611/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "5.2.3. Caracterización y control de calidad de los tableros derivados de la madera. Control de calidad normalizado y alternativo mediante métodos ND. Informes de idoneidad. Estadística para la calidad. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004611/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Manual de Calidad Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004611/2025-26/syllabus/20> a ns1:SyllabusItem ;
    ns1:itemIndex 20 ;
    ns1:syllabusDescription "5.3. Control de calidad de las industrias de segunda transformación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004611/2025-26/syllabus/21> a ns1:SyllabusItem ;
    ns1:itemIndex 21 ;
    ns1:syllabusDescription "5.3.1. Caracetrización y control de calidad de carpinetría y mobiliario. Métodos de control y ensayo. Diferentes roles para un resultado de calidad. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004611/2025-26/syllabus/22> a ns1:SyllabusItem ;
    ns1:itemIndex 22 ;
    ns1:syllabusDescription "5.3.2. Control de calidad en obra: Informes y peritaciones. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004611/2025-26/syllabus/23> a ns1:SyllabusItem ;
    ns1:itemIndex 23 ;
    ns1:syllabusDescription "5.4. El laboratorio de calidad. Control de equipos de medición y ensayo. Mantenimiento, verificación y calibración. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004611/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "1.3. Instrucciones Técnicas Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004611/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "1.4. Especificaciones Técnicas Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004611/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "1.5. Práctica 1: Indice genérico de un documento. Elaboración del procedimiento general. Control de documentación y datos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004611/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "1.6. Práctica 2: Ejecución de una Auditoria documental y redacción del correspondiente informe. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004611/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "2. La gestión medioambiental. Norma ISO 14001."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004611/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "2.1. Introducción. Problemas ambientales. Empresa y el Medio ambiente. Sistema de Gestión ambiental. Beneficios derivados de la implantación de un Sistema de gestión ambiental. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004611/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "2.2. Norma ISO 14001:2004. Certificación ISO 14001, Sistema EMAS. Revisión ambiental inicial (introducción, descripción de la empresa, aspectos ambientales y significativos de la misma, legislación aplicable a la empresa, y descripción de la gestión ambiental. Sin subniveles"@es .

