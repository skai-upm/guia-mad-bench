    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/43000428/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000428/2025-26/didactic_resource/2> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/43000428/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/43000428/2025-26/RA1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000428/2025-26/RA12>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000428/2025-26/RA15>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000428/2025-26/RA26>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000428/2025-26/RA6>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000428/2025-26/RA7> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/43000428/2025-26/syllabus> ;
    ns1:inpersonHours "48 horas (41%)"@es ;
    ns1:numberOfCredits 4.5 ;
    ns1:otherInformation """El alumno debe conocer las nociones básicas de mecánica del suelo.
Durante el curso 2024-2025 no se impartirá docencia. Los alumnos podrán acudir a tutoría para resolver dudas"""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "48 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/43000428/2025-26/eventSchedule> ;
    schema:description """La asignatura esta enfocada al estudio de las técnicas de cimentación y mejora del terreno en las obras civiles.
De manera preliminar se presentan ordenadamente los conceptos básicos de mecánica del suelo.
Se realizará una descripción de los distintos tipos de cimentación, problemas que pueden aparecer en las mismas así como casos reales."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/jesus.gonzalezg%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/enrique.asanza%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/jesus.gonzalezg%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/jg.gutierrez%40upm.es> ;
    schema:name "Cimentaciones Especiales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000428/2025-26/CB7> a ns1:Competency ;
    ns1:competencyCode "CB7" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en entornos nuevos o poco conocidos dentro de contextos más amplios (o multidisciplinares) relacionados con su área de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000428/2025-26/CE2> a ns1:Competency ;
    ns1:competencyCode "CE2" ;
    ns1:competencyDescription "Capacidad para la resolución de problemas de proyecto, construcción, conservación y evaluación técnica de infraestructuras que requieran el uso de cimentaciones especiales y se planteen en contextos globalizados."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000428/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Capacidad de diseñar, analizar e interpretar experimentos relevantes en Ingeniería Estructural, Geotécnica y de Materiales Estructurales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000428/2025-26/RA1> a ns1:LearningResult ;
    ns1:learningResultCode "RA1" ;
    ns1:learningResultDescription "Utiliza con eficacia, autonomía y polivalencia recursos de modelización predictiva en la temática de la materia"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000428/2025-26/RA12> a ns1:LearningResult ;
    ns1:learningResultCode "RA12" ;
    ns1:learningResultDescription "Realiza individualmente un proyecto o una preinvestigación originales de Ingeniería estructural, geotécnica o de materiales estructurales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000428/2025-26/RA15> a ns1:LearningResult ;
    ns1:learningResultCode "RA15" ;
    ns1:learningResultDescription "Aplica normativa europea e internacional de ingeniería estructural, geotécnica y de materiales estructurales en proyecto, construcción, conservación y evaluación técnica Interioriza los principios de deontología profesional de ingeniería civil"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000428/2025-26/RA26> a ns1:LearningResult ;
    ns1:learningResultCode "RA26" ;
    ns1:learningResultDescription "Plantea el proyecto de un puente sobre la base de los datos de trazado, funcionalidad, topografía y geotecnia disponibles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000428/2025-26/RA6> a ns1:LearningResult ;
    ns1:learningResultCode "RA6" ;
    ns1:learningResultDescription "Aplica normativa europea e internacional de ingeniería estructural, geotécnica y de materiales estructurales en proyecto, construcción, conservación y evaluación técnica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000428/2025-26/RA7> a ns1:LearningResult ;
    ns1:learningResultCode "RA7" ;
    ns1:learningResultDescription "Diseña, analiza e interpreta experimentos relevantes en ingeniería estructural, geotécnica y de materiales estructurales"@es .

