    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. La comunicación profesional en la ingeniería: aspectos relevantes"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000106/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. La comunicación: un aspecto poco desarrollado en los ingenieros. El buen comunicador. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000106/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "1.5.2. Metodologías de trabajo en equipo. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000106/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "1.5.3. Toma de decisiones (E. de Bono) y liderazgo. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000106/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "1.6. Análisis de aspectos comunicativos en CODA. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000106/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "1.7. Canales oral y escrito: preparación de una entrevista a un profesional."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000106/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "1.7.1. Aspectos socioculturales. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000106/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "1.7.2. Actividad práctica: diseminación de resultados de la entrevista en un vídeo (taller de Moodle)."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000106/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "1.7.2.1. Planos de vídeo. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000106/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "2. Tecnología y sociedad: prácticas de la escritura académica y profesional."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000106/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "2.1. El acta. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000106/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "2.2. Introducción al informe. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000106/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Las competencias transversales. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000106/2025-26/syllabus/20> a ns1:SyllabusItem ;
    ns1:itemIndex 20 ;
    ns1:syllabusDescription "2.3. Ficha informativa en formato de póster. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000106/2025-26/syllabus/21> a ns1:SyllabusItem ;
    ns1:itemIndex 21 ;
    ns1:syllabusDescription "2.4. Ejercicios de paráfrasis, reconocimiento de errores y mejora de la expresión escrita. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000106/2025-26/syllabus/22> a ns1:SyllabusItem ;
    ns1:itemIndex 22 ;
    ns1:syllabusDescription "3. Exposición y defensa oral presencial de trabajos académicos y profesionales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000106/2025-26/syllabus/23> a ns1:SyllabusItem ;
    ns1:itemIndex 23 ;
    ns1:syllabusDescription "3.1. Tema de la exposición: tecnología/empresa tecnológica y su relación con alguno de los objetivos de desarrollo sostenible. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000106/2025-26/syllabus/24> a ns1:SyllabusItem ;
    ns1:itemIndex 24 ;
    ns1:syllabusDescription "3.2. Estructura de una exposición oral: introducción, desarrollo, conclusión y preguntas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000106/2025-26/syllabus/25> a ns1:SyllabusItem ;
    ns1:itemIndex 25 ;
    ns1:syllabusDescription "3.2.1. Estructuración del apoyo visual de la presentación y lectura de gráficos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000106/2025-26/syllabus/26> a ns1:SyllabusItem ;
    ns1:itemIndex 26 ;
    ns1:syllabusDescription "3.3. Cómo presentar la información en público: voz, lenguaje verbal y no-verbal, saber estar, ayudas visuales en las exposiciones orales. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000106/2025-26/syllabus/27> a ns1:SyllabusItem ;
    ns1:itemIndex 27 ;
    ns1:syllabusDescription "3.4. Cómo evaluar una exposición oral. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000106/2025-26/syllabus/28> a ns1:SyllabusItem ;
    ns1:itemIndex 28 ;
    ns1:syllabusDescription "3.5. Exposiciones orales presenciales en grupo. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000106/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "1.3. Comunicación para la acción: claridad y eficacia"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000106/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "1.3.1. Interpretación de la información: saber escuchar. Escucha activa, malos entendidos y dicción. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000106/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "1.3.2. Estilos de comunicación: asertivo, no asertivo y agresivo. La técnica DESC. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000106/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "1.3.3. Adecuación a la audiencia: expertos y no-expertos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000106/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "1.4. Correo electrónico: formalidad y cortesía. Léxico formal y parafraseo. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000106/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "1.5. El trabajo en equipo vs trabajo en grupo: condición clave en el trabajo de ingeniería"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000106/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "1.5.1. Equipo: análisis de roles (Belbin) y fortalezas (DAFO). Sin subniveles"@es .

