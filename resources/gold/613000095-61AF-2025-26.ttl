<https://guia-kg.skai.etsisi.upm.es/resource/613000095/2025-26/CE01> a ns1:Competency ;
    ns1:competencyCode "CE01" ;
    ns1:competencyDescription "Requisitar, analizar y diseñar en un desarrollo Web bajo las metodologías vigentes en el entorno profesional."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000095/2025-26/CE02> a ns1:Competency ;
    ns1:competencyCode "CE02" ;
    ns1:competencyDescription "Programar y probar en un desarrollo Web con los lenguajes y técnicas vigentes en el entorno profesional."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000095/2025-26/CE03> a ns1:Competency ;
    ns1:competencyCode "CE03" ;
    ns1:competencyDescription "Desplegar y mantener un desarrollo Web sobre las plataformas y arquitecturas vigentes en el entorno profesional."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000095/2025-26/CE04> a ns1:Competency ;
    ns1:competencyCode "CE04" ;
    ns1:competencyDescription "Configurar herramientas y entornos de desarrollo Web vigentes en el entorno profesional."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000095/2025-26/CE05> a ns1:Competency ;
    ns1:competencyCode "CE05" ;
    ns1:competencyDescription "Integrar bibliotecas, protocolos y estándares Web vigentes en el entorno profesional."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000095/2025-26/CE06> a ns1:Competency ;
    ns1:competencyCode "CE06" ;
    ns1:competencyDescription "Incorporar seguridad, calidad, usabilidad y persistencia al desarrollo Web vigentes en el entorno profesional."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000095/2025-26/CE07> a ns1:Competency ;
    ns1:competencyCode "CE07" ;
    ns1:competencyDescription "Organizar, coordinar y supervisar al equipo de desarrollo Web con técnicas vigentes en el entorno profesional"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000095/2025-26/CE08> a ns1:Competency ;
    ns1:competencyCode "CE08" ;
    ns1:competencyDescription "Estimar costes tiempos/recuros para un desarrollo Web con metodologías vigentes en el entorno profesional."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000095/2025-26/CE09> a ns1:Competency ;
    ns1:competencyCode "CE09" ;
    ns1:competencyDescription "Respetar los marcos legal, social y económico de los desarrollos vigentes en el entorno profesional."@es .

