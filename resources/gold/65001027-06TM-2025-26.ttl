    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/65001027/2025-26/eventSchedule> ;
    schema:description """Ingeniería de los Explosivos contiene los conocimientos básicos sobre explosivos necesarios para el profesional titulado en este grado universitario: modos de funcionamiento, propiedades, tipos, utilización en voladura de rocas, efectos medioambientales de su uso y fundamentos normativos y de seguridad.
El enfoque de la asignatura es teórico-práctico, incluyendo el uso de herramientas de cálculo y diseño por ordenador y práctica en mina."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/ja.sanchidrian%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/ja.sanchidrian%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/jesusfelix.domingo%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/lina.lopez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/pablo.segarra%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/santiago.gomez%40upm.es> ;
    schema:name "Ingenieria de Explosivos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001027/2025-26/CG%201> a ns1:Competency ;
    ns1:competencyCode "CG 1" ;
    ns1:competencyDescription "Conocer y aplicar conocimientos de ciencias y tecnologías básicas a la práctica de la Tecnología Minera."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001027/2025-26/CG%202> a ns1:Competency ;
    ns1:competencyCode "CG 2" ;
    ns1:competencyDescription "Poseer capacidad para diseñar, analizar, calcular, proyectar, construir, mantener, conservar, explotar, desarrollar, implementar, gestionar y mejorar productos, sistemas y procesos en los distintos ámbitos de las Tecnologías Mineras, usando técnicas analíticas, computacionales o experimentales apropiadas, incluyendo la función de asesoría en estos campos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001027/2025-26/CG%203> a ns1:Competency ;
    ns1:competencyCode "CG 3" ;
    ns1:competencyDescription "Aplicar los conocimientos adquiridos para identificar, formular y resolver problemas dentro de contextos amplios y multidisciplinarios, siendo capaces de integrar conocimientos, trabajando en equipos multidisciplinares."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001027/2025-26/CG%205> a ns1:Competency ;
    ns1:competencyCode "CG 5" ;
    ns1:competencyDescription "Saber comunicar los conocimientos y conclusiones, tanto de forma oral, escrita y gráfica, a públicos especializados y no especializados de un modo claro y sin ambigüedades."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001027/2025-26/CG%206> a ns1:Competency ;
    ns1:competencyCode "CG 6" ;
    ns1:competencyDescription "Poseer habilidades de aprendizaje que permitan continuar estudiando a lo largo de la vida para su adecuado desarrollo profesional"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001027/2025-26/F31> a ns1:Competency ;
    ns1:competencyCode "F31" ;
    ns1:competencyDescription "Manejo, transporte y distribución de explosivos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001027/2025-26/RA141> a ns1:LearningResult ;
    ns1:learningResultCode "RA141" ;
    ns1:learningResultDescription "Conocer los explosivos, sus mecanismos de reacción y propiedades generales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001027/2025-26/RA142> a ns1:LearningResult ;
    ns1:learningResultCode "RA142" ;
    ns1:learningResultDescription "Conocer de forma elemental la composición y las propiedades de los explosivos, mezclas explosivas y mezclas pirotécnicas más importantes."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001027/2025-26/RA143> a ns1:LearningResult ;
    ns1:learningResultCode "RA143" ;
    ns1:learningResultDescription "Aplicar los criterios para la más adecuada selección de los explosivos para las distintas aplicaciones."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001027/2025-26/RA144> a ns1:LearningResult ;
    ns1:learningResultCode "RA144" ;
    ns1:learningResultDescription "Aplicar los métodos de ejecución de las voladuras en banco y en túnel."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001027/2025-26/RA145> a ns1:LearningResult ;
    ns1:learningResultCode "RA145" ;
    ns1:learningResultDescription "Conocer las normas de seguridad que deben tenerse en cuenta en la correcta utilización de los explosivos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001027/2025-26/RA146> a ns1:LearningResult ;
    ns1:learningResultCode "RA146" ;
    ns1:learningResultDescription "Conocer los efectos medioambientales de la utilización de los explosivos y su control."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001027/2025-26/RA147> a ns1:LearningResult ;
    ns1:learningResultCode "RA147" ;
    ns1:learningResultDescription "Capacidad para conocer, comprender y utilizar los principios de:, manejo y utilización de explosivos industriales y materiales pirotécnicos. Ensayos de caracterización de sustancias explosivas. Transporte y distribución de explosivos."@es .

