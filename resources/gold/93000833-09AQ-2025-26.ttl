    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/93000833/2025-26/eventSchedule> ;
    schema:description """Esta asignatura profundiza en los conceptos de Redes Definidas por Software y de Virtualización de Funciones de Red mediante la exposición de su aplicación en ámbitos específicos y en la elaboración de casos de uso.
La asignatura tiene un fuerte componente práctico por lo que se propondrán problemas específicos sobre el análisis y diseño de redes de ordenadores que cubrirán el análisis y diseño de tecnologías, topologías, arquitecturas, servicios y calidad del servicio de las mismas.
A tal fin, se proporcionarán conocimientos específicos sobre los nuevos paradigmas arquitecturales de las redes de comunicaciones basados en la definición "software" de las redes (SDN), en la virtualización de las funciones de la red (NFV) y en la orquestación de servicios.
Aunando los nuevos paradigmas, tecnologías y técnicas vistas durante el curso, los alumnos trabajarán en grupos de dos o tres componentes en un reto final en el que deberán diseñar e implementar un servicio de red con unos requisitos funcionales y de calidad de servicio específicos. El profesorado guiará las diferentes fases del reto, determinando los "entregables" a producir y su planificación temporal."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/luis.bellido%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/c.lentisco%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/daniel.gonzalez.sanchez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/david.fernandez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/ignacio.soto%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/luis.bellido%40upm.es> ;
    schema:name "Redes Definidas por Software, Virtualización y Servicios Avanzados de Red"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000833/2025-26/CE4> a ns1:Competency ;
    ns1:competencyCode "CE4" ;
    ns1:competencyDescription "Capacidad para diseñar y dimensionar redes de transporte, difusión y distribución de señales multimedia."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000833/2025-26/CE6> a ns1:Competency ;
    ns1:competencyCode "CE6" ;
    ns1:competencyDescription "Capacidad para modelar, diseñar, implantar, gestionar, operar, administrar y mantener redes, servicios y contenidos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000833/2025-26/CE8> a ns1:Competency ;
    ns1:competencyCode "CE8" ;
    ns1:competencyDescription "Capacidad de comprender y saber aplicar el funcionamiento y organización de Internet, las tecnologías y protocolos de Internet de nueva generación, los modelos de componentes, software intermediario y servicios."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000833/2025-26/CE9> a ns1:Competency ;
    ns1:competencyCode "CE9" ;
    ns1:competencyDescription "Capacidad para resolver la convergencia, interoperabilidad y diseño de redes heterogéneas con redes locales, de acceso y troncales, así como la integración de servicios de telefonía, datos, televisión e interactivos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000833/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Poseer y comprender conocimientos que aporten una base u oportunidad de ser originales en el desarrollo y/o aplicación de ideas, a menudo en un contexto de investigación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000833/2025-26/CG4> a ns1:Competency ;
    ns1:competencyCode "CG4" ;
    ns1:competencyDescription "Que los estudiantes sepan comunicar sus conclusiones ?y los conocimientos y razones últimas que las sustentan? a públicos especializados y no especializados de un modo claro y sin ambigüedades."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000833/2025-26/CT1> a ns1:Competency ;
    ns1:competencyCode "CT1" ;
    ns1:competencyDescription "Capacidad para comprender los contenidos de clases magistrales, conferencias y seminarios en lengua inglesa."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000833/2025-26/CT3> a ns1:Competency ;
    ns1:competencyCode "CT3" ;
    ns1:competencyDescription "Capacidad para adoptar soluciones creativas que satisfagan adecuadamente las diferentes necesidades planteadas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000833/2025-26/CT4> a ns1:Competency ;
    ns1:competencyCode "CT4" ;
    ns1:competencyDescription "Capacidad para trabajar de forma efectiva como individuo, organizando y planificando su propio trabajo, de forma independiente o como miembro de un equipo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000833/2025-26/CT5> a ns1:Competency ;
    ns1:competencyCode "CT5" ;
    ns1:competencyDescription "Capacidad para gestionar la información, identificando las fuentes necesarias, los principales tipos de documentos técnicos y científicos, de una manera adecuada y eficiente."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000833/2025-26/RA10> a ns1:LearningResult ;
    ns1:learningResultCode "RA10" ;
    ns1:learningResultDescription "Saber realizar una presentación de carácter técnico, ante una audiencia de pares, que describa el trabajo realizado y sus resultados, de forma clara y bien estructurada, en el tiempo establecido, y usando un lenguaje preciso"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000833/2025-26/RA102> a ns1:LearningResult ;
    ns1:learningResultCode "RA102" ;
    ns1:learningResultDescription "Capacidad de diferenciar entre modelos arquitecturales de red basados en capas y definidos por software"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000833/2025-26/RA103> a ns1:LearningResult ;
    ns1:learningResultCode "RA103" ;
    ns1:learningResultDescription "Capacidad de identificar los diferentes componentes de una arquitectura de red definida por \"software\""@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000833/2025-26/RA104> a ns1:LearningResult ;
    ns1:learningResultCode "RA104" ;
    ns1:learningResultDescription "Capacidad de definir y dimensionar la arquitectura de redes corporativas como resultado de una especificación de servicios, tipos de usuarios, tráficos, y distribución geográfica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000833/2025-26/RA14> a ns1:LearningResult ;
    ns1:learningResultCode "RA14" ;
    ns1:learningResultDescription "El alumno conoce y es capaz de cuantificar los principales parámetros que definen los requisitos de los tráficos multimedia, estableciendo un compromiso calidad/coste y es capaz de aplicarlo al dimensionado de las redes de soporte."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000833/2025-26/RA307> a ns1:LearningResult ;
    ns1:learningResultCode "RA307" ;
    ns1:learningResultDescription "Capacidad de analizar y sintetizar modelos arquitectónicos de red basados en virtualización de funciones"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000833/2025-26/RA308> a ns1:LearningResult ;
    ns1:learningResultCode "RA308" ;
    ns1:learningResultDescription "Capacidad de analizar y sintetizar modelos arquitectónicos de red basados en orquestación de funciones"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000833/2025-26/RA310> a ns1:LearningResult ;
    ns1:learningResultCode "RA310" ;
    ns1:learningResultDescription "Capacidad de analizar y sintetizar la segmentación de redes basada en técnicas de virtualización"@es .

