    ns1:otherInformation """La asignatura se relaciona con el ODS 9 "Industria, innovación e infraestructura", en el ámbito de las TIC.
La modalidad de enseñanza es presencial."""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
