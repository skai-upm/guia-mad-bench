<https://guia-kg.skai.etsisi.upm.es/resource/115100047/2025-26/didactic_resource/10> a ns1:DidacticResource ;
    ns1:bibliographyDescription "El cultivo de la compasión constituye un campo científico en auge ya que se relaciona con cambios en las redes neuronales implicadas en la conexión y el desarrollo humano."@es ;
    ns1:bibliographyTitle "García-Campayo, J., Cebolla, A. y Demarzo, M. (2016) La Ciencia De La Compasión. Más Allá Del Mindfulness. Madrid: Alianza Editorial."@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100047/2025-26/didactic_resource/11> a ns1:DidacticResource ;
    ns1:bibliographyDescription "La era de la toma de conciencia se completa con el desrrrollo de las tecnicas aprendidas a travñés del mindfulness."@es ;
    ns1:bibliographyTitle "Tenney, Matt, and Tim Gard. The Mindfulness Edge : How to Rewire Your Brain for Leadership and Personal Excellence without Adding to Your Schedule. 2016."@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100047/2025-26/didactic_resource/12> a ns1:DidacticResource ;
    ns1:bibliographyDescription "Primer libro traducido al castellano de Kabat-Zin considerado como el padre del Mindfulness."@es ;
    ns1:bibliographyTitle "Kabat-Zinn J. (2004).Vivir con plenitud las crisis. Barcelona: Kairós."@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100047/2025-26/didactic_resource/13> a ns1:DidacticResource ;
    ns1:bibliographyDescription "Kabat -Zinn es considerado responsable de aplicar por primera vez en el ámbito médico programas de MF"@es ;
    ns1:bibliographyTitle "Kabat-Zinn, J. (2011). El poder de la atención: 100 Lecciones sobre Mindfulness: Extractos de vivir con plenitud las crisis. Barcelona: Kairós Editorial."@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100047/2025-26/didactic_resource/14> a ns1:DidacticResource ;
    ns1:bibliographyDescription "El gran científico Siegel relaciona el bienestar con el entrenamiento de la presencia."@es ;
    ns1:bibliographyTitle "Siegel, D. J. (2010). Cerebro y mindfulness: La reflexión y la atención plena para cultivar el bienestar. Barcelona: Paidós."@es ;
