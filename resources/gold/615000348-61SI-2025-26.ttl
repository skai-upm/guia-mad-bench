<https://guia-kg.skai.etsisi.upm.es/resource/615000348/2025-26/CB3> a ns1:Competency ;
    ns1:competencyCode "CB3" ;
    ns1:competencyDescription "Capacidad para comprender y dominar los conceptos básicos de matemática discreta, lógica, algorítmica y complejidad computacional, y su aplicación para el tratamiento automático de la información por medio de sistemas computacionales y su aplicación para la resolución de problemas propios de la ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000348/2025-26/CC6> a ns1:Competency ;
    ns1:competencyCode "CC6" ;
    ns1:competencyDescription "Conocimiento y aplicación de los procedimientos algorítmicos básicos de las tecnologías informáticas para diseñar soluciones a problemas, analizando la idoneidad y complejidad de los algoritmos propuestos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000348/2025-26/CT10> a ns1:Competency ;
    ns1:competencyCode "CT10" ;
    ns1:competencyDescription "Creatividad e innovación: Habilidad para presentar recursos, ideas y métodos novedosos y concretarlos en acciones. Capacidad para innovar en cada una de las obras. Resolver de forma nueva y original situaciones o problemas en el ámbito de la ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000348/2025-26/RA181> a ns1:LearningResult ;
    ns1:learningResultCode "RA181" ;
    ns1:learningResultDescription "Identifica las principales estructuras de datos y técnicas algorítmicas y sus complejidades."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000348/2025-26/RA262> a ns1:LearningResult ;
    ns1:learningResultCode "RA262" ;
    ns1:learningResultDescription "Analiza la complejidad de un algoritmo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000348/2025-26/RA263> a ns1:LearningResult ;
    ns1:learningResultCode "RA263" ;
    ns1:learningResultDescription "Conoce el Esquema Divide y Vencerás en el diseño de algoritmos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000348/2025-26/RA264> a ns1:LearningResult ;
    ns1:learningResultCode "RA264" ;
    ns1:learningResultDescription "Conoce el Esquema Backtracking en el diseño de algoritmos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000348/2025-26/RA265> a ns1:LearningResult ;
    ns1:learningResultCode "RA265" ;
    ns1:learningResultDescription "Conoce el Esquema de Algoritmos Voraces en el diseño de algoritmos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000348/2025-26/RA266> a ns1:LearningResult ;
    ns1:learningResultCode "RA266" ;
    ns1:learningResultDescription "Conoce el Esquema de Programación Dinámica en el diseño de algoritmos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000348/2025-26/RA57> a ns1:LearningResult ;
    ns1:learningResultCode "RA57" ;
    ns1:learningResultDescription "Presenta recursos, ideas y métodos novedosos y concretados en acciones. Resuelve de forma nueva y original situaciones o problemas en el ámbito de la ingeniería."@es .

