    ns1:inpersonHours "50 horas (42.7%)"@es ;
    ns1:numberOfCredits 4.5 ;
    ns1:otherInformation "Aunque no se habla de ellos a lo largo del curso se puede decir que la asignatura se relaciona con el ODS7 (garantizar el acceso a una energía asequible, segura, sostenible y moderna) y el ODS9 (construir infraestructuras resilientes, promover la industrialización sostenible y fomentar la innovación)."@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "50 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/55000204/2025-26/eventSchedule> ;
    schema:description """La asignatura Electrotecnia II es una ampliación de la asignatura Electrotecnia estudiada en el segundo curso del Grado en Ingeniería en Tecnologías Industriales.
A lo largo del curso se estudian algunos temas avanzados de Teoría de Circuitos que son aplicables a la Tecnología Electrónica. La docencia se completa usando unos programas de Matlab que resuelven algunos problemas de clase porque es muy común en el ejercicio profesional usar programas de ordenador (comerciales o desarrollos propios) para analizar los circuitos eléctricos."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/rafael.asensi%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/rafael.asensi%40upm.es> ;
    schema:name "Electrotecnia II"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000204/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Conocer y aplicar conocimientos de ciencias y tecnologías básicas a la práctica de la Ingeniería Industrial."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000204/2025-26/CG5> a ns1:Competency ;
    ns1:competencyCode "CG5" ;
    ns1:competencyDescription "Saber comunicar los conocimientos y conclusiones, de forma oral, escrita y gráfica, a públicos especializados y no especializados de un modo claro y sin ambigüedades."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000204/2025-26/CG6> a ns1:Competency ;
    ns1:competencyCode "CG6" ;
    ns1:competencyDescription "Poseer habilidades de aprendizaje que permitan continuar estudiando a lo largo de la vida para su adecuado desarrollo profesional."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000204/2025-26/CG7> a ns1:Competency ;
    ns1:competencyCode "CG7" ;
    ns1:competencyDescription "Incorporar nuevas tecnologías y herramientas de la Ingeniería Industrial en sus actividades profesionales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000204/2025-26/RA22> a ns1:LearningResult ;
    ns1:learningResultCode "RA22" ;
    ns1:learningResultDescription "Conocer las características particulares de regímenes de funcionamiento más complejos en Ingeniería Eléctrica."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000204/2025-26/RA23> a ns1:LearningResult ;
    ns1:learningResultCode "RA23" ;
    ns1:learningResultDescription "Analizar de forma sistemática el comportamiento de los circuitos eléctricos, mediante técnicas avanzadas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000204/2025-26/RA24> a ns1:LearningResult ;
    ns1:learningResultCode "RA24" ;
    ns1:learningResultDescription "Reconocer más aplicaciones tecnológicas de la electricidad y utilizar los conocimientos adquiridos en la resolución de problemas comunes."@es .

