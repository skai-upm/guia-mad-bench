<https://guia-kg.skai.etsisi.upm.es/resource/53000690/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/53000690/2025-26/CB09>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53000690/2025-26/CE11>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53000690/2025-26/CG05>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53000690/2025-26/CT04>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53000690/2025-26/CT07> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/53000690/2025-26/didactic_resource/1> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/53000690/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/53000690/2025-26/RA29>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53000690/2025-26/RA30>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53000690/2025-26/RA63> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/53000690/2025-26/syllabus> ;
    ns1:inpersonHours "40 horas (51.3%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation "This subjetc contributes to all Sustainable Development Goals, but specially to SDG 3. Good Health and Well-being. and SDG 8. Decent work and economic grouth."@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "40 horas"@es ;
    schema:activitiesWorkload "140%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/53000690/2025-26/eventSchedule> ;
    schema:description """The subject Conscious Leadership has the aim of awakening inner reflection about those key elements that allow a person to successfully lead people and projects consciously.. For that purpose, in a participatory and experiential climate, powerful questions will help us to better understand why we are as we are, and to identify and develop the talent of people. Specific tools will be applied to lead consciously, including an approach based on Inner Development Goals, which is presented as a framworkt to better achieve Sustainable Development Goals (SDG). Some of the elements that will be addressed have to do with skills related to different areas: BEING, THINKING, RELATING, COLLABORATING and ACTING.
The main objectives of this subject are:
Learn how to promote inner development skills
Analyse conscious leaders that has had impact in the present and in the past
Develop awareness based on emotional intelligence principles.
Create a personal and professional vision, connecting with core values and using creativity tools.
Learn how to define and apply and appropriate action plan to achieve goals in any context.
Develop talent of people and teams to achieve outstanding results."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/luisignacio.ballesteros%40upm.es> ;
    schema:inLanguage "Inglés/Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/luisignacio.ballesteros%40upm.es> ;
    schema:name "Conscious Leadership"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000690/2025-26/CB09> a ns1:Competency ;
    ns1:competencyCode "CB09" ;
    ns1:competencyDescription "Que los estudiantes sepan comunicar sus conclusiones y los conocimientos y razones últimas que las sustentan a públicos especializados y no especializados de un modo claro y sin ambigüedades"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000690/2025-26/CE11> a ns1:Competency ;
    ns1:competencyCode "CE11" ;
    ns1:competencyDescription "Conocer los fundamentos de la organización del trabajo y de la gestión de recursos humanos y dominar las habilidades de dirección y gestión de equipos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000690/2025-26/CG05> a ns1:Competency ;
    ns1:competencyCode "CG05" ;
    ns1:competencyDescription "Conocer las tendencias predominantes en el entorno actual de las distintas políticas funcionales (marketing, producción, logística, finanzas, recursos humanos, liderazgo...)"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000690/2025-26/CT04> a ns1:Competency ;
    ns1:competencyCode "CT04" ;
    ns1:competencyDescription "Trabaja en equipo. Habilidad para trabajar en equipos multidisciplinares"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000690/2025-26/CT07> a ns1:Competency ;
    ns1:competencyCode "CT07" ;
    ns1:competencyDescription "Comunica. Habilidad para comunicar eficazmente"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000690/2025-26/RA29> a ns1:LearningResult ;
    ns1:learningResultCode "RA29" ;
    ns1:learningResultDescription "Dominar habilidades y técnicas específicas de trabajo en equipo y de dirección y gestión de equipos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000690/2025-26/RA30> a ns1:LearningResult ;
    ns1:learningResultCode "RA30" ;
    ns1:learningResultDescription "Enumerar, seleccionar y aplicar metodologías y técnicas para estimular y explotar la capacidad creativa individual y de grupo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000690/2025-26/RA63> a ns1:LearningResult ;
    ns1:learningResultCode "RA63" ;
    ns1:learningResultDescription "Identificar, comprender y aplicar actitudes, comportamientos y herramientas de liderazgo para definir y alcanzar los objetivos"@es .

