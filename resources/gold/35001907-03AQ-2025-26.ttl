    schema:name "Intensificacion en Estructuras de Edificacion"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35001907/2025-26/CE%201> a ns1:Competency ;
    ns1:competencyCode "CE 1" ;
    ns1:competencyDescription "Aptitud para aplicar los procedimientos gráficos a la representación de espacios y objetos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35001907/2025-26/CE%2011> a ns1:Competency ;
    ns1:competencyCode "CE 11" ;
    ns1:competencyDescription "Conocimiento aplicado del cálculo numérico, la geometría analítica y diferencial y los métodos algebraicos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35001907/2025-26/CE%2017> a ns1:Competency ;
