    ns1:inpersonHours "59 horas (50.4%)"@es ;
    ns1:numberOfCredits 4.5 ;
    ns1:otherInformation """El contenido docente de esta asignatura está alineado con los Objetivos de Desarrollo Sostenible (ODS) siguientes:
ODS 4
ODS 8
ODS 9"""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "61 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/143000115/2025-26/eventSchedule> ;
    schema:description """El objetivo de la asignatura es que el estudiante adquiera las competencias generales y específicas que se enumeran en el apartado 4 de esta guía.
En primer lugar se expone la base teórica necesaria para la adquisición de los conocimientos necesarios para comprender diferentes metodologías de diseño mecánico en función de los elementos a diseñar, la aplicación e interpretación de información técnica asociada al modelo y el uso experto de herramientas gráficas de generación en tres dimensiones tanto para modelos sólidos, superficies, conjuntos completos y sus aplicaciones específicas. Mediante la aplicación de estos conocimientos, el estudiante se formará en las competencias que se detallan posteriormente. La comprensión adecuada de estos contenidos contribuye a que el estudiante sea capaz de entender los principios relacionados con el diseño mecánico que subyacen en sistemas complejos, y explicar, con el nivel adecuado para la audiencia, tales principios y metodologías."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/javier.perez%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/blanca.boado.cuartero%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/javier.perez%40upm.es> ;
    schema:name "Ingeniería Gráfica para Diseño Mecánico Aeroespacial"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000115/2025-26/E02> a ns1:Competency ;
    ns1:competencyCode "E02" ;
    ns1:competencyDescription "Aplicar los métodos de análisis propios de un determinado subsistema, para verificar la adecuación del diseño del mismo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000115/2025-26/E05> a ns1:Competency ;
    ns1:competencyCode "E05" ;
    ns1:competencyDescription "Comprender de forma estructurada la ingeniería de sistemas espaciales y las habilidades, tecnologías y metodologías relacionadas con el desarrollo de esta disciplina"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000115/2025-26/E07> a ns1:Competency ;
    ns1:competencyCode "E07" ;
    ns1:competencyDescription "Conocer las fases de diseño, desarrollo, integración, ensayos, lanzamiento y operación en órbita de un vehículo espacial."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000115/2025-26/E10> a ns1:Competency ;
    ns1:competencyCode "E10" ;
    ns1:competencyDescription "Conocer los diferentes tipos de configuraciones de subsistemas y su relación con los distintos tipos de misión y los correspondientes requisitos, así como las relaciones entre diferentes subsistemas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000115/2025-26/E11> a ns1:Competency ;
    ns1:competencyCode "E11" ;
    ns1:competencyDescription "Establecer, diseñar, poner en práctica y adoptar un proceso de desarrollo de un subsistema de un vehículo espacial, y también del sistema completo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000115/2025-26/E23> a ns1:Competency ;
    ns1:competencyCode "E23" ;
    ns1:competencyDescription "Desarrollar un trabajo de diseño de un producto propio de la ingeniería aeroespacial, utilizando eficazmente los recursos modernos de información y tecnologías, así como los recursos e infraestructuras disponibles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000115/2025-26/E24> a ns1:Competency ;
    ns1:competencyCode "E24" ;
    ns1:competencyDescription "Evaluar la bondad de un determinado diseño para satisfacer los requisitos de misión"@es .

