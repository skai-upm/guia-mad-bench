<https://guia-kg.skai.etsisi.upm.es/resource/45001425/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/45001425/2025-26/CT2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/45001425/2025-26/CT3>,
        <https://guia-kg.skai.etsisi.upm.es/resource/45001425/2025-26/CT4> ;
