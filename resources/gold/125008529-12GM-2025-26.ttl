    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/125008529/2025-26/eventSchedule> ;
    schema:description """En esta asignatura, se introduce el concepto de información geográfica, se detallan los modelos de datos estándar más utilizados, se estudia la relación entre las coordenadas y los sistemas de referencia y se trabaja con los formatos de almacenamiento utilizados.
En la parte práctica se buscan las fuentes de información geográfica públicas más relevantes. Se integran datos de fuentes distintas y se trabaja en el análisis de la información geográfica como característica principal de los SIG. Los alumnos utilizan ampliamente información en formatos vectorial y ráster, aplican las funciones de análisis más empleadas para cada uno de los modelos y, por último, aprenden a generar salidas cartográficas como forma de presentar la información geográfica y los resultados de sus procesos de análisis.
El cronograma sigue una planificación teórica de la asignatura y puede sufrir modificaciones durante el curso."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/y.torres%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/i.sinde%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/sandra.mcuevas%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/y.torres%40upm.es> ;
    schema:name "Sistemas de Información Geográfica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125008529/2025-26/CRT3> a ns1:Competency ;
    ns1:competencyCode "CRT3" ;
    ns1:competencyDescription "Conocimiento, utilización y aplicación de las técnicas de tratamiento. Análisis de datos espaciales. Estudio de modelos aplicados a la ingeniería y arquitectura."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125008529/2025-26/CRT5> a ns1:Competency ;
    ns1:competencyCode "CRT5" ;
    ns1:competencyDescription "Diseño, producción y difusión de la cartografía básica y temática; Implementación, gestión y explotación de Sistemas de Información Geográfica (SIG)."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125008529/2025-26/CT09> a ns1:Competency ;
    ns1:competencyCode "CT09" ;
    ns1:competencyDescription "RESOLUCIÓN DE PROBLEMAS Desarrollar en los alumnos una actitud mental mediante la aplicación de procedimientos estructurados de resolución de problemas que promueva su capacidad de aprender, comprender y aplicar conocimientos de forma autónoma."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125008529/2025-26/CTE10> a ns1:Competency ;
    ns1:competencyCode "CTE10" ;
    ns1:competencyDescription "Desarrollar sistemas de información geográfica en distintos ámbitos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125008529/2025-26/CTE13> a ns1:Competency ;
    ns1:competencyCode "CTE13" ;
    ns1:competencyDescription "Capacidad de usar las tecnologías de análisis espacial de la información geográfica en distintos ámbitos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125008529/2025-26/RA163> a ns1:LearningResult ;
    ns1:learningResultCode "RA163" ;
    ns1:learningResultDescription "Desarrollar capacidades en comunicación gráfica y visualización aplicadas a la Información Geográfica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125008529/2025-26/RA164> a ns1:LearningResult ;
    ns1:learningResultCode "RA164" ;
    ns1:learningResultDescription "Identificar y utilizar las fuentes de información geográfica existentes en procesos de compilación cartográfica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125008529/2025-26/RA166> a ns1:LearningResult ;
    ns1:learningResultCode "RA166" ;
    ns1:learningResultDescription "· Llevar a cabo procesos de simbolización cartográfica con herramientas de CAD y SIG"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125008529/2025-26/RA168> a ns1:LearningResult ;
    ns1:learningResultCode "RA168" ;
    ns1:learningResultDescription "Desarrollar capacidades en integración de datos y su aplicación a la Información geográfica. Resolver los problemas derivados de la integración y edición de datos geoespaciales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125008529/2025-26/RA172> a ns1:LearningResult ;
    ns1:learningResultCode "RA172" ;
    ns1:learningResultDescription "Conocer y aplicar las técnicas básicas de consulta y análisis espacial de datos geoespaciales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125008529/2025-26/RA173> a ns1:LearningResult ;
    ns1:learningResultCode "RA173" ;
    ns1:learningResultDescription "Diseñar secuencias operativas básicas de análisis espacial en estructuras de datos geoespaciales"@es .

