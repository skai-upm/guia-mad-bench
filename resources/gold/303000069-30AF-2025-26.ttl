<https://guia-kg.skai.etsisi.upm.es/resource/303000069/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/303000069/2025-26/CON11.CE14.>,
        <https://guia-kg.skai.etsisi.upm.es/resource/303000069/2025-26/CON16.CE20.>,
        <https://guia-kg.skai.etsisi.upm.es/resource/303000069/2025-26/CON19.CE26.>,
        <https://guia-kg.skai.etsisi.upm.es/resource/303000069/2025-26/HAB1.CG2.>,
        <https://guia-kg.skai.etsisi.upm.es/resource/303000069/2025-26/HAB19.CE27.> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/303000069/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/303000069/2025-26/didactic_resource/2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/303000069/2025-26/didactic_resource/3>,
        <https://guia-kg.skai.etsisi.upm.es/resource/303000069/2025-26/didactic_resource/4> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/303000069/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/303000069/2025-26/RA26>,
        <https://guia-kg.skai.etsisi.upm.es/resource/303000069/2025-26/RA27>,
        <https://guia-kg.skai.etsisi.upm.es/resource/303000069/2025-26/RA28>,
        <https://guia-kg.skai.etsisi.upm.es/resource/303000069/2025-26/RA29>,
        <https://guia-kg.skai.etsisi.upm.es/resource/303000069/2025-26/RA30>,
        <https://guia-kg.skai.etsisi.upm.es/resource/303000069/2025-26/RA40> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/303000069/2025-26/syllabus> ;
    ns1:inpersonHours "28 horas (35.9%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation """Aunque se fije un horario de tutorías el alumno puede solicitar por correo electrónico o a través de Moodle una tutoría fuera de ese horario. Si se tuviera que impartir la tutoría de manera telemática se utilizarán las herramientas de videoconferencia previstas por la Universidad, como Blackboard Collaborate, Zoom o Microsoft Teams, utilizando pizarra virtual.
Si fuera necesario impartir docencia de manera telemática se utilizará estos mismos entornos para las clases, y se prepararían materiales y actividades especiales dentro del entorno de Moodle (aparte de enlaces a vídeos, simuladores o entornos virtuales disponibles en internet)."""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "28 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/303000069/2025-26/eventSchedule> ;
    schema:description "En esta asignatura se tratan los métodos y estrategias para abordar la implementación de la computación en física y química en Educación Secundaria y Bachillerato. En esta asignatura los estudiantes deberán resolver un problema que se les planteará mediante un vídeo enviado desde un exoplaneta. Para ello se preparará un proyecto que contiene las distintas partes del problema, que resolverán mediante el trabajo en grupos. A cada grupo se le asignará una de estas partes del proyecto que deberán resolver mediante la elaboración de un programa. El correcto funcionamiento del programa deberá dar como salida una parte de los resultados que finalmente tendrán que integrar para dar la solución final a los profesores astronautas."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/javier.galeano%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/javier.galeano%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/juanmanuel.pastor%40upm.es> ;
    schema:name "Laboratorio de Computación en la Didáctica de la Física y la Química"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000069/2025-26/CON11.CE14.> a ns1:Competency ;
    ns1:competencyCode "CON11.CE14." ;
    ns1:competencyDescription "Conocer la historia y los desarrollos recientes de las materias y sus perspectivas para poder transmitir una visión dinámica de las mismas. TIPO: Conocimientos o contenidos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000069/2025-26/CON16.CE20.> a ns1:Competency ;
    ns1:competencyCode "CON16.CE20." ;
    ns1:competencyDescription "Adquirir criterios de selección y elaboración de materiales educativos. TIPO: Conocimientos o contenidos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000069/2025-26/CON19.CE26.> a ns1:Competency ;
    ns1:competencyCode "CON19.CE26." ;
    ns1:competencyDescription "Identificar problemas relativos a la enseñanza y aprendizaje de las materias de la especialización y plantear alternativas y soluciones. TIPO: Conocimientos o contenidos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000069/2025-26/HAB1.CG2.> a ns1:Competency ;
    ns1:competencyCode "HAB1.CG2." ;
    ns1:competencyDescription "Planificar, desarrollar y evaluar el proceso de enseñanza y aprendizaje potenciando procesos educativos que faciliten la adquisición de las competencias propias de las respectivas enseñanzas, atendiendo al nivel y formación previa de los estudiantes, así como la orientación de los mismos, tanto individualmente como en colaboración con otros docentes y profesionales del centro. TIPO: Habilidades o destrezas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000069/2025-26/HAB19.CE27.> a ns1:Competency ;
    ns1:competencyCode "HAB19.CE27." ;
    ns1:competencyDescription "Conocer y aplicar metodologías y técnicas básicas de investigación y evaluación educativas y ser capaz de diseñar y desarrollar proyectos de investigación, innovación y evaluación. TIPO: Habilidades o destrezas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000069/2025-26/RA26> a ns1:LearningResult ;
    ns1:learningResultCode "RA26" ;
    ns1:learningResultDescription "Seleccionar la información procedente de diferentes fuentes y de otras áreas del conocimiento con el fin de adquirir una visión crítica de los problemas científicos, tecnológicos y sociales relacionados con la Física."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000069/2025-26/RA27> a ns1:LearningResult ;
    ns1:learningResultCode "RA27" ;
    ns1:learningResultDescription "Identificar las interacciones de la Física con la tecnología y la sociedad."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000069/2025-26/RA28> a ns1:LearningResult ;
    ns1:learningResultCode "RA28" ;
    ns1:learningResultDescription "Identificar, seleccionar y aplicar métodos didácticos en las ciencias experimentales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000069/2025-26/RA29> a ns1:LearningResult ;
    ns1:learningResultCode "RA29" ;
    ns1:learningResultDescription "Relacionar los contenidos anteriores con los de otras áreas científicas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000069/2025-26/RA30> a ns1:LearningResult ;
    ns1:learningResultCode "RA30" ;
    ns1:learningResultDescription "Analizar los contenidos de Física en Educación Secundaria y Bachillerato, aplicándolos a situaciones concretas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000069/2025-26/RA40> a ns1:LearningResult ;
    ns1:learningResultCode "RA40" ;
    ns1:learningResultDescription "Los resultados del aprendizaje correspondientes a esta asignatura han quedado definidos en el apartado de competencias de este documento, señalando los que corresponden a conocimientos, habilidades y competencias propiamente dichas."@es .

