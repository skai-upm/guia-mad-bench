    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/145006203/2025-26/eventSchedule> ;
    schema:description """El objetivo fundamental de la asignatura es la formación, a nivel de experto, en problemas de utilización, selección y actuaciones de motores de reacción utilizados en aeronáutica (aerorreactores) y turbinas de gas. Además, se impartirán conocimientos sobre los problemas ambientales (contaminación y ruido) que se originan en el aeropuerto debido a los aerorreactores.
El tipo de docencia será prioritariamente presencial, pero en función de la normativa vigente podría ser no presencial."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/luis.sanchezdeleon%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/francisco.sastre%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/luis.sanchezdeleon%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/michele.greco%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/salvador.rodriguez%40upm.es> ;
    schema:name "Aerorreactores"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145006203/2025-26/CE34> a ns1:Competency ;
    ns1:competencyCode "CE34" ;
    ns1:competencyDescription "Conocimiento adecuado y aplicado a la Ingeniería de: los métodos de cálculo y de desarrollo de instalaciones de los sistemas propulsivos; la regulación y control de instalaciones de los sistemas propulsivos; el manejo de las técnicas experimentales, equipamiento e instrumentos de medida propios de la disciplina; los combustibles y lubricantes empleados en los motores de aviación y automoción; la simulación numérica de los procesos físico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145006203/2025-26/CE35> a ns1:Competency ;
    ns1:competencyCode "CE35" ;
    ns1:competencyDescription "Conocimiento aplicado de: aerodinámica interna; teoría de la propulsión; actuaciones de aviones y de aerorreactores; ingeniería de sistemas de propulsión; mecánica y termodinámica."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145006203/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Capacidad para identificar y resolver problemas aplicando, con creatividad, los conocimientos adquiridos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145006203/2025-26/CG9> a ns1:Competency ;
    ns1:competencyCode "CG9" ;
    ns1:competencyDescription "Razonamiento crítico y capacidad de asociación que posibiliten el aprendizaje continuo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145006203/2025-26/RA204> a ns1:LearningResult ;
    ns1:learningResultCode "RA204" ;
    ns1:learningResultDescription "Conocer las necesidades propulsivas de las aeronaves."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145006203/2025-26/RA205> a ns1:LearningResult ;
    ns1:learningResultCode "RA205" ;
    ns1:learningResultDescription "Conocer los empujes y resistencias relacionados con los aerorreactores."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145006203/2025-26/RA206> a ns1:LearningResult ;
    ns1:learningResultCode "RA206" ;
    ns1:learningResultDescription "Conocer y cuantificar de forma aplicada el proceso de combustión de los aerorreactres y el rendimiento de la combustión."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145006203/2025-26/RA207> a ns1:LearningResult ;
    ns1:learningResultCode "RA207" ;
    ns1:learningResultDescription "Saber realizar un balance energético diferenciando y calculando los rendimientos involucrados."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145006203/2025-26/RA208> a ns1:LearningResult ;
    ns1:learningResultCode "RA208" ;
    ns1:learningResultDescription "Saber resolver problemas relacionados con el cálculo de los ciclos termodinámicos y las características de los aerorreactores; así como el efecto de las características y calidad de los componentes."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145006203/2025-26/RA209> a ns1:LearningResult ;
    ns1:learningResultCode "RA209" ;
    ns1:learningResultDescription "Conocer los diferentes aerorreactores y saber obtener los sistemas óptimos bajo el punto de vista de propulsivo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145006203/2025-26/RA210> a ns1:LearningResult ;
    ns1:learningResultCode "RA210" ;
    ns1:learningResultDescription "Dimensionar los componentes que intervienen en sistema propulsivo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145006203/2025-26/RA211> a ns1:LearningResult ;
    ns1:learningResultCode "RA211" ;
    ns1:learningResultDescription "Utilizar herramientas informáticas de cálculo de actuaciones de aerorreactores."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145006203/2025-26/RA212> a ns1:LearningResult ;
    ns1:learningResultCode "RA212" ;
    ns1:learningResultDescription "Conocer el efecto de las condiciones de vuelo: velocidad y altitud en el funcionamiento de los aerorreactores."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145006203/2025-26/RA213> a ns1:LearningResult ;
    ns1:learningResultCode "RA213" ;
    ns1:learningResultDescription "Conocer los problemas ambientales de los aerorreactores y sus posibles soluciones."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145006203/2025-26/RA214> a ns1:LearningResult ;
    ns1:learningResultCode "RA214" ;
    ns1:learningResultDescription "Redactar informes técnicos y hacer exposiciones orales técnicas relacionadas con lo anterior."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145006203/2025-26/RA215> a ns1:LearningResult ;
    ns1:learningResultCode "RA215" ;
    ns1:learningResultDescription "Resolver problemas derivados del ámbito de la materia de forma autónoma y en colaboración con otros."@es .

