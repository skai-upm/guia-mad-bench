    ns1:learningResultCode "RA6" ;
    ns1:learningResultDescription "Adquirir los conocimientos teóricos y prácticos sobre cartografía, topografía y fotogrametría."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001015/2025-26/RA7> a ns1:LearningResult ;
    ns1:learningResultCode "RA7" ;
    ns1:learningResultDescription "Interpretar la cartografía y los planos topográficos que intervienen en un proyecto de ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001015/2025-26/RA8> a ns1:LearningResult ;
    ns1:learningResultCode "RA8" ;
    ns1:learningResultDescription "Conocer y manejar los instrumentos y los métodos utilizados en los levantamientos topográficos y en el replanteo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001015/2025-26/RA9> a ns1:LearningResult ;
    ns1:learningResultCode "RA9" ;
    ns1:learningResultDescription "Conocer las distintas técnicas fotogramétricas utilizadas para la obtención de documentos cartográficos."@es .

