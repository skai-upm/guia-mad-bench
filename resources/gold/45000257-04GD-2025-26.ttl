<https://guia-kg.skai.etsisi.upm.es/resource/45000257/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/45000257/2025-26/04GC.%20CM28.2> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/45000257/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/45000257/2025-26/didactic_resource/2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/45000257/2025-26/didactic_resource/3>,
        <https://guia-kg.skai.etsisi.upm.es/resource/45000257/2025-26/didactic_resource/4>,
        <https://guia-kg.skai.etsisi.upm.es/resource/45000257/2025-26/didactic_resource/5>,
