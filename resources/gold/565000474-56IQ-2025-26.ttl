    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/565000474/2025-26/eventSchedule> ;
    schema:description "En esta asignatura se analizan los parámetros de calidad del agua y su relación con los contaminantes presentes en estas, legislación vigente y las diferentes alternativas de tratamiento de aguas residuales urbanas e industriales. Teniendo en cuenta las características del agua a tratar y el uso final que se puede dar a las mismas, el estudiante será capaz de proponer una estrategia de depuración de aguas residuales en función de las características de los contaminantes y seleccionando las tecnologías de depuración adecuada."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/n.merayo%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/isabel.carrillo%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/n.merayo%40upm.es> ;
    schema:name "Contaminacion de Aguas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000474/2025-26/CE%2016> a ns1:Competency ;
    ns1:competencyCode "CE 16" ;
    ns1:competencyDescription "Conocimientos básicos y aplicación de tecnologías medioambientales y sostenibilidad."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000474/2025-26/CE%2019> a ns1:Competency ;
    ns1:competencyCode "CE 19" ;
    ns1:competencyDescription "Conocimientos sobre balances de materia y energía, biotecnología, transferencia de materia, operaciones de separación, ingeniería de la reacción química, diseño de reactores, y valoración y transformación de materias primas y recursos energéticos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000474/2025-26/CE%2021> a ns1:Competency ;
    ns1:competencyCode "CE 21" ;
    ns1:competencyDescription "Capacidad para el diseño y gestión de procedimientos de experimentación aplicada, especialmente para la determinación de propiedades termodinámicas y de transporte, y modelado de fenómenos y sistemas en el ámbito de la ingeniería química, sistemas con flujo de fluidos, transmisión de calor, operaciones de transferencia de materia, cinética de las reacciones químicas y reactores."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000474/2025-26/CG%203> a ns1:Competency ;
    ns1:competencyCode "CG 3" ;
    ns1:competencyDescription "Aplicar los conocimientos adquiridos para identificar, formular y resolver problemas en contextos amplios, siendo capaces de integrar los trabajando en equipos multidisciplinares"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000474/2025-26/CG%204> a ns1:Competency ;
    ns1:competencyCode "CG 4" ;
    ns1:competencyDescription "Comprender el impacto de la ingeniería en el medio ambiente, el desarrollo sostenible de la sociedad y la importancia de trabajar en un entorno profesional y responsable"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000474/2025-26/CG%205> a ns1:Competency ;
    ns1:competencyCode "CG 5" ;
    ns1:competencyDescription "Comunicar conocimientos y conclusiones, tanto de forma oral como escrita, a públicos especializados y no especializados de modo claro y sin ambigüedades"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000474/2025-26/CG%206> a ns1:Competency ;
    ns1:competencyCode "CG 6" ;
    ns1:competencyDescription "Poseer las habilidades de aprendizaje que permitan continuar estudiando a lo largo de toda la vida para un desarrollo profesional adecuado"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000474/2025-26/RA313> a ns1:LearningResult ;
    ns1:learningResultCode "RA313" ;
    ns1:learningResultDescription "Capacidad de conocer los conceptos y principios básicos relacionados con la calidad del agua"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000474/2025-26/RA314> a ns1:LearningResult ;
    ns1:learningResultCode "RA314" ;
    ns1:learningResultDescription "Diferenciar y aplicar los distintos procesos físicos, químicos y biológicos para el tratamiento de aguas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000474/2025-26/RA315> a ns1:LearningResult ;
    ns1:learningResultCode "RA315" ;
    ns1:learningResultDescription "Adquirir una visión global de una planta de tratamiento integrando los distintos procesos y líneas de tratamiento involucrados."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000474/2025-26/RA316> a ns1:LearningResult ;
    ns1:learningResultCode "RA316" ;
    ns1:learningResultDescription "Realizar el análisis de ingeniería y el diseño básico de los principales procesos individuales de tratamiento de las aguas residuales urbanas e industriales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000474/2025-26/RA317> a ns1:LearningResult ;
    ns1:learningResultCode "RA317" ;
    ns1:learningResultDescription "Evaluar la calidad de un agua residual en función de los parámetros de caracterización, y hacer el diseño conceptual del proceso de tratamiento en función de la calidad del agua residual, de su destino (vertido, reciclaje, reutilización), de la normativa y de otros condicionantes"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000474/2025-26/RA6> a ns1:LearningResult ;
    ns1:learningResultCode "RA6" ;
    ns1:learningResultDescription "Conocimientos básicos y aplicación de tecnologías medioambientales y sostenibilidad. Comparar y seleccionar alternativas técnicas."@es .

