    ns1:learningResultDescription "Utilizar e interpretar los resultados de aplicaciones informáticas de cálculo estructural."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000190/2025-26/RA160> a ns1:LearningResult ;
