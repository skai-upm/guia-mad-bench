    schema:description "La asignatura está orientada a que el alumno sepa manejar distintos tipos de programas informáticos necesarios, todos ellos, para la elaboración de un Proyecto de Ingeniería."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/miguelangel.gomezelvira%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
