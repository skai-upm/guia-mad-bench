<https://guia-kg.skai.etsisi.upm.es/resource/55001069/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. MÓDULO I. TIPOLOGÍAS ESTRUCTURALES Y MODELOS DE CÁLCULO"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001069/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Descripción y comparación de los distintos tipos de elementos de una estructura. Clasificación geométrica y por cargas Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001069/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "3.1. Introducción al cálculo matricial de sistemas discretos de barras y vigas Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001069/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "3.2. Método de elementos finitos: Conceptos básicos de discretización e interpolación Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001069/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "3.3. Matriz de rigidez y vector de cargas elementales. Ensamblaje. Cálculo de desplazamientos y esfuerzos Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001069/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "3.4. Aplicación del método de elementos finitos a distintos tipos de estructuras de barras y vigas Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001069/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "3.5. El problema del bloqueo Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001069/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "3.6. La analogía del problema de transmisión de calor Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001069/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "3.7. Problemas termoestructurales Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001069/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "4. MÓDULO IV. PANDEO"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001069/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "4.1. Introducción al cálculo de pandeo lineal Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001069/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "4.2. Formulaciones fuerte y débil del problema de pandeo lineal Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001069/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Introducción a los modelos de cálculo estructural Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001069/2025-26/syllabus/20> a ns1:SyllabusItem ;
    ns1:itemIndex 20 ;
    ns1:syllabusDescription "4.3. Aplicación del método de elementos finitos a la resolución del problema de pandeo. Matriz de rigidez geométrica Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001069/2025-26/syllabus/21> a ns1:SyllabusItem ;
    ns1:itemIndex 21 ;
    ns1:syllabusDescription "4.4. Multiplicador de carga, carga crítica de pandeo y modos de pandeo Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001069/2025-26/syllabus/22> a ns1:SyllabusItem ;
    ns1:itemIndex 22 ;
    ns1:syllabusDescription "4.5. Aplicaciones prácticas Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001069/2025-26/syllabus/23> a ns1:SyllabusItem ;
    ns1:itemIndex 23 ;
    ns1:syllabusDescription "5. MÓDULO V. DISEÑO ÓPTIMO DE ESTRUCTURAS"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001069/2025-26/syllabus/24> a ns1:SyllabusItem ;
    ns1:itemIndex 24 ;
    ns1:syllabusDescription "5.1. Conceptos básicos del diseño óptimo estructural. Variables de diseño, restricciones y funciones objetivo. Problemas mono y multiobjetivo Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001069/2025-26/syllabus/25> a ns1:SyllabusItem ;
    ns1:itemIndex 25 ;
    ns1:syllabusDescription "5.2. Descripción general de los métodos de optimización clásicos y por algoritmos genéticos. Ventajas e inconvenientes. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001069/2025-26/syllabus/26> a ns1:SyllabusItem ;
    ns1:itemIndex 26 ;
    ns1:syllabusDescription "5.3. Ejemplos de aplicación de diseño con el método de elementos de finitos a estructuras de barras y vigas Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001069/2025-26/syllabus/27> a ns1:SyllabusItem ;
    ns1:itemIndex 27 ;
    ns1:syllabusDescription "5.4. Análisis de sensibilidad Sin subniveles"@es .

