    ns1:itemIndex 4 ;
    ns1:syllabusDescription "2.1. Isostaticidad e hiperestaticidad Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001069/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "2.2. Equilibrio, compatibilidad y comportamiento Sin subniveles"@es .

