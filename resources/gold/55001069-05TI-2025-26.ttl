    ns1:itemIndex 6 ;
    ns1:syllabusDescription "2.3. El Principio de los Trabajos Virtuales Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001069/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "2.4. Formulaciones fuerte y débil: Barras, Vigas a flexión según las teorías de Bernoulli y Timoshenko Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001069/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "2.5. La analogía del problema de transmisión de calor Sin subniveles"@es .

