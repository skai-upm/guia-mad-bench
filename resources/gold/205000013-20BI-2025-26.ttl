    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/205000013/2025-26/RA102>,
        <https://guia-kg.skai.etsisi.upm.es/resource/205000013/2025-26/RA103>,
        <https://guia-kg.skai.etsisi.upm.es/resource/205000013/2025-26/RA104>,
        <https://guia-kg.skai.etsisi.upm.es/resource/205000013/2025-26/RA105>,
        <https://guia-kg.skai.etsisi.upm.es/resource/205000013/2025-26/RA106>,
        <https://guia-kg.skai.etsisi.upm.es/resource/205000013/2025-26/RA107> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/205000013/2025-26/syllabus> ;
    ns1:inpersonHours "75 horas (55.6%)"@es ;
    ns1:numberOfCredits 5.0 ;
    ns1:otherInformation """Actividades de enseñanza-aprendizaje y evaluación de la asignatura
Actividad
Breve descripción con indicación del método docente utilizado
Clases de teoría
Exposición al estudiante de los contenidos básicos y/o avanzados del tema objeto de estudio. Se relacionarán los contenidos teóricos con los aspectos prácticos de la vida empresarial. La exposición se apoyará en materiales preparados previamente por el profesor mediante presentaciones multimedia, estas podrán estar disponibles para el alumno en la plataforma Moodle.
Clases de problemas
Tienen la finalidad de facilitar la comprensión y aplicación de los conceptos teóricos previamente explicados, por ello no se plantea una división entre los dos tipos de clases, teóricas y de problemas.
Prácticas de laboratorio y/o campo
Se realizaran prácticas con software informático de uso general en algunos temas específicos de la asignatura
Otras actividades presenciales (tutorías grupales, seminarios, conferencias, visitas?)
Trabajos autónomos (individual y/o en grupo)
En el trabajo individual y grupal, el alumno deberá ser capaz de estudiar las cuestiones teóricas y entender y resolver por si mismo los problemas tipo realizados en el aula así como resolver las cuestiones y problemas propuestos

Otros (especificar)
En caso de necesidad se modificará la correspondiente actividad presencial por la de la misma semana en modo no presencial. "Si, por motivos sanitarios, fuera preciso impartir la asignatura en modalidad de tele-enseñanza, las actividades indicadas en la columna "Actividad Presencial en Aula" del Cronograma deberán considerarse trasladadas, sin cambios, a la columna "Tele-enseñanza" del mismo\""""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "75 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/205000013/2025-26/eventSchedule> ;
    schema:description "La asignatura intenta ofrecer al alumno una visión preliminar e introductoria sobre la naturaleza de la empresa desde los puntos de vista organizativo, estratégico, productivo y financiero. La asignatura se considera como de Formación Básica y de carácter obligatorio."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/sonia.benito%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/sonia.benito%40upm.es> ;
    schema:name "Administración de Empresas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000013/2025-26/CE13> a ns1:Competency ;
    ns1:competencyCode "CE13" ;
    ns1:competencyDescription "Conocimientos básicos del concepto de empresa, su marco institucional y jurídico, así como de su organización y gestión en el ámbito agrario."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000013/2025-26/CG06> a ns1:Competency ;
    ns1:competencyCode "CG06" ;
    ns1:competencyDescription "Adquirir la formación profesional en los aspectos básicos de la gestión y comercialización de los productos y servicios agrarios."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000013/2025-26/CG08> a ns1:Competency ;
    ns1:competencyCode "CG08" ;
    ns1:competencyDescription "Adquirir la capacidad emprendedora para la generación de iniciativas en el ámbito agrario, asi como para la transferencia de conocimientos a la sociedad."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000013/2025-26/CT08> a ns1:Competency ;
    ns1:competencyCode "CT08" ;
    ns1:competencyDescription "Ser capaz de manejar las tecnologías de la información y comunicación en un contexto profesional."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000013/2025-26/RA102> a ns1:LearningResult ;
    ns1:learningResultCode "RA102" ;
    ns1:learningResultDescription "Comprender los principios fundamentales de la Economía de la Empresa y los conceptos y herramientas necesarios para la dirección de organizaciones."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000013/2025-26/RA103> a ns1:LearningResult ;
    ns1:learningResultCode "RA103" ;
    ns1:learningResultDescription "Comprender los fundamentos de la contabilidad."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000013/2025-26/RA104> a ns1:LearningResult ;
    ns1:learningResultCode "RA104" ;
    ns1:learningResultDescription "Saber tomar decisiones en la empresa en relación con fuentes de financiación, inversiones y marketing."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000013/2025-26/RA105> a ns1:LearningResult ;
    ns1:learningResultCode "RA105" ;
    ns1:learningResultDescription "Saber estimar costes de producción."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000013/2025-26/RA106> a ns1:LearningResult ;
    ns1:learningResultCode "RA106" ;
    ns1:learningResultDescription "Desarrollar la capacidad de búsqueda, almacenamiento y tratamiento de información para la toma de decisiones y el aprendizaje autónomo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000013/2025-26/RA107> a ns1:LearningResult ;
    ns1:learningResultCode "RA107" ;
    ns1:learningResultDescription "Poder exponer y comunicar sus ideas y reflexiones, tanto de forma oral como escrita."@es .

