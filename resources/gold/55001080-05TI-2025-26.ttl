    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/55001080/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/55001080/2025-26/RA286>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55001080/2025-26/RA287> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/55001080/2025-26/syllabus> ;
    ns1:inpersonHours "50 horas (42.7%)"@es ;
    ns1:numberOfCredits 4.5 ;
    ns1:otherInformation "La asignatura se relaciona con el ODS7 y el ODS12."@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "50 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/55001080/2025-26/eventSchedule> ;
    schema:description """Los objetivos de esta asignatura son:
- Conocer la influencia de las propiedades de los materiales estructurales en su comportamiento en servicio.
- Conocer los criterios y técnicas de selección de materiales y conocer las bases de diseño con materiales con finalidad estructural y su relación con las propiedades de comportamiento de los mismos.
- Conocer las características a considerar en diseños no convencionales.
- Conocer los factores principales que afectan al diseño de uniones soldadas y adhesivas
- Conocer los requisitos de los códigos de diseño y ejecución de componentes y materiales y de las especificaciones técnicas
- Introducción a los códigos de diseño ASME"""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/javier.onoro%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/antonio.portoles%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/javier.onoro%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/lino.sanchez%40upm.es> ;
    schema:name "Diseño y Selección de Materiales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001080/2025-26/CE21E> a ns1:Competency ;
    ns1:competencyCode "CE21E" ;
    ns1:competencyDescription "Capacidad para identificar y utilizar las propiedades y caracterÃ­sticas de las aleaciones no fÃ©rreas mÃ¡s utilizadas, correlacionÃ¡ndolas con su estructura metalogrÃ¡fica, y aprender a manejar los tratamientos tÃ©rmicos para la modificaciÃ³n de sus propiedades"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001080/2025-26/CE22E> a ns1:Competency ;
    ns1:competencyCode "CE22E" ;
    ns1:competencyDescription "Conocimientos de propiedades y posibles tratamientos térmicos de aleaciones férreas para su utilización industrial."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001080/2025-26/CE27C> a ns1:Competency ;
    ns1:competencyCode "CE27C" ;
    ns1:competencyDescription "Conocimientos y capacidades para la aplicación de la ingeniería de materiales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001080/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Conocer y aplicar conocimientos de ciencias y tecnologías básicas a la práctica de la Ingeniería Industrial."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001080/2025-26/CG2> a ns1:Competency ;
    ns1:competencyCode "CG2" ;
    ns1:competencyDescription "Poseer capacidad para diseñar, desarrollar, implementar, gestionar y mejorar productos, sistemas y procesos en los distintos ámbitos industriales, usando técnicas analíticas, computacionales o experimentales apropiadas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001080/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Aplicar los conocimientos adquiridos para identificar, formular y resolver problemas dentro de contextos amplios y multidisciplinarios, siendo capaces de integrar conocimientos, trabajando en equipos multidisciplinares."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001080/2025-26/CG4> a ns1:Competency ;
    ns1:competencyCode "CG4" ;
    ns1:competencyDescription "Comprender el impacto de la ingeniería industrial en el medio ambiente, el desarrollo sostenible de la sociedad y la importancia de trabajar en un entorno profesional y responsable."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001080/2025-26/CG5> a ns1:Competency ;
    ns1:competencyCode "CG5" ;
    ns1:competencyDescription "Saber comunicar los conocimientos y conclusiones, de forma oral, escrita y gráfica, a públicos especializados y no especializados de un modo claro y sin ambigüedades."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001080/2025-26/CG6> a ns1:Competency ;
    ns1:competencyCode "CG6" ;
    ns1:competencyDescription "Poseer habilidades de aprendizaje que permitan continuar estudiando a lo largo de la vida para su adecuado desarrollo profesional."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001080/2025-26/CG7> a ns1:Competency ;
    ns1:competencyCode "CG7" ;
    ns1:competencyDescription "Incorporar nuevas tecnologías y herramientas de la Ingeniería Industrial en sus actividades profesionales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001080/2025-26/RA286> a ns1:LearningResult ;
    ns1:learningResultCode "RA286" ;
    ns1:learningResultDescription "Capacidad de determinar los requisitos de calidad que debe cumplir un material para unas condiciones de servicio determinadas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001080/2025-26/RA287> a ns1:LearningResult ;
