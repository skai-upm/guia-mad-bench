    ns1:inpersonHours "46 horas (56.8%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation """Se recomienda asistencia a clase para realizar un seguimiento adecuado de la asignatura.
Hay actividades evaluables como trabajos en grupo que se deben realizar en pequeños grupos y defender en clase en exposición individual de forma organizada con el grupo, esta actividad se evalúa de forma anónima por el resto de compañeros y el profesor, y es muy adecuada para que el estudiante aprenda a expresarse y responder a las cuestiones que se le planteen, al igual que sucederá en su desarrollo profesional.
Otra actividad evaluable es la visita técnica a dos instalaciones que es muy recomendable, suelen asistir casi todos los alumnos."""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "46 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/63000141/2025-26/eventSchedule> ;
    schema:description "Esta asignatura está compuesta por dos bloques diferenciados, el primero relacionado con la gestión y el tratamiento de residuos (20h), y otro segundo basado en la gestión y tratamiento de los efluentes líquidos (10h). Se mostraran ejemplos prácticos de instalaciones de reciclado y valorización energética de residuos, así como de efluentes líquidos contaminados y su manera depurarlos."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/dulce.gomezlimon%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/dulce.gomezlimon%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/inigomariano.devicente%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/lauramaria.valle%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/pedro.mora%40upm.es> ;
    schema:name "Tratamiento de Residuos Solidos y Efluentes Liquidos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000141/2025-26/CE03> a ns1:Competency ;
    ns1:competencyCode "CE03" ;
    ns1:competencyDescription "Conocimiento adecuado de evaluación de proyectos y análisis de riesgo. Dirección, organización y mantenimiento. Economía y gestión de empresas. Calidad. . Legislación aplicable al medio natural. Gestión del conocimiento"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000141/2025-26/CE09> a ns1:Competency ;
    ns1:competencyCode "CE09" ;
    ns1:competencyDescription "Capacidad para proyectar y ejecutar tratamiento de aguas y gestión de residuos urbanos, industriales o peligrosos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000141/2025-26/CE10> a ns1:Competency ;
    ns1:competencyCode "CE10" ;
    ns1:competencyDescription "Capacidad para evaluar y gestionar ambientalmente proyectos, plantas e instalaciones propias de los campos de actividad del ingeniero de minas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000141/2025-26/CG02> a ns1:Competency ;
    ns1:competencyCode "CG02" ;
    ns1:competencyDescription "Comprensión de los múltiples condicionamientos de carácter técnicos, legal y de la propiedad que se plantean en el proyectos de una planta o instalación, y capacidad para establecer diferentes alternativas válidas, elegir la óptima y plasmarla adecuadamente, previendo los problemas de su desarrollo, y empleando los métodos y tecnologías más adecuadas, tanto tradicionales como innovadores, con la finalidad de conseguir la mayor eficacia y favorecer el progreso y un desarrollo de la sociedad sostenible y respetuoso con el medio ambiente"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000141/2025-26/CG13> a ns1:Competency ;
    ns1:competencyCode "CG13" ;
    ns1:competencyDescription "Capacidad para evaluar y gestionar ambientalmente proyectos, plantas o instalaciones"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000141/2025-26/CG14> a ns1:Competency ;
    ns1:competencyCode "CG14" ;
    ns1:competencyDescription "Capacidad para proyectar y ejecutar tratamientos de aguas y gestión de residuos (urbanos, industriales o peligrosos)"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000141/2025-26/CT04> a ns1:Competency ;
    ns1:competencyCode "CT04" ;
    ns1:competencyDescription "Capacidad para trabajar de forma efectiva como individuo, organizando y planificando su propio trabajo, de forma independiente o como miembro de un equipo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000141/2025-26/CT05> a ns1:Competency ;
    ns1:competencyCode "CT05" ;
    ns1:competencyDescription "Capacidad para gestionar la información, identificando las fuentes necesarias, los principales tipos de documentos técnicos y científicos, de una manera adecuada y eficiente"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000141/2025-26/RA45> a ns1:LearningResult ;
    ns1:learningResultCode "RA45" ;
    ns1:learningResultDescription "Capacidad para diseñar los tratamientos físico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000141/2025-26/RA46> a ns1:LearningResult ;
