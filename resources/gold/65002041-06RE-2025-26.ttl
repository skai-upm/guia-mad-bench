    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/65002041/2025-26/syllabus> ;
    ns1:inpersonHours "55 horas (47%)"@es ;
    ns1:numberOfCredits 4.5 ;
    ns1:otherInformation """La asignatura se imparte de manera Intensiva. Se dan tres clases por semana, y se termina la docencia a mediados de Marzo.
La asignatura permite relacionar los Objetivos de Desarrollo Sostenible con las distintas fuentes de generación de energía eléctrica siguiendo los informes del IPCC. Se relaciona con el ODS 7 Energía Asequible y No contaminante.
Los alumnos se podrán comunicar por email o por Teams con el profesorado de la asignatura."""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "65 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/65002041/2025-26/eventSchedule> ;
    schema:description "En esta asignatura se pretenderá dar una visión global del panorama energético mundial, con una especial incisión en las centrales nucleares de nueva generación, tanto de Fisión, como de Fusión Nuclear."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/kevin.fcosials%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/cesar.queral%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/kevin.fcosials%40upm.es> ;
    schema:name "Centrales Avanzadas de Generación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65002041/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Conocer y aplicar conocimientos de ciencias y tecnologías básicas a la práctica de la Ingeniería de los Recursos Energéticos, Combustibles y Explosivos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65002041/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Aplicar los conocimientos adquiridos para identificar, formular y resolver problemas dentro de contextos amplios y multidisciplinarios, siendo capaces de integrar conocimientos, trabajando en equipos multidisciplinares."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65002041/2025-26/CG4> a ns1:Competency ;
    ns1:competencyCode "CG4" ;
    ns1:competencyDescription "Comprender el impacto de la Ingeniería de los Recursos Energéticos, Combustibles y Explosivos en el medio ambiente, el desarrollo sostenible de la sociedad . desarrollando la capacidad para la realización de estudios de ordenación del territorio y de los aspectos medioambientales relacionados con los proyectos, plantas e instalaciones, en su ámbito."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65002041/2025-26/CG5> a ns1:Competency ;
    ns1:competencyCode "CG5" ;
    ns1:competencyDescription "Saber comunicar los conocimientos y conclusiones, tanto de forma oral, escrita y gráfica, a públicos especializados y no especializados de un modo claro y sin ambigüedades."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65002041/2025-26/CG6> a ns1:Competency ;
    ns1:competencyCode "CG6" ;
    ns1:competencyDescription "Poseer habilidades de aprendizaje que permitan continuar estudiando a lo largo de la vida para su adecuado desarrollo profesional."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65002041/2025-26/CG7> a ns1:Competency ;
    ns1:competencyCode "CG7" ;
    ns1:competencyDescription "Incorporar nuevas tecnologías y herramientas de la Ingeniería de los Recursos Energéticos, Combustibles y Explosivos en sus actividades profesionales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65002041/2025-26/F23> a ns1:Competency ;
    ns1:competencyCode "F23" ;
    ns1:competencyDescription "Obras e instalaciones hidráulicas. Planificación y gestión de recursos hidráulicos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65002041/2025-26/F24> a ns1:Competency ;
    ns1:competencyCode "F24" ;
    ns1:competencyDescription "Industrias de generación, transporte, transformación y gestión de la energía eléctrica y térmica."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65002041/2025-26/F29> a ns1:Competency ;
    ns1:competencyCode "F29" ;
    ns1:competencyDescription "Energías alternativas y uso eficiente de la energía."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65002041/2025-26/F31> a ns1:Competency ;
