    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/133000274/2025-26/eventSchedule> ;
    schema:description "Asignatura transversal que aborda los valores culturales y humanísticos que se precisan en la formación del ingeniero más allá de los propiamente técnicos o tecnológicos. Reflexión sobre cómo se sitúa la ingeniería en la historia, la estética y el entorno físico y social. Análisis de la importancia de transversalidad entre disciplinas: Introducción a la Metodología BIM."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/mariajesus.rosado%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/mariajesus.rosado%40upm.es> ;
    schema:name "Humanismo y Transversalidad en Ingeniería. Introducción a la Metodología Bim"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000274/2025-26/CB06> a ns1:Competency ;
    ns1:competencyCode "CB06" ;
    ns1:competencyDescription "Poseer y comprender conocimientos que aporten una base u oportunidad de ser originales en el desarrollo y/o apl0icación de ideas, a menudo en un contexto de investigación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000274/2025-26/CB07> a ns1:Competency ;
    ns1:competencyCode "CB07" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en entornos nuevos o poco conocidos dentro de contextos más amplios (o multidisciplinares) relacionados con su área de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000274/2025-26/CB08> a ns1:Competency ;
    ns1:competencyCode "CB08" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de integrar conocimientos y enfrentarse a la complejidad de formular juicios a partir de una información que, siendo incompleta o limitada, incluya reflexiones sobre las responsabilidades sociales y éticas vinculadas a la aplicación de sus conocimientos y juicios"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000274/2025-26/CB09> a ns1:Competency ;
    ns1:competencyCode "CB09" ;
    ns1:competencyDescription "Que los estudiantes sepan comunicar sus conclusiones y los conocimientos y razones últimas que las sustentan a públicos especializados y no especializados de un modo claro y sin ambigüedades"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000274/2025-26/CB10> a ns1:Competency ;
    ns1:competencyCode "CB10" ;
    ns1:competencyDescription "Que los estudiantes posean las habilidades de aprendizaje que les permitan continuar estudiando de un modo que habrá de ser en gran medida autodirigido o autónomo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000274/2025-26/CT01> a ns1:Competency ;
    ns1:competencyCode "CT01" ;
    ns1:competencyDescription "Habilidades de comunicación escrita y oral"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000274/2025-26/CT02> a ns1:Competency ;
    ns1:competencyCode "CT02" ;
    ns1:competencyDescription "Integrar los conocimientos previos (propios de grado) de manera crítica y relacionada de forma que se puedan aplicar al estudio de situaciones reales y a la propuesta de alternativas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000274/2025-26/CT04> a ns1:Competency ;
    ns1:competencyCode "CT04" ;
    ns1:competencyDescription "Capacidad crítica para el análisis, la síntesis y el aprendizaje mediante el intercambio de opiniones, presentando argumentos sólidos y estructurados"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000274/2025-26/CT06> a ns1:Competency ;
    ns1:competencyCode "CT06" ;
    ns1:competencyDescription "Búsqueda bibliográfica, análisis de documentación y tratamiento de la información procedente de diversas fuentes y de su análisis y síntesis aplicándola a la resolución de problemas complejos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000274/2025-26/CT09> a ns1:Competency ;
    ns1:competencyCode "CT09" ;
    ns1:competencyDescription "Utilización de las TICs para el trabajo cooperativo y el trabajo en equipo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000274/2025-26/CT10> a ns1:Competency ;
    ns1:competencyCode "CT10" ;
    ns1:competencyDescription "Valores humanos positivos: Respeto a los derechos humanos fundamentales; los principios de igualdad de oportunidades, accesibilidad universal y no discriminación; y los valores propios de una cultura de paz y de valores democráticos. Compromiso con estos derechos, principios y valores, motivación, actitud positiva y entusiasta; ética, integridad y honestidad profesional"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000274/2025-26/RA134> a ns1:LearningResult ;
    ns1:learningResultCode "RA134" ;
    ns1:learningResultDescription "Capacidad para realizar búsquedas bibliográficas, consultar y utilizar con criterio bases de datos y otras fuentes de información, para llevar a cabo simulaciones con el objetivo de realizar investigaciones sobre temas complejos de su especialidad"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000274/2025-26/RA175> a ns1:LearningResult ;
    ns1:learningResultCode "RA175" ;
    ns1:learningResultDescription "Saber emitir juicios críticos y opiniones fundamentadas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000274/2025-26/RA178> a ns1:LearningResult ;
    ns1:learningResultCode "RA178" ;
    ns1:learningResultDescription "Saber utilizar motores de búsqueda de información bibliográfica de relevancia y probado rigor científico y opiniones fundamentadas en las evidencias suministrada por datos muestrales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000274/2025-26/RA190> a ns1:LearningResult ;
    ns1:learningResultCode "RA190" ;
    ns1:learningResultDescription "Saber utilizar herramientas TIC de trabajo colaborativo en el entorno empresarial"@es .

