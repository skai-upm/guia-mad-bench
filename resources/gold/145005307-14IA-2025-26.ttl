        <https://guia-kg.skai.etsisi.upm.es/resource/pedro.blanco%40upm.es> ;
    schema:name "Aeropuertos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005307/2025-26/CE70> a ns1:Competency ;
    ns1:competencyCode "CE70" ;
    ns1:competencyDescription "Conocimiento adecuado y aplicado a la Ingeniería de: Los métodos de cálculo y de desarrollo de la navegación aérea; el cálculo de los sistemas específicos de la aeronavegación y sus infraestructuras; las actuaciones, maniobras y control de las aeronaves; la normativa aplicable; el funcionamiento y la gestión del transporte aéreo; los sistemas de navegación y circulación aérea; los sistemas de comunicación y vigilancia aérea."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005307/2025-26/CE72> a ns1:Competency ;
    ns1:competencyCode "CE72" ;
    ns1:competencyDescription "Conocimiento adecuado y aplicado a la ingeniería de las necesidades y desarrollo de las infraestructuras aeroportuarias y su impacto ambiental, la operación y funcionamiento de los aeropuertos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005307/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Capacidad de Organización y de Planificación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005307/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Capacidad para identificar y resolver problemas aplicando, con creatividad, los conocimientos adquiridos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005307/2025-26/CG8> a ns1:Competency ;
    ns1:competencyCode "CG8" ;
    ns1:competencyDescription "Capacidad de integrar el respeto al medio ambiente en el desarrollo de sus actividades"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005307/2025-26/CG9> a ns1:Competency ;
    ns1:competencyCode "CG9" ;
    ns1:competencyDescription "Razonamiento crítico y capacidad de asociación que posibiliten el aprendizaje continuo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005307/2025-26/RA60> a ns1:LearningResult ;
    ns1:learningResultCode "RA60" ;
    ns1:learningResultDescription "Conocer, comprender, analizar y valorar los roles de aeropuertos y su relación con las compañías en el contexto del transporte aéreo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005307/2025-26/RA61> a ns1:LearningResult ;
    ns1:learningResultCode "RA61" ;
    ns1:learningResultDescription "Conocer, comprender, analizar y valorar la operación aeroportuaria y sus repercusiones respecto del mercado del transporte aéreo, del dimensionamiento aeroportuario y de las características del pasajero"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005307/2025-26/RA62> a ns1:LearningResult ;
    ns1:learningResultCode "RA62" ;
    ns1:learningResultDescription "Conocer , comprender, analizar y valorar la estructura de un aeropuerto y sus procesos funcionales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005307/2025-26/RA63> a ns1:LearningResult ;
    ns1:learningResultCode "RA63" ;
    ns1:learningResultDescription "Aplicación del concepto de sistema y el funcionamiento respecto de su capacidad"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005307/2025-26/RA64> a ns1:LearningResult ;
    ns1:learningResultCode "RA64" ;
    ns1:learningResultDescription "Analizar, valorar y sintetizar el Plan Director Aeroportuario."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005307/2025-26/RA65> a ns1:LearningResult ;
    ns1:learningResultCode "RA65" ;
    ns1:learningResultDescription "Conocer, comprender, analizar y sintetizar los conceptos básicos y elementos que definen un helipuerto."@es .

