<https://guia-kg.skai.etsisi.upm.es/resource/20504417/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/20504417/2025-26/CB05>,
        <https://guia-kg.skai.etsisi.upm.es/resource/20504417/2025-26/CE27>,
        <https://guia-kg.skai.etsisi.upm.es/resource/20504417/2025-26/CE32>,
        <https://guia-kg.skai.etsisi.upm.es/resource/20504417/2025-26/CG05> ;
