    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/45001433/2025-26/eventSchedule> ;
    schema:description """El objetivo fundamental de la asignatura es la aplicación práctica de los sistemas aplicados en la Tecnología Energética. Los alumnos adquirieren los conocimientos adecuados para el diseño y funcionamiento termodinámico de las Instalaciones industriales de producción térmica y de los equipos del sector energético de frío y climatización. Conocerán los conceptos necesarios para la gestión y ahorro energético y desarrollarán el cálculo de instalaciones térmicas energéticamente eficientes.
Se conseguirá una formación multidisciplinar en el campo de la energía, incluyendo los recursos renovables utilizados y la aplicación de las energías renovables en el campo de la ingeniería."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/mariajose.suarez%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/ja.deisabel%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/luis.pujol%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/manuel.fuentes%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/mariajose.suarez%40upm.es> ;
    schema:name "Tecnologia Energetica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001433/2025-26/CM37.1> a ns1:Competency ;
    ns1:competencyCode "CM37.1" ;
    ns1:competencyDescription "Conocimiento y capacidad para proyectar y dimensionar obras e instalaciones hidráulicas, sistemas energéticos, aprovechamientos hidroeléctricos y planificación y gestión de recursos hidráulicos superficiales y subterráneos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001433/2025-26/CM37.4> a ns1:Competency ;
    ns1:competencyCode "CM37.4" ;
    ns1:competencyDescription "Comprensión del fundamento y de los sistemas de utilización de las energías renovables."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001433/2025-26/CM45> a ns1:Competency ;
    ns1:competencyCode "CM45" ;
    ns1:competencyDescription "Comprensión y asunción de los principios de incertidumbre, riesgo y oportunidad en la aplicación de los métodos y modelos de la ingeniería civil (Desarrolla parcialmente la competencia transversal 3ª del R.D. 1393/2007)."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001433/2025-26/CT2> a ns1:Competency ;
    ns1:competencyCode "CT2" ;
    ns1:competencyDescription "Capacidad de organizar y dirigir los esfuerzos de un grupo humano reducido y homogéneo. Desarrolla la competencia transversal 8ª de la normativa UPM."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001433/2025-26/CT3> a ns1:Competency ;
    ns1:competencyCode "CT3" ;
    ns1:competencyDescription "Capacidad de actuar con efectividad como miembro de equipos interdisciplinares. Desarrolla la competencia transversal 5ª de la normativa UPM."@es .

