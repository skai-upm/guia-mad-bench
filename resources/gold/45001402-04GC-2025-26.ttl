    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/45001402/2025-26/eventSchedule> ;
    schema:description "La asignatura presenta los aspectos generales de las construcciones de edificación incluyendo estructura, albañilería y aspectos más específicos (control de calidad, mantenimiento, instalaciones). En cuanto a la prefabricación, se presentan las tipologías más habituales, los métodos de fabricación, parámetros de diseño, y los aspectos relacionados con transporte y puesta en obra"@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/jaime.fernandez.gomez%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/alfonso.barba.perez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/franciscojose.gonzalezr%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/jaime.fernandez.gomez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/rosalia.pacheco%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/tiago.martins%40upm.es> ;
    schema:name "Edificacion y Prefabricacion"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001402/2025-26/CM29.1> a ns1:Competency ;
    ns1:competencyCode "CM29.1" ;
    ns1:competencyDescription "Conocimiento de la tipología y las bases de cálculo de los elementos prefabricados y su aplicación en los procesos de fabricación."@es .

