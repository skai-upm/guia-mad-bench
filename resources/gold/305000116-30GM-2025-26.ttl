    ns1:learningResultCode "RA117" ;
    ns1:learningResultDescription "Producir un modelo matemático de un fenómeno real. Identificar todos los compo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000116/2025-26/RA118> a ns1:LearningResult ;
    ns1:learningResultCode "RA118" ;
    ns1:learningResultDescription "Utilizar el análisis de las series numéricas para resolver diversidad de problemas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000116/2025-26/RA119> a ns1:LearningResult ;
    ns1:learningResultCode "RA119" ;
    ns1:learningResultDescription "Reconocer y manejar el concepto medida"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000116/2025-26/RA12> a ns1:LearningResult ;
    ns1:learningResultCode "RA12" ;
    ns1:learningResultDescription "Aplicar las herramientas de combinatoria adecuadas para resolver problemas básicos de conteo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000116/2025-26/RA120> a ns1:LearningResult ;
    ns1:learningResultCode "RA120" ;
    ns1:learningResultDescription "Conocer y manejar el concepto de integral de Lebesgue y sus aplicaciones"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000116/2025-26/RA140> a ns1:LearningResult ;
    ns1:learningResultCode "RA140" ;
    ns1:learningResultDescription "Plantear, resolver e interpretar modelos matemáticos de problemas aplicados"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000116/2025-26/RA70> a ns1:LearningResult ;
    ns1:learningResultCode "RA70" ;
    ns1:learningResultDescription "Programar algoritmos sencillos de resolución de modelos matemáticos con las habilidades de programación adquiridas en la asignatura de programación."@es .

