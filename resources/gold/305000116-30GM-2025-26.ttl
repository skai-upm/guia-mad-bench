    ns1:learningResultCode "RA71" ;
    ns1:learningResultDescription "Plantear un modelo matemático a un problema aplicado sencillo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000116/2025-26/RA73> a ns1:LearningResult ;
    ns1:learningResultCode "RA73" ;
    ns1:learningResultDescription "Asociar y aplicar el modelo probabilístico adecuado al problema propuesto"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000116/2025-26/RA74> a ns1:LearningResult ;
