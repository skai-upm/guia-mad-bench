<https://guia-kg.skai.etsisi.upm.es/resource/145007502/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. BLOQUE TEMÁTICO 1. INTRODUCCIÓN GENERAL A LA MECÁNICA DEL VUELO"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145007502/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Tema 1. INTRODUCCIÓN Y PRESENTACIÓN DE LA ASIGNATURA. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145007502/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "2.6. Tema 9. ACTUACIONES DE AVIONES DE ALTA VELOCIDAD. 9.1. Efectos de la compresibilidad. 9.2. Diagramas M-h. 9.3. Energía específica. Exceso de potencia específico Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145007502/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "3. BLOQUE TEMÁTICO 3. ESTABILIDAD Y COTROL ESTÁTICOS"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145007502/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "3.1. Tema 10. ESTABILIDAD ESTÁTICA LONGITUDINAL. 10.1. Sustentación total. 10.2. Momento de cabeceo total. 10.3. Índice de estabilidad estática longitudinal con mandos fijos. 10.4. Punto neutro con mandos fijos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145007502/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "3.2. Tema 11. CONTROL ESTÁTICO LONGITUDINAL. 11.1. Métodos de control longitudinal. 11.2. Deflexión del timón de profundidad para el equilibrio Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145007502/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "3.3. Tema 12. SISTEMAS DE MANDO. FUERZAS EN PALANCA Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145007502/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "3.4. Tema 13. ESTABILIDAD Y CONTROL ESTÁTICOS LATERAL DIRECCIONALES. 13.1. Coeficientes de fuerza y momentos lateral-direccionales. 13.2. Fuerza lateral total. 13.3. Momento de balance total. 13.4. Momento de guiñada total. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145007502/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "4. BLOQUE TEMÁTICO 4. INTRODUCCIÓN A LA ESTABILIDAD Y CONTROL DINÁMICOS, A LAS CUALIDADES DE VUELO Y A LOS ENSAYOS EN VUELO"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145007502/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "4.1. Tema 14. ESTABILIDAD Y CONTROL DINÁMICOS LONGITUDINALES Y LATERAL DIRECCIONALES Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145007502/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "4.2. Tema 15. CUALIDADES DE VUELO Y ENSAYOS EN VUELO Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145007502/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Tema 2. SISTEMAS BÁSICOS DE REFERENCIA. 2.1. Sistemas de referencia generales. 2.2. Orientación entre distintos sistemas de referencia. 2.3. Matrices de transformación de vectores entre distintos sistemas de referencia. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145007502/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "1.3. Tema 3. ECUACIONES GENERALES DEL MOVIMIENTO DEL AVIÓN Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145007502/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "2. BLOQUE TEMÁTICO 2. ACTUACIONES"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145007502/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "2.1. Tema 4. RELACIONES BÁSICAS PARA LA DETERMINACIÓN DE ACTUACIONES. 4.1. Forma de expresar las ecuaciones de fuerzas y cinemáticas. 4.2. Velocidad evolutoria. 4.3. Relaciones dinámicas y cinemáticas. 4.4. Discusión general del sistema y casos particulares. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145007502/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "2.2. Tema 5. ACTUACIONES DEL PLANEADOR. 5.1. Adimensionalización de las ecuaciones para el cálculo de actuaciones. Magnitudes características. 5.2. Actuaciones de punto del planeador. 5.3. Actuaciones integrales del planeador. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145007502/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "2.3. Tema 6. ACTUACIONES DE AVIONES DOTADOS DE TURBORREACTOR. 6.1. Actuaciones en vuelo horizontal. Velocidad máxima y techo. 6.2. Actuaciones en subida. 6.3. Actuaciones en viraje. 6.4. Actuaciones integrales. Alcance y autonomía Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145007502/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "2.4. Tema 7. ACTUACIONES DE AVIONES DOTADOS DE MOTOR ALTERNATIVO Y HÉLICE. 7.1. Actuaciones en vuelo horizontal. 7.2. Actuaciones en subida. 7.3. Actuaciones en viraje. 7.4. Actuaciones integrales. Alcance y autonomía. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145007502/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "2.5. Tema 8. ACTUACIONES EN DESPEGUE Y ATERRIZAJE. 8.1. Rodadura en el suelo. 8.2. Recorrido en el aire. 8.3. Aterrizaje. Sin subniveles"@es .

