    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/53000912/2025-26/syllabus> ;
    ns1:inpersonHours "51 horas (39.2%)"@es ;
    ns1:numberOfCredits 5.0 ;
    ns1:otherInformation "En esta asignatura se intenta trabajar el objetivo número 8 de la lista de Objetivos de crecimiento sostenible de Naciones Unidas, relativo al trabajo decente y al crecimiento económico. Para ello la asignatura trabaja el concepto de imagen fiel de la empresa y la necesidad de aportar información contable transparente y fiable que contribuya a la creación de relaciones comerciales de confianza y que contribuya a la mejor gestión de la responsabilidad social corporativa de la empresa."@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "57 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/53000912/2025-26/eventSchedule> ;
    schema:description """1. Creación y evolución de la UE
2. La Unión Monetaria: la tragedia del Euro
3. Marco general de la innovación en la UE
4. Instituciones y presupuestos de la UE
5. Estrategias transregionales y ecosistemas de innovación
6. Dimensión internacional del Espacio Europeo de Investigación
7. Horizonte Europa
8. Políticas Sectoriales I
9. Políticas Sectoriales II
10. Políticas Sectoriales III
11. El Estado Emprendedor y sus críticas"""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/gustavo.morales%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/gustavo.morales%40upm.es> ;
    schema:name "Politicas de I+D e Innovavion en la Union Europea"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000912/2025-26/CE1> a ns1:Competency ;
    ns1:competencyCode "CE1" ;
    ns1:competencyDescription "Comprender la importancia de la innovación para la productividad, competitividad y crecimiento de las economías."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000912/2025-26/CE14> a ns1:Competency ;
    ns1:competencyCode "CE14" ;
    ns1:competencyDescription "Conocer los instrumentos de gestión de la propiedad industrial y los procedimiento de concesión."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000912/2025-26/CE17> a ns1:Competency ;
    ns1:competencyCode "CE17" ;
    ns1:competencyDescription "Conocer metodologías para la evaluación del impacto de programas de apoyo a la innovación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000912/2025-26/CE4> a ns1:Competency ;
    ns1:competencyCode "CE4" ;
    ns1:competencyDescription "Conocer el marco normativo en el que se desenvuelve la gestión de la innovación y sus implicaciones."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000912/2025-26/CE5> a ns1:Competency ;
    ns1:competencyCode "CE5" ;
    ns1:competencyDescription "Comprender la evolución de las políticas de investigación e innovación a nivel nacional e internacional."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000912/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de integrar conocimientos y enfrentarse a la complejidad de formular juicios a partir de una información que, siendo incompleta o limitada, incluya reflexiones sobre las responsabilidades sociales y éticas vinculadas a la aplicación de sus conocimientos y juicios."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000912/2025-26/CG6> a ns1:Competency ;
    ns1:competencyCode "CG6" ;
    ns1:competencyDescription "Que el estudiante sea capaz de estructurar de forma coherente los pasos a seguir para alcanzar sus objetivos, teniendo en cuenta los recursos con los que cuenta."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000912/2025-26/CT1> a ns1:Competency ;
    ns1:competencyCode "CT1" ;
    ns1:competencyDescription "Capacidad de búsqueda de información e investigación. El estudiante debe ser capaz de encontrar la información relevante utilizando diferentes fuentes (bases de datos, medios de comunicación, manuales, etc.) y estudiar a fondo esa información."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000912/2025-26/CT2> a ns1:Competency ;
    ns1:competencyCode "CT2" ;
    ns1:competencyDescription "Capacidad de manejo de las tecnologías de la información y las telecomunicaciones. El estudiante debe saber desenvolverse bien con los medios tecnológicos a su alcance (Internet, programas y aplicaciones informáticas, etc.)."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000912/2025-26/CT3> a ns1:Competency ;
    ns1:competencyCode "CT3" ;
    ns1:competencyDescription "Capacidad de trabajo en equipo. El alumno debe ser capaz de colaborar y cooperar con los demás para el logro de resultados del equipo. Debe aceptar y valorar las competencias de otros construyendo relaciones de respeto y crecimiento mutuo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000912/2025-26/CT5> a ns1:Competency ;
    ns1:competencyCode "CT5" ;
    ns1:competencyDescription "Capacidad para trabajar en contextos internacionales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000912/2025-26/RA11> a ns1:LearningResult ;
    ns1:learningResultCode "RA11" ;
    ns1:learningResultDescription "Conocimiento de las principales alternativas para el diseño y evaluación de políticas de innovación y cambio tecnológico."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000912/2025-26/RA17> a ns1:LearningResult ;
    ns1:learningResultCode "RA17" ;
    ns1:learningResultDescription "Examinar las distintas teorías sobre el cambio técnico, y los efectos que dicho cambio tiene sobre el crecimiento y desarrollo de los pueblos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000912/2025-26/RA18> a ns1:LearningResult ;
    ns1:learningResultCode "RA18" ;
    ns1:learningResultDescription "? Estudiar los distintos modelos y políticas en materia de gestión del conocimiento en las organizaciones."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000912/2025-26/RA2> a ns1:LearningResult ;
    ns1:learningResultCode "RA2" ;
    ns1:learningResultDescription "Conocer instrumentos financieros para la innovación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000912/2025-26/RA20> a ns1:LearningResult ;
    ns1:learningResultCode "RA20" ;
    ns1:learningResultDescription "Conocimiento de los conceptos básicos que comprende la gestión de la innovación tecnológica en los diferentes tipos de organizaciones."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000912/2025-26/RA22> a ns1:LearningResult ;
    ns1:learningResultCode "RA22" ;
    ns1:learningResultDescription "Caracterización de metodologías de planificación tecnológica, lo que implica el diseño del Plan Tecnológico."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000912/2025-26/RA25> a ns1:LearningResult ;
    ns1:learningResultCode "RA25" ;
    ns1:learningResultDescription "Conocimiento de la estructura de la Unión Europea."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000912/2025-26/RA26> a ns1:LearningResult ;
    ns1:learningResultCode "RA26" ;
    ns1:learningResultDescription "Conocimiento de las políticas básicas relacionadas con la I+D y la innovación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000912/2025-26/RA27> a ns1:LearningResult ;
    ns1:learningResultCode "RA27" ;
    ns1:learningResultDescription "Conocimiento de importancia, prioridades e instrumentos relacionados con la Unión Europea."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000912/2025-26/RA28> a ns1:LearningResult ;
    ns1:learningResultCode "RA28" ;
    ns1:learningResultDescription "Acercar a los alumnos al estudio metodológico de la ciencia y la investigación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000912/2025-26/RA35> a ns1:LearningResult ;
    ns1:learningResultCode "RA35" ;
    ns1:learningResultDescription "Capacidad de identificar problemas y ámbitos de estudio en el contexto de la internacionalización de la actividad innovadora."@es .

