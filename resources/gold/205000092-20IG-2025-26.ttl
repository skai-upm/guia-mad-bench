<https://guia-kg.skai.etsisi.upm.es/resource/205000092/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Introducción a la Ecología"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000092/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Definición. Datos históricos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000092/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "3.1. Definición de población. Densidad de la población y otras medidas de abundancia. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000092/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "3.2. Estructura espacial de una población. Distribución (Dispersión) interna. Dispersión externa (migraciones) Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000092/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "3.3. Estructura temporal (clases etarias) de una población. Pirámides de población y tipos. Curvas de supervivencia y tipos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000092/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "4. Población: dinámica de poblaciones"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000092/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "4.1. Dinámica de crecimiento exponencial y logístico. Concepto de capacidad de carga (K). Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000092/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "4.2. Estrategias de crecimiento: estrategia de la K y de la r. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000092/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "4.3. Ritmos y fluctuaciones Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000092/2025-26/syllabus/17> a ns1:SyllabusItem ;
