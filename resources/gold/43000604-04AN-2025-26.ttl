    ns1:syllabusDescription "4.5. Tribology tests"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000604/2025-26/syllabus/41> a ns1:SyllabusItem ;
    ns1:itemIndex 41 ;
    ns1:syllabusDescription "4.5.1. Introduction. Origins and history of tribology. Fundamentals of tribology: surfaces in contact, friction, lubrication, and wear. Definition of the Tribo-test. Standard tests. Case studies. Sin subniveles"@es .

