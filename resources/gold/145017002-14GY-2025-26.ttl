<https://guia-kg.skai.etsisi.upm.es/resource/145017002/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. INTRODUCCIÓN AL ATFCM."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145017002/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Problemática de la gestión de la capacidad. 1.2. Identificación de necesidades y requisitos. 1.3. Aplicación del concepto de gestión de capacidad en Europa. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145017002/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "6.1. . Identificación de objetivos y elementos del Plan de Capacidad. 6.2. Preparación de plan de capacidad de un escenario determinado. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145017002/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "2. USO FLEXIBLE DEL ESPACIO AÉREO (FUA) Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145017002/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "3. PROCESO DE PLANIFICACIÓN DE CAPACIDAD"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145017002/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "3.1. Valoración del escenario de planificación de capacidad europeo. 3.2. Metodología de evaluación de capacidad. 3.3. Proceso de planificación de capacidad a nivel europeo. 3.4. Evaluación del proceso de planificación de capacidad. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145017002/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "4. DESARROLLO DE PROCEDIMIENTOS OPERATIVOS EN EL EQUILIBRIO CAPACIDAD ? DEMANDA."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145017002/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "4.1. Procedimientos generales ATFCM. 4.2. El proceso de asignación de slots. 4.3. Procedimientos de cambio de ruta. 4.4. Análisis y asignación de demoras. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145017002/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "5. NUEVOS CONCEPTOS EN LA GESTIÓN DEL EQUILIBRIO CAPACIDAD ? DEMANDA."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145017002/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "5.1. 5.1. Identificación de puntos de mejora en el proceso ATFCM. 5.2. Nuevos conceptos y técnicas de gestión de la capacidad. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145017002/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "6. PREPARACIÓN Y DESARROLLO DE PLAN DE CAPACIDAD."@es .

