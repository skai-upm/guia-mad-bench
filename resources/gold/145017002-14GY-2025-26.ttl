<https://guia-kg.skai.etsisi.upm.es/resource/145017002/2025-26/CE06> a ns1:Competency ;
    ns1:competencyCode "CE06" ;
    ns1:competencyDescription "Capacidad para comprender la globalidad del sistema de navegación aérea y la complejidad del tráfico aéreo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145017002/2025-26/CG04> a ns1:Competency ;
    ns1:competencyCode "CG04" ;
    ns1:competencyDescription "Capacidad para analizar implicaciones económicas, administrativas, sociales o medioambientales ligadas a la aplicación de nuevos conceptos y técnicas en el ámbito de la Gestión y Operación del Transporte Aéreo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145017002/2025-26/CT01> a ns1:Competency ;
    ns1:competencyCode "CT01" ;
    ns1:competencyDescription "Capacidad de Organización y de Planificación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145017002/2025-26/CT08> a ns1:Competency ;
    ns1:competencyCode "CT08" ;
    ns1:competencyDescription "Capacidad de integrar el respeto al medio ambiente en el desarrollo de sus actividades"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145017002/2025-26/RA7> a ns1:LearningResult ;
    ns1:learningResultCode "RA7" ;
    ns1:learningResultDescription "Organiza y aplica las relaciones operativas entre los servicios aeroportuarios y los servicios de tránsito aéreo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145017002/2025-26/RA8> a ns1:LearningResult ;
    ns1:learningResultCode "RA8" ;
    ns1:learningResultDescription "Interpreta las metodologías y técnicas de cálculo y optimización de capacidad en los servicios de tránsito aéreo y operaciones aeroportuarias"@es .

