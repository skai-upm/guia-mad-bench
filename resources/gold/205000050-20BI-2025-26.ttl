<https://guia-kg.skai.etsisi.upm.es/resource/205000050/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/205000050/2025-26/CG02>,
        <https://guia-kg.skai.etsisi.upm.es/resource/205000050/2025-26/CT07> ;
