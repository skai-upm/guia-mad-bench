<https://guia-kg.skai.etsisi.upm.es/resource/23000624/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/23000624/2025-26/CE1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/23000624/2025-26/CE2>,
