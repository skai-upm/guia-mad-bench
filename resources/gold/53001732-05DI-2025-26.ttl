<https://guia-kg.skai.etsisi.upm.es/resource/53001732/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/53001732/2025-26/MUAR.CB06>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001732/2025-26/MUAR.CE05>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001732/2025-26/MUAR.CG01>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001732/2025-26/MUAR.CT11> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/53001732/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001732/2025-26/didactic_resource/2> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/53001732/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/53001732/2025-26/RA51>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001732/2025-26/RA52>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001732/2025-26/RA53> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/53001732/2025-26/syllabus> ;
    ns1:inpersonHours "29 horas y 30 minutos (37.8%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation """El temario propuesto se imparte por primera vez durante este curso, de forma que es posible que haya alguna alteración en la programación individual de alguna clase o un cambio de orden en los bloques de la asignatura.
Igualmente, se acordará con los alumnos el peso en la calificación final que pueda tener el trabajo de clase."""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "29 horas y 30 minutos"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/53001732/2025-26/eventSchedule> ;
    schema:description "La asignatura recoge las principales bases matemáticas necesarias para cursar las asignaturas del Máster en Automática y Robótica. Partiendo de los conceptos incluidos en las asignaturas de matemáticas de los grados de referencia, ahonda en nuevos conceptos destacando su importancia y su relación con la temática del máster."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/sergio.dominguez%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/claudio.rossi%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/sergio.dominguez%40upm.es> ;
    schema:name "Matemáticas para Automática y Robótica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001732/2025-26/MUAR.CB06> a ns1:Competency ;
    ns1:competencyCode "MUAR.CB06" ;
    ns1:competencyDescription "Poseer y comprender conocimientos que aporten una base u oportunidad de ser originales en el desarrollo y/o aplicación de ideas, a menudo en un contexto de investigación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001732/2025-26/MUAR.CE05> a ns1:Competency ;
    ns1:competencyCode "MUAR.CE05" ;
    ns1:competencyDescription "Capacidad para aplicar técnicas matemáticas adecuadas en la resolución de problemas de Automática y Robótica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001732/2025-26/MUAR.CG01> a ns1:Competency ;
    ns1:competencyCode "MUAR.CG01" ;
    ns1:competencyDescription "Tener conocimientos adecuados de los aspectos científicos y tecnológicos de la automática y la robótica."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001732/2025-26/MUAR.CT11> a ns1:Competency ;
    ns1:competencyCode "MUAR.CT11" ;
    ns1:competencyDescription "Usa herramientas. Habilidad para usar las técnicas, destrezas y herramientas ingenieriles modernas necesarias para la práctica de la ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001732/2025-26/RA51> a ns1:LearningResult ;
    ns1:learningResultCode "RA51" ;
    ns1:learningResultDescription "El alumno debe ser capaz de formalizar problemas de automática y robótica haciendo el correcto uso de las herramientas matemáticas presentadas en la asignatura"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001732/2025-26/RA52> a ns1:LearningResult ;
    ns1:learningResultCode "RA52" ;
    ns1:learningResultDescription "El alumno debe conocer las posibles alternativas matemáticas para la solución de un problema en automática y robótica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001732/2025-26/RA53> a ns1:LearningResult ;
    ns1:learningResultCode "RA53" ;
    ns1:learningResultDescription "El alumno debe establecer la correcta algorítmica que conduce de un problema correctamente formulado a una solución válida"@es .

