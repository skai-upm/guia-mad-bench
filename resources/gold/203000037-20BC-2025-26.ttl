<https://guia-kg.skai.etsisi.upm.es/resource/203000037> a ns1:Course ;
    ns1:courseType "Optativa"@es ;
    ns1:courseYear 1 ;
    ns1:semester "Segundo semestre"@es ;
    schema:courseCode 203000037 ;
    schema:hasCourseInstance <https://guia-kg.skai.etsisi.upm.es/resource/203000037/2025-26> ;
    schema:name "Technological Innovation"@en,
        "Valorización e Innovación Tecnológica"@es ;
    schema:numberOfCredits 3.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/203000037/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/203000037/2025-26/CE06>,
        <https://guia-kg.skai.etsisi.upm.es/resource/203000037/2025-26/CG06>,
        <https://guia-kg.skai.etsisi.upm.es/resource/203000037/2025-26/CT04> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/203000037/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/203000037/2025-26/didactic_resource/2> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/203000037/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/203000037/2025-26/RA56>,
        <https://guia-kg.skai.etsisi.upm.es/resource/203000037/2025-26/RA57>,
        <https://guia-kg.skai.etsisi.upm.es/resource/203000037/2025-26/RA58>,
        <https://guia-kg.skai.etsisi.upm.es/resource/203000037/2025-26/RA59>,
        <https://guia-kg.skai.etsisi.upm.es/resource/203000037/2025-26/RA60> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/203000037/2025-26/syllabus> ;
    ns1:inpersonHours "87 horas (107.4%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation """This Subject will contribute to the following ODS:
- Salud y bienestar
- Industria, innovación e infraestructura
- Reducción de las desigualdades
- Ciudades y comunidades sostenibles
- Producción y consumo responsables
- Alianzas para lograr los objetivos"""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "87 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/203000037/2025-26/eventSchedule> ;
    schema:description """The aims of this topic is to provide fundamental knowledge in valorization and technology transfer. Among the topics to be studied are the following:
- To acquire knowledge and experience on the legislation applicable to the commercialization of computational biology technology
- To gain knowledge on the legal aspects of the transfer of material and technology between public and private entities.
- To understand the technology value chain and technology valorization and technology value chain
- To study the legal aspects of intellectual property and personal data protection
- To acquire knowledge about the legal and economic aspects in the creation of technology-based companies (EBT).
- To gain knowledge about the legal and administrative aspects to consider in the creation of biotechnological companies and their management.
- To understand the management of the economic value of investment in R + D + i."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/antonio.molina%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/antonio.molina%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/lucia.jorda%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/victor.rodriguez%40upm.es> ;
    schema:name "Valorización e Innovación Tecnológica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000037/2025-26/CE06> a ns1:Competency ;
    ns1:competencyCode "CE06" ;
    ns1:competencyDescription "Identificar las necesidades bioinformáticas de los centros de investigación y las empresas del sector de la biotecnología y la biomedicina/ Identifying the bioinformatics needs of research centers and enterprises in the biotechnology and biomedicine sectors."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000037/2025-26/CG06> a ns1:Competency ;
    ns1:competencyCode "CG06" ;
    ns1:competencyDescription "Que los estudiantes posean las habilidades de aprendizaje que les permitan continuar estudiando de un modo que habrá de ser en gran medida autodirigido o autónomo para adaptarse a la rápida evolución prevista en el área de la Biología Computacional/ Provide students with the learning abilities that allow them to study in a largely autodirected and autonomous manner so that they can adapt to the fast evolving nature of the Computational Biology field."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000037/2025-26/CT04> a ns1:Competency ;
    ns1:competencyCode "CT04" ;
    ns1:competencyDescription "Capacidad para comunicar a todo tipo de audiencias en lengua inglesa, tanto de forma oral como escrita/ Capacity to communicate through oral of written communications in English to every type of audience ."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000037/2025-26/RA56> a ns1:LearningResult ;
    ns1:learningResultCode "RA56" ;
    ns1:learningResultDescription "Adquirir conocimientos y experiencia sobre la legislación aplicable a la comercialización de tecnología de biología computacional Adquirir conocimientos en los aspectos legales de la transferencia de material y tecnología entre entidades publicas y privadas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000037/2025-26/RA57> a ns1:LearningResult ;
    ns1:learningResultCode "RA57" ;
    ns1:learningResultDescription "Adquirir conocimiento sobre valorización tecnológica y cadena de valor de la tecnología Adquirir conocimiento sobre aspectos legales de registro de propiedad intelectual(industrial y negociación de acuerdos de explotación entre entidades públicas y/ o privadas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000037/2025-26/RA58> a ns1:LearningResult ;
    ns1:learningResultCode "RA58" ;
    ns1:learningResultDescription "Adquirir conocimiento sobre los aspectos legales y económicos a consideran en la creación de empresas de base tecnológica (EBTs)"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000037/2025-26/RA59> a ns1:LearningResult ;
    ns1:learningResultCode "RA59" ;
    ns1:learningResultDescription "Adquirir conocimiento sobre los aspectos legales y administrativos a considerar en la creación de empresas biotecnológicas y su gestión"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000037/2025-26/RA60> a ns1:LearningResult ;
    ns1:learningResultCode "RA60" ;
    ns1:learningResultDescription "Adquirir conocimiento sobre la gestión del valor económico de la inversión en I+D+i."@es .

