    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/145025002/2025-26/eventSchedule> ;
    schema:description """La asignatura de Elasticidad y Resistencia de materiales tiene como objetivo dotar al alumno de la capacidad de generar un razonamiento crítico, ingenieril y cuantitativo sobre la relación existente entre las cargas aplicadas en una estructura y el estado de esfuerzos y deformaciones que se produce en los sistemas deformables. El alumno tendrá capacidad para formular, aplicar e implementar las ecuaciones de la elasticidad lineal,
las hipótesis de la Resistencia de materiales y las técnicas básicas del análisis estructural."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/joseluis.hernando%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/alberto.badias%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/joseluis.hernando%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/khanhnguyen.gia%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/roman.torres%40upm.es> ;
    schema:name "Elasticidad y Resistencia de Materiales"@es .

