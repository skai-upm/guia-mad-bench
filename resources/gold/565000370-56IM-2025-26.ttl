    schema:name "Oficina Tecnica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000370/2025-26/CE18> a ns1:Competency ;
    ns1:competencyCode "CE18" ;
    ns1:competencyDescription "Conocimientos y capacidades para organizar y gestionar proyectos. Conocer la estructura organizativa y las funciones de una oficina de proyectos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000370/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Conocer y aplicar los conocimientos de ciencias y tecnologías básicas a la práctica de la Ingeniería Industrial"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000370/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Aplicar los conocimientos adquiridos para identificar, formular y resolver problemas en contextos amplios, siendo capaces de integrar los trabajando en equipos multidisciplinares"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000370/2025-26/CG4> a ns1:Competency ;
    ns1:competencyCode "CG4" ;
    ns1:competencyDescription "Comprender el impacto de la ingeniería en el medio ambiente, el desarrollo sostenible de la sociedad y la importancia de trabajaren un entorno profesional y responsable."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000370/2025-26/CG5> a ns1:Competency ;
    ns1:competencyCode "CG5" ;
    ns1:competencyDescription "Comunicar conocimientos y conclusiones, tanto de forma oral como escrita, a públicos especializados y no especializados de modo claro y sin ambigüedades."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000370/2025-26/CG6> a ns1:Competency ;
    ns1:competencyCode "CG6" ;
    ns1:competencyDescription "Poseer las habilidades de aprendizaje que permitan continuar estudiando a lo largo de toda la vida para un desarrollo profesional adecuado"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000370/2025-26/CG7> a ns1:Competency ;
    ns1:competencyCode "CG7" ;
    ns1:competencyDescription "Incorporar las TIC y las tecnologías y herramientas de la Ingeniería Industrial en sus actividades profesionales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000370/2025-26/CG9> a ns1:Competency ;
    ns1:competencyCode "CG9" ;
    ns1:competencyDescription "Organización y planificación de proyectos y equipos humanos. Trabajo en equipo y capacidad de liderazgo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000370/2025-26/RA240> a ns1:LearningResult ;
    ns1:learningResultCode "RA240" ;
    ns1:learningResultDescription "Conocimientos y capacidades para realizar proyectos de legalización de actividades industriales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000370/2025-26/RA241> a ns1:LearningResult ;
    ns1:learningResultCode "RA241" ;
    ns1:learningResultDescription "Conocimientos y capacidades para evaluar diseño de productos y gestionar la calidad en proyectos de fabricación industria"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000370/2025-26/RA242> a ns1:LearningResult ;
    ns1:learningResultCode "RA242" ;
    ns1:learningResultDescription "Conocimientos y capacidades para utilizar herramientas de análisis y mejora de la fabricación industrial"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000370/2025-26/RA243> a ns1:LearningResult ;
    ns1:learningResultCode "RA243" ;
    ns1:learningResultDescription "Conocimientos y capacidades para elaborar el presupuesto y la planificación y programación de proyectos de fabricación industria"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000370/2025-26/RA90> a ns1:LearningResult ;
    ns1:learningResultCode "RA90" ;
    ns1:learningResultDescription "Conocimientos y capacidades para redactar desarrollar y dirigir proyectos de ingeniería industrial."@es .

