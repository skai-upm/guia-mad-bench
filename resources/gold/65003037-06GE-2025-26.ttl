        <https://guia-kg.skai.etsisi.upm.es/resource/rogelio.delavega%40upm.es> ;
    schema:name "Sig y Teledeteccion"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65003037/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Conocer y aplicar conocimientos de ciencias y tecnologías básicas a la práctica de la Ingeniería Geológica."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65003037/2025-26/CG2> a ns1:Competency ;
    ns1:competencyCode "CG2" ;
    ns1:competencyDescription "Poseer capacidad para diseñar, desarrollar, implementar, gestionar y mejorar productos, sistemas y procesos en los distintos ámbitos geológicos, usando técnicas analíticas, computacionales o experimentales apropiadas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65003037/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Aplicar los conocimientos adquiridos para identificar, formular y resolver problemas dentro de contextos amplios y multidisciplinarios, siendo capaces de integrar conocimientos, trabajando en equipos multidisciplinares."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65003037/2025-26/CG5> a ns1:Competency ;
    ns1:competencyCode "CG5" ;
    ns1:competencyDescription "Saber comunicar los conocimientos y conclusiones, tanto de forma oral, escrita y gráfica, a públicos especializados y no especializados de un modo claro y sin ambigüedades."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65003037/2025-26/CG6> a ns1:Competency ;
    ns1:competencyCode "CG6" ;
    ns1:competencyDescription "Poseer habilidades de aprendizaje que permitan continuar estudiando a lo largo de la vida para su adecuado desarrollo profesional."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65003037/2025-26/CG7> a ns1:Competency ;
    ns1:competencyCode "CG7" ;
    ns1:competencyDescription "Incorporar nuevas tecnologías y herramientas de la Ingeniería Geológica en sus actividades profesionales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65003037/2025-26/F14> a ns1:Competency ;
    ns1:competencyCode "F14" ;
    ns1:competencyDescription "Conocimiento de topografía, fotogrametría y cartografía."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65003037/2025-26/F19> a ns1:Competency ;
    ns1:competencyCode "F19" ;
    ns1:competencyDescription "Capacidad de planificación y gestión integral de obras, mediciones, replanteos, control y seguimiento."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65003037/2025-26/F29> a ns1:Competency ;
    ns1:competencyCode "F29" ;
    ns1:competencyDescription "Topografía general y de detalle"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65003037/2025-26/F30> a ns1:Competency ;
    ns1:competencyCode "F30" ;
    ns1:competencyDescription "Elaboración de cartografía temática"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65003037/2025-26/RA206> a ns1:LearningResult ;
    ns1:learningResultCode "RA206" ;
    ns1:learningResultDescription "Comprender las técnicas de adquisición de datos georreferenciados mediante las herramientas de la Teledetección."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65003037/2025-26/RA207> a ns1:LearningResult ;
    ns1:learningResultCode "RA207" ;
    ns1:learningResultDescription "Comprender y aplicar las distintas técnicas de análisis de datos georreferenciados mediante herramientas SIG y de análisis de imágenes."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65003037/2025-26/RA208> a ns1:LearningResult ;
    ns1:learningResultCode "RA208" ;
    ns1:learningResultDescription "Comprender las técnicas de generación de documentos cartográficos digitales y analógicos."@es .

