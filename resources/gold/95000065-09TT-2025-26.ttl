    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/jm.moya%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/p.arroba%40upm.es> ;
    schema:name "Ingenieria de Sistemas Electronicos"@es .

