        <https://guia-kg.skai.etsisi.upm.es/resource/95000065/2025-26/CG9> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/95000065/2025-26/didactic_resource/1>,
