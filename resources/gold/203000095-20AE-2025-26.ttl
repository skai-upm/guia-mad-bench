<https://guia-kg.skai.etsisi.upm.es/resource/203000095/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Tema 1. Conceptos y Metodologías de Planificación del Territorio para el Desarrollo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000095/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Introducción a la Planificación del Territorio. Enfoque territorial del desarrollo. Equilibrio, cohesión y equidad territorial. Desarrollo sostenible y sostenibilidad. Huella ecológica. El territorio en un mundo en cambio: resiliencia territorial Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000095/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "3.1. Herramientas para el diagnóstico (I). Matrices causa-efecto. Marco lógico aplicado a planificación territorial. Diagnóstico de problemas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000095/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "3.2. Fuentes de información territorial. Técnicas de manejo de la información y estimación. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000095/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "3.3. Herramientas para el diagnóstico (II). Mapeo de actores. Herramientas relacionadas con diferentes enfoques de planificación territorial. Herramientas relacionadas con la capacidad institucional. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000095/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "3.4. Herramientas para el análisis territorial. Identificación y definición de unidades. Zonificaciones y áreas de influencia. Capacidad de Acogida. Redes. Participación y análisis territorial. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000095/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "3.5. Herramientas para la planificación en el ámbito urbano Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000095/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "3.6. Herramientas para el trabajo con objetivos. Análisis de coherencia y compatibilidad. Identificación de áreas de intervención. Priorización. Escenarios. Alternativas Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000095/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "3.7. Herramientas para el análisis de intervenciones. Identificación de riesgos y debilidades. Identificación de beneficiarios. Técnicas de presupuestación. Técnicas de escalado de intervenciones. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000095/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "3.8. Herramientas para el diseño de sistemas de seguimiento y evaluación. Evaluación económico-financiera. Evaluación ambiental estratégica. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000095/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Enfoques en los procesos de planificación del territorio. Empoderamiento. Participación en innovación social. Procesos de cambio y transformación social. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000095/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "1.3. El sistema y la estructura territorial. Instrumentos de planificación y ordenación del territorio. El papel del plan y de los procesos de planificación. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000095/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "1.4. Planificación territorial en el contexto urbano. Los retos que supone la urbanización de la pobreza. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000095/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "1.5. Modelos de desarrollo urbano: Top-Down Bottom-Up y Co-producción en el espacio. Fortalezas y debilidades de las distintas estrategias de desarrollo urbano. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000095/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "2. Metodologías de Planificación Territorial"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000095/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "2.1. Metodología de planificación territorial (I). Contexto del proceso de planificación. Análisis del territorio: unidades y redes. Diagnóstico Territorial. Localización de actividades, usos y recursos territoriales. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000095/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "2.2. Metodología de planificación territorial (II). Diseño de intervenciones. Diseño de los instrumentos de gestión de los planes territoriales. Seguimiento y evaluación. Enfoques metodológicos en la Planificación del Territorio. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000095/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "3. Herramientas para la planificación del territorio"@es .

