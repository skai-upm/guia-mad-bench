    ns1:learningResultCode "RA313" ;
    ns1:learningResultDescription "Capacidad de comunicación con otros técnicos que intervendrán en el proceso de revisión y ejecución de la estructura"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35002002/2025-26/RA32> a ns1:LearningResult ;
