    ns1:learningResultCode "RA309" ;
    ns1:learningResultDescription "Capacidad de realizar del proyecto de estructuras a nivel de proyecto de ejecución. Producción de los planos generales y de detalle. Justificación de las soluciones adoptadas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35002002/2025-26/RA31> a ns1:LearningResult ;
    ns1:learningResultCode "RA31" ;
    ns1:learningResultDescription "Conocimiento y resolución de Estructuras de hormigón armado, in situ y prefabricado."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35002002/2025-26/RA310> a ns1:LearningResult ;
    ns1:learningResultCode "RA310" ;
    ns1:learningResultDescription "Capacidad para la caracterización de las acciones sobre las edificaciones convencionales, incluyendo acciones accidentales (incendio y sismo), de acuerdo a la normativa española."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35002002/2025-26/RA311> a ns1:LearningResult ;
