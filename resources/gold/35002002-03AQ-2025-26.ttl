<https://guia-kg.skai.etsisi.upm.es/resource/35002002/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Objetivos del curso. Resultados esperados. Metodología del curso y método de trabajo. Método de evaluación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35002002/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Metodología de proyecto. Marco normativo y fuentes documentales. Procesos de concepción / modelado / validación / justificación y documentación / comunicación. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35002002/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "3.3. Armados de planta, huecos, bordes, enlaces. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35002002/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "4. La estructura en el proyecto 2: Reglas de proporción en estructuras adinteladas Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35002002/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "5. Estrategias de proyecto ante acción horizontal"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35002002/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "5.1. Edificios convencionales Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35002002/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "5.2. Edificios el altura Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35002002/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "6. Estructuras de pisos 2:"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35002002/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "6.1. Proyecto de soportes Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35002002/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "6.2. Proyecto de elementos de cimentación, interacción estructura-terreno Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35002002/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "7. La estructura en el proyecto 3: Trabajo estructural. Cantidad de estructura. Teoremas de Maxwell y Mitchel. Estructura mínima. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35002002/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "8. Proyecto y análisis avanzado 1"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35002002/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Evolución histórica y casos de procesos de diseño o proyecto a lo largo de la historia. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35002002/2025-26/syllabus/20> a ns1:SyllabusItem ;
    ns1:itemIndex 20 ;
    ns1:syllabusDescription "8.1. Situación accidental: incendio; conceptos básicos, procedimiento de cálculo. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35002002/2025-26/syllabus/21> a ns1:SyllabusItem ;
    ns1:itemIndex 21 ;
    ns1:syllabusDescription "8.2. Estructuras espaciales y efectos de anillo. Trazados funiculares en alzado y planta."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35002002/2025-26/syllabus/22> a ns1:SyllabusItem ;
    ns1:itemIndex 22 ;
    ns1:syllabusDescription "8.2.1. Tipología de estructuras de cubierta de medias y grandes luces. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35002002/2025-26/syllabus/23> a ns1:SyllabusItem ;
    ns1:itemIndex 23 ;
    ns1:syllabusDescription "8.3. Rehabilitación / reutilización de edificios antiguos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35002002/2025-26/syllabus/24> a ns1:SyllabusItem ;
    ns1:itemIndex 24 ;
    ns1:syllabusDescription "8.3.1. Daños y carencias habituales Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35002002/2025-26/syllabus/25> a ns1:SyllabusItem ;
    ns1:itemIndex 25 ;
    ns1:syllabusDescription "8.3.2. Soluciones habituales en refuerzos de cimiento, estructura vertical, forjados y cibiertas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35002002/2025-26/syllabus/26> a ns1:SyllabusItem ;
    ns1:itemIndex 26 ;
    ns1:syllabusDescription "9. Proyecto y Análisis Avanzado 2"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35002002/2025-26/syllabus/27> a ns1:SyllabusItem ;
    ns1:itemIndex 27 ;
    ns1:syllabusDescription "9.1. Situación accidental de sismo: conceptos y parámetros básicos Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35002002/2025-26/syllabus/28> a ns1:SyllabusItem ;
    ns1:itemIndex 28 ;
    ns1:syllabusDescription "9.2. Uniones: Concepción y evaluación: Resistencia y rigidez completa o parcial. tipos. Modos de rotura y modelos de análisis. Casos típicos en hormigón, madera, acero o mixtos Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35002002/2025-26/syllabus/29> a ns1:SyllabusItem ;
    ns1:itemIndex 29 ;
    ns1:syllabusDescription "10. Estructuras que cubren gandes luces"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35002002/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "2. La estructura en el proyecto 1: teoría de diseño de estructuras."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35002002/2025-26/syllabus/30> a ns1:SyllabusItem ;
    ns1:itemIndex 30 ;
    ns1:syllabusDescription "10.1. Cargas. Rigidez, estabilidad y arriostramiento: efectos de segundo orden local y global. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35002002/2025-26/syllabus/31> a ns1:SyllabusItem ;
    ns1:itemIndex 31 ;
    ns1:syllabusDescription "10.2. Toma de decisiones para tipos en flexión: correas, vigas, cerchas... módulos... y para sistemas de estabilidad horizontal. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35002002/2025-26/syllabus/32> a ns1:SyllabusItem ;
    ns1:itemIndex 32 ;
    ns1:syllabusDescription "11. La estructura en el proyecto 4: Costes en estructuras a flexión: vigas, arcos y cerchas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35002002/2025-26/syllabus/33> a ns1:SyllabusItem ;
    ns1:itemIndex 33 ;
    ns1:syllabusDescription "12. Edificios de grandes luces 2: estabilidad ante acciones horizontales, arriostrar. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35002002/2025-26/syllabus/34> a ns1:SyllabusItem ;
    ns1:itemIndex 34 ;
    ns1:syllabusDescription "13. Fachada/Estructura. Cargas. Coacciones y compatibilidad de movimientos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35002002/2025-26/syllabus/35> a ns1:SyllabusItem ;
    ns1:itemIndex 35 ;
    ns1:syllabusDescription "14. Estructuras de madera: situación accidental de incendio Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35002002/2025-26/syllabus/36> a ns1:SyllabusItem ;
    ns1:itemIndex 36 ;
    ns1:syllabusDescription "15. Actividades complementarias a la docencia: Talleres, viajes, seminarios o conferencias previstos para la semana de la arquitectura y semana de viajes. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35002002/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "2.1. Materiales estruturales. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35002002/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "2.2. Alcance estructural. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35002002/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "2.3. Peso propio y estabilidad. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35002002/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "3. Estructuras de pisos. Tipos porticados, forjados y losas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35002002/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "3.1. Decisiones sobre tipo, organización, modulación y predimensionado de estructura frente a carga vertical y horizontal. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35002002/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "3.2. Determinación de cargas convencionales, y casos singulares. Hipótesis o combinaciones de carga, envolventes de esfuerzos y proyecto de capacidades. Sin subniveles"@es .

