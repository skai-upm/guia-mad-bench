<https://guia-kg.skai.etsisi.upm.es/resource/43000579> a ns1:Course ;
    ns1:courseType "Optativa"@es ;
    ns1:courseYear 2 ;
    ns1:semester "Cuarto semestre"@es ;
    schema:courseCode 43000579 ;
    schema:hasCourseInstance <https://guia-kg.skai.etsisi.upm.es/resource/43000579/2025-26> ;
    schema:name "Hydropower Generation Scheduling"@en,
        "Programación de la Generación Hidroeléctica"@es ;
    schema:numberOfCredits 4.5 .

<https://guia-kg.skai.etsisi.upm.es/resource/43000579/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/43000579/2025-26/MICCPCE19>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000579/2025-26/MICCPCGP03>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000579/2025-26/MICCPCGP06>,
