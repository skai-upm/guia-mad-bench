    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/43000579/2025-26/didactic_resource/1> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/43000579/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/43000579/2025-26/RA161>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000579/2025-26/RA162> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/43000579/2025-26/syllabus> ;
    ns1:inpersonHours "57 horas y 30 minutos (49.1%)"@es ;
    ns1:numberOfCredits 4.5 ;
    ns1:otherInformation """The course is valid as training credits for the admission to the PhD Programme in Civil Engineering Systems.
SDG 7 Affordable and Clean Energy
SDG 9 Industry, Innovation and Infrastructure
SDG 13 Climate Action"""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "127 horas y 30 minutos"@es ;
    schema:activitiesWorkload "90%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/43000579/2025-26/eventSchedule> ;
    schema:description "The course provide the student with basic knowledge about mathematical programming techniques and dynamic programming and their application to solve hydropower scheduling problems."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/ji.perez%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/i.guisandez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/ji.perez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/manuel.chazarra%40upm.es> ;
    schema:name "Programación de la Generación Hidroeléctica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000579/2025-26/MICCPCE19> a ns1:Competency ;
    ns1:competencyCode "MICCPCE19" ;
    ns1:competencyDescription "Capacidad para abordar y resolver problemas matemáticos avanzados de ingeniería, desde el planteamiento del problema hasta el desarrollo de la formulación y su implementación en un programa de ordenador. En particular, capacidad para formular, programar y aplicar modelos analíticos y numéricos avanzados de cálculo, proyecto, planificación y gestión, así como capacidad para la interpretación de los resultados obtenidos, en el contexto de la ingeniería civil. Incorpora las competencias CB6, CB7 y CB8"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000579/2025-26/MICCPCGP03> a ns1:Competency ;
    ns1:competencyCode "MICCPCGP03" ;
    ns1:competencyDescription "Conocimiento, comprensión y capacidad para aplicar la legislación necesaria en el ejercicio de la profesión de Ingeniero de Caminos, Canales y Puertos. Incorpora las competencias CB6, CB7 y CB8."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000579/2025-26/MICCPCGP06> a ns1:Competency ;
    ns1:competencyCode "MICCPCGP06" ;
    ns1:competencyDescription "Conocimiento para aplicar las capacidades técnicas y gestoras en actividades de I+D+i dentro del ámbito de la ingeniería civil. Incorpora las competencias CB6, CB7 y CB8."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000579/2025-26/MICCPCGP09> a ns1:Competency ;
    ns1:competencyCode "MICCPCGP09" ;
    ns1:competencyDescription "Capacidad para planificar y gestionar recursos hidráulicos y energéticos, incluyendo la gestión integral del ciclo del agua. Incorpora las competencias CB6, CB7 y CB8."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000579/2025-26/MICCPCGP18> a ns1:Competency ;
    ns1:competencyCode "MICCPCGP18" ;
    ns1:competencyDescription "Conocimientos adecuados de los aspectos científicos y tecnológicos de métodos matemáticos, analíticos y numéricos de la ingeniería, mecánica de fluidos, mecánica de medios continuos, cálculo de estructuras, ingeniería del terreno, ingeniería marítima, obras y aprovechamientos hidráulicos y obras lineales. Incorpora las competencias CB6, CB7 y CB8."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000579/2025-26/RA161> a ns1:LearningResult ;
    ns1:learningResultCode "RA161" ;
    ns1:learningResultDescription "The student applies and evaluates advanced models of hydraulic and environmental engineering in the design and operation of hydraulic and energy systems"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000579/2025-26/RA162> a ns1:LearningResult ;
    ns1:learningResultCode "RA162" ;
    ns1:learningResultDescription "The student applies and evaluates advanced techniques for the control and environmental management of hydraulic and energy systems"@es .

