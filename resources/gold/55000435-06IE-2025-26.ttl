    ns1:otherInformation "Por normativa, en las asignaturas de competencias no hay evaluación final mediante un examen convencional. En este caso la calificación final se obtiene mediante los resultados de las actividades individuales de cada alumno y del trabajo en equipo."@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
