<https://guia-kg.skai.etsisi.upm.es/resource/63000152> a ns1:Course ;
    ns1:courseType "Optativa"@es ;
    ns1:courseYear 2 ;
    ns1:semester "Cuarto semestre"@es ;
    schema:courseCode 63000152 ;
    schema:hasCourseInstance <https://guia-kg.skai.etsisi.upm.es/resource/63000152/2025-26> ;
    schema:name "Applied Extractive Metallurgy"@en,
        "Metalurgia Extractiva Aplicada"@es ;
    schema:numberOfCredits 3.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/63000152/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/63000152/2025-26/CG10>,
        <https://guia-kg.skai.etsisi.upm.es/resource/63000152/2025-26/CG19> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/63000152/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/63000152/2025-26/didactic_resource/2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/63000152/2025-26/didactic_resource/3> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/63000152/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/63000152/2025-26/RA50>,
        <https://guia-kg.skai.etsisi.upm.es/resource/63000152/2025-26/RA51>,
        <https://guia-kg.skai.etsisi.upm.es/resource/63000152/2025-26/RA52>,
        <https://guia-kg.skai.etsisi.upm.es/resource/63000152/2025-26/RA53>,
        <https://guia-kg.skai.etsisi.upm.es/resource/63000152/2025-26/RA54> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/63000152/2025-26/syllabus> ;
    ns1:inpersonHours "36 horas (46.2%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation """En esta asignatura se trabajan los siguientes Objetivos de Desarrollo Sostenible
ODS6: Garantizar la disponibilidad y la gestión sostenible del agua y el saneamiento para todos.
ODS9: Desarrollar infraestructuras resilientes, promover la industrialización inclusiva y sostenible, y fomentar la innovación.
ODS12: Garantizar las pautas de consumo y de producción sostenibles."""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "36 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/63000152/2025-26/eventSchedule> ;
    schema:description """Esta asignatura tiene como objetivos
1- Conocer los procesos de obtención de metales (acero, aluminio, cobre, zinc, plomo, níquel y oro)
2. Conocer los fundamentos del reciclaje de metales
3. Adquirir conocimientos prácticos en metalurgia extractiva"""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/inigo.rbustinza%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/anamaria.mendez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/inigo.rbustinza%40upm.es> ;
    schema:name "Metalurgia Extractiva Aplicada"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000152/2025-26/CG10> a ns1:Competency ;
    ns1:competencyCode "CG10" ;
    ns1:competencyDescription "Capacidad para planificar, diseñar y gestionar instalaciones de beneficio de recursos minerales y plantas metalúrgicas, siderúrgicas e industrias de materiales de construcción"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000152/2025-26/CG19> a ns1:Competency ;
    ns1:competencyCode "CG19" ;
    ns1:competencyDescription "Capacidad para planificar, diseñar y gestionar plantas de tratamiento de minerales metalúrgicos y siderúrgicos e instalaciones de procesado de materiales metálicos, cerámicos, sinterizados, refractarios y otros."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000152/2025-26/RA50> a ns1:LearningResult ;
    ns1:learningResultCode "RA50" ;
    ns1:learningResultDescription "Conocer las técnicas avanzadas en el tratamiento de minerales y el procesado de materiales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000152/2025-26/RA51> a ns1:LearningResult ;
    ns1:learningResultCode "RA51" ;
    ns1:learningResultDescription "Comprender la interrelación de las distintas etapas del proceso siderometalúrgico en el diseño de plantas metalúrgicas y siderúrgicas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000152/2025-26/RA52> a ns1:LearningResult ;
    ns1:learningResultCode "RA52" ;
    ns1:learningResultDescription "Aplicar las técnicas de gestión alas plantas siderometalúrgicas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000152/2025-26/RA53> a ns1:LearningResult ;
    ns1:learningResultCode "RA53" ;
    ns1:learningResultDescription "Conocer los criterios de selección de materiales y de sus procesos de fabricación y procesado"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000152/2025-26/RA54> a ns1:LearningResult ;
    ns1:learningResultCode "RA54" ;
    ns1:learningResultDescription "Aplicar las técnicas de planificación, diseño y gestión a instalaciones de procesado de materiales"@es .

