        <https://guia-kg.skai.etsisi.upm.es/resource/luis.matute%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/miguel.ortega%40upm.es> ;
    schema:name "Diseño y Análisis de Estructuras Mixtas de Hormigón y Acero"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000442/2025-26/CB10> a ns1:Competency ;
    ns1:competencyCode "CB10" ;
    ns1:competencyDescription "Que los estudiantes posean las habilidades de aprendizaje que les permitan continuar estudiando de un modo que habrá de ser en gran medida autodirigido o autónomo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000442/2025-26/CB6> a ns1:Competency ;
    ns1:competencyCode "CB6" ;
    ns1:competencyDescription "Poseer y comprender conocimientos que aporten una base u oportunidad de ser originales en el desarrollo y/o aplicación de ideas, a menudo en un contexto de investigación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000442/2025-26/CE11> a ns1:Competency ;
    ns1:competencyCode "CE11" ;
    ns1:competencyDescription "Capacidad para el ejercicio profesional de alta especialización o para la investigación predoctoral mediante la utilización de recursos de modelización predictiva en Análisis y diseño de puentes."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000442/2025-26/RA1> a ns1:LearningResult ;
    ns1:learningResultCode "RA1" ;
    ns1:learningResultDescription "Utiliza con eficacia, autonomía y polivalencia recursos de modelización predictiva en la temática de la materia"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000442/2025-26/RA10> a ns1:LearningResult ;
    ns1:learningResultCode "RA10" ;
    ns1:learningResultDescription "Interioriza los principios y técnicas de organización y dirección de equipos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000442/2025-26/RA11> a ns1:LearningResult ;
    ns1:learningResultCode "RA11" ;
    ns1:learningResultDescription "Realiza una exploración bibliográfica y un plan de trabajo justificado del TFM haciendo uso en particular del conocimiento adquirido sobre normativa europea e internacional de ingeniería estructural, geotécnica y de materiales estructurales para proyecto, construcción, conservación y evaluación técnica Interioriza los principios y técnicas de organización y dirección de equipos Interioriza los principios de deontología profesional de ingeniería civil"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000442/2025-26/RA12> a ns1:LearningResult ;
    ns1:learningResultCode "RA12" ;
    ns1:learningResultDescription "Realiza individualmente un proyecto o una preinvestigación originales de Ingeniería estructural, geotécnica o de materiales estructurales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000442/2025-26/RA15> a ns1:LearningResult ;
    ns1:learningResultCode "RA15" ;
    ns1:learningResultDescription "Aplica normativa europea e internacional de ingeniería estructural, geotécnica y de materiales estructurales en proyecto, construcción, conservación y evaluación técnica Interioriza los principios de deontología profesional de ingeniería civil"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000442/2025-26/RA16> a ns1:LearningResult ;
    ns1:learningResultCode "RA16" ;
    ns1:learningResultDescription "conocer los modelos teóricos de comportamiento mecánico en rotura de mayor interés aplicables a los materiales estructurales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000442/2025-26/RA18> a ns1:LearningResult ;
    ns1:learningResultCode "RA18" ;
    ns1:learningResultDescription "saber aplicar los conocimientos anteriores en diseño, construcción y mantenimiento de estructuras"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000442/2025-26/RA2> a ns1:LearningResult ;
    ns1:learningResultCode "RA2" ;
    ns1:learningResultDescription "Presenta comunicaciones orales, escritas y gráficas, estructurada y argumentadamente, en lengua española e inglesa"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000442/2025-26/RA20> a ns1:LearningResult ;
    ns1:learningResultCode "RA20" ;
    ns1:learningResultDescription "Conoce las causas de no linealidad geométrica en estructuras y los métodos de cálculo en los distintos niveles."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000442/2025-26/RA21> a ns1:LearningResult ;
    ns1:learningResultCode "RA21" ;
    ns1:learningResultDescription "Conoce las causas de no linealidad debida al material en estructuras, sus leyes constitutivas y los métodos de cálculo estructural aplicables."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000442/2025-26/RA24> a ns1:LearningResult ;
    ns1:learningResultCode "RA24" ;
    ns1:learningResultDescription "Conoce los métodos numéricos para resolver los cálculos estructurales no lineales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000442/2025-26/RA25> a ns1:LearningResult ;
    ns1:learningResultCode "RA25" ;
    ns1:learningResultDescription "Conoce el formato de seguridad necesario para poder realizar comprobaciones estructurales mediante cálculos no lineales en estructuras reales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000442/2025-26/RA27> a ns1:LearningResult ;
    ns1:learningResultCode "RA27" ;
    ns1:learningResultDescription "Aplica los métodos y modelos de cálculo de estructuras para el análisis del comportamiento de los puentes y para la comprobación de su seguridad"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000442/2025-26/RA28> a ns1:LearningResult ;
    ns1:learningResultCode "RA28" ;
    ns1:learningResultDescription "Plantea el método de construcción de un puentePlantea el método de construcción de un puente"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000442/2025-26/RA30> a ns1:LearningResult ;
    ns1:learningResultCode "RA30" ;
    ns1:learningResultDescription "Plantea el método de construcción de un puente"@es .

