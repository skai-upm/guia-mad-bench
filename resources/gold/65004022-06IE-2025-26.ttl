    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/65004022/2025-26/eventSchedule> ;
    schema:description "Asignatura multidisciplinar en la que se tratan diversos temas: eficiencia eléctrica, eficiencia térmica, aplicaciones tecnológicas de alta eficiencia energéticas. El objetivo es que el alumno adquiera una visión global de los aspectos que se tratarían en una auditoría energética y que sea capaz de realizar el cálculo de instalaciones teniendo en cuenta los principios de eficiencia y ahorro energético."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/vanesa.valino%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/david.nsimavilla%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/pablo.reina%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/vanesa.valino%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/vazquez.martinez%40upm.es> ;
    schema:name "Eficiencia y Ahorro Energetico"@es .

