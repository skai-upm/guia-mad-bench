    ns1:numberOfCredits 6.0 ;
    ns1:otherInformation "La asignatura tiene en cuenta y trabaja para el cumplimiento de los Objetivos de Desarrollo Sostenible (ODS) de Naciones Unidas. En concreto, se relaciona con el ODS2 (Hambre cero), ODS3 (Salud y bienestar), ODS4 (educación de calidad), ODS5 (Igualdad de género), ODS6 (Agua limpia y saneamiento), ODS8 (Trabajo decente y crecimiento económico), ODS12 (Producción y consumo responsables), ODS13 (Acción por el clima) y ODS15 (Vida de ecosistemas terrestres)."@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "109 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/135004503/2025-26/eventSchedule> ;
    schema:description "La asignatura pretende que los estudiantes conozcan la razón de ser, la composición, la estructura y el funcionamiento de los principales tipos de pastos (herbáceos, arbustivos y arbóreos) y sistemas agroforestales para poder planificar y llevar a cabo su gestión de forma racional, eficiente y sustentable."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/ramon.perea%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/alfonso.sanmiguel%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/marta.pelaez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/ramon.perea%40upm.es> ;
    schema:name "Pascicultura y Sistemas Agroforestales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004503/2025-26/CG02> a ns1:Competency ;
    ns1:competencyCode "CG02" ;
    ns1:competencyDescription "Capacidad para analizar la estructura y función ecológica de los sistemas y recursos forestales, incluyendo los paisajes."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004503/2025-26/CG08> a ns1:Competency ;
    ns1:competencyCode "CG08" ;
    ns1:competencyDescription "Capacidad para gestionar y proteger las poblaciones de fauna forestal, con especial énfasis en las de carácter cinegético y piscícola."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004503/2025-26/CT9> a ns1:Competency ;
    ns1:competencyCode "CT9" ;
    ns1:competencyDescription "Utilización de TICs para el trabajo cooperativo y trabajo en equipo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004503/2025-26/RA150> a ns1:LearningResult ;
    ns1:learningResultCode "RA150" ;
    ns1:learningResultDescription "Conocimiento, comprensión y capacidad de utilización de conceptos, ideas, terminología propios de la Pascicultura y los Sistemas Forestales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004503/2025-26/RA151> a ns1:LearningResult ;
    ns1:learningResultCode "RA151" ;
    ns1:learningResultDescription "Conocimiento y comprensión de la historia y la situación actual (natural, socioeconómica y política) de los pastos y sistemas agroforestales en España, Europa y el Mundo, así como de su oferta de servicios (abastecimiento, regulación y culturales) y sus pautas básicas de gestión"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004503/2025-26/RA152> a ns1:LearningResult ;
    ns1:learningResultCode "RA152" ;
    ns1:learningResultDescription "Capacidad de caracterización y diagnóstico de pastos y sistemas agroforestales: inventariación, interpretación y evaluación de comunidades vegetales y animales (ganado y fauna silvestre) y resolución de problemas prácticos de gestión, tanto de forma individual como en equipo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004503/2025-26/RA433> a ns1:LearningResult ;
    ns1:learningResultCode "RA433" ;
    ns1:learningResultDescription "Conocer y comprender la utilidad de conceptos, ideas y terminología propios de la Pascicultura y los Sistemas Agroforestales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004503/2025-26/RA434> a ns1:LearningResult ;
    ns1:learningResultCode "RA434" ;
    ns1:learningResultDescription "Conocer y comprender la historia y la situación actual (natural, socioeconómica y política) de los pastos y sistemas agroforestales en España, Europa y el Mundo, así como de su oferta de servicios (abastecimiento, regulación y culturales) y sus pautas básicas de gestion"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004503/2025-26/RA435> a ns1:LearningResult ;
    ns1:learningResultCode "RA435" ;
    ns1:learningResultDescription "Tener capacidad de caracterización y diagnóstico de pastos y sistemas agroforestales: inventariación, interpretación y evaluación de comunidades vegetales y animales (ganado y fauna silvestre) y resolución de problemas prácticos de gestión, tanto de forma individual como en equipo."@es .

