    ns1:competencyCode "CM19.1" ;
    ns1:competencyDescription "Capacidad para aplicar los conocimientos de materiales de construcción en sistemas estructurales. Conocimiento de la relación entre la estructura de los materiales y las propiedades mecánicas que de ella se derivan."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001202/2025-26/CM19.2> a ns1:Competency ;
    ns1:competencyCode "CM19.2" ;
    ns1:competencyDescription "Comprensión de los mecanismos físico"@es .

