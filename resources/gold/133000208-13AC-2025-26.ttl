<https://guia-kg.skai.etsisi.upm.es/resource/133000208/2025-26/CB06> a ns1:Competency ;
    ns1:competencyCode "CB06" ;
    ns1:competencyDescription "Poseer y comprender conocimientos que aporten una base u oportunidad de ser originales en el desarrollo y/o aplicación de ideas, a menudo en un contexto de investigación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000208/2025-26/CB08> a ns1:Competency ;
    ns1:competencyCode "CB08" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de integrar conocimientos y enfrentarse a la complejidad de formular juicios a partir de una información que, siendo incompleta o limitada, incluya reflexiones sobre las responsabilidades sociales y éticas vinculadas a la aplicación de sus conocimientos y juicios"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000208/2025-26/CB09> a ns1:Competency ;
    ns1:competencyCode "CB09" ;
    ns1:competencyDescription "Que los estudiantes sepan comunicar sus conclusiones y los conocimientos y razones últimas que las sustentan a públicos especializados y no especializados de un modo claro y sin ambigüedades"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000208/2025-26/CB10> a ns1:Competency ;
    ns1:competencyCode "CB10" ;
    ns1:competencyDescription "Que los estudiantes posean las habilidades de aprendizaje que les permitan continuar estudiando de un modo que habrá de ser en gran medida autodirigido o autónomo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000208/2025-26/CE06> a ns1:Competency ;
    ns1:competencyCode "CE06" ;
    ns1:competencyDescription "El alumno será capaz de analizar proyectos de inversión y realizar modelos de negocio en el ámbito de la economía circular."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000208/2025-26/CE07> a ns1:Competency ;
    ns1:competencyCode "CE07" ;
    ns1:competencyDescription "El alumno adquirirá la capacidad del liderazgo de equipos y la toma de decisiones en la organización."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000208/2025-26/CG01> a ns1:Competency ;
    ns1:competencyCode "CG01" ;
    ns1:competencyDescription "El alumno tendrá capacidad para analizar y evaluar las implicaciones de implantar un modelo de economía circular desde el punto de vista normativo, económico, industrial y tecnológico."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000208/2025-26/CT02> a ns1:Competency ;
    ns1:competencyCode "CT02" ;
    ns1:competencyDescription "El alumno tendrá capacidad para utilizar herramientas de gestión administrativa y económica de los recursos humanos, materiales y financieros en la propuesta y ejecución de proyectos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000208/2025-26/CT03> a ns1:Competency ;
    ns1:competencyCode "CT03" ;
    ns1:competencyDescription "El alumno tendrá capacidad para gestionar la información procedente de diversas fuentes, valorando su relevancia, fiabilidad y pertinencia para un propósito determinado, analizándola y organizándola."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000208/2025-26/CT05> a ns1:Competency ;
    ns1:competencyCode "CT05" ;
    ns1:competencyDescription "El alumno tendrá capacidad para planificar y organizar trabajos y proyectos, estableciendo los objetivos y la programación, asignando tareas y recursos y responsabilizándose de la correcta toma de decisiones."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000208/2025-26/CT07> a ns1:Competency ;
    ns1:competencyCode "CT07" ;
    ns1:competencyDescription "El alumno tendrá capacidad para utilizar la lengua inglesa para la comunicación oral y escrita a nivel avanzado en entornos académicos y profesionales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000208/2025-26/RA29> a ns1:LearningResult ;
    ns1:learningResultCode "RA29" ;
    ns1:learningResultDescription "Desarrollar un plan de identidad digital relevante, incluyendo objetivos a corto y largo plazo./ Develop a relevant digital identity plan, including short and long"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000208/2025-26/RA30> a ns1:LearningResult ;
    ns1:learningResultCode "RA30" ;
    ns1:learningResultDescription "Evaluar el entorno personal de aprendizaje propio para fines académicos y profesionales./ Evaluate the own current personal learning environment for professional and training purposes."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000208/2025-26/RA31> a ns1:LearningResult ;
    ns1:learningResultCode "RA31" ;
    ns1:learningResultDescription "Desarrollar un entorno personal de aprendizaje relevante, incluyendo TICs y recursos educativos en abierto, para la formación continua en el ámbito profesional./ Develop a relevant personal learning environment (PLE), including ICTs and open educational resources, for the continuous professional development."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000208/2025-26/RA32> a ns1:LearningResult ;
    ns1:learningResultCode "RA32" ;
    ns1:learningResultDescription "Aplicar buenas prácticas para presentaciones orales./ Apply good practices for oral presentations."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000208/2025-26/RA33> a ns1:LearningResult ;
    ns1:learningResultCode "RA33" ;
    ns1:learningResultDescription "Seleccionar recursos educativos en abierto de calidad y pertinentes, para el aprendizaje para toda la vida en economía circular./ Select pertinent and quality open educational resources for lifelong learning purposes on a circular economy."@es .

