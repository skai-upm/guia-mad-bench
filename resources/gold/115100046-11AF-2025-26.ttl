<https://guia-kg.skai.etsisi.upm.es/resource/115100046/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Concepto y clasificación de las lesiones."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100046/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. - Tipos de patologías traumáticas deportivas. - Traumatismos directos, indirectos y por sobrecarga, peculiaridadesy evolución general. - El accidente deportivo. - Características de las lesiones específicas de cada deporte. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100046/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "6. Lesiones tendinosas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100046/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "6.1. - Tipos de patologías: tendinitis, rotura parcial y rotura total. - Luxaciones tendinosas. - Prevención durante la vida activa deportiva y en la edad adulta. - Enfermedad de las inserciones y su relación con el crecimiento. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100046/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "7. Lesiones articulares."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100046/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "7.1. - Lesiones ligamentosas: clasificación y evolución. Concepto de inestabilidad y laxitud articular. - Lesiones condrales y osteocondrales: condromalacias y osteocondritis, fracturas osteocondrales. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100046/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "7.2. - Lesiones meniscales, generalidades. - Bursitis. - Luxaciones. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100046/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "8. Lesiones óseas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100046/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "8.1. - Fracturas. Clasificación. - Fracturas por sobrecarga. - Periostitis. - Arrancamientos óseos. - Patologías del crecimiento Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100046/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "9. Patologías del pie en el deporte."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100046/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "9.1. - Hallux rígidus. Hallux valgus. - Talalgias: espolón calcáneo, enfermedad de Haglund, bursitis. Prevención. - Tendinitis, fascitis plantares. - Fracturas de la cola del 5ª metatarsiano. - Sesamoiditis de la 1ª MTF. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100046/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "9.2. - Metatarsalgias: prevención deportiva. - Dedos en garra y en maza. - Patologías de las uñas del pié, uña incarnata, hematoma subungueal. - El uso del calzado deportivo y su relación con las patologías del pie, protecciones. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100046/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "2. Tratamiento médico de las lesiones."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100046/2025-26/syllabus/20> a ns1:SyllabusItem ;
    ns1:itemIndex 20 ;
    ns1:syllabusDescription "10. Patologías del tobillo en el deporte."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100046/2025-26/syllabus/21> a ns1:SyllabusItem ;
    ns1:itemIndex 21 ;
    ns1:syllabusDescription "10.1. - Patologías articulares, esguinces ligamentosos y patologías capsulares de la TPA y subastragalina. - Inestabilidades agudas y crónicas, prevención de recaídas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100046/2025-26/syllabus/22> a ns1:SyllabusItem ;
    ns1:itemIndex 22 ;
    ns1:syllabusDescription "10.2. - Patologías tendinosas. Tendón de Aquiles, clasificación, tratamiento y reentreno al esfuerzo. Tibial posterior y anterior, tipos de patologías. Tendones peroneos, prevención, patologías, luxaciones tendones extensores y flexores. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100046/2025-26/syllabus/23> a ns1:SyllabusItem ;
    ns1:itemIndex 23 ;
    ns1:syllabusDescription "10.3. Artrosis postraumática, tolerancia para la actividad física y su prevención. - Calcificaciones periarticulares postraumáticas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100046/2025-26/syllabus/24> a ns1:SyllabusItem ;
    ns1:itemIndex 24 ;
    ns1:syllabusDescription "11. Patologías de la pierna en el deporte."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100046/2025-26/syllabus/25> a ns1:SyllabusItem ;
    ns1:itemIndex 25 ;
    ns1:syllabusDescription "11.1. - Síndromes compartimentales. - Periostitis. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100046/2025-26/syllabus/26> a ns1:SyllabusItem ;
    ns1:itemIndex 26 ;
    ns1:syllabusDescription "12. Patologías de la rodilla en el deporte."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100046/2025-26/syllabus/27> a ns1:SyllabusItem ;
    ns1:itemIndex 27 ;
    ns1:syllabusDescription "12.1. - Patologías ligamentosas, LLI, LLE, LCA y LCP. Inestabilidades combinadas. Inestabilidades agudas y crónicas, tolerancia para el ejercicio. Rodilla catastrófica. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100046/2025-26/syllabus/28> a ns1:SyllabusItem ;
    ns1:itemIndex 28 ;
    ns1:syllabusDescription "12.2. - Patologías meniscales. Sintomatología. Tratamiento y tolerancia. Secuelas de las meniscectomías a corto y a largo plazo. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100046/2025-26/syllabus/29> a ns1:SyllabusItem ;
    ns1:itemIndex 29 ;
    ns1:syllabusDescription "12.3. - Patologías del aparato extensor, rótula, tendón cuadricipital y rotuliano, relación con el cuadriceps. Condromalacias rotulianas. Rodilla del saltador, enfermedad de Osgood- Schlatter, enfermedad de Sinding-Larsen-Johansson. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100046/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "2.1. - Tratamientos médicos en los accidentes deportivos. - Tratamiento de urgencia - Tipos de tratamientos: médico, ortopédico, funcional y quirúrgico - Recidivas. - Secuelas por la inmovilización prolongada. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100046/2025-26/syllabus/30> a ns1:SyllabusItem ;
    ns1:itemIndex 30 ;
    ns1:syllabusDescription "12.4. - Patologías condrales. Osteocondritis disecante. Condromalacias, tipos y evolución. - Artrosis postraumática, tolerancia para el ejercicio. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100046/2025-26/syllabus/31> a ns1:SyllabusItem ;
    ns1:itemIndex 31 ;
    ns1:syllabusDescription "12.5. - Patologías de las inserciones y de las partes blandas. Rodilla del corredor. Bursitis prerotuliana. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100046/2025-26/syllabus/32> a ns1:SyllabusItem ;
    ns1:itemIndex 32 ;
    ns1:syllabusDescription "13. Patologías del muslo en el deporte."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100046/2025-26/syllabus/33> a ns1:SyllabusItem ;
    ns1:itemIndex 33 ;
    ns1:syllabusDescription "13.1. - Contusiones, lesiones musculares. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100046/2025-26/syllabus/34> a ns1:SyllabusItem ;
    ns1:itemIndex 34 ;
    ns1:syllabusDescription "14. Patologías de la cintura pélvica en el deporte."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100046/2025-26/syllabus/35> a ns1:SyllabusItem ;
    ns1:itemIndex 35 ;
    ns1:syllabusDescription "14.1. Trocanteritis- Pubialgias, causas, diagnóstico, prevención y tratamiento. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100046/2025-26/syllabus/36> a ns1:SyllabusItem ;
    ns1:itemIndex 36 ;
    ns1:syllabusDescription "15. Patologías de la columna en el deporte."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100046/2025-26/syllabus/37> a ns1:SyllabusItem ;
    ns1:itemIndex 37 ;
    ns1:syllabusDescription "15.1. - Lumbalgias, hiperlordosis lumbar, espóndilolisis y espóndilolistesis, - Hernias discales, prevención y tolerancia. - Dorsalgias y cervicalgias. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100046/2025-26/syllabus/38> a ns1:SyllabusItem ;
    ns1:itemIndex 38 ;
    ns1:syllabusDescription "16. Patologías del tórax y del abdomen en el deporte."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100046/2025-26/syllabus/39> a ns1:SyllabusItem ;
    ns1:itemIndex 39 ;
    ns1:syllabusDescription "16.1. - Fracturas y contusiones costales. - Traumatismos abdominales. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100046/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "3. Tratamiento físico de las lesiones."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100046/2025-26/syllabus/40> a ns1:SyllabusItem ;
    ns1:itemIndex 40 ;
    ns1:syllabusDescription "17. Patologías de la cintura escapular en el deporte."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100046/2025-26/syllabus/41> a ns1:SyllabusItem ;
    ns1:itemIndex 41 ;
    ns1:syllabusDescription "17.1. - Fracturas de clavícula. - Patologías de la articulación acromio-clavicular, clasificación y tratamiento. - Patologías de la articulación externo-clavicular. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100046/2025-26/syllabus/42> a ns1:SyllabusItem ;
    ns1:itemIndex 42 ;
    ns1:syllabusDescription "17.2. - Hombro: luxaciones y luxaciones recidivantes. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100046/2025-26/syllabus/43> a ns1:SyllabusItem ;
    ns1:itemIndex 43 ;
    ns1:syllabusDescription "17.3. - Síndrome de compresión subacromial, tendinitis del manguito de los rotadores, rotura y calcificación del tendón del supraespinoso. - Bursitis subacromiodeltoidea. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100046/2025-26/syllabus/44> a ns1:SyllabusItem ;
    ns1:itemIndex 44 ;
    ns1:syllabusDescription "17.4. - Tendinitis del tendón largo del bíceps braquial. - Roturas del bíceps braquial. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100046/2025-26/syllabus/45> a ns1:SyllabusItem ;
    ns1:itemIndex 45 ;
    ns1:syllabusDescription "18. Patologías del codo en el deporte."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100046/2025-26/syllabus/46> a ns1:SyllabusItem ;
    ns1:itemIndex 46 ;
    ns1:syllabusDescription "18.1. - Luxaciones y fracturas en el deporte. - Patologías por sobrecarga: codo de tenis, codo de golf. - Bursitis olecraneana. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100046/2025-26/syllabus/47> a ns1:SyllabusItem ;
    ns1:itemIndex 47 ;
    ns1:syllabusDescription "19. Patologías de la muñeca y de la mano en el deporte."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100046/2025-26/syllabus/48> a ns1:SyllabusItem ;
    ns1:itemIndex 48 ;
    ns1:syllabusDescription "19.1. - Fractura de escafoides carpiano.- Rotura ligamentosa e inestabilidad de la articulación MTF del pulgar. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100046/2025-26/syllabus/49> a ns1:SyllabusItem ;
    ns1:itemIndex 49 ;
    ns1:syllabusDescription "19.2. Artritis traumáticas y luxaciones de las MCF, IFP y de las IFD, prevención. -Tendinitis de los tendones extensores. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100046/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "3.1. - Generalidades sobre los tratamientos físicos: frío, calor. Electroterapia, hidroterapia. - Vendajes funcionales, indicaciones. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100046/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "4. Función del preparador físico."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100046/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "4.1. - Responsabilidades del preparador físico en las recurrencia lesional. - Relación con el médico, fisioterapeuta y psicólogo, tratamientos en equipos interdisciplinarios. Sin subniveles"@es .

