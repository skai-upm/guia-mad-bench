<https://guia-kg.skai.etsisi.upm.es/resource/55000301> a ns1:Course ;
    ns1:courseType "Optativa"@es ;
    ns1:courseYear 3 ;
    ns1:semester "Sexto semestre"@es ;
    schema:courseCode 55000301 ;
    schema:hasCourseInstance <https://guia-kg.skai.etsisi.upm.es/resource/55000301/2025-26> ;
    schema:name "Deformable Bodies Mechanics"@en,
        "Mecanica del Solido Deformable"@es ;
    schema:numberOfCredits 6.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/55000301/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/55000301/2025-26/CE28C>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55000301/2025-26/CG1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55000301/2025-26/CG5>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55000301/2025-26/CG6> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/55000301/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55000301/2025-26/didactic_resource/2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55000301/2025-26/didactic_resource/3> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/55000301/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/55000301/2025-26/RA51>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55000301/2025-26/RA52>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55000301/2025-26/RA53>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55000301/2025-26/RA54> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/55000301/2025-26/syllabus> ;
    ns1:inpersonHours "65 horas (41.7%)"@es ;
    ns1:numberOfCredits 6.0 ;
    ns1:otherInformation "Esta asignatura no se volverá a impartir pues se ha cerrado la especialidad de grado donde se impartía. No hay ningún alumno suspendido así que no hay necesidad de volver a evaluarla"@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "65 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/55000301/2025-26/eventSchedule> ;
    schema:description "Estudio de las fuerzas, deformaciones, y principios energéticos que sirven para modelar el comportamiento de sólidos deformables. Además, se estudiarán los principales modelos constitutivos empleados en mecánica de sólidos (elasticidad, viscoelasticidad, plasticidad) así como la teoría de mecánica de la fractura y la fatiga de metales. La asignatura incluirá la descripción teórica de estos modelos, la realización de ejercicios"@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/david.portillo%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/david.portillo%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/ignacio.romero%40upm.es> ;
    schema:name "Mecanica del Solido Deformable"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000301/2025-26/CE28C> a ns1:Competency ;
    ns1:competencyCode "CE28C" ;
    ns1:competencyDescription "Conocimientos y capacidades para aplicar los fundamentos de la elasticidad y resistencia de materiales al comportamiento de sÃ³lidos reales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000301/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Conocer y aplicar conocimientos de ciencias y tecnologías básicas a la práctica de la Ingeniería Industrial."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000301/2025-26/CG5> a ns1:Competency ;
    ns1:competencyCode "CG5" ;
    ns1:competencyDescription "Saber comunicar los conocimientos y conclusiones, de forma oral, escrita y gráfica, a públicos especializados y no especializados de un modo claro y sin ambigüedades."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000301/2025-26/CG6> a ns1:Competency ;
    ns1:competencyCode "CG6" ;
    ns1:competencyDescription "Poseer habilidades de aprendizaje que permitan continuar estudiando a lo largo de la vida para su adecuado desarrollo profesional."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000301/2025-26/RA51> a ns1:LearningResult ;
    ns1:learningResultCode "RA51" ;
    ns1:learningResultDescription "Analizar el comportamiento mecánico de elementos de estructuras y máquinas bajo condiciones generales de carga y diferentes comportamientos del material."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000301/2025-26/RA52> a ns1:LearningResult ;
    ns1:learningResultCode "RA52" ;
    ns1:learningResultDescription "Optimizar los diseños mecánicos y evaluar de forma precisa los márgenes de seguridad frente a las distintas modalidades de fallo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000301/2025-26/RA53> a ns1:LearningResult ;
    ns1:learningResultCode "RA53" ;
    ns1:learningResultDescription "Comprender los procesos de deformación en el conformado en frío de los materiales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000301/2025-26/RA54> a ns1:LearningResult ;
    ns1:learningResultCode "RA54" ;
    ns1:learningResultDescription "Utilizar las técnicas numéricas y experimentales de análisis de tensiones."@es .

