        <https://guia-kg.skai.etsisi.upm.es/resource/123000711/2025-26/C13>,
        <https://guia-kg.skai.etsisi.upm.es/resource/123000711/2025-26/C6>,
        <https://guia-kg.skai.etsisi.upm.es/resource/123000711/2025-26/C7>,
        <https://guia-kg.skai.etsisi.upm.es/resource/123000711/2025-26/C8>,
        <https://guia-kg.skai.etsisi.upm.es/resource/123000711/2025-26/K1>,
