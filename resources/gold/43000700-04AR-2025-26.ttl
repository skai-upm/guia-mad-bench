        <https://guia-kg.skai.etsisi.upm.es/resource/43000700/2025-26/syllabus/5>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000700/2025-26/syllabus/6>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000700/2025-26/syllabus/7>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000700/2025-26/syllabus/8>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000700/2025-26/syllabus/9> .

<https://guia-kg.skai.etsisi.upm.es/resource/43000700/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Introducción al Cambio Climático y los recursos hídricos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000700/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Cambio climático: causas, variabilidad y tendencias observadas. Impactos generales en los recursos hídricos. Modelos climáticos. Herramientas de monitoreo del cambio climático en la gestión del agua. Marco internacional. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000700/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "3.1.4. Reglas de gestión. Modelación de sistemas de RRHH y evaluación del impacto del CC. Uso de IA Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000700/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "3.2. Adaptación, mitigación del impacto del CC sobre los recursos hídricos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000700/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "3.2.1. Medidas estructurales y no estructurales, globales y locales, transitorias y permanentes. Sostenibilidad y resiliencia de los sistemas de RRHH. Optimización de sistemas. Uso de IA Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000700/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "4. Evaluación del efecto del CC sobre las sequías (presente y futuro), adaptación y mitigación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000700/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "4.1. Evaluación del efecto del CC en las sequías"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000700/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "4.1.1. Introducción. Tipos y dinámicas de las Sequías. Identificación y caracterización de las sequías. Índices de sequía. Diferencia entre sequía, escasez hídrica y déficit de suministro Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000700/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "4.1.2. Evaluación del efecto del CC en las sequías y en la disponibilidad de agua. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000700/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "4.1.3. Proyecciones estacionales y efecto en los sistemas de RRHH. Enfoque probabilístico. Uso de IA Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000700/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "4.2. Medidas de mitigación y adaptación al déficit hídrico."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000700/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "4.2.1. Medidas estructurales y no estructurales, Planes especiales de sequía. Buenas prácticas Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000700/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "2. Adquisición y procesamiento de datos hidrometeorológicos, proyecciones climáticas, variables físicas y antropogénicas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000700/2025-26/syllabus/20> a ns1:SyllabusItem ;
    ns1:itemIndex 20 ;
    ns1:syllabusDescription "5. Evaluación del efecto de cambio climático en las inundaciones (presente y futuro), adaptación y mitigación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000700/2025-26/syllabus/21> a ns1:SyllabusItem ;
    ns1:itemIndex 21 ;
    ns1:syllabusDescription "5.1. Evaluación del efecto del CC en las inundaciones"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000700/2025-26/syllabus/22> a ns1:SyllabusItem ;
    ns1:itemIndex 22 ;
    ns1:syllabusDescription "5.1.1. Introducción. Definiciones, tipos de inundaciones. Caracterización de los eventos extremos (presente y futuro) utilizando series espacio-temporales de las principales variables. Análisis de P y Q máximos, hidrogramas y series completas Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000700/2025-26/syllabus/23> a ns1:SyllabusItem ;
    ns1:itemIndex 23 ;
    ns1:syllabusDescription "5.1.2. Análisis estadístico y probabilístico de resultados espacio-temporales. Análisis local y regional. Efecto del CC en las zonas inundables y en la seguridad hidrológica de infraestructuras hidráulicas, análisis de riesgo. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000700/2025-26/syllabus/24> a ns1:SyllabusItem ;
    ns1:itemIndex 24 ;
    ns1:syllabusDescription "5.2. Adaptación y mitigación del efecto del CC sobre los eventos extremos y el entorno físico."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000700/2025-26/syllabus/25> a ns1:SyllabusItem ;
    ns1:itemIndex 25 ;
    ns1:syllabusDescription "5.2.1. Medidas estructurales y no estructurales. Planes de emergencia en cuencas y de seguridad hidrológica de presas. Sistemas urbanos de drenaje sostenible. Alerta temprana. Sistemas de monitoreo. Buenas prácticas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000700/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "2.1. Identificación de fuentes de información (presente y futuro). Manejo de bases de datos espacio-temporales, obtención de series temporales con diferente resolución espacio-temporal. Manejo de imágenes satelitales, información raster, etc. Uso de IA. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000700/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "2.2. Análisis y validación de datos. Análisis de calidad de datos aplicando técnicas estadísticas. Caracterización estadística de series espacio-temporales. Análisis de incertidumbre. Tendencias. Uso de IA Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000700/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "3. Evaluación del efecto de cambio climático en los recursos hídricos, adaptación y mitigación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000700/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "3.1. Evaluación del efecto del CC en los recursos hídricos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000700/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "3.1.1. Marco institucional. Caracterízación de los sistemas de RRHH, planificación y gestión de RRHH. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000700/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "3.1.2. Evaluación de recursos hídricos, presente y futuro Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000700/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "3.1.3. Evaluación de demandas, presente y futuro Sin subniveles"@es .

