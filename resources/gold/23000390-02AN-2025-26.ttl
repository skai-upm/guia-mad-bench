    schema:numberOfCredits 4.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/23000390/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/23000390/2025-26/C2>,
