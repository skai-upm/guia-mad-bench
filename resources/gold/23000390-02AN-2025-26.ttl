    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/23000390/2025-26/syllabus> ;
    ns1:inpersonHours "49 horas (47.1%)"@es ;
    ns1:numberOfCredits 4.0 ;
    ns1:otherInformation "Esta asignatura incorpora temas que pueden contribuir a una cualificación de los estudiantes en los ODS nº 6 (agua limpia y saneamiento) y ODS nº 11 (ciudades y comunidades sostenibles)"@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "57 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/23000390/2025-26/eventSchedule> ;
    schema:description """La asignatura trata del conocimiento de las características, tipos, peculiaridades, cálculo, aplicaciones y evaluación de los movimientos de tierra y de las redes de desagüe y drenaje, y está orientada a la preparación de los Proyectos propios del sector; pero también tiene aplicación directa al conjunto de las intervenciones del establecimiento y mantenimiento de jardines, parques y espacios verdes de todo tipo.
Los contenidos de la asignatura están organizados en dos bloques temáticos:
-Bloque I: Movimiento de tierras y viales (temas 1 a 4)
-Bloque II: Desagües y drenajes (temas 5 a 9)"""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/francisco.ayuga%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/francisco.ayuga%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/guillermo.moreda%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/paco.alonso.peralta%40upm.es> ;
    schema:name "Infraestructuras: Movimientos de Tierras. Desagües y Drenajes"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000390/2025-26/C2> a ns1:Competency ;
    ns1:competencyCode "C2" ;
    ns1:competencyDescription "Capacidad para describir, organizar y analizar los elementos constitutivos de un problema de jardinería y paisajismo y diseñar estrategias que permitan alcanzar una solución técnica, ambiental y económicamente viable. TIPO: Competencias."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000390/2025-26/C5> a ns1:Competency ;
    ns1:competencyCode "C5" ;
    ns1:competencyDescription "Capacidad de diseñar, calcular y ejecutar todo tipo de instalaciones de riego, iluminación, movimiento de tierras, drenaje y desagüe, en todo tipo de actuaciones paisajísticas y áreas verdes, así como de llevar a cabo su mantenimiento, aplicando incluso las técnicas más complejas y avanzadas. TIPO: Competencias."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000390/2025-26/K6> a ns1:Competency ;
    ns1:competencyCode "K6" ;
    ns1:competencyDescription "Conocer las características y peculiaridades de las empresas y entidades vinculadas a las actividades de jardinería y paisajismo, y cómo organizar el trabajo en equipo y participar en las actuaciones ejecutivas y directivas. TIPO: Conocimientos o contenidos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000390/2025-26/RA107> a ns1:LearningResult ;
    ns1:learningResultCode "RA107" ;
    ns1:learningResultDescription "K6"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000390/2025-26/RA109> a ns1:LearningResult ;
    ns1:learningResultCode "RA109" ;
    ns1:learningResultDescription "S4"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000390/2025-26/S4> a ns1:Competency ;
    ns1:competencyCode "S4" ;
    ns1:competencyDescription "Habilidad de reconocer los principios éticos para la toma de decisiones en el ámbito de la jardinería y el paisajismo, conociendo y aplicando la normativa, con criterios de calidad y considerando las implicaciones sociales, de salud y seguridad, ambientales y económicas. TIPO: Habilidades o destrezas"@es .

