    schema:name "Fundamentos Fisicos de la Informatica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000220/2025-26/CG02> a ns1:Competency ;
    ns1:competencyCode "CG02" ;
    ns1:competencyDescription "Capacidad para comprender y dominar los fundamentos físicos y tecnológicos de la informática: electromagnetismo, ondas, teoría de circuitos, electrónica y fotónica y su aplicación para la resolución de problemas propios de la ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000220/2025-26/CT1> a ns1:Competency ;
    ns1:competencyCode "CT1" ;
    ns1:competencyDescription "Análisis y síntesis: Descomponer la información en unidades más pequeñas separando los componentes fundamentales de los no relevantes e identificando las relaciones existentes entre ellos. Síntesis: Combinar información para construir un todo a partir de las entidades previamente analizadas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000220/2025-26/RA161> a ns1:LearningResult ;
    ns1:learningResultCode "RA161" ;
    ns1:learningResultDescription "Identifica las leyes básicas de la electrostática y las aplica a la resolución de problemas de distribuciones de carga y almacenamiento de energía eléctrica."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000220/2025-26/RA162> a ns1:LearningResult ;
    ns1:learningResultCode "RA162" ;
    ns1:learningResultDescription "Analiza y resuelve circuitos de corriente continua."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000220/2025-26/RA163> a ns1:LearningResult ;
    ns1:learningResultCode "RA163" ;
    ns1:learningResultDescription "Identifica las fuentes fundamentales de campo magnético y muestra su interacción con las cargas eléctricas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000220/2025-26/RA164> a ns1:LearningResult ;
    ns1:learningResultCode "RA164" ;
    ns1:learningResultDescription "Describe las propiedades básicas de la materia como soporte de la información."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000220/2025-26/RA167> a ns1:LearningResult ;
    ns1:learningResultCode "RA167" ;
    ns1:learningResultDescription "Comprende y extrae información de enunciados científico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000220/2025-26/RA25> a ns1:LearningResult ;
    ns1:learningResultCode "RA25" ;
    ns1:learningResultDescription "Resuelve problemas relacionados con los fundamentos físicos de la informática"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000220/2025-26/RA26> a ns1:LearningResult ;
    ns1:learningResultCode "RA26" ;
    ns1:learningResultDescription "Conoce y aplica los conceptos físicos fundamentales que permitan comprender el funcionamiento básico de la tecnología informática."@es .

