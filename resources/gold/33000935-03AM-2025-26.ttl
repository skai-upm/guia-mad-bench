    ns1:syllabusDescription "2.1. Desarrollo de ejercicios prácticos de análisis estructural de distintas tipologías Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000935/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "2.2. Evaluación crítica e interpretación de las salidas de datos de programas de análisis estructural Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000935/2025-26/syllabus/8> a ns1:SyllabusItem ;
