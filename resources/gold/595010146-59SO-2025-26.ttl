    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/595010146/2025-26/eventSchedule> ;
    schema:description "Esta es una asignatura optativa tipo A de 4,5 ECTS. La asignatura está aconsejada para los alumnos que hayan cursado/aprobado la asignatura obligatoria de Sistemas Electroacústicos. La asignatura cubre las competencias relacionadas con el diseño de sistemas de refuerzo sonoro en recintos especiales (cines, estadios deportivos, etc.) utilizando programas de simulación acústica. También se trabajará con conocimientos relativos al equipamiento utilizado en este tipo de instalaciones."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/joseluis.sanchez.bote%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/daniel.prida%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/joseluis.sanchez.bote%40upm.es> ;
    schema:name "Refuerzo Sonoro"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595010146/2025-26/CE%20SO03> a ns1:Competency ;
    ns1:competencyCode "CE SO03" ;
    ns1:competencyDescription "Capacidad para realizar proyectos de locales e instalaciones destinados a la producción y grabación de señales de audio y vídeo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595010146/2025-26/CE%20SO04> a ns1:Competency ;
    ns1:competencyCode "CE SO04" ;
    ns1:competencyDescription "Capacidad para realizar proyectos de ingeniería acústica sobre: aislamiento y acondicionamiento acústico de locales; instalaciones de megafonía; especificación, análisis y selección de transductores electroacústicos; sistemas de medida, análisis y control de ruido y vibraciones; acústica medioambiental; sistemas de acústica submarina."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595010146/2025-26/RA408> a ns1:LearningResult ;
    ns1:learningResultCode "RA408" ;
    ns1:learningResultDescription "Conocer las especificaciones de los sistemas de sonido multicanal en cine actuales y las tendencias de futuro."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595010146/2025-26/RA409> a ns1:LearningResult ;
    ns1:learningResultCode "RA409" ;
    ns1:learningResultDescription "Conocer y diseñar los sistemas electroacústicos que se montan en salas cinematográficas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595010146/2025-26/RA410> a ns1:LearningResult ;
    ns1:learningResultCode "RA410" ;
    ns1:learningResultDescription "Saber interpretar las características técnicas de los sistemas electroacústicos que se montan en salas cinematográficas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595010146/2025-26/RA411> a ns1:LearningResult ;
    ns1:learningResultCode "RA411" ;
    ns1:learningResultDescription "Diseñar y dimensionar un sistema electroacústicos para una sala cinematográfica."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595010146/2025-26/RA412> a ns1:LearningResult ;
    ns1:learningResultCode "RA412" ;
    ns1:learningResultDescription "Emplear herramientas de simulación para el diseño de sistemas electroacústicos en salas cinematográficas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595010146/2025-26/RA413> a ns1:LearningResult ;
    ns1:learningResultCode "RA413" ;
    ns1:learningResultDescription "Proponer equipamiento y diagramas de conexionado de sistemas de sonido en salas cinematográficas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595010146/2025-26/RA414> a ns1:LearningResult ;
    ns1:learningResultCode "RA414" ;
    ns1:learningResultDescription "Conocer los sistemas de emisión sonora usados en grandes instalaciones."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595010146/2025-26/RA415> a ns1:LearningResult ;
    ns1:learningResultCode "RA415" ;
    ns1:learningResultDescription "Calcular la amplificación de un sistema múltiple de altavoces."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595010146/2025-26/RA416> a ns1:LearningResult ;
    ns1:learningResultCode "RA416" ;
    ns1:learningResultDescription "Conocer y aplicar las técnicas de agrupación de fuentes usadas en grandes instalaciones, clusters y arrays lineales de altavoces."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595010146/2025-26/RA417> a ns1:LearningResult ;
    ns1:learningResultCode "RA417" ;
    ns1:learningResultDescription "Predecir la radiación y cobertura de agrupaciones de altavoces utilizando herramientas profesionales"@es .

