        <https://guia-kg.skai.etsisi.upm.es/resource/25001308/2025-26/didactic_resource/6> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/25001308/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/25001308/2025-26/RA184>,
