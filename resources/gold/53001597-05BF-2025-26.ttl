    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/53001597/2025-26/eventSchedule> ;
    schema:description """Los objetivos generales de la asignatura son los siguientes:
Contribuir a la formación humanística como parte fundamental de la formación científica y técnica.
Conocer los orígenes y el desarrollo de la Física Nuclear.
Conocer el desarrollo de Ingeniería Nuclear a nivel mundial y a nivel nacional.
Profundizar en los principios de la ética y la responsabilidad científica."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/gonzalo.jimenez%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/antonio.rivera%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/gonzalo.jimenez%40upm.es> ;
    schema:name "Historia de la Física Nuclear y de la Ingeniería Nuclear"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001597/2025-26/CB08> a ns1:Competency ;
    ns1:competencyCode "CB08" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de integrar conocimientos y enfrentarse a la complejidad de formular juicios a partir de una información que, siendo incompleta o limitada, incluya reflexiones sobre las responsabilidades sociales y éticas vinculadas a la aplicación de sus conocimientos y juicios"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001597/2025-26/CB09> a ns1:Competency ;
    ns1:competencyCode "CB09" ;
    ns1:competencyDescription "Que los estudiantes sepan comunicar sus conclusiones y los conocimientos y razones últimas que las sustentan a públicos especializados y no especializados de un modo claro y sin ambigüedades"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001597/2025-26/CE05> a ns1:Competency ;
    ns1:competencyCode "CE05" ;
    ns1:competencyDescription "Entiende a fondo el sistema de regulación de la seguridad, está comprometido con la seguridad y es consciente de la importancia de la cultura de seguridad para las aplicaciones de la energía nuclear, así como las implicaciones ético"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001597/2025-26/CE06> a ns1:Competency ;
    ns1:competencyCode "CE06" ;
    ns1:competencyDescription "Concibe la utilización de los aceleradores de partículas como herramientas avanzadas en la investigación física, y sus aplicaciones en la medicina e industria"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001597/2025-26/CG04> a ns1:Competency ;
    ns1:competencyCode "CG04" ;
    ns1:competencyDescription "Ser capaz de integrar conocimientos y enfrentarse a la complejidad de formular juicios a partir de una información que, siendo incompleta o limitada, incluya reflexiones sobre las responsabilidades sociales y éticas vinculadas a la aplicación de sus conocimientos y juicios"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001597/2025-26/CT06> a ns1:Competency ;
    ns1:competencyCode "CT06" ;
    ns1:competencyDescription "Es responsable. Comprensión de la responsabilidad ética y profesional"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001597/2025-26/CT07> a ns1:Competency ;
    ns1:competencyCode "CT07" ;
    ns1:competencyDescription "Comunica. Habilidad para comunicar eficazmente"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001597/2025-26/CT08> a ns1:Competency ;
    ns1:competencyCode "CT08" ;
    ns1:competencyDescription "Entiende los impactos. Educación amplia necesaria para entender el impacto de las soluciones ingenieriles en un contexto social global"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001597/2025-26/CT09> a ns1:Competency ;
    ns1:competencyCode "CT09" ;
    ns1:competencyDescription "Se actualiza. Reconocimiento de la necesidad y la habilidad para comprometerse al aprendizaje continuo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001597/2025-26/CT10> a ns1:Competency ;
    ns1:competencyCode "CT10" ;
    ns1:competencyDescription "Conoce. Conocimiento de los temas contemporáneos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001597/2025-26/CT11> a ns1:Competency ;
    ns1:competencyCode "CT11" ;
    ns1:competencyDescription "Usa herramientas. Habilidad para usar las técnicas, destrezas y herramientas ingenieriles modernas necesarias para la práctica de la ingeniería"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001597/2025-26/RA50> a ns1:LearningResult ;
    ns1:learningResultCode "RA50" ;
    ns1:learningResultDescription "Conocer la historia de la ciencia como mecanismo de producción social e individual de conocimientos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001597/2025-26/RA51> a ns1:LearningResult ;
    ns1:learningResultCode "RA51" ;
    ns1:learningResultDescription "Aprender la sinergia entre ciencia y desarrollo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001597/2025-26/RA52> a ns1:LearningResult ;
    ns1:learningResultCode "RA52" ;
    ns1:learningResultDescription "Aprender aspectos epistemológicos de la investigación científica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001597/2025-26/RA53> a ns1:LearningResult ;
    ns1:learningResultCode "RA53" ;
    ns1:learningResultDescription "Aprender el ámbito de las distintas aplicaciones de las ciencias nucleares en áreas de desarrollo social y desarrollo sostenible"@es .

