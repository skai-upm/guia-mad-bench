    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/45000118/2025-26/syllabus> ;
    ns1:inpersonHours "54 horas (34.6%)"@es ;
    ns1:numberOfCredits 6.0 ;
    ns1:otherInformation "En esta asignatura se intenta trabajar el objetivo número 8 de la lista de Objetivos de crecimiento sostenible de Naciones Unidas, relativo al trabajo decente y al crecimiento económico. Para ello la asignatura trabaja el concepto de imagen fiel de la empresa y la necesidad de aportar información contable transparente y fiable que contribuya a la creación de relaciones comerciales de confianza y que contribuya a la mejor gestión de la responsabilidad social corporativa de la empresa."@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "54 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/45000118/2025-26/eventSchedule> ;
    schema:description """Tema 1. La empresa y el empresario
Tema 2. Organización y gestión de la empresa
Tema 3. El balance y la cuenta de resultados
Tema 4. Análisis de inversiones
Tema 5. La gestión financiera a largo plazo
Tema 6. La gestión financiera a corto plazoTema 8. El sistema financiero y mercados de renta fija y renta variable
Tema 7. Project finance
Tema 8. Análisis del entorno económico
Tema 9. El entorno jurídico e institucional de la empresa
Tema 10. Estrategia de la empresa
Tema 11. Recursos humanos
Tema 12. Mercados de renta fija y de renta variable"""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/antonio.sanchezso%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/antonio.sanchezso%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/monica.gonzalez%40upm.es> ;
    schema:name "Organización Empresarial"@es .

