<https://guia-kg.skai.etsisi.upm.es/resource/135004553/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/135004553/2025-26/CB02>,
        <https://guia-kg.skai.etsisi.upm.es/resource/135004553/2025-26/CE%201.01> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/135004553/2025-26/didactic_resource/1> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/135004553/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/135004553/2025-26/RA1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/135004553/2025-26/RA10>,
