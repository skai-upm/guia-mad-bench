        <https://guia-kg.skai.etsisi.upm.es/resource/205000010/2025-26/RA69>,
        <https://guia-kg.skai.etsisi.upm.es/resource/205000010/2025-26/RA70>,
        <https://guia-kg.skai.etsisi.upm.es/resource/205000010/2025-26/RA71>,
