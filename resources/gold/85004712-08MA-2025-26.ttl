        <https://guia-kg.skai.etsisi.upm.es/resource/85004712/2025-26/didactic_resource/4> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/85004712/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/85004712/2025-26/RA227>,
        <https://guia-kg.skai.etsisi.upm.es/resource/85004712/2025-26/RA228>,
        <https://guia-kg.skai.etsisi.upm.es/resource/85004712/2025-26/RA229>,
        <https://guia-kg.skai.etsisi.upm.es/resource/85004712/2025-26/RA230>,
        <https://guia-kg.skai.etsisi.upm.es/resource/85004712/2025-26/RA231> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/85004712/2025-26/syllabus> ;
    ns1:inpersonHours "42 horas (51.9%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation """La asignatura se relaciona con el ODS9 y el ODS12.
La asistencia a clase no es obligatoria, ni se valorará positiva o negativamente.
La realización de las prácticas es voluntaria. Lo tratado en ellas es, no obstante, objeto de examen.
En caso de necesidad por razones sanitarias, las actividades docentes y de evaluación pasarán a desarrollarse en modalidad telemática."""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "42 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/85004712/2025-26/eventSchedule> ;
    schema:description "Conocer las características y aplicaciones de las aleaciones de uso naval no estructurales. Aleaciones de cobre. Aleaciones de titanio. Aleaciones de magnesio. Aleaciones de aluminio. Aleaciones estaño-plata. Níquel y aleaciones base níquel. Superaleaciones. Aplicar a la selección de materiales para las aplicaciones eléctricas, térmicas y acústicas. Conocer la tribología. Conocer y comprender las características y aplicaciones de los diferentes lubricantes y combustibles."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/monica.carboneras%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/monica.carboneras%40upm.es> ;
    schema:name "Materiales No Estructurales y Fluidos de Máquinas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85004712/2025-26/CB2> a ns1:Competency ;
    ns1:competencyCode "CB2" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar sus conocimientos a su trabajo o vocación de una forma profesional y posean las competencias que suelen demostrarse por medio de la elaboración y defensa de argumentos y la resolución de problemas dentro de su área de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85004712/2025-26/CB5> a ns1:Competency ;
    ns1:competencyCode "CB5" ;
    ns1:competencyDescription "Que los estudiantes hayan desarrollado aquellas habilidades de aprendizaje necesarias para emprender estudios posteriores con un alto grado de autonomía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85004712/2025-26/CE18> a ns1:Competency ;
    ns1:competencyCode "CE18" ;
    ns1:competencyDescription "Conocimiento de los materiales específicos para máquinas, equipos y sistemas navales y de los criterios para su selección"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85004712/2025-26/CE25> a ns1:Competency ;
    ns1:competencyCode "CE25" ;
    ns1:competencyDescription "Conocimiento de los procesos de fabricación mecánica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85004712/2025-26/CE8> a ns1:Competency ;
    ns1:competencyCode "CE8" ;
    ns1:competencyDescription "Conocimiento de la ciencia y tecnología de materiales y capacidad para su selección y para la evaluación de su comportamiento."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85004712/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Capacidad para el aprendizaje de nuevos métodos y teorías, y en la versatilidad para adaptarse a nuevas situaciones basándose en los conocimientos adquiridos en materias básicas y tecnológicas propias de la Ingeniería Marítima."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85004712/2025-26/RA227> a ns1:LearningResult ;
    ns1:learningResultCode "RA227" ;
    ns1:learningResultDescription "Conocer las características y aplicaciones de las aleaciones de uso naval no estructurales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85004712/2025-26/RA228> a ns1:LearningResult ;
