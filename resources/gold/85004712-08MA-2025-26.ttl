    schema:courseCode 85004712 ;
    schema:hasCourseInstance <https://guia-kg.skai.etsisi.upm.es/resource/85004712/2025-26> ;
    schema:name "Non-Structural Materials And Machinery Fluids"@en,
        "Materiales No Estructurales y Fluidos de Máquinas"@es ;
    schema:numberOfCredits 3.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/85004712/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/85004712/2025-26/CB2>,
