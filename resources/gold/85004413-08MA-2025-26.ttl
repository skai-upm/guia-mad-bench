    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/85004413/2025-26/syllabus> ;
    ns1:inpersonHours "65 horas (41.7%)"@es ;
    ns1:numberOfCredits 6.0 ;
    ns1:otherInformation ""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
