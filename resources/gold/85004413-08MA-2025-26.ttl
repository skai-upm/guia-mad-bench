    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/85004413/2025-26/eventSchedule> ;
    schema:description "La asignatura pretende el conocimiento básico del sólido deformable bajo la acción de cargas externas que dan lugar a su respuesta en tensiones y deformaciones. Permitiendo el escantillonado básico de los elemento estructurales"@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/a.silva%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
