    schema:hasCourseInstance <https://guia-kg.skai.etsisi.upm.es/resource/43000651/2025-26> ;
    schema:name "Continuum Mechanics"@en,
        "Mecánica de Medios Continuos"@es ;
    schema:numberOfCredits 3.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/43000651/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/43000651/2025-26/C4>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000651/2025-26/K1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000651/2025-26/Sk1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000651/2025-26/Sk2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000651/2025-26/Sk4> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/43000651/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000651/2025-26/didactic_resource/2> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/43000651/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/43000651/2025-26/RA47> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/43000651/2025-26/syllabus> ;
    ns1:inpersonHours "35 horas y 50 minutos (45.9%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation "La asignatura se relaciona con el ODS 4.4 y 4.7"@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "51 horas y 20 minutos"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/43000651/2025-26/eventSchedule> ;
    schema:description """Este curso de Mecánica del Medio Continuo proporciona los fundamentos teóricos esenciales para las asignaturas de cálculo y análisis estructural y de cálculo y modelización geotécnica que se abordan en el resto del máster. Comienza con una introducción a los conceptos básicos de cálculo, álgebra vectorial y cálculo tensorial necesarios para el desarrollo del curso.
A continuación, se introduce el concepto de medio continuo, su cinemática y las distintas medidas de deformación, abordando tanto deformaciones finitas como infinitesimales.
Posteriormente, se estudian las fuerzas en el medio continuo, con especial atención a las fuerzas internas representadas mediante tensiones.
En los temas siguientes se abordan las ecuaciones de conservación o balance, tanto en sus formas globales como locales, incluyendo el balance de masa, de cantidad de movimiento y de energía.
Finalmente, se presentan las ecuaciones constitutivas de los materiales, comenzando por las leyes de elasticidad (incluyendo los casos particulares de elasticidad plana) y continuando con una introducción a las leyes de plasticidad."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/d.manzanal%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/d.manzanal%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/francisco.martinez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/sergio.blanco%40upm.es> ;
    schema:name "Mecánica de Medios Continuos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000651/2025-26/C4> a ns1:Competency ;
    ns1:competencyCode "C4" ;
    ns1:competencyDescription "[Proviene de las competencias CE1 y CE4]: Capacidad para el análisis del comportamiento mecánico y la durabilidad de estructuras de ingeniería civil y edificación, sus materiales y sus cimentaciones TIPO: Competencias"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000651/2025-26/K1> a ns1:Competency ;
    ns1:competencyCode "K1" ;
    ns1:competencyDescription "[Proviene parcialmente de la competencia CG1]: Aplica e integra conocimientos científicos avanzados de tipo mecánico, físico y matemático en contextos de investigación científica y tecnológica en el ámbito de las estructuras, las cimentaciones y los materiales TIPO: Conocimientos o contenidos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000651/2025-26/RA47> a ns1:LearningResult ;
    ns1:learningResultCode "RA47" ;
    ns1:learningResultDescription "Los resultados del aprendizaje correspondientes a esta asignatura han quedado definidos en el apartado de competencias de este documento, señalando los que corresponden a conocimientos, habilidades y competencias propiamente dichas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000651/2025-26/Sk1> a ns1:Competency ;
    ns1:competencyCode "Sk1" ;
    ns1:competencyDescription "[Proviene de la competencia CB6]: Utiliza de forma lógica y crítica las bases del método científico como base para llevar a cabo desarrollos originales y/o aplicaciones de ideas en el contexto de la investigación en ingeniería de estructuras, cimentaciones y materiales. TIPO: Habilidades o destrezas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000651/2025-26/Sk2> a ns1:Competency ;
    ns1:competencyCode "Sk2" ;
    ns1:competencyDescription "[Proviene de la competencia CB7]: Utiliza los conocimientos técnicos adquiridos para la resolución de problemas nuevos o poco conocidos dentro de contextos más amplios (o multidisciplinares) relacionados con el diseño de estructuras, cimentaciones y materiales en ingeniería civil y edificación. TIPO: Habilidades o destrezas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000651/2025-26/Sk4> a ns1:Competency ;
    ns1:competencyCode "Sk4" ;
    ns1:competencyDescription "[Proviene de la competencia CB10]: Demuestra que puede adquirir conocimientos complejos y continuar estudiando de un modo que habrá de ser en gran medida auto"@es .

