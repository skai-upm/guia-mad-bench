<https://guia-kg.skai.etsisi.upm.es/resource/55001011/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Introducción a las Ecuaciones Diferenciales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001011/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Generalidades sobre ecuaciones diferenciales ordinarias (EDO). Problema de valor inicial. Teoremas de existencia y unicidad. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001011/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "3.1. Sistemas de EDO lineales de primer orden y coeficientes constantes. Escritura matricial x'(t) = Ax(t). Problema de valor inicial. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001011/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "3.2. Relación entre soluciones, autovalores y autovectores. Matriz diagonalizable. Valores propios complejos y oscilaciones. Matriz fundamental. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001011/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "3.3. Sistemas diferenciales lineales no homogéneos. Método de variación de las constantes. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001011/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "3.4. Algunos ejemplos de sistemas diferenciales lineales con coeficientes variables. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001011/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "4. Ecuaciones diferenciales lineales de orden n."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001011/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "4.1. EDO lineales de orden n y coeficientes constantes. El sistema diferencial equivalente. Sistema fundamental de soluciones. Problema de valor inicial. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001011/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "4.2. EDO lineal de orden n no homogénea: métodos de variación de las constantes y de los coeficientes indeterminados. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001011/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "4.3. Ecuaciones de Euler. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001011/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "4.4. EDO lineales de orden n y coeficientes variables: reducción del orden. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001011/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "5. Sistemas diferenciales no lineales de segundo orden."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001011/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Soluciones analíticas y soluciones numéricas. Ejemplos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001011/2025-26/syllabus/20> a ns1:SyllabusItem ;
    ns1:itemIndex 20 ;
    ns1:syllabusDescription "5.1. Plano de fases de los sistemas diferenciales lineales en el plano. Clasificación: nodos, puertos, focos y centros. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001011/2025-26/syllabus/21> a ns1:SyllabusItem ;
    ns1:itemIndex 21 ;
    ns1:syllabusDescription "5.2. Sistemas diferenciales no lineales autónomos. Linealización. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001011/2025-26/syllabus/22> a ns1:SyllabusItem ;
    ns1:itemIndex 22 ;
    ns1:syllabusDescription "5.3. Órbitas o trayectorias. Puntos de equilibrio. Integrales primeras. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001011/2025-26/syllabus/23> a ns1:SyllabusItem ;
    ns1:itemIndex 23 ;
    ns1:syllabusDescription "5.4. Clasificación de los puntos de equilibrio. Puntos de equilibrio hiperbólicos: puertos, sumideros y fuentes. Teorema de Hartman-Grossman. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001011/2025-26/syllabus/24> a ns1:SyllabusItem ;
    ns1:itemIndex 24 ;
    ns1:syllabusDescription "5.5. Resolución numérica de sistemas no lineales. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001011/2025-26/syllabus/25> a ns1:SyllabusItem ;
    ns1:itemIndex 25 ;
    ns1:syllabusDescription "6. Introducción a las ecuaciones diferenciales en derivadas parciales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001011/2025-26/syllabus/26> a ns1:SyllabusItem ;
    ns1:itemIndex 26 ;
    ns1:syllabusDescription "6.1. Ecuaciones diferenciales en derivadas parciales (EDP) lineales de segundo orden y dos variables independientes. Ecuaciones de la Física Matemática: ecuaciones de ondas, de Laplace y del calor. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001011/2025-26/syllabus/27> a ns1:SyllabusItem ;
    ns1:itemIndex 27 ;
    ns1:syllabusDescription "6.2. Método de separación de variables. Problema de autovalores y autofunciones. Condiciones de frontera. Soluciones formales. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001011/2025-26/syllabus/28> a ns1:SyllabusItem ;
    ns1:itemIndex 28 ;
    ns1:syllabusDescription "6.3. Desarrollo en serie de Fourier de funciones periódicas. Extensiones pares e impares. Aplicación a la resolución de EDP. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001011/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "2. Métodos elementales de resolución de ecuaciones diferenciales ordinarias de primer orden."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001011/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "2.1. Ecuaciones separables. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001011/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "2.2. Ecuaciones diferenciales exactas. Función potencial. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001011/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "2.3. Ecuaciones diferenciales lineales de primer orden. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001011/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "2.4. Ecuaciones diferenciales de Bernoulli. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001011/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "2.5. Introducción a los métodos numéricos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001011/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "3. Sistemas diferenciales lineales de primer orden."@es .

