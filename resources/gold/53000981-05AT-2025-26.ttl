    schema:hasCourseInstance <https://guia-kg.skai.etsisi.upm.es/resource/53000981/2025-26> ;
    schema:name "New Railway Technologies"@en,
        "Nuevas Tecnologias en el Ferrocarril"@es ;
    schema:numberOfCredits 3.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/53000981/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/53000981/2025-26/CE9>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53000981/2025-26/CG%201>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53000981/2025-26/CG%203>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53000981/2025-26/CG%205> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/53000981/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53000981/2025-26/didactic_resource/2> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/53000981/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/53000981/2025-26/RA31> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/53000981/2025-26/syllabus> ;
    ns1:inpersonHours "44 horas (54.3%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation """Es muy recomendable para poder seguir la asignatura con éxito, haber realizado la asignatura de Instalaciones y Equipos Ferroviarios previamente, o tener conocimientos previos del sector ferroviario.

Dentro de la asignatura se realiza al menos una visita a un punto de interés en el entorno de la ciudad de Madrid de aplicación para alguno de los módulos impartidos.
Es habitual también la participación de algún experto de empresas ferroviarias a modo de clase magistral práctica."""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "44 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/53000981/2025-26/eventSchedule> ;
    schema:description """La asignatura está planteada como una serie de exposiciones sobre temas que son especialmente relevantes en los sistemas ferroviarios actuales desde el punto de vista de los avances tecnológicos que suponen y su aplicación real a los mismos.
En este sentido se comienza por una breve introducción al sistema ferroviario que se trate en cada módulo para pasar a continuación a exponer los nuevos desarrollos y sus aplicaciones, así como los retos tecnológicos todavía existentes en ese área.
De esta forma el temario se organiza en los siguientes módulos:
* Sistema de Señalización: ERTMS, CBTC, UTO
* Energía: sistema AC 2x vs 1x, optimización, eficiencia energética, superacumuladores, acumuladores embarcados
* Verificación y Validación: tecnologías de simulación aplicada, gemelo digital
* Técnicas de monitoreo continuo para mantenimiento por condición
* Dinámica ferroviaria: evaluación de confort y seguridad"""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/josemanuel.mera%40upm.es> ;
    schema:inLanguage "Inglés/Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/josemanuel.mera%40upm.es> ;
    schema:name "Nuevas Tecnologias en el Ferrocarril"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000981/2025-26/CE9> a ns1:Competency ;
    ns1:competencyCode "CE9" ;
    ns1:competencyDescription "Redactar de documentación técnica y no especializada dentro del ámbito de la ingeniería mecánica. Búsqueda de fuentes y uso de Bases de datos. Difusión de resultados."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000981/2025-26/CG%201> a ns1:Competency ;
    ns1:competencyCode "CG 1" ;
    ns1:competencyDescription "Aplicar conocimientos de ciencias y tecnologías avanzadas a la práctica de la Ingeniería Mecánica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000981/2025-26/CG%203> a ns1:Competency ;
    ns1:competencyCode "CG 3" ;
    ns1:competencyDescription "Aplicar los conocimientos adquiridos para identificar, formular y resolver problemas dentro de contextos amplios y multidisciplinarios, siendo capaces de integrar conocimientos, trabajando en equipos multidisciplinares y desarrollando actividades de I+D."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000981/2025-26/CG%205> a ns1:Competency ;
    ns1:competencyCode "CG 5" ;
    ns1:competencyDescription "Comunicar los conocimientos y conclusiones, tanto de forma oral, escrita y gráfica, a públicos especializados y no especializados de un modo claro y sin ambigüedades."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000981/2025-26/RA31> a ns1:LearningResult ;
    ns1:learningResultCode "RA31" ;
    ns1:learningResultDescription "Dar al alumno los conocimientos necesarios que se consideran en la aplicación de nuevos desarrollos en los sistemas ferroviarios y plantear las líneas de investigación actuales en el sector"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000981/2025-26/didactic_resource/1> a ns1:DidacticResource ;
    ns1:bibliographyDescription "Los profesores entregan a los alumnos para cada módulo apuntes de preparación propia"@es ;
    ns1:bibliographyTitle "Apuntes de Preparación Propia"@es ;
    ns1:bibliographyType "Otros"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000981/2025-26/didactic_resource/2> a ns1:DidacticResource ;
    ns1:bibliographyDescription "Los profesores entregan a los alumnos para cada módulo bibliografía complementaria para profundizar en la materia"@es ;
