    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/33000851/2025-26/syllabus> ;
    ns1:inpersonHours "58 horas (37.2%)"@es ;
    ns1:numberOfCredits 6.0 ;
    ns1:otherInformation """Para información complementaria, ver la Guía de Aprendizaje en UCM: https://www.ucm.es/patrimonio-cultural-siglo21/plan-de-estudios
La asignatura está alineada con el ODS 11, Ciudades y comunidades sostenibles, en su meta de 'redoblar los esfuerzos para proteger y salvaguardar el patrimonio cultural y natural'."""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "58 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/33000851/2025-26/eventSchedule> ;
    schema:description "La asignatura consta de tres partes. El primer bloque se centra en el manejo turístico del patrimonio a nivel de recursos y destinos. En el segundo se presentan los criterios, estrategias y proyectos en el ámbito de la cooperación al desarrollo. Por último, en el tercer bloque temático se aborda el marco jurídico de referencia para la financiación tanto pública como privada de proyectos culturales y los mecanismos de activación de esa financiación."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/rodrigo.delao%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/fernando.vela%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/rodrigo.delao%40upm.es> ;
    schema:name "Financiación, Turismo y Desarrollo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000851/2025-26/CB06> a ns1:Competency ;
    ns1:competencyCode "CB06" ;
    ns1:competencyDescription "Poseer y comprender conocimientos que aporten una base u oportunidad de ser originales en el desarrollo y/o aplicación de ideas, a menudo en un contexto de investigación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000851/2025-26/CB07> a ns1:Competency ;
    ns1:competencyCode "CB07" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en entornos nuevos o poco conocidos dentro de contextos más amplios (o multidisciplinares) relacionados con su área de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000851/2025-26/CB08> a ns1:Competency ;
    ns1:competencyCode "CB08" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de integrar conocimientos y enfrentarse a la complejidad de formular juicios a partir de una información que, siendo incompleta o limitada, incluya reflexiones sobre las responsabilidades sociales y éticas vinculadas a la aplicación de sus conocimientos y juicios"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000851/2025-26/CB09> a ns1:Competency ;
    ns1:competencyCode "CB09" ;
    ns1:competencyDescription "Que los estudiantes sepan comunicar sus conclusiones y los conocimientos y razones últimas que las sustentan a públicos especializados y no especializados de un modo claro y sin ambigüedades"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000851/2025-26/CB10> a ns1:Competency ;
    ns1:competencyCode "CB10" ;
    ns1:competencyDescription "Que los estudiantes posean las habilidades de aprendizaje que les permitan continuar estudiando de un modo que habrá de ser en gran medida autodirigido o autónomo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000851/2025-26/CE11> a ns1:Competency ;
    ns1:competencyCode "CE11" ;
    ns1:competencyDescription "Aplicar los instrumentos de cooperación internacional en la protección y difusión de los distintos elementos del Patrimonio Cultural"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000851/2025-26/CG04> a ns1:Competency ;
    ns1:competencyCode "CG04" ;
    ns1:competencyDescription "Contrastar la situación actual de la gestión del Patrimonio Cultural y abordar la propuesta de nuevos modelos de tutela, investigación y actividad profesional"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000851/2025-26/CG05> a ns1:Competency ;
    ns1:competencyCode "CG05" ;
    ns1:competencyDescription "Distinguir entre los distintos tipos de Patrimonios específicos, muy en especial el mueble, inmueble e inmaterial, aplicando los modelos de gestión e investigación adecuados para cada uno de ellos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000851/2025-26/CG07> a ns1:Competency ;
    ns1:competencyCode "CG07" ;
    ns1:competencyDescription "Analizar la relación entre el Patrimonio Cultural y la actividad económica general (turismo, transporte, desarrollo, etc.)"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000851/2025-26/CG10> a ns1:Competency ;
    ns1:competencyCode "CG10" ;
    ns1:competencyDescription "Manejar nociones de diseño de políticas públicas aplicadas a la gestión del Patrimonio Cultural"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000851/2025-26/CG19> a ns1:Competency ;
    ns1:competencyCode "CG19" ;
    ns1:competencyDescription "Identificar los recursos patrimoniales para el desarrollo cultural y económico de las distintas regiones"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000851/2025-26/CT01> a ns1:Competency ;
    ns1:competencyCode "CT01" ;
    ns1:competencyDescription "Analizar y sintetizar la información disponible y/o los resultados obtenidos, en un trabajo de investigación, en el ámbito que aquí compete"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000851/2025-26/CT02> a ns1:Competency ;
    ns1:competencyCode "CT02" ;
    ns1:competencyDescription "Desarrollar el proceso marcado por el método científico en el planteamiento y en la realización de trabajos de investigación y/o profesionales diversos, fomentando el espíritu crítico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000851/2025-26/CT04> a ns1:Competency ;
    ns1:competencyCode "CT04" ;
    ns1:competencyDescription "Organizar y planificar sistemas de gestión adecuados para el Patrimonio Cultural en cada una de sus especialidades"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000851/2025-26/CT06> a ns1:Competency ;
    ns1:competencyCode "CT06" ;
    ns1:competencyDescription "Analizar adecuadamente la bibliografía y recopilar referencias en el área de la gestión e investigación del Patrimonio Cultura"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000851/2025-26/CT10> a ns1:Competency ;
    ns1:competencyCode "CT10" ;
    ns1:competencyDescription "Desarrollar una capacidad permanente de compromiso ético y de respeto, en lo que se refiere al bienestar de la ciudadanía y al medio ambiente"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000851/2025-26/RA108> a ns1:LearningResult ;
    ns1:learningResultCode "RA108" ;
    ns1:learningResultDescription "Conocer los procedimientos para investigar sobre economía, turismo y desarrollo en Patrimonio Cultural"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000851/2025-26/RA109> a ns1:LearningResult ;
    ns1:learningResultCode "RA109" ;
    ns1:learningResultDescription "Valorar la aportación económica del Patrimonio Cultural desde una perspectiva agregada, sectorial y local."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000851/2025-26/RA110> a ns1:LearningResult ;
    ns1:learningResultCode "RA110" ;
    ns1:learningResultDescription "Reconocer y manejar los instrumentos de análisis respecto a la aportación del Patrimonio Cultural a la actividad económica."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000851/2025-26/RA118> a ns1:LearningResult ;
    ns1:learningResultCode "RA118" ;
    ns1:learningResultDescription "Reconocer los mecanismos de financiación utilizados en la gestión del Patrimonio Cultural."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000851/2025-26/RA119> a ns1:LearningResult ;
    ns1:learningResultCode "RA119" ;
    ns1:learningResultDescription "Innovar en el uso de los instrumentos de financiación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000851/2025-26/RA120> a ns1:LearningResult ;
    ns1:learningResultCode "RA120" ;
    ns1:learningResultDescription "Manejar de los sistemas de planificación turística y de su incidencia económica y patrimonial en los bienes culturales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000851/2025-26/RA121> a ns1:LearningResult ;
    ns1:learningResultCode "RA121" ;
    ns1:learningResultDescription "Reconocer los mecanismos e instituciones de cooperación al desarrollo aplicados al ámbito del Patrimonio Cultural."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000851/2025-26/RA122> a ns1:LearningResult ;
    ns1:learningResultCode "RA122" ;
    ns1:learningResultDescription "Identificar los principios básicos del manejo turístico del patrimonio, a nivel de planificación y gestión."@es .

