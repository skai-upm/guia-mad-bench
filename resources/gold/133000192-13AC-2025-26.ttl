    schema:courseCode 133000192 ;
    schema:hasCourseInstance <https://guia-kg.skai.etsisi.upm.es/resource/133000192/2025-26> ;
    schema:name "Water Reuse"@en,
        "Reutilizacion de Aguas"@es ;
    schema:numberOfCredits 3.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/133000192/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/133000192/2025-26/CB07>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000192/2025-26/CB09>,
