        <https://guia-kg.skai.etsisi.upm.es/resource/205000057/2025-26/RA349> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/205000057/2025-26/syllabus> ;
    ns1:inpersonHours "50 horas (48.1%)"@es ;
    ns1:numberOfCredits 4.0 ;
    ns1:otherInformation """Durante el semestre y en horario de clase, diferentes expertos impartirán seminarios ajustados al temario propuesto y por tanto evaluable; el Profesor Emérito de la ETSIAAB Miguel Ángel Toro será uno de ellos.
Esta asignatura está relacionada con el ODS15 (Objetivo de Desarrollo Sostenible).
La Comisión de Calidad del Centro en su reunión del 29 de mayo de 2023 acordó aprobar la propuesta de reasignación de competencias transversales en las asignaturas del Grado de Ciencias Agrarias y Bioeconomía. En virtud de dicho acuerdo esta asignatura ha sido designada como ?Asignatura NO Punto de Control?. Esto significa que si bien puede seguir considerando una o varias competencias transversales que se trabajan en distintos puntos y aspectos de la asignatura, dicha formación y evaluación no será objeto de recopilación de evidencias por los sistemas de acreditación de la calidad del Centro."""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "52 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/205000057/2025-26/eventSchedule> ;
    schema:description """El objetivo de la asignatura es mostrar la importancia de un correcto uso de la genética en la competitividad económica de un animal, raza, explotación, región o país. El alumno adquiere conocimientos para asesorar y/o evaluar si un programa de mejora genética es apropiado.
El alumno adquiere criterios para emplearlo en su vida profesional aunque no sea la mejora genética animal su especialidad. Se espera que adquiera conocimientos para evaluar la importancia de los futuros retos tanto económicos como metodológicos y las acciones a realizar.
Además se ampliarán conocimiento dentro de la Mejora Genética Animal."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/nora.formosorafferty%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/nora.formosorafferty%40upm.es> ;
    schema:name "Mejora Genética Animal"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000057/2025-26/CG05> a ns1:Competency ;
    ns1:competencyCode "CG05" ;
    ns1:competencyDescription "Adquirir la formación profesional necesaria para cubrir la demanda de las empresas del sector agrario (semillas, fitosanitarios, fertilizantes, alimentación animal, etc), del sector público relacionado, y para el acceso a estudios de postgrado del área."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000057/2025-26/CT06> a ns1:Competency ;
    ns1:competencyCode "CT06" ;
    ns1:competencyDescription "Capacidad para organizar y planificar proyectos, experimentos y, en general, trabajos de índole profesional."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000057/2025-26/RA1> a ns1:LearningResult ;
    ns1:learningResultCode "RA1" ;
    ns1:learningResultDescription "Establecer relaciones funcionales entre dos variables en el contexto de los biosistemas agrarios y la bioeconomía."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000057/2025-26/RA310> a ns1:LearningResult ;
    ns1:learningResultCode "RA310" ;
    ns1:learningResultDescription "Analizar el efecto de distintos factores intrínsecos (raza, sexo, edad..) y extrínsecos (alojamientos, ambiente) en las necesidades nutritivas y en la productividad de los rumiantes"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000057/2025-26/RA313> a ns1:LearningResult ;
    ns1:learningResultCode "RA313" ;
    ns1:learningResultDescription "Conocer y comprender los métodos básicos de mejora genética"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000057/2025-26/RA314> a ns1:LearningResult ;
    ns1:learningResultCode "RA314" ;
    ns1:learningResultDescription "Conocer el procedimiento de análisis genealógico y aplicarlo a una especie doméstica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000057/2025-26/RA316> a ns1:LearningResult ;
    ns1:learningResultCode "RA316" ;
    ns1:learningResultDescription "Estimar los parámetros genéticos para un carácter de interés económico de una especie ganadera"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000057/2025-26/RA318> a ns1:LearningResult ;
    ns1:learningResultCode "RA318" ;
    ns1:learningResultDescription "Conocer y aplicar el análisis de la estructura de costes a la explotación del ganado vacuno, ovino y caprino para identificar los principales caracteres que determinan la rentabilidad de una explotación ganadera y que son susceptibles de mejorar."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000057/2025-26/RA319> a ns1:LearningResult ;
    ns1:learningResultCode "RA319" ;
    ns1:learningResultDescription "Análisis crítico de un programa de mejora genética real aplicado en España"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000057/2025-26/RA320> a ns1:LearningResult ;
    ns1:learningResultCode "RA320" ;
    ns1:learningResultDescription "Análisis crítico de un programa de conservación de una raza autóctona"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000057/2025-26/RA321> a ns1:LearningResult ;
    ns1:learningResultCode "RA321" ;
    ns1:learningResultDescription "Aplicar programas informáticos para implementar la selección genómica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000057/2025-26/RA322> a ns1:LearningResult ;
    ns1:learningResultCode "RA322" ;
    ns1:learningResultDescription "Capacidad de diseñar y evaluar programas de mejora genética y llevarlos a la práctica."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000057/2025-26/RA348> a ns1:LearningResult ;
    ns1:learningResultCode "RA348" ;
    ns1:learningResultDescription "Comprender el interés de genes que afectan a los caracteres productivos en la ganadería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000057/2025-26/RA349> a ns1:LearningResult ;
    ns1:learningResultCode "RA349" ;
    ns1:learningResultDescription "Comprender como se integra la información molecular en los programas de mejora genética de animales domésticos"@es .

