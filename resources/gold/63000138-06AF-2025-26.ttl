    schema:name "Modelizacion II: Dinamica de Estructuras y Petroquimica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000138/2025-26/CE01> a ns1:Competency ;
    ns1:competencyCode "CE01" ;
    ns1:competencyDescription "Capacidad para abordar y resolver problemas matemáticos avanzados de ingeniería, desde el planteamiento del problema hasta el desarrollo de la formulación y su implementación en un programa de ordenador. En particular, capacidad para formular, programar y aplicar modelos analíticos y numéricos avanzados de cálculo, proyectos, planificación y gestión, así como capacidad para la interpretación de los resultados obtenidos, en el contexto de la ingeniería de minas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000138/2025-26/CE02> a ns1:Competency ;
    ns1:competencyCode "CE02" ;
    ns1:competencyDescription "Conocimiento adecuado de aspectos científicos y tecnológicos de mecánica de fluidos, mecánica de medios continuos, cálculo de estructuras, geotecnia, carboquímica y petroquímica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000138/2025-26/CE04> a ns1:Competency ;
    ns1:competencyCode "CE04" ;
    ns1:competencyDescription "Conocimiento adecuado de modelización, evaluación y gestión de recursos geológicos, incluidas las aguas subterráneas, minerales y termales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000138/2025-26/CG01> a ns1:Competency ;
    ns1:competencyCode "CG01" ;
    ns1:competencyDescription "Capacitación científico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000138/2025-26/CG04> a ns1:Competency ;
    ns1:competencyCode "CG04" ;
    ns1:competencyDescription "Conocimiento de la profesión de Ingeniero de Minas y de las actividades que se puedan realizar en el ámbito de la misma"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000138/2025-26/CG06> a ns1:Competency ;
    ns1:competencyCode "CG06" ;
    ns1:competencyDescription "Capacidad para la exploración, investigación, modelización y evaluación de yacimientos de recursos geológicos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000138/2025-26/CG18> a ns1:Competency ;
    ns1:competencyCode "CG18" ;
    ns1:competencyDescription "Conocimientos adecuados de los aspectos científicos y tecnológicos de métodos matemáticos, analíticos y numéricos de la ingeniería, mecánica de fluidos, mecánica de medios continuos, cálculo de estructuras, carboquímica, petroquímica y geotecnia"@es .

