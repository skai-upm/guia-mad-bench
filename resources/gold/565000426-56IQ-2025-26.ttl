<https://guia-kg.skai.etsisi.upm.es/resource/565000426/2025-26/syllabus> a ns1:Syllabus ;
    ns1:hasItem <https://guia-kg.skai.etsisi.upm.es/resource/565000426/2025-26/syllabus/0>,
        <https://guia-kg.skai.etsisi.upm.es/resource/565000426/2025-26/syllabus/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/565000426/2025-26/syllabus/2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/565000426/2025-26/syllabus/3>,
        <https://guia-kg.skai.etsisi.upm.es/resource/565000426/2025-26/syllabus/4>,
        <https://guia-kg.skai.etsisi.upm.es/resource/565000426/2025-26/syllabus/5>,
        <https://guia-kg.skai.etsisi.upm.es/resource/565000426/2025-26/syllabus/6>,
        <https://guia-kg.skai.etsisi.upm.es/resource/565000426/2025-26/syllabus/7>,
        <https://guia-kg.skai.etsisi.upm.es/resource/565000426/2025-26/syllabus/8> .

<https://guia-kg.skai.etsisi.upm.es/resource/565000426/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Conceptos Fundamentales en Ingeniería Química"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000426/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Introducción a los cálculos en Ingeniería Química. Convenciones para los métodos de análisis y medición. Elección de una base de cálculo. La ecuación química. Conversión, selectividad y rendimiento. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000426/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Introducción a los fenómenos de transporte. Mecanismos de los transportes molecular y turbulento. Ecuaciones cinéticas en transporte molecular. Clasificación de los fluidos. Transporte turbulento: coeficientes de transporte. Capa límite. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000426/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "2. Operaciones Básicas y Diagramas de flujo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000426/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "2.1. Procesos químicos y sus operaciones básicas. Estrategia de sistemas. Cambios de escala en los procesos químicos. Análisis económico preliminar de una opción de proceso. Control de los procesos químicos. Fuentes de energía en los procesos químicos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000426/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "2.2. Diagramas de flujo. Simbología e interpretación. Etiquetación. Escalamiento. Diferentes tipos de diagramas de flujo: Diagramas de bloques o cajas, Diagramas con equipos, Diagramas de instrumentación. Diagrama de ingeniería de flujo. Planos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000426/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "3. Balances macroscópicos de materia y de energía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000426/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "3.1. Balances macroscópicos de materia. Ecuación general de conservación de cualquier propiedad extensiva. Balances de materia macroscópicos en régimen estacionario en operaciones sin reacción química y con reacción química. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000426/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "3.2. Balances macroscópicos de energía. Principio de conservación de la energía. Balances de energía macroscópicos. Balances entálpicos. Balances macroscópicos de energía en régimen estacionario. Combustibles y combustión. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/56IQ%20-%20Grado%20en%20Ingenier%C3%ADa%20Qu%C3%ADmica> a ns1:BachelorDegree ;
    ns1:degreeCode "56IQ"@es ;
    ns1:hasCourse <https://guia-kg.skai.etsisi.upm.es/resource/565000426> ;
    schema:name "Grado en Ingeniería Química"@es .

