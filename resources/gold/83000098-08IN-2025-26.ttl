<https://guia-kg.skai.etsisi.upm.es/resource/83000098/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. PARTE 1. EL ESTADO ACTUAL"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/83000098/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Introducción: Análisis preliminar de un caso de referencia relevante en el sector de la construcción naval en España: el caso Armón. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/83000098/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "2. PARTE 2. EL FUTURO"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/83000098/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "2.1. Estado del arte de Marine Digital Manufacturing Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/83000098/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "2.2. Teoría de eventos discretos orientada a la simulación. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/83000098/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "2.3. Herramientas para simulación de eventos discretos. Siemens Tecnomatix Plant Simulation. Casos básicos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/83000098/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "2.4. Introducción a conceptos avanzados de ingeniería de procesos: lean manufacturing, takt time. Aplicaciones al sector naval. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/83000098/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "2.5. Herramientas para simulación de eventos discretos. Siemens Tecnomatix Plant Simulation. Casos de estudio en construcción naval convencional. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/83000098/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "2.6. Herramientas para simulación de eventos discretos. Siemens Tecnomatix Plant Simulation. Casos de estudio para construcción de yates a vela y/o motor. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/83000098/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Procesos en Construcción Naval Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/83000098/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "1.3. Orden de trabajo/fabricación y Valor hora. El proceso de control de obra. EVMS Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/83000098/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "1.4. Otros modelos operacionales en España en detalle. Particularización a esos modelos del esquema general del tema 1.2. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/83000098/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "1.5. Reparaciones. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/83000098/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "1.6. Modelos operacionales a nivel internacional. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/83000098/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "1.7. Caso particular de yates, megayates y buques especiales. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/83000098/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "1.8. Ing. procesos frente a ing. sistemas. Ing. Naval militar. El caso Navantia. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/83000098/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "1.9. Visita a alguna empresa relevante: preparación y análisis. Sin subniveles"@es .

