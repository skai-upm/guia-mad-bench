    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/115100074/2025-26/eventSchedule> ;
    schema:description "La asignatura tiene un carácter eminentemente práctico para la aplicación de conceptos biomecánicos y de control motor para la mejora del rendimiento técnico. Para ello se apoya en diferentes técnicas de análisis de vídeo y explora los procesos de evaluación y corrección de la técnica deportiva."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/enrique.navarro%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/archit.navandar%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/enrique.navarro%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/javier.ruedao%40upm.es> ;
    schema:name "Entrenamiento y Optimización de la Técnica Deportiva"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100074/2025-26/CE02> a ns1:Competency ;
    ns1:competencyCode "CE02" ;
    ns1:competencyDescription "Aplicar, de manera fundamentada y argumentada, los principios fisiológicos, biomecánicos, comportamentales y sociales en el diseño y puesta en práctica de propuestas y programas de Educación Física en el contexto educativo. Nivel 3."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100074/2025-26/CE07> a ns1:Competency ;
    ns1:competencyCode "CE07" ;
    ns1:competencyDescription "Planificar, desarrollar y evaluar la realización de programas y procesos de entrenamiento deportivo en sus distintos niveles. Nivel 3."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100074/2025-26/CE08> a ns1:Competency ;
    ns1:competencyCode "CE08" ;
    ns1:competencyDescription "Aplicar de manera fundamentada y argumentada los principios fisiológicos, biomecánicos, comportamentales y sociales, durante la dirección del entrenamiento deportivo. Nivel 3."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100074/2025-26/CE13> a ns1:Competency ;
    ns1:competencyCode "CE13" ;
    ns1:competencyDescription "Aplicar, de manera fundamentada y argumentada, los principios fisiológicos, biomecánicos, comportamentales y sociales al campo de la actividad física y salud. Nivel 3."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100074/2025-26/CG02> a ns1:Competency ;
    ns1:competencyCode "CG02" ;
    ns1:competencyDescription "Desarrollar habilidades y estrategias que incidan en la capacidad para trabajar en forma autónoma."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100074/2025-26/CG03> a ns1:Competency ;
    ns1:competencyCode "CG03" ;
    ns1:competencyDescription "Organizar y planificar propuestas de acción, programas y actividades propias de su campo profesional en sus diferentes ámbitos de aplicación y desarrollo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100074/2025-26/CG08> a ns1:Competency ;
    ns1:competencyCode "CG08" ;
    ns1:competencyDescription "Aplicar los conocimientos adquiridos en los procesos de formación en la práctica profesional, en diferentes contextos y situaciones."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100074/2025-26/CG09> a ns1:Competency ;
