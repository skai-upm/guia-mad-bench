        <https://guia-kg.skai.etsisi.upm.es/resource/roberto.cangas%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/sergio.catalan.gomez%40upm.es> ;
    schema:name "Física II"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000223/2025-26/CE2> a ns1:Competency ;
    ns1:competencyCode "CE2" ;
    ns1:competencyDescription "Comprensión y dominio de los conceptos básicos sobre las leyes generales de la mecánica, termodinámica, campos y ondas y electromagnetismo y su aplicación para la resolución de problemas propios de la ingeniería."@es .

