<https://guia-kg.skai.etsisi.upm.es/resource/85003611/2025-26/CB5> a ns1:Competency ;
    ns1:competencyCode "CB5" ;
    ns1:competencyDescription "Que los estudiantes hayan desarrollado aquellas habilidades de aprendizaje necesarias para emprender estudios posteriores con un alto grado de autonomía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003611/2025-26/CE%2016> a ns1:Competency ;
    ns1:competencyCode "CE 16" ;
    ns1:competencyDescription "Capacidad para la realización del cálculo y control de vibraciones y ruidos a bordo de buques y artefactos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003611/2025-26/CE%202> a ns1:Competency ;
    ns1:competencyCode "CE 2" ;
    ns1:competencyDescription "Comprensión y dominio de los conceptos básicos sobre las leyes generales de la mecánica, termodinámica, campos y ondas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003611/2025-26/CG5> a ns1:Competency ;
    ns1:competencyCode "CG5" ;
    ns1:competencyDescription "Capacidad para la realización de mediciones, cálculos, valoraciones, tasaciones, peritaciones, estudios, informes, planos de labores y otros trabajos análogos en el ámbito de la Arquitectura Naval."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003611/2025-26/RA17> a ns1:LearningResult ;
    ns1:learningResultCode "RA17" ;
    ns1:learningResultDescription "Plantear y resolver las ecuaciones fundamentales de las oscilaciones armónicas, libres, amortiguadas y forzadas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003611/2025-26/RA177> a ns1:LearningResult ;
    ns1:learningResultCode "RA177" ;
    ns1:learningResultDescription "Conocer la ecuación fundamental de la dinámica y su aplicación a modelos MDF"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003611/2025-26/RA178> a ns1:LearningResult ;
    ns1:learningResultCode "RA178" ;
    ns1:learningResultDescription "Conocer las fuentes de ruido a bordo, su análisis y control"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003611/2025-26/RA18> a ns1:LearningResult ;
    ns1:learningResultCode "RA18" ;
    ns1:learningResultDescription "Comprender y aplicar los conceptos fundamentales de las ondas a situaciones de interés en ingeniería."@es .

