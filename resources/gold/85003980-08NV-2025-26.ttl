<https://guia-kg.skai.etsisi.upm.es/resource/85003980/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Probabilidad."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003980/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Definiciones básicas y simulaciones con números aleatorios. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003980/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "2.3. Inferencia bayesiana. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003980/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "2.4. Regresión lineal. Interpolación vs extrapolación. Interpretación de los coeficientes. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003980/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "2.5. Regresión lineal múltiple. Selección de modelos. Correlación vs causalidad. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003980/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "2.6. Regresión no lineal. Sobreajuste. Conjuntos de entrenamiento y validación. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003980/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Teorema de la probabilidad total, probabilidad condicionada, independencia de sucesos, teorema de Bayes. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003980/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "1.3. Variables aleatorias discretas: esperanza y probabilidades; simulación vs cálculo exacto. Distribuciones Uniforme, de Bernoulli, Binomial, Geométrica, Poisson. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003980/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "1.4. Variables aleatorias continuas: esperanza y probabilidades; simulación versus cálculo exacto. Distribución Uniforme, Normal, Gamma. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003980/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "1.5. Distribuciones de probabilidad multivariable: Uniforme y Normal Multivariable. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003980/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "1.6. Ley de los Grandes Números y Teorema Central del límite Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003980/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "2. Estadística."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003980/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "2.1. Análisis exploratorio. Representación gráfica de datos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003980/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "2.2. Estimación de parámetros por máxima verosimilitud Sin subniveles"@es .

