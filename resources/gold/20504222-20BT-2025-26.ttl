    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/20504222/2025-26/syllabus> ;
    ns1:inpersonHours "64 horas y 50 minutos (41.6%)"@es ;
    ns1:numberOfCredits 6.0 ;
    ns1:otherInformation """La asignatura forma parte del Proyecto 'Desarrollo de Pensamiento Crítico y Capacidades en IA mediante Aulas Inversas en el Contexto de la Empresa Agroalimentaria', No. IE25.2006, de la Universidad Politécnica de Madrid, y del Proyecto FAMA (FAcilitando la comunicación efectiva para la Mejora de la enseñanzA), No. IE25.2010, de la Universidad Politécnica de Madrid.
La asignatura trabaja los Objetivos de Desarrollo Sostenible (ODS) establecidos por Naciones Unidas; en particular, se relaciona con los ODS 12 y 13."""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "64 horas y 50 minutos"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/20504222/2025-26/eventSchedule> ;
    schema:description "El objetivo general de la asignatura es que el alumnado adquiera una visión general e introductoria sobre la economía, y conozca y comprenda la empresa como unidad económica fundamental. Los conocimientos que se desarrollan a lo largo del curso pretenden proporcionar al futuro egresado una idea sobre cómo debe gestionarse una empresa en cada una de las áreas funcionales de las que se compone. De esta forma, podrán entender y comprender los conceptos básicos relativos a la administración empresarial, muy útiles para su vida profesional."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/paloma.esteve%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/cristina.lopezcozar%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/paloma.esteve%40upm.es> ;
    schema:name "Economía y Gestión de Empresas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504222/2025-26/CE14> a ns1:Competency ;
    ns1:competencyCode "CE14" ;
    ns1:competencyDescription "Ser capaz de conocer los aspectos básicos de gestión empresarial y los distintos tipos de empresas biotecnológicas, su gestión y su importancia económica, así como los diferentes métodos y técnicas de apoyo existentes."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504222/2025-26/CG08> a ns1:Competency ;
    ns1:competencyCode "CG08" ;
    ns1:competencyDescription "Adquirir la formación profesional en los aspectos básicos de la legislación, gestión y comercialización de los productos y servicios biotecnológicos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504222/2025-26/RA58> a ns1:LearningResult ;
    ns1:learningResultCode "RA58" ;
    ns1:learningResultDescription "Conocer aspectos de matemáticas financieras, criterios económicos de elección, etc."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504222/2025-26/RA59> a ns1:LearningResult ;
    ns1:learningResultCode "RA59" ;
    ns1:learningResultDescription "Tener claros los fundamentos de economía, con especial atención a las características de las empresas biotecnológicas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504222/2025-26/RA60> a ns1:LearningResult ;
    ns1:learningResultCode "RA60" ;
    ns1:learningResultDescription "Tener conocimientos básicos relacionados con la dirección de la empresa y de los distintos subsistemas empresariales, en particular el productivo y el comercial, presentando distintos métodos y técnicas de apoyo a la gestión"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504222/2025-26/RA61> a ns1:LearningResult ;
    ns1:learningResultCode "RA61" ;
    ns1:learningResultDescription "Saber elegir entre distintas alternativas y conocer como se realiza un plan de empresa"@es .

