    ns1:learningResultCode "RA143" ;
    ns1:learningResultDescription "Trabajar de forma autónoma y con iniciativa personal."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000367/2025-26/RA144> a ns1:LearningResult ;
