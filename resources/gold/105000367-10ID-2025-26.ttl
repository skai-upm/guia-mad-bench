        <https://guia-kg.skai.etsisi.upm.es/resource/105000367/2025-26/didactic_resource/9> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/105000367/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/105000367/2025-26/RA141>,
        <https://guia-kg.skai.etsisi.upm.es/resource/105000367/2025-26/RA142>,
        <https://guia-kg.skai.etsisi.upm.es/resource/105000367/2025-26/RA143>,
        <https://guia-kg.skai.etsisi.upm.es/resource/105000367/2025-26/RA144>,
        <https://guia-kg.skai.etsisi.upm.es/resource/105000367/2025-26/RA145> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/105000367/2025-26/syllabus> ;
    ns1:inpersonHours "65 horas (41.7%)"@es ;
    ns1:numberOfCredits 6.0 ;
    ns1:otherInformation """La asignatura se relaciona con los ODS 1, 4, 8, 9, 10 y 12
Esta asignatura está en proceso de implantación de actividades de innovación educativa consistentes en una gamificación en varias fases que comprende aproximadamente el 50% de la evaluación global del curso."""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "65 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/105000367/2025-26/eventSchedule> ;
    schema:description """Esta asignatura tiene como objetivo fundamental profundizar en el aprendizaje del análisis microeconómico, dominar sus modelos básicos y ejercitarse en el análisis e interpretación de los fenómenos económicos usando modelos sencillos y la teoría básica microeconómica.
En concreto, la asignatura aborda aspectos fundamentales de la teoría microeconómica (el problema del consumidor individual, el problema del productor, eficiencia y excedentes, competencia perfecta y otras estructuras de mercado, ejemplos de estática comparativa y fallos de mercado) y adopta un enfoque teórico-práctico, destacando la importancia y aplicación de la teoría microeconómica tanto en las decisiones empresariales como en las decisiones de política económica."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/raul.g.sanchis%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/raul.g.sanchis%40upm.es> ;
    schema:name "Microeconomía"@es .

