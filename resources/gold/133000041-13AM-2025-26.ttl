<https://guia-kg.skai.etsisi.upm.es/resource/133000041> a ns1:Course ;
    ns1:courseType "Obligatoria"@es ;
    ns1:courseYear 1 ;
    ns1:semester "Primer semestre"@es ;
    schema:courseCode 133000041 ;
    schema:hasCourseInstance <https://guia-kg.skai.etsisi.upm.es/resource/133000041/2025-26> ;
    schema:name "Water Quality Index And Models"@en,
        "Indices y Modelos de Calidad de Agua"@es ;
    schema:numberOfCredits 3.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/133000041/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/133000041/2025-26/CB6>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000041/2025-26/CE2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000041/2025-26/CE4>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000041/2025-26/CG4> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/133000041/2025-26/didactic_resource/1> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/133000041/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/133000041/2025-26/RA14>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000041/2025-26/RA15>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000041/2025-26/RA16>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000041/2025-26/RA61>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000041/2025-26/RA62>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000041/2025-26/RA63>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000041/2025-26/RA64>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000041/2025-26/RA76> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/133000041/2025-26/syllabus> ;
    ns1:inpersonHours "30 horas (38.5%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation """Esta asignatura iniciará su impartición de acuerdo con el calendario escolar aprobado por el centro con un esquema de presencialidad definido.
Las competencias y los resultados de aprendizaje de esta asignatura son conformes con la memoria verifica del título.
ODS: la asignatura está directamente relacionada con el ODS 6 "Agua limpia y Saneamiento\""""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "30 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/133000041/2025-26/eventSchedule> ;
    schema:description """Tema 1: Conceptos Básicos en Calidad del agua: parámetro, Indicador, índice.
Tema 2: Fuentes de Información de Calidad del agua: Tipos de Datos. Muestreo, frecuencia y tamaño de muestra. Sensores remotos.
Tema 3: Análisis Exploratorio de Datos de Calidad del agua.
B Tema 4: Modelización de Datos de Calidad del agua.
Tema 5: Elaboración de Indices de Calidad del Agua.
Tema 6: Herramientas de Big Data e Inteligencia Artificial en Calidad del agua.
Tema 7: Modelos de Simulación de Calidad del Agua."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/esperanza.ayuga%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/carolina.echavarria%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/concepcion.gonzalez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/esperanza.ayuga%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/mariajesus.garcia.garcia%40upm.es> ;
    schema:name "Indices y Modelos de Calidad de Agua"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000041/2025-26/CB6> a ns1:Competency ;
    ns1:competencyCode "CB6" ;
    ns1:competencyDescription "Poseer y comprender conocimientos que aporten una base u oportunidad de ser originales en el desarrollo y/o aplicación de ideas, a menudo en un contexto de investigación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000041/2025-26/CE2> a ns1:Competency ;
    ns1:competencyCode "CE2" ;
    ns1:competencyDescription "Conocer y aplicar los indicadores utilizados para caracterizar el estado físico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000041/2025-26/CE4> a ns1:Competency ;
    ns1:competencyCode "CE4" ;
    ns1:competencyDescription "Conocer y aplicar los modelos utilizados para la simulación de la calidad del agua en ámbitos fluviales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000041/2025-26/CG4> a ns1:Competency ;
    ns1:competencyCode "CG4" ;
    ns1:competencyDescription "Capacidad para integrar los aspectos sociales, culturales y ambientales del agua y los ecosistemas vinculados, en los proyectos de planificación, gestión y rehabilitación de recursos hídricos y sistemas acuáticos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000041/2025-26/RA14> a ns1:LearningResult ;
    ns1:learningResultCode "RA14" ;
    ns1:learningResultDescription "Conocer las características, efectos y técnicas de análisis de los principales contaminantes físicos, químicos y biológicos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000041/2025-26/RA15> a ns1:LearningResult ;
    ns1:learningResultCode "RA15" ;
    ns1:learningResultDescription "Conocer los indicadores utilizados para la determinación de la calidad de un agua, diferenciando entre parámetros e índices, la forma de obtenerlos, así como su aplicación e interpretación de sus valores"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000041/2025-26/RA16> a ns1:LearningResult ;
    ns1:learningResultCode "RA16" ;
    ns1:learningResultDescription "Conocer del modelo QUAL2K, para su aplicación e interpretación de resultados"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000041/2025-26/RA61> a ns1:LearningResult ;
    ns1:learningResultCode "RA61" ;
    ns1:learningResultDescription "Exponer y defender públicamente el trabajo realizado, apoyándose en las nuevas tecnologías disponibles para la presentación de ideas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000041/2025-26/RA62> a ns1:LearningResult ;
    ns1:learningResultCode "RA62" ;
    ns1:learningResultDescription "Conocer marco Normativo sobre calidad del agua."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000041/2025-26/RA63> a ns1:LearningResult ;
    ns1:learningResultCode "RA63" ;
    ns1:learningResultDescription "Conocer los indicadores y su aplicación para el uso y gestión del agua en el medio natural."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000041/2025-26/RA64> a ns1:LearningResult ;
    ns1:learningResultCode "RA64" ;
    ns1:learningResultDescription "Conocer índices establecidos y métodos para su cálculo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000041/2025-26/RA76> a ns1:LearningResult ;
    ns1:learningResultCode "RA76" ;
    ns1:learningResultDescription "Conocer los fundamentos de los modelos de calidad de aguas, para su aplicación, interpretación y análisis en ejemplos prácticos sencillos."@es .

