    schema:description "La asignatura está enfocada para que los alumnos adquieran conocimientos técnicos y científicos sobre los materiales objeto de la asignatura y su relación y uso en construcción."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/c.porras%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/alejandro.pedreno%40upm.es>,
