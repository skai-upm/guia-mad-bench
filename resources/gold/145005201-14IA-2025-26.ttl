    ns1:itemIndex 11 ;
    ns1:syllabusDescription "4.3. Deformaciones y tensiones en Placas y Láminas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005201/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "4.4. Soluciones de la Placa de Navier y de Levi Nadai. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005201/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "4.5. Soluciones de Rayleigh-Ritz para placas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005201/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "4.6. Teoría fundamental en Láminas y Membranas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005201/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "5. PLASTICIDAD DEL SÓLIDO."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005201/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "5.1. Curva de comportamiento elastoplástico. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005201/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "5.2. Endurecimiento isótropo y cinemático. Efectos Bausschinger y Masing. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005201/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "5.3. El espacio de tensiones de Haigh-Westergaard. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005201/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "5.4. Criterios de plastificación. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005201/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "2.1. Álgebra tensorial. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005201/2025-26/syllabus/20> a ns1:SyllabusItem ;
    ns1:itemIndex 20 ;
    ns1:syllabusDescription "5.5. Teoría incremental de la elastoplasticidad unidimensional. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005201/2025-26/syllabus/21> a ns1:SyllabusItem ;
    ns1:itemIndex 21 ;
    ns1:syllabusDescription "5.6. Teoría incremental de la elastoplasticidad tridimensional. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005201/2025-26/syllabus/22> a ns1:SyllabusItem ;
    ns1:itemIndex 22 ;
    ns1:syllabusDescription "6. FRACTURA, FATIGA Y DAÑO."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005201/2025-26/syllabus/23> a ns1:SyllabusItem ;
    ns1:itemIndex 23 ;
    ns1:syllabusDescription "6.1. Introducción a la Mecánica de la Fractura: Motivación histórica e ingenieril. Teoría energética de Griffith. Aproximación tensional de Irwin. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005201/2025-26/syllabus/24> a ns1:SyllabusItem ;
    ns1:itemIndex 24 ;
    ns1:syllabusDescription "6.2. Introducción a la fatiga y vida útil. Crecimiento subcrítico de fisuras: Lay de Paris. Daño acumulativo: regla de Palgreem-Miner. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005201/2025-26/syllabus/25> a ns1:SyllabusItem ;
    ns1:itemIndex 25 ;
    ns1:syllabusDescription "6.3. Introducción a la Mecánica del Daño Continuo: Concepto de daño isótropo. RVE y variable de daño. Tensión y deformación efectiva. Principios de equivalencia. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005201/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "2.2. Cálculo tensorial. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005201/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "3. ELASTICIDAD LINEAL ISÓTROPA Y ANISÓTROPA."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005201/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "3.1. Repaso de la elasticidad lineal: tensor de deformaciones y tensor de tensiones. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005201/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "3.2. Elasticidad plana: tensión plana y deformación plana. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005201/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "3.3. Comportamiento elástico isótropo y anisótropo. Constantes elásticas de un material anisótropo. Simetrías. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005201/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "4. PLACAS y LÁMINAS"@es .

