<https://guia-kg.skai.etsisi.upm.es/resource/43000687/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/43000687/2025-26/CG1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000687/2025-26/CG3>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000687/2025-26/CG5>,
