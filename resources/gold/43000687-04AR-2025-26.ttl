        <https://guia-kg.skai.etsisi.upm.es/resource/43000687/2025-26/SK3> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/43000687/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000687/2025-26/didactic_resource/2> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/43000687/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/43000687/2025-26/RA13> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/43000687/2025-26/syllabus> ;
    ns1:inpersonHours "40 horas y 50 minutos (50.4%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation """La asignatura Metodología Científica se imparte a través de un sistema b-learning, incluyendo actividades presenciales desarrolladas en el aula y actividades desarrolladas fuera del aula sin la presencia del profesor, como el trabajo autónomo y la realización de trabajos que se entregarán a través de la plataforma Moodle (https://moodle.upm.es/titulaciones/oficiales/). Además, a través de esta plataforma, el estudiante podrá acceder a material de apoyo para el estudio como documentación, cuestionarios, foros, etc.
La asignatura está relacionada con el Objetivo de Desarrollo Sostenible (ODS) número 9 (Industria, Innovación e Infraestructuras), en concreto con la meta 9.5 de este objetivo, que versa sobre lo siguiente: "Aumentar la investigación científica y mejorar la capacidad tecnológica de los sectores industriales de todos los países, en particular los países en desarrollo, entre otras cosas fomentando la innovación y aumentando considerablemente, de aquí a 2030, el número de personas que trabajan en investigación y desarrollo por millón de habitantes y los gastos de los sectores público y privado en investigación y desarrollo"."""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "40 horas y 50 minutos"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/43000687/2025-26/eventSchedule> ;
    schema:description "La asignatura de Metodología Científica tiene como objetivo que el alumno aprenda técnicas y métodos de investigación científica, tales como la búsqueda de información científico-técnica en bases de datos nacionales e internacionales y otras fuentes fiables; la redacción de documentos científico-técnicos; el desarrollo de destrezas en el empleo de herramientas TIC aplicadas a la investigación; la elaboración de propuestas de proyectos de investigación, etc. Los conocimientos y destrezas adquiridas por los estudiantes podrán ser aplicados tanto para el desarrollo del trabajo fin de máster, como para cualquier tipo de actividad de investigación, desarrollo e innovación."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/marian.quijano%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/araceli.martin%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/beatriz.cabau%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/daniel.fernandezm%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/ji.perez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/jorge.bernabeu%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/luis.pujol%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/marian.quijano%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/patricia.hlamas%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/stefanos.giannakis%40upm.es> ;
    schema:name "Metodología Científica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000687/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Poseer y comprender conocimientos que aporten una base u oportunidad de ser originales en el desarrollo y/o aplicación de ideas, a menudo en un contexto de investigación TIPO: Competencias."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000687/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Poseer las habilidades de aprendizaje que les permitan continuar estudiando de un modo que habrá de ser en gran medida autodirigido o autónomo TIPO: Competencias."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000687/2025-26/CG5> a ns1:Competency ;
    ns1:competencyCode "CG5" ;
    ns1:competencyDescription "Buscar bibliografía, analizar la información procedente de diversas fuentes y de su análisis y síntesis aplicarla a la resolución de problemas complejos, en el campo de la ingeniería hidráulica, energética o medioambiental TIPO: Competencias."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000687/2025-26/RA13> a ns1:LearningResult ;
    ns1:learningResultCode "RA13" ;
    ns1:learningResultDescription "Aplica las capacidades tecnicas y gestoras en actividades de I+D+i dentro del ambito de la ingenieria civil hidraulica, energetica o medioambiental"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000687/2025-26/SK1> a ns1:Competency ;
    ns1:competencyCode "SK1" ;
    ns1:competencyDescription "Aplicar las capacidades técnicas y gestoras en actividades de I+D+i dentro del ámbito de la ingeniería civil hidráulica, energética o medioambiental TIPO: Habilidades o destrezas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000687/2025-26/SK3> a ns1:Competency ;
    ns1:competencyCode "SK3" ;
    ns1:competencyDescription "Elaborar sus conclusiones, con los conocimientos y razones últimas que las sustentan, para presentarlas a públicos especializados y no especializados de un modo claro y sin Ambigüedades TIPO: Habilidades o destrezas."@es .

