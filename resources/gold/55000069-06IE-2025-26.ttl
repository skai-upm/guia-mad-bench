    ns1:bibliographyDescription "Material de curso de diseño y simulación empleando el método de los elementos finitos con distintos software aplicados a problemas de ingeniería mecánica."@es ;
    ns1:bibliographyTitle "Apuntes de la asignatura"@es ;
    ns1:bibliographyType "Bibliografía"@es .

