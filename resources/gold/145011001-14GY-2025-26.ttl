<https://guia-kg.skai.etsisi.upm.es/resource/145011001/2025-26/syllabus> a ns1:Syllabus ;
    ns1:hasItem <https://guia-kg.skai.etsisi.upm.es/resource/145011001/2025-26/syllabus/0>,
        <https://guia-kg.skai.etsisi.upm.es/resource/145011001/2025-26/syllabus/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/145011001/2025-26/syllabus/2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/145011001/2025-26/syllabus/3>,
        <https://guia-kg.skai.etsisi.upm.es/resource/145011001/2025-26/syllabus/4>,
        <https://guia-kg.skai.etsisi.upm.es/resource/145011001/2025-26/syllabus/5> .

<https://guia-kg.skai.etsisi.upm.es/resource/145011001/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Introducción. Objeto de la Física. Magnitudes y unidades. Dimensiones Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145011001/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "2. Movimiento unidimensional. Velocidad; velocidad relativa. Aceleración. Integración. Movimiento en dos y tres dimensiones. Movimiento parabólico Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145011001/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "3. El triedro Inercial. Leyes de Newton. Fuerzas de contacto. Fuerza normal y de rozamiento. Movimiento circular Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145011001/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "4. Trabajo mecánico. Energía cinética. Ecuación de la energía. Momento cinético. Leyes de Kepler Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145011001/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "5. Sistemas. Sólidos. Fuerzas interiores y exteriores. Centro de masas. Momento de inercia. Rotación. Rodadura Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145011001/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "6. Fluidos. Hidrostática. Ecuación de Bernoulli. Introducción a la Termodinámica. Primer principio: calor y trabajo. Teoría cinética de gases; temperatura. Procesos Térmodinámicos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/14GY%20-%20Grado%20en%20Gesti%C3%B3n%20y%20Operaciones%20del%20Transporte%20A%C3%A9reo> a ns1:BachelorDegree ;
    ns1:degreeCode "14GY"@es ;
    ns1:hasCourse <https://guia-kg.skai.etsisi.upm.es/resource/145011001> ;
    schema:name "Grado en Gestión y Operaciones del Transporte Aéreo"@es .

