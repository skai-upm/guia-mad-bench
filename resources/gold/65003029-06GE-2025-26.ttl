    ns1:otherInformation """La asignatura se centra en los siguientes Objetivos de Desarrollo Sostenible (ODS) establecidos por Naciones Unidas:
3. Salud y bienestar
4. Educación de calidad
5. Igualdad de género
9. Industria, innovación e infraestructura
17. Alianzas para lograr los objetivos"""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
