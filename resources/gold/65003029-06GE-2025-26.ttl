    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/65003029/2025-26/eventSchedule> ;
    schema:description """Estudio de la aplicación de la geotécnia en minería, construcción y obra civil, en suelos y rocas, para el diseño de cimentaciones, taludes y cavidades subterráneas (galerías, túneles, cavernas, etc.).
Conocer las tecnologias aplicables, como se seleccionan y su aplicación práctica para la construcción de las obras subteráneas,"""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/ricardo.lain%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/josemiguel.galera%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/mariajose.crespo%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/ricardo.lain%40upm.es> ;
    schema:name "Geotecnia y Obras Subterraneas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65003029/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Conocer y aplicar conocimientos de ciencias y tecnologías básicas a la práctica de la Ingeniería Geológica."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65003029/2025-26/CG10> a ns1:Competency ;
    ns1:competencyCode "CG10" ;
    ns1:competencyDescription "Creatividad."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65003029/2025-26/CG2> a ns1:Competency ;
    ns1:competencyCode "CG2" ;
    ns1:competencyDescription "Poseer capacidad para diseñar, desarrollar, implementar, gestionar y mejorar productos, sistemas y procesos en los distintos ámbitos geológicos, usando técnicas analíticas, computacionales o experimentales apropiadas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65003029/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Aplicar los conocimientos adquiridos para identificar, formular y resolver problemas dentro de contextos amplios y multidisciplinarios, siendo capaces de integrar conocimientos, trabajando en equipos multidisciplinares."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65003029/2025-26/CG4> a ns1:Competency ;
    ns1:competencyCode "CG4" ;
    ns1:competencyDescription "Comprender el impacto de la ingeniería geológica en el medio ambiente, el desarrollo sostenible de la sociedad y la importancia de trabajar en un entorno profesional y responsable."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65003029/2025-26/CG5> a ns1:Competency ;
    ns1:competencyCode "CG5" ;
    ns1:competencyDescription "Saber comunicar los conocimientos y conclusiones, tanto de forma oral, escrita y gráfica, a públicos especializados y no especializados de un modo claro y sin ambigüedades."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65003029/2025-26/CG6> a ns1:Competency ;
    ns1:competencyCode "CG6" ;
    ns1:competencyDescription "Poseer habilidades de aprendizaje que permitan continuar estudiando a lo largo de la vida para su adecuado desarrollo profesional."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65003029/2025-26/CG9> a ns1:Competency ;
    ns1:competencyCode "CG9" ;
    ns1:competencyDescription "Organización y planificación en el ámbito de la empresa, y otras instituciones y organizaciones de proyectos y equipos humanos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65003029/2025-26/F12> a ns1:Competency ;
    ns1:competencyCode "F12" ;
    ns1:competencyDescription "Conocimiento de geotecnia y mecánica de suelos y de rocas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65003029/2025-26/F23> a ns1:Competency ;
    ns1:competencyCode "F23" ;
    ns1:competencyDescription "Diseño, planificación y ejecución para prospección y extracción de minerales, rocas, combustibles fósiles y nucleares, aguas subterráneas y geotécnicos. Ídem para inyección de fluidos en estructuras subterráneas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65003029/2025-26/F24> a ns1:Competency ;
    ns1:competencyCode "F24" ;
    ns1:competencyDescription "Técnicas de perforación y sostenimiento aplicadas a obras subterráneas y superficiales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65003029/2025-26/F25> a ns1:Competency ;
    ns1:competencyCode "F25" ;
    ns1:competencyDescription "Ensayos mineralógicos, petrográficos y geotécnicos. Técnicas de muestreo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65003029/2025-26/F29> a ns1:Competency ;
