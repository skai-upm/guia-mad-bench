    ns1:inpersonHours "59 horas y 30 minutos (50.9%)"@es ;
    ns1:numberOfCredits 4.5 ;
    ns1:otherInformation """Los estudiantes dispondrán de los recursos didácticos de la asignatura a través en la plataforma Moodle de la universidad, que se utilizará también como medio de comunicación oficial entre el profesor y los alumnos.
Se fomentará el uso responsable de papel en la asignatura, por lo que la asignatura se relaciona con los ODS siguientes: ODS12 y ODS15."""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "59 horas y 30 minutos"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/55000056/2025-26/eventSchedule> ;
    schema:description """Se pretende dar una introducción a las técnicas matemáticas necesarias para valorar derivados financieros tales como contratos de futuros, opciones de distintos tipos sobre acciones y otros subyacentes etc.
Estos productos financieros han adquirido una importancia creciente en los últimos treinta años y los conocimientos básicos sobre su valoración son imprescindibles para todos aquellos alumnos que quieran trabajar en instituciones relacionadas con el tema."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/angeles.rincon%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/angeles.rincon%40upm.es> ;
    schema:name "Matematicas de la Especialidad Organizacion Industrial"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000056/2025-26/CE1> a ns1:Competency ;
    ns1:competencyCode "CE1" ;
    ns1:competencyDescription "Capacidad para la resolución de los problemas matemáticos que puedan plantearse en la ingeniería. Aptitud para aplicar los conocimientos sobre: álgebra lineal; geometría; geometría diferencial; cálculo diferencial e integral; ecuaciones diferenciales ordinarias y en derivadas parciales; métodos numéricos; algorítmica numérica; optimización"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000056/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Conocer y aplicar conocimientos de ciencias y tecnologías básicas a la práctica de la Ingeniería Industrial."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000056/2025-26/CG10> a ns1:Competency ;
    ns1:competencyCode "CG10" ;
    ns1:competencyDescription "Capacidad para generar nuevas ideas (Creatividad)."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000056/2025-26/CG2> a ns1:Competency ;
    ns1:competencyCode "CG2" ;
    ns1:competencyDescription "Poseer capacidad para diseñar, desarrollar, implementar, gestionar y mejorar productos, sistemas y procesos en los distintos ámbitos industriales, usando técnicas analíticas, computacionales o experimentales apropiadas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000056/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Aplicar los conocimientos adquiridos para identificar, formular y resolver problemas dentro de contextos amplios y multidisciplinarios, siendo capaces de integrar conocimientos, trabajando en equipos multidisciplinares."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000056/2025-26/CG5> a ns1:Competency ;
    ns1:competencyCode "CG5" ;
    ns1:competencyDescription "Saber comunicar los conocimientos y conclusiones, de forma oral, escrita y gráfica, a públicos especializados y no especializados de un modo claro y sin ambigüedades."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000056/2025-26/CG6> a ns1:Competency ;
    ns1:competencyCode "CG6" ;
    ns1:competencyDescription "Poseer habilidades de aprendizaje que permitan continuar estudiando a lo largo de la vida para su adecuado desarrollo profesional."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000056/2025-26/CG7> a ns1:Competency ;
    ns1:competencyCode "CG7" ;
    ns1:competencyDescription "Incorporar nuevas tecnologías y herramientas de la Ingeniería Industrial en sus actividades profesionales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000056/2025-26/RA252> a ns1:LearningResult ;
    ns1:learningResultCode "RA252" ;
    ns1:learningResultDescription "Capacidad para entender modelos matemáticos complicados de valoración de productos financieros."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000056/2025-26/RA253> a ns1:LearningResult ;
    ns1:learningResultCode "RA253" ;
    ns1:learningResultDescription "Capacidad para interpretar y formular en términos matemáticos problemas reales en el mundo de la economía."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000056/2025-26/RA254> a ns1:LearningResult ;
    ns1:learningResultCode "RA254" ;
    ns1:learningResultDescription "Habilidad para diseñar algoritmos numéricos y para manejar aplicaciones numéricas de utilidad en el mundo de las finanzas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000056/2025-26/RA255> a ns1:LearningResult ;
    ns1:learningResultCode "RA255" ;
    ns1:learningResultDescription "Habilidad para diseñar estrategias de cobertura."@es .

