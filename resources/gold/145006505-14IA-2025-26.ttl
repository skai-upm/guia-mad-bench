    schema:name "Mecanica Orbital"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145006505/2025-26/CE49> a ns1:Competency ;
    ns1:competencyCode "CE49" ;
    ns1:competencyDescription "Conocimiento aplicado de: aerodinámica; mecánica del vuelo, ingeniería de la defensa aérea (balística, misiles y sistemas aéreos), propulsión espacial, ciencia y tecnología de los materiales, teoría de estructuras."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145006505/2025-26/CE54> a ns1:Competency ;
    ns1:competencyCode "CE54" ;
    ns1:competencyDescription "Conocimiento adecuado y aplicado de la Mecánica Orbital de vehículos espaciales (Astrodinámica), incluyendo conceptos preliminares de su Dinámica de Actitud"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145006505/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Capacidad para identificar y resolver problemas aplicando, con creatividad, los conocimientos adquiridos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145006505/2025-26/CG9> a ns1:Competency ;
    ns1:competencyCode "CG9" ;
    ns1:competencyDescription "Razonamiento crítico y capacidad de asociación que posibiliten el aprendizaje continuo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145006505/2025-26/RA179> a ns1:LearningResult ;
    ns1:learningResultCode "RA179" ;
    ns1:learningResultDescription "Conocimiento, comprensión, aplicación, análisis y síntesis de los problemas astrodinámicos relacionados con el movimiento del centro de masas de un vehículos espacial; en concreto, las órbitas keplerianas, las órbitas reales condicionadas por las diferentes perturbaciones orbitales, las órbitas osculatrices y los métodos numéricos usuales en Astrodinámica."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145006505/2025-26/RA180> a ns1:LearningResult ;
    ns1:learningResultCode "RA180" ;
    ns1:learningResultDescription "Conocimiento y comprensión de la dinámica de actitud de los vehículos espaciales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145006505/2025-26/RA181> a ns1:LearningResult ;
    ns1:learningResultCode "RA181" ;
    ns1:learningResultDescription "Conocimiento de los métodos de seguimiento y del subsistema de Guiado, Navegación y Control (GNC) de los vehículos espaciales."@es .

