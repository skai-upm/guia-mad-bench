<https://guia-kg.skai.etsisi.upm.es/resource/595000323/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/595000323/2025-26/CE%20B5>,
