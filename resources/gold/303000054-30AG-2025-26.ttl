<https://guia-kg.skai.etsisi.upm.es/resource/303000054> a ns1:Course ;
    ns1:courseType "Obligatoria"@es ;
    ns1:courseYear 1 ;
    ns1:semester "Primer semestre"@es ;
    schema:courseCode 303000054 ;
    schema:hasCourseInstance <https://guia-kg.skai.etsisi.upm.es/resource/303000054/2025-26> ;
    schema:name "Information And Communication Technologies Applied To Physical Education"@en,
        "Tecnologias de la Información y la Comunicación Aplicadas a la Educación Física"@es ;
    schema:numberOfCredits 3.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/303000054/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/303000054/2025-26/CE19>,
        <https://guia-kg.skai.etsisi.upm.es/resource/303000054/2025-26/CE20>,
        <https://guia-kg.skai.etsisi.upm.es/resource/303000054/2025-26/CE22>,
        <https://guia-kg.skai.etsisi.upm.es/resource/303000054/2025-26/CE23>,
        <https://guia-kg.skai.etsisi.upm.es/resource/303000054/2025-26/CE25>,
        <https://guia-kg.skai.etsisi.upm.es/resource/303000054/2025-26/CG02>,
        <https://guia-kg.skai.etsisi.upm.es/resource/303000054/2025-26/CG03>,
        <https://guia-kg.skai.etsisi.upm.es/resource/303000054/2025-26/CT03> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/303000054/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/303000054/2025-26/RA1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/303000054/2025-26/RA3>,
        <https://guia-kg.skai.etsisi.upm.es/resource/303000054/2025-26/RA6> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/303000054/2025-26/syllabus> ;
    ns1:inpersonHours "31 horas (39.7%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "31 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/303000054/2025-26/eventSchedule> ;
    schema:description "La asignatura aborda el análisis de los componentes básicos del uso de la Tecnologías de la Comunicación e Información (TICs) en el proceso de enseñanza-aprendizaje. El objetivo es dotar de herramientas que favorezcan el seguimiento y control de las asignaturas relacionadas con la familia profesional de la Actividad Física, así como para la elaboración de materiales. Se pretende dar un enfoque metodológico orientado al conocimiento teórico-práctico de estas herramientas e implementar su aplicación en las distintas fases que aparecen en el proceso educativo."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/javier.glez.lopez%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/javier.glez.lopez%40upm.es> ;
    schema:name "Tecnologias de la Información y la Comunicación Aplicadas a la Educación Física"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000054/2025-26/CE19> a ns1:Competency ;
    ns1:competencyCode "CE19" ;
    ns1:competencyDescription "Transformar los currículos en programas de actividades y de trabajo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000054/2025-26/CE20> a ns1:Competency ;
    ns1:competencyCode "CE20" ;
    ns1:competencyDescription "Adquirir criterios de selección y elaboración de materiales educativos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000054/2025-26/CE22> a ns1:Competency ;
    ns1:competencyCode "CE22" ;
    ns1:competencyDescription "Integrar la formación en comunicación audiovisual y multimedia en el proceso de enseñanzaaprendizaje."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000054/2025-26/CE23> a ns1:Competency ;
    ns1:competencyCode "CE23" ;
    ns1:competencyDescription "Conocer estrategias y técnicas de evaluación y entender la evaluación como un instrumento de regulación y estímulo al esfuerzo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000054/2025-26/CE25> a ns1:Competency ;
    ns1:competencyCode "CE25" ;
    ns1:competencyDescription "Analizar críticamente el desempeño de la docencia, de las buenas prácticas y de la orientación, utilizando indicadores de calidad."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000054/2025-26/CG02> a ns1:Competency ;
    ns1:competencyCode "CG02" ;
    ns1:competencyDescription "Planificar, desarrollar y evaluar el proceso de enseñanza y aprendizaje potenciando procesos educativos que faciliten la adquisición de las competencias propias de las respectivas enseñanzas, atendiendo al nivel y formación previa de los estudiantes así como la orientación de los mismos, tanto individualmente como en colaboración con otros docentes y profesionales del centro."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000054/2025-26/CG03> a ns1:Competency ;
    ns1:competencyCode "CG03" ;
    ns1:competencyDescription "Buscar, obtener, procesar y comunicar información (oral, impresa, audiovisual, digital o multimedia), transformarla en conocimiento y aplicarla en los procesos de enseñanza y aprendizaje en las materias propias de la especialización cursada."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000054/2025-26/CT03> a ns1:Competency ;
    ns1:competencyCode "CT03" ;
    ns1:competencyDescription "Desarrollar la creatividad."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000054/2025-26/RA1> a ns1:LearningResult ;
    ns1:learningResultCode "RA1" ;
    ns1:learningResultDescription "Comprender las funciones y finalidades de la evaluación en E.F. y seleccionar las herramientas más adecuadas a cada situación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000054/2025-26/RA3> a ns1:LearningResult ;
    ns1:learningResultCode "RA3" ;
    ns1:learningResultDescription "Diseñar tareas, sesiones y unidades didácticas siguiendo los principios básicos de programación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000054/2025-26/RA6> a ns1:LearningResult ;
    ns1:learningResultCode "RA6" ;
    ns1:learningResultDescription "Expresarse oralmente con un grado suficiente de fluidez y corrección en lengua inglesa en entornos académicos educativos."@es .

