<https://guia-kg.skai.etsisi.upm.es/resource/113000030/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Tema 1: La Ciencia. El Método Científico."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000030/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Conceptos básicos. El Método Científico: características básicas, aplicación, líneas directrices, fases. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000030/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "4.1. Los productos de difusión científica: posters, comunicaciones, artículos, TFM, Tesis Doctorales. Estructura y posibilidades."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000030/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "4.1.1. Redacción de trabajos de investigación: Normas, principios y consejos. El Estilo Científico. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000030/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "4.2. Los artículos científicos. Características y tipos. Estructura. Proceso de elaboración y sometimiento. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000030/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "4.3. El Trabajo Final de Máster. Proceso de elaboración. Presentación y defensa. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000030/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Tipos de investigación. Estudios de Investigación. Niveles de actuación: conceptual, metodológico, analítico. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000030/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "2. Tema 2: El Trabajo de Investigación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000030/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "2.1. El proceso de investigación. Del pensamiento a la práctica. Operatividad. Factores a tener en cuenta. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000030/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "2.2. Diseño y desarrollo. Funciones y estructura. Diferentes posibilidades. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000030/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "2.3. Elección del tema, el problema de investigación, determinación de objetivos, formulación de hipótesis y planteamiento de variables. El tamaño muestral. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000030/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "2.4. Elección de métodos a utilizar. Instrumentos y recursos necesarios en la investigación. Tiempos y fases del trabajo. Registro Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000030/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "3. Difusión Científica. Presentación de trabajos científicos. Técnicas de Comunicación. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000030/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "4. Los productos de difusión científica."@es .

