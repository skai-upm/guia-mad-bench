    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/55000603/2025-26/syllabus> ;
    ns1:inpersonHours "34 horas y 30 minutos (44.2%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation """Los recursos didácticos, casos a estudiar y artículos a discutir, se van actualizando permanentemente durante el desarrollo de la asignatura. La renovación de los casos de estudio es constante.

Las herramientas de análisis estratégico implica una consideración transversal de los ODS como condicionantes o metas de las empresas, con relación más directa con los de contenido económico como son el ODS8, ODS9, ODS10 y ODS12."""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "34 horas y 30 minutos"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/55000603/2025-26/eventSchedule> ;
    schema:description "Asignatura que estudia de manera teórica y práctica los principios del Marketing en la empresa, estrategias de Producto, Precio, Distribución y Comunicación. La metodología de aprendizaje alterna las clases magistrales y la realización de casos prácticos."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/teresa.sanchez%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/fernando.onrubia%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/miguelangel.pelaez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/teresa.sanchez%40upm.es> ;
    schema:name "Introduccion Al Marketing"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000603/2025-26/CE27F> a ns1:Competency ;
    ns1:competencyCode "CE27F" ;
    ns1:competencyDescription "Conocimiento de las estrategias y planes de marketing de la empresa. ComprensiÃ³n del papel de dichas estrategias en la creaciÃ³n de valor"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000603/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Conocer y aplicar conocimientos de ciencias y tecnologías básicas a la práctica de la Ingeniería Industrial."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000603/2025-26/CG10> a ns1:Competency ;
    ns1:competencyCode "CG10" ;
    ns1:competencyDescription "Capacidad para generar nuevas ideas (Creatividad)."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000603/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Aplicar los conocimientos adquiridos para identificar, formular y resolver problemas dentro de contextos amplios y multidisciplinarios, siendo capaces de integrar conocimientos, trabajando en equipos multidisciplinares."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000603/2025-26/CG4> a ns1:Competency ;
    ns1:competencyCode "CG4" ;
    ns1:competencyDescription "Comprender el impacto de la ingeniería industrial en el medio ambiente, el desarrollo sostenible de la sociedad y la importancia de trabajar en un entorno profesional y responsable."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000603/2025-26/CG5> a ns1:Competency ;
    ns1:competencyCode "CG5" ;
    ns1:competencyDescription "Saber comunicar los conocimientos y conclusiones, de forma oral, escrita y gráfica, a públicos especializados y no especializados de un modo claro y sin ambigüedades."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000603/2025-26/CG6> a ns1:Competency ;
    ns1:competencyCode "CG6" ;
    ns1:competencyDescription "Poseer habilidades de aprendizaje que permitan continuar estudiando a lo largo de la vida para su adecuado desarrollo profesional."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000603/2025-26/CG8> a ns1:Competency ;
    ns1:competencyCode "CG8" ;
    ns1:competencyDescription "Capacidad de trabajar en un entorno bilingüe (inglés"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000603/2025-26/CG9> a ns1:Competency ;
    ns1:competencyCode "CG9" ;
    ns1:competencyDescription "Organización y planificación en el ámbito de la empresa, y otras instituciones y organizaciones de proyectos y equipos humanos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000603/2025-26/RA1> a ns1:LearningResult ;
    ns1:learningResultCode "RA1" ;
    ns1:learningResultDescription "Capacidad para modelar sistemas dinámicos sencillos mediante la transformada de Laplace."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000603/2025-26/RA268> a ns1:LearningResult ;
    ns1:learningResultCode "RA268" ;
    ns1:learningResultDescription "Capacidad de comunicar oral y por escrito los conocimientos adquiridos a especialistas y legos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000603/2025-26/RA318> a ns1:LearningResult ;
    ns1:learningResultCode "RA318" ;
    ns1:learningResultDescription "Creatividad"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000603/2025-26/RA509> a ns1:LearningResult ;
    ns1:learningResultCode "RA509" ;
    ns1:learningResultDescription "Desarrollar actividades específicas de investigación, posicionamiento, diseño de productos y precios, planes de comunicación en proyectos completos de marketing sin perder la perspectiva global"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000603/2025-26/RA510> a ns1:LearningResult ;
    ns1:learningResultCode "RA510" ;
    ns1:learningResultDescription "Habilidades: investigación, análisis, diagnóstico, creatividad, síntesis y comunicación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000603/2025-26/RA511> a ns1:LearningResult ;
    ns1:learningResultCode "RA511" ;
    ns1:learningResultDescription "Participar en proyectos de análisis, evaluación y diseño de programas completos de marketing"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000603/2025-26/RA512> a ns1:LearningResult ;
    ns1:learningResultCode "RA512" ;
    ns1:learningResultDescription "Conocer mejor la función de marketing: Atractivo para el alumno, Aptitudes del alumno"@es .

