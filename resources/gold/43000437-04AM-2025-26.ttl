<https://guia-kg.skai.etsisi.upm.es/resource/43000437/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Introduction to non conventional, medium span or large span bridges"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000437/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Determinants that led to plan a non conventional bridge. Bridge typology. Examples. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000437/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "5. The portal frame bridge"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000437/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "5.1. Morphology, supporting conditions,resistant behaviour depending on the ground and supporting conditions, prestressing design, construction, applications. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000437/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "6. The railroad bridge"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000437/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "6.1. Morphology. Special features of the hi-speed railroad bridges. Specific actions on railroad bridges. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000437/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "6.2. Spanish and European regulation. Serviceability conditions. Location of expansion joints in the bridge and on the road. Introduction to dynamic effects. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000437/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "7. Arch bridges"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000437/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "7.1. Morphology. Linkages. Resistant behaviour: deck bridge, through bridge, spandrel arch bridge, network arch bridge. Arch construction. Applications. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000437/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "8. Cable-stayed bridges."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000437/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "8.1. Longitudinal morphology. Transverse morphology. Towers. Cable properties. Cable-stayed bridge behaviour against vertical and horizontal actions. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000437/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "8.2. Calculation of cable-stayed bridges. Definition of reference state. Modelling. Construction process: cantilever method, over provisional supports. Applications. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000437/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "2. The box girder bridge"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000437/2025-26/syllabus/20> a ns1:SyllabusItem ;
    ns1:itemIndex 20 ;
    ns1:syllabusDescription "9. Extradosed bridges."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000437/2025-26/syllabus/21> a ns1:SyllabusItem ;
    ns1:itemIndex 21 ;
    ns1:syllabusDescription "9.1. Longitudinal morphology. Transverse morphology. Towers. Cable properties. Extradosed bridge behaviour against vertical and horizontal actions. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000437/2025-26/syllabus/22> a ns1:SyllabusItem ;
    ns1:itemIndex 22 ;
    ns1:syllabusDescription "9.2. Calculation of extradosed bridges. Definition of reference state. Construction process Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000437/2025-26/syllabus/23> a ns1:SyllabusItem ;
    ns1:itemIndex 23 ;
    ns1:syllabusDescription "10. Extraordinary actions."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000437/2025-26/syllabus/24> a ns1:SyllabusItem ;
    ns1:itemIndex 24 ;
    ns1:syllabusDescription "10.1. Scouring: description, research, protection design. Ship collision: description, actions during the collision, calculation, protection against the ship collision. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000437/2025-26/syllabus/25> a ns1:SyllabusItem ;
    ns1:itemIndex 25 ;
    ns1:syllabusDescription "11. Inspection and maintenance."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000437/2025-26/syllabus/26> a ns1:SyllabusItem ;
    ns1:itemIndex 26 ;
    ns1:syllabusDescription "11.1. Bridge management. Periodic inspection policy. Maintenance programs. Bridge rehabilitation. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000437/2025-26/syllabus/27> a ns1:SyllabusItem ;
    ns1:itemIndex 27 ;
    ns1:syllabusDescription "12. Integral and semi integral bridges."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000437/2025-26/syllabus/28> a ns1:SyllabusItem ;
    ns1:itemIndex 28 ;
    ns1:syllabusDescription "12.1. Justification, morphology, design and analysis, applications. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000437/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "2.1. Transverse and longitudinal morphology. Resistant behaviour: longitudinal bending, transverse bending, torsion, non uniform torsion, distortion Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000437/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "2.2. application of numerical methods, bridge modelling. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000437/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "2.3. Construction: movable scaffolding system, launching girder, cantilever segmental construction, precast segments, incremental launching. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000437/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "3. The skew bridge"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000437/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "3.1. Morphology, supporting conditions, resistant behaviour, precast beams deck, slab deck, closed box deck. Modelling, prestressing. Applications. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000437/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "4. The curved bridge"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000437/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "4.1. Morphology, supporting conditions, resistant behaviour, precast beams deck, slab deck, closed box deck. Modelling, prestressing. Applications. Sin subniveles"@es .

