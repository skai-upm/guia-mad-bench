        <https://guia-kg.skai.etsisi.upm.es/resource/jm.simon-talero%40upm.es> ;
    schema:name "Proyecto, Calculo y Construcción de Puentes"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000437/2025-26/CB10> a ns1:Competency ;
    ns1:competencyCode "CB10" ;
    ns1:competencyDescription "Que los estudiantes posean las habilidades de aprendizaje que les permitan continuar estudiando de un modo que habrá de ser en gran medida autodirigido o autónomo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000437/2025-26/CB6> a ns1:Competency ;
    ns1:competencyCode "CB6" ;
    ns1:competencyDescription "Poseer y comprender conocimientos que aporten una base u oportunidad de ser originales en el desarrollo y/o aplicación de ideas, a menudo en un contexto de investigación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000437/2025-26/CB9> a ns1:Competency ;
    ns1:competencyCode "CB9" ;
    ns1:competencyDescription "Que los estudiantes sepan comunicar sus conclusiones y los conocimientos y razones últimas que las sustentan a públicos especializados y no especializados de un modo claro y sin ambigüedades"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000437/2025-26/CE11> a ns1:Competency ;
    ns1:competencyCode "CE11" ;
    ns1:competencyDescription "Capacidad para el ejercicio profesional de alta especialización o para la investigación predoctoral mediante la utilización de recursos de modelización predictiva en Análisis y diseño de puentes."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000437/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Polivalencia para extender a ámbitos afines las competencias generales adquiridas en el ámbito temático del título."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000437/2025-26/CG4> a ns1:Competency ;
    ns1:competencyCode "CG4" ;
    ns1:competencyDescription "Capacidad de comunicación académica de contenido técnico y científico, oral y escrita en lengua inglesa."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000437/2025-26/CG5> a ns1:Competency ;
    ns1:competencyCode "CG5" ;
    ns1:competencyDescription "Capacidad de utilización de los servicios de comunicación y de obtención de información para su transformación en conocimiento aplicable al ejercicio de las competencias específicas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000437/2025-26/RA2> a ns1:LearningResult ;
    ns1:learningResultCode "RA2" ;
    ns1:learningResultDescription "Presenta comunicaciones orales, escritas y gráficas, estructurada y argumentadamente, en lengua española e inglesa"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000437/2025-26/RA3> a ns1:LearningResult ;
    ns1:learningResultCode "RA3" ;
    ns1:learningResultDescription "Interioriza los principios de deontología profesional para actividades de I+D+i"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000437/2025-26/RA30> a ns1:LearningResult ;
    ns1:learningResultCode "RA30" ;
    ns1:learningResultDescription "Plantea el método de construcción de un puente"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000437/2025-26/RA31> a ns1:LearningResult ;
    ns1:learningResultCode "RA31" ;
    ns1:learningResultDescription "Asume los principios de incertidumbre y riesgo en la aplicación de los métodos y modelos de estructuras para el estudio de los puentes."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000437/2025-26/RA4> a ns1:LearningResult ;
    ns1:learningResultCode "RA4" ;
    ns1:learningResultDescription "Utiliza con eficacia recursos de información y comunicación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000437/2025-26/RA8> a ns1:LearningResult ;
    ns1:learningResultCode "RA8" ;
    ns1:learningResultDescription "Utiliza con eficacia recursos de modelización predictiva en una o más de las materias del módulo"@es .

