    ns1:itemIndex 11 ;
    ns1:syllabusDescription "6.1. 6.1. Comportamiento en moldeo de las aleaciones de aluminio. 6.2. Aleaciones Al-Si, Al-Si-Cu y Al-Si-Mg. 6.3. Otras aleaciones de aluminio de moldeo. 6.4. Aplicaciones aeroespaciales de las aleaciones de aluminio de moldeo. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145025001/2025-26/syllabus/12> a ns1:SyllabusItem ;
