<https://guia-kg.skai.etsisi.upm.es/resource/43000659/2025-26/syllabus> a ns1:Syllabus ;
    ns1:hasItem <https://guia-kg.skai.etsisi.upm.es/resource/43000659/2025-26/syllabus/0>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000659/2025-26/syllabus/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000659/2025-26/syllabus/10>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000659/2025-26/syllabus/11>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000659/2025-26/syllabus/2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000659/2025-26/syllabus/3>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000659/2025-26/syllabus/4>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000659/2025-26/syllabus/5>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000659/2025-26/syllabus/6>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000659/2025-26/syllabus/7>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000659/2025-26/syllabus/8>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000659/2025-26/syllabus/9> .

<https://guia-kg.skai.etsisi.upm.es/resource/43000659/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Vehicle-induced vibrations in road bridges."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000659/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Vehicle models and pavement irregularities. Analysis methods for wind-vehicle-bridge interaction studies. Driving safety and comfort assessment. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000659/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "5.1. Fundamentals of wind engineering. The atmospheric boundary layer. Bluff body aerodynamics. Code treatment of the problem. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000659/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "5.2. Quasistatic, buffeting and aeroelastic effects in bridges. Wind tunnel and CFD analysis. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000659/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "2. Train-induced vibrations in railway bridges"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000659/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "2.1. Description of moving loads in railway bridges. Characteristic velocities. Analysis with moving loads and coupled models. Code treatment of the problem. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000659/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "3. Pedestrian-induced vibrations in footbridges."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000659/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "3.1. Traditional treatment of the problem. New developments following the problems with the Millenium footbridge. Human-structure interaction. Setra and Nakamura pedestrian models. Crowd loading. Code specifications. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000659/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "4. Seismic actions on bridges."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000659/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "4.1. Description of the seismic action. Multi-modal analysis of the seismic response. Ductility. Capacity design. Pushover method. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000659/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "4.2. Non-linear dynamic analysis. Damping. Performance-based design. Construction details in bridges. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000659/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "5. Wind effects on bridges."@es .

