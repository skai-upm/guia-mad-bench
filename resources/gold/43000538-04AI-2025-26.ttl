        <https://guia-kg.skai.etsisi.upm.es/resource/nicoleta.gcancelas%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/rafael.molina%40upm.es> ;
    schema:name "Puertos Avanzados"@es .

