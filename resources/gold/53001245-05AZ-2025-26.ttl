        <https://guia-kg.skai.etsisi.upm.es/resource/53001245/2025-26/%28k%29> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/53001245/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/53001245/2025-26/RA143> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/53001245/2025-26/syllabus> ;
    ns1:inpersonHours "71 horas y 30 minutos (45.8%)"@es ;
    ns1:numberOfCredits 6.0 ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "79 horas y 30 minutos"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/53001245/2025-26/eventSchedule> ;
    schema:description "Sistemas de Energía Eléctrica (II) es ampliación de la asignatura Sistemas de Energía Eléctrica I del Grado en Ingeniería en Tecnologías Industriales. Mientras que la asignatura de grado se centra en los fundamentos de los sistemas eléctricos de potencia y el análisis de su funcionamiento, la asignatura de máster trata aspectos más avanzados y está más orientada a la operación de dichos sistemas."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/sergio.martinez%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/julio.garciam%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/sergio.martinez%40upm.es> ;
    schema:name "Sistemas de Energia Electrica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001245/2025-26/%28a%29> a ns1:Competency ;
    ns1:competencyCode "(a)" ;
    ns1:competencyDescription "APLICA. Habilidad para aplicar conocimientos científicos, matemáticos y tecnológicos en sistemas relacionados con la práctica de la ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001245/2025-26/%28b%29> a ns1:Competency ;
    ns1:competencyCode "(b)" ;
    ns1:competencyDescription "EXPERIMENTA. Habilidad para diseñar y realizar experimentos así como analizar e interpretar datos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001245/2025-26/%28c%29> a ns1:Competency ;
    ns1:competencyCode "(c)" ;
    ns1:competencyDescription "DISEÑA. Habilidad para diseñar un sistema, componente o proceso que alcance los requisitos deseados teniendo en cuenta restricciones realistas tales como las económicas, medioambientales, sociales, políticas, éticas, de salud y seguridad, de fabricación y de sostenibilidad."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001245/2025-26/%28d%29> a ns1:Competency ;
    ns1:competencyCode "(d)" ;
    ns1:competencyDescription "TRABAJA EN EQUIPO. Habilidad para trabajar en equipos multidisciplinares."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001245/2025-26/%28e%29> a ns1:Competency ;
    ns1:competencyCode "(e)" ;
    ns1:competencyDescription "RESUELVE. Habilidad para identificar, formular y resolver problemas de ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001245/2025-26/%28f%29> a ns1:Competency ;
    ns1:competencyCode "(f)" ;
    ns1:competencyDescription "ES RESPONSABLE. Comprensión de la responsabilidad ética y profesional."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001245/2025-26/%28g%29> a ns1:Competency ;
    ns1:competencyCode "(g)" ;
    ns1:competencyDescription "COMUNICA. Habilidad para comunicar eficazmente."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001245/2025-26/%28h%29> a ns1:Competency ;
    ns1:competencyCode "(h)" ;
    ns1:competencyDescription "ENTIENDE LOS IMPACTOS. Educación amplia necesaria para entender el impacto de las soluciones ingenieriles en un contexto social global."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001245/2025-26/%28i%29> a ns1:Competency ;
    ns1:competencyCode "(i)" ;
    ns1:competencyDescription "SE ACTUALIZA. Reconocimiento de la necesidad y la habilidad para comprometerse al aprendizaje continuo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001245/2025-26/%28j%29> a ns1:Competency ;
    ns1:competencyCode "(j)" ;
    ns1:competencyDescription "CONOCE. Conocimiento de los temas contemporáneos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001245/2025-26/%28k%29> a ns1:Competency ;
    ns1:competencyCode "(k)" ;
    ns1:competencyDescription "USA HERRAMIENTAS. Habilidad para usar las técnicas, destrezas y herramientas ingenieriles modernas necesarias para la práctica de la ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001245/2025-26/RA143> a ns1:LearningResult ;
    ns1:learningResultCode "RA143" ;
    ns1:learningResultDescription "Conocimiento sobre análisis y operación de sistemas eléctricos de potencia"@es .

