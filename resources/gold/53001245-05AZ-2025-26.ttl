<https://guia-kg.skai.etsisi.upm.es/resource/53001245/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/53001245/2025-26/%28a%29>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001245/2025-26/%28b%29>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001245/2025-26/%28c%29>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001245/2025-26/%28d%29>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001245/2025-26/%28e%29>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001245/2025-26/%28f%29>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001245/2025-26/%28g%29>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001245/2025-26/%28h%29>,
