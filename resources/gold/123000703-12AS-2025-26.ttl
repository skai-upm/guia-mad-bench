    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/123000703/2025-26/syllabus> ;
    ns1:inpersonHours "86 horas (79.6%)"@es ;
    ns1:numberOfCredits 4.0 ;
    ns1:otherInformation "La asignatura va a ser impartida íntegramente por el Prof. Juan Rueda"@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "86 horas"@es ;
    schema:activitiesWorkload "120%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/123000703/2025-26/eventSchedule> ;
    schema:description """Con la asignatura de Sismología se pretende dotar al alumno de los conocimientos necesarios sobre la generación, propagación y efectos de un terremoto, para poder abordar en otras asignaturas los problemas derivados del riesgo.
Se comienza estudiando y profundizando matemáticamente en la fuente sísmica y la propagación de ondas, se continua resolviendo el problema de la localización de terremotos y estimación de sus parámetros y se finaliza la asignatura profundizando en los efectos y la forma de evaluarlos. Asi mismo, se ha planificado un tema específico para el estudio de la instrumentación sísmica y su calibración."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/jorge.gaspar%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/jorge.gaspar%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/juanjose.rueda%40upm.es> ;
    schema:name "Sismología"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/123000703/2025-26/C1> a ns1:Competency ;
    ns1:competencyCode "C1" ;
    ns1:competencyDescription "Poseer capacidad para diseñar, desarrollar, implementar, gestionar y mejorar productos, sistemas y procesos en los distintos ámbitos de la evaluación del riesgo sísmico, usando tecnologías de la información geoespacial.TIPO: Competencias."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/123000703/2025-26/C11> a ns1:Competency ;
    ns1:competencyCode "C11" ;
    ns1:competencyDescription "Gestión de la información.Capacidad de recopilar, generar, analizar, procesar, transformar, almacenar y seleccionar la información relevante para el desarrollo de las actividades de investigación o profesionales.TIPO: Competencias."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/123000703/2025-26/K2> a ns1:Competency ;
    ns1:competencyCode "K2" ;
    ns1:competencyDescription "Definir y caracterizar las fuentes sísmicas usando los datos geológicos, geofísicos y geodésicos y de otras TIGs.TIPO:Conocimientos o contenidos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/123000703/2025-26/RA1> a ns1:LearningResult ;
    ns1:learningResultCode "RA1" ;
    ns1:learningResultDescription "Este plan está adaptado al RD 822/2021.Los resultados del aprendizaje correspondientes a esta asignatura han quedado definidos en el apartado de competencias de este documento, señalando los que corresponden a conocimientos, habilidades y competencias propiamente dichas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/123000703/2025-26/Sk1> a ns1:Competency ;
    ns1:competencyCode "Sk1" ;
    ns1:competencyDescription "Aplicar conocimientos de ciencias de la Tierra y tecnologías de la información geoespacial en la evaluación del riesgo sísmico.TIPO: Habilidades o destrezas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/123000703/2025-26/Sk2> a ns1:Competency ;
    ns1:competencyCode "Sk2" ;
    ns1:competencyDescription "Elaborar bases de datos geoespaciales específicas para aplicaciones de riesgo sísmico a partir repositorios de datos generales.TIPO: Habilidades o destrezas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/123000703/2025-26/Sk5> a ns1:Competency ;
    ns1:competencyCode "Sk5" ;
    ns1:competencyDescription "Difundir los resultados de estudios e investigaciones de riesgo sísmico en un formato adecuado para su comunicación efectiva.TIPO: Habilidades o destrezas."@es .

