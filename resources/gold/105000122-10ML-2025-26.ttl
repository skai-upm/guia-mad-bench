    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/105000122/2025-26/eventSchedule> ;
    schema:description """Los números complejos, y la teoría de funciones de variable compleja juegan un papel esencial en todas las ramas de las matemáticas. En este curso se estudiarán las propiedades más importantes de dichos números, y de las funciones que son derivables en sentido complejo.
Se estudiará la diferenciación e integración de estas funciones definidas en distintos tipos de dominios, así como su representación en serie de Taylor y de Laurent.
Se estudia la teoría de residuos y algunas de sus aplicaciones, como el cálculo de series y de integrales impropias de funciones reales."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/juan.rojo.carulli%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/alfonso.zamora%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/juan.rojo.carulli%40upm.es> ;
    schema:name "Analisis Complejo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000122/2025-26/C1> a ns1:Competency ;
    ns1:competencyCode "C1" ;
    ns1:competencyDescription "Capacidad de resolución de problemas aplicando conocimientos de matemáticas, ciencias e ingeniería. TIPO: Competencias."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000122/2025-26/C10> a ns1:Competency ;
    ns1:competencyCode "C10" ;
    ns1:competencyDescription "Capacidad para usar las tecnologías de la información y la comunicación. TIPO: Competencias."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000122/2025-26/C13> a ns1:Competency ;
    ns1:competencyCode "C13" ;
    ns1:competencyDescription "Capacidad de elegir y usar los métodos analíticos y de modelización relevantes, y de describir una solución de forma abstracta. TIPO: Competencias."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000122/2025-26/C19> a ns1:Competency ;
    ns1:competencyCode "C19" ;
    ns1:competencyDescription "Capacidad para trabajar de forma efectiva como individuo, organizando y planificando su propio trabajo, de forma independiente o como miembro de un equipo. TIPO: Competencias."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000122/2025-26/C2> a ns1:Competency ;
    ns1:competencyCode "C2" ;
    ns1:competencyDescription "Capacidad para el aprendizaje autónomo y la actualización de conocimientos, y reconocimiento de su necesidad en las áreas de la matemática y la informática.TIPO: Competencias."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000122/2025-26/C3> a ns1:Competency ;
    ns1:competencyCode "C3" ;
    ns1:competencyDescription "Saber trabajar en situaciones carentes de información y bajo presión, teniendo nuevas ideas, siendo creativo. TIPO: Competencias."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000122/2025-26/C4> a ns1:Competency ;
    ns1:competencyCode "C4" ;
    ns1:competencyDescription "Capacidad de gestión de la información. TIPO: Competencias."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000122/2025-26/C5> a ns1:Competency ;
    ns1:competencyCode "C5" ;
    ns1:competencyDescription "Capacidad de abstracción, análisis y síntesis. TIPO: Competencias."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000122/2025-26/C8> a ns1:Competency ;
    ns1:competencyCode "C8" ;
    ns1:competencyDescription "Capacidad de comunicarse de forma efectiva con los compañeros, usuarios (potenciales) y el público en general acerca de cuestiones reales y problemas relacionados con la especialización elegida. TIPO: Competencias"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000122/2025-26/K1> a ns1:Competency ;
    ns1:competencyCode "K1" ;
    ns1:competencyDescription "Comprender y utilizar el lenguaje matemático. Conocer demostraciones de teoremas clásicos. Comprender las definiciones de objetos matemáticos. TIPO: Conocimientos o contenidos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000122/2025-26/K11> a ns1:Competency ;
    ns1:competencyCode "K11" ;
    ns1:competencyDescription "Conocer las técnicas básicas del cálculo numérico y su traducción a algoritmos. TIPO: Conocimientos o contenidos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000122/2025-26/K5> a ns1:Competency ;
    ns1:competencyCode "K5" ;
    ns1:competencyDescription "Conocer y saber utilizar los conceptos y los resultados fundamentales del Cálculo Diferencial e Integral para funciones reales y los fundamentos de la teoría de funciones de una variable compleja. TIPO: Conocimientos o contenidos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000122/2025-26/K6> a ns1:Competency ;
    ns1:competencyCode "K6" ;
    ns1:competencyDescription "Conocer la relación entre problemas reales y sus modelos matemáticos en términos de ecuaciones diferenciales y comprender la necesidad de utilizar métodos numéricos y enfoques cualitativos para su resolución. TIPO: Conocimientos o contenidos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000122/2025-26/K9> a ns1:Competency ;
    ns1:competencyCode "K9" ;
    ns1:competencyDescription "Conocer y saber utilizar los conceptos básicos de la Topología. TIPO: Conocimientos o contenidos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000122/2025-26/RA202> a ns1:LearningResult ;
    ns1:learningResultCode "RA202" ;
    ns1:learningResultDescription "Los resultados del aprendizaje correspondientes a esta asignatura han quedado definidos en el apartado de competencias de este documento, señalando los que corresponden a conocimientos, habilidades y competencias propiamente dichas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000122/2025-26/S1> a ns1:Competency ;
    ns1:competencyCode "S1" ;
    ns1:competencyDescription "Plantear nuevas definiciones. Poder enunciar resultados y construir demostraciones, detectar errores en ellas o encontrar contraejemplos. TIPO: Habilidades o destrezas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000122/2025-26/S10> a ns1:Competency ;
    ns1:competencyCode "S10" ;
    ns1:competencyDescription "Saber utilizar los conceptos y resultados clásicos en el campo de las ecuaciones diferenciales ordinarias. TIPO: Habilidades o destrezas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000122/2025-26/S14> a ns1:Competency ;
    ns1:competencyCode "S14" ;
    ns1:competencyDescription "Tener criterios para valorar y comparar distintos métodos en función de los problemas a resolver, el coste operativo y la presencia de errores. TIPO: Habilidades o destrezas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000122/2025-26/S2> a ns1:Competency ;
    ns1:competencyCode "S2" ;
    ns1:competencyDescription "Ser capaz de extraer de un objeto matemático aquellas propiedades fundamentales que lo caracterizan, distinguiéndolas de aquellas otras ocasionales compartidas con otros objetos matemáticos. TIPO: Habilidades o destrezas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000122/2025-26/S3> a ns1:Competency ;
    ns1:competencyCode "S3" ;
    ns1:competencyDescription "Ser capaz de plantear modelos matemáticos para problemas reales, utilizando para resolverlos las herramientas necesarias, interpretando la solución en los mismos términos en que estaba planteado el problema. TIPO: Habilidades o destrezas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000122/2025-26/S4> a ns1:Competency ;
    ns1:competencyCode "S4" ;
    ns1:competencyDescription "Comprender y ser capaz de encontrar soluciones a problemas matemáticos en diferentes áreas, utilizando para resolverlos las herramientas analíticas, numéricas o estadísticas disponibles. TIPO: Habilidades o destrezas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000122/2025-26/S5> a ns1:Competency ;
    ns1:competencyCode "S5" ;
    ns1:competencyDescription "Utilizar herramientas informáticas (de cálculo simbólico, de análisis estadístico, de cálculo numérico, de visualización) para resolver problemas planteados en términos matemáticos, bien de forma experimental, bien de forma rigurosa. TIPO: Habilidades o destrezas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000122/2025-26/S6> a ns1:Competency ;
    ns1:competencyCode "S6" ;
    ns1:competencyDescription "Diseñar algoritmos y desarrollar programas para resolver problemas en matemáticas. TIPO: Habilidades o destrezas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000122/2025-26/S7> a ns1:Competency ;
    ns1:competencyCode "S7" ;
    ns1:competencyDescription "Formalización y especificación de problemas reales cuya solución requiere el uso de la informática. TIPO: Habilidades o destrezas."@es .

