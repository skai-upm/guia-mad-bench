<https://guia-kg.skai.etsisi.upm.es/resource/105000122/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. El plano complejo y el plano complejo ampliado: Estructura algebraica y topología."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000122/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Aparición de los complejos: la ecuación cúbica. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000122/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "3.1. Sucesiones y series de números complejos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000122/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "3.2. Sucesiones y series de funciones complejas, convergencia puntual y uniforme. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000122/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "3.3. Series de potencias. Fórmula de Cauchy-Hadamard. Funciones analíticas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000122/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "4. Funciones elementales de variable compleja."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000122/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "4.1. Función exponencial y logaritmo. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000122/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "4.2. Funciones trigonométricas e hiperbólicas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000122/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "4.3. Funciones trigonométricas e hiperbólicas inversas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000122/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "5. Integración de funciones de variable compleja."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000122/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "5.1. Curvas en el plano complejo Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000122/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "5.2. Integrales de contorno"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000122/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. El cuerpo de los números complejos. Módulo y conjugado de un número complejo. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000122/2025-26/syllabus/20> a ns1:SyllabusItem ;
    ns1:itemIndex 20 ;
    ns1:syllabusDescription "5.2.1. Integral de funciones sobre curvas suaves Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000122/2025-26/syllabus/21> a ns1:SyllabusItem ;
    ns1:itemIndex 21 ;
    ns1:syllabusDescription "5.2.2. Integral de funciones sobre contornos Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000122/2025-26/syllabus/22> a ns1:SyllabusItem ;
    ns1:itemIndex 22 ;
    ns1:syllabusDescription "5.2.3. Independencia del contorno. Existencia de primitiva. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000122/2025-26/syllabus/23> a ns1:SyllabusItem ;
    ns1:itemIndex 23 ;
    ns1:syllabusDescription "5.3. El teorema integral de Cauchy y sus consecuencias"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000122/2025-26/syllabus/24> a ns1:SyllabusItem ;
    ns1:itemIndex 24 ;
    ns1:syllabusDescription "5.3.1. El teorema integral de Cauchy Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000122/2025-26/syllabus/25> a ns1:SyllabusItem ;
    ns1:itemIndex 25 ;
    ns1:syllabusDescription "5.3.2. La fórmula integral de Cauchy Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000122/2025-26/syllabus/26> a ns1:SyllabusItem ;
    ns1:itemIndex 26 ;
    ns1:syllabusDescription "5.3.3. Teoremas de Morera, Liouville, y teorema fundamental del Álgebra. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000122/2025-26/syllabus/27> a ns1:SyllabusItem ;
    ns1:itemIndex 27 ;
    ns1:syllabusDescription "5.3.4. Teorema del valor medio de Gauss, principio del módulo máximo, y de la aplicación abierta. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000122/2025-26/syllabus/28> a ns1:SyllabusItem ;
    ns1:itemIndex 28 ;
    ns1:syllabusDescription "6. Teoría de los residuos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000122/2025-26/syllabus/29> a ns1:SyllabusItem ;
    ns1:itemIndex 29 ;
    ns1:syllabusDescription "6.1. Ceros y singularidades. Clasificación de las singularidades. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000122/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "1.3. Forma polar y forma exponencial de un número complejo (fórmula de Euler). Potencias y raíces. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000122/2025-26/syllabus/30> a ns1:SyllabusItem ;
    ns1:itemIndex 30 ;
    ns1:syllabusDescription "6.2. Residuos de una función. Teorema de Cauchy de los residuos Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000122/2025-26/syllabus/31> a ns1:SyllabusItem ;
    ns1:itemIndex 31 ;
    ns1:syllabusDescription "6.3. Aplicaciones de la teoría de residuos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000122/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "1.4. Topología del plano complejo. Entornos del infinito y topología del plano ampliado. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000122/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "2. Derivada de funciones de variable compleja: funciones holomorfas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000122/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "2.1. Límites y continuidad. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000122/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "2.2. Derivada de una función compleja. Ecuaciones de Cauchy-Riemann. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000122/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "2.3. Funciones holomorfas y funciones armónicas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000122/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "3. Series infinitas de variable compleja"@es .

