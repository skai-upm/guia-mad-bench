<https://guia-kg.skai.etsisi.upm.es/resource/43000415/2025-26/CE29> a ns1:Competency ;
    ns1:competencyCode "CE29" ;
    ns1:competencyDescription "Capacidad para analizar y diagnosticar los condicionantes sociales, culturales, ambientales y económicos de un territorio, así como para realizar proyectos de ordenación territorial y planeamiento urbanístico desde la perspectiva de un desarrollo sostenible."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000415/2025-26/CE36> a ns1:Competency ;
    ns1:competencyCode "CE36" ;
    ns1:competencyDescription "Capacidad para integrar y aplicar los conocimientos técnicos de ordenación territorial, urbanismo y urbanización en asesoría, análisis, evaluación técnica, dirección, y gestión legal y técnica."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000415/2025-26/CE5> a ns1:Competency ;
    ns1:competencyCode "CE5" ;
    ns1:competencyDescription "Conocimiento de la profesión de Ingeniero de Caminos, Canales y Puertos y de las actividades que se pueden realizar en el ámbito de la ingeniería civil."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000415/2025-26/CGP03> a ns1:Competency ;
    ns1:competencyCode "CGP03" ;
    ns1:competencyDescription "Conocimiento, comprensión y capacidad para aplicar la legislación necesaria en el ejercicio de la profesión de Ingeniero de Caminos, Canales y Puertos. Incorpora las competencias CB6, CB7 y CB8."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000415/2025-26/CGP05> a ns1:Competency ;
    ns1:competencyCode "CGP05" ;
    ns1:competencyDescription "Conocimiento de la profesión de Ingeniero de Caminos, Canales y Puertos y de las actividades que se pueden realizar en el ámbito de la ingeniería civil. Incorpora las competencias CB6, CB7 y CB8."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000415/2025-26/CGP14> a ns1:Competency ;
    ns1:competencyCode "CGP14" ;
    ns1:competencyDescription "Capacidad de realización de estudios, planes de ordenación territorial y urbanismo y proyectos de urbanización. Incorpora las competencias CB6, CB7 y CB8."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000415/2025-26/CT1> a ns1:Competency ;
    ns1:competencyCode "CT1" ;
    ns1:competencyDescription "Capacidad de preparar y presentar comunicaciones orales, escritas y gráficas, estructurada y argumentadamente. Desarrolla la competencia transversal 4ª del Real Decreto."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000415/2025-26/CT2> a ns1:Competency ;
    ns1:competencyCode "CT2" ;
    ns1:competencyDescription "Polivalencia y capacidad de aprendizaje autónomo. Desarrolla la competencia transversal 5ª del Real Decreto."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000415/2025-26/CT4> a ns1:Competency ;
    ns1:competencyCode "CT4" ;
    ns1:competencyDescription "Capacidad de organizar y dirigir los esfuerzos de un equipo. Desarrolla la competencia transversal 5ª de la normativa UPM."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000415/2025-26/CT5> a ns1:Competency ;
    ns1:competencyCode "CT5" ;
    ns1:competencyDescription "Capacidad de ejercer las funciones profesionales de proyecto, cálculo, evaluación técnica, planificación y gestión técnica mediante el uso de normativa europea e internacional. Desarrolla la competencia transversal 7ª de la normativa UPM."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000415/2025-26/CT6> a ns1:Competency ;
    ns1:competencyCode "CT6" ;
    ns1:competencyDescription "Compromiso y capacidad de aplicación de los estándares de deontología profesional."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000415/2025-26/CT7> a ns1:Competency ;
    ns1:competencyCode "CT7" ;
    ns1:competencyDescription "Capacidad de utilización de los servicios de información y comunicación para el ejercicio de las funciones profesionales del perfil de egreso. Desarrolla la competencia transversal 3ª de la normativa UPM."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000415/2025-26/RA1> a ns1:LearningResult ;
    ns1:learningResultCode "RA1" ;
    ns1:learningResultDescription "Formula y resuelve problemas matemáticos y numéricos avanzados de ingeniería civil, identificando sus diferentes componentes científicos y técnicos y seleccionando y acoplando con eficacia los métodos de resolución."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000415/2025-26/RA10> a ns1:LearningResult ;
    ns1:learningResultCode "RA10" ;
    ns1:learningResultDescription "Planifica el territorio, el medio litoral, la ordenación y defensa de costas, incorporando los efectos y condicionantes entre el medio ambiente y las infraestructuras."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000415/2025-26/RA11> a ns1:LearningResult ;
    ns1:learningResultCode "RA11" ;
    ns1:learningResultDescription "Proyecta la ordenación territorial y el planeamiento urbanístico con criterios de desarrollo sostenible, analizando y diagnosticando los condicionantes sociales, culturales, ambientales y económicos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000415/2025-26/RA124> a ns1:LearningResult ;
    ns1:learningResultCode "RA124" ;
    ns1:learningResultDescription "Conoce los principios fundamentales del desarrollo sostenible (económico, social, ambiental) para la correcta evaluación de inversiones en ingeniería civil."@es .

