<https://guia-kg.skai.etsisi.upm.es/resource/43000415/2025-26/RA2> a ns1:LearningResult ;
    ns1:learningResultCode "RA2" ;
    ns1:learningResultDescription "Aplica con carácter predictivo las leyes generales de la termomecánica de los medios continuos en mecánica de fluidos, mecánica de sólidos y materiales, mecánica de suelos y teoría de estructuras"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000415/2025-26/RA33> a ns1:LearningResult ;
    ns1:learningResultCode "RA33" ;
    ns1:learningResultDescription "Sintetiza e integra las competencias adquiridas, en especial las que requieren ejercer la selección óptima de alternativas, por ser las de mayor nivel competencial."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000415/2025-26/RA36> a ns1:LearningResult ;
    ns1:learningResultCode "RA36" ;
    ns1:learningResultDescription "Interioriza los principios de deontología profesional de ingeniería civil."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000415/2025-26/RA72> a ns1:LearningResult ;
    ns1:learningResultCode "RA72" ;
