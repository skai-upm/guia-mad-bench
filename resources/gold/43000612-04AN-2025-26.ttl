    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000612/2025-26/didactic_resource/3> a ns1:DidacticResource ;
    ns1:bibliographyTitle "Nanocarbon-Inorganic Hybrids. Next Generation Composites for Sustainable Energy Applications Edited by: Dominik Eder and Robert Schlögl, De Gruyter 2014"@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000612/2025-26/didactic_resource/4> a ns1:DidacticResource ;
    ns1:bibliographyTitle "M. Ashby, P.J. Ferreira & D. Schodek. Nanomaterials, Nanotechnologies and Design. Butterworth-Heinemann 2009"@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000612/2025-26/evaluation> a ns1:EvaluationSystem ;
    ns1:evaluationDescription """Progressive evaluation will be carried out with two exams and the report of the laboratory practice. To pass, the students have to obtain a mark equal or greater than 4 (>= 4/10) in every partial exam, equal or greater than 5 (>= 5) in the laboratory report, and equal or greater than 5 in the weighted average, defined as :WAvg:= 0.4*Mark_partialExam1 + 0.4*Mark_partialExam2 + 0.2*LabReport >= 5. .

Ordinary exam: The students have to pass (>= 5/10)

Extraordinary exam: The students have to pass (>= 5/10)"""@es ;
    ns1:hasEvaluationTrial <https://guia-kg.skai.etsisi.upm.es/resource/43000612/2025-26/evaluation/trial1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000612/2025-26/evaluation/trial2>,
