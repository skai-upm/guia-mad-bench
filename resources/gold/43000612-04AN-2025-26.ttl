    schema:hasCourseInstance <https://guia-kg.skai.etsisi.upm.es/resource/43000612/2025-26> ;
    schema:name "Nanocompuestos y Materiales Híbridos Nanoestructur"@en,
        "Nanocomposites And Nanostructured Hybrid Materials"@es ;
    schema:numberOfCredits 3.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/43000612/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/43000612/2025-26/CE1>,
