        <https://guia-kg.skai.etsisi.upm.es/resource/145012004/2025-26/RA40>,
        <https://guia-kg.skai.etsisi.upm.es/resource/145012004/2025-26/RA41>,
        <https://guia-kg.skai.etsisi.upm.es/resource/145012004/2025-26/RA42> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/145012004/2025-26/syllabus> ;
    ns1:inpersonHours "61 horas y 30 minutos (39.4%)"@es ;
    ns1:numberOfCredits 6.0 ;
    ns1:otherInformation """Trabajos Voluntarios: Sobre cualquier tema indicado por el profesor o propuesto por el alumno, relacionado con la asignatura (y aceptado por el profesor).
Trabajo Obligatorio: A desarrollar por equipos, pudiendo incluir una presentación en clase. Tratará sobre aspectos de implementación del marco institucional y legal de la aviación civil
El contenido docente está alineado con los siguiente Objetivos de Desarrollo Sostenible (SDG) de la ONU:
Objetivo 8: Trabajo Decente y Crecimiento Económico. Promover el crecimiento económico sostenido, inclusivo y sostenible, el empleo pleno y productivo y el trabajo decente para todos
Objetivo 9: Industria, Innovación e Infraestructuras. La industrialización inclusiva y sostenible, junto con la innovación y la infraestructura, pueden dar rienda suelta a las fuerzas económicas dinámicas y competitivas que generan el empleo y los ingresos. Estas desempeñan un papel clave a la hora de introducir y promover nuevas tecnologías, facilitar el comercio internacional y permitir el uso eficiente de los recursos"""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "61 horas y 30 minutos"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/145012004/2025-26/eventSchedule> ;
    schema:description """Conocer el marco regulatorio de la aviación civil en su ámbitos internacional, regional y nacional.
Conocer el marco institucional de la aviación civil (organizaciones reguladoras/supervisoras, proveedores de servicio y otros agentes)
Particularizar dichos elementos a los servicios de navegación aéreas, las licencias del personal aeronáutico y los aspectos relacionados con la aeronavegabilidad de las aeronaves"""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/j.cubas%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/antonio.pelaez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/fernando.gcomendador%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/j.cubas%40upm.es> ;
    schema:name "Legislación Aeronáutica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145012004/2025-26/CB01> a ns1:Competency ;
    ns1:competencyCode "CB01" ;
    ns1:competencyDescription "Que los estudiantes hayan demostrado poseer y comprender conocimientos en un área de estudio que parte de la base de la educación secundaria general, y se suele encontrar a un nivel que, si bien se apoya en libros de texto avanzados, incluye también algunos aspectos que implican conocimientos procedentes de la vanguardia de su campo de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145012004/2025-26/CB05> a ns1:Competency ;
    ns1:competencyCode "CB05" ;
    ns1:competencyDescription "Que los estudiantes hayan desarrollado aquellas habilidades de aprendizaje necesarias para emprender estudios posteriores con un alto grado de autonomía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145012004/2025-26/CE12> a ns1:Competency ;
    ns1:competencyCode "CE12" ;
    ns1:competencyDescription "Conocimiento adecuado de la normativa específica en el ámbito de la operación y gestión del Transporte Aéreo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145012004/2025-26/CG01> a ns1:Competency ;
    ns1:competencyCode "CG01" ;
    ns1:competencyDescription "Capacidad para llevar a cabo actividades de proyección, de dirección técnica, de redacción de informes, y de asesoramiento técnico en tareas relativas a la industria del Transporte Aéreo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145012004/2025-26/CG03> a ns1:Competency ;
    ns1:competencyCode "CG03" ;
    ns1:competencyDescription "Capacidad para gestionar la información, identificando las fuentes necesarias, los principales tipos de documentos técnicos y científicos que son de aplicación en el entorno de la Gestión y Operación del Transporte Aéreo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145012004/2025-26/CG05> a ns1:Competency ;
    ns1:competencyCode "CG05" ;
    ns1:competencyDescription "Capacidad para la búsqueda y utilización de la normativa y reglamentación relativa a su ámbito de actuación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145012004/2025-26/CT07> a ns1:Competency ;
    ns1:competencyCode "CT07" ;
    ns1:competencyDescription "Habilidad para la comunicación oral y escrita"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145012004/2025-26/CT09> a ns1:Competency ;
    ns1:competencyCode "CT09" ;
    ns1:competencyDescription "Razonamiento crítico y capacidad de asociación que posibiliten el aprendizaje continuo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145012004/2025-26/RA16> a ns1:LearningResult ;
    ns1:learningResultCode "RA16" ;
    ns1:learningResultDescription "Conoce la estructura y los elementos que conforman el actual sistema de transporte mundial."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145012004/2025-26/RA17> a ns1:LearningResult ;
    ns1:learningResultCode "RA17" ;
    ns1:learningResultDescription "Comprende las características legales del transporte aéreo y conoce el sistema regulatorio internacional de este modo de transporte."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145012004/2025-26/RA18> a ns1:LearningResult ;
    ns1:learningResultCode "RA18" ;
    ns1:learningResultDescription "Es capaz de interpretar la normativa específica de aeropuertos y Navegación Aérea y el funcionamiento y la gestión del aeropuerto y el transporte aéreo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145012004/2025-26/RA40> a ns1:LearningResult ;
    ns1:learningResultCode "RA40" ;
    ns1:learningResultDescription "Comprende los conceptos básicos de la Navegación y Circulación Aérea y su aplicación en la operación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145012004/2025-26/RA41> a ns1:LearningResult ;
    ns1:learningResultCode "RA41" ;
    ns1:learningResultDescription "Identifica los elementos funcionales básicos de los Servicios de Navegación Aérea."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145012004/2025-26/RA42> a ns1:LearningResult ;
    ns1:learningResultCode "RA42" ;
    ns1:learningResultDescription "Es capaz de demostrar la necesidad de la evolución del Sistema de Navegación Aérea."@es .

