<https://guia-kg.skai.etsisi.upm.es/resource/43000138/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Principios generales del diseño de pavimentos. Vida útil de los pavimentos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000138/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "2. Selección previa del tipo de pavimento: pavimentos flexibles frente a pavimentos de hormigón Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000138/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "11. Fallo debido a deformaciones acumuladas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000138/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "12. Otros criterios de fallo. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000138/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "13. Análisis del comportamiento de los pavimentos y seguimiento de pavimentos en servicio. Planteamiento general. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000138/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "14. Tramos de ensayo y pistas de ensayo Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000138/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "15. Comportamiento de pavimentos a largo plazo. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000138/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "16. Características generales, ventajas y desventajas de los métodos empíricos de diseño. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000138/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "17. El método AASHTO de diseño de pavimentos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000138/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "18. MEPDG (Mechanistic-Empirical Pavement Design Guide). Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000138/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "19. Principios de la gestión de pavimentos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000138/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "20. Evaluación de pavimentos existentes. Inspección de deterioros y auscultación deflectométrica Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000138/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "3. Estudios de tráfico. Espectros de carga. Caracterización de las cargas. Interacción rueda-pavimento. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000138/2025-26/syllabus/20> a ns1:SyllabusItem ;
    ns1:itemIndex 20 ;
    ns1:syllabusDescription "21. Análisis económico de soluciones y optimización de costes. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000138/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "4. El cimiento. Formación de explanadas (mediante suelos naturales y mediante estabilizaciones in situ). Caracterización y modelización del cimiento. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000138/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "5. Comportamiento de los materiales y su caracterización. Materiales granulares, materiales tratados con cemento y materiales bituminosos. Comportamientos lineales y no lineales. Elasticidad y viscoelasticidad. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000138/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "6. Factores climáticos y ambientales. El efecto de la variación de las temperaturas. El efecto de la helada. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000138/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "7. Fiabilidad del diseño. Influencia del control de calidad de la ejecución. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000138/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "8. Modelos matemáticos. Teoría de los sistemas elásticos multicapa. Teoría de la viscoelasticidad. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000138/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "9. Programas computacionales para el diseño y análisis de pavimentos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000138/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "10. Fallo debido a la fatiga. Sin subniveles"@es .

