<https://guia-kg.skai.etsisi.upm.es/resource/143000122> a ns1:Course ;
    ns1:courseType "Obligatoria"@es ;
    ns1:courseYear 2 ;
    ns1:semester "Cuarto semestre"@es ;
    schema:courseCode 143000122 ;
    schema:hasCourseInstance <https://guia-kg.skai.etsisi.upm.es/resource/143000122/2025-26> ;
    schema:name "Space Industry And Institutions Seminar"@en,
        "Seminario sobre Industria e Instituciones Espaciales"@es ;
    schema:numberOfCredits 1.5 .

<https://guia-kg.skai.etsisi.upm.es/resource/143000122/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/143000122/2025-26/E03>,
        <https://guia-kg.skai.etsisi.upm.es/resource/143000122/2025-26/E04>,
        <https://guia-kg.skai.etsisi.upm.es/resource/143000122/2025-26/E05>,
        <https://guia-kg.skai.etsisi.upm.es/resource/143000122/2025-26/E06>,
        <https://guia-kg.skai.etsisi.upm.es/resource/143000122/2025-26/E07>,
        <https://guia-kg.skai.etsisi.upm.es/resource/143000122/2025-26/E19> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/143000122/2025-26/didactic_resource/1> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/143000122/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/143000122/2025-26/RA19>,
        <https://guia-kg.skai.etsisi.upm.es/resource/143000122/2025-26/RA20>,
        <https://guia-kg.skai.etsisi.upm.es/resource/143000122/2025-26/RA21>,
        <https://guia-kg.skai.etsisi.upm.es/resource/143000122/2025-26/RA22> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/143000122/2025-26/syllabus> ;
    ns1:inpersonHours "19 horas (48.7%)"@es ;
    ns1:numberOfCredits 1.5 ;
    ns1:otherInformation """En caso de que se establezcan restricciones que impidan la realización de clases presenciales, la docencia será impartida de forma telemática mediante clases emitidas en directo.
Respecto a los Objetivos de Desarrollo Sostenible, la asignatura tiene relación con los siguientes:
4- Educación de Calidad: Ya que trata de reunir a expertos relevantes de la industria aeroespacial y que aporten su visión de la industria de temas transversales, dificilmente abordables dentro de una asignatura de un plan de estudios.
Tribunal:

Presidente: Alejandro Martínez-Cava

Vocal: Javier Cubas

Secretario: Ignacio Torralbo"""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "19 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/143000122/2025-26/eventSchedule> ;
    schema:description """El objetivo de la asignatura es que el estudiante tenga una visión lo más detallada y equilibrada del sector espacial nacional e internacional, abordando los problemas del sector desde diferentes puntos de vista: tecnológico, científico y económico.

Para ello, esta asignatura se organiza como un conjunto de conferencias dictadas por personas de la industria, de la academia y de la administración con responsabilidad en actividades espaciales, dando la oportunidad a los estudiantes de establecer un dialogo con estos interlocutores a fin de mejorar su formación.

La metodología de enseñanza y aprendizaje está articulada en torno al desarrollo de sesiones de presentación de contenidos (que aquí son las conferencias citadas), donde se incentiva y evalúa la participación de los estudiantes en las sesiones de debate y consulta."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/alejandro.martinezcava%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/alejandro.martinezcava%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/andres.garcia.perez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/angel.porras.hermoso%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/antonio.fernandez.lopez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/elena.roibas%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/ignacio.torralbo%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/j.cubas%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/javier.piqueras%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/s.franchini%40upm.es> ;
    schema:name "Seminario sobre Industria e Instituciones Espaciales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000122/2025-26/E03> a ns1:Competency ;
    ns1:competencyCode "E03" ;
    ns1:competencyDescription "Conocer y comprender el entorno espacial y planetario, y su efecto en la operación de los vehículos aeroespaciales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000122/2025-26/E04> a ns1:Competency ;
    ns1:competencyCode "E04" ;
    ns1:competencyDescription "Conocer los sistemas de transferencia y protección del conocimiento, los mecanismos de cooperación internacional en el ámbito espacial, y la política de I+D+i espacial a nivel nacional e internacional"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000122/2025-26/E05> a ns1:Competency ;
    ns1:competencyCode "E05" ;
    ns1:competencyDescription "Comprender de forma estructurada la ingeniería de sistemas espaciales y las habilidades, tecnologías y metodologías relacionadas con el desarrollo de esta disciplina"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000122/2025-26/E06> a ns1:Competency ;
    ns1:competencyCode "E06" ;
    ns1:competencyDescription "Conocer las etapas y procedimientos propios en el desarrollo de un programa espacial, así como las metodologías empleadas en la integración y operación de sistemas espaciales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000122/2025-26/E07> a ns1:Competency ;
    ns1:competencyCode "E07" ;
    ns1:competencyDescription "Conocer las fases de diseño, desarrollo, integración, ensayos, lanzamiento y operación en órbita de un vehículo espacial."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000122/2025-26/E19> a ns1:Competency ;
    ns1:competencyCode "E19" ;
    ns1:competencyDescription "Comprender las metodologías para el desarrollo e integración del segmento de tierra"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000122/2025-26/RA19> a ns1:LearningResult ;
    ns1:learningResultCode "RA19" ;
    ns1:learningResultDescription "Se integra y forma parte activa de equipos de trabajo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000122/2025-26/RA20> a ns1:LearningResult ;
    ns1:learningResultCode "RA20" ;
    ns1:learningResultDescription "Razona críticamente y de forma asociativa"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000122/2025-26/RA21> a ns1:LearningResult ;
    ns1:learningResultCode "RA21" ;
    ns1:learningResultDescription "Se comunica correctamente de forma oral y escrita"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000122/2025-26/RA22> a ns1:LearningResult ;
    ns1:learningResultCode "RA22" ;
    ns1:learningResultDescription "Utiliza las Tecnologías de la Información y de las Comunicaciones"@es .

