<https://guia-kg.skai.etsisi.upm.es/resource/205000080/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. UT 1. ANÁLISIS QUÍMICO DE LOS ALIMENTOS, DIGESTIÓN Y METABOLISMO"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000080/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Tema 1. Importancia de la nutrición animal en la producción animal: influencia en los rendimientos productivos, salud de los animales, calidad de los productos animales y emisiones contaminantes. Alimentos y nutrientes."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000080/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "2.3. Tema 7. Ingestión de los alimentos. Regulación de la ingestión en los animales monogástricos y rumiantes. Factores que afectan a la ingestión. Unidades lastre. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000080/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "3. UT3. ALIMENTOS"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000080/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "3.1. Tema 8. Clasificación de los alimentos para animales. Concentrados energéticos. Clasificación y contenido en nutrientes. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000080/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "3.2. Tema 9. Concentrados proteicos de origen vegetal y animal. Clasificación y contenido en nutrientes. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000080/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "3.3. Tema 10. Forrajes: clasificación. Forrajes verdes y conservados (henos, ensilados y deshidratados). Contenido en nutrientes. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000080/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "3.4. Tema 11. Subproductos agroindustriales: clasificación. Limitaciones a su utilización. Criterios para su utilización en las diferentes especies animales. Sin subniveles"@es .

