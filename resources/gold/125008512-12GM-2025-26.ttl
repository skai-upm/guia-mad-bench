<https://guia-kg.skai.etsisi.upm.es/resource/125008512/2025-26/CFB4> a ns1:Competency ;
    ns1:competencyCode "CFB4" ;
    ns1:competencyDescription "Capacidad de visión espacial y conocimiento de las técnicas de representación gráfica, tanto por métodos tradicionales de geometría métrica y geometría descriptiva, como mediante las aplicaciones de diseño asistido por ordenador."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125008512/2025-26/CG03> a ns1:Competency ;
    ns1:competencyCode "CG03" ;
    ns1:competencyDescription "Comprender los problemas de implantación en el terreno de las infraestructuras, construcciones y edificaciones proyectadas desde las distintas especialidades de la ingeniería, analizar los mismos y proceder a su implantación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125008512/2025-26/CG05> a ns1:Competency ;
    ns1:competencyCode "CG05" ;
    ns1:competencyDescription "Determinar, medir, evaluar y representar el terreno, objetos tridimensionales, puntos y trayectorias"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125008512/2025-26/CT01> a ns1:Competency ;
    ns1:competencyCode "CT01" ;
    ns1:competencyDescription "COMUNICACIÓN ORAL Y ESCRITA Capacidad para transmitir conocimientos y expresar ideas y argumentos de manera clara, rigurosa y convincente, tanto de forma oral como escrita, utilizando los recursos gráficos y los medios necesarios adecuadamente y adaptándose a las características de la situación y de la audiencia."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125008512/2025-26/CT02> a ns1:Competency ;
    ns1:competencyCode "CT02" ;
    ns1:competencyDescription "USO DE LAS TIC Capacidad sobre conocimientos tecnológicos que permitan desenvolverse cómodamente y así afrontar los retos que la sociedad le va a imponer en su quehacer profesional en permanente autoformación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125008512/2025-26/CT04> a ns1:Competency ;
    ns1:competencyCode "CT04" ;
    ns1:competencyDescription "CREATIVIDAD Capacidad para resolver de forma nueva y original situaciones o problemas en el ámbito de la ingeniería"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125008512/2025-26/CT07> a ns1:Competency ;
    ns1:competencyCode "CT07" ;
    ns1:competencyDescription "LIDERAZGO Capacidad de influir sobre la gente para que trabaje con entusiasmo en la consecución de objetivos en pro del bien común"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125008512/2025-26/CT09> a ns1:Competency ;
    ns1:competencyCode "CT09" ;
    ns1:competencyDescription "RESOLUCIÓN DE PROBLEMAS Desarrollar en los alumnos una actitud mental mediante la aplicación de procedimientos estructurados de resolución de problemas que promueva su capacidad de aprender, comprender y aplicar conocimientos de forma autónoma."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125008512/2025-26/RA44> a ns1:LearningResult ;
    ns1:learningResultCode "RA44" ;
    ns1:learningResultDescription "Aplicar las relaciones que estudia Geometría Métrica y Proyectiva plana en el estudio de las figuras geométricas y resolver problemas en el plano"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125008512/2025-26/RA45> a ns1:LearningResult ;
    ns1:learningResultCode "RA45" ;
    ns1:learningResultDescription "Representar e interpretar correctamente las formas espaciales en el sistema acotado y en el sistema diédrico y resolver en el plano los problemas que se puedan plantear en el espacio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125008512/2025-26/RA46> a ns1:LearningResult ;
    ns1:learningResultCode "RA46" ;
    ns1:learningResultDescription "Interpretar correctamente las formas topográficas representadas por el sistema de curvas de nivel y resolver problemas de transformación de terrenos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125008512/2025-26/RA47> a ns1:LearningResult ;
    ns1:learningResultCode "RA47" ;
    ns1:learningResultDescription "Adquirir y aplicar destrezas básicas propias del dibujo asistido por ordenador"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125008512/2025-26/RA48> a ns1:LearningResult ;
    ns1:learningResultCode "RA48" ;
    ns1:learningResultDescription "Desarrollar la capacidad de razonamiento geométrico del alumno aplicando los conceptos aprendidos en la resolución de problemas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125008512/2025-26/RA49> a ns1:LearningResult ;
    ns1:learningResultCode "RA49" ;
    ns1:learningResultDescription "Desarrollar la capacidad perceptivo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125008512/2025-26/RA50> a ns1:LearningResult ;
    ns1:learningResultCode "RA50" ;
    ns1:learningResultDescription "Expresar con claridad y precisión las soluciones gráficas."@es .

