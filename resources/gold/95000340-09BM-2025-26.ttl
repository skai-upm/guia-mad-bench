    ns1:numberOfCredits 4.0 ;
    ns1:otherInformation """La asignatura se relaciona con el ODS 9 "Industria, innovación e infraestructura", en el ámbito de las TIC.
La modalidad de enseñanza es presencial.
En la asignatura se utilizará la técnica de aprendizaje basado en retos, en concreto un mini-reto relativo a integrar las entregas de laboratorio en un escenario de red."""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "39 horas y 30 minutos"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/95000340/2025-26/eventSchedule> ;
    schema:description "La asignatura de Redes y Servicios tiene como objetivo el introducir al alumno en las diferentes arquitecturas de redes y en el diseño de servicios de comunicación. Dentro de los contenidos que se presentan se pueden mencionar: aplicaciones y servicios en redes, centros de datos, protocolos de red/mensajería, tecnologías inalámbricas, y redes de sensores."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/jorge.martin.perez%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/c.lentisco%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/david.fernandez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/jorge.martin.perez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/luis.bellido%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/maria.calderon%40upm.es> ;
    schema:name "Redes y Servicios"@es .

