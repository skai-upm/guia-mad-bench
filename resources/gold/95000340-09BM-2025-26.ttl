    ns1:competencyCode "CE25" ;
    ns1:competencyDescription "Conocer los principales sistemas de comunicaciones por cable e inalámbricos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000340/2025-26/CE26> a ns1:Competency ;
    ns1:competencyCode "CE26" ;
    ns1:competencyDescription "Conocer las redes de comunicaciones y su uso en los sistemas de gestión intra e interhospitalaria"@es .

