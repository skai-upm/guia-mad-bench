    ns1:learningResultCode "RA76" ;
    ns1:learningResultDescription "Conocimientos teóricos y habilidades prácticas en las tecnologías necesarias para el desarrollo e integración de servicios de telemedicina."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000340/2025-26/RA78> a ns1:LearningResult ;
    ns1:learningResultCode "RA78" ;
    ns1:learningResultDescription "Conocimiento del entorno en el que se han de instalar y operar los servicios de telemedicina."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000340/2025-26/RA79> a ns1:LearningResult ;
    ns1:learningResultCode "RA79" ;
    ns1:learningResultDescription "Sabe aplicar las tecnologías de la información y las comunicaciones en todas las etapas del ciclo de vida"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000340/2025-26/RA81> a ns1:LearningResult ;
    ns1:learningResultCode "RA81" ;
    ns1:learningResultDescription "Conoce un conjunto de métodos, tecnologías y recursos para el diseño, desarrollo y evaluación de aplicaciones de telemedicina"@es .

