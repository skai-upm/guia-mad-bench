    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/145007202/2025-26/eventSchedule> ;
    schema:description "La asignatura de Diseño Mecánico está dedicada al estudio de las máquinas y su comportamiento dinámico a lo largo de su vida útil. En primer lugar se estudiarán los siguientes mecanismos, muy importantes en la fabricación de aeronaves: embragues y frenos, engranajes, levas, resortes y rodamientos, haciendo especial hincapié en la cinemática y dinámica de los mismos. Posteriormente se estudiarán los principales modos de fallo de los elementos de máquina y se darán pautas para determinar los modos de fallo crítico de un mecanismo. Se estudiarán los procedimientos de diseño conceptual de un elemento de máquina para maximiza su fiabilidad y se aplicarán los conocimientos adquiridos a los elementos estudiados."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/angel.mendez%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/a.alcazar%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/angel.mendez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/efren.moreno%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/j.ramiro%40upm.es> ;
    schema:name "Diseño Mecanico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145007202/2025-26/CE34> a ns1:Competency ;
    ns1:competencyCode "CE34" ;
    ns1:competencyDescription "Conocimiento adecuado y aplicado a la Ingeniería de: los métodos de cálculo y de desarrollo de instalaciones de los sistemas propulsivos; la regulación y control de instalaciones de los sistemas propulsivos; el manejo de las técnicas experimentales, equipamiento e instrumentos de medida propios de la disciplina; los combustibles y lubricantes empleados en los motores de aviación y automoción; la simulación numérica de los procesos físico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145007202/2025-26/CE35> a ns1:Competency ;
    ns1:competencyCode "CE35" ;
    ns1:competencyDescription "Conocimiento aplicado de: aerodinámica interna; teoría de la propulsión; actuaciones de aviones y de aerorreactores; ingeniería de sistemas de propulsión; mecánica y termodinámica."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145007202/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Capacidad para identificar y resolver problemas aplicando, con creatividad, los conocimientos adquiridos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145007202/2025-26/RA94> a ns1:LearningResult ;
    ns1:learningResultCode "RA94" ;
    ns1:learningResultDescription "Conocimiento, comprensión y aplicación de elementos mecánicos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145007202/2025-26/RA95> a ns1:LearningResult ;
    ns1:learningResultCode "RA95" ;
    ns1:learningResultDescription "Conocimiento de los aspectos más destacados de las cualidades de los sistemas mecánicos: modos de fallo y fiabilidad."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145007202/2025-26/RA96> a ns1:LearningResult ;
    ns1:learningResultCode "RA96" ;
    ns1:learningResultDescription "Capacidad para identificar y resolver problemas mecánicos."@es .

