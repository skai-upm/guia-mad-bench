<https://guia-kg.skai.etsisi.upm.es/resource/53001259/2025-26/%28a%29> a ns1:Competency ;
    ns1:competencyCode "(a)" ;
    ns1:competencyDescription "APLICA. Habilidad para aplicar conocimientos científicos, matemáticos y tecnológicos en sistemas relacionados con la práctica de la ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001259/2025-26/%28c%29> a ns1:Competency ;
    ns1:competencyCode "(c)" ;
    ns1:competencyDescription "DISEÑA. Habilidad para diseñar un sistema, componente o proceso que alcance los requisitos deseados teniendo en cuenta restricciones realistas tales como las económicas, medioambientales, sociales, políticas, éticas, de salud y seguridad, de fabricación y de sostenibilidad."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001259/2025-26/%28d%29> a ns1:Competency ;
    ns1:competencyCode "(d)" ;
    ns1:competencyDescription "TRABAJA EN EQUIPO. Habilidad para trabajar en equipos multidisciplinares."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001259/2025-26/%28e%29> a ns1:Competency ;
    ns1:competencyCode "(e)" ;
    ns1:competencyDescription "RESUELVE. Habilidad para identificar, formular y resolver problemas de ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001259/2025-26/%28f%29> a ns1:Competency ;
    ns1:competencyCode "(f)" ;
    ns1:competencyDescription "ES RESPONSABLE. Comprensión de la responsabilidad ética y profesional."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001259/2025-26/%28h%29> a ns1:Competency ;
    ns1:competencyCode "(h)" ;
    ns1:competencyDescription "ENTIENDE LOS IMPACTOS. Educación amplia necesaria para entender el impacto de las soluciones ingenieriles en un contexto social global."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001259/2025-26/%28i%29> a ns1:Competency ;
    ns1:competencyCode "(i)" ;
    ns1:competencyDescription "SE ACTUALIZA. Reconocimiento de la necesidad y la habilidad para comprometerse al aprendizaje continuo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001259/2025-26/%28j%29> a ns1:Competency ;
    ns1:competencyCode "(j)" ;
    ns1:competencyDescription "CONOCE. Conocimiento de los temas contemporáneos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001259/2025-26/%28k%29> a ns1:Competency ;
    ns1:competencyCode "(k)" ;
    ns1:competencyDescription "USA HERRAMIENTAS. Habilidad para usar las técnicas, destrezas y herramientas ingenieriles modernas necesarias para la práctica de la ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001259/2025-26/%28n%29> a ns1:Competency ;
    ns1:competencyCode "(n)" ;
    ns1:competencyDescription "IDEA. Creatividad"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001259/2025-26/RA217> a ns1:LearningResult ;
    ns1:learningResultCode "RA217" ;
    ns1:learningResultDescription "Conocer los sistemas y componentes de los vehículos eléctricos e híbridos y su normalización y legislación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001259/2025-26/RA218> a ns1:LearningResult ;
    ns1:learningResultCode "RA218" ;
    ns1:learningResultDescription "Conocer los principios de funcionamiento de la pila de combustible y del sistema."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001259/2025-26/RA219> a ns1:LearningResult ;
    ns1:learningResultCode "RA219" ;
    ns1:learningResultDescription "Aprender sobre el dimensionamiento de los diferentes trenes de propulsión híbridos y eléctricos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001259/2025-26/RA220> a ns1:LearningResult ;
    ns1:learningResultCode "RA220" ;
    ns1:learningResultDescription "Aprender las herramientas de cálculo que permitan predecir modelos de comportamiento de las configuraciones híbridas y con pila de combustible."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001259/2025-26/RA221> a ns1:LearningResult ;
    ns1:learningResultCode "RA221" ;
    ns1:learningResultDescription "Conocer las tecnologías relacionadas con la electromovilidad urbana e interurbana."@es .

