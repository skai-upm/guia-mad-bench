<https://guia-kg.skai.etsisi.upm.es/resource/33000943/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/33000943/2025-26/CB6>,
        <https://guia-kg.skai.etsisi.upm.es/resource/33000943/2025-26/CE11> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/33000943/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/33000943/2025-26/didactic_resource/2> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/33000943/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/33000943/2025-26/RA1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/33000943/2025-26/RA4>,
        <https://guia-kg.skai.etsisi.upm.es/resource/33000943/2025-26/RA6>,
        <https://guia-kg.skai.etsisi.upm.es/resource/33000943/2025-26/RA7> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/33000943/2025-26/syllabus> ;
    ns1:inpersonHours "55 horas (47%)"@es ;
    ns1:numberOfCredits 4.5 ;
    ns1:otherInformation ""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "55 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/33000943/2025-26/eventSchedule> ;
    schema:description """La asignatura de Herramientas BIM (Building Information Modeling) tiene como objetivo principal dotar a los estudiantes de los conocimientos y habilidades necesarios para utilizar herramientas digitales en la gestión de proyectos de construcción industrializada.
El curso abarca el modelado 3D con herramientas como Revit, la realización de simulaciones bioclimáticas para optimizar el diseño sostenible, y la utilización de escaneo láser para la captura precisa de datos del entorno construido."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/federicoluis.delblanco%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/beatriz.delriocalleja%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/federicoluis.delblanco%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/lj.sanchez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/miguel.nunez%40upm.es> ;
    schema:name "Herramientas Bim"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000943/2025-26/CB6> a ns1:Competency ;
    ns1:competencyCode "CB6" ;
    ns1:competencyDescription "Poseer y comprender conocimientos que aporten una base u oportunidad de ser originales en el desarrollo y/o aplicación de ideas, a menudo en un contexto de investigación.Tipo: Conocimiento"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000943/2025-26/CE11> a ns1:Competency ;
    ns1:competencyCode "CE11" ;
    ns1:competencyDescription "Capacidad para desenvolverse con soltura en entornos de trabajo multidisciplinares vinculados a la innovación y la investigación aplicada a los ámbitos de la construcción Industrializada y el prototipado en el proyecto arquitectónico.Tipo: Competencias"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000943/2025-26/RA1> a ns1:LearningResult ;
    ns1:learningResultCode "RA1" ;
    ns1:learningResultDescription "El alumnado será capaz de incorporar aspectos relativos al clima en el proyecto arquitectónico."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000943/2025-26/RA4> a ns1:LearningResult ;
    ns1:learningResultCode "RA4" ;
    ns1:learningResultDescription "El alumnado conocerá cuales son sus responsabilidades como técnico."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000943/2025-26/RA6> a ns1:LearningResult ;
    ns1:learningResultCode "RA6" ;
    ns1:learningResultDescription "El alumnado será capaz de planificar las fases del proyecto."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000943/2025-26/RA7> a ns1:LearningResult ;
    ns1:learningResultCode "RA7" ;
    ns1:learningResultDescription "El alumnado podrá identificar posibles soluciones a patentar."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000943/2025-26/didactic_resource/1> a ns1:DidacticResource ;
    ns1:bibliographyTitle "\"BIM Handbook: A Guide to Building Information Modeling for Owners, Managers, Designers, Engineers and Contractors\" por Chuck Eastman, Paul Teicholz, Rafael Sacks y Kathleen Liston."@es ;
    ns1:bibliographyType "Bibliografía"@es .

