<https://guia-kg.skai.etsisi.upm.es/resource/615000207/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Álgebra matricial. Sistemas de ecuaciones"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000207/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Álgebra matricial. Matriz escalonada y escalonada reducida Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000207/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "2.4. Contenido e igualdad de subespacios Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000207/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "2.5. Suma e intersección de subespacios. Relación dimensional. Suma directa Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000207/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "3. Aplicaciones lineales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000207/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "3.1. Definición y tipos de aplicaciones lineales. Expresión matricial de una aplicación lineal Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000207/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "3.2. Subespacios núcleo e imagen de una aplicación lineal. Relación dimensional Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000207/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "3.3. Construcción de aplicaciones lineales. Aplicaciones lineales y cambios de base Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000207/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "4. Diagonalización de endomorfismos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000207/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "4.1. Endomorfismo diagonalizable. Autovalor y autovector Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000207/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "4.2. Polinomio característico. Multiplicidad algebraica Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000207/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "4.3. Subespacio propio. Multiplicidad geométrica. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000207/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Algoritmo de Gauss y de Gauss-Jordan Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000207/2025-26/syllabus/20> a ns1:SyllabusItem ;
    ns1:itemIndex 20 ;
    ns1:syllabusDescription "4.4. Aplicaciones: potencias de matrices. Sistemas dinámicos discretos Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000207/2025-26/syllabus/21> a ns1:SyllabusItem ;
    ns1:itemIndex 21 ;
    ns1:syllabusDescription "5. Espacios vectoriales euclídeos y aplicaciones"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000207/2025-26/syllabus/22> a ns1:SyllabusItem ;
    ns1:itemIndex 22 ;
    ns1:syllabusDescription "5.1. Producto escalar. Norma y ángulo Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000207/2025-26/syllabus/23> a ns1:SyllabusItem ;
    ns1:itemIndex 23 ;
    ns1:syllabusDescription "5.2. Base ortogonal y ortonormal. Algoritmo de ortogonalización de Gram-Schmidt Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000207/2025-26/syllabus/24> a ns1:SyllabusItem ;
    ns1:itemIndex 24 ;
    ns1:syllabusDescription "5.3. Complemento ortogonal. Factorización QR Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000207/2025-26/syllabus/25> a ns1:SyllabusItem ;
    ns1:itemIndex 25 ;
    ns1:syllabusDescription "5.4. Proyección ortogonal. Distancia entre vector y subespacio Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000207/2025-26/syllabus/26> a ns1:SyllabusItem ;
    ns1:itemIndex 26 ;
    ns1:syllabusDescription "5.5. Problemas de mínimos cuadrados Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000207/2025-26/syllabus/27> a ns1:SyllabusItem ;
    ns1:itemIndex 27 ;
    ns1:syllabusDescription "5.6. Endomorfismos ortogonalmente diagonalizables. Matrices simétricas Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000207/2025-26/syllabus/28> a ns1:SyllabusItem ;
    ns1:itemIndex 28 ;
    ns1:syllabusDescription "5.7. Transformaciones ortogonales en el plano y el espacio. Clasificación y construcción Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000207/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "1.3. Aplicaciones del algoritmo de Gauss y Gauss-Jordan"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000207/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "1.3.1. Resolución de sistemas de ecuaciones lineales Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000207/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "1.3.2. Cálculo de la inversa de una matriz. Determinantes Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000207/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "2. Espacios vectoriales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000207/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "2.1. Sistema de vectores libres. Sistema generador Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000207/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "2.2. Base de un espacio vectorial finitamente generado. Dimensión. Coordenadas. Cambios de base Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000207/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "2.3. Subespacio vectorial. Ecuaciones implícitas y paramétricas de un subespacio Sin subniveles"@es .

