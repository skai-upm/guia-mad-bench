<https://guia-kg.skai.etsisi.upm.es/resource/43000565/2025-26/syllabus> a ns1:Syllabus ;
    ns1:hasItem <https://guia-kg.skai.etsisi.upm.es/resource/43000565/2025-26/syllabus/0>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000565/2025-26/syllabus/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000565/2025-26/syllabus/2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000565/2025-26/syllabus/3> .

<https://guia-kg.skai.etsisi.upm.es/resource/43000565/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Introducción y constituyentes. Fibras. Arquitectura de las fibras. Matrices. Intercaras. Materiales compuestos de matriz metálica. Materiales compuestos de matriz cerámica. Materiales compuestos de matriz polimérica. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000565/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "2. Micromecánica. Ecuaciones constitutivas. Comportamiento elástico. Tensiones higro-térmicas. Conductividad. Resistencia mecánica y rotura. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000565/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "3. Macromecánica. Lamina ortótropa. Criterios de fallo. Teoría de laminados. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000565/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "4. Comportamiento en service. Tolerance al daño. NDE. Reparaciones. Uniones. Aplicaciones de materiales compuestos en ingeniería civil. Sin subniveles"@es .

