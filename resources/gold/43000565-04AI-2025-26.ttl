    schema:name "Structural Composite Materials"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000565/2025-26/MICCPCE20> a ns1:Competency ;
    ns1:competencyCode "MICCPCE20" ;
    ns1:competencyDescription "Comprensión y dominio de las leyes de la termomecánica de los medios continuos y capacidad para su aplicación en ámbitos propios de la ingeniería como son la mecánica de fluidos, la mecánica de materiales, la teoría de estructuras, etc. Incorpora las competencias CB6, CB7 y CB8"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000565/2025-26/MICCPCE22> a ns1:Competency ;
    ns1:competencyCode "MICCPCE22" ;
    ns1:competencyDescription "Conocimiento y capacidad para el análisis estructural mediante la aplicación de los métodos y programas de diseño y cálculo avanzado de estructuras, a partir del conocimiento y comprensión de las solicitaciones y su aplicación a las tipologías estructurales de la ingeniería civil. Capacidad para realizar evaluaciones de integridad estructural. Incorpora als competencias CB6, CB7 y CB8."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000565/2025-26/RA129> a ns1:LearningResult ;
    ns1:learningResultCode "RA129" ;
    ns1:learningResultDescription "Tipología, diseño y cálculo de estructurales de materiales compuestos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000565/2025-26/didactic_resource/1> a ns1:DidacticResource ;
    ns1:bibliographyTitle "Principles of Composite Materials Mechanics. R. F. Gibson. Taylor & Francis, 2011."@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000565/2025-26/didactic_resource/2> a ns1:DidacticResource ;
    ns1:bibliographyTitle "Introduction to Composite Materials Design. E. J. Barbero. CRC press, 2013"@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000565/2025-26/didactic_resource/3> a ns1:DidacticResource ;
    ns1:bibliographyTitle "Composite Materials Handbook, vol. 3. Polymer-Matrix Composite Materials: Usage, Design and Analysis. MIL-HDBK-17-3F. Department of Defense, USA."@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000565/2025-26/didactic_resource/4> a ns1:DidacticResource ;
    ns1:bibliographyTitle "Apuntes en Moodle"@es ;
    ns1:bibliographyType "Recursos web"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000565/2025-26/evaluation> a ns1:EvaluationSystem ;
    ns1:evaluationDescription """Para superar la evaluación final, es necesario tener una calificación igual o superior a 5/10.
Para liberar cada examen parcial es necesario tener una calificación igual o superior a 5/10.
Si se ha obtenido una nota igual o superior a 3/10 en un examen parcial, esa materia se puede compensar con las notas de otros exámenes parciales siempre que la nota media de todos los exámenes parciales sea igual o superior a 5/10."""@es ;
    ns1:hasEvaluationTrial <https://guia-kg.skai.etsisi.upm.es/resource/43000565/2025-26/evaluation/trial1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000565/2025-26/evaluation/trial2>,
