    ns1:learningResultCode "RA115" ;
    ns1:learningResultDescription "Implementar aplicaciones sobre un Sistema Operativo de tiempo real en sistemas avanzados de procesadores"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93001104/2025-26/RA116> a ns1:LearningResult ;
    ns1:learningResultCode "RA116" ;
    ns1:learningResultDescription "Diseñar e implementar aplicaciones reales usando plataformas de diseño basadas en procesadores avanzados"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93001104/2025-26/RA215> a ns1:LearningResult ;
    ns1:learningResultCode "RA215" ;
    ns1:learningResultDescription "Analizar y diseñar sistemas electrónicos teniendo en cuenta aspectos de compatibilidad electromagnética"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93001104/2025-26/RA217> a ns1:LearningResult ;
    ns1:learningResultCode "RA217" ;
    ns1:learningResultDescription "Analizar la fiabilidad de un sistema electrónico y diseñar sistemas en base a restricciones de fiabilidad"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93001104/2025-26/RA218> a ns1:LearningResult ;
    ns1:learningResultCode "RA218" ;
    ns1:learningResultDescription "Analizar y diseñar el software de un sistema electrónico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93001104/2025-26/RA327> a ns1:LearningResult ;
