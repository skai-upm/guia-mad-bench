    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/145005402/2025-26/eventSchedule> ;
    schema:description "Estudio de las instalaciones y equipamientos eléctricos característicos de aeropuertos. Diseño y dimensionamiento de instalaciones eléctricas orientadas a aeropuertos. Así mismo, se estudian los equipos de generación auxiliar de electricidad que pueden existir en un aeropuerto, tanto en lo referente a sistemas de alimentación de emergencia como de continuidad, así como sistemas fotovoltaicos."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/daniel.alfonso.corcuera%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/angel.porras.hermoso%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/daniel.alfonso.corcuera%40upm.es> ;
    schema:name "Instalaciones Electricas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005402/2025-26/CE60> a ns1:Competency ;
    ns1:competencyCode "CE60" ;
    ns1:competencyDescription "Conocimiento aplicado de: edificación; electricidad; electrotecnia; electrónica; mecánica del vuelo; hidráulica; instalaciones aeroportuarias; ciencia y tecnología de los materiales; teoría de estructuras; mantenimiento y explotación de aeropuertos; transporte aéreo, cartografía, topografía, geotecnia y meteorología."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005402/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Capacidad para identificar y resolver problemas aplicando, con creatividad, los conocimientos adquiridos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005402/2025-26/CG9> a ns1:Competency ;
    ns1:competencyCode "CG9" ;
    ns1:competencyDescription "Razonamiento crítico y capacidad de asociación que posibiliten el aprendizaje continuo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005402/2025-26/RA143> a ns1:LearningResult ;
    ns1:learningResultCode "RA143" ;
    ns1:learningResultDescription "Aplicación de las técnicas utilizadas en el laboratorio y conocimiento de las medidas de seguridad dispuestas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005402/2025-26/RA144> a ns1:LearningResult ;
    ns1:learningResultCode "RA144" ;
    ns1:learningResultDescription "Conocimiento, comprensión, aplicación, análisis y síntesis de los fundamentos, concepción, mantenimiento y operatividad de los sistemas e instalaciones eléctricos de potencia en los sectores aeronáuticos tierra y aire."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005402/2025-26/RA626> a ns1:LearningResult ;
    ns1:learningResultCode "RA626" ;
    ns1:learningResultDescription "Se es capaz de describir los elementos que conforman una instalación eléctrica aeroportuaria."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005402/2025-26/RA627> a ns1:LearningResult ;
    ns1:learningResultCode "RA627" ;
    ns1:learningResultDescription "Se es capaz de identificar y describir los valores eléctricos normales de una instalación eléctrica aeroporturaria, así como las perturbaciones que puede llegar a sufrir."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005402/2025-26/RA628> a ns1:LearningResult ;
    ns1:learningResultCode "RA628" ;
    ns1:learningResultDescription "Se es capaz identificar y describir los sistemas de protección, control y accionamientos de una instalación eléctrica."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005402/2025-26/RA629> a ns1:LearningResult ;
    ns1:learningResultCode "RA629" ;
    ns1:learningResultDescription "Se es capaz de aplicar la normativa vigente al cálculo de corrientes de cortocircuito en diferentes puntos de una instalación eléctrica."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005402/2025-26/RA630> a ns1:LearningResult ;
    ns1:learningResultCode "RA630" ;
    ns1:learningResultDescription "Se es capaz de dimensionar correctamente las líneas eléctricas, así como aplicar la normativa al diseño de su trazado/características."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005402/2025-26/RA631> a ns1:LearningResult ;
    ns1:learningResultCode "RA631" ;
    ns1:learningResultDescription "Se es capaz de describir el principio de funcionamiento de los sistemas fotovoltaicos, sus sistemas asociados así como su conexión a la red eléctrica."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005402/2025-26/RA632> a ns1:LearningResult ;
    ns1:learningResultCode "RA632" ;
    ns1:learningResultDescription "Se es capaz de concebir enclavamientos y circuitos de control simples mediante lógica de circuitos."@es .

