    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/205000028/2025-26/eventSchedule> ;
    schema:description """En esta asignatura se aplican los principios del análisis económico a la gestión de los recursos naturales. Uno de sus principales objetivos es comprender mejor el papel de los recursos naturales en la economía para desarrollar métodos más sostenibles de gestión de esos recursos que garanticen su disponibilidad para las generaciones futuras y estudiar las interacciones entre los sistemas económicos y naturales, con el objetivo de desarrollar una economía sostenible y eficiente.
La gestión de los recursos naturales ayuda a los responsables de la toma de decisiones a comprender mejor los valores de mercado y de otro tipo asociados a las decisiones de uso y gestión de los recursos y el medio ambiente. También contribuye a la creación de capacidades y a la toma de decisiones informadas en relación con la asignación de recursos escasos con el fin de lograr beneficios ambientales y sociales óptimos."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/eva.iglesias%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/eva.iglesias%40upm.es> ;
    schema:name "Gestión de Recursos Naturales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000028/2025-26/CB03> a ns1:Competency ;
    ns1:competencyCode "CB03" ;
    ns1:competencyDescription "Que los estudiantes tengan la capacidad de reunir e interpretar datos relevantes (normalmente dentro de su área de estudio) para emitir juicios que incluyan una reflexión sobre temas relevantes de índole social, científica o ética"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000028/2025-26/CE16> a ns1:Competency ;
    ns1:competencyCode "CE16" ;
    ns1:competencyDescription "Conocer los efectos ambientales de la actividad agraria sobre el suelo, los recursos hídricos y la atmósfera, así como las principales técnicas para su mitigación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000028/2025-26/CE25> a ns1:Competency ;
    ns1:competencyCode "CE25" ;
    ns1:competencyDescription "Conocer y aplicar los principios de la Bioeconomía, así como las herramientas de análisis y gestión integrada de recursos y bioproductos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000028/2025-26/CG10> a ns1:Competency ;
    ns1:competencyCode "CG10" ;
    ns1:competencyDescription "Familiarizarse con el estudio de las interrelaciones entre las distintas perspectivas ecológicas, tecnológicas, económicas y sociales en relación con las Ciencias Agrarias y la Bioeconomía."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000028/2025-26/CT03> a ns1:Competency ;
    ns1:competencyCode "CT03" ;
    ns1:competencyDescription "Tener compromiso ético y profesional y respeto por el medio ambiente"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000028/2025-26/RA201> a ns1:LearningResult ;
    ns1:learningResultCode "RA201" ;
    ns1:learningResultDescription "Identificar los diferentes servicios que prestan los ecosistemas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000028/2025-26/RA202> a ns1:LearningResult ;
    ns1:learningResultCode "RA202" ;
    ns1:learningResultDescription "Conocer la problemática relacionada con la gestión de bienes públicos y bienes comunes"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000028/2025-26/RA203> a ns1:LearningResult ;
    ns1:learningResultCode "RA203" ;
    ns1:learningResultDescription "Conocer las diferentes técnicas de valoración económica de bienes y servicios ambientales y naturales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000028/2025-26/RA204> a ns1:LearningResult ;
    ns1:learningResultCode "RA204" ;
    ns1:learningResultDescription "Conocer los problemas específicos que caracterizan los diferentes recursos renovables."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000028/2025-26/RA205> a ns1:LearningResult ;
    ns1:learningResultCode "RA205" ;
    ns1:learningResultDescription "Conocer los problemas específicos de la economía de la contaminación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000028/2025-26/RA206> a ns1:LearningResult ;
    ns1:learningResultCode "RA206" ;
    ns1:learningResultDescription "Comprender el papel de la valoración en las políticas públicas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000028/2025-26/RA208> a ns1:LearningResult ;
    ns1:learningResultCode "RA208" ;
    ns1:learningResultDescription "Comprender las interconexiones entre producción de alimentos, uso de recursos, biodiversidad y sostenibilidad."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000028/2025-26/RA428> a ns1:LearningResult ;
    ns1:learningResultCode "RA428" ;
    ns1:learningResultDescription "Comprender e identificar la problemática relacionada con las externalidades ambientales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000028/2025-26/RA429> a ns1:LearningResult ;
    ns1:learningResultCode "RA429" ;
    ns1:learningResultDescription "Conocer las técnicas de valoración económica de bienes y servicios ambientales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000028/2025-26/RA430> a ns1:LearningResult ;
    ns1:learningResultCode "RA430" ;
    ns1:learningResultDescription "comprender y modelizar los problemas especificos que caracterizan el uso y gestión de los recursos naturales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000028/2025-26/RA431> a ns1:LearningResult ;
    ns1:learningResultCode "RA431" ;
    ns1:learningResultDescription "Comprender y analizar el impacto del cambio climático"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000028/2025-26/RA432> a ns1:LearningResult ;
    ns1:learningResultCode "RA432" ;
    ns1:learningResultDescription "Comprender y analizar el papel de la regulación y las políticas de gestión de recursos naturales"@es .

