    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/95000051/2025-26/syllabus> ;
    ns1:inpersonHours "46 horas (39.3%)"@es ;
    ns1:numberOfCredits 4.5 ;
    ns1:otherInformation """La asignatura se relaciona con los ODS 4 y 9:
Subobjetivo 4.4: Aumentar considerablemente el número de jóvenes y adultos que tienen las competencias profesionales y técnicas necesarias para acceder al empleo y al emprendimiento.
Subobjetivo 9.1: Desarrollar infraestructuras fiables, sostenibles, resilientes y de calidad."""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "46 horas"@es ;
    schema:activitiesWorkload "63%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/95000051/2025-26/eventSchedule> ;
    schema:description """Los objetivos de esta asignatura son:
Conocer los fundamentos organizativos y criptográficos en los que se basan las tecnologías de seguridad.
Conocer las principales amenazas y vulnerabilidades de los distintos elementos involucrados en las TIC, así como sus causas.
Conocer y aplicar las tecnologías que conforman una Arquitectura de Seguridad de las TIC, en sus distintas perspectivas."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/andres.mlopez%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/andres.mlopez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/ff.lazaro%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/victor.villagra%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/xavier.larriva.novo%40upm.es> ;
    schema:name "Seguridad en Sists y Redes de Telec."@es .

