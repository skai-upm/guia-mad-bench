    ns1:competencyCode "CG9" ;
    ns1:competencyDescription "Uso de Tecnologías de la Información y de las Comunicaciones"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000051/2025-26/RA461> a ns1:LearningResult ;
    ns1:learningResultCode "RA461" ;
    ns1:learningResultDescription "Capacidad de comprender la necesidad de introducir la seguridad en las redes y sistemas de telecomunicación como parte integral de su diseño y despliegue."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000051/2025-26/RA463> a ns1:LearningResult ;
    ns1:learningResultCode "RA463" ;
    ns1:learningResultDescription "Conocer las principales técnicas criptográficas simétricas y asimétricas y su aplicación a la seguridad de los sistemas y comunicaciones."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000051/2025-26/RA464> a ns1:LearningResult ;
    ns1:learningResultCode "RA464" ;
    ns1:learningResultDescription "Conocer el funcionamiento de las amenazas técnicas y humanas a la seguridad de las redes y sistemas de telecomunicación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000051/2025-26/RA465> a ns1:LearningResult ;
    ns1:learningResultCode "RA465" ;
    ns1:learningResultDescription "Categorizar adecuadamente los distintos servicios de seguridad para redes y sistemas, en función de los activos que protegen."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000051/2025-26/RA466> a ns1:LearningResult ;
    ns1:learningResultCode "RA466" ;
    ns1:learningResultDescription "Comprender los distintos mecanismos de seguridad basados en control de acceso: autenticación y defensa perimetral."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000051/2025-26/RA467> a ns1:LearningResult ;
    ns1:learningResultCode "RA467" ;
    ns1:learningResultDescription "Comprender y analizar distintos protocolos de seguridad, y cómo se aplican las técnicas criptográficas en las comunicaciones"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000051/2025-26/RA632> a ns1:LearningResult ;
    ns1:learningResultCode "RA632" ;
    ns1:learningResultDescription "Capacidad de entender y aplicar las principales técnicas de programación segura"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000051/2025-26/RA83> a ns1:LearningResult ;
    ns1:learningResultCode "RA83" ;
    ns1:learningResultDescription "Capacidad de diseñar, desplegar y gestionar arquitecturas de redes y servicios telemáticos, en redes de acceso, troncales y privadas, tanto en entornos fijos como móviles, utilizando herramientas de análisis y dimensionado de red."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000051/2025-26/RA86> a ns1:LearningResult ;
    ns1:learningResultCode "RA86" ;
    ns1:learningResultDescription "Capacidad de aplicar a las redes y servicios de telecomunicación los sistemas de gestión de red y de servicios para la configuración, operación, supervisión y tarificación de los mismos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000051/2025-26/RA87> a ns1:LearningResult ;
    ns1:learningResultCode "RA87" ;
    ns1:learningResultDescription "Capacidad de gestionar la seguridad de las redes y servicios de telecomunicación mediante la aplicación de tunelado, cortafuegos, protocolos de cifrado y autenticación, y mecanismos de protección de contenidos."@es .

