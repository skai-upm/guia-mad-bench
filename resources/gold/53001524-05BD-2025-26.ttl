    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation "The subject is related to SDG8 \"Promote inclusive and sustainable economic growth, employment and decent work for all\" and SDG9 \"Build resilient infrastructure, promote sustainable industrialization and foster innovation.\"."@es ;
