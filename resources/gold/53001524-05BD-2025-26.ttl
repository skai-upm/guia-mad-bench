        <https://guia-kg.skai.etsisi.upm.es/resource/teresa.sanchez%40upm.es> ;
    schema:name "Industrial And International Marketing"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001524/2025-26/CB06> a ns1:Competency ;
    ns1:competencyCode "CB06" ;
    ns1:competencyDescription "Poseer y comprender conocimientos que aporten una base u oportunidad de ser originales en el desarrollo y/o aplicación de ideas, a menudo en un contexto de investigación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001524/2025-26/CB08> a ns1:Competency ;
    ns1:competencyCode "CB08" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de integrar conocimientos y enfrentarse a la complejidad de formular juicios a partir de una información que, siendo incompleta o limitada, incluya reflexiones sobre las responsabilidades sociales y éticas vinculadas a la aplicación de sus conocimientos y juicios"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001524/2025-26/CB10> a ns1:Competency ;
    ns1:competencyCode "CB10" ;
    ns1:competencyDescription "Que los estudiantes posean las habilidades de aprendizaje que les permitan continuar estudiando de un modo que habrá de ser en gran medida autodirigido o autónomo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001524/2025-26/CE03> a ns1:Competency ;
    ns1:competencyCode "CE03" ;
    ns1:competencyDescription "Identificar y caracterizar las implicaciones económicas y estratégicas de las decisiones empresariales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001524/2025-26/CG06> a ns1:Competency ;
    ns1:competencyCode "CG06" ;
    ns1:competencyDescription "Conocer y aplicar las principales tramas conceptuales (frameworks) para el desarrollo de la estrategia de una organización y la gestión de los procesos de diseño, de gestión de la información y cambio de dicha organización"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001524/2025-26/CG07> a ns1:Competency ;
    ns1:competencyCode "CG07" ;
    ns1:competencyDescription "Modelar diferentes problemas de diseño de las organizaciones, conocer y seleccionar técnicas de Ingeniería de Organización apropiadas, así como obtener, comunicar, discutir y aplicar los resultados correspondientes"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001524/2025-26/CT04> a ns1:Competency ;
    ns1:competencyCode "CT04" ;
    ns1:competencyDescription "Trabaja en equipo. Habilidad para trabajar en equipos multidisciplinares"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001524/2025-26/CT05> a ns1:Competency ;
    ns1:competencyCode "CT05" ;
    ns1:competencyDescription "Resuelve. Habilidad para identificar, formular y resolver problemas de ingeniería"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001524/2025-26/CT06> a ns1:Competency ;
    ns1:competencyCode "CT06" ;
    ns1:competencyDescription "Es responsable. Comprensión de la responsabilidad ética y profesional"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001524/2025-26/CT07> a ns1:Competency ;
    ns1:competencyCode "CT07" ;
    ns1:competencyDescription "Comunica. Habilidad para comunicar eficazmente"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001524/2025-26/CT08> a ns1:Competency ;
    ns1:competencyCode "CT08" ;
    ns1:competencyDescription "Entiende los impactos. Educación amplia necesaria para entender el impacto de las soluciones ingenieriles en un contexto social global"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001524/2025-26/CT12> a ns1:Competency ;
    ns1:competencyCode "CT12" ;
    ns1:competencyDescription "Es bilingüe. Capacidad de trabajar en un entorno bilingüe (inglés/español)"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001524/2025-26/CT13> a ns1:Competency ;
    ns1:competencyCode "CT13" ;
    ns1:competencyDescription "Planifica. Organización y planificación en el ámbito de la empresa, y otras instituciones y organizaciones de proyectos y equipos humanos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001524/2025-26/CT14> a ns1:Competency ;
    ns1:competencyCode "CT14" ;
    ns1:competencyDescription "Idea. Creatividad"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001524/2025-26/RA1> a ns1:LearningResult ;
    ns1:learningResultCode "RA1" ;
    ns1:learningResultDescription "Elegir y aplicar técnicas de análisis exploratorios de grandes bases de datos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001524/2025-26/RA12> a ns1:LearningResult ;
    ns1:learningResultCode "RA12" ;
    ns1:learningResultDescription "Comprender y evaluar los efectos de la incorporación de las Tecnologías de la Información y las Comunicaciones (TIC) en todos los niveles de la organización"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001524/2025-26/RA29> a ns1:LearningResult ;
    ns1:learningResultCode "RA29" ;
    ns1:learningResultDescription "Dominar habilidades y técnicas específicas de trabajo en equipo y de dirección y gestión de equipos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001524/2025-26/RA49> a ns1:LearningResult ;
    ns1:learningResultCode "RA49" ;
    ns1:learningResultDescription "Identificar, analizar y definir estrategias de marketing industrial en contextos globales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001524/2025-26/RA54> a ns1:LearningResult ;
    ns1:learningResultCode "RA54" ;
    ns1:learningResultDescription "Entender el análisis de mercado, comportamiento de una organización de compras, la gestión de relación con los clientes, la gestión de la cadena de suministro y el los elementos de las estratégica de marketing para acceder a los clientes institucionales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001524/2025-26/RA55> a ns1:LearningResult ;
    ns1:learningResultCode "RA55" ;
    ns1:learningResultDescription "Entender los aspectos claves del diseño de producto, su ciclo de vida, los programas de comunicación, la estrategia de precios y la promoción."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001524/2025-26/RA56> a ns1:LearningResult ;
    ns1:learningResultCode "RA56" ;
    ns1:learningResultDescription "Entender y conocer las diferencias entre el mercado de gran consumo (business to consumer) y el dirigido a clientes institucionales (business to business)."@es .

