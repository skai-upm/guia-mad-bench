        <https://guia-kg.skai.etsisi.upm.es/resource/marcos.chimeno%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/roman.torres%40upm.es> ;
    schema:name "Calculo Estático y Dinámico de Estructuras por Ordenador (Patran ¿ Nastran)"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145009011/2025-26/CE03> a ns1:Competency ;
    ns1:competencyCode "CE03" ;
    ns1:competencyDescription "Conocimientos básicos sobre el uso y programación de los ordenadores, sistemas operativos, bases de datos y programas informáticos con aplicación en ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145009011/2025-26/CE07> a ns1:Competency ;
    ns1:competencyCode "CE07" ;
    ns1:competencyDescription "Comprender el comportamiento de las estructuras ante las solicitaciones en condiciones de servicio y situaciones límite."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145009011/2025-26/CE15> a ns1:Competency ;
    ns1:competencyCode "CE15" ;
    ns1:competencyDescription "Conocimiento adecuado y aplicado a la Ingeniería de: Los principios de la mecánica del medio continuo y las técnicas de cálculo de su respuesta."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145009011/2025-26/CE18> a ns1:Competency ;
    ns1:competencyCode "CE18" ;
    ns1:competencyDescription "Conocimiento adecuado y aplicado a la Ingeniería de: Los fundamentos de la mecánica de fluidos; los principios básicos del control y la automatización del vuelo; las principales características y propiedades físicas y mecánicas de los materiales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145009011/2025-26/CE19> a ns1:Competency ;
    ns1:competencyCode "CE19" ;
    ns1:competencyDescription "Conocimiento aplicado de: la ciencia y tecnología de los materiales; mecánica y termodinámica; mecánica de fluidos; aerodinámica y mecánica del vuelo; sistemas de navegación y circulación aérea; tecnología aeroespacial; teoría de estructuras; transporte aéreo; economía y producción; proyectos; impacto ambiental."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145009011/2025-26/CE20> a ns1:Competency ;
    ns1:competencyCode "CE20" ;
    ns1:competencyDescription "Conocimiento adecuado y aplicado de los métodos matemáticos necesarios para el estudio y la resolución de los problemas asociados a la Ingeniería Aeroespacial."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145009011/2025-26/CE22> a ns1:Competency ;
    ns1:competencyCode "CE22" ;
    ns1:competencyDescription "Conocimiento adecuado y aplicado a la Ingeniería de: La mecánica de fractura del medio continuo y los planteamientos dinámicos, de fatiga de inestabilidad estructural y de aeroelasticidad."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145009011/2025-26/CE27> a ns1:Competency ;
    ns1:competencyCode "CE27" ;
    ns1:competencyDescription "Conocimiento adecuado y aplicado a la Ingeniería de: los métodos de cálculo de diseño y proyecto aeronáutico; el uso de la experimentación aerodinámica y de los parámetros más significativos en la aplicación teórica; el manejo de las técnicas experimentales, equipamiento e instrumentos de medida propios de la disciplina; la simulación, diseño, análisis e interpretación de experimentación y operaciones en vuelo; los sistemas de mantenimiento y certificación de aeronaves"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145009011/2025-26/CE28> a ns1:Competency ;
    ns1:competencyCode "CE28" ;
    ns1:competencyDescription "Conocimiento aplicado de: aerodinámica; mecánica y termodinámica, mecánica del vuelo, ingeniería de aeronaves (ala fija y alas rotatorias), teoría de estructuras."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145009011/2025-26/CE31> a ns1:Competency ;
    ns1:competencyCode "CE31" ;
    ns1:competencyDescription "Comprensión de las propiedades y comportamiento de los materiales utilizados en los vehículos aeroespaciales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145009011/2025-26/CE33> a ns1:Competency ;
    ns1:competencyCode "CE33" ;
    ns1:competencyDescription "Conocimiento adecuado y aplicado a la Ingeniería de: La mecánica de fractura del medio continuo y los planteamientos dinámicos, de fatiga de inestabilidad estructural y de aeroelasticidad."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145009011/2025-26/CE55> a ns1:Competency ;
    ns1:competencyCode "CE55" ;
    ns1:competencyDescription "Conocimiento adecuado y aplicado a la Ingeniería de los métodos de diseño y proyecto aeronáutico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145009011/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Capacidad para identificar y resolver problemas aplicando, con creatividad, los conocimientos adquiridos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145009011/2025-26/RA231> a ns1:LearningResult ;
    ns1:learningResultCode "RA231" ;
    ns1:learningResultDescription "Comprensión, análisis y cálculo de problemas sencillos de elementos estructurales bajo comportamiento lineal."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145009011/2025-26/RA232> a ns1:LearningResult ;
    ns1:learningResultCode "RA232" ;
    ns1:learningResultDescription "Comprensión de la teoría básica y de la solución de algunos problemas fundamentales en elasticidad lineal de sólidos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145009011/2025-26/RA233> a ns1:LearningResult ;
    ns1:learningResultCode "RA233" ;
    ns1:learningResultDescription "Conocimiento, comprensión y aplicación de los métodos de cálculo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145009011/2025-26/RA234> a ns1:LearningResult ;
    ns1:learningResultCode "RA234" ;
    ns1:learningResultDescription "Aplicación, análisis y síntesis de estructuras."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145009011/2025-26/RA235> a ns1:LearningResult ;
    ns1:learningResultCode "RA235" ;
    ns1:learningResultDescription "Comprensión de las ecuaciones y principios generales del medio continuo, así como la adecuada selección de los diferentes modelos de comportamiento de sólidos deformables."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145009011/2025-26/RA237> a ns1:LearningResult ;
    ns1:learningResultCode "RA237" ;
    ns1:learningResultDescription "Conocimiento, comprensión, aplicación, análisis y síntesis de la teoría de estructuras en las aeronaves."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145009011/2025-26/RA241> a ns1:LearningResult ;
    ns1:learningResultCode "RA241" ;
    ns1:learningResultDescription "Conocimiento, comprensión, aplicación, análisis y síntesis del cálculo matricial de estructuras civiles, así como de los diferentes tipos de pandeo de elementos estructurales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145009011/2025-26/RA252> a ns1:LearningResult ;
    ns1:learningResultCode "RA252" ;
    ns1:learningResultDescription "Conocimiento, comprensión, aplicación, análisis y síntesis de los sistemas vibratorios de un grado de libertad, de múltiples grados de libertad y continuos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145009011/2025-26/RA253> a ns1:LearningResult ;
    ns1:learningResultCode "RA253" ;
    ns1:learningResultDescription "Conocimiento, comprensión, aplicación, análisis y síntesis de los métodos aproximados de cálculo para los sistemas continuos."@es .

