    ns1:itemIndex 12 ;
    ns1:syllabusDescription "3.1. Representación. Curvas de nivel. Interpretación de las curvas de nivel. Trazado de lineas de igual pendiente. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000178/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "3.2. Intersección de un terreno con un plano. Perfiles longitudinales y transversales. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000178/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "3.3. Configuración definitiva de una plataforma o vial en una superficie topográfica. Trazado de una plataforma o vial horizontal. Bordes rectos y curvos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000178/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "3.4. Trazado de una plataforma o vial inclinado. Bordes rectos y curvos inclinados. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000178/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Representación del punto, la recta y el plano. Pendiente. Módulo o intervalo. Graduación de una recta. Rectas del plano. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000178/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "1.3. Pertenencias. Paralelismo y Perpendicularidad. Distancias. Abatimientos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000178/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "1.4. Ángulos. Casos directos e inversos.Recta con una pendiente determinada en un plano. Plano que conteniendo a una recta tenga una determinada pendiente. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000178/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "1.5. Intersecciones de planos. Intersección de recta y plano. Casos particulares. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000178/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "2. Aplicaciones del Sistema de Planos Acotados. CUBIERTAS"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000178/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "2.1. Definición. Nomenclatura. Resolución de cubiertas. Caso general. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000178/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "2.2. Cubiertas con patios. Resolución de cubiertas. Casos particulares. Sin subniveles"@es .

