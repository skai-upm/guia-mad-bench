<https://guia-kg.skai.etsisi.upm.es/resource/135005405/2025-26/CB02> a ns1:Competency ;
    ns1:competencyCode "CB02" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar sus conocimientos a su trabajo o vocación de una forma profesional y posean las competencias que suelen demostrarse por medio de la elaboración y defensa de argumentos y la resolución de problemas dentro de su área de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005405/2025-26/CE%201.05> a ns1:Competency ;
    ns1:competencyCode "CE 1.05" ;
    ns1:competencyDescription "Profundizar en el conocimiento de las herramientas matemáticas necesarias para la adecuada comprensión y modelización de los fenómenos que tienen lugar en la naturaleza, así como para el desarrollo de las técnicas necesarias para la gestión del Medio Natural."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005405/2025-26/CE%201.07> a ns1:Competency ;
    ns1:competencyCode "CE 1.07" ;
    ns1:competencyDescription "Ser capaz de diseñar y realizar experimentos apropiados, interpretar los datos y extraer conclusiones."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005405/2025-26/CE%201.08> a ns1:Competency ;
    ns1:competencyCode "CE 1.08" ;
    ns1:competencyDescription "Conocer y aplicar las técnicas biométricas que permitan cuantificar las biocenosis tanto a nivel de los seres vivos como de las poblaciones."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005405/2025-26/CT06> a ns1:Competency ;
    ns1:competencyCode "CT06" ;
    ns1:competencyDescription "Desarrollar la capacidad para trabajar en equipo, integrándose y colaborando de forma activa en la consecución de objetivos comunes."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005405/2025-26/RA29> a ns1:LearningResult ;
    ns1:learningResultCode "RA29" ;
    ns1:learningResultDescription "Manejar la información estadística de forma tabular, numérica y graficamente, para sintetizarla"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005405/2025-26/RA30> a ns1:LearningResult ;
    ns1:learningResultCode "RA30" ;
    ns1:learningResultDescription "Plantear y validar modelos estadísticos que resuelvan problemas que puedan plantearse en la ingeniería"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005405/2025-26/RA31> a ns1:LearningResult ;
    ns1:learningResultCode "RA31" ;
    ns1:learningResultDescription "Conocer como tomar una muestra representativa de una población y a partir de ellla predecir parámetros de toda la población"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005405/2025-26/RA32> a ns1:LearningResult ;
    ns1:learningResultCode "RA32" ;
    ns1:learningResultDescription "Aplicar las técnicas estadísticas elementales en la resolución de problemas prácticos concretos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005405/2025-26/RA75> a ns1:LearningResult ;
    ns1:learningResultCode "RA75" ;
    ns1:learningResultDescription "RA 477 Adquirir habilidad para el seguimiento a través del muestreo, la medida y la observación de datos para su recopilación y documentación de forma sistemática y fiable"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005405/2025-26/RA97> a ns1:LearningResult ;
    ns1:learningResultCode "RA97" ;
    ns1:learningResultDescription "Determinar el tipo de inventario y técnica de muestreo más adecuada para las distintas variables y grupos taxonómicos de interés"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005405/2025-26/RA98> a ns1:LearningResult ;
    ns1:learningResultCode "RA98" ;
    ns1:learningResultDescription "Cuantificar la biodiversidad de la vegetación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005405/2025-26/RA99> a ns1:LearningResult ;
    ns1:learningResultCode "RA99" ;
    ns1:learningResultDescription "Cuantificar la biomasa y el volumen de la vegetación"@es .

