<https://guia-kg.skai.etsisi.upm.es/resource/55001034/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/55001034/2025-26/CE%2019>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55001034/2025-26/CE%2020>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55001034/2025-26/CG%201>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55001034/2025-26/CG%203>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55001034/2025-26/CG%204>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55001034/2025-26/CG%207> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/55001034/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55001034/2025-26/didactic_resource/2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55001034/2025-26/didactic_resource/3> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/55001034/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/55001034/2025-26/RA146>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55001034/2025-26/RA147> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/55001034/2025-26/syllabus> ;
    ns1:inpersonHours "32 horas (41%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation """A lo largo de esta asignatura se potenciarán las competencias y capacidades de los Ingenieros Químicos relacionadas con el diseño de procesos químicos que permitan una producción y consumo de materias primas y energía responsable.
En concreto, la asignatura se relaciona con el ODS 9 "Industria, innovación e infraestructuras" y el ODS 12 "Producción y consumo responsables"."""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "32 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/55001034/2025-26/eventSchedule> ;
    schema:description ""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/salvador.leon%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/salvador.leon%40upm.es> ;
    schema:name "Principios de Procesos Quimicos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001034/2025-26/CE%2019> a ns1:Competency ;
    ns1:competencyCode "CE 19" ;
    ns1:competencyDescription "Conocimientos sobre balances de materia y energía, biotecnología, transferencia de materia, operaciones de separación, ingeniería de la reacción química, diseño de reactores, y valoración y transformación de materias primas y recursos energéticos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001034/2025-26/CE%2020> a ns1:Competency ;
    ns1:competencyCode "CE 20" ;
    ns1:competencyDescription "Capacidad para el análisis, diseño, simulación y optimización de procesos y productos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001034/2025-26/CG%201> a ns1:Competency ;
    ns1:competencyCode "CG 1" ;
    ns1:competencyDescription "Conocer y aplicar los conocimientos de ciencias y tecnologías básicas a la práctica de la Ingeniería Industria"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001034/2025-26/CG%203> a ns1:Competency ;
    ns1:competencyCode "CG 3" ;
    ns1:competencyDescription "Aplicar los conocimientos adquiridos para identificar, formular y resolver problemas en contextos amplios, siendo capaces de integrar los trabajando en equipos multidisciplinares"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001034/2025-26/CG%204> a ns1:Competency ;
    ns1:competencyCode "CG 4" ;
    ns1:competencyDescription "Comprender el impacto de la ingeniería en el medio ambiente, el desarrollo sostenible de la sociedad y la importancia de trabajar en un entorno profesional y responsable"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001034/2025-26/CG%207> a ns1:Competency ;
    ns1:competencyCode "CG 7" ;
    ns1:competencyDescription "Incorporar las TIC y las tecnologías y herramientas de la Ingeniería Industrial en sus actividades profesionales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001034/2025-26/RA146> a ns1:LearningResult ;
    ns1:learningResultCode "RA146" ;
    ns1:learningResultDescription "Análisis integral de procesos químicos y sus eficiencias globales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001034/2025-26/RA147> a ns1:LearningResult ;
    ns1:learningResultCode "RA147" ;
    ns1:learningResultDescription "Información de balances de materia y energía para el diseño básico de operaciones básicas en una planta química"@es .

