<https://guia-kg.skai.etsisi.upm.es/resource/135005401/2025-26/CE%201.18> a ns1:Competency ;
    ns1:competencyCode "CE 1.18" ;
    ns1:competencyDescription "Conocer los fundamentos científicos de la dinámica de poblaciones de especies amenazadas, y poder aplicar las estrategias de conservación basadas en protección genética y de hábitats."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005401/2025-26/CE%201.20> a ns1:Competency ;
    ns1:competencyCode "CE 1.20" ;
    ns1:competencyDescription "Conocer y analizar los procesos hidrológicos de trascendencia ecológica, siendo capaz de modelizarlos de cara a la gestión sostenible de las cuencas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005401/2025-26/CE%201.24> a ns1:Competency ;
