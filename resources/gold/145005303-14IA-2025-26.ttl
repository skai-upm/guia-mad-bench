<https://guia-kg.skai.etsisi.upm.es/resource/145005303/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Tema 1"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005303/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Generalidades, cambios de base. Sistema binario, códigos binarios. Bases octal y hexadecimal. Códigos alfanuméricos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005303/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "4. Tema 4"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005303/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "4.1. Memorias, clasificación y tipos. Estructura interna. Direccionamiento, ampliación de la capacidad, mapas de memoria. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005303/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "4.2. Conversores A/D y D/A. Tipos y estructura interna. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005303/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "4.3. Historia y evolución de los microprocesadores. Estructura interna. Buses de conexión. Modos de funcionamiento, excepciones e interrupciones. El MC68000, estructura interna, señales de entrada y salida. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005303/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "5. Tema 5"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005303/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "5.1. Hardware del MC68000 Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005303/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "5.2. Lenguaje ensamblador & código máquina, nemónicos del MC68000. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005303/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "5.3. Estructura de un programa realizado en ensamblador. Tratamiento de las excepciones. Assembler y Linker. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005303/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "6. Tema 6"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005303/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "6.1. Microcontroladores, estructura interna. Ventajas/desventajas respecto de sistemas basados en microprocesador. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005303/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Operaciones básicas del álgebra de Boole, propiedades y teoremas. Puertas lógicas. Funciones lógicas, formas canónicas. Tabla de verdad de una función lógica. Minimización de funciones con mapas de Karnaugh. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005303/2025-26/syllabus/20> a ns1:SyllabusItem ;
    ns1:itemIndex 20 ;
    ns1:syllabusDescription "6.2. Hardware de los microcontroladores ATMEL Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005303/2025-26/syllabus/21> a ns1:SyllabusItem ;
    ns1:itemIndex 21 ;
    ns1:syllabusDescription "6.3. Software de programación en alto nivel. Programas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005303/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "2. Tema 2"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005303/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "2.1. Tipos de lógica en función de la tensión, familias lógicas Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005303/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "2.2. Parámetros de una puerta lógica. Familia TTL, puerta básica. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005303/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "2.3. Tipos de circuitos digitales. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005303/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "3. Tema 3"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005303/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "3.1. Sistemas combinacionales. Circuitos en MSI: Multiplexores, Demultiplexores, Codificadores, Decodificadores, Comparadores, Sumadores, ALU?s, Generadores y Detectores de Paridad. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005303/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "3.2. Sistemas secuenciales. Biestables SR, JK, D y T. Entradas síncronas y asíncronas. Tablas de transición. Sistemas en MSI: Registros, Contadores, Máquinas de estados. Aplicación en Lógica cableada. Lógica programable. Sin subniveles"@es .

