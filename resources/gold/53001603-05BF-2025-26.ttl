    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/53001603/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/53001603/2025-26/RA24>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001603/2025-26/RA65>,
