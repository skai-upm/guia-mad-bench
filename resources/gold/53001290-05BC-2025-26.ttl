<https://guia-kg.skai.etsisi.upm.es/resource/53001290> a ns1:Course ;
    ns1:courseType "Optativa"@es ;
    ns1:courseYear 2 ;
    ns1:semester "Tercer semestre"@es ;
    schema:courseCode 53001290 ;
    schema:hasCourseInstance <https://guia-kg.skai.etsisi.upm.es/resource/53001290/2025-26> ;
    schema:name "Innovation And Patents For Engineering"@en,
        "Vigilancia Tecnologica Competitiva"@es ;
    schema:numberOfCredits 3.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/53001290/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/53001290/2025-26/CE4>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001290/2025-26/CE7>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001290/2025-26/CE8>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001290/2025-26/CE9>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001290/2025-26/CG1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001290/2025-26/CG10>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001290/2025-26/CG11>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001290/2025-26/CG4> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/53001290/2025-26/didactic_resource/1> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/53001290/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/53001290/2025-26/RA148>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001290/2025-26/RA149>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001290/2025-26/RA150>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001290/2025-26/RA151>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001290/2025-26/RA152> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/53001290/2025-26/syllabus> ;
    ns1:inpersonHours "30 horas (38.5%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation ""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "30 horas"@es ;
    schema:activitiesWorkload "1500%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/53001290/2025-26/eventSchedule> ;
    schema:description "5.1. Course Description This course reviews the fundamental concepts for adequate technology monitoring in companies and organizations in general, with an emphasis on the analysis of technology-based information?especially patents?as well as the typical processes involved in R&D&I management. Processes are analyzed using a systemic approach for regular implementation, in accordance with the internal demands/needs of each organization and the environment/market. The teaching objectives are to acquire the knowledge and skills necessary for students to: 1. Assimilate basic knowledge of technological monitoring and intelligence and be able to integrate these into a specific strategic plan, so that R&D&I is naturally applied therein. 2. Develop skills to identify and evaluate monitoring practices, as well as patent analysis and research. 3. Become familiar with available open sources and search tools and analyze technological information. 4. Be able to develop skills and formalize systematic processes that allow for the implementation of surveillance units in organizations."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/victor.gomez.frias%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/joseantonio.blanco%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/victor.gomez.frias%40upm.es> ;
    schema:name "Vigilancia Tecnologica Competitiva"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001290/2025-26/CE4> a ns1:Competency ;
    ns1:competencyCode "CE4" ;
    ns1:competencyDescription "Tener habilidad para solucionar problemas que son poco familiares, incompletamente definidos, y tienen especificaciones en competencia, considerando los posibles métodos de solución, incluidos los más innovadores, seleccionando el más apropiado, y poder corregir la puesta en práctica, evaluando las diferentes soluciones de diseño"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001290/2025-26/CE7> a ns1:Competency ;
    ns1:competencyCode "CE7" ;
    ns1:competencyDescription "Dirigir y organizar empresas, así como sistemas de producción y servicios, aplicando conocimientos y capacidades de organización industrial, estrategia comercial, planificación y logística, legislación mercantil y laboral, contabilidad financiera y de costes."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001290/2025-26/CE8> a ns1:Competency ;
    ns1:competencyCode "CE8" ;
    ns1:competencyDescription "Dirigir y gestionar la organización del trabajo y los recursos humanos aplicando criterios de seguridad industrial, gestión de la calidad, prevención de riesgos laborales, sostenibilidad, y gestión medioambiental."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001290/2025-26/CE9> a ns1:Competency ;
    ns1:competencyCode "CE9" ;
    ns1:competencyDescription "Gestionar la Investigación, Desarrollo e Innovación Tecnológica, atendiendo a la transferencia de tecnología y los derechos de propiedad y de patentes."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001290/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Capacidad para aplicar el método científico y los principios de la ingeniería y economía, para formular y resolver problemas complejos en procesos, equipos, instalaciones y servicios, en los que la materia experimente cambios en su composición, estado o contenido energético, característicos de la industria química y de otros sectores relacionados entre los que se encuentran el farmacéutico, biotecnológico, materiales, energético, alimentario o medioambiental."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001290/2025-26/CG10> a ns1:Competency ;
    ns1:competencyCode "CG10" ;
    ns1:competencyDescription "Adaptarse a los cambios, siendo capaz de aplicar tecnologías nuevas y avanzadas y otros progresos relevantes, con iniciativa y espíritu emprendedor."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001290/2025-26/CG11> a ns1:Competency ;
    ns1:competencyCode "CG11" ;
    ns1:competencyDescription "Poseer las habilidades del aprendizaje autónomo para mantener y mejorar las competencias propias de la ingeniería química que permitan el desarrollo continuo de la profesión"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001290/2025-26/CG4> a ns1:Competency ;
    ns1:competencyCode "CG4" ;
    ns1:competencyDescription "Realizar la investigación apropiada, emprender el diseño y dirigir el desarrollo de soluciones de ingeniería, en entornos nuevos o poco conocidos, relacionando creatividad, originalidad, innovación y transferencia de tecnología"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001290/2025-26/RA148> a ns1:LearningResult ;
    ns1:learningResultCode "RA148" ;
    ns1:learningResultDescription "Adquiere conocimientos de búsqueda y análisis de información en las BBDD de patentes"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001290/2025-26/RA149> a ns1:LearningResult ;
    ns1:learningResultCode "RA149" ;
    ns1:learningResultDescription "Adquiere conocimientos de como implantar unidades de inteligencia en las organizaciones"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001290/2025-26/RA150> a ns1:LearningResult ;
    ns1:learningResultCode "RA150" ;
    ns1:learningResultDescription "Formaliza procesos sistémicos que permitan realizar la tarea de analizar el entorno de mercado tecnológico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001290/2025-26/RA151> a ns1:LearningResult ;
    ns1:learningResultCode "RA151" ;
    ns1:learningResultDescription "Integra la inteligencia de mercados tecnológicos en la cadena de valor y en el proceso de innovación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001290/2025-26/RA152> a ns1:LearningResult ;
    ns1:learningResultCode "RA152" ;
    ns1:learningResultDescription "El alumno identifica y maneja fuentes abiertas disponibles de información tecnologico"@es .

