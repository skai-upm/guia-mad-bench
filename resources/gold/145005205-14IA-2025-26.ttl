    ns1:inpersonHours "52 horas (51.4%)"@es ;
    ns1:numberOfCredits 3.75 ;
    ns1:otherInformation """El alumno podrá usar material auxiliar durante los exámenes.
Para los alumnos que hayan aprobado en la convocatoria ordinaria (por evaluación continua o por examen final), el informe de laboratorio podrá servir para aumentar la nota final hasta en dos puntos."""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
