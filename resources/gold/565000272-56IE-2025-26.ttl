    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/565000272/2025-26/eventSchedule> ;
    schema:description """Esta asignatura comprende todos los sistemas de protección utilizados en las instalaciones eléctricas, excepto las protecciones contra sobretensiones. Está dividida en:
- Protección de sobreintensidades en baja tensión: temas 1 al 6
- Protección de personas contra choques eléctricos: temas 7 al 10
- Protecciones en instalaciones eléctricas alta tensión: temas 11 al 16"""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/julio.amador%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/julio.amador%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/ricardo.granizo%40upm.es> ;
    schema:name "Protecciones Electricas"@es .

