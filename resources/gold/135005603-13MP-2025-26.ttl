    schema:name "Proteccion de Sistemas Naturales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005603/2025-26/CE%201.01> a ns1:Competency ;
    ns1:competencyCode "CE 1.01" ;
    ns1:competencyDescription "Conocer los campos de aplicación de la Ingeniería del Medio Natural, y tener una apreciación de la necesidad de poseer unos conocimientos técnicos profundos en ciertas áreas de aplicación; apreciación del grado de esta necesidad en, por lo menos, una situación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005603/2025-26/CE%201.02> a ns1:Competency ;
    ns1:competencyCode "CE 1.02" ;
    ns1:competencyDescription "Comprender los fundamentos biológicos, éticos, sociológicos y económicos que condicionan la conservación de especies y la protección del Medio Natural."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005603/2025-26/CG01> a ns1:Competency ;
    ns1:competencyCode "CG01" ;
    ns1:competencyDescription "Aplicar de manera autónoma nuevos conocimientos y técnicas adecuados para la concepción, el desarrollo o la explotación de tecnología para la gestión, conservación y protección del Medio Natural"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005603/2025-26/CG09> a ns1:Competency ;
    ns1:competencyCode "CG09" ;
    ns1:competencyDescription "Determinar y diseñar actuaciones preventivas, correctoras y compensatorias de los efectos ambientales y ecológicos causados por actuaciones que van a ser ejecutadas en el Medio Natural"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005603/2025-26/CG10> a ns1:Competency ;
    ns1:competencyCode "CG10" ;
    ns1:competencyDescription "Diseñar e implementar actuaciones de restauración de territorios y ecosistemas naturales afectados por los distintos procesos de degradación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005603/2025-26/RA131> a ns1:LearningResult ;
    ns1:learningResultCode "RA131" ;
    ns1:learningResultDescription "Adquirir habilidades y terminología adecuadas a la construcción de infraestructuras en el medio natural, así como el proyecto y diseño de las mismas"@es .

