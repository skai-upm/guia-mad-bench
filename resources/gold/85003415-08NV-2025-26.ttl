    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/85003415/2025-26/eventSchedule> ;
    schema:description "En esta asignatura se estudian equipos que se utilizan en el ámbito naval y también comunes en otros campos de la industria. Se presta especial atención a al cálculo de pérdidas de carga en tuberías y a las bombas centrífugas, terminando con bombas de vacío y desplazamiento positivo, ventiladores, compresores, equipos de separación de fluidos y generadores de agua dulce"@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/enrique.tremps%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/enrique.tremps%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/juanmanuel.delacruz%40upm.es> ;
    schema:name "Equipos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003415/2025-26/CB5> a ns1:Competency ;
    ns1:competencyCode "CB5" ;
    ns1:competencyDescription "Que los estudiantes hayan desarrollado aquellas habilidades de aprendizaje necesarias para emprender estudios posteriores con un alto grado de autonomía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003415/2025-26/CE%2013> a ns1:Competency ;
    ns1:competencyCode "CE 13" ;
    ns1:competencyDescription "Conocimiento de la mecánica y de los componentes de maquinas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003415/2025-26/CE%2015> a ns1:Competency ;
    ns1:competencyCode "CE 15" ;
    ns1:competencyDescription "Conocimiento de las características de los sistemas de propulsión naval"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003415/2025-26/CE%207> a ns1:Competency ;
    ns1:competencyCode "CE 7" ;
    ns1:competencyDescription "Conocimiento de los conceptos fundamentales de la mecánica de fluidos y de su aplicación a las carenas de buques y artefactos, y a las máquinas, equipos y sistemas navales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003415/2025-26/CE%208> a ns1:Competency ;
    ns1:competencyCode "CE 8" ;
    ns1:competencyDescription "Conocimiento de la ciencia y tecnología de materiales y capacidad para su selección y para la evaluación de su comportamiento."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003415/2025-26/CG4> a ns1:Competency ;
    ns1:competencyCode "CG4" ;
    ns1:competencyDescription "Capacidad necesaria para resolver problemas con iniciativa, toma de decisiones, creatividad, razonamiento crítico y para comunicar y transmitir conocimientos, habilidades y destrezas en los procesos del proyecto y la construcción de buques."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003415/2025-26/RA10> a ns1:LearningResult ;
    ns1:learningResultCode "RA10" ;
    ns1:learningResultDescription "Resolver problemas de mecánica, mecánica de fluidos, oscilaciones y ondas relacionados con la ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003415/2025-26/RA11> a ns1:LearningResult ;
    ns1:learningResultCode "RA11" ;
    ns1:learningResultDescription "Conocer el significado y las unidades de las magnitudes físicas, así como su orden de magnitud y resolver problemas básicos de ingeniería, expresando el resultado numérico en las unidades físicas correspondientes."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003415/2025-26/RA14> a ns1:LearningResult ;
    ns1:learningResultCode "RA14" ;
    ns1:learningResultDescription "Resolver los problemas cinemáticos, estáticos y dinámicos de los sistemas de partículas y del sólido rígido."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003415/2025-26/RA16> a ns1:LearningResult ;
    ns1:learningResultCode "RA16" ;
    ns1:learningResultDescription "Resolver problemas sencillos de hidrodinámica."@es .

