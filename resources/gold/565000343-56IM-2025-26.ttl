        <https://guia-kg.skai.etsisi.upm.es/resource/eduardo.faleiro%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/elena.cerro%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/manuel.abuin%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/sergio.catalan.gomez%40upm.es> ;
    schema:name "Transmision de Calor"@es .

