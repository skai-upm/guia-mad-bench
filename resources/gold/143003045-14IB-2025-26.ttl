    ns1:learningResultCode "RA105" ;
    ns1:learningResultDescription "Conocimiento adecuado de los principales impactos ambientales locales y globales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143003045/2025-26/RA107> a ns1:LearningResult ;
