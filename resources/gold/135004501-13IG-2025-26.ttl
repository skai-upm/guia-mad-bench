<https://guia-kg.skai.etsisi.upm.es/resource/135004501/2025-26/RA231> a ns1:LearningResult ;
    ns1:learningResultCode "RA231" ;
    ns1:learningResultDescription "Diagnosticar situaciones selvícolas de las masas forestales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004501/2025-26/RA232> a ns1:LearningResult ;
    ns1:learningResultCode "RA232" ;
    ns1:learningResultDescription "Conocer y analizar los principales esquemas selvícolas de las especies forestales más relevantes en España"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004501/2025-26/RA233> a ns1:LearningResult ;
    ns1:learningResultCode "RA233" ;
    ns1:learningResultDescription "Aplicar los conociemientos de la Selvicultura a la defensa de argumentos y resolución de problemas dentro del campo del tratamiento de los montes"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004501/2025-26/RA234> a ns1:LearningResult ;
    ns1:learningResultCode "RA234" ;
    ns1:learningResultDescription "Porponer y deseñar los tratamientos selvícolas más adecuados según especies, estado de las masas forestales y objetivos de las mismas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004501/2025-26/RA235> a ns1:LearningResult ;
    ns1:learningResultCode "RA235" ;
    ns1:learningResultDescription "Tomar conciencia de la importancia de la Selvicultura en el mundo y en España, considerando sus productos finales económicos y ecológicos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004501/2025-26/RA236> a ns1:LearningResult ;
    ns1:learningResultCode "RA236" ;
    ns1:learningResultDescription "Presentar en público y defender, con argumentos técnicos y científicos, trabajos de caracterización, diagnóstico, evaluación, planificación y gestión de masas forestales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004501/2025-26/RA237> a ns1:LearningResult ;
    ns1:learningResultCode "RA237" ;
    ns1:learningResultDescription "Realizar los señalamientos correspondientes a los distintos tratamientos de regeneración y mejora"@es .

