<https://guia-kg.skai.etsisi.upm.es/resource/53001573/2025-26/CB06> a ns1:Competency ;
    ns1:competencyCode "CB06" ;
    ns1:competencyDescription "Poseer y comprender conocimientos que aporten una base u oportunidad de ser originales en el desarrollo y/o aplicación de ideas, a menudo en un contexto de investigación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001573/2025-26/CB07> a ns1:Competency ;
    ns1:competencyCode "CB07" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en entornos nuevos o poco conocidos dentro de contextos más amplios (o multidisciplinares) relacionados con su área de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001573/2025-26/CB10> a ns1:Competency ;
    ns1:competencyCode "CB10" ;
    ns1:competencyDescription "Que los estudiantes posean las habilidades de aprendizaje que les permitan continuar estudiando de un modo que habrá de ser en gran medida autodirigido o autónomo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001573/2025-26/CE03> a ns1:Competency ;
    ns1:competencyCode "CE03" ;
    ns1:competencyDescription "Capacidad para realizar un diseño integral de un proyecto básico de visión por computador."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001573/2025-26/CG02> a ns1:Competency ;
    ns1:competencyCode "CG02" ;
    ns1:competencyDescription "Realizar investigaciÃ³n, desarrollo e innovaciÃ³n en productos, procesos y mÃ©todos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001573/2025-26/CG06> a ns1:Competency ;
    ns1:competencyCode "CG06" ;
    ns1:competencyDescription "Poseer las habilidades de aprendizaje que permitan continuar estudiando de un modo autodirigido o autónomo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001573/2025-26/CT02> a ns1:Competency ;
    ns1:competencyCode "CT02" ;
    ns1:competencyDescription "Experimenta. Habilidad para diseñar y realizar experimentos así como analizar e interpretar datos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001573/2025-26/CT03> a ns1:Competency ;
    ns1:competencyCode "CT03" ;
    ns1:competencyDescription "Planifica. Organización y planificación el desarrollo de un trabajo profesional"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001573/2025-26/RA41> a ns1:LearningResult ;
    ns1:learningResultCode "RA41" ;
    ns1:learningResultDescription "El alumno debe disponer de un conocimiento de técnicas avanzadas de visión por computador aplicadas a la solución de problemas complejos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001573/2025-26/RA42> a ns1:LearningResult ;
    ns1:learningResultCode "RA42" ;
    ns1:learningResultDescription "El alumno debe ser capaz de plantear soluciones plausibles a problemas que impliquen reconstrucción 3D, identificación y reconocimiento de un objeto en entornos variables, así como la integración de imagen real y generada por computador en aplicaciones de realidad aumentada"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001573/2025-26/RA43> a ns1:LearningResult ;
    ns1:learningResultCode "RA43" ;
    ns1:learningResultDescription "El alumno debe alcanzar un nivel suficiente de comprensión de las técnicas presentadas para continuar de manera autónoma con el aprendizaje de técnicas que se encuentren en el estado del arte."@es .

