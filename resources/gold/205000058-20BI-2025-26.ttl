    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/205000058/2025-26/RA323>,
        <https://guia-kg.skai.etsisi.upm.es/resource/205000058/2025-26/RA324>,
        <https://guia-kg.skai.etsisi.upm.es/resource/205000058/2025-26/RA325>,
        <https://guia-kg.skai.etsisi.upm.es/resource/205000058/2025-26/RA326>,
        <https://guia-kg.skai.etsisi.upm.es/resource/205000058/2025-26/RA327> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/205000058/2025-26/syllabus> ;
    ns1:inpersonHours "64 horas (49.2%)"@es ;
    ns1:numberOfCredits 5.0 ;
    ns1:otherInformation """La vinculación con los ODS está incluida en la descripción de la asignatura
?La Comisión de Calidad del Centro en su reunión de 29 de mayo de 2023 acordó aprobar la propuesta de reasignación de competencias transversales en las asignaturas de los Grados en Biotecnología, Ingeniería Alimentaria, Ingeniería Agrícola, Ingeniería Agroambiental, Ciencias Agrarias y Bioeconomía, y en el Máster Universitario en Ingeniería Agronómica. En virtud de dicho acuerdo esta asignatura ha sido designada como ?Asignatura Punto Control*? de la Competencia Transversal ?CT9- Respeto al medio ambiente. ?Capacidad para ofrecer soluciones compatibles con la conservación del entorno de forma responsable y sostenible y potenciar los beneficios que pueda generar la actividad profesional en el ámbito medioambiental?. Esto significa que tiene la obligación de recopilación de evidencias de las actividades formativas y de evaluación relacionadas con dicha CT, para su consideración en los sistemas de acreditación de la calidad del Centro.
Para ello el profesorado de la asignatura ha de hacer énfasis en las visitas de campo en los impactos medioambientales de la ganadería, impacto sobre el paisaje y la biodiversidad. También se evaluará el efecto de una granja porcina de ibérico en los GEI y producción de amoníaco por animal y por kg de producto. En la exposición del trabajo sobre ecosistemas agroganaderos internacionales deberán reflejar los retos medioambientales de dichos sistemas."""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "71 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/205000058/2025-26/eventSchedule> ;
    schema:description "La asignatura profundiza en la sostenibilidad y biodiversidad de los ecosistemas agroganaderos más característicos de la península. Analiza la interacción suelo - planta - animal en zonas de pastoreo y el papel de estos ecosistemas en la degradación y recuperación de suelos, en secuestro de carbono, en la creación y modificación del paisaje, en prevención de incendios y otros servicios ecosistémicos. En la asignatura se incidirá fundamentalmente en el ODS 15 (vida ecosistemas terrestres) y la fragilidad de algunos de estos ecosistemas y de forma indirecta en el ODS 2 (hambre cero) donde se resalta el papel de los productos de origen animal en mejorar la calidad de la dieta."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/mariajesus.villamide%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/c.hontoria%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/carlosgregorio.hernandez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/mariajesus.villamide%40upm.es> ;
    schema:name "Ecosistemas Agroganaderos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000058/2025-26/CB02> a ns1:Competency ;
    ns1:competencyCode "CB02" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar sus conocimientos a su trabajo o vocación de una forma profesional y posean las competencias que suelen demostrarse por medio de la elaboración y defensa de argumentos y la resolución de problemas dentro de su área de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000058/2025-26/CB03> a ns1:Competency ;
    ns1:competencyCode "CB03" ;
    ns1:competencyDescription "Que los estudiantes tengan la capacidad de reunir e interpretar datos relevantes (normalmente dentro de su área de estudio) para emitir juicios que incluyan una reflexión sobre temas relevantes de índole social, científica o ética"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000058/2025-26/CB04> a ns1:Competency ;
    ns1:competencyCode "CB04" ;
    ns1:competencyDescription "Que los estudiantes puedan transmitir información, ideas, problemas y soluciones a un público tanto especializado como no especializado"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000058/2025-26/CE23> a ns1:Competency ;
    ns1:competencyCode "CE23" ;
    ns1:competencyDescription "Capacidad de integrar la sostenibilidad y los principios de la Economía circular en las distintas fases de los sistemas de producción de alimentos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000058/2025-26/CE24> a ns1:Competency ;
    ns1:competencyCode "CE24" ;
    ns1:competencyDescription "Capacidad de proponer estrategias de optimización del proceso productivo en términos de un uso sostenible agronómico y ambiental."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000058/2025-26/CG07> a ns1:Competency ;
    ns1:competencyCode "CG07" ;
    ns1:competencyDescription "Adquirir la formación profesional necesaria para desarrollar estrategias sostenibles de producción vegetal y animal de forma eficiente y acorde a los recursos disponibles."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000058/2025-26/CG10> a ns1:Competency ;
    ns1:competencyCode "CG10" ;
    ns1:competencyDescription "Familiarizarse con el estudio de las interrelaciones entre las distintas perspectivas ecológicas, tecnológicas, económicas y sociales en relación con las Ciencias Agrarias y la Bioeconomía."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000058/2025-26/CT03> a ns1:Competency ;
    ns1:competencyCode "CT03" ;
    ns1:competencyDescription "Tener compromiso ético y profesional y respeto por el medio ambiente"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000058/2025-26/CT09> a ns1:Competency ;
    ns1:competencyCode "CT09" ;
    ns1:competencyDescription "Tener capacidad de análisis y síntesis para interpretar datos relevantes y abordar los problemas desde diferentes perspectivas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000058/2025-26/RA323> a ns1:LearningResult ;
    ns1:learningResultCode "RA323" ;
    ns1:learningResultDescription "Conocer la ubicación y las variables que definen los principales ecosistemas agroganaderos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000058/2025-26/RA324> a ns1:LearningResult ;
    ns1:learningResultCode "RA324" ;
    ns1:learningResultDescription "Aplicar los conocimientos de edafología, ecofisiología y tecnología de cultivos, y sistemas de producción animal para analizar las fortalezas y debilidades de los principales ecosistemas agroganaderos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000058/2025-26/RA325> a ns1:LearningResult ;
    ns1:learningResultCode "RA325" ;
    ns1:learningResultDescription "Analizar las interacciones animal"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000058/2025-26/RA326> a ns1:LearningResult ;
    ns1:learningResultCode "RA326" ;
    ns1:learningResultDescription "Aplicar los criterios de sostenibilidad a distintos ecosistemas y analizar los resultados desde las distintas vertientes"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000058/2025-26/RA327> a ns1:LearningResult ;
    ns1:learningResultCode "RA327" ;
    ns1:learningResultDescription "Proponer modelos pastoriles para la recuperación de suelos degradados o para la creación de los mismos."@es .

