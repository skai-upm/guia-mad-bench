<https://guia-kg.skai.etsisi.upm.es/resource/205000058/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. UT 1. - Introducción"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000058/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Los ecosistemas agroganaderos en España y el mundo: ocupación del territorio, importancia económica, social, medioambiental (2 h) Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000058/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "3.1. Secuestro de carbono. (2h) Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000058/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "3.2. Paisaje, prevención de incendios y biodiversidad (2h) Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000058/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "3.3. Efecto de la ganadería en el medio ambiente (2h) Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000058/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "4. UT 4 - Análisis de los ecosistemas agroganaderos desde el punto de vista de la sostenibilidad económica, social y medioambiental."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000058/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "4.1. La dehesa y el cerdo ibérico (4 h) Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000058/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "4.2. Pastos de montaña. Trastermitancia, la trashumancia y nomadismo (2 h) Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000058/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "4.3. Sistemas mixtos agrícola-ganaderos. Aprovechamiento rastrojeras, cereal en verde (3 h) Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000058/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "4.4. 13. Ecosistemas agroganaderos internacionales relevantes. Retos medioambientales: problemas y soluciones (4 h) Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000058/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Propiedades de los suelos a tener en cuenta en los sistemas agroganaderos. (3 h) Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000058/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "1.3. Cubierta vegetal: Pastos herbáceos, pastos arbolados (arbustivos). Praderas (2 h) Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000058/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "1.4. Comportamiento alimentario de los distintos tipos de animales en pastoreo. Tasa de ingestión. Rumia. (3 h) Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000058/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "2. UT2- Interacción suelo-planta-animal"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000058/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "2.1. Productividad de pasto (3 h) Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000058/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "2.2. Carga ganadera y sistema de pastoreo (3 h) Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000058/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "2.3. Degradación y recuperación de suelos. (2 h) Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000058/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "3. UT 3 - Papel de los ecosistemas agroganaderos"@es .

