    ns1:inpersonHours "35 horas (44.9%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation "En la asignatura se trabaja el concepto de finanzas sostenibles, imprescindibles para impulsar el cumplimiento de los ODS. En concreto, el objetivo número 12 relativo al crecimiento económico."@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "35 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/53001978/2025-26/eventSchedule> ;
    schema:description "En esta asignatura se analizarán los distintos mercados financieros (mercados monetarios, renta fija, divisas, acciones, productos derivados...) incidiendo en todas aquellas técnicas cuantitativas que nos permitirán un conocimiento tremendamente práctico y profundo de estos productos financieros."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/mercedes.grijalvo%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/juanpablo.jimeno%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/mercedes.grijalvo%40upm.es> ;
    schema:name "Finanzas Cuantitativas II"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001978/2025-26/CB06> a ns1:Competency ;
    ns1:competencyCode "CB06" ;
    ns1:competencyDescription "Poseer y comprender conocimientos que aporten una base u oportunidad de ser originales en el desarrollo y/o aplicación de ideas, a menudo en un contexto de investigación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001978/2025-26/CB08> a ns1:Competency ;
    ns1:competencyCode "CB08" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de integrar conocimientos y enfrentarse a la complejidad de formular juicios a partir de una información que, siendo incompleta o limitada, incluya reflexiones sobre las responsabilidades sociales y éticas vinculadas a la aplicación de sus conocimientos y juicios"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001978/2025-26/CB10> a ns1:Competency ;
    ns1:competencyCode "CB10" ;
    ns1:competencyDescription "Que los estudiantes posean las habilidades de aprendizaje que les permitan continuar estudiando de un modo que habrá de ser en gran medida autodirigido o autónomo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001978/2025-26/CE10> a ns1:Competency ;
    ns1:competencyCode "CE10" ;
    ns1:competencyDescription "Comprender y aprovechar la estructura de opciones subyacente en los proyectos de inversión y su aplicación para la valoración de proyectos, empresas y negocios"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001978/2025-26/CG01> a ns1:Competency ;
    ns1:competencyCode "CG01" ;
    ns1:competencyDescription "Utilizar los conocimientos científicos y tecnológicos adquiridos en sus estudios de Grado en Ingeniería como recurso a integrar en la generación de soluciones a problemas de las organizaciones, sean éstos de funcionamiento o de diseño"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001978/2025-26/CG02> a ns1:Competency ;
    ns1:competencyCode "CG02" ;
    ns1:competencyDescription "Analizar situaciones estructuradas y poco estructuradas de empresas y otras organizaciones, estableciendo diagnósticos apropiados, en particular, de carácter estratégico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001978/2025-26/CG07> a ns1:Competency ;
    ns1:competencyCode "CG07" ;
    ns1:competencyDescription "Modelar diferentes problemas de diseño de las organizaciones, conocer y seleccionar técnicas de Ingeniería de Organización apropiadas, así como obtener, comunicar, discutir y aplicar los resultados correspondientes"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001978/2025-26/CT01> a ns1:Competency ;
    ns1:competencyCode "CT01" ;
    ns1:competencyDescription "Aplica. Habilidad para aplicar conocimientos científicos, matemáticos y tecnológicos en sistemas relacionados con la práctica de la ingeniería"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001978/2025-26/CT02> a ns1:Competency ;
    ns1:competencyCode "CT02" ;
    ns1:competencyDescription "Experimenta. Habilidad para diseñar y realizar experimentos así como analizar e interpretar datos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001978/2025-26/CT05> a ns1:Competency ;
    ns1:competencyCode "CT05" ;
    ns1:competencyDescription "Resuelve. Habilidad para identificar, formular y resolver problemas de ingeniería"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001978/2025-26/CT08> a ns1:Competency ;
    ns1:competencyCode "CT08" ;
    ns1:competencyDescription "Entiende los impactos. Educación amplia necesaria para entender el impacto de las soluciones ingenieriles en un contexto social global"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001978/2025-26/CT09> a ns1:Competency ;
    ns1:competencyCode "CT09" ;
    ns1:competencyDescription "Se actualiza. Reconocimiento de la necesidad y la habilidad para comprometerse al aprendizaje continuo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001978/2025-26/CT10> a ns1:Competency ;
    ns1:competencyCode "CT10" ;
    ns1:competencyDescription "Conoce. Conocimiento de los temas contemporáneos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001978/2025-26/CT11> a ns1:Competency ;
    ns1:competencyCode "CT11" ;
    ns1:competencyDescription "Usa herramientas. Habilidad para usar las técnicas, destrezas y herramientas ingenieriles modernas necesarias para la práctica de la ingeniería"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001978/2025-26/RA57> a ns1:LearningResult ;
    ns1:learningResultCode "RA57" ;
    ns1:learningResultDescription "Entender y aplicar el funcionamiento de las leyes financieras"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001978/2025-26/RA58> a ns1:LearningResult ;
    ns1:learningResultCode "RA58" ;
    ns1:learningResultDescription "Comprender la operativa de los mercados financieros"@es .

