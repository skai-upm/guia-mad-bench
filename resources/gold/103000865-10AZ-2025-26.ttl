    ns1:inpersonHours "37 horas (47.4%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation "During the course, we will try to use as many the data files related to Sustainable Development Goals of UN as possible, specially number 13 Climate Action"@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
