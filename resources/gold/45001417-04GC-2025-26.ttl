    schema:name "Transportes"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001417/2025-26/CM42.1> a ns1:Competency ;
    ns1:competencyCode "CM42.1" ;
    ns1:competencyDescription "Conocimiento del diseño y funcionamiento de las infraestructuras para el intercambio modal, tales como puertos, aeropuertos, estaciones ferroviarias y centros logísticos de transporte."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001417/2025-26/CM44> a ns1:Competency ;
    ns1:competencyCode "CM44" ;
    ns1:competencyDescription "Valoración de los efectos histórico, social, económico, ambiental, cultural, político y globalizador de las realizaciones de la ingeniería civil (Desarrolla las competencias 3ª y 4ª del R.D. 1393/2007, esta última parcialmente)."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001417/2025-26/CT2> a ns1:Competency ;
    ns1:competencyCode "CT2" ;
    ns1:competencyDescription "Capacidad de organizar y dirigir los esfuerzos de un grupo humano reducido y homogéneo. Desarrolla la competencia transversal 8ª de la normativa UPM."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001417/2025-26/CT3> a ns1:Competency ;
    ns1:competencyCode "CT3" ;
    ns1:competencyDescription "Capacidad de actuar con efectividad como miembro de equipos interdisciplinares. Desarrolla la competencia transversal 5ª de la normativa UPM."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001417/2025-26/CT6> a ns1:Competency ;
    ns1:competencyCode "CT6" ;
    ns1:competencyDescription "Compromiso y capacidad de aplicación de los estándares de deontología profesional."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001417/2025-26/RA113> a ns1:LearningResult ;
    ns1:learningResultCode "RA113" ;
    ns1:learningResultDescription "Explica las razones del diseño y el funcionamiento de las infraestructuras para el intercambio modal, tales como puertos, aeropuertos, estaciones ferroviarias y centros logísticos de transporte."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001417/2025-26/RA114> a ns1:LearningResult ;
    ns1:learningResultCode "RA114" ;
    ns1:learningResultDescription "Valora los efectos social, económico, ambiental, político y globalizador del transporte."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001417/2025-26/RA183> a ns1:LearningResult ;
    ns1:learningResultCode "RA183" ;
    ns1:learningResultDescription "RA1. Analiza y describe las características de la demanda y oferta de transporte tanto para mercancías como para viajeros e identifica las variables explicativas, así como su contexto histórico."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001417/2025-26/RA184> a ns1:LearningResult ;
    ns1:learningResultCode "RA184" ;
    ns1:learningResultDescription "RA2. Identifica los procesos y servicios que tienen lugar en las infraestructuras de intercambio modal."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001417/2025-26/RA185> a ns1:LearningResult ;
    ns1:learningResultCode "RA185" ;
    ns1:learningResultDescription "RA3.Describe y analiza la relación existente entre los actores del sector transporte y la relevancia del marco jurídico."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001417/2025-26/RA186> a ns1:LearningResult ;
    ns1:learningResultCode "RA186" ;
    ns1:learningResultDescription "RA4 Describe y analiza procesos de planificación territorial y de los aspectos medioambientales relacionados con las infraestructuras de transporte."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001417/2025-26/RA187> a ns1:LearningResult ;
    ns1:learningResultCode "RA187" ;
    ns1:learningResultDescription "RA5 Comprende y explica los procesos de mantenimiento, conservación y explotación de infraestructuras de transporte."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001417/2025-26/RA188> a ns1:LearningResult ;
    ns1:learningResultCode "RA188" ;
    ns1:learningResultDescription "RA6 Comprende y explica los procesos de toma decisión por diferentes agentes económicos y sociales en materia de transporte, tanto a escala local, regional, nacional y europea."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001417/2025-26/RA189> a ns1:LearningResult ;
    ns1:learningResultCode "RA189" ;
    ns1:learningResultDescription "RA7 Es capaz de comunicarse de manera eficiente y con visión multidisciplinar con un amplio abanico de agentes sociales y económicos que intervienen en el proceso de toma de decisiones del mundo del transporte"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001417/2025-26/RA91> a ns1:LearningResult ;
    ns1:learningResultCode "RA91" ;
    ns1:learningResultDescription "Interioriza los principios de deontología profesional de ingeniería civil."@es .

