    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/203000156/2025-26/RA16>,
        <https://guia-kg.skai.etsisi.upm.es/resource/203000156/2025-26/RA17> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/203000156/2025-26/syllabus> ;
    ns1:inpersonHours "35 horas (33.7%)"@es ;
    ns1:numberOfCredits 4.0 ;
    ns1:otherInformation "La asignatura se relaciona con el ODS 12 (Garantizar modalidades de consumo y producción sostenibles)."@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "35 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/203000156/2025-26/eventSchedule> ;
    schema:description "La asignatura es introducción a la toma de decisiones en procesos productivos y en la comercialización de productos alimentarios, con especial enfásis en las particularidades de productos saludables. En los temas de gestión de la producción se tratan temas de costes, funciones y planificación de producción. En los de marketing se aborda tipos y segmentación de mercados, decisiones sobre los productos, precios, distribución y comunicación."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/cristina.lopezcozar%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/cristina.lopezcozar%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/luis.gonzalez.polonio%40upm.es> ;
    schema:name "Gestión de la Producción y Marketing"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000156/2025-26/CB8> a ns1:Competency ;
    ns1:competencyCode "CB8" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de integrar conocimientos y enfrentarse a la complejidad de formular juicios a partir de una información que, siendo incompleta o limitada, incluya reflexiones sobre las responsabilidades sociales y éticas vinculadas a la aplicación de sus conocimientos y juicios"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000156/2025-26/CE%2021> a ns1:Competency ;
    ns1:competencyCode "CE 21" ;
    ns1:competencyDescription "Conocimiento adecuado de la gestión económica de la producción."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000156/2025-26/CG2> a ns1:Competency ;
    ns1:competencyCode "CG2" ;
    ns1:competencyDescription "Capacidad de análisis y síntesis de la información disponible o de los datos extraídos de un sistema agroindustrial para el procesado de alimentos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000156/2025-26/CG6> a ns1:Competency ;
    ns1:competencyCode "CG6" ;
    ns1:competencyDescription "Capacidad de innovación, resolución de problemas, toma de decisiones, discusión y conclusiones científicas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000156/2025-26/CG7> a ns1:Competency ;
    ns1:competencyCode "CG7" ;
    ns1:competencyDescription "Desarrollo de habilidades para la comunicación y presentación de ideas favoreciendo la accesibilidad, información y consumo de alimentos sanos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000156/2025-26/RA16> a ns1:LearningResult ;
    ns1:learningResultCode "RA16" ;
    ns1:learningResultDescription "Conocer técnicas para tomar decisiones de producción"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000156/2025-26/RA17> a ns1:LearningResult ;
    ns1:learningResultCode "RA17" ;
    ns1:learningResultDescription "Saber formular un plan de marketing"@es .

