    ns1:semester "Segundo semestre"@es ;
    schema:courseCode 203000156 ;
    schema:hasCourseInstance <https://guia-kg.skai.etsisi.upm.es/resource/203000156/2025-26> ;
    schema:name "Management Production And Marketing"@en,
        "Gestión de la Producción y Marketing"@es ;
    schema:numberOfCredits 4.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/203000156/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/203000156/2025-26/CB8>,
