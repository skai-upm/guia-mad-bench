<https://guia-kg.skai.etsisi.upm.es/resource/73000027/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/73000027/2025-26/CE%203.2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/73000027/2025-26/CE%203.3>,
