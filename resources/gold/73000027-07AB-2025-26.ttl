    ns1:competencyCode "CG 4" ;
    ns1:competencyDescription "Capacidad para la gestión económica y administrativa, en la prevención, combate de los incendios y en la restauracion del territorio despues de un incendio."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/73000027/2025-26/RA1> a ns1:LearningResult ;
    ns1:learningResultCode "RA1" ;
    ns1:learningResultDescription "Capacidad para valorar cuantitativamente los bienes y recursos forestales, ambientales, paisajísticos y ganaderos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/73000027/2025-26/RA2> a ns1:LearningResult ;
    ns1:learningResultCode "RA2" ;
    ns1:learningResultDescription "Capacidad para evaluar los daños y perjuicios ocasionados por los incendios y otros fenómenos naturales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/73000027/2025-26/RA3> a ns1:LearningResult ;
    ns1:learningResultCode "RA3" ;
    ns1:learningResultDescription "Capacidad para aplicar métodos económicos a la gestión forestal y a la gestión de incendios"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/73000027/2025-26/RA4> a ns1:LearningResult ;
    ns1:learningResultCode "RA4" ;
    ns1:learningResultDescription "Capacidad para llevar a cabo estudios económicos que estimen el valor que la población otorga a los bienes recreativos y paisajísticos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/73000027/2025-26/RA6> a ns1:LearningResult ;
    ns1:learningResultCode "RA6" ;
    ns1:learningResultDescription "Conocimientos suficientes para el dimensionado de instalaciones, equipamientos y recursos humanos en materia de incendios basándose en criterios económicos"@es .

