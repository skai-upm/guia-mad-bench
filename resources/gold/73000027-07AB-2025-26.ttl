    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/73000027/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/73000027/2025-26/RA1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/73000027/2025-26/RA2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/73000027/2025-26/RA3>,
        <https://guia-kg.skai.etsisi.upm.es/resource/73000027/2025-26/RA4>,
        <https://guia-kg.skai.etsisi.upm.es/resource/73000027/2025-26/RA6> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/73000027/2025-26/syllabus> ;
    ns1:inpersonHours "29 horas (37.2%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation """LAS COMPETENCIAS Y LOS RESULTADOS DE APRENDIZAJE DE ESTA ASIGNATURA SON CONFORMES CON LA MEMORIA VERIFICA DEL TÍTULO
Se adquieren con esta Asignatura, las competencias y resultados conforme a la memoria Verifica del Título:
GENERALES
CG 4 - Capacidad para la gestión económica y administrativa, en la prevención, combate de los incendios y en la restauración del territorio después de un incendio.

COMPETENCIAS ESPECÍFICAS
CE 1.1 - Capacidad para la identificación y descripción cualitativa de los impactos ambientales.
CE 3.2 - Capacidad para valorar y cuantificar los daños y perjuicios producidos por los incendios.
CE 3.3 - Capacidad para estimar el impacto ambiental y social de los incendios.
CE 3.4 - Capacidad para diseñar, redactar y gestionar proyectos de restauración de zonas degradadas.
CE 5.1 - Capacidad para el desempeño profesional de la gestión de incendios forestales en un entorno de la empresa o de la administración"""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "42 horas y 30 minutos"@es ;
    schema:activitiesWorkload "25%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/73000027/2025-26/eventSchedule> ;
    schema:description "Esta asignatura introduce al alumno en los métodos para valorar las consecuencias de los incendios forestales desde el punto de vista económico, social y ambiental. También presenta los elementos a tener en cuenta para dimensionar adecuadamente los esfuerzos en materia de prevención y extinción de incendios forestales."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/a.martinf%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/a.martinf%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/sigfredo.ortuno%40upm.es> ;
    schema:name "Aspectos Socioeconomicos de los Incendios Forestales"@es .

