    ns1:itemIndex 3 ;
    ns1:syllabusDescription "4. Refuerzo estructural con Encamisado de Hormigón Armado y Acero: principios de diseño y comportamiento sísmico Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000950/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "5. Refuerzo estructural con FRP: criterios de diseño a flexión, cortante y confinamiento Sin subniveles"@es .

