<https://guia-kg.skai.etsisi.upm.es/resource/43000504/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Mecánica de ondas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000504/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Ecuaciones de continuidad, cantidad de movimiento y Bernouilli Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000504/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "3. Modelos matemáticos de propagación, de onda larga y computacionales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000504/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "3.1. Modelos de diferencias finitas. Modelos en elementos finitos Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000504/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "3.2. Ecuación de Berkoff. Modelos elípticos y parabólicos Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000504/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "3.3. Fenómenos de amplificación. Resonancia en puertos y dársenas Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000504/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "3.4. Modelos sedimentarios Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000504/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "4. Descripción de oleaje: métodos estadísticos y espectrales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000504/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "4.1. Funciones eulerianas. Aplicación a las distribuciones continuas, media, varianza, simetría y curtosis Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000504/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "4.2. Distribuciones discretas de temporales anuales. Distribuciones continuas en régimen medio y de extremos. Gauss, Gumbell, Weibull, Frechet, exponencial Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000504/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "4.3. Aplicación de la ROM 0.0/2002, ROM 0.2/90 y ROM 0.3/91. Actualización de la ROM 0.3 - 2019. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000504/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "4.4. Método de Goda o de los picos sobre el umbral, POT (Weibull - Poisson). Caracterización de los temporales. Método de picos utilizando las distribuciones de Pareto y Poisson."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000504/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Condiciones de contorno e integración Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000504/2025-26/syllabus/20> a ns1:SyllabusItem ;
