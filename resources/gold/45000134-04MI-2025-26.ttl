    ns1:bibliographyTitle "Zinkle, S.J. & Was, G.S. (2013). Materials challenges in nuclear energy. Acta Materialia, 61(3), 735?758. DOI: 10.1016/j.actamat.2012.11.004"@es ;
    ns1:bibliographyType "Bibliografía"@es .

