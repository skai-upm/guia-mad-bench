        <https://guia-kg.skai.etsisi.upm.es/resource/83000118/2025-26/syllabus/5>,
        <https://guia-kg.skai.etsisi.upm.es/resource/83000118/2025-26/syllabus/6>,
        <https://guia-kg.skai.etsisi.upm.es/resource/83000118/2025-26/syllabus/7>,
        <https://guia-kg.skai.etsisi.upm.es/resource/83000118/2025-26/syllabus/8> .

<https://guia-kg.skai.etsisi.upm.es/resource/83000118/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Introducción a la asignatura Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/83000118/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "2. Normativa aplicable. Revisión de los requisitos de verificación que piden las diferentes normativas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/83000118/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "3. Desplazamiento, centro de gravedad y estabilidad. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/83000118/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "4. Acciones del oleaje, viento y corrientes. Comportamiento en la mar de una plataforma flotante. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/83000118/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "5. Operación. Evaluación de la potencia generada en operación. Capacidad real. Criterios de parada - downtime. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/83000118/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "6. Diseño y verificación estructural. Condiciones de carga. Resumen de los criterios típicos de diseño para diferentes tipologías. Revisión de un caso de estudio de verificación estructural. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/83000118/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "7. Apoyo en el fondo y fondeo. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/83000118/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "8. Sistemas y otros aspectos. Descripción de los principales sistemas. Tren de potencia (descripción y criterios de dimensionamiento). Subestaciones. Elementos de seguridad. Umbilicales. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/83000118/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "9. Presupuesto y financiación Sin subniveles"@es .

