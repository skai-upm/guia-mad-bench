    schema:hasCourseInstance <https://guia-kg.skai.etsisi.upm.es/resource/83000118/2025-26> ;
    schema:name "Marine Renewables And Offshore Engineering Projects"@en,
        "Proyectos de Renovables Marinas e Ingeniería Offshore"@es ;
    schema:numberOfCredits 6.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/83000118/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/83000118/2025-26/CTUPM12>,
        <https://guia-kg.skai.etsisi.upm.es/resource/83000118/2025-26/CTUPM13> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/83000118/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/83000118/2025-26/RA21>,
        <https://guia-kg.skai.etsisi.upm.es/resource/83000118/2025-26/RA3>,
        <https://guia-kg.skai.etsisi.upm.es/resource/83000118/2025-26/RA31>,
        <https://guia-kg.skai.etsisi.upm.es/resource/83000118/2025-26/RA4>,
        <https://guia-kg.skai.etsisi.upm.es/resource/83000118/2025-26/RA5>,
        <https://guia-kg.skai.etsisi.upm.es/resource/83000118/2025-26/RA59> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/83000118/2025-26/syllabus> ;
    ns1:inpersonHours "70 horas (44.9%)"@es ;
    ns1:numberOfCredits 6.0 ;
    ns1:otherInformation ""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "72 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/83000118/2025-26/eventSchedule> ;
    schema:description "El objetivo principal de esta asignatura es revisar, desde un punto de vista eminentemente práctico, los principales aspectos que implica el diseño de un dispositivo de generación de energía oceánica. La asignatura recorre aspectos como la normativa, cálculo del desplazamiento y estabilidad, cargas sobre la estructura y comportamiento en la mar, diseño y verificación estructural, operación, apoyo en el fondo y fondeo, sistemas, presupuesto y financiación."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/julio.garcia.espinosa%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/jaime.moreu%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/javier.gonzalez.arias%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/joseluis.moran%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/julio.garcia.espinosa%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/mario.devicente%40upm.es> ;
    schema:name "Proyectos de Renovables Marinas e Ingeniería Offshore"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/83000118/2025-26/CTUPM12> a ns1:Competency ;
    ns1:competencyCode "CTUPM12" ;
    ns1:competencyDescription "Gestión económica y administrativa. Los estudiantes son capaces de realizar las operaciones administrativas vinculadas a la gestión económica y de recursos humanos.Economic and administrative management. Students are able to perform administrative operations related to economic and human resources management."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/83000118/2025-26/CTUPM13> a ns1:Competency ;
    ns1:competencyCode "CTUPM13" ;
    ns1:competencyDescription "Trabajo en contextos internacionales. Los estudiantes son capaces de integrarse en un grupo o equipo, colaborando y cooperando con otros. Tienen la capacidad para trabajar con estudiantes de otras disciplinas y de aceptar la diversidad social y cultural.Work in international contexts. Students are able to integrate into a group or team, collaborating and cooperating with others. They have the ability to work with students from other disciplines and to accept social and cultural diversity."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/83000118/2025-26/RA21> a ns1:LearningResult ;
    ns1:learningResultCode "RA21" ;
    ns1:learningResultDescription "H&D: Manejo de un código de simulación de resistencia añadida y movimientos en olas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/83000118/2025-26/RA3> a ns1:LearningResult ;
    ns1:learningResultCode "RA3" ;
    ns1:learningResultDescription "Habilidades y Destrezas: Aplicación del Método de los Elementos Finitos para el proyecto de Estructuras Navales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/83000118/2025-26/RA31> a ns1:LearningResult ;
    ns1:learningResultCode "RA31" ;
    ns1:learningResultDescription "C: Capacidad para resolver problemas complejos y para tomar decisiones con responsabilidad sobre la base de los conocimientos científicos y tecnológicos adquiridos en materias básicas y tecnológicas aplicables en la ingeniería naval y oceánica, y en métodos de gestión"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/83000118/2025-26/RA4> a ns1:LearningResult ;
    ns1:learningResultCode "RA4" ;
    ns1:learningResultDescription "Competencias: Capacidad para el análisis dinámico determinista de estructuras en el dominio del tiempo y de la frecuencia"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/83000118/2025-26/RA5> a ns1:LearningResult ;
    ns1:learningResultCode "RA5" ;
    ns1:learningResultDescription "Habilidades y Destrezas: Aplicación del Método de los Elementos Finitos para el proyecto de Estructuras Navales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/83000118/2025-26/RA59> a ns1:LearningResult ;
    ns1:learningResultCode "RA59" ;
    ns1:learningResultDescription "S7 Comunicación oral y escrita."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/83000118/2025-26/evaluation> a ns1:EvaluationSystem ;
    ns1:evaluationDescription """Evaluación progresiva
La evaluación progresiva de la asignatura se realizará mediante dos pruebas:
La realización y presentación de diversos trabajos en parejas que pongan en práctica los conocimientos adquiridos en la asignatura. Se evaluará tanto el informe de los trabajos realizados (peso del 35%) como una presentación oral relativa a esos trabajos (peso del 30%).
Un examen escrito sobre los diferentes temas tratados en la asignatura, con un peso en la nota del 35%.
Para aprobar la asignatura será necesario obtener una nota media ponderada, de acuerdo a los pesos indicados, de al menos 5.0.

Evaluación global y extraordinaria

La evaluación global y extraordinaria se realizará mediente un examen escrito sobre los diferentes temas tratados en la asignatura, en el que habrá que obtener una nota de al menos 5.0."""@es .

