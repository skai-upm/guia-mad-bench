    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation """This course meets the following Sustainable Development Goals (SDGs), also known as the Global Goals, adopted by the United Nations in 2015:

SDG3 (GOOD HEALTH AND WELL-BEING), SDG4 (QUALITY EDUCATION), SDG5 (GENDER EQUALITY), SDG8 (DECENT WORK AND ECONOMIC GROWTH), SDG13 (CLIMATE ACTION), and SDG16 (PEACE, JUSTICE AND STRONG INSTITUTIONS)."""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "36 horas y 30 minutos"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/133000269/2025-26/eventSchedule> ;
    schema:description "This course aims to give a first taste of scientific understanding by enhancing the curiosity and creativeness of students through project-based learning. Students will learn how to select interesting and promising scientific questions to further develop research hypotheses and predictions that will increase their chance of success in applying for grants, proposals or publishing scientific articles. In addition, students will work on their own experimental design and learn how to collect data in a scientifically-controlled manner in the field and in the lab. Importantly, great part of the course will be devoted to enhancing communication and networking skills by producing attractive figures, titles, posters and presentations for the general audience, and by creating and using websites, blogs and other social media platforms."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/ramon.perea%40upm.es> ;
    schema:inLanguage "Inglés/Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/jesus.rcalcerrada%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/juan.martin.garcia%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/ramon.perea%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/roberto.salomon%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/rosana.lopez%40upm.es> ;
    schema:name "Scientific Research And Communication"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000269/2025-26/CB06> a ns1:Competency ;
    ns1:competencyCode "CB06" ;
    ns1:competencyDescription "Poseer y comprender conocimientos que aporten una base u oportunidad de ser originales en el desarrollo y/o apl0icación de ideas, a menudo en un contexto de investigación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000269/2025-26/CB09> a ns1:Competency ;
    ns1:competencyCode "CB09" ;
    ns1:competencyDescription "Que los estudiantes sepan comunicar sus conclusiones y los conocimientos y razones últimas que las sustentan a públicos especializados y no especializados de un modo claro y sin ambigüedades"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000269/2025-26/CB10> a ns1:Competency ;
    ns1:competencyCode "CB10" ;
    ns1:competencyDescription "Que los estudiantes posean las habilidades de aprendizaje que les permitan continuar estudiando de un modo que habrá de ser en gran medida autodirigido o autónomo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000269/2025-26/CT01> a ns1:Competency ;
    ns1:competencyCode "CT01" ;
    ns1:competencyDescription "Habilidades de comunicación escrita y oral"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000269/2025-26/CT02> a ns1:Competency ;
    ns1:competencyCode "CT02" ;
    ns1:competencyDescription "Integrar los conocimientos previos (propios de grado) de manera crítica y relacionada de forma que se puedan aplicar al estudio de situaciones reales y a la propuesta de alternativas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000269/2025-26/CT04> a ns1:Competency ;
    ns1:competencyCode "CT04" ;
    ns1:competencyDescription "Capacidad crítica para el análisis, la síntesis y el aprendizaje mediante el intercambio de opiniones, presentando argumentos sólidos y estructurados"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000269/2025-26/CT06> a ns1:Competency ;
    ns1:competencyCode "CT06" ;
    ns1:competencyDescription "Búsqueda bibliográfica, análisis de documentación y tratamiento de la información procedente de diversas fuentes y de su análisis y síntesis aplicándola a la resolución de problemas complejos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000269/2025-26/CT07> a ns1:Competency ;
    ns1:competencyCode "CT07" ;
    ns1:competencyDescription "Perfeccionar el conocimiento oral y escrito de la lengua inglesa"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000269/2025-26/CT08> a ns1:Competency ;
    ns1:competencyCode "CT08" ;
    ns1:competencyDescription "Creatividad, capacidad de observación, generación de hipótesis y planteamiento de problemas experimentales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000269/2025-26/CT10> a ns1:Competency ;
    ns1:competencyCode "CT10" ;
    ns1:competencyDescription "Valores humanos positivos: Respeto a los derechos humanos fundamentales; los principios de igualdad de oportunidades, accesibilidad universal y no discriminación; y los valores propios de una cultura de paz y de valores democráticos. Compromiso con estos derechos, principios y valores, motivación, actitud positiva y entusiasta; ética, integridad y honestidad profesional"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000269/2025-26/RA132> a ns1:LearningResult ;
    ns1:learningResultCode "RA132" ;
    ns1:learningResultDescription "Conocimiento con sentido crítico del amplio contexto multidisciplinar de la ingeniería y de la interrelación que existe entre los conocimientos de los distintos campos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000269/2025-26/RA133> a ns1:LearningResult ;
    ns1:learningResultCode "RA133" ;
    ns1:learningResultDescription "Capacidad y destreza de alto nivel para proyectar y llevar a cabo investigaciones experimentales, interpretar datos con criterio y extraer conclusiones"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000269/2025-26/RA134> a ns1:LearningResult ;
    ns1:learningResultCode "RA134" ;
    ns1:learningResultDescription "Capacidad para realizar búsquedas bibliográficas, consultar y utilizar con criterio bases de datos y otras fuentes de información, para llevar a cabo simulaciones con el objetivo de realizar investigaciones sobre temas complejos de su especialidad"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000269/2025-26/RA177> a ns1:LearningResult ;
    ns1:learningResultCode "RA177" ;
    ns1:learningResultDescription "Saber emitir juicios críticos y opiniones fundamentadas en las evidencias suministrada por datos muestrales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000269/2025-26/RA178> a ns1:LearningResult ;
    ns1:learningResultCode "RA178" ;
    ns1:learningResultDescription "Saber utilizar motores de búsqueda de información bibliográfica de relevancia y probado rigor científico y opiniones fundamentadas en las evidencias suministrada por datos muestrales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000269/2025-26/RA179> a ns1:LearningResult ;
    ns1:learningResultCode "RA179" ;
    ns1:learningResultDescription "Que los estudiantes puedan transmitir información, ideas, problemas y soluciones a un público tanto especializado como no especializado"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000269/2025-26/RA184> a ns1:LearningResult ;
    ns1:learningResultCode "RA184" ;
    ns1:learningResultDescription "Conocer si existen diferencias significativas en las funciones de distribución, medias, varianzas, coeficientes de correlación y asociación ecológica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000269/2025-26/RA189> a ns1:LearningResult ;
    ns1:learningResultCode "RA189" ;
    ns1:learningResultDescription "Elaborar hipótesis y predicciones científicas en base al conocimiento existente"@es .

