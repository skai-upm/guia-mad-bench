<https://guia-kg.skai.etsisi.upm.es/resource/63000132/2025-26/CE06> a ns1:Competency ;
    ns1:competencyCode "CE06" ;
    ns1:competencyDescription "Capacidad para planificar y gestionar recursos energéticos, incluyendo generación, transporte, distribución y utilización"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000132/2025-26/CE08> a ns1:Competency ;
    ns1:competencyCode "CE08" ;
    ns1:competencyDescription "Capacidad para proyectar y ejecutar instalaciones de transporte, distribución y almacenamiento de sólidos, líquidos y gases"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000132/2025-26/CG01> a ns1:Competency ;
    ns1:competencyCode "CG01" ;
    ns1:competencyDescription "Capacitación científico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000132/2025-26/CG02> a ns1:Competency ;
    ns1:competencyCode "CG02" ;
    ns1:competencyDescription "Comprensión de los múltiples condicionamientos de carácter técnicos, legal y de la propiedad que se plantean en el proyectos de una planta o instalación, y capacidad para establecer diferentes alternativas válidas, elegir la óptima y plasmarla adecuadamente, previendo los problemas de su desarrollo, y empleando los métodos y tecnologías más adecuadas, tanto tradicionales como innovadores, con la finalidad de conseguir la mayor eficacia y favorecer el progreso y un desarrollo de la sociedad sostenible y respetuoso con el medio ambiente"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000132/2025-26/CG03> a ns1:Competency ;
    ns1:competencyCode "CG03" ;
    ns1:competencyDescription "Conocimiento, comprensión y capacidad para aplicar la legislación necesaria en el ejercicio de la profesión de Ingenieros de Minas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000132/2025-26/CG08> a ns1:Competency ;
    ns1:competencyCode "CG08" ;
    ns1:competencyDescription "Capacidad para planificar y gestionar recursos energéticos, incluyendo la generación, transporte, distribución y utilización"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000132/2025-26/CG12> a ns1:Competency ;
    ns1:competencyCode "CG12" ;
    ns1:competencyDescription "Capacidad para proyectar y ejecutar instalaciones de transporte, distribución y almacenamiento de sólidos, líquidos y gases."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000132/2025-26/CG18> a ns1:Competency ;
    ns1:competencyCode "CG18" ;
    ns1:competencyDescription "Conocimientos adecuados de los aspectos científicos y tecnológicos de métodos matemáticos, analíticos y numéricos de la ingeniería, mecánica de fluidos, mecánica de medios continuos, cálculo de estructuras, carboquímica, petroquímica y geotecnia"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000132/2025-26/CT01> a ns1:Competency ;
    ns1:competencyCode "CT01" ;
    ns1:competencyDescription "Capacidad para comprender los contenidos de clases magistrales, conferencias y seminarios en lengua inglesa"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000132/2025-26/CT02> a ns1:Competency ;
    ns1:competencyCode "CT02" ;
    ns1:competencyDescription "Capacidad para dinamizar y liderar equipos de trabajo multidisciplinares."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000132/2025-26/CT03> a ns1:Competency ;
    ns1:competencyCode "CT03" ;
    ns1:competencyDescription "Capacidad para adoptar soluciones creativas que satisfagan adecuadamente las diferentes necesidades planteadas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000132/2025-26/CT04> a ns1:Competency ;
    ns1:competencyCode "CT04" ;
    ns1:competencyDescription "Capacidad para trabajar de forma efectiva como individuo, organizando y planificando su propio trabajo, de forma independiente o como miembro de un equipo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000132/2025-26/CT05> a ns1:Competency ;
    ns1:competencyCode "CT05" ;
    ns1:competencyDescription "Capacidad para gestionar la información, identificando las fuentes necesarias, los principales tipos de documentos técnicos y científicos, de una manera adecuada y eficiente"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000132/2025-26/CT06> a ns1:Competency ;
    ns1:competencyCode "CT06" ;
    ns1:competencyDescription "Capacidad para emitir juicios sobre implicaciones económicas, administrativas, sociales, éticas y medioambientales ligadas a la aplicación de sus conocimientos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000132/2025-26/CT07> a ns1:Competency ;
    ns1:competencyCode "CT07" ;
    ns1:competencyDescription "Capacidad para trabajar en contextos internacionales"@es .

