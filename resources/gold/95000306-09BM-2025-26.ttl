        <https://guia-kg.skai.etsisi.upm.es/resource/robin.banerjee%40upm.es> ;
    schema:name "Ampliación de Cálculo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000306/2025-26/CE01> a ns1:Competency ;
    ns1:competencyCode "CE01" ;
    ns1:competencyDescription "Saber resolver problemas de ingeniería utilizando cálculo diferencial, las ecuaciones diferenciales, el cálculo integral, el álgebra lineal y la geometría. Aplicación al plano complejo y métodos de transformación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000306/2025-26/CG07> a ns1:Competency ;
    ns1:competencyCode "CG07" ;
    ns1:competencyDescription "Ser capaz de utilizar el método científico."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000306/2025-26/CG09> a ns1:Competency ;
    ns1:competencyCode "CG09" ;
    ns1:competencyDescription "Tener capacidad de descripción, cuantificación, análisis y evaluación de resultados experimentales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000306/2025-26/CG11> a ns1:Competency ;
    ns1:competencyCode "CG11" ;
    ns1:competencyDescription "Elaborar y defender argumentos y resolver los problemas de forma efectiva y creativa."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000306/2025-26/RA2> a ns1:LearningResult ;
    ns1:learningResultCode "RA2" ;
    ns1:learningResultDescription "Capacidad de formalizar y analizar matemáticamente problemas científico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000306/2025-26/RA3> a ns1:LearningResult ;
    ns1:learningResultCode "RA3" ;
    ns1:learningResultDescription "Conocimiento de las propiedades fundamentales del cálculo diferencial en varias variables reales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000306/2025-26/RA4> a ns1:LearningResult ;
    ns1:learningResultCode "RA4" ;
    ns1:learningResultDescription "Capacidad de emplear con rigor el lenguaje matemático."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000306/2025-26/RA5> a ns1:LearningResult ;
    ns1:learningResultCode "RA5" ;
    ns1:learningResultDescription "Formular problemas de ingeniería mediante modelos de ecuaciones diferenciales y saber obtener su solución."@es .

