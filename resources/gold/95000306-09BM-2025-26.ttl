    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/95000306/2025-26/eventSchedule> ;
    schema:description "Esta asignatura engloba contenidos fundamentales respecto a funciones escalares y vectoriales de dos variables, en particular su continuidad, diferenciabilidad, extremos e integración; así como una introducción a las ecuaciones diferenciales como modelos para formular problemas de ingeniería."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/juanjose.vinagre%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
