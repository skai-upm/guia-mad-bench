    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/115100020/2025-26/eventSchedule> ;
    schema:description "La asignatura está enfocada a introducir al estudiante en el conocimiento y en la práctica del Judo para que, en un futuro, pueda utilizar este deporte como un medio o recurso didáctico en la enseñanza de la Educación Física, o bien, para que adquiera unas primeras nociones sobre cómo iniciar a otras personas en su práctica."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/gabriel.rodriguez%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/cecilia.blanco%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/gabriel.rodriguez%40upm.es> ;
    schema:name "Judo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100020/2025-26/CE02> a ns1:Competency ;
    ns1:competencyCode "CE02" ;
    ns1:competencyDescription "Aplicar, de manera fundamentada y argumentada, los principios fisiológicos, biomecánicos, comportamentales y sociales en el diseño y puesta en práctica de propuestas y programas de Educación Física en el contexto educativo. Nivel 3."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100020/2025-26/CE03> a ns1:Competency ;
    ns1:competencyCode "CE03" ;
    ns1:competencyDescription "Identificar y prevenir los riesgos que se derivan para la salud de los escolares en la práctica de actividades físicas inadecuadas o realizadas de forma incorrecta. Nivel 3."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100020/2025-26/CE06> a ns1:Competency ;
    ns1:competencyCode "CE06" ;
    ns1:competencyDescription "Promover y evaluar la formación de hábitos perdurables y autónomos de práctica actividad física y del deporte entre la población escolar. Nivel 3."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100020/2025-26/CG04> a ns1:Competency ;
    ns1:competencyCode "CG04" ;
    ns1:competencyDescription "Mostrar disposición y habilidad para el trabajo y el liderazgo en equipo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100020/2025-26/CG16> a ns1:Competency ;
    ns1:competencyCode "CG16" ;
    ns1:competencyDescription "Desarrollar la conciencia de respeto e igualdad entre géneros, igualdad democrática y atención a la diversidad, como principios éticos necesarios para el correcto ejercicio profesional en las Ciencias de la Actividad Física y del Deporte."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100020/2025-26/RA438> a ns1:LearningResult ;
    ns1:learningResultCode "RA438" ;
    ns1:learningResultDescription "Conocer los aspectos más relevantes de la historia del Judo y su evolución, como arte marcial y como deporte"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100020/2025-26/RA439> a ns1:LearningResult ;
    ns1:learningResultCode "RA439" ;
    ns1:learningResultDescription "Conocer los aspectos más relevantes del reglamento de arbitraje y competición en Judo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100020/2025-26/RA440> a ns1:LearningResult ;
    ns1:learningResultCode "RA440" ;
    ns1:learningResultDescription "Identificar y saber ejecutar correctamente todas las técnicas de control en el suelo y de proyección que integran el programa de la asignatura"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100020/2025-26/RA441> a ns1:LearningResult ;
    ns1:learningResultCode "RA441" ;
    ns1:learningResultDescription "Comprender, explicar y demostrar los fundamentos de Judo suelo y de Judo pie incluidos en el programa de la asignatura"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100020/2025-26/RA442> a ns1:LearningResult ;
    ns1:learningResultCode "RA442" ;
    ns1:learningResultDescription "Identificar, de cara a su enseñanza, los aspectos más relevantes en la ejecución de las técnicas de control en el suelo y de proyección incluidas en el programa de la asignatura, planteando progresiones metodológicas y actividades que faciliten su aprendizaje"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100020/2025-26/RA443> a ns1:LearningResult ;
    ns1:learningResultCode "RA443" ;
    ns1:learningResultDescription "Detectar y corregir errores de ejecución a la hora de realizar las técnicas de control en el suelo y de proyección, así como los fundamentos de Judo pie y Judo suelo que componen el programa de la asignatura"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100020/2025-26/RA444> a ns1:LearningResult ;
    ns1:learningResultCode "RA444" ;
    ns1:learningResultDescription "Conocer y respetar las normas básicas para la práctica segura del Judo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100020/2025-26/RA445> a ns1:LearningResult ;
    ns1:learningResultCode "RA445" ;
    ns1:learningResultDescription "Conocer y respetar los principios y valores inherentes a la práctica del Judo, con especial referencia a los relativos a la vestimenta, al respeto hacia el lugar de práctica y al trato hacia compañeros y maestro"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100020/2025-26/RA446> a ns1:LearningResult ;
    ns1:learningResultCode "RA446" ;
    ns1:learningResultDescription "Adquirir conciencia de la necesidad de ayudar y colaborar con los/as compañeros/as para poder progresar en el aprendizaje del Judo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100020/2025-26/RA447> a ns1:LearningResult ;
    ns1:learningResultCode "RA447" ;
    ns1:learningResultDescription "Adquirir conciencia del tratamiento igualitario, sin distinción de género, raza o capacidades, durante las clases de Judo"@es .

