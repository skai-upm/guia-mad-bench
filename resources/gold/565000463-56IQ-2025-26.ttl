    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/565000463/2025-26/eventSchedule> ;
    schema:description "En esta asignatura se presentan los métodos de fabricación más usuales (moldeo, deformación plástica, mecanizado...) la automatización de algunos procesos de fabricación y las técnicas de control dimensional habitualmente empleadas en producción. Se pretende que el estudiante sea capaz de modelar cuantitativamente los procesos y de estimar los valores de las variables que intervienen en cada caso, bajo diferentes condiciones."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/emilio.gomez%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/emilio.gomez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/jesus.caja%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/ricardo.garcia.ledesma%40upm.es> ;
    schema:name "Tecnologias de Fabricacion"@es .

