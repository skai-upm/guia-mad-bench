<https://guia-kg.skai.etsisi.upm.es/resource/23000635/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. MECANISMOS QUE OPERAN EN LA FRUCTIFICACIÓN Y DESARROLLO DE LA SEMILLA Y APLICACIONES BIOTECNOLOGICAS"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000635/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. CONTROL MOLECULAR DE LA FRUCTIFICACIÓN Y DESARROLLO DE LA SEMILLA Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000635/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "3.1. CONTROL CIRCADIANO DEL CRECIMIENTO VEGETAL. CONTROL DIURNO Y ESTACIONAL DE LAS TRANSICIONES DE DESARROLLO. CONTROL DEL TIEMPO DE FLORACION. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000635/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "3.2. INTERACCION DEL DESARROLLO VEGETAL CON SENALES DE LUZ Y TEMPERATURA. APLICACIONES BIOTECNOLOGICAS Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000635/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "3.3. ADAPTACION DEL DESARROLLO A ESTRESES ABIOTICOS. APLICACIONES BIOTECNOLOGICAS Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000635/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. CONTROL MOLECULAR DE LA MADURACIÓN DE LA SEMILLA . APLICACIONES BIOTECNOLOGICAS Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000635/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "1.3. METODOLOGIAS DE ESTUDIO EN BIOTECNOLOGIA VEGETAL Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000635/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "2. MECANISMOS DE CONTROL DE LA FUNCION DE LOS MERISTEMOS Y SUS APLICACIONES BIOTECNOLÓGICAS"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000635/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "2.1. MERISTEMO APICAL: ORGANIZACIÓN, CONTROL GENÉTICO Y HORMONAL. APLICACIONES BIOTECNOLÓGICAS Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000635/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "2.2. EL SISTEMA RADICULAR: FORMACIÓN Y DESARROLLO. REGULACIÓN DE LA EXPRESIÓN GÉNICA .APLICACIONES BIOTECNOLÓGICAS Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000635/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "2.3. EL CAMBIUM VASCULAR: FUNCIÓN, REGULACIÓN Y APLICACIONES BIOTECNOLÓGICAS Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000635/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "2.4. COMPARACION DE LOS MECANISMOS QUE ACTUAN EN EL DESARROLLO MERISTEMATICO Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000635/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "3. INTERACCIÓN DEL DESARROLLO VEGETAL CON EL MEDIO AMBIENTE"@es .

