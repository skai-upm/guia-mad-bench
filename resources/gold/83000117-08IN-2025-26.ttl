        <https://guia-kg.skai.etsisi.upm.es/resource/83000117/2025-26/syllabus/18>,
        <https://guia-kg.skai.etsisi.upm.es/resource/83000117/2025-26/syllabus/19>,
        <https://guia-kg.skai.etsisi.upm.es/resource/83000117/2025-26/syllabus/2>,
