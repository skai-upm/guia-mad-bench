    ns1:inpersonHours "31 horas y 15 minutos (40.1%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation "La asignatura está muy relacionada con el ODS7: Energía asequible y no contaminante"@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "31 horas y 15 minutos"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/53001638/2025-26/eventSchedule> ;
    schema:description "En esta asignatura se aborda la problemática de los convertidores electrónicos conectados a la red eléctrica, tanto para tomar energía (rectificadores) como para aportar energía (inversores). Se abordan topologías, métodos de control y se analizan las principales aplicaciones. Los alumnos serán capaces de conocer en profundidad el diseño de estos circuitos. Las clases incluyen circuitos básicos y avanzados del estado del arte."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/miroslav.vasic%40upm.es> ;
    schema:inLanguage "Inglés/Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/d.rios%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/miroslav.vasic%40upm.es> ;
    schema:name "Grid Connected Converters: Ac/dc & Dc/ac"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001638/2025-26/MUEI.CE01> a ns1:Competency ;
    ns1:competencyCode "MUEI.CE01" ;
    ns1:competencyDescription "Comprender, diseñar y analizar sistemas y componentes electrónicos en el ámbito de la electrónica industrial. Modelización y caracterización de sistemas electrónicos complejos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001638/2025-26/MUEI.CE03> a ns1:Competency ;
    ns1:competencyCode "MUEI.CE03" ;
    ns1:competencyDescription "Optimizar la gestión energética de los sistemas electrónicos mediante la aplicación de técnicas avanzadas de diseño de circuitos y de métodos de control."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001638/2025-26/MUEI.CE04> a ns1:Competency ;
    ns1:competencyCode "MUEI.CE04" ;
    ns1:competencyDescription "Utilización de herramientas CAD para la simulación, modelado y diseño de circuitos electrónicos industriales con altas prestaciones y/o restricciones."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001638/2025-26/MUEI.CE05> a ns1:Competency ;
    ns1:competencyCode "MUEI.CE05" ;
    ns1:competencyDescription "Manejo de instrumentos de medida específicos para el diseño y verificación de sistemas electrónicos industriales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001638/2025-26/MUEI.CT01> a ns1:Competency ;
    ns1:competencyCode "MUEI.CT01" ;
    ns1:competencyDescription "Uso de la lengua inglesa"@es .

