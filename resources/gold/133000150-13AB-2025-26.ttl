    ns1:previousKnowledge "El coordinador de la asignatura no ha definido otros conocimientos previos recomendados."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/E.T.S.I.%20Montes%2C%20Forestal%20Y%20Medio%20Natur.> a ns1:UniversityCenter ;
    ns1:offers <https://guia-kg.skai.etsisi.upm.es/resource/13AB%20-%20Master%20Universitario%20en%20Gestion%20del%20Turismo%20Ecologico%20y%20Sostenible> ;
    schema:name "E.T.S.I. Montes, Forestal Y Medio Natur." .

<https://guia-kg.skai.etsisi.upm.es/resource/133000150> a ns1:Course ;
    ns1:courseType "Obligatoria"@es ;
    ns1:courseYear 1 ;
    ns1:semester "Primer semestre"@es ;
    schema:courseCode 133000150 ;
    schema:hasCourseInstance <https://guia-kg.skai.etsisi.upm.es/resource/133000150/2025-26> ;
    schema:name "Introduction. Conceptualization And Importance Of Ecological And Sustainable Tourism."@en,
        "Introducción. Conceptualización e Importancia del Turismo Ecológico y Sostenible."@es ;
    schema:numberOfCredits 5.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/133000150/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/133000150/2025-26/CB07>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000150/2025-26/CB09>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000150/2025-26/CE01>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000150/2025-26/CG07> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/133000150/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000150/2025-26/didactic_resource/2> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/133000150/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/133000150/2025-26/RA29>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000150/2025-26/RA3>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000150/2025-26/RA46>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000150/2025-26/RA56> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/133000150/2025-26/syllabus> ;
    ns1:inpersonHours "59 horas y 30 minutos (45.8%)"@es ;
    ns1:numberOfCredits 5.0 ;
    ns1:otherInformation """La asignatura se desarrolla con los ODS 1,5,8,10,11,12,13 y 17 el turismo sostenible afecta a todos estos objetivos, dado que su finalidad es precisamente eso.
LAS COMPETENCIAS Y LOS RESULTADOS DE APRENDIZAJE DE ESTA ASIGNATURA SON LOS ACORDES CON LA MEMORIA VERIFICA DEL TÍTULO"""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "68 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/133000150/2025-26/eventSchedule> ;
    schema:description "La asignatura tiene un carácter introductorio y de homogeneiazación de concimientos. Para aquellos estudiantes que vengan de la rama de turismo, muchos elementos de las unidades, seguramente los hayan manejado. Por el contrario, aquellos estudiantes que vengan de otras ramas má ambientalistas, seguramente conozcan los elementos ecológicos del tema. Se trata por tanto, de llegar a un equilibrio, donde unos y otros pueden alimentar el debate a través de los foros y el intercambio de experiencias."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/carlos.calderon%40upm.es> ;
    schema:inLanguage "Inglés/Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/carlos.calderon%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/roberto.rodriguezsolano%40upm.es> ;
    schema:name "Introducción. Conceptualización e Importancia del Turismo Ecológico y Sostenible."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000150/2025-26/CB07> a ns1:Competency ;
    ns1:competencyCode "CB07" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en entornos nuevos o poco conocidos dentro de contextos más amplios (o multidisciplinares) relacionados con su área de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000150/2025-26/CB09> a ns1:Competency ;
    ns1:competencyCode "CB09" ;
    ns1:competencyDescription "Que los estudiantes sepan comunicar sus conclusiones y los conocimientos y razones últimas que las sustentan a públicos especializados y no especializados de un modo claro y sin ambigüedades"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000150/2025-26/CE01> a ns1:Competency ;
    ns1:competencyCode "CE01" ;
    ns1:competencyDescription "Conocimiento y capacidad para interpretar y comprender los aspectos ambientales, económicos y socioculturales que afectan al ecoturismo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000150/2025-26/CG07> a ns1:Competency ;
    ns1:competencyCode "CG07" ;
    ns1:competencyDescription "Utilización de las TICs para el trabajo cooperativo y el trabajo en equipo en el ámbito del turismo ecológico y sostenible."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000150/2025-26/RA29> a ns1:LearningResult ;
    ns1:learningResultCode "RA29" ;
    ns1:learningResultDescription "Comprender los principios de la Gestión Ambiental, la Gestión de Residuos, y su implicación en el turismo sostenible y ecológico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000150/2025-26/RA3> a ns1:LearningResult ;
    ns1:learningResultCode "RA3" ;
    ns1:learningResultDescription "Reconocer un producto de la naturaleza y procurar su conservación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000150/2025-26/RA46> a ns1:LearningResult ;
    ns1:learningResultCode "RA46" ;
    ns1:learningResultDescription "Un buen nivel de expresión oral, basado en una buena dicción, claridad y orden en la exposición de los conceptos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000150/2025-26/RA56> a ns1:LearningResult ;
    ns1:learningResultCode "RA56" ;
    ns1:learningResultDescription "Inclulcar los valores que deben de primar en un observador de la Naturaleza"@es .

