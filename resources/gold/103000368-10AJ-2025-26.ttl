<https://guia-kg.skai.etsisi.upm.es/resource/103000368/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/103000368/2025-26/C14>,
        <https://guia-kg.skai.etsisi.upm.es/resource/103000368/2025-26/C9>,
