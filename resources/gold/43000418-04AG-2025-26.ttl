<https://guia-kg.skai.etsisi.upm.es/resource/43000418/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/43000418/2025-26/CGP01>,
