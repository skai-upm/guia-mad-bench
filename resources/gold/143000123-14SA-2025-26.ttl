    ns1:inpersonHours "49 horas (41.9%)"@es ;
    ns1:numberOfCredits 4.5 ;
    ns1:otherInformation "La asignatura se relaciona con el ODS9 y el ODS12."@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "49 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/143000123/2025-26/eventSchedule> ;
    schema:description """El objetivo de la asignatura es que el estudiante conozca la importancia del subsistema estructural de un vehículo espacial y que sea capaz, conforme a las competencias básicas y específicas detalladas posteriormente, de realizar y verificar el diseño y dimensionado de la estructura de un vehículo espacial.
La metodología de enseñanza y aprendizaje está articulada en torno al desarrollo de clases de presentación de contenidos, complementadas con clases prácticas guiadas. Puesto que se trata, en línea con la naturaleza del máster, de que los alumnos pongan en práctica los conocimientos adquiridos, se realizarán prácticas con las herramientas de cálculo de estructuras que son el estándar en la industria aeroespacial (Patran / Nastran), lo que requerirá lógicamente la previa impartición de formación en el uso de las mismas."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/andres.garcia.perez%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/andres.garcia.perez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/elena.roibas%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/gustavo.alonso%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/marcos.chimeno%40upm.es> ;
    schema:name "Estructuras de Uso Espacial"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000123/2025-26/E01> a ns1:Competency ;
    ns1:competencyCode "E01" ;
    ns1:competencyDescription "Aplicar los principios físicos y matemáticos avanzados y los métodos numéricos empleados en el análisis de problemas típicos de la ingeniería de sistemas espaciales. Evaluar e interpretar críticamente los resultados obtenidos con estos métodos, tanto cualitativa como cuantitativamente"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000123/2025-26/E02> a ns1:Competency ;
    ns1:competencyCode "E02" ;
    ns1:competencyDescription "Aplicar los métodos de análisis propios de un determinado subsistema, para verificar la adecuación del diseño del mismo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000123/2025-26/E03> a ns1:Competency ;
    ns1:competencyCode "E03" ;
    ns1:competencyDescription "Conocer y comprender el entorno espacial y planetario, y su efecto en la operación de los vehículos aeroespaciales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000123/2025-26/E10> a ns1:Competency ;
    ns1:competencyCode "E10" ;
    ns1:competencyDescription "Conocer los diferentes tipos de configuraciones de subsistemas y su relación con los distintos tipos de misión y los correspondientes requisitos, así como las relaciones entre diferentes subsistemas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000123/2025-26/E12> a ns1:Competency ;
    ns1:competencyCode "E12" ;
    ns1:competencyDescription "Desarrollar los diferentes subsistemas específicos que conforman un vehículo espacial."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000123/2025-26/E13> a ns1:Competency ;
    ns1:competencyCode "E13" ;
    ns1:competencyDescription "Analizar los subsistemas específicos que conforman un vehículo espacial."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000123/2025-26/E21> a ns1:Competency ;
    ns1:competencyCode "E21" ;
    ns1:competencyDescription "Calcular estructuras espaciales con la herramienta de uso industrial Patran/Nastran"@es .

