    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. UT1-Tema 1- Conceptos básicos relacionados con el cambio climático Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001415/2025-26/syllabus/10> a ns1:SyllabusItem ;
