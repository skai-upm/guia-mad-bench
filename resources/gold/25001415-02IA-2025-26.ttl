    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/25001415/2025-26/eventSchedule> ;
    schema:description """El objetivo general es comprender las relaciones entre las variables físicas, agronómicas, económicas y sociales que determinan en cambio global.
Los objetivos de la asignatura son:
1 Comprender el papel que juega la atmósfera en la regulación térmica del planeta a través de los gases de efecto invernadero.
2 Identificar y dimensionar las principales emisiones de gases de efecto invernadero relacionadas con la Agricultura y el cambio de uso.
3 Conocer estrategias de mitigación del cambio climático y su aplicación específica a través del secuestro de carbono en el suelo.
4 Conocer los principales escenarios de cambio climático a nivel mundial y en España en particular y sus implicaciones en la fertilización
5 Conocer el impacto del calentamiento global/cambio climático en la ecofisiología de los cultivos.
6 Conocer las herramientas de evaluación de impactos y adaptación al cambio climático de los sistemas agrícolas.
7 Abordar la problemática del nitrógeno en el cambio global
8 Conocer las proyecciones existentes de impacto y comprender las incertidumbres asociadas.
9 Conocer los fundamentos en los que se basa la adaptación agronómica de los sistemas agrícolas.
10 Comprender los instrumentos políticos para hacer frente al cambio climático.
11 Analizar las interacciones entre cambio global, desarrollo y crecimiento económico."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/luis.lassaletta%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/ana.iglesias%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/c.hontoria%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/luis.lassaletta%40upm.es> ;
    schema:name "Cambio Global y Agricultura"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001415/2025-26/CE11> a ns1:Competency ;
    ns1:competencyCode "CE11" ;
    ns1:competencyDescription "Describir el funcionamiento del recurso suelo y recomendar el manejo más adecuado como medio productivo y como componente del medio ambiente."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001415/2025-26/CE30> a ns1:Competency ;
    ns1:competencyCode "CE30" ;
    ns1:competencyDescription "Capacidad para evaluar la metodología más adecuada para obtener, reunir e interpretar datos relevantes del área agroambiental para emitir juicios que incluyan una reflexión sobre temas relevantes de índole técnica, científica, social, o ética."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001415/2025-26/CE32> a ns1:Competency ;
    ns1:competencyCode "CE32" ;
    ns1:competencyDescription "Capacidad para analizar, diagnosticar y cuantificar los efectos ambientales de la producción agraria, los proyectos de ingeniería y otras actuaciones sobre el medio rural, incluyendo todos los aspectos técnicos de impacto."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001415/2025-26/CE44> a ns1:Competency ;
    ns1:competencyCode "CE44" ;
    ns1:competencyDescription "Capacidad para describir y evaluar el papel de la agricultura en la emisión y mitigación de gases de efecto invernadero (GEI) y adaptar la agricultura al cambio climático y realizar proyectos agrícolas de carbono."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001415/2025-26/CE7> a ns1:Competency ;
    ns1:competencyCode "CE7" ;
    ns1:competencyDescription "Capacidad para elaborar estudios y evaluar aspectos climatológicos relacionados con la producción agraria, la generación de energía, y el medio ambiente a distintas escalas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001415/2025-26/CG14> a ns1:Competency ;
    ns1:competencyCode "CG14" ;
    ns1:competencyDescription "Análisis y síntesis, razonamiento crítico y resolución de problemas científicos y técnicos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001415/2025-26/CG16> a ns1:Competency ;
    ns1:competencyCode "CG16" ;
    ns1:competencyDescription "Aplicar conocimientos adquiridos a la práctica de la ingeniería agraria"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001415/2025-26/CG2> a ns1:Competency ;
