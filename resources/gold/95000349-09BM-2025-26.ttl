        <https://guia-kg.skai.etsisi.upm.es/resource/p.sanchez%40upm.es> ;
    schema:name "Tratamiento Digital de Imágenes Biomédicas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000349/2025-26/CE14> a ns1:Competency ;
    ns1:competencyCode "CE14" ;
    ns1:competencyDescription "Comprender los principios de la metodología científica; capacidad para su aplicación a la resolución de problemas en el campo de la ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000349/2025-26/CE42> a ns1:Competency ;
    ns1:competencyCode "CE42" ;
    ns1:competencyDescription "Conocer técnicas de muestreo y procesado de señales e imágenes para diversas aplicaciones en relación con la Ingeniería Biomédica."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000349/2025-26/CE43> a ns1:Competency ;
    ns1:competencyCode "CE43" ;
    ns1:competencyDescription "Capacidad de análisis e interpretación de señales e imágenes biomédicas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000349/2025-26/CG01> a ns1:Competency ;
    ns1:competencyCode "CG01" ;
    ns1:competencyDescription "Desarrollar las habilidades de aprendizaje necesarias para emprender actividades o estudios posteriores de forma autónoma y con confianza."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000349/2025-26/CG02> a ns1:Competency ;
    ns1:competencyCode "CG02" ;
    ns1:competencyDescription "Aplicar de forma profesional a su trabajo los conocimientos adquiridos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000349/2025-26/CG03> a ns1:Competency ;
    ns1:competencyCode "CG03" ;
    ns1:competencyDescription "Ser capaz de manejar todas las tecnologías de la información y las comunicaciones."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000349/2025-26/CG04> a ns1:Competency ;
    ns1:competencyCode "CG04" ;
    ns1:competencyDescription "Trabajar de forma adecuada en un laboratorio incluyendo un registro anotado de las actividades y seguridad, manipulación y eliminación de residuos químicos o biológicos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000349/2025-26/CG05> a ns1:Competency ;
    ns1:competencyCode "CG05" ;
    ns1:competencyDescription "Tener capacidad de análisis y síntesis, pensar de forma integrada, abordar los problemas desde diferentes perspectivas y estar siempre preparado para ¿to think out of the box¿"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000349/2025-26/CG06> a ns1:Competency ;
    ns1:competencyCode "CG06" ;
    ns1:competencyDescription "Adoptar una actitud ante los problemas de su competencia que considere que su papel no es exclusivamente aportar soluciones sino, siempre que sea posible, participar además en la propia identificación u definición de dichos problemas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000349/2025-26/CG07> a ns1:Competency ;
    ns1:competencyCode "CG07" ;
    ns1:competencyDescription "Ser capaz de utilizar el método científico."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000349/2025-26/CG08> a ns1:Competency ;
    ns1:competencyCode "CG08" ;
    ns1:competencyDescription "Entender, aplicar, adaptar y desarrollar herramientas, técnicas y protocolos de experimentación con rigor metodológico comprendiendo las limitaciones que tiene la aproximación experimental."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000349/2025-26/CG09> a ns1:Competency ;
    ns1:competencyCode "CG09" ;
    ns1:competencyDescription "Tener capacidad de descripción, cuantificación, análisis y evaluación de resultados experimentales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000349/2025-26/CG10> a ns1:Competency ;
    ns1:competencyCode "CG10" ;
    ns1:competencyDescription "Formular, diseñar y elaborar proyectos siendo capaz de liderar grupos de trabajo y buscar en distintas fuentes de información e integrar nuevos conocimientos en su investigación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000349/2025-26/CG11> a ns1:Competency ;
    ns1:competencyCode "CG11" ;
    ns1:competencyDescription "Elaborar y defender argumentos y resolver los problemas de forma efectiva y creativa."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000349/2025-26/CG12> a ns1:Competency ;
    ns1:competencyCode "CG12" ;
    ns1:competencyDescription "Tener capacidad de iniciativa, integración, colaboración y potenciación de la discusión crítica en el ámbito del trabajo en equipo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000349/2025-26/CG13> a ns1:Competency ;
    ns1:competencyCode "CG13" ;
    ns1:competencyDescription "Ser capaz de colaborar con grupos internacionales, interdisciplinares y multiculturales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000349/2025-26/CG14> a ns1:Competency ;
    ns1:competencyCode "CG14" ;
    ns1:competencyDescription "Reunir e interpretar datos relevantes para emitir juicios que incluyan una reflexión sobre temas relevantes de índole social, económica, científica o ética."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000349/2025-26/CG15> a ns1:Competency ;
    ns1:competencyCode "CG15" ;
    ns1:competencyDescription "Transmitir la información adquirida, las ideas, los problemas y las soluciones de forma oral y escrita en castellano e inglés."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000349/2025-26/CG16> a ns1:Competency ;
    ns1:competencyCode "CG16" ;
    ns1:competencyDescription "Aplicar los sistemas de divulgación de los resultados científicos de manera apropiada y utilizar los principios y medios relacionados con la transferencia de tecnología"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000349/2025-26/CG17> a ns1:Competency ;
    ns1:competencyCode "CG17" ;
    ns1:competencyDescription "Tener un comportamiento ético y profesional en todos los aspectos relacionados con el respeto por el medio ambiente y con el bienestar social, para utilizar de forma equilibrada las tecnologías en busca de una economía social y medioambientalmente sostenible."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000349/2025-26/RA165> a ns1:LearningResult ;
    ns1:learningResultCode "RA165" ;
    ns1:learningResultDescription "Presentar de forma oral o escrita las conclusiones más relevantes de un trabajo de investigación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000349/2025-26/RA228> a ns1:LearningResult ;
    ns1:learningResultCode "RA228" ;
    ns1:learningResultDescription "Realizar un trabajo en equipo creativo que sintetice los conocimientos prácticos de la asignatura"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000349/2025-26/RA232> a ns1:LearningResult ;
    ns1:learningResultCode "RA232" ;
    ns1:learningResultDescription "Programar algunos de los algoritmos de procesamiento que más se utilizan para facilitar las tareas de diagnóstico médico a los especialistas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000349/2025-26/RA233> a ns1:LearningResult ;
    ns1:learningResultCode "RA233" ;
    ns1:learningResultDescription "Conocer y comprender los principales métodos y técnicas de procesamiento de imágenes médicas"@es .

