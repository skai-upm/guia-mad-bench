    ns1:evaluationDuration "01:00"@es ;
    ns1:evaluationType "progresiva"@es ;
    ns1:gradePercentage "35%"@es ;
    ns1:hasScheduleEvent <https://guia-kg.skai.etsisi.upm.es/resource/55001016/2025-26/eventSchedule/8> ;
    ns1:involvesCompetency <https://guia-kg.skai.etsisi.upm.es/resource/CE%2016>,
        <https://guia-kg.skai.etsisi.upm.es/resource/CG%205>,
        <https://guia-kg.skai.etsisi.upm.es/resource/CG%206> ;
    ns1:minimumScore "4 / 10"@es ;
    ns1:trialDescription "Prueba de evaluación intermedia (PEI1) - Liberatoria - Recuperable"@es ;
