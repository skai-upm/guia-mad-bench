<https://guia-kg.skai.etsisi.upm.es/resource/205000119/2025-26/RA251> a ns1:LearningResult ;
    ns1:learningResultCode "RA251" ;
    ns1:learningResultDescription "Conocer las regulaciones de dichas máquinas para su correcta aplicación en el campo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000119/2025-26/RA253> a ns1:LearningResult ;
