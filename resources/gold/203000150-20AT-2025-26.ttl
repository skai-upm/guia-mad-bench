<https://guia-kg.skai.etsisi.upm.es/resource/203000150/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/203000150/2025-26/CB10>,
        <https://guia-kg.skai.etsisi.upm.es/resource/203000150/2025-26/CE%2014>,
