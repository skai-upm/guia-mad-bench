    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/93000842/2025-26/eventSchedule> ;
    schema:description """El objetivo de esta asignatura es presentar los fundamentos de la generación y procesado de las señales e imágenes con especial énfasis en los problemas ligados a la investigación biomédica y práctica clínica. El temario incluye, entre otros, la adquisición de los datos, filtrado, codificación, extracción de características, y modelado.
The objective of this course is to present the fundamentals of signal and image generation and processing, with special emphasis on problems related to biomedical research and clinical practice. The curriculum includes, among others, data acquisition, filtering, coding, feature extraction, and modeling."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/enriquejavier.gomez%40upm.es> ;
    schema:inLanguage "Inglés"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/enriquejavier.gomez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/i.oropesa%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/josejavier.serrano%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/mariaelena.hernando%40upm.es> ;
    schema:name "Señales e Imagenes Medicas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000842/2025-26/CE15> a ns1:Competency ;
    ns1:competencyCode "CE15" ;
    ns1:competencyDescription "Capacidad para la integración de tecnologías y sistemas propios de la Ingeniería de Telecomunicación, con carácter generalista, y en contextos más amplios y multidisciplinares como por ejemplo en bioingeniería, conversión fotovoltaica, nanotecnología, telemedicina."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000842/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Poseer y comprender conocimientos que aporten una base u oportunidad de ser originales en el desarrollo y/o aplicación de ideas, a menudo en un contexto de investigación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000842/2025-26/CG2> a ns1:Competency ;
    ns1:competencyCode "CG2" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en entornos nuevos o poco conocidos dentro de contextos más amplios (o multidisciplinares) relacionados con su área de estudio."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000842/2025-26/CG4> a ns1:Competency ;
    ns1:competencyCode "CG4" ;
    ns1:competencyDescription "Que los estudiantes sepan comunicar sus conclusiones ?y los conocimientos y razones últimas que las sustentan? a públicos especializados y no especializados de un modo claro y sin ambigüedades."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000842/2025-26/CG5> a ns1:Competency ;
    ns1:competencyCode "CG5" ;
    ns1:competencyDescription "Que los estudiantes posean las habilidades de aprendizaje que les permitan continuar estudiando de un modo que habrá de ser en gran medida autodirigido o autónomo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000842/2025-26/CT2> a ns1:Competency ;
    ns1:competencyCode "CT2" ;
    ns1:competencyDescription "Capacidad para dinamizar y liderar equipos de trabajo multidisciplinares."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000842/2025-26/CT4> a ns1:Competency ;
    ns1:competencyCode "CT4" ;
    ns1:competencyDescription "Capacidad para trabajar de forma efectiva como individuo, organizando y planificando su propio trabajo, de forma independiente o como miembro de un equipo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000842/2025-26/CT5> a ns1:Competency ;
    ns1:competencyCode "CT5" ;
    ns1:competencyDescription "Capacidad para gestionar la información, identificando las fuentes necesarias, los principales tipos de documentos técnicos y científicos, de una manera adecuada y eficiente."@es .

