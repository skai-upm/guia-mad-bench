<https://guia-kg.skai.etsisi.upm.es/resource/135005802/2025-26/CB02> a ns1:Competency ;
    ns1:competencyCode "CB02" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar sus conocimientos a su trabajo o vocación de una forma profesional y posean las competencias que suelen demostrarse por medio de la elaboración y defensa de argumentos y la resolución de problemas dentro de su área de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005802/2025-26/CE%201.28> a ns1:Competency ;
    ns1:competencyCode "CE 1.28" ;
    ns1:competencyDescription "Conocer la legislación medioambiental y la específica del Medio Natural, en sus niveles Comunitario, Estatal, Autonómico y Municipal."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005802/2025-26/CE%201.31> a ns1:Competency ;
    ns1:competencyCode "CE 1.31" ;
    ns1:competencyDescription "Tener en consideración las condiciones sociales, éticas y legales deseadas en la profesión y práctica de la ingeniería del medio natural."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005802/2025-26/CE%202.08> a ns1:Competency ;
    ns1:competencyCode "CE 2.08" ;
    ns1:competencyDescription "Conocer la morfología de proyectos y comprender el ciclo proyectual, los métodos de elaboración de proyectos y los métodos de selección de alternativas técnicas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005802/2025-26/CE%202.11> a ns1:Competency ;
    ns1:competencyCode "CE 2.11" ;
    ns1:competencyDescription "Comprender los conceptos básicos de la ordenación territorial y conocer las distintas escalas, tipologías sectoriales y procedimientos de elaboración."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005802/2025-26/CG05> a ns1:Competency ;
    ns1:competencyCode "CG05" ;
    ns1:competencyDescription "Identificar y cuantificar las implicaciones ambientales y ecológicas de la ejecución de actuaciones humanas sobre el medio físico natural y la estuctura y funcionamiento de los ecosistemas naturales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005802/2025-26/CG11> a ns1:Competency ;
    ns1:competencyCode "CG11" ;
    ns1:competencyDescription "Realizar consultorías ecológicas y ambientales en el Medio Natural."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005802/2025-26/CT01> a ns1:Competency ;
    ns1:competencyCode "CT01" ;
    ns1:competencyDescription "Aplicar los conocimientos adquiridos para idear y desarrollar estrategias que permitan obtener, de forma razonada, una solución contrastada de problemas en el ámbito de la ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005802/2025-26/CT02> a ns1:Competency ;
    ns1:competencyCode "CT02" ;
    ns1:competencyDescription "Aplicar las principales técnicas de análisis y síntesis para la gestión de la información procedente de distintas fuentes, extrayendo las conclusiones pertinentes e integrándolas con los conocimientos previos y los objetivos perseguidos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005802/2025-26/CT06> a ns1:Competency ;
    ns1:competencyCode "CT06" ;
    ns1:competencyDescription "Desarrollar la capacidad para trabajar en equipo, integrándose y colaborando de forma activa en la consecución de objetivos comunes."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005802/2025-26/CT07> a ns1:Competency ;
    ns1:competencyCode "CT07" ;
    ns1:competencyDescription "Planificar y organizar trabajos, estableciendo los objetivos y la programación, asignando tareas y recursos y responsabilizándose de la correcta toma de decisiones."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005802/2025-26/RA301> a ns1:LearningResult ;
    ns1:learningResultCode "RA301" ;
    ns1:learningResultDescription "Establecer medidas para mitigar los impactos y, en lo posible, corregirlos"@es .

