    ns1:totalHours "48 horas y 30 minutos"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/65001034/2025-26/eventSchedule> ;
    schema:description "Dotar de la cualificación técnica necesaria para acceder al mundo profesional, dentro del- Planeamiento- Proyecto /diseño- Dirección de obra- Responsable de conservación de obras subterráneas.La asignatura se focaliza en el diseño y construcción de excavaciones subterráneas en rocas."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/ricardo.lain%40upm.es> ;
