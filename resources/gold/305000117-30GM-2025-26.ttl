    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/305000117/2025-26/eventSchedule> ;
    schema:description """La asignatura introduce la modelización y la simulación como herramientas fundamentales para la investigación científica. Lo vivo, como síntesis de todos los procesos que caracterizan
y generan la vida, conforma el hilo conductor de los modelos matemáticos que se presentan en esta asignatura. Los distintos capítulos abordan distintas facetas del fenómeno vivo. Las
cuestiones que emanan de lo vivo, su implementación matemática o computacional, el estudio de los modelos y la comparación con los datos experimentales conforman el
paradigma sobre el que giran todos y cada uno de los capítulos. Estos se complementan con la realización de talleres y prácticas que permiten al estudiante profundizar en el
conocimiento de lo vivo y de las matemáticas que se aplican para entenderlo."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/juancarlos.nuno%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/juancarlos.nuno%40upm.es> ;
    schema:name "Modelización y Simulación II"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000117/2025-26/CE1> a ns1:Competency ;
    ns1:competencyCode "CE1" ;
    ns1:competencyDescription "Comprender y utilizar el lenguaje matemático. Adquirir la capacidad para enunciar propiedades en distintos campos de la Matemática, para construir argumentaciones, elaborar cálculos y para transmitir los conocimientos matemáticos adquiridos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000117/2025-26/CE3> a ns1:Competency ;
    ns1:competencyCode "CE3" ;
    ns1:competencyDescription "Asimilar la definición de un nuevo objeto matemático, en términos de otros ya conocidos, y ser capaz de utilizar este objeto en diferentes contextos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000117/2025-26/CE4> a ns1:Competency ;
    ns1:competencyCode "CE4" ;
    ns1:competencyDescription "Abstraer las propiedades estructurales de objetos matemáticos, de la realidad observada o de otros ámbitos distinguiéndolas de aquellas puramente ocasionales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000117/2025-26/CE6> a ns1:Competency ;
    ns1:competencyCode "CE6" ;
    ns1:competencyDescription "Proponer, analizar, validar e interpretar modelos matemáticos de sistemas reales, utilizando las herramientas matemáticas más adecuadas a los fines que se persigan, explicitando las características del sistema recogidas en el modelo y las no consideradas en el mismo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000117/2025-26/CE7> a ns1:Competency ;
    ns1:competencyCode "CE7" ;
    ns1:competencyDescription "Resolver problemas de Matemáticas, mediante habilidades de cálculo básico y tecnologías de computación, planificando su resolución en función de las herramientas de que se disponga y de las restricciones de tiempo y recursos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000117/2025-26/CE8> a ns1:Competency ;
    ns1:competencyCode "CE8" ;
    ns1:competencyDescription "Utilizar aplicaciones informáticas de análisis estadístico, cálculo numérico y simbólico, visualización gráfica, optimización u otras para experimentar en Matemáticas, buscar soluciones y resolver modelos matemáticos de sistemas reales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000117/2025-26/CE9> a ns1:Competency ;
    ns1:competencyCode "CE9" ;
    ns1:competencyDescription "Desarrollar programas que ejecuten algoritmos de resolución de modelos matemáticos o aproximación numérica a la solución utilizando para cada caso el entorno computacional adecuado."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000117/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Utilizar las capacidades analíticas y de abstracción, la intuición y el pensamiento lógico y riguroso desarrolladas a través del estudio de la Matemática en contextos tanto matemáticos como no matemáticos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000117/2025-26/CG5> a ns1:Competency ;
    ns1:competencyCode "CG5" ;
    ns1:competencyDescription "Sintetizar conocimientos y habilidades adquiridas en el campo de la matemática en diferentes materias del plan de estudios para enfocarlas en posteriores estudios especializados, tanto en una disciplina matemática como en cualquiera de las ciencias que requieran buenos fundamentos matemáticos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000117/2025-26/CT3> a ns1:Competency ;
    ns1:competencyCode "CT3" ;
    ns1:competencyDescription "Asumir el liderazgo para dirigir y gestionar equipos o proyectos, generando confianza y compromiso en el grupo de colaboradores."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000117/2025-26/RA139> a ns1:LearningResult ;
    ns1:learningResultCode "RA139" ;
    ns1:learningResultDescription "Conocer y seleccionar adecuadamente las herramientas matemáticas necesarias para formular, analizar y simular modelos matemáticos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000117/2025-26/RA140> a ns1:LearningResult ;
    ns1:learningResultCode "RA140" ;
    ns1:learningResultDescription "Plantear, resolver e interpretar modelos matemáticos de problemas aplicados"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000117/2025-26/RA141> a ns1:LearningResult ;
    ns1:learningResultCode "RA141" ;
    ns1:learningResultDescription "Distinguir y separar entre modelos lineales o no lineales, con variables continuas o discretas, deterministas o estocásticas. Enunciar y distinguir las variables que se van a modelizar."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000117/2025-26/RA142> a ns1:LearningResult ;
    ns1:learningResultCode "RA142" ;
    ns1:learningResultDescription "Reconocer las hipótesis planteadas y los límites de aplicación de los modelos utilizados."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000117/2025-26/RA143> a ns1:LearningResult ;
    ns1:learningResultCode "RA143" ;
    ns1:learningResultDescription "Simplificar modelos matemáticos mediante análisis dimensional para reducir su complejidad."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000117/2025-26/RA144> a ns1:LearningResult ;
    ns1:learningResultCode "RA144" ;
    ns1:learningResultDescription "Analizar la sensibilidad de los modelos utilizados respecto a sus parámetros."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000117/2025-26/RA145> a ns1:LearningResult ;
    ns1:learningResultCode "RA145" ;
    ns1:learningResultDescription "Calibrar los modelos mediante datos observacionales y validarlos contra datos observacionales independientes o mediante simplificaciones de los modelos resolubles de forma exacta."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000117/2025-26/RA146> a ns1:LearningResult ;
    ns1:learningResultCode "RA146" ;
    ns1:learningResultDescription "Programar, realizar e interpretar simulaciones de los modelos utilizados"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000117/2025-26/RA147> a ns1:LearningResult ;
    ns1:learningResultCode "RA147" ;
    ns1:learningResultDescription "Conocer y manejar las herramientas de visualización de resultados que más se adapten a cada situación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000117/2025-26/RA148> a ns1:LearningResult ;
    ns1:learningResultCode "RA148" ;
    ns1:learningResultDescription "Comunicar oralmente y por escrito el alcance, las limitaciones y las conclusiones científicas de los modelos, tanto en ámbitos técnicos como más abiertos, favoreciendo la difusión a la sociedad y la transferencia de conocimiento."@es .

