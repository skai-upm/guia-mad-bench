    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/93001004/2025-26/eventSchedule> ;
    schema:description "En esta asignatura, se realizará una introducción a la informática forense. Se explicará el concepto de evidencia digital y su importancia dentro del proceso del análisis forense informático, del que se describirán las fases que lo componen. Además, se explicarán las técnicas comunes que se utilizan para la adquisición y análisis de fuentes de evidencias, así como las relativas a la extracción de la información que pueden contener. Por último, se introducirán los distintos contextos digitales en los que se suelen realizar investigaciones forenses y las particularidades de cada uno de ellos."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/juanmanuel.castelo%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/alejandro.bmorante%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/juanmanuel.castelo%40upm.es> ;
    schema:name "Evidencias Forenses"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93001004/2025-26/CB07> a ns1:Competency ;
    ns1:competencyCode "CB07" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en entornos nuevos o poco conocidos dentro de contextos más amplios (o multidisciplinares) relacionados con su área de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93001004/2025-26/CB08> a ns1:Competency ;
    ns1:competencyCode "CB08" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de integrar conocimientos y enfrentarse a la complejidad de formular juicios a partir de una información que, siendo incompleta o limitada, incluya reflexiones sobre las responsabilidades sociales y éticas vinculadas a la aplicación de sus conocimientos y juicios"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93001004/2025-26/CB09> a ns1:Competency ;
    ns1:competencyCode "CB09" ;
    ns1:competencyDescription "Que los estudiantes sepan comunicar sus conclusiones y los conocimientos y razones últimas que las sustentan a públicos especializados y no especializados de un modo claro y sin ambigüedades"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93001004/2025-26/CE08> a ns1:Competency ;
    ns1:competencyCode "CE08" ;
    ns1:competencyDescription "Capacidad para abordar técnicamente la gestión de un incidente de ciberseguridad, incluyendo análisis de malware, análisis forense e ingeniería inversa"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93001004/2025-26/CG05> a ns1:Competency ;
    ns1:competencyCode "CG05" ;
    ns1:competencyDescription "Dotar al alumno de la capacidad de estar al día de los desarrollos más recientes que tengan que ver con la ciberseguridad, así como de contribuir con ideas contrastadas al desarrollo técnico de lo aprendido y a nuevas áreas en las que sea de aplicación la ciberseguridad, con posibilidad de participar en actividades directivas de nivel medio de gerencia"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93001004/2025-26/CT05> a ns1:Competency ;
    ns1:competencyCode "CT05" ;
    ns1:competencyDescription "Gestión de la información"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93001004/2025-26/CT09> a ns1:Competency ;
    ns1:competencyCode "CT09" ;
    ns1:competencyDescription "Capacidad de análisis y síntesis"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93001004/2025-26/CT10> a ns1:Competency ;
    ns1:competencyCode "CT10" ;
    ns1:competencyDescription "Resolución de problemas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93001004/2025-26/CT12> a ns1:Competency ;
    ns1:competencyCode "CT12" ;
    ns1:competencyDescription "Aprendizaje autónomo, adaptación a nuevas situaciones y motivación por el desarrollo profesional permanente"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93001004/2025-26/RA30> a ns1:LearningResult ;
    ns1:learningResultCode "RA30" ;
    ns1:learningResultDescription "Conocer los fundamentos del análisis forense informático y las evidencias digitales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93001004/2025-26/RA31> a ns1:LearningResult ;
    ns1:learningResultCode "RA31" ;
    ns1:learningResultDescription "Identificar las fases de un análisis forense informático y los requisitos de cada una de ellas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93001004/2025-26/RA32> a ns1:LearningResult ;
    ns1:learningResultCode "RA32" ;
    ns1:learningResultDescription "Adquirir la habilidad para discernir las necesidades forenses de los principales entornos digitales y sus particularidades."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93001004/2025-26/RA34> a ns1:LearningResult ;
    ns1:learningResultCode "RA34" ;
    ns1:learningResultDescription "Determinar qué herramientas son necesarias para la adquisición y análisis de fuentes digitales dependiendo del entorno a analizar, así como qué información se puede extraer de ellas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93001004/2025-26/RA35> a ns1:LearningResult ;
    ns1:learningResultCode "RA35" ;
    ns1:learningResultDescription "Conocer la estructura y contenido de los informes forenses y adquirir la capacidad para el desarrollo de los mismos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93001004/2025-26/RA37> a ns1:LearningResult ;
    ns1:learningResultCode "RA37" ;
    ns1:learningResultDescription "Conocer y aplicar las técnicas forenses informáticas en los principales entornos digitales (escritorio, móvil, cloud e IoT) con el objetivo de extraer conclusiones a partir del análisis de evidencias digitales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93001004/2025-26/didactic_resource/1> a ns1:DidacticResource ;
    ns1:bibliographyTitle "Digital Archeaeology - The Art and Science of Digital Forensics. Addison-Wesley (1ª Edición)"@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93001004/2025-26/didactic_resource/2> a ns1:DidacticResource ;
    ns1:bibliographyTitle "Computer Forensics and Cyber Crime - An Introduction. Prentice-Hall (3ª Edición)"@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93001004/2025-26/didactic_resource/3> a ns1:DidacticResource ;
    ns1:bibliographyTitle "Guide to Computer Forensics and Investigations. Course Technology (4ª Edición)"@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93001004/2025-26/didactic_resource/4> a ns1:DidacticResource ;
    ns1:bibliographyTitle "Computer Forensics - Evidence Collection & Preservation. Course Technology (1ª Edición)"@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93001004/2025-26/evaluation> a ns1:EvaluationSystem ;
    ns1:evaluationDescription """La evaluación progresiva se compondrá de tres prácticas a realizar en grupo con una distribución de pesos de 40%, 20% y 20%, y de tres actividades que se realizarán de forma individual en el aula, cada una con un peso de 6.666%.
En el caso de la evaluación ordinaria y extraordinaria, estas se compondrán de las mismas tres prácticas a realizar, repartiéndose el peso de la nota de las actividades de forma equitativa entre ellas, quedando una distribución de pesos de 46.666%, 26.6666% y 26.6666%. En el caso de la evaluación ordinaria, seguirán siendo en grupo, mientras que en la extraordinaria serán individuales. Las prácticas que hayan sido superadas en la evaluación progresiva no será necesario recuperarlas de cara a la evaluación ordinaria o extraordinaria. Del mismo modo, las prácticas superadas en la evaluación ordinaria no tendrán que ser recuperadas en la convocatoria extraordinaria.
No existe nota mínima para ningún ítem de evaluación. El único criterio para superar la asignatura es obtener una nota media igual o superior a 5/10."""@es ;
    ns1:hasEvaluationTrial <https://guia-kg.skai.etsisi.upm.es/resource/93001004/2025-26/evaluation/trial1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/93001004/2025-26/evaluation/trial10>,
        <https://guia-kg.skai.etsisi.upm.es/resource/93001004/2025-26/evaluation/trial11>,
