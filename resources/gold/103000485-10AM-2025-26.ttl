<https://guia-kg.skai.etsisi.upm.es/resource/103000485/2025-26/CE1> a ns1:Competency ;
    ns1:competencyCode "CE1" ;
    ns1:competencyDescription "Elaborar un plan de proyecto que permita coordinar y priorizar recursos y actividades para obtener los resultados esperados en los plazos, costes y calidad establecidos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000485/2025-26/CE2> a ns1:Competency ;
    ns1:competencyCode "CE2" ;
    ns1:competencyDescription "Llevar a cabo la monitorización de un proyecto software y tomar acciones correctivas si fuera necesario"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000485/2025-26/CE3> a ns1:Competency ;
    ns1:competencyCode "CE3" ;
    ns1:competencyDescription "Elaborar una estimación de los parámetros del proyecto software."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000485/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en entornos nuevos o poco conocidos dentro de contextos más amplios (o multidisciplinares) relacionados con su área de estudio (RD)"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000485/2025-26/CG14> a ns1:Competency ;
    ns1:competencyCode "CG14" ;
    ns1:competencyDescription "Conocimiento y comprensión de la informática necesaria para la creación de modelos de información, y de los sistemas y procesos complejos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000485/2025-26/CG18> a ns1:Competency ;
    ns1:competencyCode "CG18" ;
    ns1:competencyDescription "Capacidad de trabajar y comunicarse también en contextos internacionales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000485/2025-26/CG2> a ns1:Competency ;
    ns1:competencyCode "CG2" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de integrar conocimientos y enfrentarse a la complejidad de formular juicios a partir de una información que, siendo incompleta o limitada, incluya reflexiones sobre las responsabilidades sociales y éticas vinculadas a la aplicación de sus conocimientos y juicios (RD)"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000485/2025-26/CG5> a ns1:Competency ;
    ns1:competencyCode "CG5" ;
    ns1:competencyDescription "Organización y planificación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000485/2025-26/RA2> a ns1:LearningResult ;
    ns1:learningResultCode "RA2" ;
    ns1:learningResultDescription "Facing a real problem, chooses an appropriate Software Engineering solution, analyzing its viability, what can and cannot be achieved from the current state of development of the selected solution, and what is expected to advance in the future"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000485/2025-26/RA25> a ns1:LearningResult ;
    ns1:learningResultCode "RA25" ;
    ns1:learningResultDescription "Communication skills in public SC13, SC14, CG3, CG18 S"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000485/2025-26/RA26> a ns1:LearningResult ;
    ns1:learningResultCode "RA26" ;
    ns1:learningResultDescription "Group work skill SC13, SC14, CG17 A"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000485/2025-26/RA58> a ns1:LearningResult ;
    ns1:learningResultCode "RA58" ;
    ns1:learningResultDescription "Development of a business case for a software project"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000485/2025-26/RA59> a ns1:LearningResult ;
    ns1:learningResultCode "RA59" ;
