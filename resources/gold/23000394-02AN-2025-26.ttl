<https://guia-kg.skai.etsisi.upm.es/resource/23000394> a ns1:Course ;
    ns1:courseType "Obligatoria"@es ;
    ns1:courseYear 2 ;
    ns1:semester "Tercer semestre"@es ;
    schema:courseCode 23000394 ;
    schema:hasCourseInstance <https://guia-kg.skai.etsisi.upm.es/resource/23000394/2025-26> ;
    schema:name "Civil Works In The Garden And Gardening Equipment"@en,
        "Obra Civil y Mobiliario de Jardin"@es ;
    schema:numberOfCredits 3.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/23000394/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/23000394/2025-26/C11>,
        <https://guia-kg.skai.etsisi.upm.es/resource/23000394/2025-26/C2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/23000394/2025-26/K6>,
        <https://guia-kg.skai.etsisi.upm.es/resource/23000394/2025-26/S4> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/23000394/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/23000394/2025-26/didactic_resource/2> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/23000394/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/23000394/2025-26/RA107>,
        <https://guia-kg.skai.etsisi.upm.es/resource/23000394/2025-26/RA109> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/23000394/2025-26/syllabus> ;
    ns1:inpersonHours "43 horas (53.1%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation ""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "43 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/23000394/2025-26/eventSchedule> ;
    schema:description "La asignatura consta de varios temas relacionados con los elementos constructivos más habituales en los parques y jardines a un nivel, en general, bastante descriptivo. No obstante, se repasan conceptos propios de la resistencia de materiales y el cálculo de estructuras, en especial en el tema de muros."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/luis.ricote%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/luis.ricote%40upm.es> ;
    schema:name "Obra Civil y Mobiliario de Jardin"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000394/2025-26/C11> a ns1:Competency ;
    ns1:competencyCode "C11" ;
    ns1:competencyDescription "Capacidad de diseñar, calcular, instalar y mantener posteriormente las pequeñas obras civiles necesarias en jardinería y el equipamiento y mobiliario específicos del jardín, parque, espacio verde o césped deportivo. TIPO: Competencias."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000394/2025-26/C2> a ns1:Competency ;
    ns1:competencyCode "C2" ;
    ns1:competencyDescription "Capacidad para describir, organizar y analizar los elementos constitutivos de un problema de jardinería y paisajismo y diseñar estrategias que permitan alcanzar una solución técnica, ambiental y económicamente viable. TIPO: Competencias."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000394/2025-26/K6> a ns1:Competency ;
    ns1:competencyCode "K6" ;
    ns1:competencyDescription "Conocer las características y peculiaridades de las empresas y entidades vinculadas a las actividades de jardinería y paisajismo, y cómo organizar el trabajo en equipo y participar en las actuaciones ejecutivas y directivas. TIPO: Conocimientos o contenidos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000394/2025-26/RA107> a ns1:LearningResult ;
    ns1:learningResultCode "RA107" ;
    ns1:learningResultDescription "K6"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000394/2025-26/RA109> a ns1:LearningResult ;
    ns1:learningResultCode "RA109" ;
    ns1:learningResultDescription "S4"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000394/2025-26/S4> a ns1:Competency ;
    ns1:competencyCode "S4" ;
    ns1:competencyDescription "Habilidad de reconocer los principios éticos para la toma de decisiones en el ámbito de la jardinería y el paisajismo, conociendo y aplicando la normativa, con criterios de calidad y considerando las implicaciones sociales, de salud y seguridad, ambientales y económicas. TIPO: Habilidades o destrezas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000394/2025-26/didactic_resource/1> a ns1:DidacticResource ;
    ns1:bibliographyDescription "Normativas vigentes y libros técnicos más relevantes en cada uno de los temas, a especificar en clase."@es ;
    ns1:bibliographyTitle "Bibliografía general de construcción"@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000394/2025-26/didactic_resource/2> a ns1:DidacticResource ;
    ns1:bibliographyDescription "Para algunas de las pruebas exigidas será necesario que el estudiante realice búsquedas selectivas en la red."@es ;
    ns1:bibliographyTitle "Búsqueda de documentación técnica y comercial sobre elementos constructivos y de mobiliario de jardín relacionado con la asignatura."@es ;
    ns1:bibliographyType "Recursos web"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000394/2025-26/evaluation> a ns1:EvaluationSystem ;
    ns1:evaluationDescription "Los criterios de evaluación son aquellos que, a juicio del profesor responsable de la asignatura, le indican el nivel de consecución de competencias, habilidades y resultados de aprendizaje alcanzado por el o la estudiante."@es .

