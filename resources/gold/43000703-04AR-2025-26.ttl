    ns1:inpersonHours "54 horas y 30 minutos (46.6%)"@es ;
    ns1:numberOfCredits 4.5 ;
    ns1:otherInformation "La asignatura se relaciona con el ODS4, ODS7 y ODS12"@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "54 horas y 30 minutos"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/43000703/2025-26/eventSchedule> ;
    schema:description """El objetivo de esta asignatura es el control radiológico de la presencia de radiactividad en el medio ambiente, tanto de origen natural como la debida a la operación de las instalaciones nucleares y radiactivas.
- Detectar la presencia en el medio ambiente y vigilar la evolución de los niveles de radiación ambiental (en agua, aire suelos y dieta tipo)
- Determinar las causas de posibles incrementos de los niveles radiactivos en el medio ambiente."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/mariajose.suarez%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/araceli.martin%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/luis.pujol%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/mariajose.suarez%40upm.es> ;
    schema:name "Control de la Radiactividad Ambiental"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000703/2025-26/CE1> a ns1:Competency ;
    ns1:competencyCode "CE1" ;
    ns1:competencyDescription "Realizar estudios de los aspectos medioambientales relacionados con infraestructuras civiles TIPO: Competencias."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000703/2025-26/CE2> a ns1:Competency ;
    ns1:competencyCode "CE2" ;
    ns1:competencyDescription "Abordar y resolver problemas matemáticos avanzados de ingeniería, desde el planteamiento del problema hasta el desarrollo de la formulación y su implementación en un programa de ordenador. En particular, capacidad para formular, programar y aplicar modelos analíticos y numéricos avanzados de cálculo, planificación y gestión, así como capacidad para la interpretación de los resultados obtenidos, en el contexto de la ingeniería civil hidráulica, energética o medioambiental TIPO: Competencias."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000703/2025-26/CG4> a ns1:Competency ;
    ns1:competencyCode "CG4" ;
    ns1:competencyDescription "Liderar equipos humanos multidisciplinares, de trabajo en equipo y en contextos internacionales a través de las TICs, con capacidad de organización y planificación TIPO: Competencias."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000703/2025-26/CG5> a ns1:Competency ;
    ns1:competencyCode "CG5" ;
    ns1:competencyDescription "Buscar bibliografía, analizar la información procedente de diversas fuentes y de su análisis y síntesis aplicarla a la resolución de problemas complejos, en el campo de la ingeniería hidráulica, energética o medioambiental TIPO: Competencias."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000703/2025-26/K1> a ns1:Competency ;
    ns1:competencyCode "K1" ;
    ns1:competencyDescription "Conocer y comprender la relación de los ecosistemas con las infraestructuras civiles hidráulicas y energéticas TIPO: Conocimientos o contenidos."@es .

