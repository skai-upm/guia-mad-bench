    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/65004049/2025-26/eventSchedule> ;
    schema:description "La asignatura tiene un carácter eminentemente práctico. Como quiera que es necesario un estudio de ciertos conceptos teóricos, la asignatura se ha planificado alrededor de los sensores, sistemas de adaptación de las señales entregadas por los sensores, sistemas de procesamiento (amplificación en el caso de la electrónica analógica y de circuitos digitales, combinacionales y secuenciales, en el caso de la electrónica digital), así como los actuadores más usuales."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/pedro.alou%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/d.rios%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/pedro.alou%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/regina.ramos%40upm.es> ;
    schema:name "Instrumentacion Electronica Aplicada"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004049/2025-26/CE33> a ns1:Competency ;
    ns1:competencyCode "CE33" ;
    ns1:competencyDescription "Comprender los conceptos de la electrónica básica y su aplicación a los sistemas de control e instrumentación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004049/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Conocer y aplicar conocimientos de ciencias y tecnologías básicas a la práctica de la Ingeniería de la Energía."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004049/2025-26/CG10> a ns1:Competency ;
    ns1:competencyCode "CG10" ;
    ns1:competencyDescription "Creatividad."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004049/2025-26/CG2> a ns1:Competency ;
    ns1:competencyCode "CG2" ;
    ns1:competencyDescription "Poseer capacidad para diseñar, desarrollar, implementar, gestionar y mejorar productos, sistemas y procesos en los distintos ámbitos energéticos, usando técnicas analíticas, computacionales o experimentales apropiadas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004049/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Aplicar los conocimientos adquiridos para identificar, formular y resolver problemas dentro de contextos amplios y multidisciplinarios, siendo capaces de integrar conocimientos, trabajando en equipos multidisciplinares."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004049/2025-26/CG5> a ns1:Competency ;
    ns1:competencyCode "CG5" ;
    ns1:competencyDescription "Saber comunicar los conocimientos y conclusiones, tanto de forma oral, escrita y gráfica, a públicos especializados y no especializados de un modo claro y sin ambigüedades."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004049/2025-26/CG6> a ns1:Competency ;
    ns1:competencyCode "CG6" ;
    ns1:competencyDescription "Poseer habilidades de aprendizaje que permitan continuar estudiando a lo largo de la vida para su adecuado desarrollo profesional."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004049/2025-26/CG7> a ns1:Competency ;
    ns1:competencyCode "CG7" ;
    ns1:competencyDescription "Incorporar nuevas tecnologías y herramientas de la Ingeniería Energética en sus actividades profesionales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004049/2025-26/RA261> a ns1:LearningResult ;
    ns1:learningResultCode "RA261" ;
    ns1:learningResultDescription "Identificar la necesidad de la instrumentación electrónica en los múltiples ámbitos de aplicación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004049/2025-26/RA262> a ns1:LearningResult ;
    ns1:learningResultCode "RA262" ;
    ns1:learningResultDescription "Capacidad de valorar las ventajas e inconvenientes de los diferentes sistemas de adquisición y tratamiento de señales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004049/2025-26/RA263> a ns1:LearningResult ;
    ns1:learningResultCode "RA263" ;
    ns1:learningResultDescription "Capacidad para analizar las características de sensores comerciales y criterios de selección del sensor y método de procesamiento adecuados"@es .

