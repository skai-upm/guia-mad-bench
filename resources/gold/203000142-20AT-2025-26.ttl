<https://guia-kg.skai.etsisi.upm.es/resource/203000142/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Introducción"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000142/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Conceptos básicos: Toxicología, tóxico, toxina, intoxicación Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000142/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "4. Toxicodinamia"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000142/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "4.1. Mecanismos de acción de los tóxicos a nivel molecular Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000142/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "4.2. Mecanismos de acción de los tóxicos a nivel celular Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000142/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "4.3. Alteraciones de la división y diferenciación celular: genotoxicidad y carcinogénesis Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000142/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "4.4. Disruptores endocrinos. Inmunotoxicidad Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000142/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "5. Métodos de valoración de la toxicidad"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000142/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "5.1. Evaluación del riesgo toxicológico. Estudios de mutagénesis, carcinogénesis y efectos sobre la función reproductora. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000142/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "6. Tóxicos de origen natural"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000142/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "6.1. Sustancias antinutritivas: sustancias que interfieren con la asimilación de proteínas, carbohidratos, sales minerales y vitaminas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000142/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "6.2. Tóxicos de origen vegetal. Bociógenos. Favismo, latirismo, glicósidos cianogénicos, lectinas, alcaloides. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000142/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Hitos históricos relacionados con la Toxicología Alimentaria Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000142/2025-26/syllabus/20> a ns1:SyllabusItem ;
    ns1:itemIndex 20 ;
    ns1:syllabusDescription "6.3. Tóxicos en alimentos de origen animal. Mitilotoxinas, ictiotoxinas. Encefalopatías espongiformes transmisibles. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000142/2025-26/syllabus/21> a ns1:SyllabusItem ;
    ns1:itemIndex 21 ;
    ns1:syllabusDescription "6.4. Micotoxinas. Intoxicaciones por consumo de setas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000142/2025-26/syllabus/22> a ns1:SyllabusItem ;
    ns1:itemIndex 22 ;
    ns1:syllabusDescription "6.5. Intoxicaciones alimentarias de origen bacteriano. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000142/2025-26/syllabus/23> a ns1:SyllabusItem ;
    ns1:itemIndex 23 ;
    ns1:syllabusDescription "7. Contaminación de alimentos por residuos agrícolas e industriales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000142/2025-26/syllabus/24> a ns1:SyllabusItem ;
    ns1:itemIndex 24 ;
    ns1:syllabusDescription "7.1. Intoxicaciones por metales pesados Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000142/2025-26/syllabus/25> a ns1:SyllabusItem ;
    ns1:itemIndex 25 ;
    ns1:syllabusDescription "7.2. Presencia en alimentos de pesticidas. Presencia en alimentos de fármacos utilizados en producción animal o agrícola. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000142/2025-26/syllabus/26> a ns1:SyllabusItem ;
    ns1:itemIndex 26 ;
    ns1:syllabusDescription "8. Tóxicos formados durante el procesamiento del alimento"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000142/2025-26/syllabus/27> a ns1:SyllabusItem ;
    ns1:itemIndex 27 ;
    ns1:syllabusDescription "8.1. Hidrocarburos aromáticos policíclicos (HAP), acrilamida, nitrosaminas, aminas heterocíclicas Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000142/2025-26/syllabus/28> a ns1:SyllabusItem ;
    ns1:itemIndex 28 ;
    ns1:syllabusDescription "9. Aditivos alimentarios"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000142/2025-26/syllabus/29> a ns1:SyllabusItem ;
    ns1:itemIndex 29 ;
    ns1:syllabusDescription "9.1. Colorantes, conservantes, antioxidantes, edulcorantes y saborizantes Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000142/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "1.3. Relación dosis-efecto y dosis-respuesta. Principales parámetros toxicológicos utilizados en Toxicología Alimentaria Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000142/2025-26/syllabus/30> a ns1:SyllabusItem ;
    ns1:itemIndex 30 ;
    ns1:syllabusDescription "10. Intolerancias y alergias alimentarias"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000142/2025-26/syllabus/31> a ns1:SyllabusItem ;
    ns1:itemIndex 31 ;
    ns1:syllabusDescription "10.1. Base genética de la intolerancia. Intolerancia alimentaria a la lactosa y al gluten. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000142/2025-26/syllabus/32> a ns1:SyllabusItem ;
    ns1:itemIndex 32 ;
    ns1:syllabusDescription "10.2. Alergias alimentarias. Respuesta inmune. Alergias al melocotón y a la leche como modelos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000142/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "2. Toxicocinética I"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000142/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "2.1. Mecanismos de liberación, absorción, distribución, metabolización y acumulación de los tóxicos en el organismo. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000142/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "2.2. Eliminación de los tóxicos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000142/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "3. Toxicocinética II"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000142/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "3.1. Biotransformación de los tóxicos en el organismo. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000142/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "3.2. Toxicogenética. Sin subniveles"@es .

