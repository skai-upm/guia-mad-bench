        <https://guia-kg.skai.etsisi.upm.es/resource/103000825/2025-26/didactic_resource/7>,
        <https://guia-kg.skai.etsisi.upm.es/resource/103000825/2025-26/didactic_resource/8>,
        <https://guia-kg.skai.etsisi.upm.es/resource/103000825/2025-26/didactic_resource/9> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/103000825/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/103000825/2025-26/RA60>,
        <https://guia-kg.skai.etsisi.upm.es/resource/103000825/2025-26/RA61>,
        <https://guia-kg.skai.etsisi.upm.es/resource/103000825/2025-26/RA62> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/103000825/2025-26/syllabus> ;
    ns1:inpersonHours "41 horas (35%)"@es ;
    ns1:numberOfCredits 4.5 ;
    ns1:otherInformation "Regarding the Sustainable Developing Goals, broadly speaking, proper data analysis leads to an understanding of processes and the generation of information available to everyone. This information can help clarify and make more transparent the way in wich institutions, for instance, try to meet people's needs. This information icreases transparency, accountability and citizen participation in institutions and facilitates information-sharing between different actors. In this particular case, proper analysis of data might help in achieving SDG 16: Promote peaceful and inclusive societies for sustainable development, provide access to justice for all and build effective, accountable and inclusive institutions at all levels."@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "41 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/103000825/2025-26/eventSchedule> ;
    schema:description "The course is intended to be a non-exhaustive survey of techinques to convert multivariate data into useful information so that good decisions can be made. The perspective is twofold, theorical and applied, covering topics such as: exploratory data analysis, statistical summaries and graphical representations, dimensionality reduction, regression techniques and time series analysis. There will be an emphasis on hands-on application of the theory and methods throughout, with extensive use of R.The course is taught in four modules which are broken down in topics below and properly referenced in the timeline."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/arminda.moreno%40upm.es> ;
    schema:inLanguage "Inglés/Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/antonio.jimenez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/arminda.moreno%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/jacinto.gonzalez.pachon%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/juan.fdezpozo.salamanca%40upm.es> ;
    schema:name "Statistical Data Analysis"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000825/2025-26/CB07> a ns1:Competency ;
    ns1:competencyCode "CB07" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en entornos nuevos o poco conocidos dentro de contextos más amplios (o multidisciplinares) relacionados con su área de estudio/ To apply and integrate the acquired knowledge, its understanding , its scientific basis and abilities of problem solving in new and imprecisely defined environments, including contexts of multidisciplinary character both researchers and highly specialized professionals related to their field of study"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000825/2025-26/CB10> a ns1:Competency ;
    ns1:competencyCode "CB10" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de asumir la responsabilidad de su propio desarrollo profesional y de su especialización en uno o más campos de estudio y posean las habilidades de aprendizaje que les permitan continuar estudiando de manera autónoma/ To be able to assume responsibility for their own professional development and their specialisation in one or more fields of study and have learning skills which allow them to continue studying in an autonomous way."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000825/2025-26/CE> a ns1:Competency ;
    ns1:competencyCode "CE" ;
    ns1:competencyDescription "HMDA02"@es,
        "HMDA04"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000825/2025-26/CG03> a ns1:Competency ;
    ns1:competencyCode "CG03" ;
    ns1:competencyDescription "La capacidad de usar la lengua inglesa de manera competente, es decir, con capacitación para tareas complejas de trabajo y estudio/ The ability to use the English language in a competent way, i.e., with training for work and study complex tasks."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000825/2025-26/RA60> a ns1:LearningResult ;
    ns1:learningResultCode "RA60" ;
    ns1:learningResultDescription "To know and apply the main techniques to explore, describe and analyse multivariate data."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000825/2025-26/RA61> a ns1:LearningResult ;
    ns1:learningResultCode "RA61" ;
    ns1:learningResultDescription "To know and apply dimensionality reduction and modelization techniques to multivariate data."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000825/2025-26/RA62> a ns1:LearningResult ;
    ns1:learningResultCode "RA62" ;
    ns1:learningResultDescription "To apply the proper methodology to analyse time series."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000825/2025-26/didactic_resource/1> a ns1:DidacticResource ;
    ns1:bibliographyDescription """Main communication channel with students.
Repository: slides, scripts, data sets, other resources."""@es ;
    ns1:bibliographyTitle "Moodle"@es ;
    ns1:bibliographyType "Recursos web"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000825/2025-26/didactic_resource/10> a ns1:DidacticResource ;
    ns1:bibliographyTitle "Chatfield, C. (2003) The Analysis of Time Series: An Introduction. Chapman and Hall."@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000825/2025-26/didactic_resource/11> a ns1:DidacticResource ;
    ns1:bibliographyDescription "Bibliography and web resource. Available at https://otexts.com/fpp2/"@es ;
    ns1:bibliographyTitle "Robert Hyndman, George Athanasopoulos. Forecasting: principles and practice. OTexts, 2018."@es ;
    ns1:bibliographyType "Recursos web"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000825/2025-26/didactic_resource/12> a ns1:DidacticResource ;
    ns1:bibliographyDescription "Excelent set of tips to fit ARIMA models. Available at https://people.duke.edu/~rnau/411home.htm"@es ;
    ns1:bibliographyTitle "Robert Nau. Statistical forecasting: notes on regression and time series analysis."@es ;
    ns1:bibliographyType "Recursos web"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000825/2025-26/didactic_resource/2> a ns1:DidacticResource ;
    ns1:bibliographyDescription "Friendly exposition of the most important multivariate techiques, including clustering. They also introduce other Artificial Intelligence techniques like neural networks."@es ;
    ns1:bibliographyTitle "Johnson, R.A., Whichern, D.W. (2007) Applied Multivariate Statistical Analysis. Pearson Education."@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000825/2025-26/didactic_resource/3> a ns1:DidacticResource ;
    ns1:bibliographyDescription "Clear exposition of Multivariate Analysis Techniques, from a statistical point of view. Many examples."@es ;
    ns1:bibliographyTitle "Rencher, A.C. Methods of Multivariate Analysis."@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000825/2025-26/didactic_resource/4> a ns1:DidacticResource ;
    ns1:bibliographyDescription "Excellent exposition of multivariate techniques. They make the Generalised Linear Model easily understandable."@es ;
    ns1:bibliographyTitle "Everitt, B.S. and Dunn G. (1997) Applied Multivariate Data Analysis. Arnold."@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000825/2025-26/didactic_resource/5> a ns1:DidacticResource ;
    ns1:bibliographyDescription "A Global Perspective on multivariate Techniques. Very detailed examples. In almost every topic, a \"Rules of Thumb\" section summarizes the relevant facts."@es ;
    ns1:bibliographyTitle "Hair, J.F., Black, W.C., Babin, B.J., Anderson R.E. Multivariate Data Analysis."@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000825/2025-26/didactic_resource/6> a ns1:DidacticResource ;
    ns1:bibliographyTitle "Sharma, S (1996). Applied Multivariate Techniques. Wiley."@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000825/2025-26/didactic_resource/7> a ns1:DidacticResource ;
    ns1:bibliographyDescription """http://www.fbbva.es/TLFU/tlfu/esp/publicaciones/libros/fichalibro/index.jsp?codigo=769

Excellent compilation and description of multivariate techniques applied to Ecological Data. Clear, educational, didactic explanations. Lots of examples"""@es ;
    ns1:bibliographyTitle "Multivariate Analysis of Ecological Data. Greenacre, Primicerio. Fundación BBVA."@es ;
    ns1:bibliographyType "Recursos web"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000825/2025-26/didactic_resource/8> a ns1:DidacticResource ;
    ns1:bibliographyDescription """http://www.multivariatestatistics.org/biplots.html

Excellent Monograph on Biplots."""@es ;
    ns1:bibliographyTitle "Biplots in Practice. Michael Greenacre. Fundación BBVA."@es ;
    ns1:bibliographyType "Recursos web"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000825/2025-26/didactic_resource/9> a ns1:DidacticResource ;
    ns1:bibliographyDescription "Almost everything about Regression Models."@es ;
    ns1:bibliographyTitle "Rawlings, J.O., Pantula, S.G., Dickey, D.A. Applied Regression Analysis."@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000825/2025-26/evaluation> a ns1:EvaluationSystem ;
    ns1:evaluationDescription """Progressive evaluation:
The overall course grade will be based on the performance on 4 exams, equally weighed, corresponding to each of the modules taught. The weeks in which each exam is scheduled might change depending on the academic calendar.
Each exam should obtain a grade equal or greater than 3 (0-10 scale) for the overall course grade to be computed. The overall course grade will be the average of the grades obtined in the 4 exams and it must be equal or greater than 5 to pass the course.
No makeup exams will be scheduled.
January exam:
As far as exams are concerned, the final exam in January is only for those failing to take the midterms when requested or those obtaining an overall grade less than 5. In the latter case, only those specific exams not previuosly passed have to be taken again.
Extraordinary exam:
In case you are opting for the extraordinary exam in July's session, you have to warn the instructor(s) in advance (at least two weeks before the exam, by email, but the sooner the better). If you have taken some of the exams on the ordinary session and obtained a grade grater or equal than 3, these grades can be kept and no repetition of these exams is required. Otherwise, all 4 exams can be taken in this opportunity."""@es .

