<https://guia-kg.skai.etsisi.upm.es/resource/65001043/2025-26/CG%201> a ns1:Competency ;
    ns1:competencyCode "CG 1" ;
    ns1:competencyDescription "Conocer y aplicar conocimientos de ciencias y tecnologías básicas a la práctica de la Tecnología Minera."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001043/2025-26/CG%202> a ns1:Competency ;
    ns1:competencyCode "CG 2" ;
    ns1:competencyDescription "Poseer capacidad para diseñar, analizar, calcular, proyectar, construir, mantener, conservar, explotar, desarrollar, implementar, gestionar y mejorar productos, sistemas y procesos en los distintos ámbitos de las Tecnologías Mineras, usando técnicas analíticas, computacionales o experimentales apropiadas, incluyendo la función de asesoría en estos campos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001043/2025-26/CG%203> a ns1:Competency ;
    ns1:competencyCode "CG 3" ;
    ns1:competencyDescription "Aplicar los conocimientos adquiridos para identificar, formular y resolver problemas dentro de contextos amplios y multidisciplinarios, siendo capaces de integrar conocimientos, trabajando en equipos multidisciplinares."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001043/2025-26/CG%204> a ns1:Competency ;
    ns1:competencyCode "CG 4" ;
    ns1:competencyDescription "Comprender el impacto de la tecnología minera en el medio ambiente, el desarrollo sostenible de la sociedad. desarrollando la capacidad para la realización de estudios de ordenación del territorio y de los aspectos medioambientales relacionados con los proyectos, plantas e instalaciones, en su ámbito"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001043/2025-26/CG%205> a ns1:Competency ;
    ns1:competencyCode "CG 5" ;
    ns1:competencyDescription "Saber comunicar los conocimientos y conclusiones, tanto de forma oral, escrita y gráfica, a públicos especializados y no especializados de un modo claro y sin ambigüedades."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001043/2025-26/CG%206> a ns1:Competency ;
    ns1:competencyCode "CG 6" ;
    ns1:competencyDescription "Poseer habilidades de aprendizaje que permitan continuar estudiando a lo largo de la vida para su adecuado desarrollo profesional"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001043/2025-26/CG%207> a ns1:Competency ;
    ns1:competencyCode "CG 7" ;
    ns1:competencyDescription "Incorporar nuevas tecnologías y herramientas de la ingeniería en tecnología minera en sus actividades profesionales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001043/2025-26/F37> a ns1:Competency ;
    ns1:competencyCode "F37" ;
    ns1:competencyDescription "Metalurgia y tratamiento de concentrados minerales, metales y aleaciones: Industria metalurgia férrea y no férrea, aleaciones especiales, ensayos metalotécnicos, etc"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001043/2025-26/RA207> a ns1:LearningResult ;
    ns1:learningResultCode "RA207" ;
    ns1:learningResultDescription "Capacidad de conocer, comprender y utilizar los principios y metodología de la metalurgia no férrea."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001043/2025-26/RA208> a ns1:LearningResult ;
    ns1:learningResultCode "RA208" ;
    ns1:learningResultDescription "Capacidad de conocer, comprender y utilizar los principios y metodología de la siderurgia."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001043/2025-26/RA209> a ns1:LearningResult ;
    ns1:learningResultCode "RA209" ;
    ns1:learningResultDescription "Comprender las leyes y fenómenos básicos de la ciencia e ingeniería metalúrgica primaria y secundaria tanto en vía hidro como pirometalúrgica, sus rasgos comunes y diferenciales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001043/2025-26/RA210> a ns1:LearningResult ;
    ns1:learningResultCode "RA210" ;
    ns1:learningResultDescription "Comprender y seleccionar con criterios de usuarios el comportamiento de los concentrados metálicos en relación con los procesos extractivos y los metales obtenidos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001043/2025-26/RA211> a ns1:LearningResult ;
    ns1:learningResultCode "RA211" ;
    ns1:learningResultDescription "Comprender la relación entre la tipología de un yacimiento, las características mineralógicas y los distintos procesos de aplicación posibles para la extracción económica del metal, bien a través de la mineralurgia o directamente."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001043/2025-26/RA212> a ns1:LearningResult ;
    ns1:learningResultCode "RA212" ;
    ns1:learningResultDescription "Practicar el cálculo metalúrgico en diversos supuestos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001043/2025-26/RA213> a ns1:LearningResult ;
    ns1:learningResultCode "RA213" ;
    ns1:learningResultDescription "Conocer los aspectos económicos, de calidad y medioambientales de la metalurgia extractiva y sus particularidades en la siderurgia."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001043/2025-26/RA247> a ns1:LearningResult ;
    ns1:learningResultCode "RA247" ;
    ns1:learningResultDescription "Conocer las distintas familias de materiales no metálicos, sus propiedades y obtención Aplicar los fundamentos del análisis de secciones en vigas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001043/2025-26/RA248> a ns1:LearningResult ;
    ns1:learningResultCode "RA248" ;
    ns1:learningResultDescription "Relacionar las características de los diferentes tipos de materiales no metálicos con sus propiedades y método de obtención."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001043/2025-26/RA249> a ns1:LearningResult ;
    ns1:learningResultCode "RA249" ;
    ns1:learningResultDescription "Aplicar los diferentes materiales no metálicos a sus distintos usos."@es .

