    schema:name "Mecánica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85004314/2025-26/CB1> a ns1:Competency ;
    ns1:competencyCode "CB1" ;
    ns1:competencyDescription "Que los estudiantes hayan demostrado poseer y comprender conocimientos en un área de estudio que parte de la base de la educación secundaria general, y se suele encontrar a un nivel que, si bien se apoya en libros de texto avanzados, incluye también algunos aspectos que implican conocimientos procedentes de la vanguardia de su campo de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85004314/2025-26/CB5> a ns1:Competency ;
    ns1:competencyCode "CB5" ;
    ns1:competencyDescription "Que los estudiantes hayan desarrollado aquellas habilidades de aprendizaje necesarias para emprender estudios posteriores con un alto grado de autonomía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85004314/2025-26/CE13> a ns1:Competency ;
    ns1:competencyCode "CE13" ;
    ns1:competencyDescription "Conocimiento de la mecánica y de los componentes de maquinas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85004314/2025-26/CE16> a ns1:Competency ;
    ns1:competencyCode "CE16" ;
    ns1:competencyDescription "Capacidad para la realización del cálculo y control de vibraciones y ruidos a bordo de buques y artefactos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85004314/2025-26/CE2> a ns1:Competency ;
    ns1:competencyCode "CE2" ;
    ns1:competencyDescription "Comprensión y dominio de los conceptos básicos sobre las leyes generales de la mecánica, termodinámica, campos y ondas y electromagnetismo y su aplicación para la resolución de problemas propios de la ingeniería"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85004314/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Capacidad para el aprendizaje de nuevos métodos y teorías, y en la versatilidad para adaptarse a nuevas situaciones basándose en los conocimientos adquiridos en materias básicas y tecnológicas propias de la Ingeniería Marítima."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85004314/2025-26/RA1> a ns1:LearningResult ;
    ns1:learningResultCode "RA1" ;
    ns1:learningResultDescription "Resolver problemas de mecánica, mecánica de fluidos, oscilaciones y ondas relacionados con la ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85004314/2025-26/RA2> a ns1:LearningResult ;
    ns1:learningResultCode "RA2" ;
    ns1:learningResultDescription "Conocer el significado y las unidades de las magnitudes físicas, así como su orden de magnitud y resolver problemas básicos de ingeniería, expresando el resultado numérico en las unidades físicas correspondientes."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85004314/2025-26/RA27> a ns1:LearningResult ;
    ns1:learningResultCode "RA27" ;
    ns1:learningResultDescription "Conocer el significado y las unidades de las magnitudes físicas, así como su orden de magnitud y resolver problemas básicos de ingeniería, expresando el resultado numérico en las unidades físicas adecuadas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85004314/2025-26/RA5> a ns1:LearningResult ;
    ns1:learningResultCode "RA5" ;
    ns1:learningResultDescription "Conocer las definiciones de las variables cinemáticas y aplicarlas a la resolución de movimientos de partículas y sistemas de partículas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85004314/2025-26/RA6> a ns1:LearningResult ;
    ns1:learningResultCode "RA6" ;
    ns1:learningResultDescription "Comprender y aplicar los teoremas de conservación de la Mecánica a sistemas de partículas."@es .

