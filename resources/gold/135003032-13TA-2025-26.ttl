<https://guia-kg.skai.etsisi.upm.es/resource/135003032> a ns1:Course ;
    ns1:courseType "Obligatoria"@es ;
    ns1:courseYear 3 ;
    ns1:semester "Sexto semestre"@es ;
    schema:courseCode 135003032 ;
    schema:hasCourseInstance <https://guia-kg.skai.etsisi.upm.es/resource/135003032/2025-26> ;
    schema:name "Environmental Economics"@en,
        "Economia Ambiental"@es ;
    schema:numberOfCredits 6.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/135003032/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/135003032/2025-26/CE23> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/135003032/2025-26/didactic_resource/1> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/135003032/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/135003032/2025-26/RA173>,
        <https://guia-kg.skai.etsisi.upm.es/resource/135003032/2025-26/RA180>,
        <https://guia-kg.skai.etsisi.upm.es/resource/135003032/2025-26/RA181>,
        <https://guia-kg.skai.etsisi.upm.es/resource/135003032/2025-26/RA69>,
        <https://guia-kg.skai.etsisi.upm.es/resource/135003032/2025-26/RA70> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/135003032/2025-26/syllabus> ;
    ns1:inpersonHours "60 horas (38.5%)"@es ;
    ns1:numberOfCredits 6.0 ;
    ns1:otherInformation """Esta asignatura está relacionada con los ODS 7, 9 y 12.
La asignatura está prevista impartirse en el segundo semestre de forma presencial, pero si la situación sanitaria lo exigiera se podría pasar a una enseñanza por tele enseñanza replanificando la guía con las correspondientes adendas.
LAS COMPETENCIAS Y LOS RESULTADOS DE APRENDIZAJE DE ESTA ASIGNATURA SON LOS ACORDES CON LA MEMORIA VERIFICA DEL TÍTULO"""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "60 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/135003032/2025-26/eventSchedule> ;
    schema:description """La asignatura pretende establecer los vínculos entre el medio natural y el sistema económico, con el propósito básico de establecer los fundamentos de una gestión sostenible del medio natural. Los temas a tratar son los siguientes:
Bloque de Introducción a la Ec General
Conceptos introductorios para el estudio de la Economía Ambiental
Gestión óptima de los recursos no renovables
Gestión óptima de los recursos renovables
Política económica ambiental : fallos de mercado y bienes públicos
Valoración de bienes y servicios ambientales"""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/sigfredo.ortuno%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/juan.teson%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/sigfredo.ortuno%40upm.es> ;
    schema:name "Economia Ambiental"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003032/2025-26/CE23> a ns1:Competency ;
    ns1:competencyCode "CE23" ;
    ns1:competencyDescription "Conocer los principios de la Economía Ambiental y las políticas internacionales, nacionales y autonómicas en materia de legislación ambiental"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003032/2025-26/RA173> a ns1:LearningResult ;
    ns1:learningResultCode "RA173" ;
    ns1:learningResultDescription "Elaborar informes técnicos, memorias de reconocimiento, valoraciones, peritajes y tasaciones, así como diseñar y aplicar proyectos y planes técnicos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003032/2025-26/RA180> a ns1:LearningResult ;
    ns1:learningResultCode "RA180" ;
    ns1:learningResultDescription "Proporcionar unos conocimientos básicos que posibiliten la comprensión de los mecanismos de funcionamiento del sistema económico en general y de su interacción con el medio natural en particular."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003032/2025-26/RA181> a ns1:LearningResult ;
    ns1:learningResultCode "RA181" ;
    ns1:learningResultDescription "Proporcionar unos conocimientos básicos que posibiliten la capacidad para el diseño, elaboración y desarrollo de políticas ambientales a escala internacional, estatal y autonómica."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003032/2025-26/RA69> a ns1:LearningResult ;
    ns1:learningResultCode "RA69" ;
    ns1:learningResultDescription "Entender principios y objetivos de las diferentes teorías de la economía Ambiental"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003032/2025-26/RA70> a ns1:LearningResult ;
    ns1:learningResultCode "RA70" ;
    ns1:learningResultDescription "Capacidad para realizar una valoración económica de bienes, servicios y costes ambientales"@es .

