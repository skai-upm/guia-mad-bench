    ns1:numberOfCredits 6.0 ;
    ns1:otherInformation "La asignatura se relaciona con el ODS4: \"Garantizar una educación inclusiva, equitativa y de calidad y promover oportunidades de aprendizaje durante toda la vida para todos\"."@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "65 horas y 30 minutos"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/95000312/2025-26/eventSchedule> ;
    schema:description "Esta asignatura está dividida en dos partes diferenciadas: análisis complejo y ecuaciones en derivadas parciales. En la primera parte de la asignatura se estudian y analizan los principales conceptos y propiedades de las funciones de una variable compleja, incidiendo en la adquisición de habilidades que permitan manejar adecuadamente los números y las funciones complejas más importantes en Ingeniería Biomédica. La segunda parte de la asignatura está dedicada al estudio de las ecuaciones diferenciales en derivadas parciales con lo que, partiendo de las ecuaciones diferenciales ordinarias que el alumno ya ha estudiado en primer curso, nos centraremos en aquellas que usualmente aparecen en el modelado de problemas relacionados con la Ingeniería Biomédica."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/carmen.sanchez.avila%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/carmen.sanchez.avila%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/mariaisabel.decorcuera%40upm.es> ;
    schema:name "Métodos Matemáticos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000312/2025-26/CE01> a ns1:Competency ;
    ns1:competencyCode "CE01" ;
    ns1:competencyDescription "Saber resolver problemas de ingeniería utilizando cálculo diferencial, las ecuaciones diferenciales, el cálculo integral, el álgebra lineal y la geometría. Aplicación al plano complejo y métodos de transformación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000312/2025-26/CG07> a ns1:Competency ;
    ns1:competencyCode "CG07" ;
    ns1:competencyDescription "Ser capaz de utilizar el método científico."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000312/2025-26/CG09> a ns1:Competency ;
    ns1:competencyCode "CG09" ;
    ns1:competencyDescription "Tener capacidad de descripción, cuantificación, análisis y evaluación de resultados experimentales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000312/2025-26/CG11> a ns1:Competency ;
    ns1:competencyCode "CG11" ;
    ns1:competencyDescription "Elaborar y defender argumentos y resolver los problemas de forma efectiva y creativa."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000312/2025-26/RA131> a ns1:LearningResult ;
    ns1:learningResultCode "RA131" ;
    ns1:learningResultDescription "Reconocer la importancia del razonamiento abstracto y la necesidad de trasladar los problemas de ingeniería a formulaciones matemáticas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000312/2025-26/RA268> a ns1:LearningResult ;
    ns1:learningResultCode "RA268" ;
    ns1:learningResultDescription "Habilidad para manejar correctamente los números complejos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000312/2025-26/RA269> a ns1:LearningResult ;
    ns1:learningResultCode "RA269" ;
    ns1:learningResultDescription "Habilidades para transformar supuestos prácticos experimentales en problemas matemáticos resolubles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000312/2025-26/RA270> a ns1:LearningResult ;
    ns1:learningResultCode "RA270" ;
    ns1:learningResultDescription "Ser capaz de formalizar y analizar matemáticamente problemas científico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000312/2025-26/RA271> a ns1:LearningResult ;
    ns1:learningResultCode "RA271" ;
    ns1:learningResultDescription "Conocer y aplicar las propiedades fundamentales de las funciones de variable compleja y habilidad para manejarlas correctamente"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000312/2025-26/RA272> a ns1:LearningResult ;
    ns1:learningResultCode "RA272" ;
    ns1:learningResultDescription "Conocer la teoría de Cauchy sobre integrales complejas y adquirir habilidad para su resolución"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000312/2025-26/RA273> a ns1:LearningResult ;
    ns1:learningResultCode "RA273" ;
    ns1:learningResultDescription "Conocer las propiedades fundamentales de las series complejas y saber manejarlas adecuadamente"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000312/2025-26/RA274> a ns1:LearningResult ;
    ns1:learningResultCode "RA274" ;
    ns1:learningResultDescription "Conocer las principales propiedades de la transformada de Laplace y adquirir habilidad para aplicarlas en problemas de ingeniería"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000312/2025-26/RA275> a ns1:LearningResult ;
    ns1:learningResultCode "RA275" ;
    ns1:learningResultDescription "Conocer y saber aplicar la teoría de residuos complejos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000312/2025-26/RA276> a ns1:LearningResult ;
    ns1:learningResultCode "RA276" ;
    ns1:learningResultDescription "Formular problemas de ingeniería mediante modelos de ecuaciones diferenciales o en derivadas parciales y saber obtener su solución"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000312/2025-26/RA4> a ns1:LearningResult ;
    ns1:learningResultCode "RA4" ;
    ns1:learningResultDescription "Capacidad de emplear con rigor el lenguaje matemático."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000312/2025-26/RA82> a ns1:LearningResult ;
    ns1:learningResultCode "RA82" ;
    ns1:learningResultDescription "Resolución de problemas de álgebra lineal, cálculo diferencial e integral, ecuaciones diferenciales y métodos numéricos"@es .

