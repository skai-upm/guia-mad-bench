    ns1:otherInformation """Esta asignatura está relacionada con los ODS 1, ODS 3, ODS 4, ODS 5, ODS 6, ODS 7, ODS 8, ODS 9, OS 10,
ODS 11, ODS 12, ODS 14, ODS 15, ODS 16 y ODS 17."""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
