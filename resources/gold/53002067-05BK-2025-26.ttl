<https://guia-kg.skai.etsisi.upm.es/resource/53002067/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/53002067/2025-26/CB7>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53002067/2025-26/CB8>,
