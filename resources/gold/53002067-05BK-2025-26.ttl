    ns1:syllabusDescription "1. Introduction Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002067/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "2. Review of themodynamics of closed systems. Concept of Exergy Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002067/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "3. Review of thermodynamics of open systems. Flow exergy. Coefficients of structural bonds. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002067/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "4. Method of exergoeconomic optimisation. Relation between design and operation parameters and process behaviour. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002067/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "5. Economic parameters in industrial processes: discount factor, LCOE, NPV, IRR. Sin subniveles"@es .

