        <https://guia-kg.skai.etsisi.upm.es/resource/53001575/2025-26/CG07>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001575/2025-26/CT02>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001575/2025-26/CT05> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/53001575/2025-26/didactic_resource/1>,
