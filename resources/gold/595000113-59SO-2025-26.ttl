<https://guia-kg.skai.etsisi.upm.es/resource/595000113/2025-26/CE%20B1> a ns1:Competency ;
    ns1:competencyCode "CE B1" ;
    ns1:competencyDescription "Capacidad para la resolución de los problemas matemáticos que puedan plantearse en la ingeniería. Aptitud para aplicar los conocimientos sobre: álgebra lineal; geometría; geometría diferencial; cálculo diferencial e integral; ecuaciones diferenciales y en derivadas parciales; métodos numéricos; algorítmica numérica; estadística y optimización."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000113/2025-26/CG%2002> a ns1:Competency ;
    ns1:competencyCode "CG 02" ;
    ns1:competencyDescription "Capacidad de búsqueda y selección de información, de razonamiento crítico y de elaboración y defensa de argumentos dentro del área."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000113/2025-26/CG%2003> a ns1:Competency ;
    ns1:competencyCode "CG 03" ;
    ns1:competencyDescription "Capacidad para expresarse correctamente de forma oral y escrita y transmitir información mediante documentos y exposiciones en público."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000113/2025-26/CG%2004> a ns1:Competency ;
    ns1:competencyCode "CG 04" ;
    ns1:competencyDescription "Capacidad de abstracción, de análisis y de síntesis y de resolución de problemas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000113/2025-26/CG%2011> a ns1:Competency ;
    ns1:competencyCode "CG 11" ;
    ns1:competencyDescription "Habilidades para la utilización de las Tecnologías de la Información y las Comunicaciones."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000113/2025-26/RA1047> a ns1:LearningResult ;
    ns1:learningResultCode "RA1047" ;
    ns1:learningResultDescription "Aplicar las técnicas y modelos probabilísticos a la resolución de problemas en telecomunicación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000113/2025-26/RA1049> a ns1:LearningResult ;
    ns1:learningResultCode "RA1049" ;
    ns1:learningResultDescription "Comprender el concepto de probabilidad, conocer sus propiedades y aplicar los teoremas fundamentales del cálculo de probabilidades."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000113/2025-26/RA1050> a ns1:LearningResult ;
    ns1:learningResultCode "RA1050" ;
    ns1:learningResultDescription "Comprender los conceptos de variable aleatoria y distribución de probabilidad asociada"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000113/2025-26/RA1051> a ns1:LearningResult ;
    ns1:learningResultCode "RA1051" ;
    ns1:learningResultDescription "Calcular probabilidades y momentos de variables aleatorias discretas. Conocer y aplicar los modelos binomial, geométrica, binomial negativa y de Poisson"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000113/2025-26/RA1052> a ns1:LearningResult ;
    ns1:learningResultCode "RA1052" ;
    ns1:learningResultDescription "Calcular probabilidades y momentos de variables aleatorias continuas. Conocer y aplicar los modelos uniforme, normal y exponencial"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000113/2025-26/RA1053> a ns1:LearningResult ;
    ns1:learningResultCode "RA1053" ;
    ns1:learningResultDescription "Comprender los conceptos de variable aleatoria multidimensional y distribución de probabilidad asociada"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000113/2025-26/RA1054> a ns1:LearningResult ;
    ns1:learningResultCode "RA1054" ;
    ns1:learningResultDescription "Calcular distribuciones marginales y condicionadas. Calcular probabilidades y momentos de variables aleatorias multidimensionales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000113/2025-26/RA1055> a ns1:LearningResult ;
    ns1:learningResultCode "RA1055" ;
    ns1:learningResultDescription "Comprender y aplicar la independencia de variables aleatorias"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000113/2025-26/RA1056> a ns1:LearningResult ;
    ns1:learningResultCode "RA1056" ;
    ns1:learningResultDescription "Calcular la distribución de una función de una o varias variable aleatorias independientes."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000113/2025-26/RA1057> a ns1:LearningResult ;
    ns1:learningResultCode "RA1057" ;
    ns1:learningResultDescription "Conocer y aplicar el modelo normal multidimensional"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000113/2025-26/RA1058> a ns1:LearningResult ;
    ns1:learningResultCode "RA1058" ;
    ns1:learningResultDescription "Conocer los principales estadísticos muestrales y su distribución en el muestreo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000113/2025-26/RA1059> a ns1:LearningResult ;
    ns1:learningResultCode "RA1059" ;
    ns1:learningResultDescription "Obtener información sobre la ley de probabilidades que rige un fenómeno aleatorio a partir de observaciones del mismo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000113/2025-26/RA1060> a ns1:LearningResult ;
    ns1:learningResultCode "RA1060" ;
    ns1:learningResultDescription "Conocer las nociones básicas de procesos estocásticos. Caracterizar procesos estacionarios. Calcular la media, autocorrelación y densidad espectral de un proceso"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000113/2025-26/RA1061> a ns1:LearningResult ;
    ns1:learningResultCode "RA1061" ;
    ns1:learningResultDescription "Conocer y aplicar los procesos de Poisson y normal"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000113/2025-26/RA11> a ns1:LearningResult ;
    ns1:learningResultCode "RA11" ;
    ns1:learningResultDescription "Aplicar las herramientas con las que se pueden tratar sistemas en los que aparecen señales en presencia de incertidumbre."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000113/2025-26/RA12> a ns1:LearningResult ;
    ns1:learningResultCode "RA12" ;
    ns1:learningResultDescription "Manejar las herramientas numéricas y gráficas del análisis de datos estadísticos"@es .

