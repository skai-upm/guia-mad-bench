        <https://guia-kg.skai.etsisi.upm.es/resource/53002005/2025-26/CT1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53002005/2025-26/CT14>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53002005/2025-26/CT3>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53002005/2025-26/CT8> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/53002005/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53002005/2025-26/didactic_resource/2> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/53002005/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/53002005/2025-26/RA11>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53002005/2025-26/RA12> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/53002005/2025-26/syllabus> ;
    ns1:inpersonHours "27 horas y 30 minutos (35.3%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation """The subject relates to SDG7 and SDG12, in the framework of efforts to combat climate change and the implementation of clean and sustainable energy systems.

A visit to the CiudadEnergía facilities is planned, as a complement to the Master Battery business case."""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "30 horas y 10 minutos"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/53002005/2025-26/eventSchedule> ;
    schema:description """This subject is linked to the sustainable development goals SDG7, on clean and affordable energy.

In this sense, the aim of this subject is to understand the integration of energy storage systems in the system according to the different scenarios of energy demand and generation, to understand the storage technologies available on the market and potentially available in the short-medium term, and to dimension storage systems for cases in industry and at the domestic level. An important part is the estimation of the technical and economic feasibility of the available storage systems."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/alberto.abanades%40upm.es> ;
    schema:inLanguage "Inglés"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/alberto.abanades%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/elisa.alonso%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/mathieu.legrand%40upm.es> ;
    schema:name "Energy Storage"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002005/2025-26/CB6> a ns1:Competency ;
    ns1:competencyCode "CB6" ;
    ns1:competencyDescription "Poseer y comprender conocimientos que aporten una base u oportunidad de ser originales en el desarrollo y/o aplicación de ideas, a menudo en un contexto de investigación/ Students have demonstrated knowledge and understanding providing the groundwork or opportunity for innovation in developing and/or applying ideas, often within a research context"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002005/2025-26/CB7> a ns1:Competency ;
    ns1:competencyCode "CB7" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en entornos nuevos o poco conocidos dentro de contextos más amplios (o multidisciplinares) relacionados con su área de estudio/ Students are capable of applying their knowledge, understanding, and problem"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002005/2025-26/CB9> a ns1:Competency ;
    ns1:competencyCode "CB9" ;
    ns1:competencyDescription "Que los estudiantes sepan comunicar sus conclusiones y los conocimientos y razones últimas que las sustentan a públicos especializados y no especializados de un modo claro y sin ambigüedades/ Students are capable of clearly and unambiguously communicating their conclusions, and the underlying knowledge and rationale to specialist and non"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002005/2025-26/CE10> a ns1:Competency ;
    ns1:competencyCode "CE10" ;
    ns1:competencyDescription "Evaluar el potencial energético de las fuentes de energía renovable: radiación solar, recurso eólico, recurso hidráulico, potencial energético de la biomasa, recurso energético marino, geotérmico, etc.; a partir de las bases de datos meteorológicas y recursos naturales./ Evaluate the energy potential of renewable energy sources: solar radiation, wind resource, hydraulic resource, energy potential of biomass, marine energy resource, geothermal, etc .; from meteorological databases and natural resources."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002005/2025-26/CE17> a ns1:Competency ;
    ns1:competencyCode "CE17" ;
    ns1:competencyDescription "Comprender los procesos que integran el ciclo de vida de los procesos energéticos, desde la obtención del recurso primario, hasta su desmantelamiento, y su integración en la economía circular./ Understand the processes that make up the life cycle of energy processes, from obtaining the primary resource, to its dismantling, and its integration into the circular economy."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002005/2025-26/CE3> a ns1:Competency ;
    ns1:competencyCode "CE3" ;
    ns1:competencyDescription "Utilizar las herramientas necesarias para el diseño y análisis de sistemas de generación, trasformación, almacenamiento y utilización de energías nucleares, mecánicas, eléctricas, térmicas e hidráulicas./ Use the necessary tools for the design and analysis of systems for the generation, transformation, storage and use of nuclear, mechanical, electrical, thermal and hydraulic energies."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002005/2025-26/CE7> a ns1:Competency ;
    ns1:competencyCode "CE7" ;
    ns1:competencyDescription "Conocer y aplicar las alternativas para la operación segura de instalaciones energéticas, tanto renovables, como no renovables, y de transformación de vectores energéticos, como refinerías o biorrefinerías/ Know and apply the alternatives for the safe operation of energy facilities, both renewable and non"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002005/2025-26/CE8> a ns1:Competency ;
    ns1:competencyCode "CE8" ;
    ns1:competencyDescription "Disponer de habilidades, criterios y conocimientos para investigar, desarrollar e innovar en el campo de la energía: tecnologías renovables y no renovables, almacenamiento, vectores energéticos, en un contexto de decarbonización del sistema./ Skills, criteria and knowledge to research, develop and innovate in the field of energy: renewable and non"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002005/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Aplicar conocimientos de ciencias y tecnologías avanzadas a la práctica profesional o investigadora de la Ingeniería Energética./ Apply knowledge of advanced science and technology to the professional or research practice of Energy Engineering."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002005/2025-26/CG5> a ns1:Competency ;
    ns1:competencyCode "CG5" ;
    ns1:competencyDescription "Comprender el impacto de la Ingeniería Energética en el medio ambiente, el desarrollo sostenible de la sociedad y la importancia de trabajar en un entorno profesional y responsable./ Understand the impact of Energy Engineering on the environment, the sustainable development of society and the importance of working in a professional and responsible environment."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002005/2025-26/CG8> a ns1:Competency ;
    ns1:competencyCode "CG8" ;
    ns1:competencyDescription "Incorporar nuevas tecnologías y herramientas avanzadas de la Ingeniería Energética en sus actividades profesionales o investigadoras./ Incorporate new technologies and advanced tools of Energy Engineering in their professional or research activities."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002005/2025-26/CT1> a ns1:Competency ;
    ns1:competencyCode "CT1" ;
    ns1:competencyDescription "Aplica. Habilidad para aplicar conocimientos científicos, matemáticos y tecnológicos en sistemas relacionados con la práctica de la ingeniería./ Apply. Ability to apply scientific, mathematical and technological knowledge in systems related to the practice of engineering."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002005/2025-26/CT14> a ns1:Competency ;
    ns1:competencyCode "CT14" ;
    ns1:competencyDescription "Idea. Creatividad./ Idea. Creativity."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002005/2025-26/CT3> a ns1:Competency ;
    ns1:competencyCode "CT3" ;
    ns1:competencyDescription "Diseña. Habilidad para diseñar un sistema, componente o proceso que alcance los requisitos deseados teniendo en cuenta restricciones realistas tales como las económicas, medioambientales, sociales, políticas, éticas, de salud y seguridad, de fabricación y de sostenibilidad./ Design. Ability to design a system, component or process that meets the desired requirements taking into account realistic constraints such as economic, environmental, social, political, ethical, health and safety, manufacturing and sustainability."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002005/2025-26/CT8> a ns1:Competency ;
    ns1:competencyCode "CT8" ;
    ns1:competencyDescription "Entiende los impactos. Educación amplia necesaria para entender el impacto de las soluciones ingenieriles en un contexto social global./ Understand the impacts. Broad education to understand the impact of engineering solutions in a global social context."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002005/2025-26/RA11> a ns1:LearningResult ;
    ns1:learningResultCode "RA11" ;
    ns1:learningResultDescription "Conocimiento y habilidades de integración de sistemas de almacenamiento térmico en sistemas energéticos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002005/2025-26/RA12> a ns1:LearningResult ;
    ns1:learningResultCode "RA12" ;
    ns1:learningResultDescription "Conocimientos y habilidades de cálculo y diseño de sistemas de almacenamiento térmico y eléctrico."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002005/2025-26/didactic_resource/1> a ns1:DidacticResource ;
    ns1:bibliographyDescription "Visit to an external storage facility"@es ;
    ns1:bibliographyTitle "Visit"@es ;
    ns1:bibliographyType "Otros"@es .

