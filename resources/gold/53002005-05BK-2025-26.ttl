    schema:courseCode 53002005 ;
    schema:hasCourseInstance <https://guia-kg.skai.etsisi.upm.es/resource/53002005/2025-26> ;
    schema:name "Almacenamiento de Energía"@en,
        "Energy Storage"@es ;
    schema:numberOfCredits 3.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/53002005/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/53002005/2025-26/CB6>,
