        <https://guia-kg.skai.etsisi.upm.es/resource/pedro.mora%40upm.es> ;
    schema:name "Seguridad e Higiene"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001022/2025-26/CG%201> a ns1:Competency ;
    ns1:competencyCode "CG 1" ;
    ns1:competencyDescription "Conocer y aplicar conocimientos de ciencias y tecnologías básicas a la práctica de la Tecnología Minera."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001022/2025-26/CG%202> a ns1:Competency ;
    ns1:competencyCode "CG 2" ;
    ns1:competencyDescription "Poseer capacidad para diseñar, analizar, calcular, proyectar, construir, mantener, conservar, explotar, desarrollar, implementar, gestionar y mejorar productos, sistemas y procesos en los distintos ámbitos de las Tecnologías Mineras, usando técnicas analíticas, computacionales o experimentales apropiadas, incluyendo la función de asesoría en estos campos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001022/2025-26/CG%203> a ns1:Competency ;
    ns1:competencyCode "CG 3" ;
    ns1:competencyDescription "Aplicar los conocimientos adquiridos para identificar, formular y resolver problemas dentro de contextos amplios y multidisciplinarios, siendo capaces de integrar conocimientos, trabajando en equipos multidisciplinares."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001022/2025-26/CG%204> a ns1:Competency ;
    ns1:competencyCode "CG 4" ;
    ns1:competencyDescription "Comprender el impacto de la tecnología minera en el medio ambiente, el desarrollo sostenible de la sociedad. desarrollando la capacidad para la realización de estudios de ordenación del territorio y de los aspectos medioambientales relacionados con los proyectos, plantas e instalaciones, en su ámbito"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001022/2025-26/CG%205> a ns1:Competency ;
    ns1:competencyCode "CG 5" ;
    ns1:competencyDescription "Saber comunicar los conocimientos y conclusiones, tanto de forma oral, escrita y gráfica, a públicos especializados y no especializados de un modo claro y sin ambigüedades."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001022/2025-26/CG%206> a ns1:Competency ;
    ns1:competencyCode "CG 6" ;
    ns1:competencyDescription "Poseer habilidades de aprendizaje que permitan continuar estudiando a lo largo de la vida para su adecuado desarrollo profesional"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001022/2025-26/F16> a ns1:Competency ;
    ns1:competencyCode "F16" ;
    ns1:competencyDescription "Capacidad de análisis de la problemática de la seguridad y salud en los proyectos, plantas o instalaciones."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001022/2025-26/F18> a ns1:Competency ;
    ns1:competencyCode "F18" ;
    ns1:competencyDescription "Capacidad para aplicar metodologías de estudios y evaluaciones de impacto ambiental y, en general, de tecnologías ambientales, sostenibilidad y tratamiento de residuos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001022/2025-26/F19> a ns1:Competency ;
    ns1:competencyCode "F19" ;
    ns1:competencyDescription "Capacidad de planificación y gestión integral de obras, mediciones, replanteos, control y seguimiento."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001022/2025-26/F21> a ns1:Competency ;
    ns1:competencyCode "F21" ;
    ns1:competencyDescription "Conocimiento de la metodología, gestión y organización de proyectos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001022/2025-26/F8> a ns1:Competency ;
    ns1:competencyCode "F8" ;
    ns1:competencyDescription "Comprensión de los conceptos de aleatoriedad de los fenómenos físicos, sociales y económicos, así como de incertidumbre."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001022/2025-26/RA103> a ns1:LearningResult ;
    ns1:learningResultCode "RA103" ;
    ns1:learningResultDescription "Conocer las implicaciones que la legislación en materia de seguridad tiene para la empresa, en particular en lo referente a la prevención de riesgos laborales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001022/2025-26/RA104> a ns1:LearningResult ;
    ns1:learningResultCode "RA104" ;
    ns1:learningResultDescription "Conocer las técnicas de evaluación y prevención de riesgos, la legislación en vigor al respecto y los aspectos teóricos y prácticos que deben ser analizados para la realización de un Plan de Seguridad e Higiene"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001022/2025-26/RA105> a ns1:LearningResult ;
    ns1:learningResultCode "RA105" ;
    ns1:learningResultDescription "Comprender los fundamentos de la Higiene Industrial y su aplicación en la prevención de riesgos profesionales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001022/2025-26/RA106> a ns1:LearningResult ;
    ns1:learningResultCode "RA106" ;
    ns1:learningResultDescription "Conocer los factores ambientales unidos al trabajo, sus efectos sobre la salud del trabajador y las técnicas para la evaluación de los mismos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001022/2025-26/RA107> a ns1:LearningResult ;
    ns1:learningResultCode "RA107" ;
    ns1:learningResultDescription "Conocer los métodos de la higiene operativa para el control de los efectos nocivos derivados de la exposición laboral a agentes físicos, químicos y biológicos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001022/2025-26/RA108> a ns1:LearningResult ;
    ns1:learningResultCode "RA108" ;
    ns1:learningResultDescription "Aplicar las enseñanzas al análisis de casos prácticos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001022/2025-26/didactic_resource/1> a ns1:DidacticResource ;
    ns1:bibliographyTitle "Seguridad e Higiene. 2019. Mora, P. De Vicente, I. ISBN: 978-84-09-10009-5"@es ;
    ns1:bibliographyType "Bibliografía"@es .

