        <https://guia-kg.skai.etsisi.upm.es/resource/lutz.hermanns%40upm.es> ;
    schema:name "Determinación y Verificación de las Prestaciones Estructurales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002079/2025-26/%28a%29> a ns1:Competency ;
    ns1:competencyCode "(a)" ;
    ns1:competencyDescription "APLICA. Habilidad para aplicar conocimientos científicos, matemáticos y tecnológicos en sistemas relacionados con la práctica de la ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002079/2025-26/%28d%29> a ns1:Competency ;
    ns1:competencyCode "(d)" ;
    ns1:competencyDescription "TRABAJA EN EQUIPO. Habilidad para trabajar en equipos multidisciplinares."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002079/2025-26/%28e%29> a ns1:Competency ;
    ns1:competencyCode "(e)" ;
    ns1:competencyDescription "RESUELVE. Habilidad para identificar, formular y resolver problemas de ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002079/2025-26/%28f%29> a ns1:Competency ;
    ns1:competencyCode "(f)" ;
    ns1:competencyDescription "ES RESPONSABLE. Comprensión de la responsabilidad ética y profesional."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002079/2025-26/%28g%29> a ns1:Competency ;
    ns1:competencyCode "(g)" ;
    ns1:competencyDescription "COMUNICA. Habilidad para comunicar eficazmente."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002079/2025-26/%28i%29> a ns1:Competency ;
    ns1:competencyCode "(i)" ;
    ns1:competencyDescription "SE ACTUALIZA. Reconocimiento de la necesidad y la habilidad para comprometerse al aprendizaje continuo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002079/2025-26/%28k%29> a ns1:Competency ;
    ns1:competencyCode "(k)" ;
    ns1:competencyDescription "USA HERRAMIENTAS. Habilidad para usar las técnicas, destrezas y herramientas ingenieriles modernas necesarias para la práctica de la ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002079/2025-26/CE17> a ns1:Competency ;
    ns1:competencyCode "CE17" ;
    ns1:competencyDescription "Capacidad para el diseño, construcción y explotación de plantas industriales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002079/2025-26/CE18> a ns1:Competency ;
    ns1:competencyCode "CE18" ;
    ns1:competencyDescription "Conocimientos sobre construcción, edificación, instalaciones, infraestructuras y urbanismo en el ámbito de la ingeniería industrial."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002079/2025-26/CE19> a ns1:Competency ;
    ns1:competencyCode "CE19" ;
    ns1:competencyDescription "Conocimientos y capacidades para el cálculo y diseño de estructuras."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002079/2025-26/CG01> a ns1:Competency ;
    ns1:competencyCode "CG01" ;
    ns1:competencyDescription "Tener conocimientos adecuados de los aspectos científicos y tecnológicos de: métodos matemáticos, analíticos y numéricos en la ingeniería, ingeniería eléctrica, ingeniería energética, ingeniería química, ingeniería mecánica, mecánica de medios continuos, electrónica industrial, automática, fabricación, materiales, métodos cuantitativos de gestión, informática industrial, urbanismo, infraestructuras, etc."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002079/2025-26/CG02> a ns1:Competency ;
    ns1:competencyCode "CG02" ;
    ns1:competencyDescription "Proyectar, calcular y diseñar productos, procesos, instalaciones y plantas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002079/2025-26/CG06> a ns1:Competency ;
    ns1:competencyCode "CG06" ;
    ns1:competencyDescription "Gestionar técnica y económicamente proyectos, instalaciones, plantas, empresas y centros tecnológicos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002079/2025-26/CG08> a ns1:Competency ;
    ns1:competencyCode "CG08" ;
    ns1:competencyDescription "Aplicar los conocimientos adquiridos y resolver problemas en entornos nuevos o poco conocidos dentro de contextos más amplios y multidisciplinares."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002079/2025-26/CG09> a ns1:Competency ;
    ns1:competencyCode "CG09" ;
    ns1:competencyDescription "Ser capaz de integrar conocimientos y enfrentarse a la complejidad de formular juicios a partir de una información que, siendo incompleta o limitada, incluya reflexiones sobre las responsabilidades sociales y éticas vinculadas a la aplicación de sus conocimientos y juicios."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002079/2025-26/CG10> a ns1:Competency ;
    ns1:competencyCode "CG10" ;
    ns1:competencyDescription "Saber comunicar las conclusiones ¿y los conocimientos y razones últimas que las sustentan ¿a públicos especializados y no especializados de un modo claro y sin ambigüedades."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002079/2025-26/CG11> a ns1:Competency ;
    ns1:competencyCode "CG11" ;
    ns1:competencyDescription "Poseer las habilidades de aprendizaje que permitan continuar estudiando de un modo autodirigido o autónomo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002079/2025-26/CG12> a ns1:Competency ;
    ns1:competencyCode "CG12" ;
    ns1:competencyDescription "Conocimiento, comprensión y capacidad para aplicar la legislación necesaria en el ejercicio de la profesión de Ingeniero Industrial."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002079/2025-26/RA101> a ns1:LearningResult ;
    ns1:learningResultCode "RA101" ;
    ns1:learningResultDescription "Comprender el comportamiento del terreno como soporte del resto de la instalación que se proyecta y su importancia en el diseño global."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002079/2025-26/RA102> a ns1:LearningResult ;
    ns1:learningResultCode "RA102" ;
    ns1:learningResultDescription "Conocer e interpretar las normativas de la edificación. La definición de acciones, los estados límite, las hipótesis de combinación, etc."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002079/2025-26/RA103> a ns1:LearningResult ;
    ns1:learningResultCode "RA103" ;
    ns1:learningResultDescription "Profundizar en el conocimiento de los materiales que se emplean en la construcción sus cualidades, su forma de funcionamiento, sus características habituales en el análisis de las estructuras, sus ventajas e inconvenientes."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002079/2025-26/RA104> a ns1:LearningResult ;
    ns1:learningResultCode "RA104" ;
    ns1:learningResultDescription "Comprender que el Cálculo de Estructuras es una de las fases que conforman el proceso global del proyecto de una estructura; y en ella habrá de determinarse, mediante la aplicación de los Principios de la Mecánica de los Sólidos Deformables, si la estructura podrá desempeñar la función para la que inicialmente fue concebida."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002079/2025-26/RA439> a ns1:LearningResult ;
    ns1:learningResultCode "RA439" ;
    ns1:learningResultDescription "Capacidad de comprensión de las normativas empleadas en el ámbito estructural, en particular la identificación de las prestaciones y los métodos de control"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002079/2025-26/RA440> a ns1:LearningResult ;
    ns1:learningResultCode "RA440" ;
    ns1:learningResultDescription "? Capacidad de determinación de las prestaciones ligadas a elementos de hormigón armado y aplicación en ejemplos sencillos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002079/2025-26/RA441> a ns1:LearningResult ;
    ns1:learningResultCode "RA441" ;
    ns1:learningResultDescription "Capacidad de determinación de las prestaciones ligadas a elementos de acero estructural y aplicación en ejemplos sencillos"@es .

