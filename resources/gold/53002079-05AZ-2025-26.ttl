    ns1:syllabusDescription "4. Determinación de las prestaciones en problemas de mecánica de suelos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002079/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "4.1. Clasificación. Índices de fase. Principio de Terzaghi. Filtración. Consolidación. Estado Límite de Servicio, cálculo de asientos Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002079/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "4.2. Resistencia al corte de los suelos. Ensayos de identificación. Teoría de Mohr-Coulomb y Cam Clay Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002079/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "4.3. Cálculo de cimentaciones superficiales y profundas Sin subniveles"@es .

