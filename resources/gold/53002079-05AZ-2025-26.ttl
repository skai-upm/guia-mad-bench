<https://guia-kg.skai.etsisi.upm.es/resource/53002079/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Bases. Índices de Fiabilidad. Métodos de evaluación Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002079/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "3.1. Métodos seccionales. Relaciones de comportamiento de materiales, sección, elemento, estructura Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002079/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "3.2. Métodos de Límite. Bielas y Tirantes. Otros Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002079/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "3.3. Otras prestaciones. Durabilidad. Resistencia al fuego Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002079/2025-26/syllabus/13> a ns1:SyllabusItem ;
