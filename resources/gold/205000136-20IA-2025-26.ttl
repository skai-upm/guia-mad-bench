<https://guia-kg.skai.etsisi.upm.es/resource/205000136/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. FUNCIONES"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000136/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Funciones elementales, modelos matemáticos basados en sistemas reales Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000136/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "3.1. Sucesiones y series. Criterios básicos de convergencia. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000136/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "4. LA INTEGRAL"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000136/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "4.1. La integral de Riemann. Teorema fundamental del cálculo. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000136/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "4.2. Aplicaciones de la integral: áreas, volúmenes, longitud de arco, valor promedio de una función. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000136/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "4.3. Otras aplicaciones a la física, economía, biología, estadística, .... Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000136/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "4.4. Integrales impropias. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000136/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "5. ECUACIONES DIFERENCIALES"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000136/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "5.1. Ecuaciones diferenciales. Aplicación a las ciencias naturales y sociales. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000136/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "5.2. Campo de direcciones y método de Euler. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000136/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "5.3. Ecuaciones en variables separables. Aplicaciones. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000136/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Curvas parametrizadas Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000136/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "2. LA DERIVADA"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000136/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "2.1. La derivada. Razon de cambio en las ciencias naturales y sociales. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000136/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "2.2. Regla de la cadena y derivación implícita. Aplicación a contextos prácticos (razones relacionadas). Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000136/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "2.3. Aproximación lineal. Orden de aproximación mediante la derivada. La diferencial. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000136/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "2.4. Derivadas sucesivas. Máximos y mínimos. Teorema del valor medio. La derivada y la gráfica de la función. Problemas de optimización. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000136/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "2.5. Polinomio de Taylor. Orden de aproximación. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000136/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "3. SERIES"@es .

