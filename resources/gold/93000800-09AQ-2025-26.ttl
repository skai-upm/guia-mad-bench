<https://guia-kg.skai.etsisi.upm.es/resource/93000800/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Establecimiento del marco de desarrollo de la asignatura. / Course context and framework."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000800/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Presentación de la asignatura: programa de trabajo. Motivación. Rúbrica de la asignatura. / Introduction: workplan and motivation. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000800/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "3.1. Procesos de Iniciación del proyecto. El porfolio de proyectos. / Initiating processes. The project portfolio. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000800/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "3.2. Planificación del alcance: formalización de especificaciones. / Project scope management: specifications definition. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000800/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "3.3. Planes de Calidad. Calidad en el entorno TIC. / Quality planning. Quality in ICT projects. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000800/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "4. Sobre la Segunda Restricción: Tiempo. Procesos de Planificación de actividades. / On the second constraint: Time management. Scheduling and planning processes.."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000800/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "4.1. Planificación de actividades. PERT-CPM, Gantt, Teoría de Restricciones. / Activity scheduling. PERT-CPM, Gantt, Theory of Constraints. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000800/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "4.2. Planificación de la asignación de recursos. / Resource allocation planning. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000800/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "5. Sobre la Tercera Restricción: Costes. Procesos de Planificación Costes. / On the third constraint: Costs. Budgeting and Cost Planning."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000800/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "5.1. Identificación de las fuentes de costes del proyecto. / Definition of the project cost structure. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000800/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "5.2. Nociones de Caso de Negocio de un proyecto. / Introduction to a project business case. Sin subniveles"@es .

