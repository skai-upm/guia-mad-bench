    schema:name "Animal Behavior And Welfare"@en,
        "Comportamiento y Bienestar Animal"@es ;
    schema:numberOfCredits 3.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/205000051/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/205000051/2025-26/CB04>,
        <https://guia-kg.skai.etsisi.upm.es/resource/205000051/2025-26/CG09>,
