        <https://guia-kg.skai.etsisi.upm.es/resource/205000051/2025-26/RA294>,
        <https://guia-kg.skai.etsisi.upm.es/resource/205000051/2025-26/RA415>,
        <https://guia-kg.skai.etsisi.upm.es/resource/205000051/2025-26/RA416>,
        <https://guia-kg.skai.etsisi.upm.es/resource/205000051/2025-26/RA417>,
        <https://guia-kg.skai.etsisi.upm.es/resource/205000051/2025-26/RA418>,
        <https://guia-kg.skai.etsisi.upm.es/resource/205000051/2025-26/RA419> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/205000051/2025-26/syllabus> ;
    ns1:inpersonHours "47 horas y 10 minutos (58.2%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation """La asignatura se relaciona con el ODS3 y el ODS12.
Sobre CTs: "?La Comisión de Calidad del Centro en su reunión de 29 de mayo de 2023 acordó aprobar la propuesta de reasignación de competencias transversales en las asignaturas de los Grados en Biotecnología, Ingeniería Alimentaria, Ingeniería Agrícola, Ingeniería Agroambiental, Ciencias Agrarias y Bioeconomía, y en el Máster Universitario en Ingeniería Agronómica. En virtud de dicho acuerdo esta asignatura ha sido designada como ?Asignatura NO Punto Control*?. Esto significa que si bien puede seguir trabajando una o varias competencias transversales que se abordan en distintos puntos y aspectos de la asignatura, dicha formación y evaluación no será objeto de recopilación de evidencias por los sistemas de acreditación de la calidad del Centro?. *Asignatura punto control (APC): aquella asignatura en la que se verificará la formación y evaluación de la competencia transversal que le corresponda."""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "47 horas y 10 minutos"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/205000051/2025-26/eventSchedule> ;
    schema:description "Esta asignatura optativa es integradora de conceptos aprendidos durante las asignaturas obligatorias del área de Producción Animal. Los contenidos sirven para ayudar a capacitar a los profesionales a entender proyectos relacionados con la producción animal para mejorar el manejo, la productividad y la eficiencia del sistema. Los alumnos aprenderán cómo evaluar el bienestar animal desde un punto de vista objetivo, destacando la importancia del método científico y la experimentación junto con sesiones prácticas donde se entrará en contacto directo con animales. Se valorarán las bases legislativas sobre bienestar animal a nivel europeo y nacional. Se estudiará la base ética de los derechos de los animales desde varios puntos de vista, incluido el de los profesionales del sector. Se explicarán las herramientas analíticas disponibles para valorar el estrés en animales a nivel de granja, tanto fisiológicas como de comportamiento y otras relacionadas con la salud. Finalmente, se analizará la relación entre bienestar animal y calidad de producto."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/morris.villarroel%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/morris.villarroel%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/pilar.grebollar%40upm.es> ;
    schema:name "Comportamiento y Bienestar Animal"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000051/2025-26/CB04> a ns1:Competency ;
    ns1:competencyCode "CB04" ;
    ns1:competencyDescription "Que los estudiantes puedan transmitir información, ideas, problemas y soluciones a un público tanto especializado como no especializado"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000051/2025-26/CG09> a ns1:Competency ;
    ns1:competencyCode "CG09" ;
    ns1:competencyDescription "Familiarizarse con los fundamentos de las nuevas tecnologías necesarios para llevar a cabo investigación, gestión de la producción, y desarrollo adecuados a los nuevos retos en el ámbito agrario, incluyendo los aspectos éticos y bioéticos del área."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000051/2025-26/CT04> a ns1:Competency ;
    ns1:competencyCode "CT04" ;
    ns1:competencyDescription "Capacidad para comunicar a todo tipo de audiencias en lengua castellana e inglesa y tanto de forma oral como escrita."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000051/2025-26/RA290> a ns1:LearningResult ;
    ns1:learningResultCode "RA290" ;
    ns1:learningResultDescription "Capacidad para comprender la base ética del bienestar animal, desde el punto de vista filosófico, social, político y agrario (ganaderos, transportistas, mataderos, supermercados)."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000051/2025-26/RA291> a ns1:LearningResult ;
    ns1:learningResultCode "RA291" ;
    ns1:learningResultDescription "Aprender a usar indicadores de estrés a nivel de granja, desde nivel fisiológico al de comportamiento."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000051/2025-26/RA292> a ns1:LearningResult ;
    ns1:learningResultCode "RA292" ;
    ns1:learningResultDescription "Comprender el concepto de la etología aplicada y su base científica. Analizar comparativamente los normativas sobre Bienestar Animal"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000051/2025-26/RA293> a ns1:LearningResult ;
    ns1:learningResultCode "RA293" ;
    ns1:learningResultDescription "Valorar las bases legislativas sobre bienestar animal a nivel europeo y nacional, así como casos prácticos de su aplicación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000051/2025-26/RA294> a ns1:LearningResult ;
    ns1:learningResultCode "RA294" ;
    ns1:learningResultDescription "Desarrollar el hábito de leer, resumir y analizar datos científicos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000051/2025-26/RA415> a ns1:LearningResult ;
