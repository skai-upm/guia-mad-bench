    schema:name "Reactores Quimicos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000465/2025-26/CE%2019> a ns1:Competency ;
    ns1:competencyCode "CE 19" ;
    ns1:competencyDescription "Conocimientos sobre balances de materia y energía, biotecnología, transferencia de materia, operaciones de separación, ingeniería de la reacción química, diseño de reactores, y valoración y transformación de materias primas y recursos energéticos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000465/2025-26/CG%2010> a ns1:Competency ;
    ns1:competencyCode "CG 10" ;
    ns1:competencyDescription "Creatividad."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000465/2025-26/CG%202> a ns1:Competency ;
    ns1:competencyCode "CG 2" ;
    ns1:competencyDescription "Poseer la capacidad para diseñar, desarrollar, implementar, gestionar y mejorar productos, sistemas y procesos en los distintos ámbitos industriales, usando técnicas analíticas, computacionales o experimentales apropiadas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000465/2025-26/CG%203> a ns1:Competency ;
    ns1:competencyCode "CG 3" ;
    ns1:competencyDescription "Aplicar los conocimientos adquiridos para identificar, formular y resolver problemas en contextos amplios, siendo capaces de integrar los trabajando en equipos multidisciplinares"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000465/2025-26/CG%207> a ns1:Competency ;
    ns1:competencyCode "CG 7" ;
    ns1:competencyDescription "Incorporar las TIC y las tecnologías y herramientas de la Ingeniería Industrial en sus actividades profesionales"@es .

