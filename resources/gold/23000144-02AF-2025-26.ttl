    schema:courseCode 23000144 ;
    schema:hasCourseInstance <https://guia-kg.skai.etsisi.upm.es/resource/23000144/2025-26> ;
    schema:name "Application Of Socially Intelligent Complex Systems For Rural Development"@en,
        "Aplicaciones de los Sistemas Complejos Socialmente Inteligentes (Scsi) en el Desarrollo Rural"@es ;
    schema:numberOfCredits 2.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/23000144/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/23000144/2025-26/CE34>,
        <https://guia-kg.skai.etsisi.upm.es/resource/23000144/2025-26/CG1> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/23000144/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/23000144/2025-26/didactic_resource/2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/23000144/2025-26/didactic_resource/3> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/23000144/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/23000144/2025-26/RA13> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/23000144/2025-26/syllabus> ;
    ns1:inpersonHours "24 horas (46.2%)"@es ;
    ns1:numberOfCredits 2.0 ;
    ns1:otherInformation """La asignatura se relaciona con ODS 10 y 12
La principal vía de comunicación con los estudiantes será el correo electrónico institucional y los foros y noticias de la plataforma MOODLE."""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "24 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/23000144/2025-26/eventSchedule> ;
    schema:description "La asignatura presenta como en nuestra vida habitual nos vemos inmersos en las interacciones de sistemas complejos. La toma de decisión implica la selección de un curso de acción, entre dos o más posibles alternativas, con el fin de llegar a una solución para un problema dado. En el desarrollo rural cada proyecto involucra variables que lo hacen único. A pesar de la planeación, existe un porcentaje de incertidumbre que hace que su manejo deba ser el adecuado con las circunstancias y características de cada momento. En la presente asignatura plantearemos en proceso de toma de decisiones desde un punto de vista general, para luego pasar a estudiarlo en un sistema complejo."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/joseluis.yague%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/joseluis.yague%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/manuel.aparicio%40upm.es> ;
    schema:name "Aplicaciones de los Sistemas Complejos Socialmente Inteligentes (Scsi) en el Desarrollo Rural"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000144/2025-26/CE34> a ns1:Competency ;
    ns1:competencyCode "CE34" ;
    ns1:competencyDescription "Conocer los métodos de valoración socioeconómica y de captación de opiniones y preferencias que permiten su integración en los procesos de toma de decisiones, identificando los métodos de valoración más adecuado ante un problema de gestión y/o desarrollo rural y ambiental sostenibles."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000144/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Habilidades de comunicación escrita y oral: Concluir aportaciones por escrito, desarrollando la capacidad de síntesis y presentación de las ideas propias en un grupo de trabajo y en exposición pública."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000144/2025-26/RA13> a ns1:LearningResult ;
    ns1:learningResultCode "RA13" ;
    ns1:learningResultDescription "Saber enmarcar el proceso de toma de decisiones en el ámbito público en el contexto económico y social adecuado"@es .

