    schema:hasCourseInstance <https://guia-kg.skai.etsisi.upm.es/resource/45000104/2025-26> ;
    schema:name "Electricity And Magnetism"@en,
        "Electricidad y Magnetismo"@es ;
    schema:numberOfCredits 6.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/45000104/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/45000104/2025-26/CE%202.>,
        <https://guia-kg.skai.etsisi.upm.es/resource/45000104/2025-26/CE%205.>,
        <https://guia-kg.skai.etsisi.upm.es/resource/45000104/2025-26/CG%2011>,
        <https://guia-kg.skai.etsisi.upm.es/resource/45000104/2025-26/CG%203> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/45000104/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/45000104/2025-26/didactic_resource/2> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/45000104/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/45000104/2025-26/RA6>,
        <https://guia-kg.skai.etsisi.upm.es/resource/45000104/2025-26/RA7>,
        <https://guia-kg.skai.etsisi.upm.es/resource/45000104/2025-26/RA8> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/45000104/2025-26/syllabus> ;
    ns1:inpersonHours "95 horas y 15 minutos (58.8%)"@es ;
    ns1:numberOfCredits 6.0 ;
    ns1:otherInformation """Esta asignatura contribuye a los siguientes Objetivos de Desarrollo sostenible de la ONU, a través de sus procesos de aprendizaje y con los resultados obtenidos:
OBJETIVO 7. Asegurar el acceso a energías asequibles, fiables, sostenibles y modernas para todos.
OBJETIVO 9. Desarrollar infraestructuras resilientes, promover la industrialización inclusiva y sostenible, y fomentar la innovación."""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "95 horas y 15 minutos"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/45000104/2025-26/eventSchedule> ;
    schema:description "El objetivo de la asignatura es que los estudiantes adquieran un conocimiento básico de los fenómenos físicos producidos por la interacción electromagnética y los modelos matemáticos que los describen. En la asignatura se introducen las diferentes leyes que describen fenómenos sencillos observados experimentalmente y las ecuaciones de Maxwell. La comprensión de este modelo general es el primer objetivo de la asignatura, que se completa con el estudio de los fundamentos de circuitos eléctricos y de ondas electromagnéticas."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/gustavo.plaza%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/blanca.gbermudez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/gustavo.plaza%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/m.deabreu%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/rafael.daza%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/sergio.fernandezga%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/v.rey%40upm.es> ;
    schema:name "Electricidad y Magnetismo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000104/2025-26/CE%202.> a ns1:Competency ;
    ns1:competencyCode "CE 2." ;
    ns1:competencyDescription "Saber modelizar el comportamiento (mecánico, electrónico, químico o biológico) de los materiales y su integración en componentes y dispositivos./ Know how to model the behavior (mechanical, electronic, chemical or biological) of materials and their integration into components and devices."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000104/2025-26/CE%205.> a ns1:Competency ;
    ns1:competencyCode "CE 5." ;
    ns1:competencyDescription "Capacitar para el aprendizaje autÃ³nomo de nuevos conocimientos y tÃ©cnicas / Train for autonomous learning of new knowledge and techniques"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000104/2025-26/CG%2011> a ns1:Competency ;
    ns1:competencyCode "CG 11" ;
    ns1:competencyDescription "Responsabilidad y ética profesional/ Responsibility and professional ethics"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000104/2025-26/CG%203> a ns1:Competency ;
