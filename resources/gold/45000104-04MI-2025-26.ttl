    ns1:competencyDescription "Comunicación oral y escrita"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000104/2025-26/RA6> a ns1:LearningResult ;
    ns1:learningResultCode "RA6" ;
    ns1:learningResultDescription "Entender, asimilar y manejar los conceptos, métodos y herramientas básicas de las ciencias sobre las que se apoya la Ciencia de Materiales, con una visión integradora y aplicada que refuerce la unidad conceptual y evite la disgregación de contenidos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000104/2025-26/RA7> a ns1:LearningResult ;
    ns1:learningResultCode "RA7" ;
    ns1:learningResultDescription "Conocer las teorías y modelos matemáticos, físicos, químicos y biológicos más relevantes en Ciencia de los Materiales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000104/2025-26/RA8> a ns1:LearningResult ;
    ns1:learningResultCode "RA8" ;
    ns1:learningResultDescription "Utilizar con soltura la comunicación oral y escrita y las Tecnologías de la Información y de la Comunicación"@es .

