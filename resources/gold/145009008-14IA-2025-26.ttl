        <https://guia-kg.skai.etsisi.upm.es/resource/145009008/2025-26/RA588> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/145009008/2025-26/syllabus> ;
    ns1:inpersonHours "35 horas y 15 minutos (45.2%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation ""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "35 horas y 15 minutos"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/145009008/2025-26/eventSchedule> ;
    schema:description "Se presentan los fundamentos físicos y las aplicaciones tecnológicas de los láseres, especialmente las aeronáuticas y espaciales. Los primeros tres temas del programa corresponden a los fundamentos físicos, los cuales se describen a nivel cualitativo sin que sean necesarios conocimientos adicionales a los de las asignaturas de Física I y II. En el capítulo 4 se presentan los tipos de láseres, desde los mas convencionales hasta aquellos que se encuentran todavía en fase de investigación, tales como los láseres de electrones libres. El Capítulo 5 está dedicado a la interacción del láser con la materia. La absorción de la luz láser en blancos solidos en el régimen de baja intensidad se presenta sólo cualitativamente, reduciéndose a un problema de conducción térmica en el blanco. En el régimen de alta intensidad se estudiará con detalle la absorción colisional clásica (bremsstrahlung inverso) y la respuesta fluidodinámica del blanco, incluida la generación de ondas de choque. Las aplicaciones se discuten en los siguientes capítulos, que incluyen aplicaciones aeronáuticas civiles y militares, aplicaciones al procesado de materiales, generación de haces de partículas y radiación, y fusión por láser."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/javier.honrubia%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/javier.honrubia%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/l.volpe%40upm.es> ;
    schema:name "Laseres y Sus Aplicaciones"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145009008/2025-26/CE01> a ns1:Competency ;
    ns1:competencyCode "CE01" ;
    ns1:competencyDescription "Capacidad para la resolución de los problemas matemáticos que puedan plantearse en la ingeniería. Aptitud para aplicar los conocimientos sobre: álgebra lineal; geometría; geometría diferencial; cálculo diferencial e integral; ecuaciones diferenciales y en derivadas parciales; métodos numéricos; algoritmos numéricos; estadística y optimización."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145009008/2025-26/CE02> a ns1:Competency ;
    ns1:competencyCode "CE02" ;
    ns1:competencyDescription "Comprensión y dominio de los conceptos básicos sobre las leyes generales de la mecánica, termodinámica, campos y ondas y electromagnetismo y su aplicación para la resolución de problemas propios de la ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145009008/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Capacidad para identificar y resolver problemas aplicando, con creatividad, los conocimientos adquiridos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145009008/2025-26/CG7> a ns1:Competency ;
    ns1:competencyCode "CG7" ;
    ns1:competencyDescription "Comunicación oral y escrita"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145009008/2025-26/CG9> a ns1:Competency ;
    ns1:competencyCode "CG9" ;
    ns1:competencyDescription "Razonamiento crítico y capacidad de asociación que posibiliten el aprendizaje continuo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145009008/2025-26/RA585> a ns1:LearningResult ;
    ns1:learningResultCode "RA585" ;
    ns1:learningResultDescription "Conocimiento adecuado de la física fundamental de los láseres y su tipología"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145009008/2025-26/RA586> a ns1:LearningResult ;
    ns1:learningResultCode "RA586" ;
    ns1:learningResultDescription "Conocimiento adecuado de las aplicaciones más importantes de los láseres en el sector aeroespacial"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145009008/2025-26/RA587> a ns1:LearningResult ;
    ns1:learningResultCode "RA587" ;
    ns1:learningResultDescription "Conocimiento, comprensión y aplicación de los tipos de láseres y sus aplicaciones en los distintos regímenes de intensidad y potencia"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145009008/2025-26/RA588> a ns1:LearningResult ;
    ns1:learningResultCode "RA588" ;
    ns1:learningResultDescription "Identificación de las potenciales aplicaciones del láser en diferentes áreas, desde la metrología y tratamiento de materiales hasta la generación de plasmas de alta densidad de energía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145009008/2025-26/didactic_resource/1> a ns1:DidacticResource ;
    ns1:bibliographyTitle "O. Svelto, Principles of Lasers, Plenum Press, New York (1998)."@es ;
    ns1:bibliographyType "Bibliografía"@es .

