    schema:name "Fundamentos de Metalurgia Extractiva"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65005003/2025-26/C13> a ns1:Competency ;
    ns1:competencyCode "C13" ;
    ns1:competencyDescription "Capacidad para aplicar los principios de economía circular en la obtención, procesado, diseño y reciclaje de materiales metálicos. TIPO: Competencias"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65005003/2025-26/C5> a ns1:Competency ;
    ns1:competencyCode "C5" ;
    ns1:competencyDescription "Comprender y aplicar el diseño, operación y mantenimiento de plantas metalúrgicas y de reciclaje de materiales metálicos. TIPO: Competencias"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65005003/2025-26/CON14> a ns1:Competency ;
    ns1:competencyCode "CON14" ;
    ns1:competencyDescription "Capacidad para conocer, comprender y utilizar los principios de la ingeniería mineralúrgica, metalúrgica y de la Tecnología de Materiales.TIPO: Conocimientos o contenidos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65005003/2025-26/HAB10> a ns1:Competency ;
    ns1:competencyCode "HAB10" ;
    ns1:competencyDescription "Poseer habilidades de aprendizaje que permitan continuar estudiando a lo largo de la vida para su adecuado desarrollo profesional. TIPO: Habilidades o destrezas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65005003/2025-26/HAB6> a ns1:Competency ;
    ns1:competencyCode "HAB6" ;
    ns1:competencyDescription "Capacidad para aplicar metodologías de estudios y evaluaciones de impacto ambiental y, en general, de tecnologías ambientales, sostenibilidad y tratamiento de residuos. TIPO: Habilidades o destrezas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65005003/2025-26/HAB8> a ns1:Competency ;
    ns1:competencyCode "HAB8" ;
    ns1:competencyDescription "Aplicar los conocimientos adquiridos para identificar, formular y resolver problemas dentro de contextos amplios y multidisciplinarios, siendo capaces de integrar conocimientos, trabajando en equipos multidisciplinares. TIPO: Habilidades o destrezas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65005003/2025-26/HAB9> a ns1:Competency ;
    ns1:competencyCode "HAB9" ;
    ns1:competencyDescription "Saber comunicar los conocimientos y conclusiones, tanto de forma oral, escrita y gráfica, a públicos especializados y no especializados de un modo claro y sin ambigüedades. TIPO: Habilidades o destrezas"@es .

