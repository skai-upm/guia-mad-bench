    ns1:itemIndex 27 ;
    ns1:syllabusDescription "5.6. Protección de participantes humanos y animales. Declaración de Helsinki. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000031/2025-26/syllabus/28> a ns1:SyllabusItem ;
    ns1:itemIndex 28 ;
    ns1:syllabusDescription "5.7. Autorizaciones de organismos oficiales para llevar a cabo una investigación. Sin subniveles"@es .

