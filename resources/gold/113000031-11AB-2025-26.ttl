    ns1:itemIndex 7 ;
    ns1:syllabusDescription "2.2. La investigación epidemiológica en las Ciencias de la Actividad Física y del Deporte. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000031/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "2.3. El metaanálisis y la evidencia científica. Estatutos o regulación de PRISMA para las revisiones sistemáticas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000031/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "2.4. Metodología de la valoración. Validez y sesgos de la investigación. Sin subniveles"@es .

