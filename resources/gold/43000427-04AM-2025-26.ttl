<https://guia-kg.skai.etsisi.upm.es/resource/43000427/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/43000427/2025-26/CB7>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000427/2025-26/CB8>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000427/2025-26/CB9>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000427/2025-26/CE1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000427/2025-26/CG2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000427/2025-26/CG3> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/43000427/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/43000427/2025-26/RA20>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000427/2025-26/RA21>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000427/2025-26/RA22>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000427/2025-26/RA23>,
