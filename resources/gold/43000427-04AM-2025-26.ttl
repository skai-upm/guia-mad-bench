<https://guia-kg.skai.etsisi.upm.es/resource/43000427/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Introducción"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000427/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Comportamiento no lineal de estructuras Causas de la no linealidad: geometría, material, otras. Consecuencias de la no linealidad. Ejemplos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000427/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "3.3. Modelos de comportamiento seccional. Diagramas momento curvatura. Modelo multicapa. Ductilidad. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000427/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "3.4. Métodos de cálculo estructural Aplicación a cálculo matricial y método de los Elementos Finitos. Ejemplos: estructuras de hormigón, acero y mixtas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000427/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "3.5. Combinación de ambas no linealidades Aplicación a cálculo matricial y método de los Elementos Finitos. Métodos simplificados. Planteamiento normativo. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000427/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "4. Otras no linealidades"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000427/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "4.1. Condiciones de contorno Condiciones de sustentación. Problemas de contacto: deslizamiento, rodadura, rozamiento, anclaje, etc. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000427/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "5. Dinámica no lineal de estructuras"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000427/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "5.1. Cálculo Dinámico no lineal Causas de no linealidad dinámica. Métodos de integración explícitos e implícitos. Aplicación a cálculo matricial y método de los Elementos Finitos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000427/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "6. Resolución de los cálculos estructurales no lineales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000427/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "6.1. Métodos numéricos de resolución Métodos iterativos e incrementales (paso a paso). Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000427/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "7. La seguridad en cálculos estructurales no lineales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000427/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "2. No Linealidad Geométrica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000427/2025-26/syllabus/20> a ns1:SyllabusItem ;
    ns1:itemIndex 20 ;
    ns1:syllabusDescription "7.1. Formato de seguridad en cálculo no lineal Influencia de la no linealidad en el formato de seguridad. Método de los coeficientes parciales. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000427/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "2.1. Tipos de no linealidad geométrica Grandes desplazamientos, grandes giros, grandes deformaciones. Segundo orden. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000427/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "2.2. Planteamiento analítico Cálculo de segundo orden en barras y lajas. Carga crítica de Euler. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000427/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "2.3. Método de la matriz de rigidez geométrica Aplicación al cálculo matricial de estructuras de barras. Aplicación al método de los Elementos Finitos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000427/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "2.4. Método de grandes desplazamientos Aplicación a cálculo matricial y método de los Elementos Finitos. Resolución de problemas con cables y mallas tesas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000427/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "3. No Linealidad del Material"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000427/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "3.1. Tipos de no linealidad del material Comportamiento elástico no lineal, plástico, viscoelástico, fisuración, elementos de elasticidad y elementos estructurales. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000427/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "3.2. Modelos de comportamiento del material Elasticidad no lineal, plasticidad, viscoelasticidad. Sin subniveles"@es .

