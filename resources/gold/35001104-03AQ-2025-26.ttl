    schema:name "Introduccion a la Arquitectura"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35001104/2025-26/CE%2040> a ns1:Competency ;
    ns1:competencyCode "CE 40" ;
    ns1:competencyDescription "Capacidad para ejercer la crítica arquitectónica."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35001104/2025-26/CE%2048> a ns1:Competency ;
    ns1:competencyCode "CE 48" ;
    ns1:competencyDescription "Conocimiento adecuado de las teorías generales de la forma, la composición y los tipos arquitectónicos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35001104/2025-26/CE%2049> a ns1:Competency ;
    ns1:competencyCode "CE 49" ;
    ns1:competencyDescription "Conocimiento adecuado de la historia general de la arquitectura."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35001104/2025-26/CE%2053> a ns1:Competency ;
    ns1:competencyCode "CE 53" ;
    ns1:competencyDescription "Conocimiento adecuado de las tradiciones arquitectónicas, urbanísticas y paisajísticas de la cultura occidental, así como de sus fundamentos técnicos, climáticos, económicos, sociales e ideológicos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35001104/2025-26/CE%2055> a ns1:Competency ;
    ns1:competencyCode "CE 55" ;
    ns1:competencyDescription "Conocimiento adecuado de la relación entre los patrones culturales y las responsabilidades sociales del arquitecto."@es .

