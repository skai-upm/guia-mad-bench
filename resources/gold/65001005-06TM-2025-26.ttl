        <https://guia-kg.skai.etsisi.upm.es/resource/luisfelipe.mazadiego%40upm.es> ;
    schema:name "Expresion Grafica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001005/2025-26/CG%201> a ns1:Competency ;
    ns1:competencyCode "CG 1" ;
    ns1:competencyDescription "Conocer y aplicar conocimientos de ciencias y tecnologías básicas a la práctica de la Tecnología Minera."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001005/2025-26/CG%2010> a ns1:Competency ;
    ns1:competencyCode "CG 10" ;
    ns1:competencyDescription "Creatividad."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001005/2025-26/CG%202> a ns1:Competency ;
    ns1:competencyCode "CG 2" ;
    ns1:competencyDescription "Poseer capacidad para diseñar, analizar, calcular, proyectar, construir, mantener, conservar, explotar, desarrollar, implementar, gestionar y mejorar productos, sistemas y procesos en los distintos ámbitos de las Tecnologías Mineras, usando técnicas analíticas, computacionales o experimentales apropiadas, incluyendo la función de asesoría en estos campos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001005/2025-26/CG%203> a ns1:Competency ;
    ns1:competencyCode "CG 3" ;
    ns1:competencyDescription "Aplicar los conocimientos adquiridos para identificar, formular y resolver problemas dentro de contextos amplios y multidisciplinarios, siendo capaces de integrar conocimientos, trabajando en equipos multidisciplinares."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001005/2025-26/CG%206> a ns1:Competency ;
    ns1:competencyCode "CG 6" ;
    ns1:competencyDescription "Poseer habilidades de aprendizaje que permitan continuar estudiando a lo largo de la vida para su adecuado desarrollo profesional"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001005/2025-26/F2> a ns1:Competency ;
    ns1:competencyCode "F2" ;
    ns1:competencyDescription "Capacidad de visión espacial y conocimiento de las técnicas de representación gráfica, tanto por métodos tradicionales de geometría métrica y geometría descriptiva, como mediante las aplicaciones de diseño asistido por ordenador."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001005/2025-26/F3> a ns1:Competency ;
    ns1:competencyCode "F3" ;
    ns1:competencyDescription "Conocimientos básicos sobre el uso y programación de los ordenadores, sistemas operativos, bases de datos y programas informáticos con aplicación en ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001005/2025-26/RA29> a ns1:LearningResult ;
    ns1:learningResultCode "RA29" ;
    ns1:learningResultDescription "Resolver problemas técnicos de ingeniería de forma eminentemente gráfica."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001005/2025-26/RA30> a ns1:LearningResult ;
    ns1:learningResultCode "RA30" ;
    ns1:learningResultDescription "Demostrar visión espacial y capacidad para distinguir y utilizar representación gráfica, por métodos tradicionales de geometría métrica y geometría descriptiva"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001005/2025-26/RA31> a ns1:LearningResult ;
    ns1:learningResultCode "RA31" ;
    ns1:learningResultDescription "Capacidad de interpretación y representación de planos para proyectos de ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001005/2025-26/RA395> a ns1:LearningResult ;
    ns1:learningResultCode "RA395" ;
    ns1:learningResultDescription "Aplicación de herramientas software al diseño 3D de piezas de ingeniería"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001005/2025-26/RA396> a ns1:LearningResult ;
    ns1:learningResultCode "RA396" ;
    ns1:learningResultDescription "Comprensión de los principales procesos de impresión 3D disponibles actualmente y su aplicabilidad a los procesos de diseño."@es .

