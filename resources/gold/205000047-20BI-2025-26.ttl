    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/205000047/2025-26/RA272>,
        <https://guia-kg.skai.etsisi.upm.es/resource/205000047/2025-26/RA273>,
        <https://guia-kg.skai.etsisi.upm.es/resource/205000047/2025-26/RA274>,
        <https://guia-kg.skai.etsisi.upm.es/resource/205000047/2025-26/RA275>,
        <https://guia-kg.skai.etsisi.upm.es/resource/205000047/2025-26/RA276>,
        <https://guia-kg.skai.etsisi.upm.es/resource/205000047/2025-26/RA277> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/205000047/2025-26/syllabus> ;
    ns1:inpersonHours "74 horas (47.4%)"@es ;
    ns1:numberOfCredits 6.0 ;
    ns1:otherInformation """Para la realización de prácticas en el laboratorio será obligatorio el uso de bata y para las prácticas en campo será obligatorio el uso de zapato y vestuario adecuado. En las prácticas de poda será obligatorio el uso de gafas protectoras.
La asignatura se relaciona con los ODS 4, 12 y 13
La Comisión de Calidad del Centro en su reunión de 29 de mayo de 2023 acordó aprobar la propuesta de reasignación de competencias transversales en las asignaturas de los Grados en Biotecnología, Ingeniería Alimentaria, Ingeniería Agrícola, Ingeniería Agroambiental, Ciencias Agrarias y Bioeconomía, y en el Máster Universitario en Ingeniería Agronómica. En virtud de dicho acuerdo esta asignatura ha sido designada como "Asignatura NO Punto Control*". Esto significa que si bien puede seguir trabajando una o varias competencias transversales que se abordan en distintos puntos y aspectos de la asignatura, dicha formación y evaluación no será objeto de recopilación de evidencias por los sistemas de acreditación de la calidad del Centro.
*Asignatura punto control (APC): aquella asignatura en la que se verificará la formación y evaluación de la competencia transversal que le corresponda."""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "74 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/205000047/2025-26/eventSchedule> ;
    schema:description "La asignatura trata sobre la morfología y fisiología de las especies frutales leñosas, su adaptación ecológica, las técnicas de multiplicación empleadas en la producción de la planta de vivero, los principales patrones y variedades por especies, las técnicas utilizadas en el establecimiento de las plantaciones y la problemática específica de su cultivo."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/david.perezl%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/ana.centeno%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/david.perezl%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/raquel.casas%40upm.es> ;
    schema:name "Fruticultura"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000047/2025-26/CG07> a ns1:Competency ;
    ns1:competencyCode "CG07" ;
    ns1:competencyDescription "Adquirir la formación profesional necesaria para desarrollar estrategias sostenibles de producción vegetal y animal de forma eficiente y acorde a los recursos disponibles."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000047/2025-26/CT08> a ns1:Competency ;
    ns1:competencyCode "CT08" ;
    ns1:competencyDescription "Ser capaz de manejar las tecnologías de la información y comunicación en un contexto profesional."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000047/2025-26/RA272> a ns1:LearningResult ;
    ns1:learningResultCode "RA272" ;
    ns1:learningResultDescription "Saber reconocerlas por sus características botánicas y morfológicas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000047/2025-26/RA273> a ns1:LearningResult ;
    ns1:learningResultCode "RA273" ;
    ns1:learningResultDescription "Conocer los factores edafoclimáticos que condicionan o limitan su implantación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000047/2025-26/RA274> a ns1:LearningResult ;
    ns1:learningResultCode "RA274" ;
    ns1:learningResultDescription "Conocer las características de los patrones y variedades más importantes"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000047/2025-26/RA275> a ns1:LearningResult ;
    ns1:learningResultCode "RA275" ;
    ns1:learningResultDescription "Conocer y evaluar las peculiaridades y la problemática específica del cultivo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000047/2025-26/RA276> a ns1:LearningResult ;
    ns1:learningResultCode "RA276" ;
    ns1:learningResultDescription "Conocer las principales fuentes de información sobre los distintos cultivos frutales en España."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000047/2025-26/RA277> a ns1:LearningResult ;
    ns1:learningResultCode "RA277" ;
    ns1:learningResultDescription "Comunicar correctamente contenidos técnicos mediante distintas técnicas de presentación."@es .

