    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/20504311/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/20504311/2025-26/didactic_resource/2>,
