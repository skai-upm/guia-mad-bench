    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/95000338/2025-26/eventSchedule> ;
    schema:description "La asignatura se desarrolla enteramente en el laboratorio de Biomecanica Deportiva de la UPM y tiene por objetivo que los alumnos aprendan el manejo y la aplicación de las herramientas de análisisico biomecánico actuales (sistemas de captura del mov 3D, Plataformas de Fuerza, Electromiografía de Superficie). Se estudiará la marcha mediante prácticas reales de análisis biomecáno."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/enrique.navarro%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/archit.navandar%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/enrique.navarro%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/javier.ruedao%40upm.es> ;
    schema:name "Laboratorio de Biomecánica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000338/2025-26/CE06> a ns1:Competency ;
    ns1:competencyCode "CE06" ;
    ns1:competencyDescription "Comprender y saber calcular el equilibrio y la dinámica de sistemas mecánicos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000338/2025-26/CG07> a ns1:Competency ;
    ns1:competencyCode "CG07" ;
    ns1:competencyDescription "Ser capaz de utilizar el método científico."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000338/2025-26/CG08> a ns1:Competency ;
    ns1:competencyCode "CG08" ;
    ns1:competencyDescription "Entender, aplicar, adaptar y desarrollar herramientas, técnicas y protocolos de experimentación con rigor metodológico comprendiendo las limitaciones que tiene la aproximación experimental."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000338/2025-26/CG09> a ns1:Competency ;
    ns1:competencyCode "CG09" ;
    ns1:competencyDescription "Tener capacidad de descripción, cuantificación, análisis y evaluación de resultados experimentales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000338/2025-26/CG15> a ns1:Competency ;
    ns1:competencyCode "CG15" ;
    ns1:competencyDescription "Transmitir la información adquirida, las ideas, los problemas y las soluciones de forma oral y escrita en castellano e inglés."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000338/2025-26/RA127> a ns1:LearningResult ;
    ns1:learningResultCode "RA127" ;
    ns1:learningResultDescription "Aplicar técnicas avanzadas en procesamiento de señales para la resolución de problemas de señales biomédicas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000338/2025-26/RA129> a ns1:LearningResult ;
    ns1:learningResultCode "RA129" ;
    ns1:learningResultDescription "Identificar, a partir de inspección visual y técnicas de procesamiento, distintos patrones de señales biomédicas tanto en registros de pacientes sanos como aquellos que presenten una patología."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000338/2025-26/RA17> a ns1:LearningResult ;
    ns1:learningResultCode "RA17" ;
    ns1:learningResultDescription "Capacidad para elaborar informes con el tratamiento y la interpretación adecuada de resultados experimentales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000338/2025-26/RA248> a ns1:LearningResult ;
    ns1:learningResultCode "RA248" ;
    ns1:learningResultDescription "Desarrollar la capacidad de realizar un trabajo en equipo, en la planificación del trabajo común, la búsqueda de fuentes de información y la presentación de resultados"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000338/2025-26/RA285> a ns1:LearningResult ;
    ns1:learningResultCode "RA285" ;
    ns1:learningResultDescription "RA365"@es .

