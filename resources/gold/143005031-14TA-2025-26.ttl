        <https://guia-kg.skai.etsisi.upm.es/resource/josefelix.alonso%40upm.es> ;
    schema:name "Tratamiento de Informacion Multisensor"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005031/2025-26/CE10> a ns1:Competency ;
    ns1:competencyCode "CE10" ;
    ns1:competencyDescription "Comprender la problemática propia de los sistemas electrónicos terrestres y embarcados en los diferentes elementos del Sistema del Transporte Aéreo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005031/2025-26/CG2> a ns1:Competency ;
    ns1:competencyCode "CG2" ;
    ns1:competencyDescription "Aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en los entornos de evolución previstos en los Sistemas de Transporte Aéreo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005031/2025-26/CG4> a ns1:Competency ;
    ns1:competencyCode "CG4" ;
    ns1:competencyDescription "Comunicar sus conclusiones y los conocimientos y razones últimas que las sustentan a públicos especializados, y no especializados de un modo claro y sin ambigüedades"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005031/2025-26/CG6> a ns1:Competency ;
    ns1:competencyCode "CG6" ;
    ns1:competencyDescription "Que los estudiantes posean las habilidades de aprendizaje que les permitan continuar estudiando de un modo que habrá de ser en gran medida autodirigido o autónomo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005031/2025-26/RA3> a ns1:LearningResult ;
    ns1:learningResultCode "RA3" ;
    ns1:learningResultDescription "El alumno conoce las leyes fundamentales de la luminotecnia."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005031/2025-26/RA91> a ns1:LearningResult ;
    ns1:learningResultCode "RA91" ;
    ns1:learningResultDescription "El/La alumno/a conoce todos los tipos de sensores de posicionamiento y actitud utilizados en la aeronave, aprende a modelizarlos y conoce sus prestaciones y errores."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005031/2025-26/RA92> a ns1:LearningResult ;
    ns1:learningResultCode "RA92" ;
    ns1:learningResultDescription "El/La alumno/a aprende como tratar la información a nivel señal para eliminar el máximo nivel de ruido."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005031/2025-26/RA93> a ns1:LearningResult ;
    ns1:learningResultCode "RA93" ;
    ns1:learningResultDescription "El/La alumno/a conoce las arquitecturas y procesos utilizados en el tratamiento de información multisensor, es capaz de aplicar diferentes técnicas y utilizar diferentes estimadores del vector de estado."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005031/2025-26/RA94> a ns1:LearningResult ;
    ns1:learningResultCode "RA94" ;
    ns1:learningResultDescription "El/La alumno/a conoce y es capaz de aplicar técnicas de filtrado Kalman en la estimación del vector de estado en sistemas multisensor."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005031/2025-26/RA95> a ns1:LearningResult ;
    ns1:learningResultCode "RA95" ;
    ns1:learningResultDescription "El/La alumno/a es capaz de estimar la actuación de una plataforma inercial de bajo coste, simular su funcionamiento e implementarla en un sistema microcontrolador."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005031/2025-26/RA96> a ns1:LearningResult ;
    ns1:learningResultCode "RA96" ;
    ns1:learningResultDescription "El/La alumno/a es conoce la forma de operar la aeronave mediante la utilización de técnicas de posicionamiento basadas en el procesamiento y fusión de la información multisensor."@es .

