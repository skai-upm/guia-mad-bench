<https://guia-kg.skai.etsisi.upm.es/resource/95000007/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Geometría de Rn."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000007/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. El espacio vectorial Rn. Producto escalar. Coordenadas cartesianas, polares, cilíndricas y esféricas. Producto vectorial. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000007/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "2.3.2. Derivadas parciales. Derivadas direccionales. Gradiente. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000007/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "2.3.3. Diferenciabilidad. Interpretación geométrica. Matriz jacobiana. Transformaciones (coordenadas cartesianas, polares, cilíndricas y esféricas). Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000007/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "2.3.4. Composición de funciones: regla de la cadena y aplicaciones. Teorema de la función implícita. Derivación implícita. Teorema de la función inversa. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000007/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "2.3.5. Aproximaciones de Taylor de primer y segundo orden. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000007/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "2.3.6. Extremos relativos y absolutos. Extremos condicionados. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000007/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "3. Integración de campos escalares y vectoriales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000007/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "3.1. La integral de Riemann en Rn. Propiedades generales. Teorema del valor medio. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000007/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "3.2. Cálculo de integrales múltiples. Teorema de Fubini. Teorema del cambio de variable. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000007/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "3.3. Integrales de línea: tipos y propiedades. Valor medio de una función escalar sobre una curva. Función potencial. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000007/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "3.4. Superficies parametrizadas. Orientación. Vector normal. Plano tangente. Reparametrización. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000007/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Curvas en Rn. Curvas regulares. Vector tangente, aceleración, normal principal. Reparamatrización. Longitud. Ecuaciones implícitas en coordenadas polares y cartesianas. Curvas de nivel. Cónicas y otras curvas planas notables. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000007/2025-26/syllabus/20> a ns1:SyllabusItem ;
    ns1:itemIndex 20 ;
    ns1:syllabusDescription "3.5. Integrales de superficie: tipos y propiedades. Área de una superficie. Valor medio de una función escalar sobre una superficie. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000007/2025-26/syllabus/21> a ns1:SyllabusItem ;
    ns1:itemIndex 21 ;
    ns1:syllabusDescription "4. Teoremas integrales del Análisis Vectorial."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000007/2025-26/syllabus/22> a ns1:SyllabusItem ;
    ns1:itemIndex 22 ;
    ns1:syllabusDescription "4.1. Operadores diferenciales: gradiente, rotacional, divergencia y laplaciano. Expresión en coordenadas cartesianas, cilíndricas y esféricas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000007/2025-26/syllabus/23> a ns1:SyllabusItem ;
    ns1:itemIndex 23 ;
    ns1:syllabusDescription "4.2. Campos conservativos, solenoidales y armónicos. Caracterización. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000007/2025-26/syllabus/24> a ns1:SyllabusItem ;
    ns1:itemIndex 24 ;
    ns1:syllabusDescription "4.3. Teorema de Green. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000007/2025-26/syllabus/25> a ns1:SyllabusItem ;
    ns1:itemIndex 25 ;
    ns1:syllabusDescription "4.4. Teorema de Stokes. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000007/2025-26/syllabus/26> a ns1:SyllabusItem ;
    ns1:itemIndex 26 ;
    ns1:syllabusDescription "4.5. Teorema de Gauss (o de la divergencia). Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000007/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "1.3. Superficies en R3. Superficies regulares. Ecuación implícita en coordenadas cartesianas, cilíndricas y esféricas. Superficies de nivel. Cuádricas y otras superficies notables. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000007/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "1.4. Parametrización de curvas y superficies. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000007/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "2. Cálculo diferencial."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000007/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "2.1. Topología del espacio euclídeo Rn. Generalidades de las funciones vectoriales de Rn en Rm. Campos escalares y vectoriales. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000007/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "2.2. Funciones vectoriales de una variable. Interpretación geométrica y física. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000007/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "2.3. Funciones vectoriales de varias variables."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000007/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "2.3.1. Límites y continuidad. Sin subniveles"@es .

