    schema:hasCourseInstance <https://guia-kg.skai.etsisi.upm.es/resource/53001966/2025-26> ;
    schema:name "Environmental Economics"@en,
        "Economía Ambiental"@es ;
    schema:numberOfCredits 3.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/53001966/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/53001966/2025-26/CB07>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001966/2025-26/CB08>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001966/2025-26/CE06>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001966/2025-26/CE08>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001966/2025-26/CG04>,
