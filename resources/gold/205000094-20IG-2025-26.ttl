    schema:name "Agroecosystems Degradation And Climate Change"@en,
        "Degradación de Agrosistemas y Cambio Climático"@es ;
    schema:numberOfCredits 5.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/205000094/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/205000094/2025-26/CB03>,
