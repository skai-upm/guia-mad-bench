<https://guia-kg.skai.etsisi.upm.es/resource/23000391> a ns1:Course ;
    ns1:courseType "Obligatoria"@es ;
    ns1:courseYear 1 ;
    ns1:semester "Segundo semestre"@es ;
    schema:courseCode 23000391 ;
    schema:hasCourseInstance <https://guia-kg.skai.etsisi.upm.es/resource/23000391/2025-26> ;
    schema:name "Electrical Installations And Equipment"@en,
        "Instalaciones Electricas y de Iluminacion"@es ;
    schema:numberOfCredits 3.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/23000391/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/23000391/2025-26/C2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/23000391/2025-26/C5>,
        <https://guia-kg.skai.etsisi.upm.es/resource/23000391/2025-26/K6>,
        <https://guia-kg.skai.etsisi.upm.es/resource/23000391/2025-26/S4> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/23000391/2025-26/didactic_resource/1> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/23000391/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/23000391/2025-26/RA107>,
        <https://guia-kg.skai.etsisi.upm.es/resource/23000391/2025-26/RA109> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/23000391/2025-26/syllabus> ;
    ns1:inpersonHours "38 horas (48.7%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation "La asignatura está relacionada con el ODS 7."@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "84 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/23000391/2025-26/eventSchedule> ;
    schema:description "El objetivo de la asignatura es que el alumno sea capaz de realiza un proyecto eléctrico y de iluminación con acabado profesional. Para ello se imparten sucesivamente talleres sobre iluminación, líneas eléctricas y aparamenta de protección, maniobra y seguridad, siempre en el ámbito de los proyectos de parques y jardines."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/joseluis.garciaf%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/alicia.perdigones%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/joseluis.garciaf%40upm.es> ;
    schema:name "Instalaciones Electricas y de Iluminacion"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000391/2025-26/C2> a ns1:Competency ;
    ns1:competencyCode "C2" ;
    ns1:competencyDescription "Capacidad para describir, organizar y analizar los elementos constitutivos de un problema de jardinería y paisajismo y diseñar estrategias que permitan alcanzar una solución técnica, ambiental y económicamente viable. TIPO: Competencias."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000391/2025-26/C5> a ns1:Competency ;
    ns1:competencyCode "C5" ;
    ns1:competencyDescription "Capacidad de diseñar, calcular y ejecutar todo tipo de instalaciones de riego, iluminación, movimiento de tierras, drenaje y desagüe, en todo tipo de actuaciones paisajísticas y áreas verdes, así como de llevar a cabo su mantenimiento, aplicando incluso las técnicas más complejas y avanzadas. TIPO: Competencias."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000391/2025-26/K6> a ns1:Competency ;
    ns1:competencyCode "K6" ;
    ns1:competencyDescription "Conocer las características y peculiaridades de las empresas y entidades vinculadas a las actividades de jardinería y paisajismo, y cómo organizar el trabajo en equipo y participar en las actuaciones ejecutivas y directivas. TIPO: Conocimientos o contenidos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000391/2025-26/RA107> a ns1:LearningResult ;
    ns1:learningResultCode "RA107" ;
    ns1:learningResultDescription "K6"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000391/2025-26/RA109> a ns1:LearningResult ;
    ns1:learningResultCode "RA109" ;
    ns1:learningResultDescription "S4"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000391/2025-26/S4> a ns1:Competency ;
    ns1:competencyCode "S4" ;
    ns1:competencyDescription "Habilidad de reconocer los principios éticos para la toma de decisiones en el ámbito de la jardinería y el paisajismo, conociendo y aplicando la normativa, con criterios de calidad y considerando las implicaciones sociales, de salud y seguridad, ambientales y económicas. TIPO: Habilidades o destrezas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000391/2025-26/didactic_resource/1> a ns1:DidacticResource ;
    ns1:bibliographyDescription "La asignatura se imparte en el aula de ordenadores de electrotecnia con los programas informáticos adecuados."@es ;
    ns1:bibliographyTitle "Aula de ordenadores de electrotecnia"@es ;
    ns1:bibliographyType "Equipamiento"@es .

