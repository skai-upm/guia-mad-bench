    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/563000111/2025-26/eventSchedule> ;
    schema:description "El objetivo de la asignatura es adquirir las competencias necesarias para la implementación de prototipos de sistemas digitales de control sencillos basados en microprocesadores y lógica programable empleando tarjetas de desarrollo y prototipado rápido."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/pedroluis.castedo%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/pedroluis.castedo%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/roberto.gonzalez%40upm.es> ;
    schema:name "Microcontroladores y Lógica Programable"@es .

