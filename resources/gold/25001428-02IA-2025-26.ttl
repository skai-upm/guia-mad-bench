        <https://guia-kg.skai.etsisi.upm.es/resource/25001428/2025-26/didactic_resource/3>,
        <https://guia-kg.skai.etsisi.upm.es/resource/25001428/2025-26/didactic_resource/4>,
        <https://guia-kg.skai.etsisi.upm.es/resource/25001428/2025-26/didactic_resource/5>,
        <https://guia-kg.skai.etsisi.upm.es/resource/25001428/2025-26/didactic_resource/6> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/25001428/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/25001428/2025-26/RA318>,
        <https://guia-kg.skai.etsisi.upm.es/resource/25001428/2025-26/RA319>,
        <https://guia-kg.skai.etsisi.upm.es/resource/25001428/2025-26/RA320> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/25001428/2025-26/syllabus> ;
    ns1:inpersonHours "53 horas (51%)"@es ;
    ns1:numberOfCredits 4.0 ;
    ns1:otherInformation """Esta asignatura se relaciona con el ODS 7: Energía asequible y no contaminante.
La Comisión de Calidad del Centro en su reunión de 29 de mayo de 2023 acordó aprobar la propuesta de reasignación de competencias transversales en las asignaturas de los Grados en Biotecnología, Ingeniería Alimentaria, Ingeniería Agrícola, Ingeniería Agroambiental, Ciencias Agrarias y Bioeconomía, y en el Máster Universitario en Ingeniería Agronómica.
En virtud de dicho acuerdo esta asignatura ha sido designada como Asignatura NO Punto Control. Esto significa que si bien puede seguir trabajando una o varias competencias transversales que se abordan en distintos puntos y aspectos de la asignatura, dicha formación y evaluación no será objeto de recopilación de evidencias por los sistemas de acreditación de la calidad del Centro."""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "53 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/25001428/2025-26/eventSchedule> ;
    schema:description """La docencia en el aula se basa en el aprendizaje orientado a proyectos, además de clases magistrales sobre los aspectos teóricos.
Se realizarán prácticas en las instalaciones de energía solar térmica y fotovoltaica del departamento. Además se realizarán ejercicios de cálculo orientados al diseño de las instalaciones de suministro de energía.
Cada alumno realizará trabajo personal de asimilación de los contenidos, que integrará en un proyecto final de diseño de una instalación de suministro de energía con fuentes renovables."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/rm.benavente%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/af.almeida%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/ana.gserrano%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/f.ruiz%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/joseluis.garciaf%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/miguelangel.munoz%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/rm.benavente%40upm.es> ;
    schema:name "Energias Renovables"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001428/2025-26/CE58> a ns1:Competency ;
    ns1:competencyCode "CE58" ;
    ns1:competencyDescription "Capacidad para describir, comprender e interpretar los fundamentos de las distintas fuentes de energía renovable en el contexto energético actual y futuro de España y sus aplicaciones e implicaciones en el medio rural"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001428/2025-26/CG16> a ns1:Competency ;
    ns1:competencyCode "CG16" ;
    ns1:competencyDescription "Aplicar conocimientos adquiridos a la práctica de la ingeniería agraria"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001428/2025-26/CG2> a ns1:Competency ;
    ns1:competencyCode "CG2" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar sus conocimientos a su trabajo o vocación de una forma profesional y posean las competencias que suelen demostrarse por medio de la elaboración y defensa de argumentos y la resolución de problemas dentro de su área de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001428/2025-26/RA318> a ns1:LearningResult ;
    ns1:learningResultCode "RA318" ;
    ns1:learningResultDescription "Conocimiento de los fundamentos y elementos básicos de las instalaciones de energías alternativas: energía eólica, minihidráulica, solar térmica y fotovoltaica, biodigestores."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001428/2025-26/RA319> a ns1:LearningResult ;
    ns1:learningResultCode "RA319" ;
    ns1:learningResultDescription "Capacitación para la evaluación económica de las instalaciones con energías alternativas, en comparación con una instalación convencional (caldera o grupo electrógeno)."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001428/2025-26/RA320> a ns1:LearningResult ;
    ns1:learningResultCode "RA320" ;
    ns1:learningResultDescription "Capacitación para integrar esos conocimientos en el diseño y proyecto de una instalación de suministro de energía en el ámbito de la ingeniería agroforestal."@es .

