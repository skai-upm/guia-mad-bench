    schema:name "Diseño y Fabricacion Basado en Montaje"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000071/2025-26/CB6> a ns1:Competency ;
    ns1:competencyCode "CB6" ;
    ns1:competencyDescription "Poseer y comprender conocimientos que aporten una base u oportunidad de ser originales en el desarrollo y/o aplicación de ideas, a menudo en un contexto de investigación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000071/2025-26/CE2> a ns1:Competency ;
    ns1:competencyCode "CE2" ;
    ns1:competencyDescription "Capacidad de gestionar el ciclo de vida del producto"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000071/2025-26/CE3> a ns1:Competency ;
    ns1:competencyCode "CE3" ;
    ns1:competencyDescription "Capacidad de aplicar los conceptos innovadores de las nuevas tendencias en los diseños de producto"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000071/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Capacidad para fomentar, en contextos académicos y profesionales, el avance tecnológico, social o cultural dentro de una sociedad basada en el conocimiento"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000071/2025-26/CG4> a ns1:Competency ;
    ns1:competencyCode "CG4" ;
    ns1:competencyDescription "Conocimiento de los procesos industriales para ser capaz de decidir sobre los criterios adecuados en la fabricación de productos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000071/2025-26/CG5> a ns1:Competency ;
    ns1:competencyCode "CG5" ;
    ns1:competencyDescription "Capacidad de integrar herramientas de representación en los procesos de fabricación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000071/2025-26/CG7> a ns1:Competency ;
    ns1:competencyCode "CG7" ;
    ns1:competencyDescription "Capacidad de integrar metodologías, tecnologías, procesos y herramientas en el campo de la ingeniería y el diseño industrial"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000071/2025-26/RA178> a ns1:LearningResult ;
    ns1:learningResultCode "RA178" ;
    ns1:learningResultDescription "Conocimiento de las alternativas de procesos de unión y montaje aplicables en relación al diseño del producto."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000071/2025-26/RA179> a ns1:LearningResult ;
    ns1:learningResultCode "RA179" ;
    ns1:learningResultDescription "Capacidad de análisis operativo integrado para la toma de decisiones en contexto de ciclo de vida sobre el desarrollo de producto, en sus fases de diseño y fabricación industriales basados en montaje."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000071/2025-26/RA180> a ns1:LearningResult ;
    ns1:learningResultCode "RA180" ;
    ns1:learningResultDescription "Conocimiento de las técnicas actuales de mejora de sistemas de fabricación para la competitividad, aplicadas a istemas de montaje industrial."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000071/2025-26/RA181> a ns1:LearningResult ;
    ns1:learningResultCode "RA181" ;
    ns1:learningResultDescription "Conocimiento de técnicas de simulación de sistemas de fabricación, como herramienta de análisis para la mejora o investigación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000071/2025-26/RA182> a ns1:LearningResult ;
    ns1:learningResultCode "RA182" ;
    ns1:learningResultDescription "Capacidad para analizar las alternbativas y restricciones en el diseño de producto desde la fabricación basada en montaje."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000071/2025-26/RA184> a ns1:LearningResult ;
    ns1:learningResultCode "RA184" ;
    ns1:learningResultDescription "Contribución desde la formación al ODS 12: \"Garantizar modalidades de consumo y producción sostenibles\""@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000071/2025-26/RA185> a ns1:LearningResult ;
