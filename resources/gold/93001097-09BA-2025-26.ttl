    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/93001097/2025-26/eventSchedule> ;
    schema:description """La asignatura Seminarios Profesionales propone la impartición de Seminarios por parte de las profesionales y empresas del sector de la ingeniería de redes y servicios telemáticos, la organización de visitas a empresas y la asistencia a seminarios y presentaciones externas relacionadas con el desarrollo profesional y el mercado laboral en el área de la ingeniería telemática, tales como las organizadas por:
- Evento anual de empleo UPM: Talent UPM
- Foro de empleo y tecnología en ETSIT UPM: Satelec
- El Programa de Emprendimiento UPM, actúaupm.

En general, las actividades propuestas abarcarán distintos aspectos del desarrollo profesional:
- avances tecnológicos y nuevos productos tecnológicos en el área de las redes o los servicios telemáticos, es decir, en relación con cualquiera de las materias del máster
- entrevistas o charlas relacionadas con el emprendimiento
- metodologías de resolución de problemas y trabajo en equipo"""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/luis.bellido%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/luis.bellido%40upm.es> ;
    schema:name "Seminarios Profesionales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93001097/2025-26/CB08> a ns1:Competency ;
    ns1:competencyCode "CB08" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de integrar conocimientos y enfrentarse a la complejidad de formular juicios a partir de una información que, siendo incompleta o limitada, incluya reflexiones sobre las responsabilidades sociales y éticas vinculadas a la aplicación de sus conocimientos y juicios"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93001097/2025-26/CG01> a ns1:Competency ;
    ns1:competencyCode "CG01" ;
    ns1:competencyDescription "Capacidad para conocer y practicar las técnicas y metodologías básicas empleadas en las actividades de innovación en el área de la ingeniería de redes y servicios telemáticos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93001097/2025-26/CG03> a ns1:Competency ;
    ns1:competencyCode "CG03" ;
    ns1:competencyDescription "Capacidad para profundizar en la tendencia a la integración de los sistemas telemáticos, englobando aspectos técnicos, de gestión, sociales, económicos, éticos, etc. y para reflexionar sobre todos los aspectos implicados para formular sus juicios."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93001097/2025-26/RA74> a ns1:LearningResult ;
    ns1:learningResultCode "RA74" ;
    ns1:learningResultDescription "Identificar su perfil profesional dentro del mercado laboral en el área de la ingeniería de redes y servicios telemáticos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93001097/2025-26/RA75> a ns1:LearningResult ;
    ns1:learningResultCode "RA75" ;
    ns1:learningResultDescription "Conocer y ser capaz de formular juicios sobre avances y nuevos productos tecnológicos desarrollados por empresas del sector"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93001097/2025-26/RA76> a ns1:LearningResult ;
    ns1:learningResultCode "RA76" ;
    ns1:learningResultDescription "Conocer y ser capaz de formular juicios sobre iniciativas de emprendimiento en el sector"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93001097/2025-26/RA77> a ns1:LearningResult ;
    ns1:learningResultCode "RA77" ;
    ns1:learningResultDescription "Conocer y ser capaz de formular juicios sobre metodologías de resolución de problemas y trabajo en equipo"@es .

