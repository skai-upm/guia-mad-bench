    schema:name "Plantas de Tratamiento de Minerales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001035/2025-26/CG%201> a ns1:Competency ;
    ns1:competencyCode "CG 1" ;
    ns1:competencyDescription "Conocer y aplicar conocimientos de ciencias y tecnologías básicas a la práctica de la Tecnología Minera."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001035/2025-26/CG%2010> a ns1:Competency ;
