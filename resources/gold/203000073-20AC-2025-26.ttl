    ns1:inpersonHours "105 horas (50.5%)"@es ;
    ns1:numberOfCredits 8.0 ;
    ns1:otherInformation "El Máster en Producción y Sanidad Animal en un Máster Interuniversitario en el que participan la UPM y la UCM. El profesor coordinador de esta asignatura es Luis Miguel Ortega Mora, profesor de la Facultad de Veterinaria de la Universidad Complutense de Madrid. La asignatura se relaciona con el ODS15."@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "105 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/203000073/2025-26/eventSchedule> ;
    schema:description """Sanidad en el vacuno lechero.
Sanidad en el cebo de terneros.
Sanidad en la producción de vaca nodriza y en el ganado de lidia.
Sanidad en el ovino y caprino lechero.
Sanidad en el cebo de corderos.
Sanidad en la producción extensiva de ovino y caprino de carne.
En todos los casos anteriores se tendrá en cuenta el significado e importancia económica y sanitaria de las principales enfermedades transmisibles (exóticas, zoonósicas y productivas) de acuerdo con el grupo de edad, su diagnóstico, control y prevención dentro de un programa integral de medicina preventiva, la exposición de casos clínicos representativos y la legislación aplicable."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/nora.formosorafferty%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/nora.formosorafferty%40upm.es> ;
    schema:name "Sanidad Animal en Rumiantes"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000073/2025-26/CE01> a ns1:Competency ;
    ns1:competencyCode "CE01" ;
    ns1:competencyDescription "Adquirir unos conocimientos y unas destrezas adecuadas en producción y sanidad animal para poder plantear soluciones y resolver las problemáticas inherentes a las explotaciones ganaderas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000073/2025-26/CE02> a ns1:Competency ;
    ns1:competencyCode "CE02" ;
    ns1:competencyDescription "Aplicar conocimientos avanzados acerca de la gestión técnico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000073/2025-26/CE05> a ns1:Competency ;
    ns1:competencyCode "CE05" ;
    ns1:competencyDescription "Dominar los aspectos éticos, legales, medioambientales y los protocolos de bioseguridad, que deben cumplir las empresas pecuarias y los trabajos experimentales realizados en producción animal y en sanidad animal."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000073/2025-26/CE08> a ns1:Competency ;
    ns1:competencyCode "CE08" ;
    ns1:competencyDescription "Conocer las metodologías de investigación disponibles en la producción animal y en la sanidad animal."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000073/2025-26/CE09> a ns1:Competency ;
    ns1:competencyCode "CE09" ;
    ns1:competencyDescription "Saber utilizar las herramientas y técnicas bioinformáticas más actuales a la investigación en producción animal y en sanidad animal."@es .

