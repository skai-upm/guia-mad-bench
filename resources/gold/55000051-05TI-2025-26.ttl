<https://guia-kg.skai.etsisi.upm.es/resource/55000051/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Álgebra lineal numérica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000051/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Métodos directos de resolución de sistemas lineales: eliminación de Gauss y factorización LU. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000051/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "3.3. Fenómeno de Runge. Elección óptima de los nodos de interpolación: nodos de Chebychev. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000051/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "4. Integración numérica."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000051/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "4.1. Fórmulas del rectángulo, del trapecio y de Simpson. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000051/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "4.2. Fórmulas de cuadratura gaussiana: nodos de Legendre. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000051/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "5. Series de Fourier"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000051/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "5.1. Aproximación trigonométrica de funciones periódicas. Series de Fourier. Coeficientes de Fourier.. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000051/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "5.2. Fenómeno de Gibbs. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000051/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "6. Transformada Discreta de Fourier (DFT)"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000051/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "6.1. Definición de la DFT. Motivación a partir de los coeficientes de Fourier. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000051/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "6.2. Matriz de Fourier y DFT. Propiedades de la DFT. Algoritmo FFT. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000051/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Problemas mal condicionados. Número de condición Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000051/2025-26/syllabus/20> a ns1:SyllabusItem ;
    ns1:itemIndex 20 ;
    ns1:syllabusDescription "6.3. Interpolación trigonométrica. Relación con la DFT. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000051/2025-26/syllabus/21> a ns1:SyllabusItem ;
    ns1:itemIndex 21 ;
    ns1:syllabusDescription "7. Transformada de Fourier"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000051/2025-26/syllabus/22> a ns1:SyllabusItem ;
    ns1:itemIndex 22 ;
    ns1:syllabusDescription "7.1. Definición y propiedades. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000051/2025-26/syllabus/23> a ns1:SyllabusItem ;
    ns1:itemIndex 23 ;
    ns1:syllabusDescription "7.2. Teorema del muestreo de Shannon: reconstrucción de señales de banda limitada. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000051/2025-26/syllabus/24> a ns1:SyllabusItem ;
    ns1:itemIndex 24 ;
    ns1:syllabusDescription "7.3. Aplicaciones del análisis de Fourier: diseño de filtros, análisis espectral y compresión de señal. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000051/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "1.3. Métodos iterativos de resolución de sistemas lineales: máximo descenso y gradientes conjugados. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000051/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "2. El problema de mínimos cuadrados"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000051/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "2.1. Soluciones de mínimos cuadrados. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000051/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "2.2. Cálculo mediante: Gram-Schmidt y factorización QR. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000051/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "3. Interpolación polinómica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000051/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "3.1. El problema del condicionamiento de las matrices de Vandermonde Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000051/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "3.2. Fórmulas interpolatorias de Lagrange y de Newton. Sin subniveles"@es .

