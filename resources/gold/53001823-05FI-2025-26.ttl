    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation "La asignatura podría relacionarse con el ODS7 \"Garantizar el acceso a una energía asequible, segura, sostenible y moderna\""@es ;
    ns1:periodEndingMonth "Junio"@es ;
