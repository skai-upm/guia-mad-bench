    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/615000363/2025-26/eventSchedule> ;
    schema:description """El objetivo de la asignatura es familiarizar al alumno con el ciclo de vida de un servicio de TI, estudiando todos los procesos que lo constituyen y que suponen un conjunto de buenas prácticas para la gestión y gobierno de esos servicios y por lo tanto, proporcionar a los administradores de sistemas de TI las mejores herramientas y documentos que les permitan mejorar la calidad de sus servicios, es decir, mejorar la satisfacción del cliente al mismo tiempo que alcanzan los objetivos estratégicos de su organización.

Para ello, el departamento de TI debe ser considerado como un conjunto de procesos estrechamente vinculados. Los departamentos de TI no son las únicas organizaciones que se benefician con el enfoque de las Mejores Prácticas de Gestión de Servicios, ya que éstas consisten en hacer que los departamentos sean conscientes de que la calidad y disponibilidad de las infraestructuras de TI tienen un impacto directo sobre la calidad global de la compañía y los negocios de la misma."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/agustin.yague%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/agustin.yague%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/luis.redondo%40upm.es> ;
    schema:name "Mejores Practicas para Gestion de Servicios"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000363/2025-26/CE1> a ns1:Competency ;
    ns1:competencyCode "CE1" ;
    ns1:competencyDescription "Capacidad de integrar soluciones de Tecnologías de la Información y las Comunicaciones y procesos empresariales para satisfacer las necesidades de información de las organizaciones, permitiéndoles alcanzar sus objetivos de forma efectiva y eficiente, dándoles así ventajas competitivas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000363/2025-26/CE4> a ns1:Competency ;
    ns1:competencyCode "CE4" ;
    ns1:competencyDescription "Capacidad para comprender y aplicar los principios y prácticas de las organizaciones, de forma que puedan ejercer como enlace entre las comunidades técnica y de gestión de una organización y participar activamente en la formación de los usuarios."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000363/2025-26/CE5> a ns1:Competency ;
    ns1:competencyCode "CE5" ;
    ns1:competencyDescription "Capacidad para comprender y aplicar los principios de la evaluación de riesgos y aplicarlos correctamente en la elaboración y ejecución de planes de actuación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000363/2025-26/CE6> a ns1:Competency ;
    ns1:competencyCode "CE6" ;
    ns1:competencyDescription "Capacidad para comprender y aplicar los principios y las técnicas de gestión de la calidad y de la innovación tecnológica en las organizaciones."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000363/2025-26/CT11> a ns1:Competency ;
    ns1:competencyCode "CT11" ;
    ns1:competencyDescription "Liderazgo: Cualidades, actitudes, conocimientos y destrezas que posee un individuo, desenvolviéndose de modo que logra inspirar, generar confianza y credibilidad en un grupo de colaboradores, además del compromiso para el logro de la visión corporativa a través de sinergias, motivaciones y compromisos, y no de manera coercitiva e individualista."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000363/2025-26/CT7> a ns1:Competency ;
    ns1:competencyCode "CT7" ;
    ns1:competencyDescription "Aprendizaje autónomo: El estudiante debe responsabilizarse de su propio aprendizaje, lo que le lleva a utilizar procesos cognitivos de forma estratégica y flexible, en función del objetivo de aprendizaje."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000363/2025-26/RA114> a ns1:LearningResult ;
    ns1:learningResultCode "RA114" ;
    ns1:learningResultDescription "Conoce la importancia estratégica del capital humano."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000363/2025-26/RA134> a ns1:LearningResult ;
    ns1:learningResultCode "RA134" ;
    ns1:learningResultDescription "Conoce y sabe comunicar en qué se basa la cultura de gestión enfocada al cliente en distintas organizaciones."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000363/2025-26/RA135> a ns1:LearningResult ;
    ns1:learningResultCode "RA135" ;
    ns1:learningResultDescription "Conoce y define qué son los Servicios de TI y su ciclo de vida."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000363/2025-26/RA136> a ns1:LearningResult ;
    ns1:learningResultCode "RA136" ;
    ns1:learningResultDescription "Conoce y sabe comunicar la necesidad de un buen gobierno y gestión de los servicios de TI."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000363/2025-26/RA137> a ns1:LearningResult ;
    ns1:learningResultCode "RA137" ;
    ns1:learningResultDescription "Define y distingue las funciones de los distintos roles y competencias en la gestión y gobierno de servicios de TI."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000363/2025-26/RA138> a ns1:LearningResult ;
    ns1:learningResultCode "RA138" ;
    ns1:learningResultDescription "Define y distingue los procesos involucrados en la gestión y gobierno durante el ciclo de vida del Servicio de TI."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000363/2025-26/RA139> a ns1:LearningResult ;
    ns1:learningResultCode "RA139" ;
    ns1:learningResultDescription "Relaciona y aplica los conceptos aprendidos acerca de los procesos de gestión y gobierno de servicios de TI."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000363/2025-26/RA141> a ns1:LearningResult ;
    ns1:learningResultCode "RA141" ;
    ns1:learningResultDescription "Conoce las distintas herramientas que facilitan los procesos estandarizados de gestión y gobierno de servicios de TI en la organización."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000363/2025-26/RA142> a ns1:LearningResult ;
    ns1:learningResultCode "RA142" ;
    ns1:learningResultDescription "Conoce y relaciona los conceptos básicos relativos al gobierno, la gestión, los servicios TI."@es .

