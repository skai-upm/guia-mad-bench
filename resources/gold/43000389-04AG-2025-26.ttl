    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/43000389/2025-26/eventSchedule> ;
    schema:description """La asignatura profundiza en algunos temas fundamentales para el ingeniero especialista en el proyecto de estructuras y puentes metálicos o mixtos, que son los siguientes:
- Redistribuciones de esfuerzos en estructuras mixtas y de hormigón: fisuración, efectos reológicos diferidos y movimientos de apoyos, tanto a nivel de sección como de estructura.
- Dimensionamiento de estructuras con paneles esbeltos y rigidizados frente a abolladura e inestabilidades locales.
- Diseño frente a fatiga de estructuras metálicas.
- Tipologías habituales en puentes metálicos y mixtos de carretera y ferrocarril.
Los métodos y planteamientos que se estudian en la asignatura colaboran muy favorablemente a la formación global del ingeniero de estructuras, más allá del ámbito de las estructuras metálicas o mixtas, y suponen un complemento excelente a la formación básica que pudiera haberse adquirido en unos estudios de grado."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/javier.pascual%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/alvaro.serrano%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/javier.pascual%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/luis.matute%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/miguel.ortega%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/tomasluis.ripa%40upm.es> ;
    schema:name "Analisis y Diseño Avanzado de Estructuras de Acero y Mixtas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000389/2025-26/CE22> a ns1:Competency ;
    ns1:competencyCode "CE22" ;
    ns1:competencyDescription "Conocimiento y capacidad para el análisis estructural mediante la aplicación de los métodos y programas de diseño y cálculo avanzado de estructuras, a partir del conocimiento y comprensión de las solicitaciones y su aplicación a las tipologías estructurales de la ingeniería civil. Capacidad para realizar evaluaciones de integridad estructural."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000389/2025-26/CE38> a ns1:Competency ;
    ns1:competencyCode "CE38" ;
    ns1:competencyDescription "Capacidad para integrar y aplicar los conocimientos técnicos en asesoría, análisis, diseño y modelización físico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000389/2025-26/CGP11> a ns1:Competency ;
    ns1:competencyCode "CGP11" ;
    ns1:competencyDescription "Capacidad para el proyecto, ejecución e inspección de estructuras (puentes, edificaciones, etc.), de obras de cimentación y de obras subterráneas de uso civil (túneles, aparcamientos), y el diagnóstico sobre su integridad. Incorpora las competencias CB6, CB7 y CB8."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000389/2025-26/RA179> a ns1:LearningResult ;
    ns1:learningResultCode "RA179" ;
    ns1:learningResultDescription "Aplica la normativa comunitaria para el cálculo de detalles constructivos en estructuras metálicas y mixtas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000389/2025-26/RA220> a ns1:LearningResult ;
    ns1:learningResultCode "RA220" ;
    ns1:learningResultDescription "Concibe, proyecta, construye y mantiene estructuras metálicas y mixtas a partir de los fundamentos de su comportamiento mecánico y resistente."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000389/2025-26/RA221> a ns1:LearningResult ;
    ns1:learningResultCode "RA221" ;
    ns1:learningResultDescription "Asume los principios de incertidumbre y riesgo en la aplicación de la normativa comunitaria de estructuras de hormigón armado y de estructuras metálicas y mixtas."@es .

