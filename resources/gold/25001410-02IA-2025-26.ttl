<https://guia-kg.skai.etsisi.upm.es/resource/25001410/2025-26/CE62> a ns1:Competency ;
    ns1:competencyCode "CE62" ;
    ns1:competencyDescription "Capacidad para diseñar instalaciones y procesos para la valorización de los diferentes tipos de residuos orgánicos, desde el punto de vista energético, económica y medioambiental."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001410/2025-26/CG16> a ns1:Competency ;
    ns1:competencyCode "CG16" ;
    ns1:competencyDescription "Aplicar conocimientos adquiridos a la práctica de la ingeniería agraria"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001410/2025-26/CG2> a ns1:Competency ;
    ns1:competencyCode "CG2" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar sus conocimientos a su trabajo o vocación de una forma profesional y posean las competencias que suelen demostrarse por medio de la elaboración y defensa de argumentos y la resolución de problemas dentro de su área de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001410/2025-26/RA325> a ns1:LearningResult ;
    ns1:learningResultCode "RA325" ;
    ns1:learningResultDescription "Conocimiento de los fundamentos y elementos básicos de las instalaciones para procesado y valorización de residuos agrarios: digestión anaerobia de residuos orgánicos en digestores, uso de residuos orgánicos vegetales en alimentación de ganado, producción de compost, reciclado de plásticos, y otros tipos de instalaciones relacionadas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001410/2025-26/RA326> a ns1:LearningResult ;
    ns1:learningResultCode "RA326" ;
    ns1:learningResultDescription "Capacitación para integrar esos conocimientos en el diseño y proyecto de una instalación de procesado y valorización en el ámbito de la ingeniería agroforestal."@es .

