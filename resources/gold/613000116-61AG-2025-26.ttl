    ns1:competencyCode "CE01" ;
    ns1:competencyDescription "Capacidad para la integración de tecnologías y sistemas propios del software de Sistemas Distribuidos y Empotrados en contextos multidisciplinares."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000116/2025-26/CE07> a ns1:Competency ;
    ns1:competencyCode "CE07" ;
    ns1:competencyDescription "Capacidad de diseñar y desarrollar aplicaciones y servicios informáticos en sistemas móviles, de tiempo real, empotrados y ubicuos."@es .

