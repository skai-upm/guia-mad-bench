<https://guia-kg.skai.etsisi.upm.es/resource/595000135/2025-26/CE%20SO01> a ns1:Competency ;
    ns1:competencyCode "CE SO01" ;
    ns1:competencyDescription "Capacidad de construir, explotar y gestionar servicios y aplicaciones de telecomunicaciones, entendidas éstas como sistemas de captación, tratamiento analógico y digital, codificación, transporte, representación, procesado, almacenamiento, reproducción, gestión y presentación de servicios audiovisuales e información multimedia."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000135/2025-26/CE%20SO02> a ns1:Competency ;
    ns1:competencyCode "CE SO02" ;
    ns1:competencyDescription "Capacidad de analizar, especificar, realizar y mantener sistemas, equipos, cabeceras e instalaciones de televisión, audio y vídeo, tanto en entornos fijos como móviles."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000135/2025-26/CE%20SO05> a ns1:Competency ;
    ns1:competencyCode "CE SO05" ;
    ns1:competencyDescription "Capacidad para crear, codificar, gestionar, difundir y distribuir contenidos multimedia, atendiendo a criterios de usabilidad y accesibilidad de los servicios audiovisuales, de difusión e interactivos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000135/2025-26/CE%20SO06> a ns1:Competency ;
    ns1:competencyCode "CE SO06" ;
    ns1:competencyDescription "Capacidad para realizar proyectos en el ámbito de las tecnologías específicas de la Ingeniería de Telecomunicación, de naturaleza profesional en que se sinteticen e integren las competencias adquiridas en las enseñanzas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000135/2025-26/CE%20TEL01> a ns1:Competency ;
    ns1:competencyCode "CE TEL01" ;
    ns1:competencyDescription "Capacidad para aprender de manera autónoma nuevos conocimientos y técnicas adecuados para la concepción, el desarrollo o la explotación de sistemas y servicios de telecomunicación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000135/2025-26/CE%20TEL04> a ns1:Competency ;
    ns1:competencyCode "CE TEL04" ;
    ns1:competencyDescription "Capacidad de analizar y especificar los parámetros fundamentales de un sistema de comunicaciones."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000135/2025-26/CE%20TEL14> a ns1:Competency ;
    ns1:competencyCode "CE TEL14" ;
    ns1:competencyDescription "Capacidad de diferenciar los conceptos de redes de acceso y transporte, redes de conmutación de circuitos y de paquetes, redes fijas y móviles, así como los sistemas y aplicaciones de red distribuidos, servicios de voz, datos, audio, video y servicios interactivos y multimedia."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000135/2025-26/CE%20TEL16> a ns1:Competency ;
    ns1:competencyCode "CE TEL16" ;
    ns1:competencyDescription "Conocimiento de la normativa y la regulación de las telecomunicaciones en los ámbitos nacional, europeo e internacional."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000135/2025-26/CG%2002> a ns1:Competency ;
    ns1:competencyCode "CG 02" ;
    ns1:competencyDescription "Capacidad de búsqueda y selección de información, de razonamiento crítico y de elaboración y defensa de argumentos dentro del área."@es .

