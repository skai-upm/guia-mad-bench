        <https://guia-kg.skai.etsisi.upm.es/resource/33000716/2025-26/syllabus/8>,
        <https://guia-kg.skai.etsisi.upm.es/resource/33000716/2025-26/syllabus/9> .

<https://guia-kg.skai.etsisi.upm.es/resource/33000716/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Caracterización Tectónica del proyecto de arquitectura. Definición de la relación como solución integrada de Geometría, Estructura y Forma constructiva. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000716/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "2. Elección, Identificación y trazado de las Tipología Estructural, Constructiva y de Instalaciones. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000716/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "10.1. .-Proyectos de Construcción .-Gestión del Alcance .-Requisitos de Cliente .-Estructura de Desglose de Trabajo EDT .-Gestión del Tiempo .-Cronograma y Planificación .-Transformación Digital de la Construcción Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000716/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "10.2. .-Proyectos Complejos en Construcción .-Principios Gestión Proyectos PMBok 7ed .-Ingeniería Concurrente .-Metodologías Ágiles .-Scrum .-Filosofía Lean en Construcción Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000716/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "11. Industrialización y DfMA"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000716/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "11.1. .-Industrialización como proceso constructivo .-Diseño para fabricación y ensamblaje .-Digitalización de la industrialización .-Gestión de los datos .-Prototipos .-Control de ejecución y eficiencia Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000716/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "3. Elección y designación de materiales. Dimensionamiento y validación de la compatibilidad constructiva de los elementos proyectados Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000716/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "4. Diseño constructivo de estructura y envolventes. Soluciones constructivas de coordinación y compatibilidad Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000716/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "5. Escalas y Dimensionamiento. La solución de las superficies, escala y tamaño. Materiales y elementos constructivos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000716/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "6. Instalaciones y Acondicionamiento. La inserción de las instalaciones en el proyecto de arquitectura. Elección de sistemas y trazado de instalaciones e implantación de maquinaria. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000716/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "7. Comportamiento Energético. Diseño de Sistemas constructivos para la validación del comportamiento energético. Sistemas activos y pasivos Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000716/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "8. Planos de definición geométrica y constructiva de la solución proyectada Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000716/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "9. Sostenibilidad y eficiencia energética de la edificación proyectada Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000716/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "10. Gestión de proyectos"@es .

