    ns1:learningResultCode "RA31" ;
    ns1:learningResultDescription "Conocer las tecnologias y el funcionamiento de los componentes específicos de aerogeneradores"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000555/2025-26/RA32> a ns1:LearningResult ;
    ns1:learningResultCode "RA32" ;
    ns1:learningResultDescription "Conocer las tecnologías específicas aplicadas a las instalaciones de Parques Eólicos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000555/2025-26/RA33> a ns1:LearningResult ;
    ns1:learningResultCode "RA33" ;
    ns1:learningResultDescription "Conocer aspectos de diseño y de control específico para los sistemas eléctricos de Aerogeneradores"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000555/2025-26/RA34> a ns1:LearningResult ;
    ns1:learningResultCode "RA34" ;
    ns1:learningResultDescription "Evaluar y desarrollar sistemas de acondicionamiento de potencia de aerogeneradores y parques eólicos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000555/2025-26/RA35> a ns1:LearningResult ;
    ns1:learningResultCode "RA35" ;
    ns1:learningResultDescription "Conocer los condicionantes de inserción de parques eólicos en las redes eléctricas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000555/2025-26/RA36> a ns1:LearningResult ;
    ns1:learningResultCode "RA36" ;
    ns1:learningResultDescription "Capacidad para evaluar cualitativamente la integración de Generación Eólica en las redes eléctricas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000555/2025-26/RA37> a ns1:LearningResult ;
    ns1:learningResultCode "RA37" ;
    ns1:learningResultDescription "Capacidad de analizar la viabilidad energética y económica de sistemas eólicos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000555/2025-26/RA38> a ns1:LearningResult ;
    ns1:learningResultCode "RA38" ;
    ns1:learningResultDescription "Conocer la situación actual y perspectivas de futuro de la energía eó"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000555/2025-26/RA39> a ns1:LearningResult ;
    ns1:learningResultCode "RA39" ;
    ns1:learningResultDescription "Capacidad para aplicar los conocimientos adquiridos a la resolución de problemas multidisciplinares en el entorno de las energía eólica."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000555/2025-26/RA40> a ns1:LearningResult ;
    ns1:learningResultCode "RA40" ;
    ns1:learningResultDescription "Capacidad para la integración de conocimientos multidisciplinares para la toma de decisiones sobre componentes y sistemas de energía eólica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000555/2025-26/RA41> a ns1:LearningResult ;
    ns1:learningResultCode "RA41" ;
    ns1:learningResultDescription "Capacidad de análisis e interpretación del comportamiento eléctrico de los sistemas de energía eólica a partir de modelos teóricos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000555/2025-26/RA42> a ns1:LearningResult ;
    ns1:learningResultCode "RA42" ;
    ns1:learningResultDescription "Capacidad para el autoaprendizaje y la formación continua en el ámbito de las energía eólica y su integración en el contexto general de la problemática de abastecimiento de Energía Eléctrica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000555/2025-26/RA43> a ns1:LearningResult ;
    ns1:learningResultCode "RA43" ;
    ns1:learningResultDescription "Capacidad para contribuir al desarrollo e innovación tecnológicos en sistemas de energia eólica."@es .

