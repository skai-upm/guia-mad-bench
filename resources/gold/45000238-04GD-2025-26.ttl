<https://guia-kg.skai.etsisi.upm.es/resource/45000238/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/45000238/2025-26/30AD.%20E03>,
        <https://guia-kg.skai.etsisi.upm.es/resource/45000238/2025-26/30AD.%20G01>,
        <https://guia-kg.skai.etsisi.upm.es/resource/45000238/2025-26/30AD.%20G02>,
        <https://guia-kg.skai.etsisi.upm.es/resource/45000238/2025-26/30AD.%20G05>,
        <https://guia-kg.skai.etsisi.upm.es/resource/45000238/2025-26/30AD.%20G10> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/45000238/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/45000238/2025-26/didactic_resource/10>,
