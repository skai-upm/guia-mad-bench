    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/85003918/2025-26/syllabus> ;
    ns1:inpersonHours "38 horas (48.7%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation "La asignatura se relaciona con el ODS 9 y ODS 12"@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "38 horas"@es ;
    schema:activitiesWorkload "99.99%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/85003918/2025-26/eventSchedule> ;
    schema:description "La asignatura de Corrosión y Protección tiene como objetivo introducir al estudiante en el estudio de la corrosión de los metales y en las estrategias más eficaces para su prevención y control, un ámbito de gran relevancia en el ejercicio profesional de la ingeniería, y especialmente crítico en el sector naval. A lo largo del curso, se abordan en primer lugar los fundamentos científicos que explican los procesos de corrosión, proporcionando una base sólida para comprender los mecanismos electroquímicos implicados. Posteriormente, se analizan las principales formas de corrosión que pueden afectar a los materiales metálicos en distintos entornos. Finalmente, se estudian los métodos de protección disponibles, tanto preventivos como correctivos, con el fin de evitar el deterioro prematuro de los componentes metálicos y garantizar su integridad estructural y funcional a lo largo del tiempo."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/monica.carboneras%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/monica.carboneras%40upm.es> ;
    schema:name "Corrosión y Protección"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003918/2025-26/CE%208> a ns1:Competency ;
    ns1:competencyCode "CE 8" ;
    ns1:competencyDescription "Conocimiento de la ciencia y tecnología de materiales y capacidad para su selección y para la evaluación de su comportamiento."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003918/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Capacidad para la redacción, firma y desarrollo de proyectos en el ámbito de la ingeniería naval y oceánica, de acuerdo con los conocimientos adquiridos según lo establecido en el Apartado 3.3 de esta memoria, que formen parte de las actividades de construcción, montaje, transformación, explotación, mantenimiento, reparación, o desguace de buques, embarcaciones y artefactos marinos, así como las de fabricación, instalación, montaje o explotación de los equipos y sistemas navales y oceánicos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003918/2025-26/CG2> a ns1:Competency ;
    ns1:competencyCode "CG2" ;
    ns1:competencyDescription "Capacidad necesaria para la dirección de las actividades objeto de los proyectos de Arquitectura Naval."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003918/2025-26/RA27> a ns1:LearningResult ;
    ns1:learningResultCode "RA27" ;
    ns1:learningResultDescription "Conocer el mecanismo de la corrosión y su importancia en el ámbito naval."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003918/2025-26/RA28> a ns1:LearningResult ;
    ns1:learningResultCode "RA28" ;
    ns1:learningResultDescription "Comprender y manejar los sistemas de prevención y lucha contra la corrosión marina."@es .

