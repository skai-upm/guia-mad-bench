    schema:activitiesWorkload "115%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/53001236/2025-26/eventSchedule> ;
    schema:description """[ES] La asignatura se plantea como una continuación de las asignaturas de Electrónica Analógica que se imparten en cursos de grado y máster de diferentes titulaciones. A partir de los conocimientos fundamentales de electrónica analógica, se plantea la aplicación de los circuitos teóricos a sistemas reales de instrumentación. El principal objetivo de esta asignatura es el diseño de la parte analógica de los sistemas de instrumentación.
[EN] The subject is proposed as a continuation of the Analog Electronics subjects taught in bachelor's and master's courses in different academic programs. It is based on the fundamental principles of analog electronics and the application of these concepts of theoretical circuits to real Instrumentation systems. The main objective of this subject is the design of the analog part of instrumentation systems."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/regina.ramos%40upm.es> ;
    schema:inLanguage "Inglés/Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/regina.ramos%40upm.es> ;
    schema:name "Instrumentacion Electronica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001236/2025-26/%28a%29> a ns1:Competency ;
    ns1:competencyCode "(a)" ;
    ns1:competencyDescription "APLICA. Habilidad para aplicar conocimientos científicos, matemáticos y tecnológicos en sistemas relacionados con la práctica de la ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001236/2025-26/%28b%29> a ns1:Competency ;
    ns1:competencyCode "(b)" ;
    ns1:competencyDescription "EXPERIMENTA. Habilidad para diseñar y realizar experimentos así como analizar e interpretar datos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001236/2025-26/%28c%29> a ns1:Competency ;
    ns1:competencyCode "(c)" ;
    ns1:competencyDescription "DISEÑA. Habilidad para diseñar un sistema, componente o proceso que alcance los requisitos deseados teniendo en cuenta restricciones realistas tales como las económicas, medioambientales, sociales, políticas, éticas, de salud y seguridad, de fabricación y de sostenibilidad."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001236/2025-26/%28d%29> a ns1:Competency ;
    ns1:competencyCode "(d)" ;
    ns1:competencyDescription "TRABAJA EN EQUIPO. Habilidad para trabajar en equipos multidisciplinares."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001236/2025-26/%28e%29> a ns1:Competency ;
    ns1:competencyCode "(e)" ;
    ns1:competencyDescription "RESUELVE. Habilidad para identificar, formular y resolver problemas de ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001236/2025-26/%28g%29> a ns1:Competency ;
    ns1:competencyCode "(g)" ;
    ns1:competencyDescription "COMUNICA. Habilidad para comunicar eficazmente."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001236/2025-26/%28i%29> a ns1:Competency ;
    ns1:competencyCode "(i)" ;
    ns1:competencyDescription "SE ACTUALIZA. Reconocimiento de la necesidad y la habilidad para comprometerse al aprendizaje continuo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001236/2025-26/%28k%29> a ns1:Competency ;
    ns1:competencyCode "(k)" ;
    ns1:competencyDescription "USA HERRAMIENTAS. Habilidad para usar las técnicas, destrezas y herramientas ingenieriles modernas necesarias para la práctica de la ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001236/2025-26/%28n%29> a ns1:Competency ;
