    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Sistemas termodinámicos, energía interna, calor y trabajo. El primer principio; equilibrio térmico; ecuaciones de estado. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000105/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "3.2. Igualdad de Gibbs-Duhem Sin subniveles"@es .

