    ns1:itemIndex 11 ;
    ns1:syllabusDescription "3.3. Modelos avanzados y condiciones para el equilibrio Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000105/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "3.4. Disoluciones ideales, reales y diluidas Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000105/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "3.5. Equilibrio líquido-vapor Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000105/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "3.6. Diagramas g-x Sin subniveles"@es .

