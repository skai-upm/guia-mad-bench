    ns1:itemIndex 21 ;
    ns1:syllabusDescription "4.1.1. Definición de fórmula. Árbol estructural. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000228/2025-26/syllabus/22> a ns1:SyllabusItem ;
    ns1:itemIndex 22 ;
    ns1:syllabusDescription "4.1.2. Semántica. Valor veritativo de una fórmula. Modelos. Clasificación de fórmulas. Sin subniveles"@es .

