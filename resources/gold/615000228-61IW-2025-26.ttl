    ns1:itemIndex 10 ;
    ns1:syllabusDescription "2.6. Congruencias en Z. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000228/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "2.7. Aritmética en Zn. Divisores de cero y elementos inversibles. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000228/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "2.8. Teoremas de Euler, Fermat y Wilson. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000228/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "2.9. Ecuaciones en congruencias. Ecuaciones lineales. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000228/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "2.10. Criptografía RSA. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000228/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "3. COMBINATORIA"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000228/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "3.1. Técnicas básicas de recuento: Principios de adición, multiplicación, inclusión-exclusión y complementario. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000228/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "3.2. Selecciones sobre conjuntos: variaciones, permutaciones y combinaciones. Selecciones con repetición y sin repetición. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000228/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "3.3. Coeficientes binomiales. Sin subniveles"@es .

