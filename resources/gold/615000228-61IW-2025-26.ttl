    ns1:itemIndex 24 ;
    ns1:syllabusDescription "4.3. Estructuras deductivas. Reglas de inferencia. Métodos de demostración. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000228/2025-26/syllabus/25> a ns1:SyllabusItem ;
    ns1:itemIndex 25 ;
    ns1:syllabusDescription "4.4. Sintaxis y semántica de la lógica de predicados. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000228/2025-26/syllabus/26> a ns1:SyllabusItem ;
    ns1:itemIndex 26 ;
    ns1:syllabusDescription "4.5. Equivalencias. Extensión del Método del tableau. Sin subniveles"@es .

