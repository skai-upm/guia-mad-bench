    ns1:itemIndex 33 ;
    ns1:syllabusDescription "6.1. Conceptos básicos sobre grafos: grado de un vértice, grafo regular, bipartito, subgrafos, isomorfismo, recorridos, conectividad. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000228/2025-26/syllabus/34> a ns1:SyllabusItem ;
