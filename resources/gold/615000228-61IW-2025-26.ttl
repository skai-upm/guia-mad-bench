    ns1:itemIndex 27 ;
    ns1:syllabusDescription "4.6. Estructuras deductivas. Introducción a las Reglas de inferencia. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000228/2025-26/syllabus/28> a ns1:SyllabusItem ;
    ns1:itemIndex 28 ;
    ns1:syllabusDescription "5. RELACIONES DE ORDEN"@es .

