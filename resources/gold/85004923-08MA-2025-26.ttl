<https://guia-kg.skai.etsisi.upm.es/resource/85004923/2025-26/CB2> a ns1:Competency ;
    ns1:competencyCode "CB2" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar sus conocimientos a su trabajo o vocación de una forma profesional y posean las competencias que suelen demostrarse por medio de la elaboración y defensa de argumentos y la resolución de problemas dentro de su área de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85004923/2025-26/CE12> a ns1:Competency ;
    ns1:competencyCode "CE12" ;
    ns1:competencyDescription "Conocimiento de la elasticidad y resistencia de materiales y capacidad para realizar cálculos de elementos sometidos a solicitaciones diversas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85004923/2025-26/CE21> a ns1:Competency ;
    ns1:competencyCode "CE21" ;
    ns1:competencyDescription "Conocimiento de las máquinas eléctricas y de los sistemas eléctricos navales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85004923/2025-26/CE25> a ns1:Competency ;
    ns1:competencyCode "CE25" ;
    ns1:competencyDescription "Conocimiento de los procesos de fabricación mecánica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85004923/2025-26/CE26> a ns1:Competency ;
    ns1:competencyCode "CE26" ;
    ns1:competencyDescription "Conocimiento de los procesos de montaje a bordo de máquinas equipos y sistemas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85004923/2025-26/RA206> a ns1:LearningResult ;
    ns1:learningResultCode "RA206" ;
    ns1:learningResultDescription "Conocer los distintos sistemas de protección del buque contra la corrosión en el medio marino y su proceso de aplicación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85004923/2025-26/RA207> a ns1:LearningResult ;
    ns1:learningResultCode "RA207" ;
    ns1:learningResultDescription "Conocer las fases, hitos más destacados y etapas del proceso de construcción del buque"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85004923/2025-26/RA208> a ns1:LearningResult ;
    ns1:learningResultCode "RA208" ;
    ns1:learningResultDescription "Conocer los distintos sistemas de varada y los procesos aplicados en la reparación y transformación de los buques"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85004923/2025-26/RA209> a ns1:LearningResult ;
    ns1:learningResultCode "RA209" ;
    ns1:learningResultDescription "Conocer la normativa aplicable en la Construcción Naval"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85004923/2025-26/RA210> a ns1:LearningResult ;
    ns1:learningResultCode "RA210" ;
    ns1:learningResultDescription "Conocer los agentes y autoridades intervinientes en la Construcción Naval"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85004923/2025-26/RA211> a ns1:LearningResult ;
    ns1:learningResultCode "RA211" ;
    ns1:learningResultDescription "Conocer el proceso de construcción en los astilleros, sus características y evolución"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85004923/2025-26/RA212> a ns1:LearningResult ;
    ns1:learningResultCode "RA212" ;
    ns1:learningResultDescription "Conocer la documentación, materiales, medios de producción, procesos y tecnologías empleadas en las distintas fases de la construcción"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85004923/2025-26/RA213> a ns1:LearningResult ;
    ns1:learningResultCode "RA213" ;
    ns1:learningResultDescription "Conocer los procedimientos de inspección, garantía de la calidad y el proceso de pruebas y entrega"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85004923/2025-26/RA214> a ns1:LearningResult ;
    ns1:learningResultCode "RA214" ;
    ns1:learningResultDescription "Conocer los sistemas de puesta a flote y su cálculo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85004923/2025-26/RA215> a ns1:LearningResult ;
    ns1:learningResultCode "RA215" ;
    ns1:learningResultDescription "Conocer los métodos más relevantes aplicados en la mejora de los procesos y los modelos de simulación de los procesos constructivos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85004923/2025-26/RA57> a ns1:LearningResult ;
    ns1:learningResultCode "RA57" ;
    ns1:learningResultDescription "Conocer y distinguir los agentes intervinientes en el proceso de la Construcción Naval"@es .

