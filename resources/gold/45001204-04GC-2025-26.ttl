        <https://guia-kg.skai.etsisi.upm.es/resource/roberto.gil%40upm.es> ;
    schema:name "Geologia"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001204/2025-26/CM15.1> a ns1:Competency ;
    ns1:competencyCode "CM15.1" ;
    ns1:competencyDescription "Conocimientos básicos de geología y morfología del terreno (Geodinámica externa e interna, Petrología, Mineralogía, Paleontología y Geología histórica) y capacidad de aplicación a problemas de ingeniería. Conocimientos básicos de climatología y su relación con la ingeniería"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001204/2025-26/CM15.2> a ns1:Competency ;
    ns1:competencyCode "CM15.2" ;
    ns1:competencyDescription "Comprensión de la interacción entre el medio geológico y las obras públicas y capacidad de predicción de los condicionamientos que el medio geológico impone a la viabilidad, diseño, construcción y explotación de las obras públicas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001204/2025-26/CT3> a ns1:Competency ;
    ns1:competencyCode "CT3" ;
    ns1:competencyDescription "Capacidad de actuar con efectividad como miembro de equipos interdisciplinares. Desarrolla la competencia transversal 5ª de la normativa UPM."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001204/2025-26/CT9> a ns1:Competency ;
    ns1:competencyCode "CT9" ;
    ns1:competencyDescription "Capacidad de diseñar, analizar e interpretar experimentos relevantes en ingeniería civil."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001204/2025-26/RA24> a ns1:LearningResult ;
    ns1:learningResultCode "RA24" ;
    ns1:learningResultDescription "Aplica los conceptos y principios de la Geología y Morfología del terreno y de la Climatología a problemas de ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001204/2025-26/RA25> a ns1:LearningResult ;
    ns1:learningResultCode "RA25" ;
    ns1:learningResultDescription "Predice racionalmente los condicionamientos que el medio geológico impone a la viabilidad, diseño, construcción y explotación de las obras públicas, a partir de la interacción mutua."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001204/2025-26/RA26> a ns1:LearningResult ;
    ns1:learningResultCode "RA26" ;
    ns1:learningResultDescription "Aplica los métodos experimentales de Geología relevantes en ingeniería civil."@es .

