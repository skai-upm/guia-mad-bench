<https://guia-kg.skai.etsisi.upm.es/resource/45001204/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Introducción"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001204/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Presentación de la asignatura Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001204/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "3.3. Minerales pétreos no silicatados. Minerales metálicos. Minerales energéticos Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001204/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "3.4. Petrología de Rocas Ígneas Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001204/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "3.5. Petrología de Rocas Sedimentarias Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001204/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "3.6. Petrología de Rocas Metamórficas Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001204/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "4. Climatología y Geodinámica Externa"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001204/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "4.1. La atmósfera terrestre y su dinámica. Precipitación, masas de aire, borrascas. Clasificación de los climas y regimenes climáticos. El agua en el suelo y balance hídrico. Tipos de climas Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001204/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "4.2. Climatología, relación con riesgos naturales e Ingeniería del Terreno.Clima de España Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001204/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "4.3. Geomorfología. El ciclo externo. Procesos y formas. La meteorización. Modelado. El Paisaje. Importancia y significado para las obras públicas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001204/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "4.4. Glaciarismo y periglaciarismo. Glaciarismo y periglaciarismo. El glaciarismo cuaternario y actual en España. Materiales y consecuencias en las obras I Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001204/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "4.5. Inestabilidades de ladera. Causas y consecuencias. Tipología: desprendimientos, deslizamientos rotacionales, etc. Prevención, sistemas de control y corrección. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001204/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Tipología de Obras Públicas Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001204/2025-26/syllabus/20> a ns1:SyllabusItem ;
    ns1:itemIndex 20 ;
    ns1:syllabusDescription "4.6. Los ríos Redes fluviales. Acción fluvial. Perfiles longitudinales. Capturas fluviales. Terrazas fluviales. Torrentes. Materiales y consecuencias para la ingeniería Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001204/2025-26/syllabus/21> a ns1:SyllabusItem ;
    ns1:itemIndex 21 ;
    ns1:syllabusDescription "4.7. Lagos. Acción del mar. Acción del viento. Acción biológica Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001204/2025-26/syllabus/22> a ns1:SyllabusItem ;
    ns1:itemIndex 22 ;
    ns1:syllabusDescription "5. Paleontología y Geología Histórica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001204/2025-26/syllabus/23> a ns1:SyllabusItem ;
    ns1:itemIndex 23 ;
    ns1:syllabusDescription "5.1. Los fósiles. Su valor estratigráfico. La evolución. El fósil en los problemas de Geología Aplicada. Micropaleontología. Taxonomía paleontológica. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001204/2025-26/syllabus/24> a ns1:SyllabusItem ;
    ns1:itemIndex 24 ;
    ns1:syllabusDescription "5.2. Geología histórica. Generalidades. Cronología relativa y absoluta. Divisiones crono estratigráficas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001204/2025-26/syllabus/25> a ns1:SyllabusItem ;
    ns1:itemIndex 25 ;
    ns1:syllabusDescription "5.3. Las distintas eras geológicas. Era Arcaica. Paleozoico. Era Arcaica. Paleozoico: definición y límites. Paleogeografía y divisiones. Facies, fauna y gea. Paisaje. Materiales y obras en cada sistema. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001204/2025-26/syllabus/26> a ns1:SyllabusItem ;
    ns1:itemIndex 26 ;
    ns1:syllabusDescription "5.4. El Mesozoico y el Cenozoico. Triásico, Jurásico, Cretácico, Paleógeno y Neógeno. Definición y límites. Paleogeografía. Tectónica. Facies, fauna y gea. Paisaje. Materiales y obras en cada sistema. Presencia en España. Aspectos de aplicación ingenieril. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001204/2025-26/syllabus/27> a ns1:SyllabusItem ;
    ns1:itemIndex 27 ;
    ns1:syllabusDescription "5.5. El Cuaternario. Definición y división del Cuaternario. Sedimentos. Glaciaciones. Terrazas fluviales. Aspectos de aplicación ingenieril Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001204/2025-26/syllabus/28> a ns1:SyllabusItem ;
    ns1:itemIndex 28 ;
    ns1:syllabusDescription "5.6. Geología de España. Fisiografía. Constitución geológica. Tectónica e historia geológica. Baleares y Canarias Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001204/2025-26/syllabus/29> a ns1:SyllabusItem ;
    ns1:itemIndex 29 ;
    ns1:syllabusDescription "6. Energía y Recursos Minerales Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001204/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "2. Geodinámica Interna"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001204/2025-26/syllabus/30> a ns1:SyllabusItem ;
    ns1:itemIndex 30 ;
    ns1:syllabusDescription "7. Prácticas de Laboratorio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001204/2025-26/syllabus/31> a ns1:SyllabusItem ;
    ns1:itemIndex 31 ;
    ns1:syllabusDescription "7.1. Climatología. Determinación de los climas de Koppen y de diagramas bioclimáticos. Cálculo de balances hidráulicos Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001204/2025-26/syllabus/32> a ns1:SyllabusItem ;
    ns1:itemIndex 32 ;
    ns1:syllabusDescription "7.2. Mineralogía Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001204/2025-26/syllabus/33> a ns1:SyllabusItem ;
    ns1:itemIndex 33 ;
    ns1:syllabusDescription "7.3. Petrología I Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001204/2025-26/syllabus/34> a ns1:SyllabusItem ;
    ns1:itemIndex 34 ;
    ns1:syllabusDescription "7.4. Petrología II Sin subniveles"@es .

