    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/93001007/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/93001007/2025-26/RA11>,
        <https://guia-kg.skai.etsisi.upm.es/resource/93001007/2025-26/RA27>,
        <https://guia-kg.skai.etsisi.upm.es/resource/93001007/2025-26/RA28> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/93001007/2025-26/syllabus> ;
    ns1:inpersonHours "51 horas (43.6%)"@es ;
    ns1:numberOfCredits 4.5 ;
    ns1:otherInformation """El cronograma, si bien está ajustado a la planificación estimada, debe entenderse de forma orientativa ya que, según los avances del grupo en las distintas prácticas, se podrán realizar ajustes durante el curso.
La solución de las pruebas objetivas de respuesta cerrada (selección de una respuesta entre un conjunto predefinido de opciones o determinación de veracidad/falsedad de aserciones relativas a un contexto previamente descrito) estará disponible para los estudiantes solicitantes de revisión en el momento y lugar en que dicha revisión tenga lugar. No se ofrecerá la publicación de estas respuestas en otros momentos ya que forman parte de un banco de preguntas de evaluación.
Esta asignatura se alinea con varios Objetivos de Desarrollo Sostenible (ODS). Particularmente, contribuye al ODS 9 (Industria, Innovación e Infraestructura), al formar profesionales capaces de diseñar y mantener infraestructuras digitales seguras y resilientes, esenciales para la innovación y el desarrollo industrial. Asimismo, impacta en el ODS 16 (Paz, Justicia e Instituciones Sólidas), al proveer herramientas y conocimientos para proteger los sistemas y servicios contra actividades ilícitas, fomentando un ciberespacio más seguro y confiable. La metodología de aprendizaje basado en proyectos y el análisis de tecnologías concretas permiten a los estudiantes aplicar estos principios de forma práctica, fortaleciendo su capacidad para contribuir activamente a estos objetivos."""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "51 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/93001007/2025-26/eventSchedule> ;
    schema:description """El curso de Protección de Sistemas y Servicios tiene como principal objetivo la presentación de la problemática y técnicas existentes a la hora de realizar instalaciones seguras de plataformas software que soporten el despliegue y desarrollo de aplicaciones. Abarcar este ámbito de conocimiento desde un enfoque puramente académico es algo complicado ya que tanto las amenazas existentes como las técnicas de protección evolucionan de forma suficientemente rápida como para evitar la creación de un marco teórico que facilite su abstracción. Para solucionar este inconveniente, el curso seguirá una metodología de aprendizaje basado en proyecto. Este método plantea un proyecto que debe llevar a cabo y cuyo desarrollo implica la necesidad de aprender conceptos nuevos que están alineados con los objetivos propuestos del curso.
Adicionalmente al desarrollo del proyecto los estudiantes deberán preparar un trabajo relacionado con alguna tecnología concreta. Estas tecnologías pueden ser servicios no contemplados en el proyecto o herramientas auxiliares que ayuden a la protección de los sistemas y servicios como gestores de configuración, contenedores, enfoques de seguridad de otros sistemas operativos al tratado en el proyecto, computación en la nube, etc."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/ivan.pau%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/ivan.pau%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/javier.martin%40upm.es> ;
    schema:name "Protección de Sistemas y Servicios"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93001007/2025-26/CB09> a ns1:Competency ;
    ns1:competencyCode "CB09" ;
    ns1:competencyDescription "Que los estudiantes sepan comunicar sus conclusiones y los conocimientos y razones últimas que las sustentan a públicos especializados y no especializados de un modo claro y sin ambigüedades"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93001007/2025-26/CB10> a ns1:Competency ;
    ns1:competencyCode "CB10" ;
    ns1:competencyDescription "Que los estudiantes posean las habilidades de aprendizaje que les permitan continuar estudiando de un modo que habrá de ser en gran medida autodirigido o autónomo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93001007/2025-26/CE04> a ns1:Competency ;
    ns1:competencyCode "CE04" ;
    ns1:competencyDescription "Capacidad para establecer una categorización de servicios de ciberseguridad para proteger a las infraestructuras conectadas en red."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93001007/2025-26/CG03> a ns1:Competency ;
    ns1:competencyCode "CG03" ;
    ns1:competencyDescription "Dotar al alumno de la capacidad de diseñar e implantar procedimientos de protección de la información asociados con los sistemas de información, las redes y comunicaciones telemáticas y los servicios de Internet, así como en la protección contra el fraude utilizando estos sistemas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93001007/2025-26/CT08> a ns1:Competency ;
    ns1:competencyCode "CT08" ;
    ns1:competencyDescription "Trabajo en equipo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93001007/2025-26/CT12> a ns1:Competency ;
    ns1:competencyCode "CT12" ;
    ns1:competencyDescription "Aprendizaje autónomo, adaptación a nuevas situaciones y motivación por el desarrollo profesional permanente"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93001007/2025-26/RA11> a ns1:LearningResult ;
    ns1:learningResultCode "RA11" ;
    ns1:learningResultDescription "Analizar y seleccionar los mecanismos adecuados para proteger los sistemas y servicios"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93001007/2025-26/RA27> a ns1:LearningResult ;
    ns1:learningResultCode "RA27" ;
    ns1:learningResultDescription "Conocer, escoger y saber implantar mecanismos de protección a nivel del sistema operativo"@es .

