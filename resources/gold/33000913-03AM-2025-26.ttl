    ns1:itemIndex 5 ;
    ns1:syllabusDescription "6. Tema 06. Determinantes urbanos de salud y la Guia para planificar ciudades saludables Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000913/2025-26/syllabus/6> a ns1:SyllabusItem ;
