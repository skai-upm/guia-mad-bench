<https://guia-kg.skai.etsisi.upm.es/resource/93000969/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/93000969/2025-26/CB06>,
        <https://guia-kg.skai.etsisi.upm.es/resource/93000969/2025-26/CB07>,
