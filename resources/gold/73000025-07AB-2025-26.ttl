    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/73000025/2025-26/eventSchedule> ;
    schema:description "La prevención de incendios forestales debe considerar los aspectos normativos, territoriales (socioeconómicos y del medio natural) y el histórico de ocurrencia de incendios para poder diseñar las principales medidas a implantar en un territorio para disminuir la incidencia de los incendios forestales. Se revisarán las medidas preventivas y la eficacia de cada una de ellas. Finalmente se revisarán los documentos de planificación tanto espacial y temporal, de la prevención. El uso de SIG es un elemento muy importante de la asignatura."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/ruben.laina%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/carolina.martinez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/javier.madrigal%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/ruben.laina%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/tasio.fyuste%40upm.es> ;
    schema:name "Prevencion de Incendios"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/73000025/2025-26/CE%201.2> a ns1:Competency ;
    ns1:competencyCode "CE 1.2" ;
    ns1:competencyDescription "Capacidad para emprender acciones relacionadas con la gestión forestal"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/73000025/2025-26/CE%202.1> a ns1:Competency ;
    ns1:competencyCode "CE 2.1" ;
    ns1:competencyDescription "Capacidad para diseñar, redactar y gestionar planes y políticas de prevención y detección de incendios"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/73000025/2025-26/CG%205> a ns1:Competency ;
    ns1:competencyCode "CG 5" ;
    ns1:competencyDescription "Búsqueda bibliográfica, análisis de documentación y tratamiento de la información procedente de diversas fuentes y de su análisis y síntesis aplicándola a la resolución de problemas complejos, en el campo de la gestión de incendios forestales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/73000025/2025-26/CG%206> a ns1:Competency ;
    ns1:competencyCode "CG 6" ;
    ns1:competencyDescription "Perfeccionar el conocimiento oral y escrito de la lengua inglesa"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/73000025/2025-26/RA11> a ns1:LearningResult ;
    ns1:learningResultCode "RA11" ;
    ns1:learningResultDescription "Relacionar los conocimientos adquiridos en otras materias adquiridas en una titulación anterior directa o indirectamente relacionada, con el fin de elaborar trabajos y proyectos multidisciplinares"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/73000025/2025-26/RA41> a ns1:LearningResult ;
    ns1:learningResultCode "RA41" ;
    ns1:learningResultDescription "Capacidad para diseñar, dirigir, elaborar, implementar e interpretar proyectos y planes de prevención y gestión territorial de incendios"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/73000025/2025-26/RA42> a ns1:LearningResult ;
    ns1:learningResultCode "RA42" ;
    ns1:learningResultDescription "Conocimientos adecuados para la gestión de trabajos de limpieza del sotobosque y el establecimiento de cortafuegos y cortacombustibles y de infraestructuras de apoyo al combate del fuego."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/73000025/2025-26/RA43> a ns1:LearningResult ;
    ns1:learningResultCode "RA43" ;
    ns1:learningResultDescription "Capacidad para poner en práctica técnicas de selvicultura preventiva y de reducción del combustible en el monte"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/73000025/2025-26/RA44> a ns1:LearningResult ;
    ns1:learningResultCode "RA44" ;
    ns1:learningResultDescription "Que los estudiantes tengan conocimientos y capacidades para tomar, gestionar y analizar datos de detección, prevención o lucha contra incendios."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/73000025/2025-26/RA45> a ns1:LearningResult ;
    ns1:learningResultCode "RA45" ;
    ns1:learningResultDescription "Que los estudiantes tengan conocimientos para crear e interpretar cartografía temática y aplicarla a la gestión en su campo de trabajo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/73000025/2025-26/RA49> a ns1:LearningResult ;
    ns1:learningResultCode "RA49" ;
    ns1:learningResultDescription "· Que los estudiantes tengan conocimientos y capacidades para tomar, gestionar y analizar datos de detección, prevención o lucha contra incendios"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/73000025/2025-26/RA68> a ns1:LearningResult ;
    ns1:learningResultCode "RA68" ;
    ns1:learningResultDescription "Seleccionar y aplicar las metodologías adecuadas para el trabajo propuesto."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/73000025/2025-26/RA72> a ns1:LearningResult ;
    ns1:learningResultCode "RA72" ;
    ns1:learningResultDescription "Capacitación para diseñar las líneas maestras de un proyecto en la prevención, vigilancia, extinción de incendios forestales o de restauración del territorio despues del incendio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/73000025/2025-26/RA88> a ns1:LearningResult ;
    ns1:learningResultCode "RA88" ;
    ns1:learningResultDescription "Capacidad para diseñar un plan de prevención de riesgos laborales a partir de la realización de un estudio inicial de riesgos (o su actualización), incluyendo la selección y mantenimiento de los EPIs utilizados en prevención y extinción de incendios."@es .

