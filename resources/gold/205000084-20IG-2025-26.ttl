    ns1:learningResultDescription "Describir y determinar cualquier planta vascular mediante el uso de claves"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000084/2025-26/RA358> a ns1:LearningResult ;
    ns1:learningResultCode "RA358" ;
    ns1:learningResultDescription "Definir los factores que afectan a la fotosíntesis y como consecuencia a la producción."@es .

