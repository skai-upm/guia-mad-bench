<https://guia-kg.skai.etsisi.upm.es/resource/205000084/2025-26/RA107> a ns1:LearningResult ;
    ns1:learningResultCode "RA107" ;
    ns1:learningResultDescription "Identificar la anatomía de los órganos vegetativos de las plantas: raíz, tallo y hoja."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000084/2025-26/RA108> a ns1:LearningResult ;
    ns1:learningResultCode "RA108" ;
    ns1:learningResultDescription "Describir la anatomía de los órganos reproductores de las plantas: flor, fruto y semilla."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000084/2025-26/RA109> a ns1:LearningResult ;
    ns1:learningResultCode "RA109" ;
    ns1:learningResultDescription "Relacionar el papel del agua en la planta y los factores que determinan el movimiento de la misma en el continuo suelo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000084/2025-26/RA110> a ns1:LearningResult ;
    ns1:learningResultCode "RA110" ;
    ns1:learningResultDescription "Mostrar cómo las plantas obtienen sus nutrientes orgánicos e inorgánicos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000084/2025-26/RA111> a ns1:LearningResult ;
    ns1:learningResultCode "RA111" ;
    ns1:learningResultDescription "Interpretar la fisiología del desarrollo de la planta y su regulación tanto por las hormonas vegetales como por factores ambientales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000084/2025-26/RA112> a ns1:LearningResult ;
    ns1:learningResultCode "RA112" ;
    ns1:learningResultDescription "Reconocer las principales familias y especies de interés agronómico y ornamental."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000084/2025-26/RA113> a ns1:LearningResult ;
