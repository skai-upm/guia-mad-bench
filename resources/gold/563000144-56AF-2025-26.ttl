<https://guia-kg.skai.etsisi.upm.es/resource/563000144/2025-26/CB07> a ns1:Competency ;
    ns1:competencyCode "CB07" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en entornos nuevos o poco conocidos dentro de contextos más amplios (o multidisciplinares) relacionados con su área de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000144/2025-26/CB08> a ns1:Competency ;
    ns1:competencyCode "CB08" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de integrar conocimientos y enfrentarse a la complejidad de formular juicios a partir de una información que, siendo incompleta o limitada, incluya reflexiones sobre las responsabilidades sociales y éticas vinculadas a la aplicación de sus conocimientos y juicios"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000144/2025-26/CB10> a ns1:Competency ;
    ns1:competencyCode "CB10" ;
    ns1:competencyDescription "Que los estudiantes posean las habilidades de aprendizaje que les permitan continuar estudiando de un modo que habrá de ser en gran medida autodirigido o autónomo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000144/2025-26/CEC08> a ns1:Competency ;
    ns1:competencyCode "CEC08" ;
    ns1:competencyDescription "Conocimiento, comprensión y capacidad para aplicar la legislación necesaria en el ámbito de la ingeniería de producción."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000144/2025-26/CEI03> a ns1:Competency ;
    ns1:competencyCode "CEI03" ;
    ns1:competencyDescription "Desarrollar capacidades de aplicación de los conocimientos adquiridos al diseño de procesos industriales, en función de las características de los elementos a producir, con criterios de máxima calidad, productividad, seguridad y respeto al medio ambiente"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000144/2025-26/CG06> a ns1:Competency ;
    ns1:competencyCode "CG06" ;
    ns1:competencyDescription "Capacidad para la aplicación de los conocimientos adquiridos y resolver problemas en entornos nuevos o poco conocidos dentro de contextos más amplios y multidisciplinares, siendo capaces de integrar conocimientos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000144/2025-26/CG07> a ns1:Competency ;
    ns1:competencyCode "CG07" ;
    ns1:competencyDescription "Capacidad para saber comunicar (de forma oral y escrita) las conclusiones y los conocimientos y razones últimas que lo sustentan a públicos especializados y no especializados de un modo claro y sin ambigüedades."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000144/2025-26/CG08> a ns1:Competency ;
    ns1:competencyCode "CG08" ;
    ns1:competencyDescription "Poseer habilidades para el aprendizaje continuado, autodirigido y autónomo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000144/2025-26/RA31> a ns1:LearningResult ;
    ns1:learningResultCode "RA31" ;
    ns1:learningResultDescription "Conocer los desarrollos y las herramientas europeas y mundiales en la materia."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000144/2025-26/RA32> a ns1:LearningResult ;
    ns1:learningResultCode "RA32" ;
    ns1:learningResultDescription "Conocer y aplicar adecuadamente los Sistemas de Gestión Ambiental."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000144/2025-26/RA33> a ns1:LearningResult ;
    ns1:learningResultCode "RA33" ;
    ns1:learningResultDescription "Proporcionar las herramientas para la realización de Auditorías Ambientales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000144/2025-26/RA34> a ns1:LearningResult ;
    ns1:learningResultCode "RA34" ;
    ns1:learningResultDescription "Profundizar en el estudio de los métodos de evaluación ambiental en los dominios industriales, así como las soluciones para reducir las emisiones generadas y el consumo de recursos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000144/2025-26/RA35> a ns1:LearningResult ;
    ns1:learningResultCode "RA35" ;
    ns1:learningResultDescription "Proporcionar las nociones fundamentales en materia de impactos y protección ambiental para la toma de decisiones técnicas de los proyectos."@es .

