    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/43000525/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000525/2025-26/didactic_resource/2> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/43000525/2025-26/evaluation> ;
