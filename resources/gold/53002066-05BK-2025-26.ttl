<https://guia-kg.skai.etsisi.upm.es/resource/53002066/2025-26/syllabus> a ns1:Syllabus ;
    ns1:hasItem <https://guia-kg.skai.etsisi.upm.es/resource/53002066/2025-26/syllabus/0>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53002066/2025-26/syllabus/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53002066/2025-26/syllabus/2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53002066/2025-26/syllabus/3>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53002066/2025-26/syllabus/4>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53002066/2025-26/syllabus/5> .

<https://guia-kg.skai.etsisi.upm.es/resource/53002066/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Descripción general de los tipos de motores térmicos existentes, sus aplicaciones, sus ventajas e inconvenientes y sus alternativas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002066/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "2. Descripción general de los motores de combustión interna alternativos. Fundamentos para su elección dependiendo de la aplicación. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002066/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "3. Medios para mejorar la eficiencia energética y disminuir las emisiones contaminantes de los motores térmicos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002066/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "4. Descripción de la metodología CORINAIR. Tratamiento de los datos de entrada al programa COPERT. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002066/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "5. Descripción de los conjuntos de medidas para mejorar la eficiencia energética. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002066/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "6. Comparación de los motores térmicos con otros sistemas de propulsión. Sin subniveles"@es .

