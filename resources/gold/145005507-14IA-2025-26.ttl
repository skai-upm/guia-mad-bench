    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/145005507/2025-26/eventSchedule> ;
    schema:description "La asignatura de Aleaciones Aeroespaciales debe considerarse como una continuación de la de Ciencia de los Materiales, profundizando en el conocimiento de las aleaciones metálicas más utilizadas en la industria aeroespacial. Se estudian sus propiedades mecánicas, microestructura, tratamientos térmicos y comportamiento en servicio. Se profundiza especialmente en las aleaciones base aluminio y titanio, por ser las más utilizadas en el ámbito aeronáutico."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/laura.cordova%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/conrado.garrido%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/daniel.barba%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/ignacio.luque%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/joseantonio.heredero%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/laura.cordova%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/me.palacios%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/nuria.mpiris%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/rodrigo.santos%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/sergio.perosanz%40upm.es> ;
    schema:name "Aleaciones Aeroespaciales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005507/2025-26/CE46> a ns1:Competency ;
    ns1:competencyCode "CE46" ;
    ns1:competencyDescription "Conocimiento adecuado y aplicado a la Ingeniería de: Las prestaciones tecnológicas, las técnicas de optimización de los materiales utilizados en el sector aeroespacial y los procesos de tratamientos para modificar sus propiedades mecánicas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005507/2025-26/CE48> a ns1:Competency ;
    ns1:competencyCode "CE48" ;
    ns1:competencyDescription "Conocimiento adecuado y aplicado a la Ingeniería de: Los métodos de cálculo y de desarrollo de los materiales y sistemas de la defensa; el manejo de las técnicas experimentales, equipamiento e instrumentos de medida propios de la disciplina; la simulación numérica de los procesos físico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005507/2025-26/CE49> a ns1:Competency ;
    ns1:competencyCode "CE49" ;
    ns1:competencyDescription "Conocimiento aplicado de: aerodinámica; mecánica del vuelo, ingeniería de la defensa aérea (balística, misiles y sistemas aéreos), propulsión espacial, ciencia y tecnología de los materiales, teoría de estructuras."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005507/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Capacidad para identificar y resolver problemas aplicando, con creatividad, los conocimientos adquiridos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005507/2025-26/CG4> a ns1:Competency ;
    ns1:competencyCode "CG4" ;
    ns1:competencyDescription "Capacidad para integrarse y formar parte activa de equipos de trabajo. Trabajo en equipo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005507/2025-26/CG9> a ns1:Competency ;
    ns1:competencyCode "CG9" ;
    ns1:competencyDescription "Razonamiento crítico y capacidad de asociación que posibiliten el aprendizaje continuo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005507/2025-26/RA31> a ns1:LearningResult ;
    ns1:learningResultCode "RA31" ;
    ns1:learningResultDescription "Conocimientos en Aleaciones Aeroespaciales: Capacidad de identificar y comprender las diferencias de este tipo de materiales, y desarrollar su aplicación en el ámbito Aeroespacial."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005507/2025-26/RA32> a ns1:LearningResult ;
    ns1:learningResultCode "RA32" ;
    ns1:learningResultDescription "Conocimiento básico de las herramientas para la determinación del comportamiento y propiedades de las aleaciones aeroespaciales."@es .

