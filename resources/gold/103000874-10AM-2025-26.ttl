    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/103000874/2025-26/eventSchedule> ;
    schema:description "This course will be focused on designing mobile interactions with good user experience (UX). Contents of the course include: UX as a broadening of the scope of usability, design concepts, global user interfaces, designing for mobile experiences, interaction design patterns for mobile applications, mobile wireframes and prototypes and platform-specific design guidelines."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/ricardo.imbert%40upm.es> ;
    schema:inLanguage "Inglés"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/j.barambones%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/ricardo.imbert%40upm.es> ;
    schema:name "User Experience And Mobile Interaction"@es .

