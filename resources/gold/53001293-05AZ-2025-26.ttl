    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/53001293/2025-26/eventSchedule> ;
    schema:description """La asignatura se impartirá sobre todo en alemán combinado en español de acuerdo con las necesidades de cada momento. Se centra en aplicar los conocimientos previos de alemán a las siguientes situaciones:
comprender clases impartidas en alemán
comprender textos complejos en alemán y debatir sobre ellos en este idioma
iniciación a la presentación temas relacionados con el ámbito laboral en Alemania y estudios
Así mismo, la asignatura introduce contrastes culturales que diferencian las expectativas comunicativas en entornos Germanófonos de los Hispanófonos."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/ismael.arinas%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/elena.zapatero%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/ismael.arinas%40upm.es> ;
    schema:name "Aleman III"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001293/2025-26/%28g%29> a ns1:Competency ;
    ns1:competencyCode "(g)" ;
    ns1:competencyDescription "COMUNICA. Habilidad para comunicar eficazmente."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001293/2025-26/%28i%29> a ns1:Competency ;
    ns1:competencyCode "(i)" ;
    ns1:competencyDescription "SE ACTUALIZA. Reconocimiento de la necesidad y la habilidad para comprometerse al aprendizaje continuo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001293/2025-26/%28j%29> a ns1:Competency ;
    ns1:competencyCode "(j)" ;
    ns1:competencyDescription "CONOCE. Conocimiento de los temas contemporáneos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001293/2025-26/CB08> a ns1:Competency ;
    ns1:competencyCode "CB08" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de integrar conocimientos y enfrentarse a la complejidad de formular juicios a partir de una información que, siendo incompleta o limitada, incluya reflexiones sobre las responsabilidades sociales y éticas vinculadas a la aplicación de sus conocimientos y juicios"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001293/2025-26/CB10> a ns1:Competency ;
    ns1:competencyCode "CB10" ;
    ns1:competencyDescription "Que los estudiantes posean las habilidades de aprendizaje que les permitan continuar estudiando de un modo que habrá de ser en gran medida autodirigido o autónomo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001293/2025-26/CG11> a ns1:Competency ;
    ns1:competencyCode "CG11" ;
    ns1:competencyDescription "Poseer las habilidades de aprendizaje que permitan continuar estudiando de un modo autodirigido o autónomo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001293/2025-26/RA122> a ns1:LearningResult ;
    ns1:learningResultCode "RA122" ;
    ns1:learningResultDescription "Utiliza el estilo adecuado para facilitar la comprensión del lector teniendo en cuenta sus expectativas y conocimientos previos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001293/2025-26/RA125> a ns1:LearningResult ;
    ns1:learningResultCode "RA125" ;
    ns1:learningResultDescription "Utiliza correctamente técnicas de comunicación oral."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001293/2025-26/RA51> a ns1:LearningResult ;
    ns1:learningResultCode "RA51" ;
    ns1:learningResultDescription "Relación de los contenidos estudiados con el mundo real."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001293/2025-26/RA83> a ns1:LearningResult ;
    ns1:learningResultCode "RA83" ;
    ns1:learningResultDescription "El alumno ampliará sus destrezas comunicativas, entiendo éstas, como la capacidad para transmitir conocimientos, expresar ideas y argumentos de manera clara, rigurosa y convincente, tanto de forma oral como escrita, utilizando los recursos gráficos y los medios necesarios."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001293/2025-26/didactic_resource/1> a ns1:DidacticResource ;
    ns1:bibliographyDescription "Die Lektionen im Kursbuch enthalten jeweils eine sich abgeschlossene Lektionsgeschichte. Im Mittelpunkt stehen Personen, die sich in Situationen befinden, die das Agieren im deutschsprachigen Umfeld erlauben."@es ;
    ns1:bibliographyTitle "DaF kompakt neu B1"@es ;
    ns1:bibliographyType "Otros"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001293/2025-26/didactic_resource/2> a ns1:DidacticResource ;
    ns1:bibliographyDescription "Im Unterricht werden Sachtexte bearbeitet, damit der Student selbständig mit diesen Texten umgehen kann."@es ;
    ns1:bibliographyTitle "Sachtexte"@es ;
    ns1:bibliographyType "Otros"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001293/2025-26/didactic_resource/3> a ns1:DidacticResource ;
