    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/305000128/2025-26/syllabus> ;
    ns1:inpersonHours "77 horas (49.4%)"@es ;
    ns1:numberOfCredits 6.0 ;
    ns1:otherInformation "This subject encourages oral presentations and written tasks related to sustainable development goals nº 4, 5, 8, 9 , 10 and 12."@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "77 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/305000128/2025-26/eventSchedule> ;
    schema:description """English for Professional and Academic Communication (EPAC) is a course designed to enable Math students to communicate fluently and accurately in written and oral English in professional and academic environments.
The student will be able to write a logically organized and coherent document on a wide variety of topics and support his/her views . s/he will also be able to write specialized-content documents.
The course also enhances oral skills, which are essential in professional contexts."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/samira.allani%40upm.es> ;
    schema:inLanguage "Inglés"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/samira.allani%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/silvia.molina%40upm.es> ;
    schema:name "English For Professional And Academic Communication"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000128/2025-26/CB4> a ns1:Competency ;
    ns1:competencyCode "CB4" ;
    ns1:competencyDescription "Que los estudiantes puedan transmitir información, ideas, problemas y soluciones a un público tanto especializado como no especializado"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000128/2025-26/CT1> a ns1:Competency ;
    ns1:competencyCode "CT1" ;
    ns1:competencyDescription "Trabajar dentro de un equipo, en entornos interdisciplinares y complejos, negociando y resolviendo conflictos, diseñando soluciones eficientes, fiables, robustas y responsables."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000128/2025-26/CT5> a ns1:Competency ;
    ns1:competencyCode "CT5" ;
    ns1:competencyDescription "Trabajar en un contexto internacional, comunicándose en lengua inglesa y adaptándose a las condiciones del entorno."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000128/2025-26/CT7> a ns1:Competency ;
    ns1:competencyCode "CT7" ;
    ns1:competencyDescription "Analizar los impactos sociales, ambientales y económicos de investigaciones y proyectos, de forma responsable y comprometida con la búsqueda de soluciones a los retos de un desarrollo sostenible."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000128/2025-26/CT8> a ns1:Competency ;
    ns1:competencyCode "CT8" ;
    ns1:competencyDescription "Mostrar capacidad para comunicar ideas, problemas y soluciones, tanto a público especializado como no especializado, de manera oral y escrita."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000128/2025-26/RA148> a ns1:LearningResult ;
    ns1:learningResultCode "RA148" ;
    ns1:learningResultDescription "Comunicar oralmente y por escrito el alcance, las limitaciones y las conclusiones científicas de los modelos, tanto en ámbitos técnicos como más abiertos, favoreciendo la difusión a la sociedad y la transferencia de conocimiento."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000128/2025-26/RA246> a ns1:LearningResult ;
    ns1:learningResultCode "RA246" ;
    ns1:learningResultDescription "Comunicar ideas y conceptos matemáticos de forma coherente y adecuada en la expresión oral y escrita en inglés"@es .

