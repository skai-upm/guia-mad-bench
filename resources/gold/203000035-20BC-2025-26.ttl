    ns1:learningResultDescription "Escribir y depurar aplicaciones Spark para el análisis de datos masivos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000035/2025-26/RA51> a ns1:LearningResult ;
    ns1:learningResultCode "RA51" ;
    ns1:learningResultDescription "Utilizar Spark para desarrollar productos y servicios intensivos en datos, como sistemas de recomendación, predicción y diagnóstico, utilizando procesamiento paralelo, Spark Machine Learning Pipelines y Spark Streaming"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000035/2025-26/RA52> a ns1:LearningResult ;
    ns1:learningResultCode "RA52" ;
    ns1:learningResultDescription "Utilizar SparkR para realizar análisis estadístico en grandes volúmenes de datos."@es .

