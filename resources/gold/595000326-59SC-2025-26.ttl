    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/595000326/2025-26/eventSchedule> ;
    schema:description """La asignatura introduce al alumno en la aplicación práctica de las técnicas de tratamiento digital de señal orientadas a los sistemas de telecomunicación. Para ello se presentarán en clase técnicas de estimación espectral, de simulación y de muestreo pasobanda de señal. En el transcurso del curso se presentarán algoritmos de utilización directa en los contenidos explicados. Algunos de estos algoritmos serán implementados, de forma sencilla, en el laboratorio.
El laboratorio se realizará de forma individual siendo obligatorio la entrega de las prácticas.
La asignatura se aprueba por curso con los siguientes pesos entre teoría y laboratorio:
Teoría: 80%
Laboratorio: 20%
Para aprobar la asignatura es obligatorio aprobar la teoría y el laboratorio.
Aprobar el laboratorio implica su liberación.
En el examen de teoría se podrán preguntar temas relacionados con las prácticas realizadas.
Las clases serán, preferentemente, presenciales. Si las circunstancias sanitarias así lo requiriesen, se cambiaría a clases a distancia.
La planificación podrá sufrir modificaciones en función del calendario definitivo."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/josemanuel.pardo%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/joseenrique.gonzalez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/josemanuel.pardo%40upm.es> ;
    schema:name "Procesado de Señal en Comunicaciones"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000326/2025-26/CE%20SC01> a ns1:Competency ;
    ns1:competencyCode "CE SC01" ;
    ns1:competencyDescription "Capacidad para construir, explotar y gestionar las redes, servicios, procesos y aplicaciones de telecomunicaciones, entendidas éstas como sistemas de captación, transporte, representación, procesado, almacenamiento, gestión y presentación de información multimedia, desde el punto de vista de los sistemas de transmisión."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000326/2025-26/CE%20SC06> a ns1:Competency ;
    ns1:competencyCode "CE SC06" ;
    ns1:competencyDescription "Capacidad para analizar, codificar, procesar y transmitir información multimedia empleando técnicas de procesado analógico y digital de señal."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000326/2025-26/CE%20SC07> a ns1:Competency ;
    ns1:competencyCode "CE SC07" ;
    ns1:competencyDescription "Capacidad para realizar proyectos en el ámbito de las tecnologías específicas de la Ingeniería de Telecomunicación, de naturaleza profesional en que se sinteticen e integren las competencias adquiridas en las enseñanzas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000326/2025-26/CE%20TEL01> a ns1:Competency ;
    ns1:competencyCode "CE TEL01" ;
    ns1:competencyDescription "Capacidad para aprender de manera autónoma nuevos conocimientos y técnicas adecuados para la concepción, el desarrollo o la explotación de sistemas y servicios de telecomunicación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000326/2025-26/CE%20TEL04> a ns1:Competency ;
    ns1:competencyCode "CE TEL04" ;
    ns1:competencyDescription "Capacidad de analizar y especificar los parámetros fundamentales de un sistema de comunicaciones."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000326/2025-26/CG%2002> a ns1:Competency ;
    ns1:competencyCode "CG 02" ;
    ns1:competencyDescription "Capacidad de búsqueda y selección de información, de razonamiento crítico y de elaboración y defensa de argumentos dentro del área."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000326/2025-26/CG%2004> a ns1:Competency ;
    ns1:competencyCode "CG 04" ;
    ns1:competencyDescription "Capacidad de abstracción, de análisis y de síntesis y de resolución de problemas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000326/2025-26/CG%2013> a ns1:Competency ;
    ns1:competencyCode "CG 13" ;
    ns1:competencyDescription "Habilidades de aprendizaje con un alto grado de autonomía."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000326/2025-26/RA230> a ns1:LearningResult ;
    ns1:learningResultCode "RA230" ;
    ns1:learningResultDescription "Utilizar las diferentes técnicas de estimación de la potencia, la densidad espectral de potencia, la relación señal a ruido, etc., de señales analógicas mediante técnicas digitales de procesado basadas en la transformada discreta de Fourier."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000326/2025-26/RA231> a ns1:LearningResult ;
    ns1:learningResultCode "RA231" ;
    ns1:learningResultDescription "Implementar, verificar y comparar algoritmos de filtrado, codificación, análisis, etc., en placas de evaluación basadas en DSP"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000326/2025-26/RA232> a ns1:LearningResult ;
    ns1:learningResultCode "RA232" ;
    ns1:learningResultDescription "Estimar probabilidades de error en los sistemas de comunicaciones digitales y de detección y/o falsa alarma en los sistemas radar, mediante simulación Monte Carlo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000326/2025-26/RA233> a ns1:LearningResult ;
    ns1:learningResultCode "RA233" ;
    ns1:learningResultDescription "Simulación de sistemas y subsistemas de comunicaciones, incluyendo la generación de la señal, modulación/demodulación, el canal, y el análisis de la calidad de la señal recibida"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000326/2025-26/RA234> a ns1:LearningResult ;
    ns1:learningResultCode "RA234" ;
    ns1:learningResultDescription "Implementación de subsistemas de conversión a frecuencias menores de señales paso banda (moduladas) mediante técnicas de submuestreo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000326/2025-26/RA235> a ns1:LearningResult ;
    ns1:learningResultCode "RA235" ;
    ns1:learningResultDescription "Interpretar las especificaciones de los principales sistemas y servicios de telecomunicación, los requisitos de calidad exigidos, y las medidas que han de realizarse para comprobar esas especificaciones."@es .

