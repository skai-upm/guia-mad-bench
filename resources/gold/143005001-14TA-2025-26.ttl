    ns1:inpersonHours "73 horas (54.1%)"@es ;
    ns1:numberOfCredits 5.0 ;
    ns1:otherInformation """Las actividades de docencia y de evaluación contenidas en el cronograma se encuentran sujetas a modificación en función del desarrollo del curso. En particular el número de horas establecido por semana puede variar en función de las fechas no lectivas establecidas en el calendario oficial de la universidad.
El cronograma está basado en una situación ideal de quince semanas con cinco días lectivos cada una. Por ello, la semana establecida para cada actividad de evaluación es indicativa y puede sufrir modificaciones. Si se diera esta eventualidad, la modificación se publicará en el espacio de la asignatura en Moodle y demás espacios que se establezcan para ello."""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "73 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/143005001/2025-26/eventSchedule> ;
    schema:description """Probabilidad y estadística
Inferencia bayesiana
Estadísticas y análisis de datos de fallos. Tratamiento de series históricas
Análisis de incertidumbres
Juicio de expertos: Analytical Hierarchy Process (AHP).
Simulaciones de Montecarlo.
Teoría de decisión y análisis de riesgos
Teoría de juegos
Técnicas de IA (redes neuronales, lógica difusa, algoritmos genéticos, ...)"""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/jose.olarrea%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/jose.olarrea%40upm.es> ;
    schema:name "Teoria de la Estimacion"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005001/2025-26/CE1> a ns1:Competency ;
    ns1:competencyCode "CE1" ;
    ns1:competencyDescription "Comprender y aplicar los fundamentos matemáticos necesarios para el análisis de seguridad de sistemas complejos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005001/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Poseer y comprender conocimientos que aporten una base u oportunidad de ser originales en el desarrollo de nuevos conceptos y técnicas aplicados al Sistema del Transporte Aéreo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005001/2025-26/CG4> a ns1:Competency ;
    ns1:competencyCode "CG4" ;
    ns1:competencyDescription "Comunicar sus conclusiones y los conocimientos y razones últimas que las sustentan a públicos especializados, y no especializados de un modo claro y sin ambigüedades"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005001/2025-26/CG6> a ns1:Competency ;
    ns1:competencyCode "CG6" ;
    ns1:competencyDescription "Que los estudiantes posean las habilidades de aprendizaje que les permitan continuar estudiando de un modo que habrá de ser en gran medida autodirigido o autónomo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005001/2025-26/CT4> a ns1:Competency ;
    ns1:competencyCode "CT4" ;
    ns1:competencyDescription "Analizar implicaciones económicas, administrativas, sociales o medioambientales ligadas a la aplicación de nuevos conceptos y técnicas en el Sistema del Transporte Aéreo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005001/2025-26/RA19> a ns1:LearningResult ;
    ns1:learningResultCode "RA19" ;
    ns1:learningResultDescription "El alumno conoce las técnicas básicas de sistemas complejos aplicables al transporte aéreo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005001/2025-26/RA20> a ns1:LearningResult ;
    ns1:learningResultCode "RA20" ;
    ns1:learningResultDescription "El alumno conoce las técnicas de toma de decisión con incertidumbre y riesgo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005001/2025-26/RA21> a ns1:LearningResult ;
    ns1:learningResultCode "RA21" ;
    ns1:learningResultDescription "El alumno conoce las técnicas de análisis de redes booleanas y sus derivadas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005001/2025-26/RA22> a ns1:LearningResult ;
    ns1:learningResultCode "RA22" ;
    ns1:learningResultDescription "El alumno conoce las aplicaciones de los procesos estocásticos al transporte aéreo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005001/2025-26/RA23> a ns1:LearningResult ;
    ns1:learningResultCode "RA23" ;
    ns1:learningResultDescription "El alumno sabe realizar simulaciones de procesos asociados al transporte aéreo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005001/2025-26/RA24> a ns1:LearningResult ;
    ns1:learningResultCode "RA24" ;
    ns1:learningResultDescription "El alumno conoce los principios de la estimación bayesiana y sus aplicaciones"@es .

