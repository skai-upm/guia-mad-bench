<https://guia-kg.skai.etsisi.upm.es/resource/145007306/2025-26/syllabus> a ns1:Syllabus ;
    ns1:hasItem <https://guia-kg.skai.etsisi.upm.es/resource/145007306/2025-26/syllabus/0>,
        <https://guia-kg.skai.etsisi.upm.es/resource/145007306/2025-26/syllabus/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/145007306/2025-26/syllabus/10>,
        <https://guia-kg.skai.etsisi.upm.es/resource/145007306/2025-26/syllabus/11>,
        <https://guia-kg.skai.etsisi.upm.es/resource/145007306/2025-26/syllabus/2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/145007306/2025-26/syllabus/3>,
        <https://guia-kg.skai.etsisi.upm.es/resource/145007306/2025-26/syllabus/4>,
        <https://guia-kg.skai.etsisi.upm.es/resource/145007306/2025-26/syllabus/5>,
        <https://guia-kg.skai.etsisi.upm.es/resource/145007306/2025-26/syllabus/6>,
        <https://guia-kg.skai.etsisi.upm.es/resource/145007306/2025-26/syllabus/7>,
        <https://guia-kg.skai.etsisi.upm.es/resource/145007306/2025-26/syllabus/8>,
        <https://guia-kg.skai.etsisi.upm.es/resource/145007306/2025-26/syllabus/9> .

<https://guia-kg.skai.etsisi.upm.es/resource/145007306/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. PROCESOS Y ELEMENTOS DEL AEROPUERTO"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145007306/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Tráfico de aeronaves. Operación de aeronaves. Tratamiento de pasajeros y compañías. Servicios aeroportuarios. Instalaciones del aeropuerto. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145007306/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "5.1. Análisis operativo del aeropuerto. Análisis de las demoras en la operación aeroportuaria. Indicadores y fuentes de información. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145007306/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "5.2. Rendimiento aeroportuario a nivel europeo. Reglamentación de obligado cumplimiento. Indicadores de capacidad, medioambiente, seguridad y rentabilidad. ATMAP. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145007306/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Planificación de operaciones, coordinación de horarios, asignación de medios, gestión de afluencia, asignación slot ATFM, prognosis de tráfico Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145007306/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "2. GESTIÓN OPERATIVA."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145007306/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "2.1. Estructura y organización de la empresa aeroportuaria. Elementos funcionales del aeropuerto: funciones y responsabilidades Procesos y agentes de la actividad aeroportuaria: interrelación (integración de sistemas). Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145007306/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "3. GESTIÓN ECONÓMICA DEL AEROPUERTO"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145007306/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "3.1. Estructura y función de costes aeroportuarios. Estructura y naturaleza de ingresos aeroportuarios. Tarificación y fijación de precios. Prácticas comerciales para el desarrollo del aeropuerto Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145007306/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "4. MODELOS DE GESTIÓN."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145007306/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "4.1. Modelos de gestión pública, privada y mixta. Gestión individualiza vs centralizada. Propiedad de los aeropuertos a nivel europeo. Caso del sistema aeroportuario español. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145007306/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "5. METODOLOGÍA Y TÉCNICAS DE OPTIMIZACIÓN EN LA OPERACIÓN AEROPORTUARIA"@es .

