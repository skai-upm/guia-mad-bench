<https://guia-kg.skai.etsisi.upm.es/resource/135004512/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Conceptos básicos. Descripción ecológica y socio-económica del ámbito tropical. Principales climas y biomas del cinturón intertropical Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004512/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "2. Distribución, ecología, composición, estructura, dinámica y productividad de las principales formaciones forestales del cinturón intertropical"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004512/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "2.1. Las pluvisilvas Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004512/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "2.2. El bosque tropical húmedo-seco (Bioma II de Walter) Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004512/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "2.3. Manglares, el bambú, coníferas intertropicales y otras de importancia económica y ambiental Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004512/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "3. Selvicultura del bosque tropical húmedo (principales sistemas y técnicas selvícolas, inventariación y técnicas) Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004512/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "4. Sistemas agroforestales en el entorno tropical Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004512/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "5. Bosques plantados en el entorno tropical Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004512/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "6. Aprovechamiento de impacto reducido en el ámbito forestal tropical. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004512/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "7. Comercio y legislación relacionada con los productos forestales tropicales Sin subniveles"@es .

