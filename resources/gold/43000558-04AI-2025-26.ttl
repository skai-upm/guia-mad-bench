    schema:name "Ingeniería Geológica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000558/2025-26/MICCPCE21> a ns1:Competency ;
    ns1:competencyCode "MICCPCE21" ;
    ns1:competencyDescription "Aplicación de los conocimientos de la mecánica de suelos y de las rocas para el desarrollo del estudio, proyecto, construcción y explotación de cimentaciones, desmontes, terraplenes, túneles y demás construcciones realizadas sobre o a través del terreno, cualquiera que sea la naturaleza y el estado de éste, y cualquiera que sea la finalidad de la obra de que se trate. Incorpora las competencias CB6, CB7 y CB8"@es .

