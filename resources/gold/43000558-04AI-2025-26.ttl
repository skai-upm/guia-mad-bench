    ns1:hasItem <https://guia-kg.skai.etsisi.upm.es/resource/43000558/2025-26/syllabus/0>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000558/2025-26/syllabus/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000558/2025-26/syllabus/10>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000558/2025-26/syllabus/11>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000558/2025-26/syllabus/12>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000558/2025-26/syllabus/13>,
