    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/73000024/2025-26/eventSchedule> ;
    schema:description """La asignatura introduce al alumno en los procesos de la toma de decisiones, desde los conceptos básicos de qué es una decisión, a la modelización de procesos complejos de toma de decisiones.

Se analizan métodos de toma de decisiones empleados en la gestión de catástrofes por parte de administraciones españolas y extranjeras."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/susana.martin%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/eugenio.mfalero%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/susana.martin%40upm.es> ;
    schema:name "Sistemas de Apoyo a la Toma de Decisiones para el Manejo de Incendios Forestales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/73000024/2025-26/CE%202.5> a ns1:Competency ;
    ns1:competencyCode "CE 2.5" ;
    ns1:competencyDescription "Capacidad para optimizar la toma de decisiones en materia de prevención y lucha contra incendios."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/73000024/2025-26/CE%202.6> a ns1:Competency ;
    ns1:competencyCode "CE 2.6" ;
    ns1:competencyDescription "Capacidad para diseñar y aplicar técnicas participativas de gestión de incendios forestales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/73000024/2025-26/CG%205> a ns1:Competency ;
    ns1:competencyCode "CG 5" ;
    ns1:competencyDescription "Búsqueda bibliográfica, análisis de documentación y tratamiento de la información procedente de diversas fuentes y de su análisis y síntesis aplicándola a la resolución de problemas complejos, en el campo de la gestión de incendios forestales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/73000024/2025-26/CG%206> a ns1:Competency ;
    ns1:competencyCode "CG 6" ;
    ns1:competencyDescription "Perfeccionar el conocimiento oral y escrito de la lengua inglesa"@es .

