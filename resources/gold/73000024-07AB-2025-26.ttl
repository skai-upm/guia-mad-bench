    ns1:learningResultCode "RA54" ;
    ns1:learningResultDescription "Conocimientos y capacidad para aplicar técnicas monetarias, matemáticas y estadísticas para la toma de decisiones óptimas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/73000024/2025-26/RA56> a ns1:LearningResult ;
    ns1:learningResultCode "RA56" ;
    ns1:learningResultDescription "Capacidades y conocimientos para construir y modificar modelos de prevención y simulación de incendios"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/73000024/2025-26/RA69> a ns1:LearningResult ;
    ns1:learningResultCode "RA69" ;
    ns1:learningResultDescription "Tomar las decisiones adecuadas para el cumplimiento de los objetivos propuestos"@es .

