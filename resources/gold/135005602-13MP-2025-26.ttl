<https://guia-kg.skai.etsisi.upm.es/resource/135005602/2025-26/CB03> a ns1:Competency ;
    ns1:competencyCode "CB03" ;
    ns1:competencyDescription "Que los estudiantes tengan la capacidad de reunir e interpretar datos relevantes (normalmente dentro de su área de estudio) para emitir juicios que incluyan una reflexión sobre temas relevantes de índole social, científica o ética"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005602/2025-26/CB05> a ns1:Competency ;
    ns1:competencyCode "CB05" ;
    ns1:competencyDescription "Que los estudiantes hayan desarrollado aquellas habilidades de aprendizaje necesarias para emprender estudios posteriores con un alto grado de autonomía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005602/2025-26/CE%201.01> a ns1:Competency ;
    ns1:competencyCode "CE 1.01" ;
    ns1:competencyDescription "Conocer los campos de aplicación de la Ingeniería del Medio Natural, y tener una apreciación de la necesidad de poseer unos conocimientos técnicos profundos en ciertas áreas de aplicación; apreciación del grado de esta necesidad en, por lo menos, una situación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005602/2025-26/CE%201.02> a ns1:Competency ;
    ns1:competencyCode "CE 1.02" ;
    ns1:competencyDescription "Comprender los fundamentos biológicos, éticos, sociológicos y económicos que condicionan la conservación de especies y la protección del Medio Natural."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005602/2025-26/CE%201.03> a ns1:Competency ;
    ns1:competencyCode "CE 1.03" ;
    ns1:competencyDescription "Formalización y especificación de problemas reales de gestión del Medio Natural cuya solución requiere de aplicaciones de Ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005602/2025-26/CE%201.24> a ns1:Competency ;
    ns1:competencyCode "CE 1.24" ;
    ns1:competencyDescription "Saber utilizar programas informáticos en el almacenamiento y procesamiento de datos que permita la modelización de las complejas estructuras y procesos existentes en el Medio Natural, de manera que se facilite su gestión."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005602/2025-26/CE%202.16> a ns1:Competency ;
    ns1:competencyCode "CE 2.16" ;
    ns1:competencyDescription "Conocer el concepto, la tipología y los procesos de declaración de especies protegidas. Conocer la tipología de instrumentos de gestión y su alcance legal y territorial. Diseñar, implementar, monitorear y evaluar la eficacia de los planes de conservación de especies."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005602/2025-26/CG01> a ns1:Competency ;
    ns1:competencyCode "CG01" ;
    ns1:competencyDescription "Aplicar de manera autónoma nuevos conocimientos y técnicas adecuados para la concepción, el desarrollo o la explotación de tecnología para la gestión, conservación y protección del Medio Natural"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005602/2025-26/CG04> a ns1:Competency ;
    ns1:competencyCode "CG04" ;
    ns1:competencyDescription "Identificar y cuantificar las características ambientales del Medio Natural y los requerimientos ecológicos de las especies de flora y fauna silvestres, así como sus hábitats"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005602/2025-26/CT09> a ns1:Competency ;
    ns1:competencyCode "CT09" ;
    ns1:competencyDescription "Desarrollar las mejores prácticas para interactuar con el entorno, de forma ética, responsable y sostenible, para evitar o disminuir los efectos negativos que ocasiona la actividad humana, así como promover los beneficios que pueda generar la actividad profesional en el ámbito medioambiental, teniendo en cuenta sus implicaciones económicas y sociales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005602/2025-26/RA152> a ns1:LearningResult ;
    ns1:learningResultCode "RA152" ;
    ns1:learningResultDescription "Conocimiento, comprensi?n y capacidad de utilizaci?n de la normativa, conceptos, ideas y terminología propios de la conservación de especies y hábitats protegido"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005602/2025-26/RA153> a ns1:LearningResult ;
    ns1:learningResultCode "RA153" ;
    ns1:learningResultDescription "Conocimiento de la normativa internacional, europea, nacional y autonómica que regula el estado de protección y las medidas de conservación de especies y hábitats"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005602/2025-26/RA154> a ns1:LearningResult ;
    ns1:learningResultCode "RA154" ;
    ns1:learningResultDescription "Conocimiento de las especies y los tipos de hábitats de interés comunitario, de su descripción detallada y los procedimientos para su seguimiento y la evaluación de su estado de conservación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005602/2025-26/RA155> a ns1:LearningResult ;
    ns1:learningResultCode "RA155" ;
    ns1:learningResultDescription "Capacidad de diseño, elaboración y ejecución de estrategias y planes de gestión para la recuperación y conservación de especies de flora y fauna protegidas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005602/2025-26/RA156> a ns1:LearningResult ;
    ns1:learningResultCode "RA156" ;
    ns1:learningResultDescription "Conocimiento y capacidad de utilización de las normas y planes de conservación de las razas ganaderas autóctonas protegidas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005602/2025-26/RA157> a ns1:LearningResult ;
    ns1:learningResultCode "RA157" ;
    ns1:learningResultDescription "Capacidad para presentar en público y defender, con argumentos científicos y técnicos, trabajos de caracterización, diagnóstico, evaluación, planificación y gestión de especies protegidas"@es .

