<https://guia-kg.skai.etsisi.upm.es/resource/23000392/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/23000392/2025-26/C2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/23000392/2025-26/C5>,
