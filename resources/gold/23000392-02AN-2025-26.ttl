        <https://guia-kg.skai.etsisi.upm.es/resource/23000392/2025-26/S4> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/23000392/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/23000392/2025-26/didactic_resource/10>,
