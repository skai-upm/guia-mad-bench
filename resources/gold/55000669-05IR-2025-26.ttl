    ns1:competencyCode "CE18" ;
    ns1:competencyDescription "Conocimientos aplicados de organización de empresas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000669/2025-26/CE19> a ns1:Competency ;
    ns1:competencyCode "CE19" ;
    ns1:competencyDescription "Conocimientos y capacidades para organizar y gestionar proyectos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000669/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Conocer y aplicar conocimientos de ciencias y tecnologías básicas a la práctica de la Ingeniería de organización"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000669/2025-26/CG10> a ns1:Competency ;
    ns1:competencyCode "CG10" ;
    ns1:competencyDescription "Capacidad para generar nuevas ideas (Creatividad)."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000669/2025-26/CG4> a ns1:Competency ;
    ns1:competencyCode "CG4" ;
    ns1:competencyDescription "Comprender el impacto de la ingeniería de organización en el medio ambiente, el desarrollo sostenible de la sociedad y la importancia de trabajar en un entorno profesional y responsable."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000669/2025-26/CG5> a ns1:Competency ;
    ns1:competencyCode "CG5" ;
    ns1:competencyDescription "Saber comunicar los conocimientos y conclusiones, tanto de forma oral, escrita y gráfica, a públicos especializados y no especializados de un modo claro y sin ambigüedades"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000669/2025-26/CG6> a ns1:Competency ;
    ns1:competencyCode "CG6" ;
    ns1:competencyDescription "Poseer habilidades de aprendizaje que permitan continuar estudiando a lo largo de la vida para su adecuado desarrollo profesional"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000669/2025-26/CG7> a ns1:Competency ;
    ns1:competencyCode "CG7" ;
    ns1:competencyDescription "Incorporar nuevas tecnologías y herramientas de la Ingeniería de organización en sus actividades profesionales"@es .

