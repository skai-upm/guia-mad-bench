        <https://guia-kg.skai.etsisi.upm.es/resource/35001603/2025-26/syllabus/12>,
        <https://guia-kg.skai.etsisi.upm.es/resource/35001603/2025-26/syllabus/13>,
        <https://guia-kg.skai.etsisi.upm.es/resource/35001603/2025-26/syllabus/14>,
