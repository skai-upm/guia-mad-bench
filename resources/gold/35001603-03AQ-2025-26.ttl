    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/35001603/2025-26/eventSchedule> ;
    schema:description "Estudio de las tradiciones paisajísticas de la cultura occidental: vinculación histórica entre jardín y paisaje. La concepción del paisaje: antecedentes, fundamentos y evolución. El jardín como proyección de la arquitectura en el paisaje: bases teóricas y transformaciones conceptuales; procesos formativos y evolución compositiva en los periodos clásico y paisajista; conexiones tipológicas, temáticas y formales con las obras contemporáneas."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/marta.garcia%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/alberto.sanz%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/carmen.toribio%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/david.escudero%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/i.cardenas%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/marta.garcia%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/rodrigo.delao%40upm.es> ;
    schema:name "Paisaje y Jardin"@es .

