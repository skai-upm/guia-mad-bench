        <https://guia-kg.skai.etsisi.upm.es/resource/35001603/2025-26/syllabus/9> .

<https://guia-kg.skai.etsisi.upm.es/resource/35001603/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. El jardín clásico en Italia: la villa en el paisaje."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35001603/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Perspectiva y representación del paisaje. El jardín en los tratados de arquitectura: L.B. Alberti. Asentamiento y vista. Trazado regular y espacio perspectivo. Tipo aterrazado y tipo llano. Desarrollos barrocos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35001603/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "6. El parque público en Inglaterra: la ciudad inglesa."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35001603/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "6.1. Nuevos mecanismos de crecimiento: squares y terraces. Los parques de Londres. Joseph Paxton: el parque habitado. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35001603/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "7. El París de Haussmann: el paisaje de la ciudad moderna."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35001603/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "7.1. La reforma de la ciudad. El sistema de los espacios públicos: bosques, parques, plazas y bulevares. La nueva percepción de la ciudad. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35001603/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "8. El Movimiento de los Parques en Estados Unidos: la arquitectura de paisaje."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35001603/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "8.1. Valores cívicos del parque público. Frederick L. Olmsted: el Parque Central de Nª York; parques y sistemas de parques. Arquitectura de paisaje: concepto y ámbito. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35001603/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "9. La arquitectura de paisaje en el siglo XX."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35001603/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "9.1. El jardín en la arquitectura moderna. Exponentes de la arquitectura de paisaje desde 1945. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35001603/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "2. El jardín clásico en España y la adaptación al medio físico."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35001603/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "2.1. Antecedentes: el jardín hispano-musulmán; las condiciones del medio. Los jardines de Felipe II y su estructuración territorial. Otros ejemplos de los siglos XVI y XVII. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35001603/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "3. El jardín clásico en Francia: el dominio del territorio."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35001603/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "3.1. Proceso formativo y adaptación de los tipos. La obra de André Le Nôtre: reglas de la composición; Versalles y otras aplicaciones del sistema. La codificación del sistema clásico. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35001603/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "4. 1.Los jardines barrocos europeos y la integración en el paisaje."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35001603/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "4.1. Variaciones compositivas. Integración de jardín y ciudad. Composición en bandas y reducción axial. Desarrollo a contrapendiente. Fragmentación espacial. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35001603/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "5. El jardín paisajista en Inglaterra: la naturaleza como modelo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35001603/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "5.1. El concepto de lo pintoresco. Irregularización del jardín. La arquitectura en el paisaje. La formación de la escena. La organización del recorrido. El paisaje estructurado: Capability Brown. Lo pintoresco selvático. Expansión del jardín paisajista. Sin subniveles"@es .

