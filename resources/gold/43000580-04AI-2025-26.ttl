    ns1:otherInformation """Se recomienda que los alumnos tengan conocimientos de Resistencia de Materiales y Análisis de Estructuras.
Asimismo, se recomienda que los alumnos interesados tengan conocimiento de Historia, en general, y de Historia del Arte en particular."""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
