        <https://guia-kg.skai.etsisi.upm.es/resource/43000580/2025-26/syllabus/6>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000580/2025-26/syllabus/7>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000580/2025-26/syllabus/8>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000580/2025-26/syllabus/9> .

<https://guia-kg.skai.etsisi.upm.es/resource/43000580/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Planteamiento general del problema. El contexto general. El ámbito que cubre esta asignatura. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000580/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "2. Caracterización del comportamiento mecánico de las fábricas. Propiedades de bloques, morteros, interfaz. Fábrica aparejada. Comportamiento en el plano y fuera de él. Comportamiento reológico. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000580/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "4.3. Metodología para el análisis estructural de comprobación y de proyecto de refuerzos Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000580/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "5. Cúpulas. Evolución histórica y formal. Procesos constructivos Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000580/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "6. Iglesias y catedrales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000580/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "6.1. Recorrido cronológico de tipologías constructivas y significados. Particularidades especiales Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000580/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "6.2. Comprobación de la sección transversal típica. Importancia de los rellenos en trasdós de bóvedas de puentes y edificios. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000580/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "3. Procedimientos de análisis estructural de construcciones de fábrica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000580/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "3.1. Procedimientos empíricos clásicos. Ratios geométricas habituales. Procedimientos basados en el equilibrio: análisis límite y bloques rígidos (nivel I). Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000580/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "3.2. Procedimientos basados en la Estática Gráfica. Conceptos fundamentales y herramientas informáticas disponibles (nivel I). Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000580/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "3.3. Procedimientos basados en el encadenamiento de líneas de presión y comprobación seccional (nivel II). Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000580/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "3.4. Posibilidades prácticas en el diseño de nuevas obras de fábrica, con la experiencia de las existentes. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000580/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "4. Puentes de bóvedas de fábrica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000580/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "4.1. Tipologías. Clasificación geométrica e histórica. Identificación de elementos estructurales y constructivos Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000580/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "4.2. Revisión del proyecto y construcción clásicos de puentes de piedra Sin subniveles"@es .

