<https://guia-kg.skai.etsisi.upm.es/resource/20504323/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Introducción"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504323/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Concepto de genoma, transcriptoma, proteoma y metaboloma Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504323/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "3.1. Definición de proteoma y proteómica. Homogeneización de células. Preparación de muestras. Electroenfoque. Electroforesis bidimensional (2D) de proteínas. Visualización y Análisis. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504323/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "3.2. MALDI-TOF MS. Extracción de proteínas intactas. Huella de masa péptidica (PMF). LC-ESI MS/MS. Huella de fragmento peptídico (PFF). Secuenciación de novo. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504323/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "3.3. Marcaje isotópico diferencial (ICAT). Uso de etiquetas para cuantificación relativa y absoluta (iTRAQ). Cuantificación absoluta de proteínas (AQUA). Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504323/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "3.4. Tecnología multidimensional de identificación de proteínas. (MudPIT). nanoLC-ESI MS/MS. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504323/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "3.5. Microarrays de proteínas. Sistema de dos híbridos en levaduras. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504323/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "3.6. Sistemas de análisis de interacción proteína-proteína en vivo: TAP-tag, BiFC, TurboID Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504323/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "3.7. LiP-MS y CETSA-MS. Estudio de interacción de proteínas Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504323/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "4. Metabolómica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504323/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "4.1. Definición de metaboloma y metabolómica. Extracción total y selectiva de metabolitos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504323/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "4.2. Resolución cromatográfica. Distribución isotópica. Cromatografía líquida - Espectrometría de masas (LC MS). Derivatización. Fragmentación. Cromatografía de gas. Espectrometría de masas (GC MS). Headspace GC MS (HS/GC-MS). Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504323/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Estructura y función de los principales grupos de biomoléculas: ácidos nucleícos, proteinas, glúcidos, lípidos. Otras biomoléculas y metabolitos secundarios Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504323/2025-26/syllabus/20> a ns1:SyllabusItem ;
    ns1:itemIndex 20 ;
    ns1:syllabusDescription "4.3. Metabolómica cuantitativa (dirigida). Perfiles quimiométricos (no dirigidos) Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504323/2025-26/syllabus/21> a ns1:SyllabusItem ;
    ns1:itemIndex 21 ;
    ns1:syllabusDescription "4.4. Análisis de componentes principales (PCA). Mínimos cuadrados parciales (PLS) mediante proyecciones de estructuras latentes. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504323/2025-26/syllabus/22> a ns1:SyllabusItem ;
    ns1:itemIndex 22 ;
    ns1:syllabusDescription "5. Biología de sistemas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504323/2025-26/syllabus/23> a ns1:SyllabusItem ;
    ns1:itemIndex 23 ;
    ns1:syllabusDescription "5.1. Redes e interacciones de macromoléculas. Interacción entre niveles de organización. Herramientas bioinformáticas en el análisis de redes. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504323/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "1.3. Avances tecnológicos en el análisis global de biomoléculas. Metaanálisis y bioinformática Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504323/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "2. Transcriptómica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504323/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "2.1. Expresión génica. Herramientas para la cuantificación de la RNAs. Tecnologías de baja y media cobertura: Northern-blot, RT-qPCR, AFLP y SAGE. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504323/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "2.2. Microarrays Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504323/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "2.3. RNAseq Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504323/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "2.4. Diseño experimental. Normalización. Genes diferencialmente expresados. Análisis de clusterización. Ontologías génicas. Atlas de expresión. Integración en flujos metabólicos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504323/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "3. Proteómica"@es .

