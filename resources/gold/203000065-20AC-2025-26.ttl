    ns1:learningResultDescription "RA13"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000065/2025-26/RA34> a ns1:LearningResult ;
    ns1:learningResultCode "RA34" ;
    ns1:learningResultDescription "Desarrollar en el alumno la capacidad de resolución de problemas con creatividad, iniciativa, metodología y razonamiento crítico, en el ámbito de la nutrición y la producción animal"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000065/2025-26/RA50> a ns1:LearningResult ;
    ns1:learningResultCode "RA50" ;
    ns1:learningResultDescription "Saber diseñar y dimensionar un alojamiento e instalación ganadera"@es .

