    ns1:inpersonHours "38 horas (48.7%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation """La asignatura se relaciona con ODS 11."Ciudades y comunidades sostenibles".
La principal vía de comunicación con los estudiantes será el correo electrónico institucional y los foros y noticias de la plataforma MOODLE."""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "38 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/23000395/2025-26/eventSchedule> ;
    schema:description "Esta asignatura trata sobre el proyecto en sus aspectos formales, lo que se denomina la morfología del proyecto: los documentos que debe llevar según el destino."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/julia.urquijo%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/jesus.lopez.santiago%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/julia.urquijo%40upm.es> ;
    schema:name "Documentos del Proyecto. Programas de Calculo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000395/2025-26/C3> a ns1:Competency ;
    ns1:competencyCode "C3" ;
    ns1:competencyDescription "Capacidad de establecer los objetivos de un trabajo o proyecto de jardinería y paisajismo y programar las actividades necesarias para su consecución, determinando sus fases y tiempo de ejecución, así como los recursos necesarios para alcanzar el objetivo fijado. TIPO: Competencias."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000395/2025-26/C9> a ns1:Competency ;
    ns1:competencyCode "C9" ;
    ns1:competencyDescription "Capacidad de preparar y redactar los documentos propios de un proyecto profesional relacionado con la jardinería y el paisajismo, empleando programas informáticos para el cálculo y la presentación de dichos documentos TIPO: Competencias."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000395/2025-26/K7> a ns1:Competency ;
    ns1:competencyCode "K7" ;
    ns1:competencyDescription "Conocer las características de los documentos de los proyectos profesionales dentro del ámbito de la jardinería y el paisajismo, así como la normativa aplicable en cada caso. TIPO: Conocimientos o contenidos."@es .

