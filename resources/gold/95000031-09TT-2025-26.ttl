<https://guia-kg.skai.etsisi.upm.es/resource/95000031/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Que los estudiantes hayan demostrado poseer y comprender conocimientos en un área de estudio que parte de la base de la educación secundaria general, y se suele encontrar a un nivel que, si bien se apoya en libros de texto avanzados, incluye también algunos aspectos que implican conocimientos procedentes de la vanguardia de su campo de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000031/2025-26/CG10> a ns1:Competency ;
    ns1:competencyCode "CG10" ;
    ns1:competencyDescription "Creatividad"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000031/2025-26/CG12> a ns1:Competency ;
    ns1:competencyCode "CG12" ;
    ns1:competencyDescription "Organización y planificación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000031/2025-26/CG2> a ns1:Competency ;
    ns1:competencyCode "CG2" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar sus conocimientos a su trabajo o vocación de una forma profesional y posean las competencias que suelen demostrarse por medio de la elaboración y defensa de argumentos y la resolución de problemas dentro de su área de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000031/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Que los estudiantes tengan la capacidad de reunir e interpretar datos relevantes (normalmente dentro de su área de estudio) para emitir juicios que incluyan una reflexión sobre temas relevantes de índole social, científica o ética"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000031/2025-26/CG5> a ns1:Competency ;
    ns1:competencyCode "CG5" ;
    ns1:competencyDescription "Que los estudiantes hayan desarrollado aquellas habilidades de aprendizaje necesarias para emprender estudios posteriores con un alto grado de autonomía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000031/2025-26/CG8> a ns1:Competency ;
    ns1:competencyCode "CG8" ;
    ns1:competencyDescription "Comunicación oral y escrita"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000031/2025-26/CG9> a ns1:Competency ;
    ns1:competencyCode "CG9" ;
    ns1:competencyDescription "Uso de Tecnologías de la Información y de las Comunicaciones"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000031/2025-26/RA509> a ns1:LearningResult ;
    ns1:learningResultCode "RA509" ;
    ns1:learningResultDescription "Comprender la estructura de Internet, el proceso de normalización y las propiedades de los recursos de denominación y direccionamiento."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000031/2025-26/RA510> a ns1:LearningResult ;
    ns1:learningResultCode "RA510" ;
    ns1:learningResultDescription "Comprender el funcionamiento conjunto de protocolos de aplicación, transporte, red y subred de la arquitectura TCP/IP."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000031/2025-26/RA511> a ns1:LearningResult ;
    ns1:learningResultCode "RA511" ;
    ns1:learningResultDescription "Conocer los servicios que ofrecen los protocolos de transporte, sabiendo seleccionar el más adecuado en función de los requisitos de las aplicaciones. Comprender el funcionamiento de los protocolos de transporte y los algoritmos asociados."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000031/2025-26/RA512> a ns1:LearningResult ;
    ns1:learningResultCode "RA512" ;
    ns1:learningResultDescription "Comprender el funcionamiento de una red IP, tanto en lo que se refiere a las operaciones que se realizan para entregar el tráfico al destino, como a los procesos que ejecutan los nodos para mantener automáticamente las tablas de encaminamiento."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000031/2025-26/RA513> a ns1:LearningResult ;
    ns1:learningResultCode "RA513" ;
    ns1:learningResultDescription "Comprender las técnicas de direccionamiento y encaminamiento existentes para que las redes tengan buenas propiedades de escalabilidad."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000031/2025-26/RA514> a ns1:LearningResult ;
    ns1:learningResultCode "RA514" ;
    ns1:learningResultDescription "Conocer las limitaciones de Internet y las características de la nueva versión de protocolos, conocida como IPv6."@es .

