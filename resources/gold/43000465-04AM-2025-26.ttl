    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/43000465/2025-26/eventSchedule> ;
    schema:description "La asignatura profundiza en los conceptos de plasticidad aplicados a problemas geotécnicos, geomecánicos y de interacción suelo-estructura usando diversos programas de elementos finitos (Abaqus, GeHoMadrid, Midas GNX). El objetivo es que los estudiantes profundizen conocimientos de la plasticidad para utilizar modelos constitutivos en el contexto de los elementos finitos para estudiar el comportamiento de geomateriales (suelos, rocas, hormigones) en problemas de ingeniería civil (p.e.: cimentaciones superficiales y profundas, deslizamientos de taludes, excavaciones urbanas y procesos contructivos). La asignatura busca proveer a los alumnos de herramientas y conocimiento sólidos de plasticidad aplicada a problemas prácticos de los ingenieros civil."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/d.manzanal%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/d.manzanal%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/pedro.navas%40upm.es> ;
    schema:name "Fundamentos de Plasticidad en Geomateriales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000465/2025-26/CB9> a ns1:Competency ;
    ns1:competencyCode "CB9" ;
    ns1:competencyDescription "Que los estudiantes sepan comunicar sus conclusiones y los conocimientos y razones últimas que las sustentan a públicos especializados y no especializados de un modo claro y sin ambigüedades"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000465/2025-26/CE14> a ns1:Competency ;
    ns1:competencyCode "CE14" ;
    ns1:competencyDescription "Capacidad para el ejercicio profesional de alta especialización o para la investigación predoctoral mediante la utilización de recursos de modelización predictiva en Análisis y diseño en ingeniería geotécnica."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000465/2025-26/CT3> a ns1:Competency ;
    ns1:competencyCode "CT3" ;
    ns1:competencyDescription "Compromiso y capacidad de aplicación de los estándares de deontología en investigación y ejercicio profesional avanzado"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000465/2025-26/RA1> a ns1:LearningResult ;
    ns1:learningResultCode "RA1" ;
    ns1:learningResultDescription "Utiliza con eficacia, autonomía y polivalencia recursos de modelización predictiva en la temática de la materia"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000465/2025-26/RA2> a ns1:LearningResult ;
    ns1:learningResultCode "RA2" ;
    ns1:learningResultDescription "Presenta comunicaciones orales, escritas y gráficas, estructurada y argumentadamente, en lengua española e inglesa"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000465/2025-26/RA3> a ns1:LearningResult ;
    ns1:learningResultCode "RA3" ;
    ns1:learningResultDescription "Interioriza los principios de deontología profesional para actividades de I+D+i"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000465/2025-26/RA34> a ns1:LearningResult ;
    ns1:learningResultCode "RA34" ;
    ns1:learningResultDescription "Conoce y sabe aplicar la mecánica de medios continuos no lineal, incluyendo grandes rotaciones y deformaciones, y comportamiento no lineal de los materiales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000465/2025-26/RA38> a ns1:LearningResult ;
    ns1:learningResultCode "RA38" ;
    ns1:learningResultDescription "RA38"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000465/2025-26/RA4> a ns1:LearningResult ;
    ns1:learningResultCode "RA4" ;
    ns1:learningResultDescription "Utiliza con eficacia recursos de información y comunicación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000465/2025-26/RA8> a ns1:LearningResult ;
    ns1:learningResultCode "RA8" ;
    ns1:learningResultDescription "Utiliza con eficacia recursos de modelización predictiva en una o más de las materias del módulo"@es .

