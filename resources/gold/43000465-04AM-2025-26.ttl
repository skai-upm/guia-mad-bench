        <https://guia-kg.skai.etsisi.upm.es/resource/43000465/2025-26/syllabus/16>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000465/2025-26/syllabus/17>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000465/2025-26/syllabus/2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000465/2025-26/syllabus/3>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000465/2025-26/syllabus/4>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000465/2025-26/syllabus/5>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000465/2025-26/syllabus/6>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000465/2025-26/syllabus/7>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000465/2025-26/syllabus/8>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000465/2025-26/syllabus/9> .

<https://guia-kg.skai.etsisi.upm.es/resource/43000465/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Conceptos básicos de la Teoría de Plasticidad"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000465/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Respuesta uniaxial de materiales. Punto de fluiencia. Invariantes de tensión. Nociones de supeficie de fluiencia y potencial plástico. Generalización de los conceptos de plasticidad perfecta y endurecimiento por deformación. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000465/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "5. Geomateriales fluidificados"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000465/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "5.1. Conceptos de reología. Modelos reológicos de Binham, Bagnold, Voellmy. Modelos actuales Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000465/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "6. Métodos de integración de relaciones constitutivas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000465/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "6.1. Integración numérica en plano triaxial de ecuaciones constitutivas. Esquemas de control de deformación y de control de tensión. Ejemplos simples de integración de los modelos de Estado Crítico. Carga drenada y no drenada. Formulaciones generales. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000465/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "7. Casos de aplicación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000465/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "7.1. Casos simples de aplicación de los modelos estudiados: Talud Vertical, Zapata, Columna de suelo Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000465/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "7.2. Uso de programas de elementos finitos comerciales: Desarrollos de casos de interacción suelo-estructura. Excavaciones urbanas. Comportamiento de Torres eólicas. Comportamiento de grupo de pilotes. Comparativa de modelos y resultados. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000465/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "7.3. Uso de programas de elementos finitos de investigación: GeHoMadrid. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000465/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "2. Criterios de rotura en geomateriales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000465/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "2.1. Consideraciones generales desde los resultados experimentales en diferentes geomateriales (suelos, rocas y hormigones). Representación geométrica de superficies de falla. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000465/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "2.2. Criterios de rotura en geomateriales: Tresca, Van Mises, Mohr Coulomb, Drucker Prager, Lade-Duncan, Matsouka-Nakai, William-Warnke, Hoek-Brown, Criterios modificados Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000465/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "3. Derivación de relaciones constitutivas en geomateriales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000465/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "3.1. Conceptos de endurecimiento y reblandecimiento en geomateriales. Análisis de resultados experimentales en arcillas y arenas. Conceptos de Estado Crítico. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000465/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "3.2. Formulaciones con endurecimiento isotrópico. Modelo Cam-Clay modificado. Formulaciones con endurecimiento cinemático y combinadas:isotrópico y cinemátcios. Hardening Soil Model. Modelos de Superficie de Fluencia. Plasticidad generalizada. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000465/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "4. Extensión de modelos constitutivos a casos especiales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000465/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "4.1. Comportamiento ciclico. Extensión a materiales anisotrópicos, estructurados y no saturados. Sin subniveles"@es .

