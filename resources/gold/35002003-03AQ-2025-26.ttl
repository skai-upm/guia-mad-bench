    ns1:inpersonHours "90 horas (55.6%)"@es ;
    ns1:numberOfCredits 6.0 ;
    ns1:otherInformation """La asignatura afecta a los siguientes Objetivos de Desarrollo sostenible:
- ODS 3: Salud y bienestar
- ODS 6: Agua limpia y saneamiento
- ODS 7: Energía asequible y no contaminante
- ODS 11: Ciudades y comunidades sostenibles

La asignatura afecta a los siguientes aspectos relativos a la Agenda Urbana:
- EVITAR LA DISPERSIÓN URBANA Y REVITALIZAR LA CIUDAD EXISTENTE
- 2.6. MEJORAR LA CALIDAD Y LA SOSTENIBILIDAD DE LOS EDIFICIOS
- PREVENIR Y REDUCIR LOS IMPACTOS DEL CAMBIO CLIMÁTICO Y MEJORAR LA RESILIENCIA
- 3.2. REDUCIR LAS EMISIONES DE GASES DE EFECTO INVERNADERO.
- HACER UNA GESTIÓN SOSTENIBLE DE LOS RECURSOS Y FAVORECER LA ECONOMÍA CIRCULAR
4.1. SER MÁS EFICIENTES ENERGÉTICAMENTE Y AHORRAR ENERGÍA.
4.2. OPTIMIZAR Y REDUCIR EL CONSUMO DE AGUA."""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "93 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/35002003/2025-26/eventSchedule> ;
    schema:description "La asignatura pretende que tras los conocimientos adquiridos, los alumnos sean capaces de implantar en un edificio, ya desarrollado por ellos en cursos anteriores, las instalaciones mecánicas mas apropiadas a las características y necesidades de dicho edificio, analizando además las condiciones de limitación de la demanda energética y de las condiciones de protección pasiva contra incendios necesarias. El alumno deberá representar de forma grafica la posición de la maquinaria y de las redes de distribución de fluidos con una aproximación a las dimensiones reales, modificando en caso necesario los aspectos formales, morfológicos y constructivos del edificio seleccionado"@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/jorge.gallego%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/agustin.sanchez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/alexander.diaz%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/beatriz.arranz%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/f.atares%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/jesus.garciah%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/jorge.gallego%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/juancarlos.herranz%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/juanpedro.castejon%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/teresa.carrascal%40upm.es> ;
    schema:name "Proyecto de Instalaciones"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35002003/2025-26/CE%2016> a ns1:Competency ;
    ns1:competencyCode "CE 16" ;
    ns1:competencyDescription "Capacidad para concebir, calcular, diseñar, integrar en edificios y conjuntos urbanos y ejecutar instalaciones de suministro, tratamiento y evacuación de aguas, de calefacción y de climatización."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35002003/2025-26/CE%2017> a ns1:Competency ;
    ns1:competencyCode "CE 17" ;
    ns1:competencyDescription "Aptitud para aplicar las normas técnicas y constructivas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35002003/2025-26/CE%2034> a ns1:Competency ;
    ns1:competencyCode "CE 34" ;
    ns1:competencyDescription "Capacidad para la concepción, la práctica y desarrollo de proyectos básicos y de ejecución, croquis y anteproyectos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35002003/2025-26/CE%2041> a ns1:Competency ;
    ns1:competencyCode "CE 41" ;
    ns1:competencyDescription "Aptitud para resolver el acondicionamiento ambiental pasivo, incluyendo el aislamiento térmico y acústico, el control climático, el rendimiento energético y la iluminación natural."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35002003/2025-26/CG%2015.> a ns1:Competency ;
    ns1:competencyCode "CG 15." ;
    ns1:competencyDescription "Sensibilidad hacia temas medioambientales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35002003/2025-26/CG%203.> a ns1:Competency ;
    ns1:competencyCode "CG 3." ;
    ns1:competencyDescription "Sensibilidad estética"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35002003/2025-26/RA1> a ns1:LearningResult ;
    ns1:learningResultCode "RA1" ;
    ns1:learningResultDescription "Con esta asignatura el alumno será capaz de proponer e identificar las instalaciones hidráulicas y de climatización que forman parte integral del edificio, llegando a proponer una distribución y un predimensionado de las redes y los equipos de que se componen estas instalaciones, además de ser capaz de aplicar la normativa vigente a sus propuestas de instalaciones hidráulicas y de climatización ."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35002003/2025-26/RA126> a ns1:LearningResult ;
    ns1:learningResultCode "RA126" ;
    ns1:learningResultDescription "El alumno será capaz de proponer una distribución de las redes y de los equipos de que se componen estas instalaciones."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35002003/2025-26/RA136> a ns1:LearningResult ;
    ns1:learningResultCode "RA136" ;
    ns1:learningResultDescription "Conocer las condiciones básicas de la sostenibilidad en arquitectura"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35002003/2025-26/RA3> a ns1:LearningResult ;
    ns1:learningResultCode "RA3" ;
    ns1:learningResultDescription "El alumno será capaz de predimensionar las redes y los equipos necesarios."@es .

