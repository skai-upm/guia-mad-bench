    ns1:semester "Séptimo semestre"@es ;
    schema:courseCode 45000158 ;
    schema:hasCourseInstance <https://guia-kg.skai.etsisi.upm.es/resource/45000158/2025-26> ;
    schema:name "Advanced Materials For Microelectronics"@en,
        "Materiales Avanzados para Microelectrónica"@es ;
    schema:numberOfCredits 5.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/45000158/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/45000158/2025-26/CE%206.>,
        <https://guia-kg.skai.etsisi.upm.es/resource/45000158/2025-26/CE%207.>,
        <https://guia-kg.skai.etsisi.upm.es/resource/45000158/2025-26/CG%203>,
        <https://guia-kg.skai.etsisi.upm.es/resource/45000158/2025-26/CG%204> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/45000158/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/45000158/2025-26/didactic_resource/2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/45000158/2025-26/didactic_resource/3>,
        <https://guia-kg.skai.etsisi.upm.es/resource/45000158/2025-26/didactic_resource/4>,
        <https://guia-kg.skai.etsisi.upm.es/resource/45000158/2025-26/didactic_resource/5> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/45000158/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/45000158/2025-26/RA40>,
        <https://guia-kg.skai.etsisi.upm.es/resource/45000158/2025-26/RA41> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/45000158/2025-26/syllabus> ;
    ns1:inpersonHours "54 horas y 30 minutos (41.9%)"@es ;
    ns1:numberOfCredits 5.0 ;
    ns1:otherInformation ""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "54 horas y 30 minutos"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/45000158/2025-26/eventSchedule> ;
    schema:description "El objetivo de la asignatura es que los estudiantes adquieran un conocimiento aplicado del funcionamiento de los dispositivos sobre los que se desarrolla la microelectrónica y de los fundamentos de los materiales involucrados. Para ello se estudia la tecnología de los transistores basados en uniones pn y de efecto campo, con especial énfasis en los transistores de unión metal-óxido-semiconductor (MOSFET), y su integración en tecnología CMOS (memorias RAM, CCDs, puertas lógicas, etc). Una vez definido el funcionamiento de los dispositivos microelectrónicos básicos, se analizan los materiales semiconductores de mayor relevancia actual, como el Si, el Si-Ge y las aleaciones basadas en GaAs, y los que tienen mayor perspectiva futura, como el SiC, diamante y aleaciones basadas en GaN."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/adrian.hierro%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/adrian.hierro%40upm.es> ;
    schema:name "Materiales Avanzados para Microelectrónica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000158/2025-26/CE%206.> a ns1:Competency ;
    ns1:competencyCode "CE 6." ;
    ns1:competencyDescription "Saber diseÃ±ar, evaluar, seleccionar y fabricar materiales segÃºn sus aplicaciones / Know how to design, evaluate, select and manufacture materials according to their applications"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000158/2025-26/CE%207.> a ns1:Competency ;
    ns1:competencyCode "CE 7." ;
    ns1:competencyDescription "Saber diseñar, desarrollar y controlar los procesos de producción y transformación de materiales / Know how to design, develop and control the processes of production and transformation of materials"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000158/2025-26/CG%203> a ns1:Competency ;
    ns1:competencyCode "CG 3" ;
    ns1:competencyDescription "Comunicación oral y escrita"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000158/2025-26/CG%204> a ns1:Competency ;
    ns1:competencyCode "CG 4" ;
    ns1:competencyDescription "Uso de las Tecnologías de la Información y de las Comunicaciones/ Use of Information and Communication Technologies"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000158/2025-26/RA40> a ns1:LearningResult ;
    ns1:learningResultCode "RA40" ;
    ns1:learningResultDescription "Conocer y comprender los procesos de selección y diseño de las distintas familias de materiales, sabiendo entender de forma integradora los aspectos comunes de las tecnologías utilizadas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000158/2025-26/RA41> a ns1:LearningResult ;
    ns1:learningResultCode "RA41" ;
    ns1:learningResultDescription "Conocer y comprender las distintas técnicas de fabricación y transformación de materiales, y las tecnologías subyacentes, poniendo de relieve los aspectos comunes a cada familia de materiales."@es .

