    schema:description "El contenido de esta asignatura está enfocado a la prevención de riesgos laborales en el ámbito profesional."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/jorge.moreno%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/fj.tarin%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/jorge.moreno%40upm.es> ;
    schema:name "Seguridad y Salud en el Trabajo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000185/2025-26/CG%201.> a ns1:Competency ;
    ns1:competencyCode "CG 1." ;
    ns1:competencyDescription "Conocer y aplicar los conocimientos de ciencias y tecnologías básicas a la práctica de la Ingeniería Industrial"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000185/2025-26/CG%202.> a ns1:Competency ;
    ns1:competencyCode "CG 2." ;
    ns1:competencyDescription "Poseer la capacidad para diseñar, desarrollar, implementar, gestionar y mejorar productos, sistemas y procesos en los distintos ámbitos industriales, usando técnicas analíticas, computacionales o experimentales apropiadas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000185/2025-26/CG%203.> a ns1:Competency ;
    ns1:competencyCode "CG 3." ;
    ns1:competencyDescription "Aplicar los conocimientos adquiridos para identificar, formular y resolver problemas en contextos amplios, siendo capaces de integrar los trabajando en equipos multidisciplinares"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000185/2025-26/CG%204.> a ns1:Competency ;
    ns1:competencyCode "CG 4." ;
    ns1:competencyDescription "Comprender el impacto de la ingeniería en el medio ambiente, el desarrollo sostenible de la sociedad y la importancia de trabajar en un entorno profesional y responsable"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000185/2025-26/CG%205.> a ns1:Competency ;
    ns1:competencyCode "CG 5." ;
    ns1:competencyDescription "Comunicar conocimientos y conclusiones, tanto de forma oral como escrita, a públicos especializados y no especializados de modo claro y sin ambigüedades."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000185/2025-26/CG%206.> a ns1:Competency ;
    ns1:competencyCode "CG 6." ;
    ns1:competencyDescription "Poseer las habilidades de aprendizaje que permitan continuar estudiando a lo largo de toda la vida para un desarrollo profesional adecuado"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000185/2025-26/CG%207.> a ns1:Competency ;
    ns1:competencyCode "CG 7." ;
    ns1:competencyDescription "Incorporar las TIC y las tecnologías y herramientas de la Ingeniería Industrial en sus actividades profesionales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000185/2025-26/CG%209.> a ns1:Competency ;
    ns1:competencyCode "CG 9." ;
    ns1:competencyDescription "Organización y planificación de proyectos y equipos humanos. Trabajo en equipo y capacidad de liderazgo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000185/2025-26/RA124> a ns1:LearningResult ;
    ns1:learningResultCode "RA124" ;
    ns1:learningResultDescription "Procesos normativos y regulaciones asociadas a la seguridad y salud laboral aplicables a procesos laborales (Leyes, Reglamentos, Reales Decretos, Normas, etc.)"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000185/2025-26/RA125> a ns1:LearningResult ;
    ns1:learningResultCode "RA125" ;
    ns1:learningResultDescription "Reconocimiento, evaluación de riesgos por distintas metodologías y propuesta de medidas de control en los procesos laborales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000185/2025-26/RA126> a ns1:LearningResult ;
    ns1:learningResultCode "RA126" ;
    ns1:learningResultDescription "Cultura preventiva, así, como potenciación de la integración de la prevención de riesgos laborales en el proceso organizativo laboral."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000185/2025-26/RA127> a ns1:LearningResult ;
    ns1:learningResultCode "RA127" ;
    ns1:learningResultDescription "Elaborar planes de prevención de riegos laborales, manuales de autoprotección y estudios de seguridad y salud."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000185/2025-26/RA44> a ns1:LearningResult ;
    ns1:learningResultCode "RA44" ;
    ns1:learningResultDescription "Conocimientos de seguridad en el trabajo e higiene industrial así como capacidad para su aplicación práctica"@es .

