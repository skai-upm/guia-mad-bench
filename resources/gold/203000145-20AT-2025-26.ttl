        <https://guia-kg.skai.etsisi.upm.es/resource/203000145/2025-26/RA3> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/203000145/2025-26/syllabus> ;
    ns1:inpersonHours "38 horas (36.5%)"@es ;
    ns1:numberOfCredits 4.0 ;
    ns1:otherInformation "En la asignatura se trabajaran temas que conectan con los objetivos Hambre cero(ODS2) y Salud y Bienestar(ODS3) de la agenda de Desarrollo Sostenible (ODS) de Naciones Unidas, ya que ser abordaran temas relacionados con la mejora en la produccion de alimentos, su calidad, y su seguridad para el consumo humano."@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "46 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/203000145/2025-26/eventSchedule> ;
    schema:description "La asignatura consiste en conocer las bases de la genómica y la bioinformática, y cómo éste conocimiento podría ser útil para la investigación y desarrollo en el contesto de la Ingeniería Alimentaria. Por un lado, se estudia cómo se representan los datos biológicos en un ordenador. A continuación, se revisarán las principales técnicas de obtención de datos genómicos en la actualidad, y los principales métodos para identificar especies y variedades de organismos beneficiosos y patógenos, en procesos y productos relacionados con la industria alimentaria. Posteriormente, se introducirá el trabajo en bioinformática. Con un enfoque más práctico, se harán algunas prácticas de trabajo de análisis de datos mediante aplicaciones web y programación informática."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/carlos.cantalapiedra%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/carlos.cantalapiedra%40upm.es> ;
    schema:name "Bioinformática y Genómica Aplicada Al Análisis de Alimentos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000145/2025-26/CB7> a ns1:Competency ;
    ns1:competencyCode "CB7" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en entornos nuevos o poco conocidos dentro de contextos más amplios (o multidisciplinares) relacionados con su área de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000145/2025-26/CE10> a ns1:Competency ;
    ns1:competencyCode "CE10" ;
    ns1:competencyDescription "Conocimientos y capacidad para diseñar, organizar, ejecutar y analizar pruebas sensoriales adecuadas para lograr los objetivos de un estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000145/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Capacidad de observación, generación de hipótesis y planteamiento de problemas experimentales en el ámbito de la alimentación y la salud."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000145/2025-26/CG5> a ns1:Competency ;
    ns1:competencyCode "CG5" ;
    ns1:competencyDescription "Capacidad para realizar búsquedas bibliográficas en bases de datos y para gestionar la información trabajando en contextos internacionales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000145/2025-26/CG6> a ns1:Competency ;
    ns1:competencyCode "CG6" ;
    ns1:competencyDescription "Capacidad de innovación, resolución de problemas, toma de decisiones, discusión y conclusiones científicas."@es .

