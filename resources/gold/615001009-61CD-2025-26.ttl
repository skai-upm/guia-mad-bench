<https://guia-kg.skai.etsisi.upm.es/resource/615001009/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Introducción a la representación de la información"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615001009/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Introducción: Los datos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615001009/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "3.4. Introducción a la administración de sistemas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615001009/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Representación de la información numérica. Aritmética. Representación de la información no escalar. Representación de la información gráfica. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615001009/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "1.3. Introducción a la compresión de la información y la criptografía. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615001009/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "2. Arquitectura de computadores"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615001009/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "2.1. Arquitectura Von Neumann. Paralelismo a nivel de instrucción. Programas máquina y ensamblador. Estudio de rendimiento.Jerarquía de memorias. Memoria Principal. Memoria Caché. Memoria Virtual. E/S. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615001009/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "3. Sistemas Operativos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615001009/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "3.1. Software de sistemas y software de aplicación. Fundamentos de programación para sistemas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615001009/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "3.2. Funciones del sistema operativo. Concepto de usuario y de proceso. Arranque del computador. Activación del SO. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615001009/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "3.3. Procesos. Threads. Servidor de ficheros. Intérprete de mandatos. Concurrencia. Seguridad. Sin subniveles"@es .

