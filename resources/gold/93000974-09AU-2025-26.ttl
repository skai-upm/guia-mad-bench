    ns1:inpersonHours "34 horas (43.6%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation "This course is related to United Nations' Sustainable Development Goals, in particular goal 3: Ensure healthy lives and promote well-being for all at all ages, and goal 4: Quality education"@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "34 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/93000974/2025-26/eventSchedule> ;
    schema:description "The course studies advanced techniques to analyze and process biomedical images and signals to obtain information about the function or the activity of tissues and organs. This information will be useful for medical diagnosis or for therapy planning and follow-up. The theoretical knowledge will be applied practically by developing algorithms for the analysis and visualization of images and signals in real cases."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/mj.ledesma%40upm.es> ;
    schema:inLanguage "Inglés/Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/lucilio.cordero%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/mj.ledesma%40upm.es> ;
    schema:name "Temas Avanzados en Señales e Imágenes Médicas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000974/2025-26/CB06> a ns1:Competency ;
    ns1:competencyCode "CB06" ;
    ns1:competencyDescription "Poseer y comprender conocimientos que aporten una base u oportunidad de ser originales en el desarrollo y/o aplicación de ideas, a menudo en un contexto de investigación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000974/2025-26/CB07> a ns1:Competency ;
    ns1:competencyCode "CB07" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en entornos nuevos o poco conocidos dentro de contextos más amplios (o multidisciplinares) relacionados con su área de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000974/2025-26/CB08> a ns1:Competency ;
    ns1:competencyCode "CB08" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de integrar conocimientos y enfrentarse a la complejidad de formular juicios a partir de una información que, siendo incompleta o limitada, incluya reflexiones sobre las responsabilidades sociales y éticas vinculadas a la aplicación de sus conocimientos y juicios"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000974/2025-26/CB09> a ns1:Competency ;
    ns1:competencyCode "CB09" ;
    ns1:competencyDescription "Que los estudiantes sepan comunicar sus conclusiones y los conocimientos y razones últimas que las sustentan a públicos especializados y no especializados de un modo claro y sin ambigüedades"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000974/2025-26/CB10> a ns1:Competency ;
    ns1:competencyCode "CB10" ;
    ns1:competencyDescription "Que los estudiantes posean las habilidades de aprendizaje que les permitan continuar estudiando de un modo que habrá de ser en gran medida autodirigido o autónomo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000974/2025-26/CE> a ns1:Competency ;
    ns1:competencyCode "CE" ;
    ns1:competencyDescription "MIB01"@es,
