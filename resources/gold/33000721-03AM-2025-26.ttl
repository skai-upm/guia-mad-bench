    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/alejandro.garcia.hermida%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/fernando.vela%40upm.es> ;
    schema:name "Estudio Documental y Arqueológico de Construcciones Históricas"@es .

