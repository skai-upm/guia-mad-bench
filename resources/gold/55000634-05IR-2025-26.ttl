<https://guia-kg.skai.etsisi.upm.es/resource/55000634/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Integrales sobre curvas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000634/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Arco de curva parametrizado. Curva geométrica. Curva de Jordan. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000634/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "3.2. Teorema de la divergencia o de Gauss. Significado geométrico del operador divergencia. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000634/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "3.3. Orientación coherente de superficie y borde. Teorema de Stokes. Significado geométrico del operador rotacional. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000634/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "4. Teoría de campos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000634/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "4.1. Dominios convexos, estrellados y simplemente conexos en Rn. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000634/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "4.2. Campos irrotacionales. Condición suficiente para que un campo sea conservativo en R3. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000634/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "5. Ecuaciones diferenciales ordinarias (EDO) de primer orden."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000634/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "5.1. Introducción a las ecuaciones diferenciales: definición, aplicaciones, tipos, orden, solución. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000634/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "5.2. EDO de orden n. Problema de valor inicial. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000634/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "5.3. Resolución de EDO de primer orden: EDO de variables separables, EDO homogénea, EDO lineal, EDO de Bernoulli, EDO exacta. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000634/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "5.4. Aplicaciones: ley de desintegración radiactiva, ley de enfriamiento de Newton, reacciones químicas, crecimiento de poblaciones. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000634/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Longitud de una curva. Integral de línea de un campo escalar. Integral de línea de un campo vectorial. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000634/2025-26/syllabus/20> a ns1:SyllabusItem ;
    ns1:itemIndex 20 ;
    ns1:syllabusDescription "6. Sistemas de ecuaciones diferenciales lineales de primer orden y coeficientes constantes."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000634/2025-26/syllabus/21> a ns1:SyllabusItem ;
    ns1:itemIndex 21 ;
    ns1:syllabusDescription "6.1. Escritura matricial. Sistema homogéneo x'=Ax. Solución general si A es diagonalizable en R. Solución general si A es diagonalizable en C. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000634/2025-26/syllabus/22> a ns1:SyllabusItem ;
    ns1:itemIndex 22 ;
    ns1:syllabusDescription "6.2. Exponencial de una matriz. Sistema no homogéneo x'=Ax+b. Solución general y solución del problema de valor inicial. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000634/2025-26/syllabus/23> a ns1:SyllabusItem ;
    ns1:itemIndex 23 ;
    ns1:syllabusDescription "7. EDO lineal de segundo orden con coeficientes constantes."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000634/2025-26/syllabus/24> a ns1:SyllabusItem ;
    ns1:itemIndex 24 ;
    ns1:syllabusDescription "7.1. EDO homogénea. Ecuación característica. Conjunto fundamental de soluciones. Solución general. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000634/2025-26/syllabus/25> a ns1:SyllabusItem ;
    ns1:itemIndex 25 ;
    ns1:syllabusDescription "7.2. EDO no homogénea. Solución general. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000634/2025-26/syllabus/26> a ns1:SyllabusItem ;
    ns1:itemIndex 26 ;
    ns1:syllabusDescription "7.3. Aplicaciones: movimiento armónico simple, movimiento amortiguado, movimiento forzado. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000634/2025-26/syllabus/27> a ns1:SyllabusItem ;
    ns1:itemIndex 27 ;
    ns1:syllabusDescription "8. Sistemas de ecuaciones diferenciales no lineales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000634/2025-26/syllabus/28> a ns1:SyllabusItem ;
    ns1:itemIndex 28 ;
    ns1:syllabusDescription "8.1. Sistemas diferenciales no lineales planos autónomos. Plano de fases. Solución. Trayectorias u órbitas. Ecuación de las órbitas. Integral primera. Diagrama de fases. Puntos de equilibrio. Estabilidad de los puntos de equilibrio. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000634/2025-26/syllabus/29> a ns1:SyllabusItem ;
    ns1:itemIndex 29 ;
    ns1:syllabusDescription "8.2. Espacio de fases de sistemas lineales planos x'=Ax, con det(A) distinto de 0. Naturaleza y estabilidad del origen. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000634/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "1.3. Operador gradiente. Campos de gradientes. Potencial escalar. Independencia del camino. Campos conservativos. Condición necesaria para que un campo sea conservativo. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000634/2025-26/syllabus/30> a ns1:SyllabusItem ;
    ns1:itemIndex 30 ;
    ns1:syllabusDescription "8.3. Puntos de equilibrio hiperbólicos de un sistema lineal plano. Linealización de un sistema no lineal plano autónomo. Teorema de Hartman-Grobman. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000634/2025-26/syllabus/31> a ns1:SyllabusItem ;
    ns1:itemIndex 31 ;
    ns1:syllabusDescription "9. Ecuaciones en derivadas parciales (EDP)."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000634/2025-26/syllabus/32> a ns1:SyllabusItem ;
    ns1:itemIndex 32 ;
    ns1:syllabusDescription "9.1. Definición. Orden de una EDP. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000634/2025-26/syllabus/33> a ns1:SyllabusItem ;
    ns1:itemIndex 33 ;
    ns1:syllabusDescription "9.2. Series de Fourier. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000634/2025-26/syllabus/34> a ns1:SyllabusItem ;
    ns1:itemIndex 34 ;
    ns1:syllabusDescription "9.3. Problema de autofunciones y autovalores. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000634/2025-26/syllabus/35> a ns1:SyllabusItem ;
    ns1:itemIndex 35 ;
    ns1:syllabusDescription "9.4. Método de separación de variables para resolver EDP de segundo orden. Resolución de la ecuación del calor, la ecuación de ondas y la ecuación de Laplace. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000634/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "1.4. Dominios simplemente conexos en el plano. Teorema de Green en el plano. Condición suficiente para que un campo sea conservativo en el plano. Aplicación al cálculo de áreas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000634/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "2. Integrales de superficie."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000634/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "2.1. Superficies parametrizadas en R3. Vector normal, recta normal y plano tangente a una superficie. Superficies orientables. Superficies cerradas y superficies con borde. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000634/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "2.2. Área de una superficie. Integral de un campo escalar sobre una superficie. Integral de un campo vectorial sobre una superficie. Significado geométrico del operador laplaciano. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000634/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "3. Teoremas Integrales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000634/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "3.1. Operador divergencia. Operador rotacional. Sin subniveles"@es .

