    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/55000634/2025-26/eventSchedule> ;
    schema:description "La primera parte de la asignatura se ocupa del análisis vectorial: parametrización, teoría de campos, integrales de línea y superficie y los teoremas de Green, Gauss y Stokes. La segunda parte se ocupa del estudio de las ecuaciones diferenciales. En ambos casos se pretende instruir al alumnado en el uso de dichas herramientas para modelizar problemas que aparecen en la ingeniería (físicos, químicos, etc.) ."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/juancarlos.garciaa%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/juancarlos.garciaa%40upm.es> ;
    schema:name "Matemáticas III"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000634/2025-26/CE1> a ns1:Competency ;
    ns1:competencyCode "CE1" ;
    ns1:competencyDescription "Capacidad para conocer, entender y utilizar los principios de Álgebra lineal, cálculo diferencial e integral, ecuaciones diferenciales y métodos y algorítmica numérica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000634/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Conocer y aplicar conocimientos de ciencias y tecnologías básicas a la práctica de la Ingeniería de organización"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000634/2025-26/CG5> a ns1:Competency ;
    ns1:competencyCode "CG5" ;
    ns1:competencyDescription "Saber comunicar los conocimientos y conclusiones, tanto de forma oral, escrita y gráfica, a públicos especializados y no especializados de un modo claro y sin ambigüedades"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000634/2025-26/CG6> a ns1:Competency ;
    ns1:competencyCode "CG6" ;
    ns1:competencyDescription "Poseer habilidades de aprendizaje que permitan continuar estudiando a lo largo de la vida para su adecuado desarrollo profesional"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000634/2025-26/RA10> a ns1:LearningResult ;
    ns1:learningResultCode "RA10" ;
    ns1:learningResultDescription "Comprender los conceptos básicos de la geometría diferencial de curvas y superficies"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000634/2025-26/RA11> a ns1:LearningResult ;
    ns1:learningResultCode "RA11" ;
    ns1:learningResultDescription "Parametrizar curvas y superficies sencillas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000634/2025-26/RA12> a ns1:LearningResult ;
    ns1:learningResultCode "RA12" ;
    ns1:learningResultDescription "Comprender de los conceptos de integral curvilínea y de superficie"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000634/2025-26/RA13> a ns1:LearningResult ;
    ns1:learningResultCode "RA13" ;
    ns1:learningResultDescription "Expresar integrales curvilíneas como integrales simples e integrales de superficie como integrales dobles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000634/2025-26/RA14> a ns1:LearningResult ;
    ns1:learningResultCode "RA14" ;
    ns1:learningResultDescription "Manejar las técnica de separación de variables para el estudio de las soluciones de ecuaciones en derivadas parciales lineales de segundo orden"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000634/2025-26/RA15> a ns1:LearningResult ;
    ns1:learningResultCode "RA15" ;
    ns1:learningResultDescription "Utilizar todos los conceptos introducidos para construir modelos de algunos problemas reales sencillos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000634/2025-26/RA2> a ns1:LearningResult ;
    ns1:learningResultCode "RA2" ;
    ns1:learningResultDescription "Comprender del significado e importancia de la linealidad como metodología para la formulación de problemas de ingeniería"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000634/2025-26/RA218> a ns1:LearningResult ;
    ns1:learningResultCode "RA218" ;
    ns1:learningResultDescription "Capacidad de abstracción"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000634/2025-26/RA219> a ns1:LearningResult ;
    ns1:learningResultCode "RA219" ;
    ns1:learningResultDescription "Habilidad para aplicación de métodos analíticos a problemas de la Física"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000634/2025-26/RA7> a ns1:LearningResult ;
    ns1:learningResultCode "RA7" ;
    ns1:learningResultDescription "Manejar las técnicas de integración para el cálculo de áreas y volúmenes"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000634/2025-26/RA8> a ns1:LearningResult ;
    ns1:learningResultCode "RA8" ;
    ns1:learningResultDescription "Utilizar estos conceptos para construir modelos de algunos problemas reales sencillos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000634/2025-26/RA9> a ns1:LearningResult ;
    ns1:learningResultCode "RA9" ;
    ns1:learningResultDescription "Distinguir cuando los modelos se pueden resolver mediante las técnicas introducidas y, en tales casos, capacidad para obtener la solución"@es .

