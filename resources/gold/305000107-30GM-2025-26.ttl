<https://guia-kg.skai.etsisi.upm.es/resource/305000107/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Introducción"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000107/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. El plano afín. Aplicaciones afines. Razón simple. Coordenadas cartesianas y baricéntricas. El plano proyectivo. Coordenadas homogéneas. Aplicaciones proyectivas. Razón doble. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000107/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "6. Generación de superficies"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000107/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "6.1. Superficies traslacionales. Superficies regladas y desarrollables. Superficies de Coons. Superficies de revolución. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000107/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "2. Curvas de Bézier"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000107/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "2.1. Polinomios de Bernstein. Curvas polinómicas en forma de Bézier. Propiedades. Elevación del grado. Algoritmo de de Casteljau. Forma polar. Derivadas. Interpolación y aproximación. Elección de nudos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000107/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "3. Curvas racionales de Bézier"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000107/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "3.1. Curvas racionales de Bézier. Pesos. Propiedades. Elevación del grado. Algoritmo de de Casteljau. Derivadas. Interpolación y aproximación. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000107/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "4. Curvas spline"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000107/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "4.1. Ejemplos de curvas polinómicas a trozos. Curvas B-spline. Algoritmo de de Boor. Propiedades. Algoritmo de inserción. Elevación del grado. Diferenciabilidad. Funciones B-spline o nodales. Propiedades. Splines racionales. Teorema de Holladay. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000107/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "5. Superficies de Bézier y spline"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000107/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "5.1. Superficies polinómicas en forma de Bézier. Superficies racionales. Propiedades. Elevación del grado. Algoritmo de de Casteljau. Forma polar. Derivadas. Interpolación y aproximación Sin subniveles"@es .

