    ns1:itemIndex 19 ;
    ns1:syllabusDescription "6.3. Métodos iterativos para sistemas de ecuaciones lineales Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125008507/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Triedro de Frenet. Curvatura y torsión. Cálculo geométrico de la curvatura de una curva plana Sin subniveles"@es .

