    ns1:itemIndex 12 ;
    ns1:syllabusDescription "4. Valores extremos de funciones de varias variables"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125008507/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "4.1. Máximos y mínimos relativos. Criterios para la existencia de valores extremos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125008507/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "4.2. Máximos y mínimos condicionados. Método de los multiplicadores de Lagrange. Problemas de optimización. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125008507/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "5. Integrales dobles Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125008507/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "6. Resolución numérica de sistemas de ecuaciones lineales"@es .

