<https://guia-kg.skai.etsisi.upm.es/resource/65001033/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Introducción general de la Mineralurgia"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001033/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. L1.- Fundamentos de los procesos mineralúrgicos. Operaciones unitarias. Grado y tamaño de liberación. Técnicas de separación y concentración. Conceptos de ley y recuperación. Acondicionamiento de productos. Esquemas de proceso. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001033/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "3.4. L8.- Trituradoras de impacto. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001033/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "3.5. L9.- Trituradores de cilindros. Funcionamiento y tipos (lisos/dentados, dos cilindros/placa). Granulometría de los productos. Criterios de selección. Elementos de regulación. Control de tamaño y seguridad. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001033/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "4. Clasificación por equivalencia"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001033/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "4.1. L10.- Clasificación por equivalencia. Conceptos. Velocidad límite. Partículas isódromas. Índice de esfericidad. Imperfección de la clasificación. Curvas de Tromp. Curvas de partición. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001033/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "4.2. L11.- Clasificadores hidráulicos. Conos. Cajas de puntas. Clasificadores de corriente ascendente. Clasificadores mecánicos. Clasificadores en contracorriente. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001033/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "4.3. L12.- Hidrociclones. Funcionamiento y selección. Aplicaciones como clasificadores y espesadores. Dimensiones de partición. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001033/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "4.4. L13.- Decantación, filtración y centrifugación. Equipos, condiciones y campo de utilización de cada uno de estos procesos. Secado. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001033/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "5. Molienda"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001033/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "5.1. L14.- Principios de la molienda. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001033/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "5.2. L15.- Molienda en barras y bolas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001033/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "2. Cribado"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001033/2025-26/syllabus/20> a ns1:SyllabusItem ;
    ns1:itemIndex 20 ;
    ns1:syllabusDescription "5.3. L16.- Molienda autógena (AG) y semiautógena (SAG). Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001033/2025-26/syllabus/21> a ns1:SyllabusItem ;
    ns1:itemIndex 21 ;
    ns1:syllabusDescription "6. Concentración gravimétrica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001033/2025-26/syllabus/22> a ns1:SyllabusItem ;
    ns1:itemIndex 22 ;
    ns1:syllabusDescription "6.1. L17.- Sistemas de concentración gravimétrica. Fundamento. Velocidad de caída. Criterio de Taggart. Métodos de lámina pelicular fluente. Equipos de plano fijo. Conos Reichert. Espirales. Equipos de plano móvil. Mesas de sacudidas. Tipos. Instalaciones. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001033/2025-26/syllabus/23> a ns1:SyllabusItem ;
    ns1:itemIndex 23 ;
    ns1:syllabusDescription "6.2. L18.- Método de aceleración diferencial. Equipos. Criba hidráulica. Jigs de criba fija y móvil. Jigs centrífugos. Jigs neumáticos. Aplicaciones. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001033/2025-26/syllabus/24> a ns1:SyllabusItem ;
    ns1:itemIndex 24 ;
    ns1:syllabusDescription "6.3. L19.- Concentración por medios densos. Fundamento. Características del medio. Circuitos de separación por medios densos. Equipos. Separadores con medio denso estático/dinámico. Instalaciones. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001033/2025-26/syllabus/25> a ns1:SyllabusItem ;
    ns1:itemIndex 25 ;
    ns1:syllabusDescription "6.4. L20.- Ensayos de separación por líquidos densos. Curvas de lavabilidad y densimétricas. Dificultad de lavado del bruto. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001033/2025-26/syllabus/26> a ns1:SyllabusItem ;
    ns1:itemIndex 26 ;
    ns1:syllabusDescription "6.5. L21.- Control del lavado por medios densos. Triángulos de error. Curva de partición del aparato separador. Imperfección del lavado. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001033/2025-26/syllabus/27> a ns1:SyllabusItem ;
    ns1:itemIndex 27 ;
    ns1:syllabusDescription "7. Separación magnética y electrostática"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001033/2025-26/syllabus/28> a ns1:SyllabusItem ;
    ns1:itemIndex 28 ;
    ns1:syllabusDescription "7.1. L22.- Concentración magnética. Fundamento. Clasificación de las sustancias minerales por sus propiedades magnéticas. Equipos de separación en seco/húmedo. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001033/2025-26/syllabus/29> a ns1:SyllabusItem ;
    ns1:itemIndex 29 ;
    ns1:syllabusDescription "7.2. L23.- Separación electrostática. Fundamento. Efecto corona. Tipos de carga de las partículas (conductoras y no). Equipos electrodinámicos y electrostáticos (rotor y placa). Precipitadores electrostáticos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001033/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "2.1. L2.- Importancia de la clasificación en la industria. Control en el Laboratorio. Análisis granulométricos. Escalas de tamices más utilizadas. Representación gráfica de los resultados y utilización práctica de las curvas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001033/2025-26/syllabus/30> a ns1:SyllabusItem ;
    ns1:itemIndex 30 ;
    ns1:syllabusDescription "8. Concentración por flotación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001033/2025-26/syllabus/31> a ns1:SyllabusItem ;
    ns1:itemIndex 31 ;
    ns1:syllabusDescription "8.1. L24.- Fundamento de la concentración por flotación. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001033/2025-26/syllabus/32> a ns1:SyllabusItem ;
    ns1:itemIndex 32 ;
    ns1:syllabusDescription "8.2. L25.- Interfase líquido-gas. Tensión superficial. Medidas. Adsorción en la interfase. Reactivos espumantes. Ácidos y alcoholes. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001033/2025-26/syllabus/33> a ns1:SyllabusItem ;
    ns1:itemIndex 33 ;
    ns1:syllabusDescription "8.3. L26.- Interfase sólido-líquido-gas. Tamaño máximo flotable. Ensayos de flotación. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001033/2025-26/syllabus/34> a ns1:SyllabusItem ;
    ns1:itemIndex 34 ;
    ns1:syllabusDescription "8.4. L27.- Reactivos de flotación. Colectores aniónicos, catiónicos y no iónicos. Xantatos. Aminas. Iones activantes. Agentes depresores. Curvas críticas. Espumantes. Tipos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001033/2025-26/syllabus/35> a ns1:SyllabusItem ;
    ns1:itemIndex 35 ;
    ns1:syllabusDescription "8.5. L28.- Esquemas de flotación. Minerales con flotabilidad natural. Flotación de sulfuros y minerales sulfurables. Flotación de minerales oxidados y silicatos. Flotación de sales solubles e insolubles. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001033/2025-26/syllabus/36> a ns1:SyllabusItem ;
    ns1:itemIndex 36 ;
    ns1:syllabusDescription "8.6. L29.- Equipos de flotación. Elementos que compone un sistema de flotación. Descripción de la celda de flotación. Tipos. Acondicionadores. Dosificadores de reactivos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001033/2025-26/syllabus/37> a ns1:SyllabusItem ;
    ns1:itemIndex 37 ;
    ns1:syllabusDescription "8.7. L30.- Celdas de flotación mecánicas. Características. Turbinas de agitación. Tanques. Parámetros hidrodinámicos. Controles. Instalación en bancos de desbaste (rougher), barrido (scavenger) y re-lavado (re-cleaner). Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001033/2025-26/syllabus/38> a ns1:SyllabusItem ;
    ns1:itemIndex 38 ;
    ns1:syllabusDescription "8.8. L31.- Celdas de flotación neumáticas. Características. Reactores y difusores. Celdas planas y de columna. Controles. Ventajas e inconvenientes frente a las mecánicas. Circuitos. Celdas para aplicaciones especiales. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001033/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "2.2. L3.- Cribado industrial. Cribas y superficies de cribado. Control del cribado. Factores que intervienen en la capacidad de una criba (luz de malla, forma y dimensiones relativas de los granos y la malla, tamaños críticos, inclinación y humedad). Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001033/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "2.3. L4.- Descripción de las cribas industriales: parrillas fijas, de movimiento lento, curvas, cribas de sacudidas, de resonancia y vibratorias. Frecuencia y amplitud de la vibración. Rendimiento/eficiencia del cribado. Campo de aplicación. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001033/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "3. Trituración"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001033/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "3.1. L5.- Mecanismos de fragmentación. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001033/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "3.2. L6.- Machacadoras primarias. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001033/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "3.3. L7.- Trituradoras secundarias y terciarias. Conos Symons e Hidroconos. Tipos standard/cabeza corta. Tipos de cámaras de trituración. Regulación y potencias. Capacidad. Sin subniveles"@es .

