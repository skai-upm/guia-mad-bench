    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/203000029/2025-26/RA27>,
        <https://guia-kg.skai.etsisi.upm.es/resource/203000029/2025-26/RA28>,
        <https://guia-kg.skai.etsisi.upm.es/resource/203000029/2025-26/RA29>,
        <https://guia-kg.skai.etsisi.upm.es/resource/203000029/2025-26/RA30> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/203000029/2025-26/syllabus> ;
    ns1:inpersonHours "32 horas (41%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation """La Comisión de Calidad del Centro en su reunión de 29 de mayo de 2023 acordó aprobar la propuesta de reasignación de competencias transversales en las asignaturas de los Grados en Biotecnología, Ingeniería Alimentaria, Ingeniería Agrícola, Ingeniería Agroambiental, Ciencias Agrarias y Bioeconomía, y en el Máster Universitario en Ingeniería Agronómica.En virtud de dicho acuerdo, este sujeto ha sido designado como Sujeto Punto NO de Control. Esto significa que si bien se puede seguir trabajando una o varias competencias transversales que se abordan en diferentes puntos y aspectos de la materia, dicha formación y evaluación no será objeto de recogida de evidencia por parte de los sistemas de acreditación de calidad del Centro.
La asignatura se relaciona con el ODS9, ODS11 y el ODS12. En esta asignatura se imparten conocimientos de vanguardia en bioingeniería y diseño de sistemas sintéticos. El aprendizaje de estos conocimientos dota al estudiante de las habilidades y competencias para comprender, seleccionar y aplicar las metas establecidas en el ODS9, ODS11 y el ODS12."""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "40 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/203000029/2025-26/eventSchedule> ;
    schema:description "Synthetic Biology began as a discipline that aimed to program transcriptional circuits in bacterial cells with diverse dynamic behaviors (bistable switches, oscillators, excitability, etc.). This approach complemented Systems Biology by helping to profile some of the hypotheses about the functioning of natural biological systems through the construction of synthetic alternatives. Initial ideas have subsequently developed into other organisms (yeast, mammalian cells, plant cells) with the use of various molecular substrates (along with transcription factors, microRNAs, protein phosphorylation, etc.). Additional aspects that complement modern Synthetic Biology include genomic editing, accelerated evolution, and the notion of the minimal cell. The ultimate goal of this discipline is to combine the best understanding of natural systems with the rules for designing and implementing de novo biological systems."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/k.wabnik%40upm.es> ;
    schema:inLanguage "Inglés"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/k.wabnik%40upm.es> ;
    schema:name "Biología Sintética y de Biosistemas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000029/2025-26/CE02> a ns1:Competency ;
    ns1:competencyCode "CE02" ;
    ns1:competencyDescription "Utilizar sistemas operativos, programas y herramientas de uso común en biología computacional, así como, manejar plataformas de cómputo de altas prestaciones, lenguajes de programación y análisis bioinformáticos/ Utilizing operative systems, software and tools commonly used in computational biology, and working with high throughput platforms, programing languages and bioinformatics tools."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000029/2025-26/CE03> a ns1:Competency ;
    ns1:competencyCode "CE03" ;
    ns1:competencyDescription "Analizar e interpretar bioinformáticamente los datos que se derivan de las tecnologías ómicas, y proponer soluciones bioinformáticas en relación a dichos datos/ Analyzing and interpreting bioinformatically data derived from ?omics technologies, and proposing bioinformatics solutions according to such data."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000029/2025-26/CE05> a ns1:Competency ;
    ns1:competencyCode "CE05" ;
    ns1:competencyDescription "Utilizar herramientas de biología computacional para el análisis genómico, incluida la genómica comparativa y biología evolutiva/ Using computational biology tools for genomics analyses, including comparative genomics and evolutionary biology."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000029/2025-26/CE10> a ns1:Competency ;
    ns1:competencyCode "CE10" ;
    ns1:competencyDescription "Conocimiento de las técnicas de representación del conocimiento reutilizables y modelos de razonamiento en entornos centralizados y distribuidos a utilizar en la resolución de problemas que impliquen conducta inteligente/ Knowing reusable techniques for knowledge representation and reasoning models in centralized and distributed environments, and when to used them for problem solving."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000029/2025-26/CG01> a ns1:Competency ;
    ns1:competencyCode "CG01" ;
    ns1:competencyDescription "Poseer los conocimientos que constituyen la base científica y tecnológica de la Biología computacional, lo que permitirá el desarrollo de ideas originales en este campo, en un contexto de investigación o desarrollo/ Having the scientific and technological knowledge in which Computational Biology is based, which will allow the development of original ideas in this field, in the context of both research or development."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000029/2025-26/CG03> a ns1:Competency ;
    ns1:competencyCode "CG03" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en entornos nuevos o poco conocidos dentro de contextos más amplios (o multidisciplinares) relacionados con el area de la Biología Computacional/ Provide students with the ability to apply the acquired knowledge to solve problems in new environments within ample or multidisciplinary contexts in the field of Computational Biology."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000029/2025-26/CG05> a ns1:Competency ;
    ns1:competencyCode "CG05" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de integrar conocimientos en el area de la Biología Computacional, de formular conclusiones, hipótesis o líneas de trabajo a partir de la información disponible, y de formarse una opinion fundamentada sobre las responsabilidades sociales y éticas vinculadas a la aplicación de sus conocimientos/ Provide students with the capacity to integrate knowledge in the area of Computational Biology, formulate conclusions, hypotheses or research lines from the available information, and with the ability to elaborate solid opinions about the social and ethic responsibilities derived from the application of their knowledge."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000029/2025-26/CT08> a ns1:Competency ;
    ns1:competencyCode "CT08" ;
    ns1:competencyDescription "Tener capacidad de análisis y síntesis para interpretar datos relevantes y abordar los problemas desde diferentes perspectivas/ To have capacity for analysis and synthesis to interpret relevant data and approach to problems from different perspectives."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000029/2025-26/RA27> a ns1:LearningResult ;
    ns1:learningResultCode "RA27" ;
    ns1:learningResultDescription "Familiarizar a los estudiantes con los datos de biología molecular utilizados en biología sintética"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000029/2025-26/RA28> a ns1:LearningResult ;
    ns1:learningResultCode "RA28" ;
    ns1:learningResultDescription "Conocer las aplicaciones de los principios de ingeniería a la ingeniería de sistemas biológicos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000029/2025-26/RA29> a ns1:LearningResult ;
    ns1:learningResultCode "RA29" ;
    ns1:learningResultDescription "Conocer las diferentes etapas del ciclo biológico de la biología sintética"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000029/2025-26/RA30> a ns1:LearningResult ;
    ns1:learningResultCode "RA30" ;
    ns1:learningResultDescription "Conocer las teorías subyacentes que se aplican a los conceptos y técnicas de la biología sintética."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000029/2025-26/didactic_resource/1> a ns1:DidacticResource ;
    ns1:bibliographyTitle "S. Strogatz, Nonlinear Dynamics And Chaos: With Applications To Physics, Biology, Chemistry, And Engineering, 2nd Ed., Westview Press, 2014."@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000029/2025-26/didactic_resource/2> a ns1:DidacticResource ;
    ns1:bibliographyTitle "Purnick, P. E. M., & Weiss, R. (2009). The second wave of synthetic biology: from modules to systems. Nature Reviews Molecular Cell Biology, 10(6), 410?422. https://doi.org/10.1038/nrm2698"@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000029/2025-26/didactic_resource/3> a ns1:DidacticResource ;
    ns1:bibliographyTitle "Cheng, A. A., & Lu, T. K. (2012). Synthetic Biology: An Emerging Engineering Discipline. Annual Review of Biomedical Engineering, 14(1), 155?178. https://doi.org/10.1146/annurev-bioeng-071811-150118"@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000029/2025-26/didactic_resource/4> a ns1:DidacticResource ;
    ns1:bibliographyTitle "E. Voit. A First Course in Systems Biology, 2nd Edition. Garland Science, 2018. ISBN-10: 0815345682"@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000029/2025-26/didactic_resource/5> a ns1:DidacticResource ;
    ns1:bibliographyTitle "S. Camazine et al. Self-Organization in Biological Systems. Princeton University Press, 2003"@es ;
    ns1:bibliographyType "Bibliografía"@es .

