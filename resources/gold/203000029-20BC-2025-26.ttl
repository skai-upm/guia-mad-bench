<https://guia-kg.skai.etsisi.upm.es/resource/203000029/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/203000029/2025-26/CE02>,
        <https://guia-kg.skai.etsisi.upm.es/resource/203000029/2025-26/CE03>,
        <https://guia-kg.skai.etsisi.upm.es/resource/203000029/2025-26/CE05>,
        <https://guia-kg.skai.etsisi.upm.es/resource/203000029/2025-26/CE10>,
        <https://guia-kg.skai.etsisi.upm.es/resource/203000029/2025-26/CG01>,
        <https://guia-kg.skai.etsisi.upm.es/resource/203000029/2025-26/CG03>,
        <https://guia-kg.skai.etsisi.upm.es/resource/203000029/2025-26/CG05>,
        <https://guia-kg.skai.etsisi.upm.es/resource/203000029/2025-26/CT08> ;
