    ns1:totalHours "35 horas y 52 minutos"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/45001431/2025-26/eventSchedule> ;
    schema:description "El objetivo de la asignatura es aportar al alumno, en los bloques temáticos diferenciados, conocimientos avanzados y de detalle sobre la gestión, el mantenimiento y explotación de las diferentes unidades que componen un servicio de aguas municipal de modo que sea capaz de plantear, ante unas necesidades concretas, las estrategias y tecnologías más eficientes desde el punto de vista técnico y ambiental. Como apoyo y ayuda en la toma de decisiones, se familiariza al alumno con el empleo de las herramientas informáticas más habitualmente empleadas en el cálculo y gestión de las infraestructuras hidráulicas de las redes de abastecimiento y saneamiento."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/jesus.sanchez.rubal%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/jesus.sanchez.rubal%40upm.es> ;
    schema:name "Ingenieria del Agua en Nucleos Urbanos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001431/2025-26/CM37.1> a ns1:Competency ;
    ns1:competencyCode "CM37.1" ;
    ns1:competencyDescription "Conocimiento y capacidad para proyectar y dimensionar obras e instalaciones hidráulicas, sistemas energéticos, aprovechamientos hidroeléctricos y planificación y gestión de recursos hidráulicos superficiales y subterráneos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001431/2025-26/CM39.1> a ns1:Competency ;
    ns1:competencyCode "CM39.1" ;
    ns1:competencyDescription "Conocimiento de los proyectos de servicios urbanos relacionados con la distribución de agua y el saneamiento"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001431/2025-26/CM45> a ns1:Competency ;
    ns1:competencyCode "CM45" ;
    ns1:competencyDescription "Comprensión y asunción de los principios de incertidumbre, riesgo y oportunidad en la aplicación de los métodos y modelos de la ingeniería civil (Desarrolla parcialmente la competencia transversal 3ª del R.D. 1393/2007)."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001431/2025-26/CT2> a ns1:Competency ;
    ns1:competencyCode "CT2" ;
    ns1:competencyDescription "Capacidad de organizar y dirigir los esfuerzos de un grupo humano reducido y homogéneo. Desarrolla la competencia transversal 8ª de la normativa UPM."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001431/2025-26/CT3> a ns1:Competency ;
    ns1:competencyCode "CT3" ;
    ns1:competencyDescription "Capacidad de actuar con efectividad como miembro de equipos interdisciplinares. Desarrolla la competencia transversal 5ª de la normativa UPM."@es .

