    ns1:learningResultCode "RA45" ;
    ns1:learningResultDescription "Planifica y gestiona recursos hidráulicos superficiales y subterráneos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001431/2025-26/RA97> a ns1:LearningResult ;
