    ns1:inpersonHours "33 horas y 52 minutos (43.4%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation "La asignatura se relaciona con el ODS6: AGUA LIMPIA Y SANEAMIENTO"@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
