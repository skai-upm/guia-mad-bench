    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/583000039/2025-26/syllabus> ;
    ns1:inpersonHours "37 horas y 40 minutos (48.3%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation "La asignatura esta relacionada con los ODS 4, 9 y 11."@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "37 horas y 50 minutos"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/583000039/2025-26/eventSchedule> ;
    schema:description """La asignatura aborda la planificación de las infraestructuras, profundizando en la génesis y diseño de proyectos de ingeniería.
El proceso de creación de una infraestructuras esta constituido por la siguientes fases:
Planificación
Diseño
Construcción
Explotación
Conservación
En esta asignatura se desarrollaran los conocimientos relativos a la primera fase, es decir, todo lo que es necesario evaluar previamente a abordar el diseño de una nueva infraestructura."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/miriam.martinez%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/clara.zamorano%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/david.delvillar%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/david.romero%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/juanjose.alvarez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/miguel.delval%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/miriam.martinez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/natalia.sobrino%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/nicoleta.gcancelas%40upm.es> ;
    schema:name "Planificación de Proyectos de Infraestructuras"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/583000039/2025-26/CE%2002> a ns1:Competency ;
    ns1:competencyCode "CE 02" ;
    ns1:competencyDescription "Capacidad para la gestión, dentro de equipos multidisciplinares, de aspectos relacionados con la planificación, ejecución o explotación de infraestructuras"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/583000039/2025-26/CE%2003> a ns1:Competency ;
    ns1:competencyCode "CE 03" ;
    ns1:competencyDescription "Capacidad para la aplicación de aspectos de seguridad en la ejecución y seguridad en ambientes de riesgo relacionados con la ejecución o explotación de infraestructuras"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/583000039/2025-26/CE%2005> a ns1:Competency ;
    ns1:competencyCode "CE 05" ;
    ns1:competencyDescription "Capacidad para la gestión, dentro de equipos multidisciplinares, en lo relacionado a la planificación estratégica, siguiendo criterios de calidad y medioambientales, de aspectos relacionados con la dirección, coordinación y gestión técnica y económica de proyectos en todos los ámbitos de las infraestructuras"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/583000039/2025-26/CE%2009> a ns1:Competency ;
    ns1:competencyCode "CE 09" ;
    ns1:competencyDescription "Capacidad para la formación continuada en relación a los diferentes tipos de infraestructuras, proporcionando una formación avanzada y competencias en la aplicación tecnológica y de ingeniería en el ámbito de las infraestructuras Terrestres."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/583000039/2025-26/CG%2005> a ns1:Competency ;
    ns1:competencyCode "CG 05" ;
    ns1:competencyDescription "Capacidad para la puesta en marcha, dirección y gestión de planificación y gestión de infraestructuras, etc., en el ámbito de la ingeniería civil y de infraestructuras con garantía de seguridad para las personas y bienes, con calidad final de las infraestructuras"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/583000039/2025-26/RA3> a ns1:LearningResult ;
    ns1:learningResultCode "RA3" ;
    ns1:learningResultDescription "Adquisicion de herramientas y destrezas necesarias para la evaluacion de inversiones en infraestructuras"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/583000039/2025-26/RA48> a ns1:LearningResult ;
    ns1:learningResultCode "RA48" ;
    ns1:learningResultDescription "Desmostrar capacidad para identificar, formular y resolver problemas de ingeniería en áreas emergentes de la sostenibilidad de infraestructuras"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/583000039/2025-26/RA5> a ns1:LearningResult ;
    ns1:learningResultCode "RA5" ;
    ns1:learningResultDescription "Adquisicion de destrezas adecuadas para la correcta planificacion de infraestructuras y profundizacion en la genesis y diseño de proyectos de ingenieria."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/583000039/2025-26/RA50> a ns1:LearningResult ;
    ns1:learningResultCode "RA50" ;
    ns1:learningResultDescription "Desmostrar capacidad para consultar y aplicar códigos de buenas prácticas y de seguridad de planificación y gestión de infraestructuras.."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/583000039/2025-26/RA67> a ns1:LearningResult ;
    ns1:learningResultCode "RA67" ;
    ns1:learningResultDescription "Conocimiento y comprensión de los sistemas inteligentes de transporte en relación con la planificación y la gestión de infraestructuras."@es .

