    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/23000611/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/23000611/2025-26/RA4>,
