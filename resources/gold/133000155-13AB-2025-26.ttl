        <https://guia-kg.skai.etsisi.upm.es/resource/133000155/2025-26/didactic_resource/5> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/133000155/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/133000155/2025-26/RA1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000155/2025-26/RA2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000155/2025-26/RA47>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000155/2025-26/RA48>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000155/2025-26/RA49> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/133000155/2025-26/syllabus> ;
    ns1:inpersonHours "87 horas (64.4%)"@es ;
    ns1:numberOfCredits 5.0 ;
    ns1:otherInformation """* La asignatura se relaciona con el ODS11, el ODS12, el ODS13 y el ODS16*
**Esta asignatura, al igual que el Master, sigue el modelo de enseñanza a distancia. Aunque en el apartado del "Cronograma" aparezca que parte de la enseñanza es "presencial", se debe a que en la implementación de la aplicación de rellenar las guías de aprendizaje no aparece la opción de "no presencial", en algunos casos (a pesar de que la columna en la que se encuentran las actividades sea de tele-enseñanza)**
***En esta asignatura se tratará de cumplir con la identificación de los alumnos propuesta en el Plan de Mejoras del METS, pero en todo caso se actuará de acuerdo con la normativa de la UPM***
**** Las actividades evaluables deben ser realizadas única y exclusivamente por el alumno (-a). La clave de acceso es personal e intransferible y la suplantación de la identidad puede conllevar faltas graves e incluso la expulsión de la UPM"
*****"Para el seguimiento del alumnado se verificará las IP¿s desde las que se conecta y se accede a la Plataforma Moodle y se podrá exigir alguna comprobación extra de la identidad, mediante contacto telefónico o videoconferencia, si se detectara alguna anomalía"*****
******"Se usarán el programa Turnitin y otras estrategias de detección de plagio"******
*******LAS COMPETENCIAS Y LOS RESULTADOS DE APRENDIZAJE DE ESTA ASIGNATURA SON LOS ACORDES CON LA MEMORIA VERIFICA DEL TÍTULO"""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "108 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/133000155/2025-26/eventSchedule> ;
    schema:description """Patrimonio Cultural es una asignatura obligatoria que se imparte durante el primer semestre del Máster.
Consta de las siguientes partes:

1. Concepto de Patrimonio Cultural e Historia de la Conservación del Patrimonio
2. La gestión y conservación del Patrimonio Cultural
3. Interpretación del Patrimonio Cultural
4. Principales manifestaciones culturales I
5. Principales manifestaciones culturales II
6. Innovación en Gestión del Patrimonio Cultural"""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/carlos.calderon%40upm.es> ;
    schema:inLanguage "Inglés/Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/carlos.calderon%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/josel.garcia%40upm.es> ;
    schema:name "Patrimonio Cultural."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000155/2025-26/CB06> a ns1:Competency ;
    ns1:competencyCode "CB06" ;
    ns1:competencyDescription "Poseer y comprender conocimientos que aporten una base u oportunidad de ser originales en el desarrollo y/o aplicación de ideas, a menudo en un contexto de investigación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000155/2025-26/CB10> a ns1:Competency ;
    ns1:competencyCode "CB10" ;
    ns1:competencyDescription "Que los estudiantes posean las habilidades de aprendizaje que les permitan continuar estudiando de un modo que habrá de ser en gran medida autodirigido o autónomo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000155/2025-26/CE01> a ns1:Competency ;
    ns1:competencyCode "CE01" ;
    ns1:competencyDescription "Conocimiento y capacidad para interpretar y comprender los aspectos ambientales, económicos y socioculturales que afectan al ecoturismo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000155/2025-26/CE04> a ns1:Competency ;
    ns1:competencyCode "CE04" ;
    ns1:competencyDescription "Capacidad para identificar y valorar productos de la naturaleza y procurar su conservación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000155/2025-26/CE05> a ns1:Competency ;
    ns1:competencyCode "CE05" ;
    ns1:competencyDescription "Capacidad para identificar y valorar las ventajas y los inconvenientes del turismo responsable en el entorno natural para las comunidades y empresas locales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000155/2025-26/CG05> a ns1:Competency ;
    ns1:competencyCode "CG05" ;
    ns1:competencyDescription "Búsqueda bibliográfica, análisis de documentación y tratamiento de la información procedente de diversas fuentes y de su análisis y síntesis aplicándola a la resolución de problemas complejos, en el campo del Turismo Ecológico y Sostenible"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000155/2025-26/RA1> a ns1:LearningResult ;
    ns1:learningResultCode "RA1" ;
    ns1:learningResultDescription "Conocer el patrimonio natural mundial, europeo y nacional y el impacto del turismo sobre él."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000155/2025-26/RA2> a ns1:LearningResult ;
    ns1:learningResultCode "RA2" ;
    ns1:learningResultDescription "Identificar los destinos del patrimonio y las leyes de cada país, con el fin de conseguir una actividad de ecoturismo sostenible."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000155/2025-26/RA47> a ns1:LearningResult ;
    ns1:learningResultCode "RA47" ;
    ns1:learningResultDescription "Disponer de la capacidad necesaria para recopilar información sobre valores patrimoniales, estructurarla y exponerla de forma ordenada y clara."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000155/2025-26/RA48> a ns1:LearningResult ;
    ns1:learningResultCode "RA48" ;
    ns1:learningResultDescription "Disponer de los conocimientos adecuados para valorar las posibilidades de atracción turística de los valores culturales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000155/2025-26/RA49> a ns1:LearningResult ;
    ns1:learningResultCode "RA49" ;
    ns1:learningResultDescription "Disponer de las destrezas necesarias para elaborar los elementos interpretativos precisos para la puesta en valor de valores culturales."@es .

