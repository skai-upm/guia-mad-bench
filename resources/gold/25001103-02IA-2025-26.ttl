<https://guia-kg.skai.etsisi.upm.es/resource/25001103/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Disoluciones acuosas y coloides."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001103/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Disoluciones. Tipos de disoluciones. Formas de expresar la concentración. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001103/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "2.3.1. Disoluclones mezcla de líquidos volátiles. Diagramas de punto de ebullición. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001103/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "2.3.2. Destilación de disoluciones ideales. Mezclas azeotrópicas Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001103/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "2.4. Operaciones básicas basadas en la transferencia de materia. Extracción Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001103/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "3. Cinética química"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001103/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "3.1. Velocidad de reacción. Modelos teóricos de la cinética química. Factores que afectan a la velocidad. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001103/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "3.2. Ecuación de velocidad. Orden de reacción. Determinación experimental de la ecuación de velocidad. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001103/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "3.3. Ecuación integrada de velocidad y vida media. Velocidad de reacción y temperatura. Ecuación de Arrhenius. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001103/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "3.4. Mecanismos de reacción. Catálisis. Aplicaciones. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001103/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "3.5. Cinética y equilibrio químico. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001103/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "3.6. Sesión 2. Práctica 3 . Cinética química. Determinación del orden de reacción y de la energía de activación. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001103/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Disoluciones de líquidos en líquidos, de sólidos en líquidos y de gases en líquidos. Variación de la solubilidad con la temperatura y la presión. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001103/2025-26/syllabus/20> a ns1:SyllabusItem ;
    ns1:itemIndex 20 ;
    ns1:syllabusDescription "4. Equilibrios ácido-base"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001103/2025-26/syllabus/21> a ns1:SyllabusItem ;
    ns1:itemIndex 21 ;
    ns1:syllabusDescription "4.1. Concepto de ácido y base. Teoría de Brönsted?Lowry. Teoría de Lewis. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001103/2025-26/syllabus/22> a ns1:SyllabusItem ;
    ns1:itemIndex 22 ;
    ns1:syllabusDescription "4.2. Fuerza de los ácidos y las bases. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001103/2025-26/syllabus/23> a ns1:SyllabusItem ;
    ns1:itemIndex 23 ;
    ns1:syllabusDescription "4.3. Cálculos numéricos y gráficos de pH en disoluciones de ácidos y de bases. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001103/2025-26/syllabus/24> a ns1:SyllabusItem ;
    ns1:itemIndex 24 ;
    ns1:syllabusDescription "4.4. Propiedades ácido?base de las sales. Aspectos cuantitativos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001103/2025-26/syllabus/25> a ns1:SyllabusItem ;
    ns1:itemIndex 25 ;
    ns1:syllabusDescription "4.5. Disoluciones amortiguadoras. Cálculo del pH. Capacidad reguladora. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001103/2025-26/syllabus/26> a ns1:SyllabusItem ;
    ns1:itemIndex 26 ;
    ns1:syllabusDescription "4.6. Valoraciones ácido?base. Aplicaciones al análisis cuantitativo. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001103/2025-26/syllabus/27> a ns1:SyllabusItem ;
    ns1:itemIndex 27 ;
    ns1:syllabusDescription "4.7. Sesión 3. Práctica 4. Fuerza ácido-base. Disoluciones amortiguadoras. Determinación de la acidez de muestras alimenticias. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001103/2025-26/syllabus/28> a ns1:SyllabusItem ;
    ns1:itemIndex 28 ;
    ns1:syllabusDescription "5. Equilibrios redox"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001103/2025-26/syllabus/29> a ns1:SyllabusItem ;
    ns1:itemIndex 29 ;
    ns1:syllabusDescription "5.1. Oxidantes y reductores. Concepto de oxidación?reducción. Ajuste de reacciones redox. Potenciales estándar de electrodo. Célula electroquímica. Pila galvánica. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001103/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "1.3. Propiedades coligativas de las disoluciones. Factor de Van?t Hoff. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001103/2025-26/syllabus/30> a ns1:SyllabusItem ;
    ns1:itemIndex 30 ;
    ns1:syllabusDescription "5.2. Ecuación de Nernst. Espontaneidad y equilibrio. Influencia del pH en el potencial de electrodo. Tipos de electrodos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001103/2025-26/syllabus/31> a ns1:SyllabusItem ;
    ns1:itemIndex 31 ;
    ns1:syllabusDescription "5.3. Algunas aplicaciones de las reacciones redox. Pilas y baterías. Corrosión. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001103/2025-26/syllabus/32> a ns1:SyllabusItem ;
    ns1:itemIndex 32 ;
    ns1:syllabusDescription "5.4. Valoraciones redox. Aplicaciones. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001103/2025-26/syllabus/33> a ns1:SyllabusItem ;
    ns1:itemIndex 33 ;
    ns1:syllabusDescription "5.5. Sesión 4 (1ªparte) Práctica 5. Comportamiento oxidación-reducción de diferentes especies. Influencia del pH. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001103/2025-26/syllabus/34> a ns1:SyllabusItem ;
    ns1:itemIndex 34 ;
    ns1:syllabusDescription "6. Equilibrios de precipitación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001103/2025-26/syllabus/35> a ns1:SyllabusItem ;
    ns1:itemIndex 35 ;
    ns1:syllabusDescription "6.1. Equilibrio de solubilidad. Disolución saturada. Solubilidad. Reglas generales de grupos de compuestos solubles e insolubles. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001103/2025-26/syllabus/36> a ns1:SyllabusItem ;
    ns1:itemIndex 36 ;
    ns1:syllabusDescription "6.2. Constante del producto de solubilidad y su relación con la solubilidad. Factores que afectan a la solubilidad. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001103/2025-26/syllabus/37> a ns1:SyllabusItem ;
    ns1:itemIndex 37 ;
    ns1:syllabusDescription "6.3. Formación de precipitados. Separación de iones por precipitación fraccionada. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001103/2025-26/syllabus/38> a ns1:SyllabusItem ;
    ns1:itemIndex 38 ;
    ns1:syllabusDescription "6.4. Interdependencia de los equilibrios de solubilidad con otros equilibrios Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001103/2025-26/syllabus/39> a ns1:SyllabusItem ;
    ns1:itemIndex 39 ;
    ns1:syllabusDescription "6.5. Aplicaciones de los equilibrios de precipitación al análisis cuantitativo. Gravimetrías. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001103/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "1.4. Sesión 1. Práctica 1. Operaciones básicas del trabajo en el laboratorio. Manejo de material. Preparación de disoluciones. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001103/2025-26/syllabus/40> a ns1:SyllabusItem ;
    ns1:itemIndex 40 ;
    ns1:syllabusDescription "6.6. Sesión 4 (2ª parte) Practica 6. Reacciones de precipitación y formación de complejos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001103/2025-26/syllabus/41> a ns1:SyllabusItem ;
