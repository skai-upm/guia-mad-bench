    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/93000844/2025-26/eventSchedule> ;
    schema:description """This course focuses on electronic systems that interact with the human body, particularly the nervous system and sensory organs.
This includes assistive technology for people with disabilities and communication systems that use speech and brain-computer interfaces.
Examples of artificial systems that emulate biological ones and advanced multisensory interfaces will also be covered."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/andres.santos%40upm.es> ;
    schema:inLanguage "Inglés"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/andres.santos%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/juanjo.gomez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/ricardo.cordoba%40upm.es> ;
    schema:name "Ingenieria Neurosensorial"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000844/2025-26/CE15> a ns1:Competency ;
    ns1:competencyCode "CE15" ;
    ns1:competencyDescription "Capacidad para la integración de tecnologías y sistemas propios de la Ingeniería de Telecomunicación, con carácter generalista, y en contextos más amplios y multidisciplinares como por ejemplo en bioingeniería, conversión fotovoltaica, nanotecnología, telemedicina."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000844/2025-26/CG4> a ns1:Competency ;
    ns1:competencyCode "CG4" ;
    ns1:competencyDescription "Que los estudiantes sepan comunicar sus conclusiones ?y los conocimientos y razones últimas que las sustentan? a públicos especializados y no especializados de un modo claro y sin ambigüedades."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000844/2025-26/CG5> a ns1:Competency ;
    ns1:competencyCode "CG5" ;
    ns1:competencyDescription "Que los estudiantes posean las habilidades de aprendizaje que les permitan continuar estudiando de un modo que habrá de ser en gran medida autodirigido o autónomo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000844/2025-26/CT1> a ns1:Competency ;
    ns1:competencyCode "CT1" ;
    ns1:competencyDescription "Capacidad para comprender los contenidos de clases magistrales, conferencias y seminarios en lengua inglesa."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000844/2025-26/CT4> a ns1:Competency ;
    ns1:competencyCode "CT4" ;
    ns1:competencyDescription "Capacidad para trabajar de forma efectiva como individuo, organizando y planificando su propio trabajo, de forma independiente o como miembro de un equipo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000844/2025-26/CT5> a ns1:Competency ;
    ns1:competencyCode "CT5" ;
    ns1:competencyDescription "Capacidad para gestionar la información, identificando las fuentes necesarias, los principales tipos de documentos técnicos y científicos, de una manera adecuada y eficiente."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000844/2025-26/RA10> a ns1:LearningResult ;
    ns1:learningResultCode "RA10" ;
    ns1:learningResultDescription "Saber realizar una presentación de carácter técnico, ante una audiencia de pares, que describa el trabajo realizado y sus resultados, de forma clara y bien estructurada, en el tiempo establecido, y usando un lenguaje preciso"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000844/2025-26/RA26> a ns1:LearningResult ;
    ns1:learningResultCode "RA26" ;
    ns1:learningResultDescription "Capacidad para abordar la gestión de proyectos de ingeniería como un problema ético y sistémico, de tecnología, gestión y factor humano. (CG3, CT5, CT6, CE6, CE7, CE8, CE9)"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000844/2025-26/RA60> a ns1:LearningResult ;
    ns1:learningResultCode "RA60" ;
    ns1:learningResultDescription "Capacidad para entender los fundamentos del procesamiento de información en el sistema nervioso"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000844/2025-26/RA61> a ns1:LearningResult ;
    ns1:learningResultCode "RA61" ;
    ns1:learningResultDescription "Capacidad para entender el funcionamiento básico de sistemas que interactúan directamente con el sistema nervioso como interfaces cerebro"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000844/2025-26/RA62> a ns1:LearningResult ;
    ns1:learningResultCode "RA62" ;
    ns1:learningResultDescription "Conocer el funcionamiento básico de los órganos sensoriales del cuerpo humano y saber analizar el funcionamiento y las posibilidades de prótesis y ayudas para discapacitados"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000844/2025-26/RA63> a ns1:LearningResult ;
    ns1:learningResultCode "RA63" ;
    ns1:learningResultDescription "Comprender el funcionamiento, las características principales y aplicaciones de las interfaces sensoriales basadas en habla (síntesis y reconocimiento), multisensoriales y de realidad virtual"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000844/2025-26/RA9> a ns1:LearningResult ;
    ns1:learningResultCode "RA9" ;
    ns1:learningResultDescription "Saber redactar informes técnicos sobre trabajos realizados, con una estructura, contenidos y lenguaje del nivel adecuado a un trabajo de ingeniería"@es .

