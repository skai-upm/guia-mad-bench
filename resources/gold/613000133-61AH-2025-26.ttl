    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/613000133/2025-26/syllabus> ;
    ns1:inpersonHours "31 horas (39.7%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation "La asignatura de imparte de modo condensado en 5 semanas, a 6 horas por semana, por lo que semana 1 significa la primera semana desde que comience la impartición, no desde el inicio del curso."@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "31 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/613000133/2025-26/eventSchedule> ;
    schema:description """El paradigma Map-Reduce: programación de aplicaciones masivamente paralelas utilizando Map-Reduce
Frameworks para la computación intensiva en datos: Hadoop y Spark
Procesamiento de datos masivos en tiempo real (streaming): Kafka
Paralelizacion masiva de algoritmos de Machine Learning.
Caso de uso de paralelización de Algoritmos de Machine Learning Supervisado: Regresion Logistica con Gradiente Descendente
Caso de uso de paralelización de Algoritmos de Machine Learning No Supervisado: K-Means"""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/a.mozo%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/a.mozo%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/l.delacal%40upm.es> ;
    schema:name "Optimización para Grandes Volúmenes de Datos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000133/2025-26/CB10> a ns1:Competency ;
    ns1:competencyCode "CB10" ;
    ns1:competencyDescription "Que los estudiantes posean las habilidades de aprendizaje que les permitan continuar estudiando de un modo que habrá de ser en gran medida autodirigido o autónomo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000133/2025-26/CB6> a ns1:Competency ;
    ns1:competencyCode "CB6" ;
    ns1:competencyDescription "Poseer y comprender conocimientos que aporten una base u oportunidad de ser originales en el desarrollo y/o aplicación de ideas, a menudo en un contexto de investigación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000133/2025-26/CB7> a ns1:Competency ;
    ns1:competencyCode "CB7" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en entornos nuevos o poco conocidos dentro de contextos más amplios (o multidisciplinares) relacionados con su área de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000133/2025-26/CB8> a ns1:Competency ;
    ns1:competencyCode "CB8" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de integrar conocimientos y enfrentarse a la complejidad de formular juicios a partir de una información que, siendo incompleta o limitada, incluya reflexiones sobre las responsabilidades sociales y éticas vinculadas a la aplicación de sus conocimientos y juicios"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000133/2025-26/CB9> a ns1:Competency ;
    ns1:competencyCode "CB9" ;
    ns1:competencyDescription "Que los estudiantes sepan comunicar sus conclusiones y los conocimientos y razones últimas que las sustentan a públicos especializados y no especializados de un modo claro y sin ambigüedades"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000133/2025-26/CE02> a ns1:Competency ;
    ns1:competencyCode "CE02" ;
    ns1:competencyDescription "Gestionar grandes volúmenes de información procedentes de diversas fuentes heterogéneas y efectuar su análisis en tiempo real mediante el diseño de cuadros de mando e informes para obtener conocimiento útil."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000133/2025-26/CE05> a ns1:Competency ;
    ns1:competencyCode "CE05" ;
    ns1:competencyDescription "Diseñar y desplegar modelos de aprendizaje automático de manera escalable y eficiente usando estrategias de contenerización y computación de altas prestaciones."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000133/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Capacidad para aplicar el método científico y saber organizar y planificar experimentos con rigor metodológico en el ámbito del aprendizaje automático y los datos masivos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000133/2025-26/CG2> a ns1:Competency ;
    ns1:competencyCode "CG2" ;
    ns1:competencyDescription "Participar en la aplicación de mecanismos de descripción, cuantificación, análisis, interpretación y evaluación de resultados experimentales del ámbito de los datos masivos y el aprendizaje automático"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000133/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Capacidad para reunir e interpretar datos masivos relevantes para emitir juicios que incluyan una reflexión sobre temas importantes de índole científico, social o ético en el ámbito del aprendizaje automático y los datos masivos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000133/2025-26/CG4> a ns1:Competency ;
    ns1:competencyCode "CG4" ;
    ns1:competencyDescription "Capacidad de aplicar iniciativa, integración, colaboración y potenciación de la discusión crítica en el ámbito del trabajo en equipo dentro del ámbito del aprendizaje automático y datos masivos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000133/2025-26/CG5> a ns1:Competency ;
    ns1:competencyCode "CG5" ;
    ns1:competencyDescription "Participar en la transmisión de la información generada, las ideas, los problemas y las soluciones de forma oral y escrita para un público tanto especializado como no especializado"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000133/2025-26/CT1> a ns1:Competency ;
    ns1:competencyCode "CT1" ;
    ns1:competencyDescription "Creatividad"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000133/2025-26/CT2> a ns1:Competency ;
    ns1:competencyCode "CT2" ;
    ns1:competencyDescription "Organización y planificación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000133/2025-26/CT3> a ns1:Competency ;
    ns1:competencyCode "CT3" ;
    ns1:competencyDescription "Gestión de la información"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000133/2025-26/CT4> a ns1:Competency ;
    ns1:competencyCode "CT4" ;
    ns1:competencyDescription "Liderazgo de equipos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000133/2025-26/CT5> a ns1:Competency ;
    ns1:competencyCode "CT5" ;
    ns1:competencyDescription "Trabajo en contextos internacionales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000133/2025-26/K05> a ns1:Competency ;
    ns1:competencyCode "K05" ;
    ns1:competencyDescription "El alumno analiza las distintas arquitecturas para el almacenamiento y procesado de datos masivos de altas prestaciones"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000133/2025-26/RA37> a ns1:LearningResult ;
    ns1:learningResultCode "RA37" ;
    ns1:learningResultDescription "Capacidad de analizar y diseñar arquitecturas y tecnologías de altas prestaciones para grandes volúmenes de datos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000133/2025-26/RA38> a ns1:LearningResult ;
    ns1:learningResultCode "RA38" ;
    ns1:learningResultDescription "· Conocer y aplicar técnicas de diseño y desarrollo de aplicaciones de computación de altas prestaciones"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000133/2025-26/RA39> a ns1:LearningResult ;
    ns1:learningResultCode "RA39" ;
    ns1:learningResultDescription "· Analizar y modelar las tecnologías más adecuadas para cada problema, adecuándose a las especificaciones de los casos concretos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000133/2025-26/S02> a ns1:Competency ;
    ns1:competencyCode "S02" ;
    ns1:competencyDescription "El alumno planifica y ejecuta la gestión y el despliegue de infraestructuras de datos masivos"@es .

