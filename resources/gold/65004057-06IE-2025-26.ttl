        <https://guia-kg.skai.etsisi.upm.es/resource/65004057/2025-26/CE44>,
        <https://guia-kg.skai.etsisi.upm.es/resource/65004057/2025-26/CE48>,
        <https://guia-kg.skai.etsisi.upm.es/resource/65004057/2025-26/CG2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/65004057/2025-26/CG4>,
