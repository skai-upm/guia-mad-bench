    ns1:learningResultDescription "Analizar y relacionar las características de las fuentes de energía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004057/2025-26/RA213> a ns1:LearningResult ;
    ns1:learningResultCode "RA213" ;
    ns1:learningResultDescription "Incorporar los conceptos de eficiencia, ahorro y gestión energética en proyectos industriales"@es .

