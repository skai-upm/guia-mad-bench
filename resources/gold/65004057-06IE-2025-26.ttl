<https://guia-kg.skai.etsisi.upm.es/resource/65004057/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/65004057/2025-26/CE25>,
        <https://guia-kg.skai.etsisi.upm.es/resource/65004057/2025-26/CE31>,
