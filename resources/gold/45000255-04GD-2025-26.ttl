        <https://guia-kg.skai.etsisi.upm.es/resource/45000255/2025-26/RA237> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/45000255/2025-26/syllabus> ;
    ns1:inpersonHours "62 horas y 40 minutos (40.2%)"@es ;
    ns1:numberOfCredits 6.0 ;
    ns1:otherInformation """Esta asignatura se relaciona con los siguientes Objetivos de Desarrollo Sostenible (ODS):
- Objetivo 8: Trabajo decente y crecimiento económico
- Objetivo 12: Producción y consumo responsables"""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "62 horas y 40 minutos"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/45000255/2025-26/eventSchedule> ;
    schema:description """Los objetivos de la asignatura son:
- Entender la naturaleza de la dirección estratégica, así como los conceptos de Misión, objetivos y valores de las empresas.
- Conocer cómo se realiza un análisis del entorno, así como el análisis interno de la empresa.
- Conocer las distintas estrategias y ventajas competitivas, así como las estrategias con base en las características de la industria.
- Conocer las direcciones de desarrollo de la empresa, así como los aspectos relacionados con la evaluación e implantación de estrategias."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/oscar.martinez%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/david.romero%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/jr.ballesteros%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/oscar.martinez%40upm.es> ;
    schema:name "Dirección Estratégica"@es .

