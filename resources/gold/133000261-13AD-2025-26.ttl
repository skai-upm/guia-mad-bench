    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/133000261/2025-26/eventSchedule> ;
    schema:description "El objetivo de esta asignatura es introducir a los alumnos en el manejo de una fuente de datos (LiDAR) que actualmente presenta gran aplicación en el ámbito forestal y medioambiental."@es ;
