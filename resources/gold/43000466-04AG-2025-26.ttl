    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/43000466/2025-26/eventSchedule> ;
    schema:description "La asignatura que se propone, Cálculo Avanzado de Estructuras, supone una continuidad con las anteriores asignaturas estructurales y en ella se prosigue profundizando en el análisis lineal de estructuras y se estudia, en primer lugar, el método de los Elementos Finitos aplicado a estructuras, tanto de barras como continuas, incidiendo en el significado estructural de los diferentes elementos que intervienen en el proceso: variables, matrices, ecuaciones, etc. Se incide especialmente en la modelización de las estructuras, analizando posibles problemas asociados a la discretización y comentando las ventajas e inconvenientes de los diversos tipos de elementos, y en la interpretación de los resultados del cálculo, discriminando qué se puede pedir y qué no a los resultados del mismo. Aplicaciones típicas son los estudios de efectos locales, los elementos con geometría compleja, los elementos masivos, e incluso la modelización de la estructura completa."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/josemaria.arrieta%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/antonio.carnerero%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/david.izquierdo%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/josemaria.arrieta%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/mariamercedes.madrid%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/miguel.fernandezruiz%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/nicola.tarque%40upm.es> ;
    schema:name "Calculo Avanzado de Estructuras"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000466/2025-26/CE22> a ns1:Competency ;
    ns1:competencyCode "CE22" ;
    ns1:competencyDescription "Conocimiento y capacidad para el análisis estructural mediante la aplicación de los métodos y programas de diseño y cálculo avanzado de estructuras, a partir del conocimiento y comprensión de las solicitaciones y su aplicación a las tipologías estructurales de la ingeniería civil. Capacidad para realizar evaluaciones de integridad estructural."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000466/2025-26/CE23> a ns1:Competency ;
    ns1:competencyCode "CE23" ;
    ns1:competencyDescription "Conocimiento de todo tipo de estructuras y sus materiales, y capacidad para diseñar, proyectar, ejecutar y mantener las estructuras y edificaciones de obra civil."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000466/2025-26/CE38> a ns1:Competency ;
    ns1:competencyCode "CE38" ;
    ns1:competencyDescription "Capacidad para integrar y aplicar los conocimientos técnicos en asesoría, análisis, diseño y modelización físico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000466/2025-26/CE39> a ns1:Competency ;
    ns1:competencyCode "CE39" ;
    ns1:competencyDescription "Capacidad predictiva para optimización de soluciones en ingeniería estructural."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000466/2025-26/CGP01> a ns1:Competency ;
    ns1:competencyCode "CGP01" ;
    ns1:competencyDescription "Capacitación científico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000466/2025-26/CGP06> a ns1:Competency ;
    ns1:competencyCode "CGP06" ;
    ns1:competencyDescription "Conocimiento para aplicar las capacidades técnicas y gestoras en actividades de I+D+i dentro del ámbito de la ingeniería civil. Incorpora las competencias CB6, CB7 y CB8."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000466/2025-26/CGP11> a ns1:Competency ;
    ns1:competencyCode "CGP11" ;
    ns1:competencyDescription "Capacidad para el proyecto, ejecución e inspección de estructuras (puentes, edificaciones, etc.), de obras de cimentación y de obras subterráneas de uso civil (túneles, aparcamientos), y el diagnóstico sobre su integridad. Incorpora las competencias CB6, CB7 y CB8."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000466/2025-26/CGP12> a ns1:Competency ;
    ns1:competencyCode "CGP12" ;
    ns1:competencyDescription "Capacidad para planificar, diseñar y gestionar infraestructuras, así como su mantenimiento, conservación y explotación. Incorpora las competencias CB6, CB7 y CB8."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000466/2025-26/CGP18> a ns1:Competency ;
    ns1:competencyCode "CGP18" ;
    ns1:competencyDescription "Conocimientos adecuados de los aspectos científicos y tecnológicos de métodos matemáticos, analíticos y numéricos de la ingeniería, mecánica de fluidos, mecánica de medios continuos, cálculo de estructuras, ingeniería del terreno, ingeniería marítima, obras y aprovechamientos hidráulicos y obras lineales. Incorpora las competencias CB6, CB7 y CB8."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000466/2025-26/CT2> a ns1:Competency ;
    ns1:competencyCode "CT2" ;
    ns1:competencyDescription "Polivalencia y capacidad de aprendizaje autónomo. Desarrolla la competencia transversal 5ª del Real Decreto."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000466/2025-26/CT8> a ns1:Competency ;
    ns1:competencyCode "CT8" ;
    ns1:competencyDescription "Capacidad de diseñar, analizar e interpretar experimentos relevantes en ingeniería civil."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000466/2025-26/RA128> a ns1:LearningResult ;
    ns1:learningResultCode "RA128" ;
    ns1:learningResultDescription "Modela y dimensiona elementos continuos y estructurales sometidos a acciones estáticas mediante el método numérico de los Elementos Finitos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000466/2025-26/RA129> a ns1:LearningResult ;
    ns1:learningResultCode "RA129" ;
    ns1:learningResultDescription "Modela y dimensiona elementos continuos y estructurales sometidos a acciones dinámicas mediante métodos analíticos y numéricos."@es .

