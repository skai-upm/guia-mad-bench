<https://guia-kg.skai.etsisi.upm.es/resource/43000466/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Cálculo de Estructuras por Elementos Finitos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000466/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Introducción. Generalidades. Ámbito de aplicación. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000466/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "2.1. Introducción al Cálculo Dinámico. Concepto. Objetivos. Causas de aparición de fenómenos dinámicos. Problemas típicos de Cálculo Dinámico. Clasificación del Cálculo Dinámico.. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000466/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "2.2. Acciones Dinámicas. Acciones Impulsivas. Acciones Periódicas. Acciones Sísmicas. Viento. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000466/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "2.3. El problema dinámico. Planteamiento general. Modelos continuos: la viga. Modelos discretos: sistema de 1 gdl. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000466/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "2.4. Estructuras asimilables a sistemas de 1 gdl. Estructuras simples. Estructuras complejas: estructuras con elementos rígidos, estructuras con elementos flexibles. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000466/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "2.5. Sistema de 1 gdl: respuesta a cargas sencillas. Respuesta a cargas impulsivas: FCD. Respuesta a acciones armónicas: FCD y resonancia. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000466/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "2.6. Sistema de 1 gdl: respuesta a cargas genéricas. Introducción. Método de la Integral de Duhamel o de Convolución. Método de la Función Salto Unidad. Espectro de Respuesta. Métodos de Integración Paso a Paso. Paso de un eje por un tablero. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000466/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "2.7. Sistemas de múltiples gdl. Planteamiento del problema. Matrices de masas. Oscilación libre sin amortiguamiento. Desacoplamiento del sistema sin amortiguamiento. Desacoplamiento del sistema con amortiguamiento. Condiciones iniciales. Otras cuestiones. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000466/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Planteamiento del M.E.F. Planteamiento Variacional. Desarrollo del Método. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000466/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "1.3. Método de las funciones de forma Interpolación de Lagrange. Elemento de Referencia. Elemento Genérico. Reformulación del Problema. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000466/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "1.4. Funciones de forma en elementos continuos. Elementos Bidimensionales. Elementos Unidimensionales. Elementos Tridimensionales. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000466/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "1.5. Integración numérica. Métodos de integración. Orden de integración. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000466/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "1.6. Convergencia Condiciones Básicas y Adicionales. Aproximación a la Solución. Compatibilidad y Equilibrio. Cálculo de Tensiones. Modelización y Errores. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000466/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "1.7. Tipos de elementos. Elementos continuos 1D. Elementos continuos 2D. Elementos continuos 3D. Barra Articulada. Vigas. Placas. Láminas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000466/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "1.8. Otras técnicas del M.E.F. Condensación Estática. Funciones de Forma Adicionales. Integración Selectiva. Campo de Deformaciones Impuesto. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000466/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "2. Cálculo Dinámico de Estructuras."@es .

