    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/20504121/2025-26/eventSchedule> ;
    schema:description "La asignatura de Matemáticas II es una introducción al cálculo diferencial e integral de funciones de dos y tres variables así como a las ecuaciones diferenciales incluyendo el estudio cualitativo de sistemas bidimensionales autónomos. Se hará especial hincapié en las nociones de gráfica y conjunto de nivel para visualizarlas así como en los conceptos de derivada parcial y gradiente. Se pondrá especial énfasis en la interpretación geométrica de estos conceptos y su utilización para describir la dependencia funcional de tres y cuatro variables así como su utilidad a la hora de resolver problemas de optimización. Además se presentarán los procedimientos de la integración múltiple para calcular áreas, volúmenes y otras aplicaciones. En los elementos de las ecuaciones diferenciales que se desarrollarán durante el curso, se potenciará su utilización como parte esencial de la modelización en el ámbito de la biotecnología. Se introducirán modelos matemáticos relativos a dinámica de poblaciones, mezclas, administración de fármacos y propagación de enfermedades infecciosas, entre otros. Estos modelos servirán para ilustrar los procedimientos de resolución de ecuaciones diferenciales ordinarias de primer orden para ecuaciones separables y exactas, así como lineales de primer y segundo orden. Asimismo se introducirán procedimientos de resolución de sistemas de dos ecuaciones diferenciales autónomas lineales y no lineales, las primeras por métodos matriciales, y utilizando la teoría cualitativa, las segundas."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/j.caniego%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/j.caniego%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/katherine.castro%40upm.es> ;
    schema:name "Matemáticas II"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504121/2025-26/CB05> a ns1:Competency ;
    ns1:competencyCode "CB05" ;
    ns1:competencyDescription "Que los estudiantes hayan desarrollado aquellas habilidades de aprendizaje necesarias para emprender estudios posteriores con un alto grado de autonomía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504121/2025-26/CE06> a ns1:Competency ;
    ns1:competencyCode "CE06" ;
    ns1:competencyDescription "Capacidad para conocer y aplicar los conocimientos sobre el álgebra lineal, el cálculo diferencial e integral y aplicar procedimientos matemáticos para la resolución de problemas en el ámbito de la biotecnología."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504121/2025-26/CE07> a ns1:Competency ;
    ns1:competencyCode "CE07" ;
    ns1:competencyDescription "Capacidad de conocer y saber aplicar los métodos matemáticos, estadísticos y bioinformáticos básicos para el estudio, análisis y control de experimentos o procesos biotecnológicos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504121/2025-26/CG05> a ns1:Competency ;
    ns1:competencyCode "CG05" ;
    ns1:competencyDescription "Familiarizarse con los fundamentos de informática necesarios para llevar a cabo una investigación y desarrollo modernos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504121/2025-26/RA17> a ns1:LearningResult ;
    ns1:learningResultCode "RA17" ;
    ns1:learningResultDescription "Representar gráficamente funciones reales de dos variables por medio de la gráfica y funciones de dos y tres variables mediantes curvas y superficies de nivel."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504121/2025-26/RA18> a ns1:LearningResult ;
    ns1:learningResultCode "RA18" ;
    ns1:learningResultDescription "Utilizar las derivadas parciales de primer y segundo orden y el método de los multiplicadores de Lagrange para obtener los extremos de una función."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504121/2025-26/RA19> a ns1:LearningResult ;
    ns1:learningResultCode "RA19" ;
    ns1:learningResultDescription "Interpretar los conceptos de derivada parcial y gradiente de funciones de dos y tres variables en el contexto de la biotecnología."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504121/2025-26/RA20> a ns1:LearningResult ;
    ns1:learningResultCode "RA20" ;
    ns1:learningResultDescription "Resolver problemas mediante integración múltiple en contextos prácticos de la biotecnología"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504121/2025-26/RA21> a ns1:LearningResult ;
    ns1:learningResultCode "RA21" ;
    ns1:learningResultDescription "Resolver ecuaciones diferenciales ordinarias simples de primer orden y sus problemas de valores iniciales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504121/2025-26/RA22> a ns1:LearningResult ;
    ns1:learningResultCode "RA22" ;
    ns1:learningResultDescription "Interpretar geométricamente las ecuaciones diferenciales ordinarias a través de los campos de direcciones."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504121/2025-26/RA23> a ns1:LearningResult ;
    ns1:learningResultCode "RA23" ;
    ns1:learningResultDescription "Modelizar vibraciones mecánicas no forzadas con ecuaciones diferenciales ordinarias de 2º orden y obtener las soluciones del modelo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504121/2025-26/RA24> a ns1:LearningResult ;
    ns1:learningResultCode "RA24" ;
    ns1:learningResultDescription "Resolver sistemas de ecuaciones diferenciales lineales con coeficientes constantes bidimensionales y sus problemas de valores iniciales por métodos matriciales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504121/2025-26/RA25> a ns1:LearningResult ;
    ns1:learningResultCode "RA25" ;
    ns1:learningResultDescription "Deducir e interpretar el comportamiento de sistemas dinámicos bidimensionales simples a través de las nociones de plano de fases, de estabilidad y de linealización en los puntos críticos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504121/2025-26/RA26> a ns1:LearningResult ;
    ns1:learningResultCode "RA26" ;
    ns1:learningResultDescription "Traducir un problema real a un problema de enunciado matemático con datos e incógnitas para obtener un modelo matemático simple (representación matemática con elementos introducidos en este curso) en el contexto de la biotecnolgía."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504121/2025-26/RA27> a ns1:LearningResult ;
    ns1:learningResultCode "RA27" ;
    ns1:learningResultDescription "Aplicar correctamente resultados matemáticos y seleccionar procedimientos y herramientas matemáticas introducidas en este curso para resolver problemas y extraer información relevante de modelos matemáticos simples en el contexto de la biotecnología."@es .

