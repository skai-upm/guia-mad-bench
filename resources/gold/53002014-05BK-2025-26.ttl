    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/53002014/2025-26/eventSchedule> ;
    schema:description "The course aims to deepen knowledge in Thermal Engineering by building upon concepts learned during the undergraduate degree. To this end, it reviews the current and future landscape of thermal energy and adopts a practical approach to the energy analysis of various thermal systems: thermal power plants, systems at ultra-high temperature, heating and cooling systems, industrial combustion applications, and technologies for reducing environmental impact. In addition, the course explores different potential energy vectors in decarbonization scenarios."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/lf.gonzalez%40upm.es> ;
    schema:inLanguage "Inglés"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/alberto.abanades%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/javier.munoz.anton%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/lf.gonzalez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/victor.dominguez.perez%40upm.es> ;
    schema:name "Thermal Engineering Advanced"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002014/2025-26/CB10> a ns1:Competency ;
    ns1:competencyCode "CB10" ;
    ns1:competencyDescription "Que los estudiantes posean las habilidades de aprendizaje que les permitan continuar estudiando de un modo que habrá de ser en gran medida autodirigido o autónomo./ Students have the learning skills that they require to pursue their studies in a largely self"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002014/2025-26/CB7> a ns1:Competency ;
    ns1:competencyCode "CB7" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en entornos nuevos o poco conocidos dentro de contextos más amplios (o multidisciplinares) relacionados con su área de estudio/ Students are capable of applying their knowledge, understanding, and problem"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002014/2025-26/CE16> a ns1:Competency ;
    ns1:competencyCode "CE16" ;
    ns1:competencyDescription "Aplicar conocimientos y habilidades adquiridas para la práctica profesional de alto nivel y la gestión de equipos en las empresas del sector energético./ Apply knowledge and skills acquired for high"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002014/2025-26/CE2> a ns1:Competency ;
    ns1:competencyCode "CE2" ;
    ns1:competencyDescription "Analizar y establecer criterios de mejora energética y económica en instalaciones de generación y de consumo, incluyendo el sector transportes, conducente al diseño de alternativas más eficientes y con menor impacto ambiental./ Analyze and establish criteria for energy and economic improvement in generation and consumption facilities, including the transport sector, leading to the design of more efficient alternatives with less environmental impact"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002014/2025-26/CE8> a ns1:Competency ;
    ns1:competencyCode "CE8" ;
    ns1:competencyDescription "Disponer de habilidades, criterios y conocimientos para investigar, desarrollar e innovar en el campo de la energía: tecnologías renovables y no renovables, almacenamiento, vectores energéticos, en un contexto de decarbonización del sistema./ Skills, criteria and knowledge to research, develop and innovate in the field of energy: renewable and non"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002014/2025-26/CE9> a ns1:Competency ;
    ns1:competencyCode "CE9" ;
    ns1:competencyDescription "Disponer de criterios y herramientas para entender la composición y características de los diferentes tipos de combustibles convencionales y no convencionales./ Skills, criteria and knowledge to research, develop and innovate in the field of energy: renewable and non"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002014/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Aplicar conocimientos de ciencias y tecnologías avanzadas a la práctica profesional o investigadora de la Ingeniería Energética./ Apply knowledge of advanced science and technology to the professional or research practice of Energy Engineering."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002014/2025-26/CG2> a ns1:Competency ;
    ns1:competencyCode "CG2" ;
    ns1:competencyDescription "Poseer capacidad para diseñar, desarrollar, implementar, gestionar y mejorar productos, sistemas y procesos en los distintos ámbitos energéticos, usando técnicas analíticas, computacionales o experimentales avanzadas./ Ability to design, develop, implement, manage and improve products, systems and processes in the different energy fields, using advanced analytical, computational or experimental techniques."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002014/2025-26/CT1> a ns1:Competency ;
    ns1:competencyCode "CT1" ;
    ns1:competencyDescription "Aplica. Habilidad para aplicar conocimientos científicos, matemáticos y tecnológicos en sistemas relacionados con la práctica de la ingeniería./ Apply. Ability to apply scientific, mathematical and technological knowledge in systems related to the practice of engineering."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002014/2025-26/CT10> a ns1:Competency ;
    ns1:competencyCode "CT10" ;
    ns1:competencyDescription "Conoce. Conocimiento de los temas contemporáneos./ Knowledge of contemporary issues."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002014/2025-26/CT11> a ns1:Competency ;
    ns1:competencyCode "CT11" ;
    ns1:competencyDescription "Usa herramientas. Habilidad para usar las técnicas, destrezas y herramientas ingenieriles modernas necesarias para la práctica de la ingeniería./ Use tools. Ability to use modern engineering techniques, skills, and tools necessary for engineering practice."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002014/2025-26/CT12> a ns1:Competency ;
    ns1:competencyCode "CT12" ;
    ns1:competencyDescription "Es bilingüe. Capacidad de trabajar en un entorno bilingüe (inglés/español). / Bilingual. Ability to work in a bilingual environment (English / Spanish)."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002014/2025-26/CT3> a ns1:Competency ;
    ns1:competencyCode "CT3" ;
    ns1:competencyDescription "Diseña. Habilidad para diseñar un sistema, componente o proceso que alcance los requisitos deseados teniendo en cuenta restricciones realistas tales como las económicas, medioambientales, sociales, políticas, éticas, de salud y seguridad, de fabricación y de sostenibilidad./ Design. Ability to design a system, component or process that meets the desired requirements taking into account realistic constraints such as economic, environmental, social, political, ethical, health and safety, manufacturing and sustainability."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002014/2025-26/CT5> a ns1:Competency ;
    ns1:competencyCode "CT5" ;
    ns1:competencyDescription "Resuelve. Habilidad para identificar, formular y resolver problemas de ingeniería./ Solve. Ability to identify, formulate and solve engineering problems."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002014/2025-26/RA104> a ns1:LearningResult ;
    ns1:learningResultCode "RA104" ;
    ns1:learningResultDescription "Identificar cómo mejorar la eficiencia de un ciclo para producción de frío y calor y sus consecuencias económicas y ambientales a través de modelos matemáticos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002014/2025-26/RA105> a ns1:LearningResult ;
    ns1:learningResultCode "RA105" ;
    ns1:learningResultDescription "Explicar y evaluar las características, fortalezas y debilidades, y alternativas de vectores energéticos disponibles en un contexto de descarbonización del sistema energético"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002014/2025-26/RA106> a ns1:LearningResult ;
    ns1:learningResultCode "RA106" ;
    ns1:learningResultDescription "Calcular los parámetros y los caudales de aire y combustible de procesos de combustión y postratamiento de gases utilizados en la industria y el trasporte"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002014/2025-26/RA107> a ns1:LearningResult ;
    ns1:learningResultCode "RA107" ;
    ns1:learningResultDescription "Explicar las partes de una central térmica y la influencia que los distintos parámetros que las definen tienen en la eficiencia del proceso"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002014/2025-26/RA108> a ns1:LearningResult ;
    ns1:learningResultCode "RA108" ;
    ns1:learningResultDescription "Explicar un trabajo relacionado con la ingeniería energética mediante una presentación oral y un informe escrito"@es .

