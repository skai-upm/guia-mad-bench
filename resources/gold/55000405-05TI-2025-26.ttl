<https://guia-kg.skai.etsisi.upm.es/resource/55000405/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Conceptos, definiciones, clasificación de las máquinas y los motores térmicos. Aplicación de las máquinas y los motores térmicos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000405/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "2. Clasificación y parámetros fundamentales de los motores de combustión interna volumétricos (m.c.i.v.) Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000405/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "3. Balance energético de los motores de c. i. volumétricos. Pérdidas de calor y mecánicas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000405/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "4. Fundamentos de la renovación de la carga y la formación de mezcla en los motores de c. i. volúmetricos Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000405/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "5. Los procesos de combustión en los motores de c. i. alternativos Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000405/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "6. Fundamentos del funcionamiento y clasificación de las turbomáquinas térmicas Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000405/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "7. Flujo bidimensional en turbomáquinas axiales Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000405/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "8. Compresores centrífugos y turbinas centrípetas Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000405/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "9. Funcionamiento de las turbomáquinas térmicas fuera de condiciones de diseño. Curvas características Sin subniveles"@es .

