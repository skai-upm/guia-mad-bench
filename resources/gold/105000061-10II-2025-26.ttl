    schema:hasCourseInstance <https://guia-kg.skai.etsisi.upm.es/resource/105000061/2025-26> ;
    schema:name "Geometría 3D para Informática Gráfica"@en,
        "Geometría 3D para Informática Gráfica"@es ;
    schema:numberOfCredits 3.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/105000061/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/105000061/2025-26/CG>,
        <https://guia-kg.skai.etsisi.upm.es/resource/105000061/2025-26/Ce%2012/16> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/105000061/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/105000061/2025-26/didactic_resource/2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/105000061/2025-26/didactic_resource/3>,
        <https://guia-kg.skai.etsisi.upm.es/resource/105000061/2025-26/didactic_resource/4>,
        <https://guia-kg.skai.etsisi.upm.es/resource/105000061/2025-26/didactic_resource/5>,
        <https://guia-kg.skai.etsisi.upm.es/resource/105000061/2025-26/didactic_resource/6>,
        <https://guia-kg.skai.etsisi.upm.es/resource/105000061/2025-26/didactic_resource/7>,
        <https://guia-kg.skai.etsisi.upm.es/resource/105000061/2025-26/didactic_resource/8> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/105000061/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/105000061/2025-26/RA278> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/105000061/2025-26/syllabus> ;
    ns1:inpersonHours "33 horas (42.3%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation "En esta asignatura se fomenta el Objetivo de Desarrollo Sostenible 04 (ODS04) ya que trabajamos con los fundamentos matemáticos sobre los que se asienta la visualización 3D. Gracias al conocimiento de dichos fundamentos, no es sólo el conocimiento, sino también abre la posibilidad de transformar y crear."@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "38 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/105000061/2025-26/eventSchedule> ;
    schema:description "La representación de objetos tridimensionales en dos dimensiones ha sido objeto de estudio durante mucho tiempo: desde el Renacimiento, que los pintores desarrollaron técnicas matemáticas que lo elevaron a nivel de ciencia, hasta nuestros días con los motores gráficos actuales. En este curso veremos un motor gráfico, OpenGL, sobre el que aprenderemos de forma introductoria a programar con esta librería, y nos centraremos en las matemáticas que hay debajo de ese motor, enfocándonos sobre todo en los aspectos geométricos. Ello nos obligará a repasar el Álgebra Lineal, pero también a introducirnos en los espacios afín y proyectivo, y sus transformaciones."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/jonatan.sanchez%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/jonatan.sanchez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/juan.rojo.carulli%40upm.es> ;
    schema:name "Geometría 3D para Informática Gráfica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000061/2025-26/CG> a ns1:Competency ;
    ns1:competencyCode "CG" ;
    ns1:competencyDescription "1/21"@es,
        "19"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000061/2025-26/Ce%2012/16> a ns1:Competency ;
    ns1:competencyCode "Ce 12/16" ;
    ns1:competencyDescription "Conocer los campos de aplicación de la informática, y tener una apreciación de la necesidad de poseer unos conocimientos técnicos profundos en ciertas áreas de aplicación; apreciación del grado de esta necesidad en, por lo menos, una situación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000061/2025-26/RA278> a ns1:LearningResult ;
    ns1:learningResultCode "RA278" ;
    ns1:learningResultDescription "Desarrollar la solución matemática y algorítmica mas apropiada a un problema informático que requiera un tratamiento especialmente complejo, analizando y exponiendo su viabilidad."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000061/2025-26/didactic_resource/1> a ns1:DidacticResource ;
    ns1:bibliographyDescription "Referencia básica de la asignatura. Aunque está desactualizado, recoge buena parte de las funciones de OpenGL tal y como los vamos a utilizar. También contiene breves explicaciones de los aspectos matemáticos de las funciones de OpenGL."@es ;
    ns1:bibliographyTitle "Hearn, Baker: Computer Graphics C version, Prentice Hall, 1997"@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000061/2025-26/didactic_resource/2> a ns1:DidacticResource ;
    ns1:bibliographyDescription "Referencia para la parte de espacios proyectivos. Además de introducir brevemente el espacio proyectivo, trata con extensión aquellas aplicaciones del espacio proyectivo en computer vision."@es ;
    ns1:bibliographyTitle "Hartley, Zisserman: Multiple View Geometry in Computer Vision, Cambridge University Press, 2004"@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000061/2025-26/didactic_resource/3> a ns1:DidacticResource ;
    ns1:bibliographyTitle "Buss: 3D Computer Graphics, Cambridge Univ. Press, 2005"@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000061/2025-26/didactic_resource/4> a ns1:DidacticResource ;
    ns1:bibliographyDescription "Es una de las referencias matemáticas de la asignatura. Útil por lo sencillo de sus explicaciones. Dirigido a personas con un nivel de matemáticas bastante bajo, y esto determina la exposición de los temas que trata, tanto para bien como para mal."@es ;
    ns1:bibliographyTitle "Vince: Mathematics for Computer Graphics, Springer, 2006"@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000061/2025-26/didactic_resource/5> a ns1:DidacticResource ;
    ns1:bibliographyTitle "www.euclideanspace.com"@es ;
    ns1:bibliographyType "Recursos web"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000061/2025-26/didactic_resource/6> a ns1:DidacticResource ;
    ns1:bibliographyDescription "Tutorial de OpenGL (desactualizado) donde el alumno puede profundizar aún más. Sin embargo, existen otros tutoriales más actuales, aunque no tan completos como éste."@es ;
    ns1:bibliographyTitle "http://nehe.gamedev.net"@es ;
    ns1:bibliographyType "Recursos web"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000061/2025-26/didactic_resource/7> a ns1:DidacticResource ;
    ns1:bibliographyTitle "www.python.org"@es ;
    ns1:bibliographyType "Recursos web"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000061/2025-26/didactic_resource/8> a ns1:DidacticResource ;
    ns1:bibliographyDescription "Tutorial más moderno (usa shaders) que el de NeHe. Está incluso traducido al castellano. Contiene muy breves explicaciones matemáticas."@es ;
    ns1:bibliographyTitle "Tutorial de OpenGL: https://www.opengl-tutorial.org/"@es ;
    ns1:bibliographyType "Recursos web"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000061/2025-26/evaluation> a ns1:EvaluationSystem ;
    ns1:evaluationDescription """Convocatoria ordinaria de Febrero
1) Sistema de evaluación progresiva.
Para ser evaluado por este sistema es obligatoria la asistencia a todas las clases. En algunas clases se pedirán entregas que serán evaluadas, que serán alrededor de 5 como mínimo. La nota final es la nota media de todas las entregas solicitadas. Estas actividades de evaluación no son recuperables puesto que están asociadas al trabajo en el aula.

2) Sistema de evaluación global.
Solamente para los alumnos que lo soliciten según normativa de exámenes UPM.
Examen escrito y práctico con ordenador.

Convocatoria extraordinaria de Julio:
Examen escrito y práctico con ordenador."""@es ;
