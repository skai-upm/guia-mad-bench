<https://guia-kg.skai.etsisi.upm.es/resource/95000318> a ns1:Course ;
    ns1:courseType "Obligatoria"@es ;
    ns1:courseYear 2 ;
    ns1:semester "Cuarto semestre"@es ;
    schema:courseCode 95000318 ;
    schema:hasCourseInstance <https://guia-kg.skai.etsisi.upm.es/resource/95000318/2025-26> ;
    schema:name "Systems And Signals"@en,
        "Sistemas y Señales"@es ;
    schema:numberOfCredits 6.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/95000318/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/95000318/2025-26/CE42> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/95000318/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/95000318/2025-26/didactic_resource/2> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/95000318/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/95000318/2025-26/RA91>,
        <https://guia-kg.skai.etsisi.upm.es/resource/95000318/2025-26/RA92>,
        <https://guia-kg.skai.etsisi.upm.es/resource/95000318/2025-26/RA94> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/95000318/2025-26/syllabus> ;
    ns1:inpersonHours "60 horas (38.5%)"@es ;
    ns1:numberOfCredits 6.0 ;
    ns1:otherInformation ""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "60 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/95000318/2025-26/eventSchedule> ;
    schema:description "Asignatura introductoria al procesado de señales. Presenta las herramientas generales para el estudio sistemático de la evolución temporal de magnitudes físicas y su procesado. Aquí nos centraremos principalmente en procesado de señales mediante transformaciones lineales (representadas por ecuaciones diferenciales lineales). Se trata de dar una visión general de las distintas técnicas de procesado y análisis de señal que luego podrán aplicarse a señales e imágenes médicas. Se comenzará por presentar las herramientas de análisis de señales continuas en el tiempo: análisis en el dominio temporal y el dominio espectral (Análisis de Fourier). A continuación se introducirán los conceptos de muestreo de señales para, seguidamente, describir las técnicas básicas de procesado de señales digitales. Se concluye la asignatura con un capítulo dedicado a la transformada Z con la finalidad de poder analizar sistemas digitales lineales no estables."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/gonzalo.demiguel%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/d.carraminana%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/gonzalo.demiguel%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/luca.bergesio%40upm.es> ;
    schema:name "Sistemas y Señales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000318/2025-26/CE42> a ns1:Competency ;
    ns1:competencyCode "CE42" ;
    ns1:competencyDescription "Conocer técnicas de muestreo y procesado de señales e imágenes para diversas aplicaciones en relación con la Ingeniería Biomédica."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000318/2025-26/RA91> a ns1:LearningResult ;
    ns1:learningResultCode "RA91" ;
    ns1:learningResultDescription "Entender y conocer las diferentes técnicas de transformadas de señales temporales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000318/2025-26/RA92> a ns1:LearningResult ;
    ns1:learningResultCode "RA92" ;
    ns1:learningResultDescription "Conocer los elementos que hacen falta y qué aspectos se deben tener en cuenta para poner en práctica el diseño de sistemas de tratamiento digital de señales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000318/2025-26/RA94> a ns1:LearningResult ;
    ns1:learningResultCode "RA94" ;
    ns1:learningResultDescription "Ser capaz de analizar y valorar qué estrategia de tratamiento digital de señales sería la más adecuada para analizar las señales de determinado proceso físico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000318/2025-26/didactic_resource/1> a ns1:DidacticResource ;
    ns1:bibliographyDescription "Libro principal. De él se extraerán muchos de los ejercicios resueltos en clase."@es ;
    ns1:bibliographyTitle "\"Signals and Systems\" , segunda edición, de A.V. Oppenheim, A.S. Willsky y S.H. Nawab. Editorial Prentice Hall, 1997."@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000318/2025-26/didactic_resource/2> a ns1:DidacticResource ;
    ns1:bibliographyTitle "\"Signals and Systems\", Simon Haykin, Barry Van Veen. Editorial Johm Wiley 1999."@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000318/2025-26/evaluation> a ns1:EvaluationSystem ;
    ns1:evaluationDescription """La evaluación en la convocatoria extraordinaria se realizará exclusivamente a través del sistema de prueba final.
_________________________
Evaluación progresiva:
La calificación de la asignatura para estos alumnos se realizará del siguiente modo:
30 % de los controles de seguimiento de la asignatura+
70 % de la evaluación del examen final
La calificación se obtiene promediando la nota de los ejercicios de evaluación realizados en clase (uno por cada uno de los dos primeros capítulos) y del examen final. Para poder realizar esta media se necesita sacar más de un cuatro en el examen final.
----------------------------------------
Evaluación mediante prueba global
La calificación final se obtendría de acuerdo a la siguiente fórmula:
100 % nota examen final

----------------------------------------
La evaluación comprobará si los estudiantes han adquirido las competencias de la asignatura. Por tanto, la evaluación en la convocatoria extraordinaria usará los mismos tipos de técnicas evaluativas que se usan en la evaluación de la convocatoria ordinaria (EX, ET, TG, etc.).
Para TODOS los alumnos que tengan que acudir al examen EXTRAORDINARIO de la asignatura la calificación final se obtendrá
como:
100 % nota examen final"""@es ;
    ns1:hasEvaluationTrial <https://guia-kg.skai.etsisi.upm.es/resource/95000318/2025-26/evaluation/trial1>,
