    schema:name "Fisica I"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000213/2025-26/CE2> a ns1:Competency ;
    ns1:competencyCode "CE2" ;
    ns1:competencyDescription "Comprensión y dominio de los conceptos básicos sobre las leyes generales de la mecánica, termodinámica, campos y ondas y electromagnetismo y su aplicación para la resolución de problemas propios de la ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000213/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Conocer y aplicar los conocimientos de ciencias y tecnologías básicas a la práctica de la Ingeniería Industrial"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000213/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Aplicar los conocimientos adquiridos para identificar, formular y resolver problemas en contextos amplios, siendo capaces de integrar los trabajando en equipos multidisciplinares"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000213/2025-26/CG6> a ns1:Competency ;
    ns1:competencyCode "CG6" ;
    ns1:competencyDescription "Poseer las habilidades de aprendizaje que permitan continuar estudiando a lo largo de toda la vida para un desarrollo profesional adecuado"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000213/2025-26/RA18> a ns1:LearningResult ;
    ns1:learningResultCode "RA18" ;
    ns1:learningResultDescription "Conocimientos y capacidades de pensamiento y razonamiento necesarios para el análisis, enfoque y resolución de problemas concretos. Saber aplicar el método científico y el lenguaje científicotecnológico a la resolución de problemas concretos de la Ingeniería. Adquirir las habilidades necesarias para aplicar los conocimientos físicos a la investigación, desarrollo e innovación en Ingeniería. Adquirir las habilidades necesarias para el manejo y aprovechamiento de los equipos, dispositivos y sistemas de medida. Ser capaz de recoger, tratar, analizar e interpretar críticamente los datos experimentales. Actitudes de razonamiento crítico y actuaciones creativas para abordar y resolver problemas."@es .

