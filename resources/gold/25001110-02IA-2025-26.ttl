<https://guia-kg.skai.etsisi.upm.es/resource/25001110/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. TIEMPO GEOLÓGICO"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001110/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Introducción. Concepto de geología. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001110/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "3. PETROLOGÍA"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001110/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "3.1. Petrología Endógena."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001110/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "3.1.1. Ciclo de las rocas. Ambientes genéticos formadores de las rocas Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001110/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "3.1.2. Rocas Ígneas: Origen de los magmas. Ámbitos geodinámicos de la fusión de rocas. Evolución de los magmas: diferenciación, asimilación, mezcla de magmas Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001110/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "3.1.3. Rocas endógenas ígneas. Rocas plutónicas. Intrusión magmática. Clasificación y propiedades. Rocas filonianas o subvolcánicas. Clasificación y propiedades. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001110/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "3.1.4. Rocas volcánicas y vulcanismo. Factores que controlan las erupciones volcánicas. Estructuras asociadas a las erupciones volcánicas. Clasificación, propiedades y aplicaciones. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001110/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "3.1.5. Rocas endógenas metamórficas. Factores del metamorfismo (presión y temperatura). Procesos metamórficos. Tipos de metamorfismo. Rocas metamórficas. Clasificación y propiedades. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001110/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "3.2. Petrología Exógena."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001110/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "3.2.1. Procesos generadores de rocas sedimentarias I: Meteorización. Procesos de meteorización física y química. Transporte y erosión. Factores formadores de los suelos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001110/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "3.2.2. Procesos generadores de rocas sedimentarias II: Sedimentación y ambientes sedimentarios; Procesos postsedimentarios. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001110/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. El Tiempo geológico. Datación relativa y absoluta. Principios de datación relativa. Datación absoluta. La Escala del tiempo Geológico. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001110/2025-26/syllabus/20> a ns1:SyllabusItem ;
    ns1:itemIndex 20 ;
    ns1:syllabusDescription "3.2.3. Rocas exógenas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001110/2025-26/syllabus/21> a ns1:SyllabusItem ;
    ns1:itemIndex 21 ;
    ns1:syllabusDescription "3.2.3.1. Rocas exógenas detríticas. Génesis, clasificación y características. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001110/2025-26/syllabus/22> a ns1:SyllabusItem ;
    ns1:itemIndex 22 ;
    ns1:syllabusDescription "3.2.3.2. Rocas exógenas de precipitación química . Génesis, clasificación y características. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001110/2025-26/syllabus/23> a ns1:SyllabusItem ;
    ns1:itemIndex 23 ;
    ns1:syllabusDescription "4. GEOMORFOLOGÍA"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001110/2025-26/syllabus/24> a ns1:SyllabusItem ;
    ns1:itemIndex 24 ;
    ns1:syllabusDescription "4.1. Introducción al modelado terrestre. Geomorfología. Unidades morfoestructurales. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001110/2025-26/syllabus/25> a ns1:SyllabusItem ;
    ns1:itemIndex 25 ;
    ns1:syllabusDescription "4.2. Procesos de gravedad. Condicionantes de estabilidad de laderas. Desprendimientos. Deslizamientos. Flujo. Reptación. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001110/2025-26/syllabus/26> a ns1:SyllabusItem ;
    ns1:itemIndex 26 ;
    ns1:syllabusDescription "4.3. Procesos asociados a aguas superficiales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001110/2025-26/syllabus/27> a ns1:SyllabusItem ;
    ns1:itemIndex 27 ;
    ns1:syllabusDescription "4.3.1. El Ciclo hidrológico. Formas erosivas y depósitos resultantes. Abanicos aluviales, conos de deyección, glacis, llanura de inundación y terrazas fluviales. Hidrogeología. Acuíferos libres. Acuíferos confinados. Explotación. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001110/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "2. MINERALOGÍA"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001110/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "2.1. Concepto de mineral. Clasificación de los minerales. Estructura de los silicatos. Bases de la estabilidad de los minerales frente a la alteración. Polimerización. Tipos de enlace. Sustituciones isomórficas. Sin subniveles"@es .

