        <https://guia-kg.skai.etsisi.upm.es/resource/95000308/2025-26/RA66>,
        <https://guia-kg.skai.etsisi.upm.es/resource/95000308/2025-26/RA67>,
        <https://guia-kg.skai.etsisi.upm.es/resource/95000308/2025-26/RA68>,
        <https://guia-kg.skai.etsisi.upm.es/resource/95000308/2025-26/RA69>,
        <https://guia-kg.skai.etsisi.upm.es/resource/95000308/2025-26/RA70> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/95000308/2025-26/syllabus> ;
    ns1:inpersonHours "85 horas y 45 minutos (52.9%)"@es ;
    ns1:numberOfCredits 6.0 ;
    ns1:otherInformation """En la presente situación, la asignatura se planifica con clases presenciales.
En esta asignatura se promueve el Objetivo de Desarrollo Sostenible número 3: Garantizar una vida sana y promover el bienestar para todos en todas las edades.
El alumno deberá asistir a las prácticas docentes con los elementos de seguridad necesarios. En las prácticas de Biología Celular y Tisular estos elementos son bata y gafas protectoras. Además los alumnos deberán traer unos zapatos cerrados. Los guantes serán suministrados por la unidad. Los alumnos que no se presenten con los medios requeridos no podrán realizar las prácticas asumiendo las consecuencias que ello pudiera acarrear en términos de evaluación de la asignatura."""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "85 horas y 45 minutos"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/95000308/2025-26/eventSchedule> ;
    schema:description """La asignatura de Biología Celular y Tisular ofrece al alumno un conocimiento sobre los diferentes componentes de la célula eucariota animal y vegetal y de como los diferentes tipos celulares se agrupan en tejidos y órganos para realizar funciones específicas. La vertiente práctica en esta asignatura es muy importante, ya que permite a los alumnos identificar mediante microscopía diferentes elementos que se dan a conocer en la parte teórica de la asignatura. La asignatura está articulada en 2 unidades temáticas:
Unidad Temática 1. Biología Celular (28 h). Temas 1-10.
Unidad Temática 2. Histología (28 h). Temas 11-23."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/miguelangel.torres%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/cesar.perez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/clara.martinez.arias%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/miguelangel.torres%40upm.es> ;
    schema:name "Biología Celular y Tisular"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000308/2025-26/CE47> a ns1:Competency ;
    ns1:competencyCode "CE47" ;
    ns1:competencyDescription "Conocer los niveles jerarquizados de complejidad biológica: Desde las moléculas hasta organismos más complejos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000308/2025-26/CE48> a ns1:Competency ;
    ns1:competencyCode "CE48" ;
    ns1:competencyDescription "Conocer los tipos celulares y sus mecanismos principales, así como su impacto en la formación de tejidos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000308/2025-26/CG05> a ns1:Competency ;
    ns1:competencyCode "CG05" ;
    ns1:competencyDescription "Tener capacidad de análisis y síntesis, pensar de forma integrada, abordar los problemas desde diferentes perspectivas y estar siempre preparado para ¿to think out of the box¿"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000308/2025-26/RA63> a ns1:LearningResult ;
    ns1:learningResultCode "RA63" ;
    ns1:learningResultDescription "Conocer los diferentes protocolos aplicados al estudio celular."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000308/2025-26/RA64> a ns1:LearningResult ;
    ns1:learningResultCode "RA64" ;
    ns1:learningResultDescription "Demostrar comprensión detallada de la función de cada uno de los orgánulos que forman parte de las células."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000308/2025-26/RA65> a ns1:LearningResult ;
    ns1:learningResultCode "RA65" ;
    ns1:learningResultDescription "Conocer los componentes celulares y saber identificarlos mediante microscopía."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000308/2025-26/RA66> a ns1:LearningResult ;
    ns1:learningResultCode "RA66" ;
    ns1:learningResultDescription "Saber utilizar un microscopio óptico para observar preparaciones."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000308/2025-26/RA67> a ns1:LearningResult ;
    ns1:learningResultCode "RA67" ;
    ns1:learningResultDescription "Adquirir la destreza necesaria en la preparación de muestras macroscópicas y preparaciones anatómicas microscópicas de animales y vegetales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000308/2025-26/RA68> a ns1:LearningResult ;
    ns1:learningResultCode "RA68" ;
    ns1:learningResultDescription "Conocer y relacionar la estructura y la función de los distintos tipos de células en su contexto fisiológico."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000308/2025-26/RA69> a ns1:LearningResult ;
    ns1:learningResultCode "RA69" ;
    ns1:learningResultDescription "Conocer el significado del ciclo celular y su regulación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000308/2025-26/RA70> a ns1:LearningResult ;
    ns1:learningResultCode "RA70" ;
    ns1:learningResultDescription "Conocer y saber identificar los principales tipos de tejidos animales y vegetales."@es .

