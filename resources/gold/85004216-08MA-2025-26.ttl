    schema:hasCourseInstance <https://guia-kg.skai.etsisi.upm.es/resource/85004216/2025-26> ;
    schema:name "Ships And Ocean Sea Artefacts"@en,
        "Buques y Artefactos Oceánicos"@es ;
    schema:numberOfCredits 3.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/85004216/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/85004216/2025-26/CB2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/85004216/2025-26/CB3>,
