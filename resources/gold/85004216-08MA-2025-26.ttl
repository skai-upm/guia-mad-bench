        <https://guia-kg.skai.etsisi.upm.es/resource/85004216/2025-26/CE15>,
        <https://guia-kg.skai.etsisi.upm.es/resource/85004216/2025-26/CE19>,
        <https://guia-kg.skai.etsisi.upm.es/resource/85004216/2025-26/CG3>,
        <https://guia-kg.skai.etsisi.upm.es/resource/85004216/2025-26/CT%20UPM%202> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/85004216/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/85004216/2025-26/didactic_resource/2>,
