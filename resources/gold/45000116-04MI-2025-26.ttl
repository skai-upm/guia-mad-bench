<https://guia-kg.skai.etsisi.upm.es/resource/45000116/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Teoría de campos y teoremas integrales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000116/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Espacio vectorial euclídeo. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000116/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "3. Introducción a las Ecuaciones en derivadas parciales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000116/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "3.1. Nociones básicas sobre ecuaciones en derivadas parciales. Ecuación del calor. Ecuación de ondas. Ecuación de Laplace. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000116/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "3.2. Problemas de contorno con y sin valores iniciales. Separación de variables. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000116/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "3.3. Introducción al método de Fourier. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000116/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "4. Introducción a la Estadística"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000116/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "4.1. Descripción de datos. Fundamentos de Probabilidad. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000116/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "4.2. Variables aleatorias. Modelos univariantes de distribución de probabilidad. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000116/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "4.3. Introducción a la inferencia estadística. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000116/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Campos escalares. Campos vectoriales. Operadores diferenciales. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000116/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "1.3. Integrales de línea y de superficie Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000116/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "1.4. Teoremas integrales: Teorema de Stokes, Teorema de Green, Teorema de Gauss Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000116/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "2. Álgebra y cálculo tensorial"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000116/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "2.1. Nociones básicas sobre tensores y campos tensoriales. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000116/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "2.2. Tensores de segundo orden. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000116/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "2.3. Autovalores y autovectores de un tensor de segundo orden. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000116/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
