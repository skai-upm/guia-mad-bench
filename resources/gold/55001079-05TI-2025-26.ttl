    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation "La asignatura está directamente relacionada con el ODS 9 Industria, Innovación e Infraestructura."@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
