    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation """La asignatura se relaciona con los ODS 3; ODS 4; ODS 5 Y ODS 10.
-------------------------------------------------------------------------------------------------------------------------------------------
El profesor David Caballol Bartolomé es el único docente asignado a esta asignatura:
Le corresponden 30h de docencia presencial por cuatrimestre."""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "33 horas y 30 minutos"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/593000350/2025-26/eventSchedule> ;
    schema:description """La asignatura se ocupará fundamentalmente de estudiar todos los elementos que forman parte de un edificio. Sus objetivos principales son:
1- Conocer e identificar los elementos y sistemas constructivos, con su lenguaje y terminología enfatizando sus propiedades y funciones en el aislamiento y acondicionamiento acústico de los edificios y su compatibilidad con los demás requerimientos del edificio .
2- Conocer los errores más comunes en la ejecución de los sistemas constructivos y su repercusión en las características acústicas del edificio.
3- Aprender a evitar los errores anteriormente descritos.
."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/david.caballol%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/david.caballol%40upm.es> ;
    schema:name "Sistemas Constructivos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/593000350/2025-26/CE04> a ns1:Competency ;
    ns1:competencyCode "CE04" ;
    ns1:competencyDescription "Capacidad de visión espacial y conocimiento de técnica de representación gráfica así como mediante las aplicaciones de diseño asistido por ordenador"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/593000350/2025-26/CE05> a ns1:Competency ;
    ns1:competencyCode "CE05" ;
    ns1:competencyDescription "Capacidad para comprender y utilizar los principios de acústica aplicada para el diseño industrial, ambiental y/o arquitectónico de equipos, instalaciones y/o recintos y su aplicación para la resolución de los problemas propios de la ingeniería acústica."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/593000350/2025-26/CG01> a ns1:Competency ;
    ns1:competencyCode "CG01" ;
    ns1:competencyDescription "Conocer y aplicar conocimientos y soluciones de ingeniería acústica a los campos de la industria, la edificación, el transporte y el medio ambiente, entre otros."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/593000350/2025-26/CG05> a ns1:Competency ;
    ns1:competencyCode "CG05" ;
    ns1:competencyDescription "Preparar al alumno para la toma de decisiones y la emisión de juicios ante el estudio de casos reales presentados por el profesorado en la forma práctica, científica y profesional."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/593000350/2025-26/RA88> a ns1:LearningResult ;
    ns1:learningResultCode "RA88" ;
    ns1:learningResultDescription "Conocer y ser capaz de emplear los materiales usuales de la construcción convencional y sus propiedades acústicas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/593000350/2025-26/RA89> a ns1:LearningResult ;
    ns1:learningResultCode "RA89" ;
    ns1:learningResultDescription "Conocer y ser capaz de emplear diferentes sistemas constructivos en situaciones concretas teniendo en cuenta sus singularidades y proceso de ejecución"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/593000350/2025-26/RA90> a ns1:LearningResult ;
    ns1:learningResultCode "RA90" ;
    ns1:learningResultDescription "Conocer diferentes sistemas constructivos y ser capaz de aplicarlos en situaciones concretas en función de su adecuación a las necesidades de absorción y aislamiento acústico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/593000350/2025-26/RA91> a ns1:LearningResult ;
    ns1:learningResultCode "RA91" ;
    ns1:learningResultDescription "Conocer los materiales y sistemas que la industria ofrece para el aislamiento y acondicionamiento acústico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/593000350/2025-26/RA92> a ns1:LearningResult ;
    ns1:learningResultCode "RA92" ;
    ns1:learningResultDescription "Comprender la representación gráfica un detalle constructivo en edificación"@es .

