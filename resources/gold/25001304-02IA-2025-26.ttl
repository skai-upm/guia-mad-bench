<https://guia-kg.skai.etsisi.upm.es/resource/25001304/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. UT1.- Sistemas agrícolas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001304/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Tema 1.- Sistemas agrícolas y alimentación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001304/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "2. UT2.- Bases de la productividad potencial de los cultivos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001304/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "2.1. Tema 3.- Intercepción de radiación en cubiertas vegetales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001304/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "2.1.1. Intercepción y balance de radiación PAR en una cubierta vegetal. Eficiencia en la intercepción de radiación PAR. Influencia de la arquitectura de la cubierta vegetal en la intercepción de radiación PAR (LAI y K). Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001304/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "2.1.2. Factores y prácticas agronómicas que determinan la intercepción de radiación durante el ciclo vegetativo. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001304/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "2.2. Tema 4.- Crecimiento: Producción y reparto de biomasa. Elaboración del rendimiento"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001304/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "2.2.1. Producción de biomasa por los cultivos. Tasas potenciales de producción de biomasa. Eficiencia en el uso de la radiación PAR: concepto y factores que influyen. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001304/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "2.2.2. Reparto de biomasa (distribución de los productos fotosintetizados). Índice de cosecha. Rendimiento y sus componentes. Factores y prácticas relacionados con el reparto de biomasa. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001304/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "2.2.3. Eficiencia potencial de la fotosíntesis de cubiertas vegetales. Valores record de crecimiento y producción de los cultivos, influencia de factores ambientales y del tipo de fotosíntesis C3-C4. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001304/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "2.2.4. Crecimiento vegetal. Concepto, fases y cinética del crecimiento. Índices de crecimiento. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001304/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "2.3. Tema 5.- Análisis y cuantificación del desarrollo de los cultivos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001304/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.1.1. Sistemas agrícolas: Definición, estructura, y propiedades. Diferencias entre sistemas agrícolas (agrosistemas) y ecosistemas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001304/2025-26/syllabus/20> a ns1:SyllabusItem ;
    ns1:itemIndex 20 ;
    ns1:syllabusDescription "2.3.1. Desarrollo vegetal. Estados fenológicos. Tasas de desarrollo. Factores ambientales que influyen en la tasa de desarrollo. Integral térmica y fototérmica. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001304/2025-26/syllabus/21> a ns1:SyllabusItem ;
    ns1:itemIndex 21 ;
    ns1:syllabusDescription "2.3.2. Respuesta del desarrollo de los cultivos al fotoperiodo. Interacción del fotoperiodo con la integral térmica: Modelos de simulación del desarrollo. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001304/2025-26/syllabus/22> a ns1:SyllabusItem ;
    ns1:itemIndex 22 ;
    ns1:syllabusDescription "2.3.3. Respuesta del desarrollo de los cultivos a las bajas temperaturas. Necesidades de frío y vernalización. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001304/2025-26/syllabus/23> a ns1:SyllabusItem ;
    ns1:itemIndex 23 ;
    ns1:syllabusDescription "2.3.4. Cuantificación de la respuesta fenológica. Aplicaciones a la predicción de estados fenológicos y planificación de siembras y plantaciones. Casos prácticos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001304/2025-26/syllabus/24> a ns1:SyllabusItem ;
    ns1:itemIndex 24 ;
    ns1:syllabusDescription "2.4. Práctica: Análisis de crecimiento e intercepción de radiación PAR Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001304/2025-26/syllabus/25> a ns1:SyllabusItem ;
    ns1:itemIndex 25 ;
    ns1:syllabusDescription "3. UT3.- Relaciones hídricas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001304/2025-26/syllabus/26> a ns1:SyllabusItem ;
    ns1:itemIndex 26 ;
    ns1:syllabusDescription "3.1. Tema 6.- Relaciones hídricas suelo-cultivo-atmósfera."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001304/2025-26/syllabus/27> a ns1:SyllabusItem ;
    ns1:itemIndex 27 ;
    ns1:syllabusDescription "3.1.1. El estado hídrico del suelo: indicadores (contenido de humedad, potencial hídrico), métodos de medida, disponibilidad hídrica para los cultivos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001304/2025-26/syllabus/28> a ns1:SyllabusItem ;
    ns1:itemIndex 28 ;
    ns1:syllabusDescription "3.1.2. El estado hídrico de los cultivos: indicadores y métodos de medida (contenido hídrico relativo, potencial hídrico foliar, índice de estrés hídrico, resistencia estomática, variaciones dimensionales). Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001304/2025-26/syllabus/29> a ns1:SyllabusItem ;
    ns1:itemIndex 29 ;
    ns1:syllabusDescription "3.1.3. Movimiento del agua en el conjunto suelo-cultivo-atmósfera. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001304/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "1.1.2. Clasificación y manejo de los sistemas agrícolas. Análisis de la diversidad y de la estabilidad de la producción agrícola global. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001304/2025-26/syllabus/30> a ns1:SyllabusItem ;
    ns1:itemIndex 30 ;
    ns1:syllabusDescription "3.2. Tema 7.- Evapotranspiración"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001304/2025-26/syllabus/31> a ns1:SyllabusItem ;
    ns1:itemIndex 31 ;
    ns1:syllabusDescription "3.2.1. Evapotranspiración. Concepto, componentes y unidades de medida. Factores que influyen en la evapotranspiración. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001304/2025-26/syllabus/32> a ns1:SyllabusItem ;
    ns1:itemIndex 32 ;
    ns1:syllabusDescription "3.2.2. Evapotranspiración de referencia, evapotranspiración máxima y real de un cultivo. Evapotranspiración de una alternativa de cultivos y de un área verde. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001304/2025-26/syllabus/33> a ns1:SyllabusItem ;
    ns1:itemIndex 33 ;
    ns1:syllabusDescription "3.2.3. Métodos de medida y estimación de la evapotranspiración. Casos prácticos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001304/2025-26/syllabus/34> a ns1:SyllabusItem ;
    ns1:itemIndex 34 ;
    ns1:syllabusDescription "3.3. Tema 8.- Cultivo en condiciones de déficit hídrico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001304/2025-26/syllabus/35> a ns1:SyllabusItem ;
    ns1:itemIndex 35 ;
    ns1:syllabusDescription "3.3.1. Conceptos básicos: Sequía, déficit hídrico y estrés hídrico. Causas que los provocan y tipos de déficit hídrico Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001304/2025-26/syllabus/36> a ns1:SyllabusItem ;
    ns1:itemIndex 36 ;
    ns1:syllabusDescription "3.3.2. Efectos del estrés hídrico. Respuesta de los cultivos al estrés hídrico. Mecanismos de adaptación. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001304/2025-26/syllabus/37> a ns1:SyllabusItem ;
    ns1:itemIndex 37 ;
    ns1:syllabusDescription "3.3.3. Relaciones entre la evapotranspiración y la producción de los cultivos. Funciones de producción. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001304/2025-26/syllabus/38> a ns1:SyllabusItem ;
    ns1:itemIndex 38 ;
    ns1:syllabusDescription "3.3.4. Eficiencia en el uso del agua: concepto, factores que intervienen y técnicas para optimizarla. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001304/2025-26/syllabus/39> a ns1:SyllabusItem ;
    ns1:itemIndex 39 ;
    ns1:syllabusDescription "3.3.5. Estrategias de manejo del agua en los cultivos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001304/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "1.1.3. Producción vegetal. Composición del material vegetal. Cadenas tróficas. Nutrición animal y humana. Cálculo de la capacidad de carga. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001304/2025-26/syllabus/40> a ns1:SyllabusItem ;
    ns1:itemIndex 40 ;
    ns1:syllabusDescription "3.4. Tema 9.- Programación del riego"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001304/2025-26/syllabus/41> a ns1:SyllabusItem ;
    ns1:itemIndex 41 ;
    ns1:syllabusDescription "3.4.1. Conceptos generales de la programación del riego. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001304/2025-26/syllabus/42> a ns1:SyllabusItem ;
    ns1:itemIndex 42 ;
    ns1:syllabusDescription "3.4.2. Métodos de programación del riego: basados en el estado hídrico del suelo, en el estado hídrico del cultivo, en el balance hídrico en el sistema suelo-cultivo-atmósfera. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001304/2025-26/syllabus/43> a ns1:SyllabusItem ;
    ns1:itemIndex 43 ;
    ns1:syllabusDescription "3.4.3. Parámetros agronómicos del riego: Necesidades netas y brutas de riego. Eficiencia del riego. Dosis unitarias, intervalo entre riegos, calendario de riego, volumen total, caudales característicos, módulos y jornadas de riego. Casos prácticos Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001304/2025-26/syllabus/44> a ns1:SyllabusItem ;
    ns1:itemIndex 44 ;
    ns1:syllabusDescription "3.4.4. Tipos y características agronómicas de los sistemas de riego. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001304/2025-26/syllabus/45> a ns1:SyllabusItem ;
    ns1:itemIndex 45 ;
    ns1:syllabusDescription "3.5. Práctica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001304/2025-26/syllabus/46> a ns1:SyllabusItem ;
    ns1:itemIndex 46 ;
    ns1:syllabusDescription "3.5.1. Medida del estado hídrico del suelo y del estado hídrico del cultivo Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001304/2025-26/syllabus/47> a ns1:SyllabusItem ;
    ns1:itemIndex 47 ;
    ns1:syllabusDescription "3.5.2. Ejercicios de riegos Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001304/2025-26/syllabus/48> a ns1:SyllabusItem ;
    ns1:itemIndex 48 ;
    ns1:syllabusDescription "4. UT4.- Suministro de nutrientes"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001304/2025-26/syllabus/49> a ns1:SyllabusItem ;
    ns1:itemIndex 49 ;
    ns1:syllabusDescription "4.1. Tema 10.- Principios de la nutrición mineral de los cultivos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001304/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "1.2. Tema 2.- Sistemas agrícolas en España"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001304/2025-26/syllabus/50> a ns1:SyllabusItem ;
    ns1:itemIndex 50 ;
    ns1:syllabusDescription "4.1.1. Elementos esenciales. Transporte y absorción de nutrientes. Fertilidad del suelo: Definición, caracterización y métodos de evaluación. Influencia de la materia orgánica y el pH del suelo en la fertilidad. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001304/2025-26/syllabus/51> a ns1:SyllabusItem ;
    ns1:itemIndex 51 ;
    ns1:syllabusDescription "4.1.2. Respuesta de los cultivos a factores de crecimiento. Funciones de producción. Consumo de nutrientes y métodos de diagnóstico de la necesidad de nutrientes de los cultivos. Fertilizantes: tipos, presentación y métodos de aplicación. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001304/2025-26/syllabus/52> a ns1:SyllabusItem ;
    ns1:itemIndex 52 ;
    ns1:syllabusDescription "4.2. Tema 11.- Fertilización nitrogenada"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001304/2025-26/syllabus/53> a ns1:SyllabusItem ;
    ns1:itemIndex 53 ;
    ns1:syllabusDescription "4.2.1. Formas de nitrógeno en el suelo. Balance de nitrógeno: Aportes y pérdidas. Aportes de nitrógeno mineral al suelo: Mineralización neta, fijación biológica, deposición de nitrógeno atmosférico, aporte por enmiendas orgánicas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001304/2025-26/syllabus/54> a ns1:SyllabusItem ;
    ns1:itemIndex 54 ;
    ns1:syllabusDescription "4.2.2. Pérdidas: Inmovilización, desnitrificación, volatilización de amoniaco, lixiviación. necesidades de los cultivos y ritmo de absorción durante el ciclo vegetativo. Carencias y excesos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001304/2025-26/syllabus/55> a ns1:SyllabusItem ;
    ns1:itemIndex 55 ;
    ns1:syllabusDescription "4.2.3. Programa de fertilización: Dosis, fraccionamiento, abonos, formas de aplicación. Seguimiento del programa de fertilización. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001304/2025-26/syllabus/56> a ns1:SyllabusItem ;
    ns1:itemIndex 56 ;
    ns1:syllabusDescription "4.2.4. Práctica enmiendas orgánicas Sin subniveles"@es .

