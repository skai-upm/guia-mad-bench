<https://guia-kg.skai.etsisi.upm.es/resource/63000207/2025-26/CB09> a ns1:Competency ;
    ns1:competencyCode "CB09" ;
    ns1:competencyDescription "Que los estudiantes sepan comunicar sus conclusiones ¿y los conocimientos y razones últimas que las sustentan¿ a públicos especializados y no especializados de un modo claro y sin ambigüedades"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000207/2025-26/CG15> a ns1:Competency ;
    ns1:competencyCode "CG15" ;
    ns1:competencyDescription "Capacidad de obsevación, generación de hipótesis y planteamiento de problemas experimentales y de integración de los resultados con el estudio de la información bibliográfica especializada así como en modelos y herramientas de simulación y análisis"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000207/2025-26/CG16> a ns1:Competency ;
    ns1:competencyCode "CG16" ;
    ns1:competencyDescription "Manejo de documentación y capacidad de procesar información procedente de diferentes fuentes para su posterior utilización en el estudio y análisis."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000207/2025-26/CG17> a ns1:Competency ;
    ns1:competencyCode "CG17" ;
    ns1:competencyDescription "Capacidad para trabajar en equipo, tanto en relación directa (equipo propio) como indirecta (otros equipos), y en un contexto internacional. Siendo capaces de organizar y planificar el trabajo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000207/2025-26/RA111> a ns1:LearningResult ;
    ns1:learningResultCode "RA111" ;
    ns1:learningResultDescription "Comprender el ciclo de vida de uso de los materiales de ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000207/2025-26/RA112> a ns1:LearningResult ;
    ns1:learningResultCode "RA112" ;
    ns1:learningResultDescription "Comprender los principios básicos de las distintas técnicas de procesado de los materiales de ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000207/2025-26/RA113> a ns1:LearningResult ;
    ns1:learningResultCode "RA113" ;
    ns1:learningResultDescription "Comprender las propiedades que presentan las distintas clases de materiales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000207/2025-26/RA114> a ns1:LearningResult ;
    ns1:learningResultCode "RA114" ;
    ns1:learningResultDescription "Comprender los problemas que presenta el comportamiento en servicio de los materiales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000207/2025-26/RA2> a ns1:LearningResult ;
    ns1:learningResultCode "RA2" ;
    ns1:learningResultDescription "Otro aspecto importante es el aprovechamiento de la luz solar. La iluminación natural debe provenir del sol, o del cielo, que es un elemento natural difusor de la luz, para ello es necesario un diseño arquitectónico adecuado."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000207/2025-26/RA20> a ns1:LearningResult ;
    ns1:learningResultCode "RA20" ;
    ns1:learningResultDescription "Aplicación del control de procesos a la eficiencia energética."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000207/2025-26/RA47> a ns1:LearningResult ;
    ns1:learningResultCode "RA47" ;
    ns1:learningResultDescription "Eficiencia Energética."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000207/2025-26/RA48> a ns1:LearningResult ;
    ns1:learningResultCode "RA48" ;
    ns1:learningResultDescription "Gestión de residuos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000207/2025-26/RA62> a ns1:LearningResult ;
    ns1:learningResultCode "RA62" ;
    ns1:learningResultDescription "Dar a conocer las diferentes opciones tecnológicas y no tecnológicas que intervienen en el tratamiento de los residuos con vistas a una mejora de la eficiencia energética."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000207/2025-26/RA74> a ns1:LearningResult ;
    ns1:learningResultCode "RA74" ;
    ns1:learningResultDescription "Conocimientos de los fundamentos para implementar sistemas de eficiencia energética"@es .

