<https://guia-kg.skai.etsisi.upm.es/resource/65004016/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/65004016/2025-26/CE3>,
        <https://guia-kg.skai.etsisi.upm.es/resource/65004016/2025-26/CE7>,
        <https://guia-kg.skai.etsisi.upm.es/resource/65004016/2025-26/CG1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/65004016/2025-26/CG3>,
        <https://guia-kg.skai.etsisi.upm.es/resource/65004016/2025-26/CG6> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/65004016/2025-26/didactic_resource/1> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/65004016/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/65004016/2025-26/RA74>,
        <https://guia-kg.skai.etsisi.upm.es/resource/65004016/2025-26/RA75>,
        <https://guia-kg.skai.etsisi.upm.es/resource/65004016/2025-26/RA76>,
        <https://guia-kg.skai.etsisi.upm.es/resource/65004016/2025-26/RA77>,
        <https://guia-kg.skai.etsisi.upm.es/resource/65004016/2025-26/RA78>,
        <https://guia-kg.skai.etsisi.upm.es/resource/65004016/2025-26/RA79> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/65004016/2025-26/syllabus> ;
    ns1:inpersonHours "49 horas (41.9%)"@es ;
    ns1:numberOfCredits 4.5 ;
    ns1:otherInformation "Esta asignatura se vincula estrechamente con varios Objetivos de Desarrollo Sostenible, en particular con el ODS 9 (Industria, innovación e infraestructuras), al proporcionar herramientas fundamentales para el diseño y simulación de procesos tecnológicos sostenibles mediante métodos numéricos. Asimismo, contribuye al ODS 7 (Energía asequible y no contaminante) al abordar la modelización de la conducción de calor y otros procesos relevantes en la optimización energética. Por último, está alineada con el ODS 6 (Agua limpia y saneamiento), ya que permite simular la dinámica de contaminantes y procesos de depuración en medios acuáticos, apoyando la gestión eficiente y segura de los recursos hídricos."@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "49 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/65004016/2025-26/eventSchedule> ;
    schema:description "En esta asignatura se realizará una introducción a los modelos matemáticos de diferentes procesos, y especialmente a los modelos numéricos y su implementación en equipos informáticos. Para ello se trabajará, fundamentalmente, con el modelo que regula los procesos de transporte mediante difusión-convección con fenómenos reactivos, de sorción y fuente, resolviendo el mismo mediante esquemas en diferencias finitas (DF) y esquemas de elementos finitos isoparamétricos, centrándose la materia en modelos evolutivos planteados en dominios espaciales 1-D y en modelos estacionarios planteados en dominios espaciales 1-D y 2-D."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/virginia.yague%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/alfredo.lopez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/virginia.yague%40upm.es> ;
    schema:name "Modelizacion y Analisis Numerico"@es .

