<https://guia-kg.skai.etsisi.upm.es/resource/63000261/2025-26/evaluation> a ns1:EvaluationSystem ;
    ns1:evaluationDescription """In order to pass the course, it is compulsory to write a scientific paper. Students can be evaluated:
- Progressively: 4 partial deliveries (10 % each) + final manuscript (60 %).
- In the global and extraordinary evaluation: written exam (40 %) + final manuscript (60 %)."""@es ;
