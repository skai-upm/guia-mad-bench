    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/123000706/2025-26/eventSchedule> ;
    schema:description """La asignatura Adquisición, análisis y visualización de información geoespacial tiene como objetivo proporcionar al alumnado las competencias necesarias para el análisis de datos geoespaciales y su adecuada representación visual. Para ello, se aborda el conocimiento y manejo de repositorios de datos existentes, como los ofrecidos por las Infraestructuras de Datos Espaciales, así como la creación de bases de datos geoespaciales mediante la adaptación de datos desde sus fuentes originales. También se estudia y se trabaja en el modelado de capas de información y la aplicación de diversos tipos de análisis, especialmente los relacionados con la geoestadística aplicada a la interpolación y la implementación de modelos predictivos. Asimismo, se estudian los principios fundamentales de la visualización de información geoespacial y se trabajan conceptos clave del diseño cartográfico, con el fin de optimizar la comunicación y transferencia de los resultados obtenidos en los análisis de esta y otras asignaturas.
Consta de tres bloques temáticos:
1. Principios de diseño y de visualización de información geoespacial.
Gramática visual, técnicas cartográficas, representación de datos espaciales y creación de documentos para la transferencia de resultados
2. Adquisición de información geoespacial relacionada con la peligrosidad y riesgo sísmico.
Análisis de fuentes de información, características de la información geoespacial y formatos.
3. Análisis de datos en entorno SIG
Análisis de datos vectoriales, ráster y 3D con aplicaciones concretas en peligrosidad sísmica. Implementación de modelos predictivos. Modelización de fuentes sismogenéticas."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/teresa.iturrioz%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/alicia.rivas%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/teresa.iturrioz%40upm.es> ;
    schema:name "Adquisición, Análisis y Visualización de Datos Geoespaciales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/123000706/2025-26/C11> a ns1:Competency ;
    ns1:competencyCode "C11" ;
    ns1:competencyDescription "Gestión de la información.Capacidad de recopilar, generar, analizar, procesar, transformar, almacenar y seleccionar la información relevante para el desarrollo de las actividades de investigación o profesionales.TIPO: Competencias."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/123000706/2025-26/C3> a ns1:Competency ;
    ns1:competencyCode "C3" ;
    ns1:competencyDescription "Conocer y aplicar las TIGs (LIDAR, GNSS, imágenes satelitales y aéreas, UAVs, SIG) en el ámbito de la observación de la Tierra y aplicación en los métodos de investigación del riesgo sísmico.TIPO: Competencias."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/123000706/2025-26/C5> a ns1:Competency ;
    ns1:competencyCode "C5" ;
    ns1:competencyDescription "Diseñar y aplicar sistemas de información geográfica en el ámbito del riesgo sísmico.TIPO: Competencias."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/123000706/2025-26/C8> a ns1:Competency ;
    ns1:competencyCode "C8" ;
    ns1:competencyDescription "Liderazgo de equipos.Capacidad de influir sobre la gente para que trabaje con entusiasmo en la consecución de objetivos en pro del bien común.TIPO: Competencias."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/123000706/2025-26/K2> a ns1:Competency ;
    ns1:competencyCode "K2" ;
    ns1:competencyDescription "Definir y caracterizar las fuentes sísmicas usando los datos geológicos, geofísicos y geodésicos y de otras TIGs.TIPO:Conocimientos o contenidos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/123000706/2025-26/RA1> a ns1:LearningResult ;
    ns1:learningResultCode "RA1" ;
    ns1:learningResultDescription "Este plan está adaptado al RD 822/2021.Los resultados del aprendizaje correspondientes a esta asignatura han quedado definidos en el apartado de competencias de este documento, señalando los que corresponden a conocimientos, habilidades y competencias propiamente dichas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/123000706/2025-26/Sk2> a ns1:Competency ;
    ns1:competencyCode "Sk2" ;
    ns1:competencyDescription "Elaborar bases de datos geoespaciales específicas para aplicaciones de riesgo sísmico a partir repositorios de datos generales.TIPO: Habilidades o destrezas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/123000706/2025-26/Sk3> a ns1:Competency ;
    ns1:competencyCode "Sk3" ;
    ns1:competencyDescription "Aplicar métodos de Geoestadística, análisis espacial y aprendizaje automático a la caracterización de todas las componentes del riesgo sísmico.TIPO: Habilidades o destrezas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/123000706/2025-26/Sk5> a ns1:Competency ;
    ns1:competencyCode "Sk5" ;
    ns1:competencyDescription "Difundir los resultados de estudios e investigaciones de riesgo sísmico en un formato adecuado para su comunicación efectiva.TIPO: Habilidades o destrezas."@es .

