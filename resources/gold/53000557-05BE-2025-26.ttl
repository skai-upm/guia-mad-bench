<https://guia-kg.skai.etsisi.upm.es/resource/53000557/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/53000557/2025-26/CE01>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53000557/2025-26/CE08>,
