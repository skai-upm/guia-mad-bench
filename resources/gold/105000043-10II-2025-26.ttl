<https://guia-kg.skai.etsisi.upm.es/resource/105000043/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. ADQUISICIÓN DE DATOS"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000043/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Sensores Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000043/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "3.2. Manejo y adquisición de señales en MATLAB. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000043/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "4. SISTEMAS DISCRETOS"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000043/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "4.1. Introducción al procesado digital y sus operaciones básicas: filtrado, convolución, etc. Implementación y manejo de datos en MATLAB Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000043/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "4.2. Clasificación de sistema discretos. Sistemas lineales Invariantes. Teorema de Convolución, etc. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000043/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "4.3. Filtros FIR e IIR: parámetros básicos de un filtro. Diseño de filtros con MATLAB Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000043/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "4.4. Transformada discreta de Fourier (DFT) y algoritmo rápido de DFT (FFT). Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000043/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "5. IMPLEMENTACIÓN Y APLICACIONES (Prácticas y trabajo en Laboratorio durante el curso)"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000043/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "5.1. Presentación de diversas aplicaciones de DSP: Filtrado adaptativo, Transformada local de Fourier, Software Defined Radio, Compresión de datos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000043/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Acondicionamiento de señal Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000043/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "1.3. Conversores Digital/Analógicos (introducción al muestreo y cuantificación) Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000043/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "2. SEÑALES BÁSICAS. REPRESENTACIÓN EN FRECUENCIA. MUESTREO."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000043/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "2.1. Sinusoides: amplitud, frecuencia y fase. Uso de fasores y exponenciales complejas. Señales básicas: impulso, escalón. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000043/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "2.2. Descomposición en frecuencias de una señal: series de Fourier, transformadas de Fourier. Relación TF señal continua y discreta. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000043/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "2.3. Teorema del muestreo: frecuencia Nyquist. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000043/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "3. INTRODUCCIÓN al PROCESADO DIGITAL"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000043/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "3.1. Introducción al DSP y sus operaciones básicas: convolución, filtrado, etc. y su implementación en MATLAB. Sin subniveles"@es .

