    ns1:inpersonHours "64 horas (41%)"@es ;
    ns1:numberOfCredits 6.0 ;
    ns1:otherInformation "Las herramientas de análisis estratégico implica una consideración transversal de los ODS como condicionantes o metas de las empresas, con relación más directa con los de contenido económico como son el 8, 9, 10 y 12."@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "64 horas"@es ;
    schema:activitiesWorkload "50%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/55001017/2025-26/eventSchedule> ;
    schema:description """Esta asignatura pretende ofrecer una visión integrada del papel de las empresas dentro del entorno económico, partiendo del conocimiento de las grandes cuestiones que la sociedad se plantea respecto a su desempeño actual, presentando las teorías que buscan explicar su funcionamiento y analizando los cambios que podrían tener lugar en los próximos años.
Bloque Economía
1. Introducción al pensamiento económico
2. La unidad de consumo
3. Teoría de la producción y los costes
4. Los mercados
5. Macroeconomía
Bloque ADE
1. La empresa como organización
2. Estrategia, innovación y producción
3. Recursos humanos
4. Financiación e inversión
5. Marketing
6. Dimensión legal"""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/antonio.hidalgo%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/antonio.hidalgo%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/javier.romero%40upm.es> ;
    schema:name "La Empresa y su Entorno"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001017/2025-26/CE%2017> a ns1:Competency ;
    ns1:competencyCode "CE 17" ;
    ns1:competencyDescription "Conocimiento adecuado del concepto de empresa, marco institucional y jurídico de la empresa. Organización y gestión de empresas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001017/2025-26/CG%201> a ns1:Competency ;
    ns1:competencyCode "CG 1" ;
    ns1:competencyDescription "Conocer y aplicar los conocimientos de ciencias y tecnologías básicas a la práctica de la Ingeniería Industria"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001017/2025-26/CG%2010> a ns1:Competency ;
    ns1:competencyCode "CG 10" ;
    ns1:competencyDescription "Creatividad."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001017/2025-26/CG%203> a ns1:Competency ;
    ns1:competencyCode "CG 3" ;
    ns1:competencyDescription "Aplicar los conocimientos adquiridos para identificar, formular y resolver problemas en contextos amplios, siendo capaces de integrar los trabajando en equipos multidisciplinares"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001017/2025-26/CG%204> a ns1:Competency ;
    ns1:competencyCode "CG 4" ;
    ns1:competencyDescription "Comprender el impacto de la ingeniería en el medio ambiente, el desarrollo sostenible de la sociedad y la importancia de trabajar en un entorno profesional y responsable"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001017/2025-26/CG%205> a ns1:Competency ;
    ns1:competencyCode "CG 5" ;
    ns1:competencyDescription "Comunicar conocimientos y conclusiones, tanto de forma oral como escrita, a públicos especializados y no especializados de modo claro y sin ambigüedades"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001017/2025-26/CG%206> a ns1:Competency ;
    ns1:competencyCode "CG 6" ;
    ns1:competencyDescription "Poseer las habilidades de aprendizaje que permitan continuar estudiando a lo largo de toda la vida para un desarrollo profesional adecuado"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001017/2025-26/CG%209> a ns1:Competency ;
    ns1:competencyCode "CG 9" ;
    ns1:competencyDescription "Organización y planificación de proyectos y equipos humanos. Trabajo en equipo y capacidad de liderazgo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001017/2025-26/RA16> a ns1:LearningResult ;
    ns1:learningResultCode "RA16" ;
    ns1:learningResultDescription "Conocimientos teóricos básicos para la dirección de las organizaciones."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001017/2025-26/RA17> a ns1:LearningResult ;
