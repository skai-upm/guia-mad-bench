    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/43000574/2025-26/eventSchedule> ;
    schema:description "La asignatura de Ingeniería Hidráulica Ambiental tiene un enfoque eminentemente práctico con el objetivo de que el alumno sea capaz de manejar adecuadamente modelos hidráulicos 1D y 2D, de flujo en aguas subterráneas y de transporte de contaminantes. Las clases se desarrollarán en su mayor parte en el Aula de Informática con la utilización de los softwares HEC-RAS, IBER y Matlab. Se utilizarán Sistemas de Información Geográfica para el tratamiento de los datos y representación de resultados."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/luis.cueto%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/david.santillan%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/luis.cueto%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/luis.mediero%40upm.es> ;
    schema:name "Ingeniería Hidráulica Ambiental"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000574/2025-26/MICCPCE19> a ns1:Competency ;
    ns1:competencyCode "MICCPCE19" ;
    ns1:competencyDescription "Capacidad para abordar y resolver problemas matemáticos avanzados de ingeniería, desde el planteamiento del problema hasta el desarrollo de la formulación y su implementación en un programa de ordenador. En particular, capacidad para formular, programar y aplicar modelos analíticos y numéricos avanzados de cálculo, proyecto, planificación y gestión, así como capacidad para la interpretación de los resultados obtenidos, en el contexto de la ingeniería civil. Incorpora las competencias CB6, CB7 y CB8"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000574/2025-26/MICCPCE20> a ns1:Competency ;
    ns1:competencyCode "MICCPCE20" ;
    ns1:competencyDescription "Comprensión y dominio de las leyes de la termomecánica de los medios continuos y capacidad para su aplicación en ámbitos propios de la ingeniería como son la mecánica de fluidos, la mecánica de materiales, la teoría de estructuras, etc. Incorpora las competencias CB6, CB7 y CB8"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000574/2025-26/MICCPCE37> a ns1:Competency ;
    ns1:competencyCode "MICCPCE37" ;
    ns1:competencyDescription "Capacidad para integrar y aplicar los conocimientos técnicos en asesoría, mantenimiento, conservación, evaluación técnica, explotación, evaluación histórico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000574/2025-26/MICCPCGP01> a ns1:Competency ;
    ns1:competencyCode "MICCPCGP01" ;
    ns1:competencyDescription "Capacitación científico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000574/2025-26/MICCPCGP06> a ns1:Competency ;
    ns1:competencyCode "MICCPCGP06" ;
    ns1:competencyDescription "Conocimiento para aplicar las capacidades técnicas y gestoras en actividades de I+D+i dentro del ámbito de la ingeniería civil. Incorpora las competencias CB6, CB7 y CB8."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000574/2025-26/MICCPCGP15> a ns1:Competency ;
    ns1:competencyCode "MICCPCGP15" ;
    ns1:competencyDescription "Capacidad para evaluar y acondicionar medioambientalmente las obras de infraestructuras en proyectos, construcción, rehabilitación y conservación. Incorpora las competencias CB6, CB7 y CB8."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000574/2025-26/MICCPCT02> a ns1:Competency ;
    ns1:competencyCode "MICCPCT02" ;
    ns1:competencyDescription "Polivalencia y capacidad de aprendizaje autónomo. Desarrolla la competencia CB10."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000574/2025-26/MICCPCT08> a ns1:Competency ;
    ns1:competencyCode "MICCPCT08" ;
    ns1:competencyDescription "Capacidad de diseñar, analizar e interpretar experimentos relevantes en ingeniería civil."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000574/2025-26/RA1> a ns1:LearningResult ;
    ns1:learningResultCode "RA1" ;
    ns1:learningResultDescription "Formula y resuelve problemas matemáticos y numéricos avanzados de ingeniería civil, identificando sus diferentes componentes científicos y técnicos y seleccionando y acoplando con eficacia los métodos de resolución."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000574/2025-26/RA134> a ns1:LearningResult ;
    ns1:learningResultCode "RA134" ;
    ns1:learningResultDescription "Comprende y domina los aspectos técnicos de la hidráulica fluvial."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000574/2025-26/RA135> a ns1:LearningResult ;
    ns1:learningResultCode "RA135" ;
    ns1:learningResultDescription "Aplica los principios de la hidráulica técnica al diseño de obras fluviales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000574/2025-26/RA136> a ns1:LearningResult ;
    ns1:learningResultCode "RA136" ;
    ns1:learningResultDescription "Aplica los principios de la hidráulica técnica al estudio de los efectos medioambientales de obras de ingeniería civil."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000574/2025-26/RA138> a ns1:LearningResult ;
    ns1:learningResultCode "RA138" ;
    ns1:learningResultDescription "Desarrolla capacidad autónoma de comprensión y análisis de problemas complejos mediante métodos matemáticos y experimentales."@es .

