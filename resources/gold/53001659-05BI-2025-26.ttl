<https://guia-kg.skai.etsisi.upm.es/resource/53001659/2025-26/MUII.%20%28i%29> a ns1:Competency ;
    ns1:competencyCode "MUII. (i)" ;
    ns1:competencyDescription "SE ACTUALIZA. Reconocimiento de la necesidad y la habilidad para comprometerse al aprendizaje continuo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001659/2025-26/MUII.%20%28k%29> a ns1:Competency ;
