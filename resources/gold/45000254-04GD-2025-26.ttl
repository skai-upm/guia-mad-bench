    ns1:otherInformation "El contenido de esta asignatura se relaciona con los ODS1 (Fin de la pobreza), ODS8 (Trabajo decente y crecimiento económico), ODS9 (Industria, innovación e infraestructura), ODS10 (Reducción de las desigualdades), ODS12 (Producción y consumo responsables), ODS16 (Paz, justicia e instituciones sólidas) y ODS17 (Alizanzas para lograr los objetivos)"@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "39 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/45000254/2025-26/eventSchedule> ;
    schema:description "La asignatura pretende dar al alumno una visión amplia sobre internacionalización de la empresa y marketing internacional. Se trabajará el análisis y la selección de mercados internacionales y las estrategias de internacionalización, así como las decisiones de Marketing Mix en sus cuatro componentes: producto, precio, promoción y distribución en los mercados internacionales."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/ji.escavy%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/eugenio.sanz%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/ignacio.menendezpidal%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/ji.escavy%40upm.es> ;
    schema:name "Comercio Exterior"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000254/2025-26/30AD.%20E07> a ns1:Competency ;
    ns1:competencyCode "30AD. E07" ;
    ns1:competencyDescription "Comprender los procesos de toma de decisiones comerciales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000254/2025-26/30AD.%20E08> a ns1:Competency ;
    ns1:competencyCode "30AD. E08" ;
    ns1:competencyDescription "Elaborar la estrategia comercial de la empresa."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000254/2025-26/30AD.%20G01> a ns1:Competency ;
    ns1:competencyCode "30AD. G01" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de comprender, interpretar, sintetizar y evaluar de forma crítica información proveniente de fuentes diversas en el ámbito de la administración y dirección de empresas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000254/2025-26/30AD.%20G03> a ns1:Competency ;
    ns1:competencyCode "30AD. G03" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de comunicar conocimientos y conclusiones del ámbito de la administración y dirección de empresas, tanto de forma oral como escrita, a públicos especializados y no especializados, expresándose de manera fluida y sin ambigüedades."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000254/2025-26/30AD.%20G06> a ns1:Competency ;
    ns1:competencyCode "30AD. G06" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de trabajar en equipos multidisciplinares, aplicando los conocimientos adquiridos en el ámbito de la administración y dirección de empresas, fomentando el espíritu de equipo y la coordinación en las tareas de los diversos miembros."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000254/2025-26/30AD.%20G07> a ns1:Competency ;
    ns1:competencyCode "30AD. G07" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de trabajar en entornos diversos, comprendiendo y adaptándose a situaciones nuevas en el ámbito de la administración y dirección de empresas."@es .

