    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/53001583/2025-26/eventSchedule> ;
    schema:description """Conferencias invitadas impartidas por relevantes personalidades en el área
Asistencia aprovechada a presentaciones de TFMs y Tesis Doctorales, desarrollados en el Centro de Automática y Robótica UPM-CSIC
Cursos cortos especializados impartidos por profesores del Master: 1.- Como presentar un TFM, 2.- Viabilidad Economica y aspectos Éticos en un TFM, 3.- Drones y 4.- Robots Cuadrúpedos"""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/pascual.campoy%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/daniel.galan%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/pascual.campoy%40upm.es> ;
    schema:name "Cursos y Conferencias"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001583/2025-26/CB07> a ns1:Competency ;
    ns1:competencyCode "CB07" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en entornos nuevos o poco conocidos dentro de contextos más amplios (o multidisciplinares) relacionados con su área de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001583/2025-26/CG03> a ns1:Competency ;
    ns1:competencyCode "CG03" ;
    ns1:competencyDescription "Aplicar los conocimientos adquiridos y resolver problemas en entornos nuevos o poco conocidos dentro de contextos más amplios y multidisciplinares"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001583/2025-26/CG07> a ns1:Competency ;
    ns1:competencyCode "CG07" ;
    ns1:competencyDescription "Dirigir, planificar y supervisar equipos multidisciplinares"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001583/2025-26/CT12> a ns1:Competency ;
    ns1:competencyCode "CT12" ;
    ns1:competencyDescription "Es bilingüe. Capacidad de trabajar en un entorno bilingüe (inglés/castellano)"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001583/2025-26/RA55> a ns1:LearningResult ;
    ns1:learningResultCode "RA55" ;
    ns1:learningResultDescription "Adquisición de conocimientos específicos en el área de Automática y Robótica y otras áreas afines, tanto de carácter avanzado o de investigación, como de aplicación industrial, mediante la asistencia a eventos de organización externa a la coordinación del máster"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001583/2025-26/didactic_resource/1> a ns1:DidacticResource ;
