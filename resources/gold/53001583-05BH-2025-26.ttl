    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/53001583/2025-26/RA55> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/53001583/2025-26/syllabus> ;
    ns1:inpersonHours "20 horas (25.6%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation "Toda la información de la asignatura está disponible en la página web de la asignatura, a través de la cual también se pueden apuntar a las distintas actividades y entregar las tareas o trabajos correspondientes"@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Junio"@es ;
