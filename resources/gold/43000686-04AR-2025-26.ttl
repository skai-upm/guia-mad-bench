        <https://guia-kg.skai.etsisi.upm.es/resource/43000686/2025-26/didactic_resource/5>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000686/2025-26/didactic_resource/6>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000686/2025-26/didactic_resource/7>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000686/2025-26/didactic_resource/8>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000686/2025-26/didactic_resource/9> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/43000686/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/43000686/2025-26/RA12>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000686/2025-26/RA6> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/43000686/2025-26/syllabus> ;
    ns1:inpersonHours "55 horas y 40 minutos (47.6%)"@es ;
    ns1:numberOfCredits 4.5 ;
    ns1:otherInformation """Metodología de enseñanza para realizar el curso en línea: los videos de las lecciones teóricas y prácticas podrán estar disponibles en el sitio Moodle del curso para aquellos estudiantes que realicen el curso en línea.
El curso está relacionado con el noveno (9º) objetivo de desarrollo sostenible de las Naciones Unidas: Industrias, Innovación e Infraestructura (ODS9)."""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "57 horas y 10 minutos"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/43000686/2025-26/eventSchedule> ;
    schema:description "La asignatura se distribuye en dos capítulos descritos en el siguiente apartado. El capítulo I trata sobre los conceptos básicos de las técnicas de optimización y de la programación dinámica, así como su aplicación para resolver problemas de la ingeniería civil. El capítulo II se corresponde con la parte de Estadística de la asignatura. Esta parte proporciona las bases para analizar e interpretar datos. Incluye temas de estadística descriptiva, probabilidad, inferencia estadística, modelos de regresión y distribuciones de probabilidad. También se abordan técnicas básicas de análisis multivariante. Su enfoque es práctico y orientado a la toma de decisiones con datos."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/manuel.chazarra%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/evamaria.garcia%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/i.guisandez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/manuel.chazarra%40upm.es> ;
    schema:name "Estadística Aplicada y Optimización"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000686/2025-26/CE2> a ns1:Competency ;
    ns1:competencyCode "CE2" ;
    ns1:competencyDescription "Abordar y resolver problemas matemáticos avanzados de ingeniería, desde el planteamiento del problema hasta el desarrollo de la formulación y su implementación en un programa de ordenador. En particular, capacidad para formular, programar y aplicar modelos analíticos y numéricos avanzados de cálculo, planificación y gestión, así como capacidad para la interpretación de los resultados obtenidos, en el contexto de la ingeniería civil hidráulica, energética o medioambiental TIPO: Competencias."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000686/2025-26/K3> a ns1:Competency ;
    ns1:competencyCode "K3" ;
    ns1:competencyDescription "Conocer los aspectos científicos y tecnológicos de métodos matemáticos, analíticos y numéricos de la ingeniería, mecánica de fluidos, ingeniería marítima, y obras y Aprovechamientos hidráulicos y energéticos TIPO: Conocimientos o contenidos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000686/2025-26/RA12> a ns1:LearningResult ;
    ns1:learningResultCode "RA12" ;
    ns1:learningResultDescription "Conocer los aspectos cientificos y tecnologicos de metodos matemáticos, analiticos y numericos de la ingenieria, aprovechamientos hidraulicos y energeticos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000686/2025-26/RA6> a ns1:LearningResult ;
    ns1:learningResultCode "RA6" ;
    ns1:learningResultDescription "RA3"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000686/2025-26/SK2> a ns1:Competency ;
    ns1:competencyCode "SK2" ;
    ns1:competencyDescription "Aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en entornos nuevos o poco conocidos dentro de contextos más amplios (o multidisciplinares) relacionados con su área de estudio TIPO: Habilidades o destrezas."@es .

