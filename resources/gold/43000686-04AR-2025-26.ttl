        "Estadística Aplicada y Optimización"@es ;
    schema:numberOfCredits 4.5 .

<https://guia-kg.skai.etsisi.upm.es/resource/43000686/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/43000686/2025-26/CE2>,
