    ns1:learningResultCode "RA507" ;
    ns1:learningResultDescription "Destrezas para construir un sistema de navegación para un robot móvil."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000067/2025-26/RA508> a ns1:LearningResult ;
