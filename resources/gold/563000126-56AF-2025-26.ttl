<https://guia-kg.skai.etsisi.upm.es/resource/563000126/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. UNIDAD DIDÁCTICA 1 (Procesos avanzados de Seguridad, Legislación)"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000126/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Seguridad y salud laboral aplicado a procesos industriales y de fabricación. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000126/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "4. 4. UNIDAD DIDÁCTICA 4 (Ergonomía, Diseño equipos de trabajo, Adecuación puestos de trabajo)"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000126/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "4.1. 4.1. Conceptos básicos de ergonomía aplicada. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000126/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "4.2. 4.2. Principios de Ergonomía aplicables al puesto de trabajo. Carga dinámica y estática Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000126/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "4.3. 4.3. Carga física de trabajo. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000126/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "4.4. 4.4. Manipulación manual de cargas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000126/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "4.5. 4.5. Posturas de trabajo. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000126/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "4.6. 4.6. Trastornos musculoesqueléticos de las extremidades superiores. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000126/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "5. 5. UNIDAD DIDÁCTICA 5 (PROCESOS AVANZADOS en Seguridad en trabajos de origen mecánico)"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000126/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "5.1. 5.1. Evaluación de las condiciones de trabajo: Método ROSA , REBA , Rula y NIOSH Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000126/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "6. 6. UNIDAD DIDACTICA 6 (Investigación de Accidentes. Problemas y supuestos prácticos) Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000126/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. La seguridad en los productos, componentes y equipos. Estudio preventivo avanzado de la Normativa: Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000126/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "1.3. 1.3. Otras normativas en materia preventiva. Responsabilidades y sanciones aplicables a incumplimientos dela normativa preventiva. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000126/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "2. 2. UNIDAD DIDÁCTICA 2 (PROCESOS AVANZADOS en la Evaluación de riesgos y Planes de prevención)"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000126/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "2.1. 2.1. Metodología de evaluación de riesgos en ingeniería de producción, instalaciones y procesos, mecánicos, eléctricos, electrónicos y químicos, fases y tipos. Gestión de riesgos. Coste-beneficio. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000126/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "2.2. 2.2. Técnicas de protecciones colectivas y propuesta de Equipos de protección individual (EPI). Elaboración de Estudios de Seguridad y Salud. Planes de prevención. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000126/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "3. 3. UNIDAD DIDÁCTICA 3 (PROCESOS AVANZADOS de Seguridad en trabajos de origen eléctrico y electrónico, químico y diseño industrial)"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000126/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "3.1. 3.1. Utilización de Equipos de Trabajo. Protección de máquinas. Prevención de riesgos en equipos de trabajo. Grados de protección, elementos de peligro. R.D. 1215/1997 y R.D. 1644/2008. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000126/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "3.2. 3.2. Riesgo Eléctrico. Instrucciones y habilitación del personal para realizar trabajos en instalaciones eléctricas. Trabajador Autorizado y Cualificado. R.D. 614/2001 Sin subniveles"@es .

