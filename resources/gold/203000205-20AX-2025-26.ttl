<https://guia-kg.skai.etsisi.upm.es/resource/203000205> a ns1:Course ;
    ns1:courseType "Obligatoria"@es ;
    ns1:courseYear 2 ;
    ns1:semester "Cuarto semestre"@es ;
    schema:courseCode 203000205 ;
    schema:hasCourseInstance <https://guia-kg.skai.etsisi.upm.es/resource/203000205/2025-26> ;
    schema:name "Precision Agriculture Applied To Arable Crops"@en,
        "Agricultura de Precisión Aplicada a Cultivos Herbáceos"@es ;
    schema:numberOfCredits 4.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/203000205/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/203000205/2025-26/C3_20AP>,
        <https://guia-kg.skai.etsisi.upm.es/resource/203000205/2025-26/C4_20AP>,
        <https://guia-kg.skai.etsisi.upm.es/resource/203000205/2025-26/CEH2_20AP>,
        <https://guia-kg.skai.etsisi.upm.es/resource/203000205/2025-26/CEH6_20AP>,
        <https://guia-kg.skai.etsisi.upm.es/resource/203000205/2025-26/CT7_20AP>,
        <https://guia-kg.skai.etsisi.upm.es/resource/203000205/2025-26/K8_20AP>,
        <https://guia-kg.skai.etsisi.upm.es/resource/203000205/2025-26/S3_20AP> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/203000205/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/203000205/2025-26/didactic_resource/2> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/203000205/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/203000205/2025-26/RA79> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/203000205/2025-26/syllabus> ;
    ns1:inpersonHours "48 horas (46.2%)"@es ;
    ns1:numberOfCredits 4.0 ;
    ns1:otherInformation """En esta asignatura se realizarán prácticas de campo de forma que los estudiantes compaginen su aprendizaje del uso de sensores espectrales y de medida del estado hídrico del cultivo con las sesiones de teoría. Los alumnos habrán de dotarse de los medios mínimos para trabajar con seguridad durante las prácticas realizadas en el campo (calzado adecuado y protección solar). Aquellos alumnos que no se presenten con los medios requeridos no podrán realizar las prácticas asumiendo las consecuencias que ello pudiera acarrear en términos de evaluación de la asignatura.
Esta asignatura contribuye a la formación de los estudiantes en los ODS, principalmente en los ODS2 (Hambre cero) y ODS6 (Agua limpia y saneamiento)."""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "49 horas y 30 minutos"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/203000205/2025-26/eventSchedule> ;
    schema:description """La gestión de los sistemas de cultivo y la aplicación de la agricultura de precisión a los cultivos herbáceos se enmarca dentro de la intensificación sostenible en los sistemas agrarios. Las tecnologías son imprescindibles para mejorar la eficiencia en el uso de recursos y, en el contexto del Pacto Verde (Green Deal) de la Unión Europea, permitir una reducción en los insumos sin disminuir los rendimientos.
Las tecnologías y herramientas que se abordan en esta asignatura están en la base de la gestión responsable de cultivos: modelos de simulación de cultivos, monitorización de praderas y cultivos forrajeros, programas para la gestión de nutrientes, la teledetección y uso sensores de campo (planta, suelo y agua)."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/miguel.quemada%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/carlosgregorio.hernandez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/miguel.quemada%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/pl.aguado%40upm.es> ;
    schema:name "Agricultura de Precisión Aplicada a Cultivos Herbáceos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000205/2025-26/C3_20AP> a ns1:Competency ;
    ns1:competencyCode "C3_20AP" ;
    ns1:competencyDescription "Diseñar los medios y las metodologías necesarias para la modelización, análisis y gestión optimizada de sistemas agrarios, y aplicar la información obtenida en la toma de decisiones de la producción con criterios ingenieriles, económicos y de sostenibilidad medioambiental."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000205/2025-26/C4_20AP> a ns1:Competency ;
    ns1:competencyCode "C4_20AP" ;
    ns1:competencyDescription "Saber integrar la información espacial y temática (suelo, cultivo) con rigor, prestando especial atención a los conceptos de precisión y calidad de los datos geográficos, en una base de datos geoespaciales (creación y consultas) para su aplicación en un entorno profesional"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000205/2025-26/CEH2_20AP> a ns1:Competency ;
    ns1:competencyCode "CEH2_20AP" ;
    ns1:competencyDescription "Poseer conocimiento avanzado y ser capaz de desarrollar tecnología en gestión de equipos e instalaciones que se integren en los procesos y sistemas de producción agroalimentaria."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000205/2025-26/CEH6_20AP> a ns1:Competency ;
    ns1:competencyCode "CEH6_20AP" ;
    ns1:competencyDescription "Poseer conocimiento avanzado y ser capaz de desarrollar tecnología en sistemas de producción vegetal y en sistemas integrados de protección de cultivos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000205/2025-26/CT7_20AP> a ns1:Competency ;
    ns1:competencyCode "CT7_20AP" ;
    ns1:competencyDescription "Creatividad: capacidad de diseñar un sistema, componente, proceso o experimento y de resolver de manera original situaciones o problemas en el ámbito científico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000205/2025-26/K8_20AP> a ns1:Competency ;
    ns1:competencyCode "K8_20AP" ;
    ns1:competencyDescription "Poseer conocimientos avanzados que permitan identificar soluciones a problemas reales relacionados con la implantación y manejo de sistemas de producción agraria utilizando herramientas de la agricultura de precisión."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000205/2025-26/RA79> a ns1:LearningResult ;
    ns1:learningResultCode "RA79" ;
    ns1:learningResultDescription "Los resultados del aprendizaje correspondientes a esta asignatura han quedado definidos en el apartado de competencias de este documento, señalando los que corresponden a conocimientos, habilidades y competencias propiamente dichas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000205/2025-26/S3_20AP> a ns1:Competency ;
    ns1:competencyCode "S3_20AP" ;
    ns1:competencyDescription "Evaluar el funcionamiento de sensores como los de humedad del suelo y otros,su calibración y posterior instalación en distintos sistemas de riego y monitorización de la parcela interpretando conjuntamente datos de suelo, planta y atmósfera."@es .

