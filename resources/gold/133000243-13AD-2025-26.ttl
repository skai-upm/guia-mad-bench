        "Gestion del Conocimiento: Instrumentos para la Toma de Decisiones"@es ;
    schema:numberOfCredits 3.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/133000243/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/133000243/2025-26/CE%203.2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000243/2025-26/CE%203.4>,
