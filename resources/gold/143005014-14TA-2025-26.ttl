<https://guia-kg.skai.etsisi.upm.es/resource/143005014/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. FUNDAMENTOS DE LUMINOTECNIA"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005014/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Características de la luz. Visión y color. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005014/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "3.1. Iluminación de exteriores (Iluminación con proyectores de plataformas de estacionamiento de aeronaves). Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005014/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "3.2. Iluminación de interiores (Iluminación ordinaria y de emergencia del interior de una terminal aeroportuaria). Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005014/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "4. SISTEMAS DE DISTRIBUCIÓN DE ENERGÍA ELÉCTRICA EN AEROPUERTOS Y AYUDAS VISUALES PARA LA NAVEGACIÓN AÉREA"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005014/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "4.1. Sistemas de generación de energía eléctrica en aeropuertos (Generador síncrono, sistemas de alimentación ininterrumpidos y placas fotovoltaicas). Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005014/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "4.2. Distribución de energía eléctrica en aeropuertos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005014/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "4.3. Sistemas de ayudas visuales en aeropuertos. Luces aeronáuticas de superficie. Circuito serie. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005014/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "5. SISTEMAS DE DISTRIBUCIÓN DE ENERGÍA ELÉCTRICA EN AERONAVES E ILUMINACIÓN EN VEHÍCULOS AEROESPACIALES"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005014/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "5.1. Sistemas de generación de energía eléctrica en aeronaves. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005014/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "5.2. Distribución de energía eléctrica en aeronaves. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005014/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "5.3. Sistemas de ayudas visuales en aeropuertos y técnicas y requisitos de iluminación en el interior de aeronaves. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005014/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Magnitudes y unidades luminosas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005014/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "1.3. Leyes de la luminotecnia. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005014/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "1.4. Diagramas fotométricos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005014/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "2. ELEMENTOS DE LOS SISTEMAS DE ILUMINACIÓN"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005014/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "2.1. Sistemas de alumbrado. Procesos productores de luz. Características de las fuentes de luz. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005014/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "2.2. Lámparas eléctricas. Lámparas de incandescencia. Lámparas de descarga. Diodos emisores de luz. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005014/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "2.3. Luminarias y equipos auxiliares. Instalaciones de alumbrado Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005014/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "3. DISEÑO DE INSTALACIONES DE ILUMINACIÓN: Realización de proyectos de iluminación"@es .

