    ns1:inpersonHours "56 horas y 30 minutos (36.2%)"@es ;
    ns1:numberOfCredits 6.0 ;
    ns1:otherInformation "El contenido de la asignatura se relaciona con los ODS 1, 4, 8, 9, 10 y 12"@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "56 horas y 30 minutos"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/545000113/2025-26/eventSchedule> ;
    schema:description """Esta asignatura tiene como objetivo fundamental profundizar en el aprendizaje del análisis microeconómico, dominar sus modelos básicos y ejercitarse en el análisis e interpretación de los fenómenos económicos usando modelos sencillos y la teoría básica microeconómica.
En concreto, la asignatura aborda aspectos fundamentales de la teoría microeconómica (el equilibrio del mercado, el problema del consumidor individual, el problema del productor, eficiencia y externalidades, análisis de políticas económicas, competencia perfecta y otras estructuras de competencia imperfecta en el mercado) y adopta un enfoque práctico, destacando la importancia y aplicación de la teoría microeconómica tanto en las decisiones empresariales como en las decisiones de política económica."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/eva.iglesias%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/eva.iglesias%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/juanramon.ferrer%40upm.es> ;
    schema:name "Microeconomia"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000113/2025-26/CB01> a ns1:Competency ;
    ns1:competencyCode "CB01" ;
    ns1:competencyDescription "Que los estudiantes hayan demostrado poseer y comprender conocimientos en un área de estudio que parte de la base de la educación secundaria general, y se suele encontrar a un nivel que, si bien se apoya en libros de texto avanzados, incluye también algunos aspectos que implican conocimientos procedentes de la vanguardia de su campo de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000113/2025-26/CB02> a ns1:Competency ;
    ns1:competencyCode "CB02" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar sus conocimientos a su trabajo o vocación de una forma profesional y posean las competencias que suelen demostrarse por medio de la elaboración y defensa de argumentos y la resolución de problemas dentro de su área de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000113/2025-26/CB03> a ns1:Competency ;
    ns1:competencyCode "CB03" ;
    ns1:competencyDescription "Que los estudiantes tengan la capacidad de reunir e interpretar datos relevantes (normalmente dentro de su área de estudio) para emitir juicios que incluyan una reflexión sobre temas relevantes de índole social, científica o ética"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000113/2025-26/CB04> a ns1:Competency ;
    ns1:competencyCode "CB04" ;
    ns1:competencyDescription "Que los estudiantes puedan transmitir información, ideas, problemas y soluciones a un público tanto especializado como no especializado"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000113/2025-26/CB05> a ns1:Competency ;
    ns1:competencyCode "CB05" ;
    ns1:competencyDescription "Que los estudiantes hayan desarrollado aquellas habilidades de aprendizaje necesarias para emprender estudios posteriores con un alto grado de autonomía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000113/2025-26/CE57> a ns1:Competency ;
    ns1:competencyCode "CE57" ;
    ns1:competencyDescription "Conocer las principales teorías sobre el comportamiento de la economía tanto a nivel individual como agregado."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000113/2025-26/CG14> a ns1:Competency ;
    ns1:competencyCode "CG14" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de comprender, interpretar, sintetizar y evaluar de forma crítica información proveniente de fuentes diversas en el ámbito de la administración y dirección de empresas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000113/2025-26/CG16> a ns1:Competency ;
    ns1:competencyCode "CG16" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de comunicar conocimientos y conclusiones del ámbito de la administración y dirección de empresas, tanto de forma oral como escrita, a públicos especializados y no especializados, expresándose de manera fluida y sin ambigüedades."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000113/2025-26/CG18> a ns1:Competency ;
    ns1:competencyCode "CG18" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de aportar soluciones creativas en la resolución de problemas en el ámbito de la administración y dirección de empresas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000113/2025-26/CG22> a ns1:Competency ;
    ns1:competencyCode "CG22" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de trabajar en el ámbito de la administración y dirección de empresas aplicando criterios de calidad y sostenibilidad."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000113/2025-26/RA92> a ns1:LearningResult ;
    ns1:learningResultCode "RA92" ;
    ns1:learningResultDescription "Conocer las principales teorías y enfoques de análisis económico para ser capaz de explicar el comportamiento de los agentes económicos a nivel microeconómico, así como las imperfecciones que pueden surgir en distintos sectores como consecuencia del proceso económico."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000113/2025-26/RA93> a ns1:LearningResult ;
    ns1:learningResultCode "RA93" ;
    ns1:learningResultDescription "Escuchar, negociar, persuadir y defender argumentos oralmente o por escrito."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000113/2025-26/RA94> a ns1:LearningResult ;
    ns1:learningResultCode "RA94" ;
    ns1:learningResultDescription "Trabajar de forma autónoma y con iniciativa personal."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000113/2025-26/RA95> a ns1:LearningResult ;
    ns1:learningResultCode "RA95" ;
    ns1:learningResultDescription "Buscar información, su análisis, interpretación, síntesis y transmisión."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000113/2025-26/RA96> a ns1:LearningResult ;
    ns1:learningResultCode "RA96" ;
    ns1:learningResultDescription "Resolver problemas de forma creativa e innovadora."@es .

