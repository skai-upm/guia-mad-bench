    schema:name "Virología"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504324/2025-26/CB03> a ns1:Competency ;
    ns1:competencyCode "CB03" ;
    ns1:competencyDescription "Que los estudiantes tengan la capacidad de reunir e interpretar datos relevantes (normalmente dentro de su área de estudio) para emitir juicios que incluyan una reflexión sobre temas relevantes de índole social, científica o ética"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504324/2025-26/CB04> a ns1:Competency ;
    ns1:competencyCode "CB04" ;
    ns1:competencyDescription "Que los estudiantes puedan transmitir información, ideas, problemas y soluciones a un público tanto especializado como no especializado"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504324/2025-26/CE26> a ns1:Competency ;
    ns1:competencyCode "CE26" ;
    ns1:competencyDescription "Conocimientos básicos sobre la diversidad de los virus bacterianos, de animales, y plantas así como sus interacciones con el huésped, los parámetros para el control y cuantificación de su crecimiento y de sus aplicaciones."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504324/2025-26/CG01> a ns1:Competency ;
    ns1:competencyCode "CG01" ;
    ns1:competencyDescription "Ser capaz de evaluar y discernir los diferentes mecanismos moleculares y celulares responsables de las transformaciones que llevan a cabo los seres vivos, así como poder desarrollar soluciones alternativas y novedosas frente a problemas biológicos conocidos y/o emergentes."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504324/2025-26/CG02> a ns1:Competency ;
    ns1:competencyCode "CG02" ;
    ns1:competencyDescription "Familiarizarse con el trabajo en el laboratorio, la instrumentación y los métodos experimentales. Además, ser capaz de realizar experimentos y/o diseñar aplicaciones de forma independiente y describir, cuantificar, analizar y evaluar críticamente los resultados obtenidos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504324/2025-26/RA210> a ns1:LearningResult ;
    ns1:learningResultCode "RA210" ;
    ns1:learningResultDescription "Distinguir los elementos estructurales y la composición de los virus, viroides y priones"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504324/2025-26/RA211> a ns1:LearningResult ;
    ns1:learningResultCode "RA211" ;
    ns1:learningResultDescription "Comprender la necesidad de los virus de ser patógenos intracelulares y describir las fases de la invasión celular y replicación de las partículas virales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504324/2025-26/RA212> a ns1:LearningResult ;
    ns1:learningResultCode "RA212" ;
    ns1:learningResultDescription "Conocer las técnicas básicas de que se dispone para el estudio de los virus"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504324/2025-26/RA213> a ns1:LearningResult ;
    ns1:learningResultCode "RA213" ;
    ns1:learningResultDescription "Conocer las características morfológicas, estructurales y de composición de los viriones de las familias más importantes de virus"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504324/2025-26/RA214> a ns1:LearningResult ;
    ns1:learningResultCode "RA214" ;
    ns1:learningResultDescription "Relacionar el modelo de replicación viral y células diana de cada una de ellas con la patogenia de la enfermedad y las posibilidades diagnósticas, terapéuticas y profilaxis"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504324/2025-26/RA215> a ns1:LearningResult ;
    ns1:learningResultCode "RA215" ;
    ns1:learningResultDescription "Conocer la capacidad de variar y evolucionar de las poblaciones de virus y los métodos para su análisis"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504324/2025-26/RA216> a ns1:LearningResult ;
    ns1:learningResultCode "RA216" ;
    ns1:learningResultDescription "Entender las implicaciones de la variabilidad de las poblaciones de virus en el diagnóstico y control de las enfermedades que producen"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504324/2025-26/RA217> a ns1:LearningResult ;
    ns1:learningResultCode "RA217" ;
    ns1:learningResultDescription "Conocer las enfermedades más importantes producidas por virs"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504324/2025-26/RA218> a ns1:LearningResult ;
