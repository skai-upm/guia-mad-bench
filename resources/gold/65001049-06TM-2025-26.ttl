    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/65001049/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/65001049/2025-26/RA247>,
        <https://guia-kg.skai.etsisi.upm.es/resource/65001049/2025-26/RA248>,
        <https://guia-kg.skai.etsisi.upm.es/resource/65001049/2025-26/RA249> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/65001049/2025-26/syllabus> ;
    ns1:inpersonHours "32 horas (41%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation """El profesor solo puede atender a un maximo de 10 alumnos en el laboratorio.
La asignatura se imparte de forma INTENSIVA según el calendario escolar. Las clases de teoria son presenciales, pero pueden seguirse de forma simultanea por internet, siempre que la jefatura de estudios de la titulación asi lo comunique.
Las practicas de laboratorio son OBLIGATORIAS, siendo su calificación mediante el correspondiente informe, de APTO/NO APTO. Es necesario tener la calificación de APTO para SUPERAR la asignatura tanto por evaluación progresiva como por examen final.
La asignatura se relaciona con el ODS 12: Producción y consumo sostenibles. Se APLICARAN CRITERIOS DE RECICABILIDAD Y SOSTENIBILIDAD en la SELECCION DE MATERIALES"""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "32 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/65001049/2025-26/eventSchedule> ;
    schema:description "Los materiales cerámicos, plásticos y compuestos completan el campo de los materiales, de los que los metales y aleaciones, los materiales refractarios y los materiales de construcción son abordados en otras asignaturas. La descripción de estos tres tipos de materiales: cerámicos, plásticos y compuestos se aborda desde el punto de vista de su aplicación, junto con un amplio programa de practicas de laboratorio para conocer su fabricación y su caracterización. Dada la estructura del plan de estudios la asignatura se realiza de forma intensiva durante el mes de Febrero."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/luis.gcambronero%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/luis.gcambronero%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/miguel.sanchez%40upm.es> ;
    schema:name "Materiales Ceramicos, Plasticos y Compuestos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001049/2025-26/CG%201> a ns1:Competency ;
    ns1:competencyCode "CG 1" ;
    ns1:competencyDescription "Conocer y aplicar conocimientos de ciencias y tecnologías básicas a la práctica de la Tecnología Minera."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001049/2025-26/CG%202> a ns1:Competency ;
    ns1:competencyCode "CG 2" ;
    ns1:competencyDescription "Poseer capacidad para diseñar, analizar, calcular, proyectar, construir, mantener, conservar, explotar, desarrollar, implementar, gestionar y mejorar productos, sistemas y procesos en los distintos ámbitos de las Tecnologías Mineras, usando técnicas analíticas, computacionales o experimentales apropiadas, incluyendo la función de asesoría en estos campos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001049/2025-26/CG%203> a ns1:Competency ;
    ns1:competencyCode "CG 3" ;
    ns1:competencyDescription "Aplicar los conocimientos adquiridos para identificar, formular y resolver problemas dentro de contextos amplios y multidisciplinarios, siendo capaces de integrar conocimientos, trabajando en equipos multidisciplinares."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001049/2025-26/CG%205> a ns1:Competency ;
    ns1:competencyCode "CG 5" ;
    ns1:competencyDescription "Saber comunicar los conocimientos y conclusiones, tanto de forma oral, escrita y gráfica, a públicos especializados y no especializados de un modo claro y sin ambigüedades."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001049/2025-26/CG%206> a ns1:Competency ;
    ns1:competencyCode "CG 6" ;
    ns1:competencyDescription "Poseer habilidades de aprendizaje que permitan continuar estudiando a lo largo de la vida para su adecuado desarrollo profesional"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001049/2025-26/CG%207> a ns1:Competency ;
    ns1:competencyCode "CG 7" ;
    ns1:competencyDescription "Incorporar nuevas tecnologías y herramientas de la ingeniería en tecnología minera en sus actividades profesionales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001049/2025-26/F11> a ns1:Competency ;
    ns1:competencyCode "F11" ;
    ns1:competencyDescription "Capacidad para conocer, comprender y utilizar los principios y tecnología de materiales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001049/2025-26/F36> a ns1:Competency ;
    ns1:competencyCode "F36" ;
    ns1:competencyDescription "Ingeniería de los materiales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001049/2025-26/F40> a ns1:Competency ;
    ns1:competencyCode "F40" ;
    ns1:competencyDescription "Ensayos y control de calidad de materiales metálicos y no metálicos, materiales cerámicos y plásticos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001049/2025-26/RA247> a ns1:LearningResult ;
    ns1:learningResultCode "RA247" ;
    ns1:learningResultDescription "Conocer las distintas familias de materiales no metálicos, sus propiedades y obtención Aplicar los fundamentos del análisis de secciones en vigas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001049/2025-26/RA248> a ns1:LearningResult ;
    ns1:learningResultCode "RA248" ;
    ns1:learningResultDescription "Relacionar las características de los diferentes tipos de materiales no metálicos con sus propiedades y método de obtención."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001049/2025-26/RA249> a ns1:LearningResult ;
    ns1:learningResultCode "RA249" ;
    ns1:learningResultDescription "Aplicar los diferentes materiales no metálicos a sus distintos usos."@es .

