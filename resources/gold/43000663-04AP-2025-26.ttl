        <https://guia-kg.skai.etsisi.upm.es/resource/joaquin.sanzdeojed%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/manueljesus.bueno%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/mariateresa.mateos%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/roberto.gil%40upm.es> ;
    schema:name "Riesgos en Ingeniería del Terreno"@es .

