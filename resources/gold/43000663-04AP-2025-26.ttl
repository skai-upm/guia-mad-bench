<https://guia-kg.skai.etsisi.upm.es/resource/43000663/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Tema 1. Introducción a los Riesgos Geológicos. Fundamentos y métodos Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000663/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "2. Tema 2. Riesgos geológicos. Prevención. Peligrosidad. Vulnerabilidad. Mitigación. Mapa de riesgos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000663/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "3. Tema 6. Riesgo sísmico. Sismicidad. Sismología. Fallas y terremotos. Ingeniería geológica y riesgo sísmico. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000663/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "4. Tema 3. Riesgos geológicos por deslizamientos y otros movimientos del terreno. Introducción movimientos de ladera. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000663/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "5. Tema 4. Riesgo kárstico. Riesgos geológicos relacionados con hundimientos y subsidencias. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000663/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "6. Tema 5. Riesgo de terrenos singulares: antrópicos, expansivos, etc Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000663/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "7. Tema 7. Riesgo volcánico. Sin subniveles"@es .

