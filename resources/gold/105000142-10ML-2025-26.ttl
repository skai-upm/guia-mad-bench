<https://guia-kg.skai.etsisi.upm.es/resource/105000142/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Una introducción a los espacios normados infinito dimensionales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000142/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Principales diferencias con los espacios finito dimensionales. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000142/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "3.2. Representación matricial en bases ortonormales en espacios de Hilbert,. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000142/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "3.3. Distintos tipos de operadores en espacios de HIlbert: unitarios, autadjuntos, normales, compactos Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000142/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "4. Teoría espectral de operadores en espacios de Hilbert."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000142/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "4.1. Diagonalización en el contexto infinito dimensional Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000142/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "4.2. Espectro de operadores en espacios de Hilbert. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000142/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "5. Algunas aplicaciones"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000142/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "5.1. Teoría de Momentos. Análisis de imágenes y reconocimiento de patrones. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000142/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "5.2. Aplicaciones al análisis de datos funcionales. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000142/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "5.3. Aplicaciones del análisis funcional en la mecánica cuántica. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000142/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Ejemplos básicos: espacios de funciones y espacios de sucesiones. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000142/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "2. Espacios de HIlbert."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000142/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "2.1. Espacios prehilbertianos. Producto interior y ortogonalidad Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000142/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "2.2. Mejor aproximación. Teorema de la proyección. Proceso de ortogonalización de Gram-Schmidt Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000142/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "2.3. Bases ortonormales en espacios de Hilbert . Aplicación a las series de Fourier Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000142/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "2.4. Polinomios ortogonales. Estudio de wavelets Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000142/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "3. Teoría de operadores en espacios de Hilbert."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000142/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "3.1. Aplicaciones lineales y continuas. Introducción a las matrices infinitas. Sin subniveles"@es .

