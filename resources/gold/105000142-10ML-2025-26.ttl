    ns1:inpersonHours "65 horas (41.7%)"@es ;
    ns1:numberOfCredits 6.0 ;
    ns1:otherInformation "ESTA GUIA DE APRENDIZAJE ES LA MISMA QUE LA DE LA TITULACIÓN MI"@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
