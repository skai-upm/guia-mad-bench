    schema:name "Control And Robotics In Medicine"@en,
        "Control y Robótica en Medicina"@es ;
    schema:numberOfCredits 3.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/93000972/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/93000972/2025-26/CB06>,
        <https://guia-kg.skai.etsisi.upm.es/resource/93000972/2025-26/CB07>,
