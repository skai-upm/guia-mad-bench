<https://guia-kg.skai.etsisi.upm.es/resource/93000972/2025-26/RA25> a ns1:LearningResult ;
    ns1:learningResultCode "RA25" ;
    ns1:learningResultDescription "Conocimiento de la teoría de la realimentación y los sistemas electrónicos de control."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000972/2025-26/RA26> a ns1:LearningResult ;
    ns1:learningResultCode "RA26" ;
    ns1:learningResultDescription "Capacidad de analizar y modelar sistemas robóticos: cinemática y dinámica. Fundamentos de biomecánica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000972/2025-26/RA27> a ns1:LearningResult ;
    ns1:learningResultCode "RA27" ;
    ns1:learningResultDescription "Capacidad de diseñar e implementar controladores para la resolución de problemas con sistemas robóticos en el área de ingeniería biomédica."@es .

