        <https://guia-kg.skai.etsisi.upm.es/resource/93000972/2025-26/CE>,
        <https://guia-kg.skai.etsisi.upm.es/resource/93000972/2025-26/CG> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/93000972/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/93000972/2025-26/didactic_resource/2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/93000972/2025-26/didactic_resource/3>,
        <https://guia-kg.skai.etsisi.upm.es/resource/93000972/2025-26/didactic_resource/4> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/93000972/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/93000972/2025-26/RA25>,
        <https://guia-kg.skai.etsisi.upm.es/resource/93000972/2025-26/RA26>,
        <https://guia-kg.skai.etsisi.upm.es/resource/93000972/2025-26/RA27> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/93000972/2025-26/syllabus> ;
    ns1:inpersonHours "31 horas (39.7%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation """This course is related to several of the Sustainable Development Goals defined by the United Nations, specifically:
- SDG3: Good Health and Well-Being
- SDG4: Quality Education
- SDG9: Industry, Innovation and Infraestructure"""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "31 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/93000972/2025-26/eventSchedule> ;
    schema:description """The course is divided in two fundamental parts.
The first part provides students with the concepts of kinematics and dynamics of robots. Later on, it focuses on the planning and generation of trajectories of robot manipulators of 6 Degrees of Freedom.
The second part focuses on the fundamental principles of force feedback, with special emphasis on haptic systems and its use in bioengineering."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/blanca.larraga%40upm.es> ;
    schema:inLanguage "Inglés/Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/a.gutierrez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/blanca.larraga%40upm.es> ;
    schema:name "Control y Robótica en Medicina"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000972/2025-26/CB06> a ns1:Competency ;
    ns1:competencyCode "CB06" ;
    ns1:competencyDescription "Poseer y comprender conocimientos que aporten una base u oportunidad de ser originales en el desarrollo y/o aplicación de ideas, a menudo en un contexto de investigación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000972/2025-26/CB07> a ns1:Competency ;
    ns1:competencyCode "CB07" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en entornos nuevos o poco conocidos dentro de contextos más amplios (o multidisciplinares) relacionados con su área de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000972/2025-26/CB08> a ns1:Competency ;
    ns1:competencyCode "CB08" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de integrar conocimientos y enfrentarse a la complejidad de formular juicios a partir de una información que, siendo incompleta o limitada, incluya reflexiones sobre las responsabilidades sociales y éticas vinculadas a la aplicación de sus conocimientos y juicios"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000972/2025-26/CB09> a ns1:Competency ;
    ns1:competencyCode "CB09" ;
    ns1:competencyDescription "Que los estudiantes sepan comunicar sus conclusiones y los conocimientos y razones últimas que las sustentan a públicos especializados y no especializados de un modo claro y sin ambigüedades"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000972/2025-26/CB10> a ns1:Competency ;
    ns1:competencyCode "CB10" ;
    ns1:competencyDescription "Que los estudiantes posean las habilidades de aprendizaje que les permitan continuar estudiando de un modo que habrá de ser en gran medida autodirigido o autónomo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000972/2025-26/CE> a ns1:Competency ;
    ns1:competencyCode "CE" ;
    ns1:competencyDescription "MIB01"@es,
        "MIB12"@es .

