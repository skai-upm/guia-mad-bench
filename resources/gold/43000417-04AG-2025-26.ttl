    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/43000417/2025-26/eventSchedule> ;
    schema:description "La dirección de proyectos es la aplicación de conocimientos, habilidades, herramientas y técnicas a las actividades del proyecto para cumplir con los requisitos del mismo. En esta asignatura se imparten las nociones básicas para la gestión de proyectos de cualquier tipología, haciendo especial hincapié en proyectos de construcción de Ingeniería Civil. A su vez, se proporcionan nociones y casos prácticos enfocados a la gestión de activos del proyecto, gestión de recursos humanos, gestión de costes, gestión de tiempos e incluso introducción a la realización de modelos de negocio."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/marcos.garcia%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/antonio.garciad%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/gonzalo.fsanchez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/i.delapena%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/marcos.garcia%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/noelia.ruano.paniagua%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/ruben.mpavon%40upm.es> ;
    schema:name "Direccion y Gestion Integrada de Proyectos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000417/2025-26/CE1> a ns1:Competency ;
    ns1:competencyCode "CE1" ;
    ns1:competencyDescription "Capacitación científico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000417/2025-26/CE12> a ns1:Competency ;
    ns1:competencyCode "CE12" ;
    ns1:competencyDescription "Capacidad para planificar, diseñar y gestionar infraestructuras, así como su mantenimiento, conservación y explotación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000417/2025-26/CE15> a ns1:Competency ;
    ns1:competencyCode "CE15" ;
    ns1:competencyDescription "Capacidad para evaluar y acondicionar medioambientalmente las obras de infraestructuras en proyectos, construcción, rehabilitación y conservación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000417/2025-26/CE17> a ns1:Competency ;
    ns1:competencyCode "CE17" ;
    ns1:competencyDescription "Capacidad de aplicación de técnicas de gestión empresarial y legislación laboral."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000417/2025-26/CE2> a ns1:Competency ;
    ns1:competencyCode "CE2" ;
    ns1:competencyDescription "Comprensión de los múltiples condicionamientos de carácter técnico, legal y de la propiedad que se plantean en el proyecto de una obra pública, y capacidad para establecer diferentes alternativas válidas, elegir la óptima y plasmarla adecuadamente, previendo los problemas de su construcción, y empleando los métodos y tecnologías más adecuadas, tanto tradicionales como innovadores, con la finalidad de conseguir la mayor eficacia y favorecer el progreso y un desarrollo de la sociedad sostenible y respetuoso con el medio ambiente."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000417/2025-26/CE29> a ns1:Competency ;
    ns1:competencyCode "CE29" ;
    ns1:competencyDescription "Capacidad para analizar y diagnosticar los condicionantes sociales, culturales, ambientales y económicos de un territorio, así como para realizar proyectos de ordenación territorial y planeamiento urbanístico desde la perspectiva de un desarrollo sostenible."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000417/2025-26/CE3> a ns1:Competency ;
    ns1:competencyCode "CE3" ;
    ns1:competencyDescription "Conocimiento, comprensión y capacidad para aplicar la legislación necesaria en el ejercicio de la profesión de Ingeniero de Caminos, Canales y Puertos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000417/2025-26/CE30> a ns1:Competency ;
    ns1:competencyCode "CE30" ;
    ns1:competencyDescription "Capacidad de planificación, gestión y explotación de infraestructuras relacionadas con la ingeniería civil."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000417/2025-26/CE32> a ns1:Competency ;
    ns1:competencyCode "CE32" ;
    ns1:competencyDescription "Capacidad para aplicar los conocimientos técnicos en la evaluación de proyectos, obras e infraestructuras dentro del ámbito de la ingeniería civil."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000417/2025-26/CE6> a ns1:Competency ;
    ns1:competencyCode "CE6" ;
    ns1:competencyDescription "Conocimiento para aplicar las capacidades técnicas y gestoras en actividades de I+D+i dentro del ámbito de la ingeniería civil."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000417/2025-26/CE7> a ns1:Competency ;
    ns1:competencyCode "CE7" ;
    ns1:competencyDescription "Capacidad para planificar, proyectar, inspeccionar y dirigir obras de infraestructuras de transportes terrestres (carreteras, ferrocarriles, puentes, túneles y vías urbanas) o marítimos (obras e instalaciones portuarias)."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000417/2025-26/CT2> a ns1:Competency ;
    ns1:competencyCode "CT2" ;
    ns1:competencyDescription "Polivalencia y capacidad de aprendizaje autónomo. Desarrolla la competencia transversal 5ª del Real Decreto."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000417/2025-26/CT4> a ns1:Competency ;
    ns1:competencyCode "CT4" ;
    ns1:competencyDescription "Capacidad de organizar y dirigir los esfuerzos de un equipo. Desarrolla la competencia transversal 5ª de la normativa UPM."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000417/2025-26/CT5> a ns1:Competency ;
    ns1:competencyCode "CT5" ;
    ns1:competencyDescription "Capacidad de ejercer las funciones profesionales de proyecto, cálculo, evaluación técnica, planificación y gestión técnica mediante el uso de normativa europea e internacional. Desarrolla la competencia transversal 7ª de la normativa UPM."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000417/2025-26/CT6> a ns1:Competency ;
    ns1:competencyCode "CT6" ;
    ns1:competencyDescription "Compromiso y capacidad de aplicación de los estándares de deontología profesional."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000417/2025-26/RA180> a ns1:LearningResult ;
    ns1:learningResultCode "RA180" ;
    ns1:learningResultDescription "Domina las técnicas de gestión de calidad, plazos y costes de la Ingeniería que le permiten gestionar los proyectos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000417/2025-26/RA182> a ns1:LearningResult ;
    ns1:learningResultCode "RA182" ;
    ns1:learningResultDescription "Aprecia y analiza las incertidumbre de los proyectos y determina la estrategia para su consideración."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000417/2025-26/RA184> a ns1:LearningResult ;
    ns1:learningResultCode "RA184" ;
    ns1:learningResultDescription "Domina las técnicas de toma decisiones en los procesos y actividades en las que participa."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000417/2025-26/RA185> a ns1:LearningResult ;
    ns1:learningResultCode "RA185" ;
    ns1:learningResultDescription "Conoce el sector en el que desarrolla las actividades un ingeniero de caminos, canales y puertos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000417/2025-26/RA186> a ns1:LearningResult ;
    ns1:learningResultCode "RA186" ;
    ns1:learningResultDescription "Interpreta los requisitos exigibles a las construcciones y los ajusta en función de las características del proyecto y su entorno, incluyendo la naturaleza y los aspectos sociales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000417/2025-26/RA187> a ns1:LearningResult ;
    ns1:learningResultCode "RA187" ;
    ns1:learningResultDescription "Sabe desagregar un plan director en proyectos en función de las condiciones del entorno, del cliente y de la sociedad."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000417/2025-26/RA188> a ns1:LearningResult ;
    ns1:learningResultCode "RA188" ;
    ns1:learningResultDescription "Domina los aspectos administrativos de la gestión de un proyecto de manera que es capaz de dirigirlo de forma individual"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000417/2025-26/RA189> a ns1:LearningResult ;
    ns1:learningResultCode "RA189" ;
    ns1:learningResultDescription "Conoce la ordenación de los procesos en los que se desarrolla un proyecto, así como las funciones, competencias y responsabilidades de los que participan."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000417/2025-26/RA190> a ns1:LearningResult ;
    ns1:learningResultCode "RA190" ;
    ns1:learningResultDescription "Integra la prevención de riesgos laborales en los procesos competencia de los ingenieros de caminos, canales y puertos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000417/2025-26/RA191> a ns1:LearningResult ;
    ns1:learningResultCode "RA191" ;
    ns1:learningResultDescription "Facilita la accesibilidad y el trabajo para todos en los procesos competencia de los ingenieros de caminos, canales y puertos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000417/2025-26/RA192> a ns1:LearningResult ;
    ns1:learningResultCode "RA192" ;
    ns1:learningResultDescription "Domina todos los elementos necesarios para dirigir individualmente un proceso de la competencia del ingeniero de caminos, canales y puertos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000417/2025-26/RA193> a ns1:LearningResult ;
    ns1:learningResultCode "RA193" ;
    ns1:learningResultDescription "Organiza y gestiona los contratos necesarios en un proceso de competencia de los ingenieros de caminos, canales y puertos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000417/2025-26/RA194> a ns1:LearningResult ;
    ns1:learningResultCode "RA194" ;
    ns1:learningResultDescription "Domina los principios sostenibles y los aplica para asegurarlos en los procesos competencia de los ingenieros de caminos, canales y puertos."@es .

