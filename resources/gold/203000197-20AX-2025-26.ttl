        <https://guia-kg.skai.etsisi.upm.es/resource/javier.galeano%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/juancarlos.losada%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/rosamaria.benito%40upm.es> ;
    schema:name "Modelización y Análisis de Datos de Sistemas Agrarios"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000197/2025-26/C7_20AP> a ns1:Competency ;
    ns1:competencyCode "C7_20AP" ;
    ns1:competencyDescription "Ser capaz de utilizar las técnicas de análisis de datos adecuadas a cada caso de estudio en la modelización y análisis de sistemas agrarios."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000197/2025-26/CEH2_20AP> a ns1:Competency ;
    ns1:competencyCode "CEH2_20AP" ;
    ns1:competencyDescription "Poseer conocimiento avanzado y ser capaz de desarrollar tecnología en gestión de equipos e instalaciones que se integren en los procesos y sistemas de producción agroalimentaria."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000197/2025-26/CEH6_20AP> a ns1:Competency ;
    ns1:competencyCode "CEH6_20AP" ;
    ns1:competencyDescription "Poseer conocimiento avanzado y ser capaz de desarrollar tecnología en sistemas de producción vegetal y en sistemas integrados de protección de cultivos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000197/2025-26/CT2_20AP> a ns1:Competency ;
    ns1:competencyCode "CT2_20AP" ;
    ns1:competencyDescription "Resolución de problemas: capacidad para describir, organizar y analizar los elementos constitutivos de un problema complejo y diseñar estrategias que permitan alcanzar una solución científico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000197/2025-26/K9_20AP> a ns1:Competency ;
    ns1:competencyCode "K9_20AP" ;
    ns1:competencyDescription "Conocer las diferentes técnicas de Aprendizaje Automático (Machine Learning), la inteligencia artificial y otras metodologías de análisis avanzado de datos en distintos casos de estudio en el ámbito de la agricultura."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000197/2025-26/RA17> a ns1:LearningResult ;
    ns1:learningResultCode "RA17" ;
    ns1:learningResultDescription "K9_20AP"@es .

