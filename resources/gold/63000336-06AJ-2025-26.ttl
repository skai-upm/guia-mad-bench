<https://guia-kg.skai.etsisi.upm.es/resource/63000336/2025-26/CB07> a ns1:Competency ;
    ns1:competencyCode "CB07" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en entornos nuevos o poco conocidos dentro de contextos más amplios (o multidisciplinares) relacionados con su área de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000336/2025-26/CB09> a ns1:Competency ;
    ns1:competencyCode "CB09" ;
    ns1:competencyDescription "Que los estudiantes sepan comunicar sus conclusiones y los conocimientos y razones últimas que las sustentan a públicos especializados y no especializados de un modo claro y sin ambigüedades"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000336/2025-26/CG01> a ns1:Competency ;
    ns1:competencyCode "CG01" ;
    ns1:competencyDescription "Capacidad para aplicar los conocimientos teóricos y prácticos adquiridos a lo largo del Máster para resolver problemas concretos relacionados con la Ingeniería Geológica y la Geotecnia en cualquier tipo de proyectos, incluidos aquellos que presentan problemas nuevos o afectan a entornos o medios poco conocidos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000336/2025-26/CG05> a ns1:Competency ;
    ns1:competencyCode "CG05" ;
    ns1:competencyDescription "Capacidad para integrar conocimientos de ingeniería geológica y geotecnia y formular juicios, aún cuando la información sea limitada o incompleta."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000336/2025-26/CT01> a ns1:Competency ;
    ns1:competencyCode "CT01" ;
    ns1:competencyDescription "Capacidad de uso de la lengua inglesa para el trabajo en contextos internacionales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000336/2025-26/RA14> a ns1:LearningResult ;
    ns1:learningResultCode "RA14" ;
    ns1:learningResultDescription "Capacidad de aplicación a casos prácticos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000336/2025-26/RA72> a ns1:LearningResult ;
    ns1:learningResultCode "RA72" ;
    ns1:learningResultDescription "Analizar y evaluar resultados"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000336/2025-26/RA84> a ns1:LearningResult ;
    ns1:learningResultCode "RA84" ;
    ns1:learningResultDescription "Conocer y aplicar conceptos de sismología"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000336/2025-26/RA85> a ns1:LearningResult ;
    ns1:learningResultCode "RA85" ;
    ns1:learningResultDescription "Conocer el campo de actuación de la ingeniería sísmica y saber resolver problemas del mismo."@es .

