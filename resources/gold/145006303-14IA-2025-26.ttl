<https://guia-kg.skai.etsisi.upm.es/resource/145006303/2025-26/CE71> a ns1:Competency ;
    ns1:competencyCode "CE71" ;
    ns1:competencyDescription "Conocimiento aplicado de: Transmisores y receptores; Líneas de transmisión y sistemas radiantes de señales para la navegación aérea; Sistemas de navegación; Instalaciones eléctricas en el sector tierra y sector aire; Mecánica del Vuelo; Cartografía; Cosmografía; Meteorología; Distribución, gestión y economía del transporte aéreo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145006303/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Capacidad para identificar y resolver problemas aplicando, con creatividad, los conocimientos adquiridos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145006303/2025-26/CG6> a ns1:Competency ;
    ns1:competencyCode "CG6" ;
    ns1:competencyDescription "Uso de las Tecnologías de la Información y de las Comunicaciones"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145006303/2025-26/CG9> a ns1:Competency ;
    ns1:competencyCode "CG9" ;
    ns1:competencyDescription "Razonamiento crítico y capacidad de asociación que posibiliten el aprendizaje continuo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145006303/2025-26/RA110> a ns1:LearningResult ;
    ns1:learningResultCode "RA110" ;
    ns1:learningResultDescription "Conocimiento, comprensión, aplicación, análisis y síntesis de la teoría de sistemas moderna, formulando las ecuaciones de estado y observación e introduciendo los conceptos de matrices de estado y de observación, controlabilidad y observabilidad."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145006303/2025-26/RA111> a ns1:LearningResult ;
    ns1:learningResultCode "RA111" ;
    ns1:learningResultDescription "Conocimiento, comprensión, aplicación, análisis y síntesis de la teoría de sistemas muestreados y de la transformada en Z."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145006303/2025-26/RA306> a ns1:LearningResult ;
    ns1:learningResultCode "RA306" ;
    ns1:learningResultDescription "Conocimiento y comprensión de la teoría de sistemas no lineales."@es .

