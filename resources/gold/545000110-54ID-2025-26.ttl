    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/545000110/2025-26/syllabus> ;
    ns1:inpersonHours "66 horas (42.3%)"@es ;
    ns1:numberOfCredits 6.0 ;
    ns1:otherInformation """El alumno debe hacer un seguimiento al día de la asignatura y deberá realizar los supuestos que se le propongan para ser capaz de seguir el ritmo acumulativo de conocimientos necesario.
Por otra parte, esta asignatura intenta trabajar el objetivo número 8 de la lista de Objetivos de crecimiento sostenible de Naciones Unidas, relativo al trabajo decente y al crecimiento económico. Para ello, la asignatura aborda el concepto de imagen fiel de la empresa y la necesidad de aportar información contable fiable que contribuya a la creación de relaciones comerciales de confianza y que contribuya a la mejor gestión de la responsabilidad social corporativa de la empresa."""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "66 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/545000110/2025-26/eventSchedule> ;
    schema:description "En esta asignatura se introduce al alumno en el lenguaje y la metodología contable. Se inicia al alumno en los conceptos básicos contables, en la cuentas anuales y en el manejo contable de las operaciones que tienen lugar en la empresa."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/mario.gazcarate%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/mario.gazcarate%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/r.iran%40upm.es> ;
    schema:name "Introduccion la Contabilidad"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000110/2025-26/CE42> a ns1:Competency ;
    ns1:competencyCode "CE42" ;
    ns1:competencyDescription "Conocer la técnica contable en relación con la situación y los resultados de la empresa, y los flujos habidos en un período."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000110/2025-26/CE43> a ns1:Competency ;
    ns1:competencyCode "CE43" ;
    ns1:competencyDescription "Comprender el impacto de las operaciones económicas que desarrollan las empresas en su patrimonio empresarial."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000110/2025-26/CG15> a ns1:Competency ;
    ns1:competencyCode "CG15" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de planificar eficientemente los trabajos en el ámbito de la administración y dirección de empresas, priorizando las tareas a desempeñar y evaluando los recursos y el tiempo necesario para llevarlas a cabo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000110/2025-26/CG19> a ns1:Competency ;
    ns1:competencyCode "CG19" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de trabajar en equipos multidisciplinares, aplicando los conocimientos adquiridos en el ámbito de la administración y dirección de empresas, fomentando el espíritu de equipo y la coordinación en las tareas de los diversos miembros."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000110/2025-26/CG23> a ns1:Competency ;
    ns1:competencyCode "CG23" ;
    ns1:competencyDescription "Que los estudiantes adquieran un compromiso ético en su trabajo en el ámbito de la administración y dirección de empresas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000110/2025-26/RA87> a ns1:LearningResult ;
    ns1:learningResultCode "RA87" ;
    ns1:learningResultDescription "Comprender los fundamentos de la contabilidad."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000110/2025-26/RA89> a ns1:LearningResult ;
    ns1:learningResultCode "RA89" ;
    ns1:learningResultDescription "Desarrollar la capacidad de búsqueda, almacenamiento y tratamiento de información para la toma de decisiones y el aprendizaje autónomo."@es .

