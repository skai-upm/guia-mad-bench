<https://guia-kg.skai.etsisi.upm.es/resource/115100013/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/115100013/2025-26/CE02>,
        <https://guia-kg.skai.etsisi.upm.es/resource/115100013/2025-26/CE03>,
        <https://guia-kg.skai.etsisi.upm.es/resource/115100013/2025-26/CE08>,
