    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/93001071/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/93001071/2025-26/RA10>,
        <https://guia-kg.skai.etsisi.upm.es/resource/93001071/2025-26/RA194>,
        <https://guia-kg.skai.etsisi.upm.es/resource/93001071/2025-26/RA305>,
