<https://guia-kg.skai.etsisi.upm.es/resource/615001005/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/615001005/2025-26/CB01>,
        <https://guia-kg.skai.etsisi.upm.es/resource/615001005/2025-26/CB02>,
