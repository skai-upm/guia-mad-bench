<https://guia-kg.skai.etsisi.upm.es/resource/133000230> a ns1:Course ;
    ns1:courseType "Obligatoria"@es ;
    ns1:courseYear 1 ;
    ns1:semester "Primer semestre"@es ;
    schema:courseCode 133000230 ;
    schema:hasCourseInstance <https://guia-kg.skai.etsisi.upm.es/resource/133000230/2025-26> ;
    schema:name "Environmental Economics And Valuation. Auditing Systems"@en,
        "Economia, Valoracion y Auditoria Ambiental"@es ;
    schema:numberOfCredits 5.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/133000230/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/133000230/2025-26/CB08>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000230/2025-26/CB10>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000230/2025-26/CE%202.7>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000230/2025-26/CE%203.4>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000230/2025-26/CG%2004>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000230/2025-26/CT02>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000230/2025-26/CT05>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000230/2025-26/CT06>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000230/2025-26/CT10> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/133000230/2025-26/didactic_resource/1> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/133000230/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/133000230/2025-26/RA1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000230/2025-26/RA3>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000230/2025-26/RA4> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/133000230/2025-26/syllabus> ;
    ns1:inpersonHours "60 horas (46.2%)"@es ;
    ns1:numberOfCredits 5.0 ;
    ns1:otherInformation """La asignatura se relaciona con los ODS 9 y 12.
Esta asignatura empieza su impartición en septiembre de forma presencial, pero si fuera necesario cambiar por situaciones sanitarias habría que hacer una replanificación con las correspondientes adendas.
LAS COMPETENCIAS Y LOS RESULTADOS DE APRENDIZAJE DE ESTA ASIGNATURA SON LOS ACORDES CON LA MEMORIA VERIFICA DEL TÍTULO"""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "60 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/133000230/2025-26/eventSchedule> ;
    schema:description """El objetivo de esta asignatura es lograr que el alumno adquiera los conocimientos complementarios a la formación de grado en las siguientes tres disciplinas, que son además complementarias entre sí:
Economía y política ambiental. Instrumentos económicos de gestión medio ambiental.
Valoración ambiental y forestal. Normativa y métodos de valoración.
Auditoría ambiental. Sistemas de gestión medio ambiental ISO y EMAS."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/sigfredo.ortuno%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/jv.lopez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/luis.diaz.balteiro%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/sigfredo.ortuno%40upm.es> ;
    schema:name "Economia, Valoracion y Auditoria Ambiental"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000230/2025-26/CB08> a ns1:Competency ;
    ns1:competencyCode "CB08" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de integrar conocimientos y enfrentarse a la complejidad de formular juicios a partir de una información que, siendo incompleta o limitada, incluya reflexiones sobre las responsabilidades sociales y éticas vinculadas a la aplicación de sus conocimientos y juicios"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000230/2025-26/CB10> a ns1:Competency ;
    ns1:competencyCode "CB10" ;
    ns1:competencyDescription "Que los estudiantes posean las habilidades de aprendizaje que les permitan continuar estudiando de un modo que habrá de ser en gran medida autodirigido o autónomo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000230/2025-26/CE%202.7> a ns1:Competency ;
    ns1:competencyCode "CE 2.7" ;
    ns1:competencyDescription "Capacidad para la elaboración de sistemas de la calidad forestal y de auditoría ambiental."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000230/2025-26/CE%203.4> a ns1:Competency ;
    ns1:competencyCode "CE 3.4" ;
    ns1:competencyDescription "Conocimiento de las herramientas para el análisis económico y financiero y capacidad para la gestión de los recursos económicos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000230/2025-26/CG%2004> a ns1:Competency ;
    ns1:competencyCode "CG 04" ;
    ns1:competencyDescription "Capacidad para aplicar y definir criterios e indicadores en el campo de la auditoría ambiental."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000230/2025-26/CT02> a ns1:Competency ;
    ns1:competencyCode "CT02" ;
    ns1:competencyDescription "Integrar los conocimientos previos (propios de grado) de manera crítica y relacionada de forma que se puedan aplicar al estudio de situaciones reales y a la propuesta de alternativas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000230/2025-26/CT05> a ns1:Competency ;
    ns1:competencyCode "CT05" ;
    ns1:competencyDescription "Capacidad para la gestión económica y administrativa"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000230/2025-26/CT06> a ns1:Competency ;
    ns1:competencyCode "CT06" ;
    ns1:competencyDescription "Búsqueda bibliográfica, análisis de documentación y tratamiento de la información procedente de diversas fuentes y de su análisis y síntesis aplicándola a la resolución de problemas complejos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000230/2025-26/CT10> a ns1:Competency ;
    ns1:competencyCode "CT10" ;
    ns1:competencyDescription "Valores humanos positivos: Respeto a los derechos humanos fundamentales; los principios de igualdad de oportunidades, accesibilidad universal y no discriminación; y los valores propios de una cultura de paz y de valores democráticos. Compromiso con estos derechos, principios y valores, motivación, actitud positiva y entusiasta; ética, integridad y honestidad profesional"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000230/2025-26/RA1> a ns1:LearningResult ;
    ns1:learningResultCode "RA1" ;
    ns1:learningResultDescription "Aplicar los métodos de valoración ambiental al cálculo de las externalidades forestales y ambientales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000230/2025-26/RA3> a ns1:LearningResult ;
    ns1:learningResultCode "RA3" ;
    ns1:learningResultDescription "Aplicar los instrumentos económicos (impuestos, normas, subsidios, derechos transferibles) para la internalización de las externalidades forestales y ambientales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000230/2025-26/RA4> a ns1:LearningResult ;
    ns1:learningResultCode "RA4" ;
    ns1:learningResultDescription "Interpretar los sistemas de certificación ambiental basados en la norma ISO 14.000 y el Reglamento EMAS y los sistemas de certificación forestal existentes en la actualidad (FSC, PEFC, etc.)"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000230/2025-26/didactic_resource/1> a ns1:DidacticResource ;
    ns1:bibliographyDescription "Documentación en moodle"@es ;
    ns1:bibliographyTitle "Material de apoyo didáctico"@es ;
    ns1:bibliographyType "Recursos web"@es .

