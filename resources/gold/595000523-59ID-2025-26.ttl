<https://guia-kg.skai.etsisi.upm.es/resource/595000523/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Introducción"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000523/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Introducción. Taxonomía y tipos de modelos de aprendizaje automático. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000523/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "3.2. Regresión lineal y descenso de gradiente. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000523/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "4. Redes neuronales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000523/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "4.1. Concepto de Red Neuronal. Tipos de redes (perceptrón, prealimentadas o progresivas, recurrentes y convolucionales). Aplicaciones. Aprendizaje profundo. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000523/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "4.2. Perceptrón multicapa. Retropropagación. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000523/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "5. Aprendizaje por refuerzo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000523/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "5.1. Concepto de Aprendizaje por Refuerzo. Procesos de Decisión Markovianos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000523/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "5.2. Implementaciones con conocimiento del modelo. Programación dinámica. Iteración por valores y por políticas. Implementaciones sin conocimiento del modelo. Q-Learning. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000523/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "5.3. Aplicaciones y nuevas direcciones en aprendizaje por refuerzo. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000523/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "6. Aprendizaje no supervisado"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000523/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "6.1. Agrupamiento. Análisis k-means. DBSCAN. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000523/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Evaluación, selección y optimización de modelos. Métricas y proceso de evaluación. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000523/2025-26/syllabus/20> a ns1:SyllabusItem ;
    ns1:itemIndex 20 ;
    ns1:syllabusDescription "6.2. Reglas de asociación. Algoritmo APriori. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000523/2025-26/syllabus/21> a ns1:SyllabusItem ;
    ns1:itemIndex 21 ;
    ns1:syllabusDescription "6.3. Reducción de dimensionalidad. PCA. SVD. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000523/2025-26/syllabus/22> a ns1:SyllabusItem ;
    ns1:itemIndex 22 ;
    ns1:syllabusDescription "6.4. Selección de características de forma no supervisada. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000523/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "2. Modelado"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000523/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "2.1. Tipos de modelado: geométrico, gráfico, bayesiano, árbol, neuronal y evolutivo. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000523/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "2.2. Modelado geométrico. Modelos lineales (perceptrón, SVM) y de distancia (kNN, k-means). Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000523/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "2.3. Modelado en árbol (ID3) y de ensamblado (bagging, boosting y stacking). Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000523/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "2.4. Modelado evolutivo. Tipos de algoritmos evolutivos. Algoritmos genéticos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000523/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "3. Aprendizaje supervisado"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000523/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "3.1. Clasificación y regresión. Sin subniveles"@es .

