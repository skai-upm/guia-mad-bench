    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/103000371/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/103000371/2025-26/didactic_resource/2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/103000371/2025-26/didactic_resource/3>,
        <https://guia-kg.skai.etsisi.upm.es/resource/103000371/2025-26/didactic_resource/4>,
        <https://guia-kg.skai.etsisi.upm.es/resource/103000371/2025-26/didactic_resource/5> ;
