        <https://guia-kg.skai.etsisi.upm.es/resource/565000457/2025-26/RA26>,
        <https://guia-kg.skai.etsisi.upm.es/resource/565000457/2025-26/RA361>,
        <https://guia-kg.skai.etsisi.upm.es/resource/565000457/2025-26/RA362>,
