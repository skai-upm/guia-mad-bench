    ns1:competencyDescription "Concebir y diseñar la arquitectura de un sistema software."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000032/2025-26/Ce%2026/27> a ns1:Competency ;
    ns1:competencyCode "Ce 26/27" ;
    ns1:competencyDescription "Definir, evaluar y seleccionar plataformas hardware y software, incluyendo el sistema operativo, y concebir, llevar a cabo, instalar y mantener arquitecturas informáticas centralizadas o distribuidas integrando hardware, software y redes."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000032/2025-26/Ce%2031> a ns1:Competency ;
    ns1:competencyCode "Ce 31" ;
    ns1:competencyDescription "Desarrollar, desplegar, organizar y gestionar servicios informáticos en contextos empresariales para mejorar sus procesos de negocio."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000032/2025-26/Ce%2048> a ns1:Competency ;
    ns1:competencyCode "Ce 48" ;
    ns1:competencyDescription "Gestionar sistemas y servicios informáticos en contextos empresariales o institucionales para mejorar sus procesos de negocio."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000032/2025-26/Ce%209> a ns1:Competency ;
    ns1:competencyCode "Ce 9" ;
    ns1:competencyDescription "Poseer las destrezas que se requieren para diseñar e implementar unidades estructurales mayores que utilizan los algoritmos y las estructuras de datos, así como las interfaces por las que se comunican estas unidades."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000032/2025-26/RA320> a ns1:LearningResult ;
    ns1:learningResultCode "RA320" ;
    ns1:learningResultDescription "Diseño arquitectónico de aplicaciones basadas en servicios y desarrollo de soluciones tecnológicas orientadas a la integración de servicios (SOA)."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000032/2025-26/RA321> a ns1:LearningResult ;
