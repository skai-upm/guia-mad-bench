    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/55000020/2025-26/eventSchedule> ;
    schema:description """La asignatura tiene un marcado carácter práctico.
Se pretende que los alumnos sean capaces de diseñar y analizar un experimento factorial con varios factores que puedan interaccionar entre ellos y también sean capaces de construir un modelo de regresión lineal, hacer la diagnosis y si ésta es adecuada, realicen predicciones en el rango en el que el modelo es válido.
Se hace especial énfasis en la selección crítica de los modelos y en su interpretación.
Los alumnos a tal fin deben manejar el programa de cálculo estadístico-científico R que se utiliza en las clases de resolución de problemas."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/eduardo.caro%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/camino.gonzalez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/eduardo.caro%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/garcia.martos%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/javier.cara%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/jesus.juan%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/josemanuel.mira%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/mariajesus.sanchez%40upm.es> ;
    schema:name "Diseño de Experimentos y Modelos de Regresion"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000020/2025-26/CE6> a ns1:Competency ;
    ns1:competencyCode "CE6" ;
    ns1:competencyDescription "Aptitud para aplicar los conocimientos y capacidad para la resolución de los problemas que puedan plantearse en la ingeniería sobre estadística."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000020/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Conocer y aplicar conocimientos de ciencias y tecnologías básicas a la práctica de la Ingeniería Industrial."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000020/2025-26/CG2> a ns1:Competency ;
    ns1:competencyCode "CG2" ;
    ns1:competencyDescription "Poseer capacidad para diseñar, desarrollar, implementar, gestionar y mejorar productos, sistemas y procesos en los distintos ámbitos industriales, usando técnicas analíticas, computacionales o experimentales apropiadas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000020/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Aplicar los conocimientos adquiridos para identificar, formular y resolver problemas dentro de contextos amplios y multidisciplinarios, siendo capaces de integrar conocimientos, trabajando en equipos multidisciplinares."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000020/2025-26/CG6> a ns1:Competency ;
    ns1:competencyCode "CG6" ;
    ns1:competencyDescription "Poseer habilidades de aprendizaje que permitan continuar estudiando a lo largo de la vida para su adecuado desarrollo profesional."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000020/2025-26/CG7> a ns1:Competency ;
    ns1:competencyCode "CG7" ;
    ns1:competencyDescription "Incorporar nuevas tecnologías y herramientas de la Ingeniería Industrial en sus actividades profesionales."@es .

