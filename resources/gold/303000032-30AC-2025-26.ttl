    schema:hasCourseInstance <https://guia-kg.skai.etsisi.upm.es/resource/303000032/2025-26> ;
    schema:name "Antecedents And History Of The Graphic Representation"@en,
        "Antecedentes e Historia de la Representacion Grafica"@es ;
    schema:numberOfCredits 3.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/303000032/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/303000032/2025-26/CON1.CG1.>,
        <https://guia-kg.skai.etsisi.upm.es/resource/303000032/2025-26/CON10.CE13.>,
        <https://guia-kg.skai.etsisi.upm.es/resource/303000032/2025-26/CON11.CE14.>,
        <https://guia-kg.skai.etsisi.upm.es/resource/303000032/2025-26/CON4.CG10.>,
        <https://guia-kg.skai.etsisi.upm.es/resource/303000032/2025-26/CON8.CE6.>,
        <https://guia-kg.skai.etsisi.upm.es/resource/303000032/2025-26/HAB22.CT5.> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/303000032/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/303000032/2025-26/RA112>,
        <https://guia-kg.skai.etsisi.upm.es/resource/303000032/2025-26/RA113>,
        <https://guia-kg.skai.etsisi.upm.es/resource/303000032/2025-26/RA114>,
        <https://guia-kg.skai.etsisi.upm.es/resource/303000032/2025-26/RA115>,
        <https://guia-kg.skai.etsisi.upm.es/resource/303000032/2025-26/RA116>,
        <https://guia-kg.skai.etsisi.upm.es/resource/303000032/2025-26/RA195> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/303000032/2025-26/syllabus> ;
    ns1:inpersonHours "33 horas (42.3%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation """Las actividades serán tipo presencial.
Las actividades semanales propuestas son una aproximación a las que de desarrollarán durante el curso susceptibles de algunas modificaciones."""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "33 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/303000032/2025-26/eventSchedule> ;
    schema:description """Conocer y comprender los métodos de enseñanza teórico-prácticos de la enseñanza del Dibujo a lo largo de la historia.
Conocer los materiales e instrumentos del Dibujo.
Reconocer la geometría en la naturaleza.
Identificar las estructuras geométricas en el arte.
Conocer y valorar la geometría como instrumento para el diseño gráfico, industrial y arquitectónico a lo largo de la historia.
Conocer la historia y los contenidos del dibujo y artes plásticas en la ESO, Bachillerato y Artes Plásticas."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/mariajesus.casati%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/mariajesus.casati%40upm.es> ;
    schema:name "Antecedentes e Historia de la Representacion Grafica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000032/2025-26/CON1.CG1.> a ns1:Competency ;
    ns1:competencyCode "CON1.CG1." ;
    ns1:competencyDescription "Conocer los contenidos curriculares de las materias relativas a la especialización docente correspondiente, así como el cuerpo de conocimientos didácticos en torno a los procesos de enseñanza y aprendizaje respectivos. Para la formación profesional se incluirá el conocimiento de las respectivas profesiones. TIPO: Conocimientos o contenidos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000032/2025-26/CON10.CE13.> a ns1:Competency ;
    ns1:competencyCode "CON10.CE13." ;
    ns1:competencyDescription "Conocer el valor formativo y cultural de las materias correspondientes a la especialización y los contenidos que se cursan en las respectivas enseñanzas. TIPO: Conocimientos o contenidos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000032/2025-26/CON11.CE14.> a ns1:Competency ;
    ns1:competencyCode "CON11.CE14." ;
    ns1:competencyDescription "Conocer la historia y los desarrollos recientes de las materias y sus perspectivas para poder transmitir una visión dinámica de las mismas. TIPO: Conocimientos o contenidos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000032/2025-26/CON4.CG10.> a ns1:Competency ;
    ns1:competencyCode "CON4.CG10." ;
    ns1:competencyDescription "Conocer y analizar las características históricas de la profesión docente, su situación actual, perspectivas e interrelación con la realidad social de cada época. TIPO: Conocimientos o contenidos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000032/2025-26/CON8.CE6.> a ns1:Competency ;
    ns1:competencyCode "CON8.CE6." ;
    ns1:competencyDescription "Conocer la evolución histórica del sistema educativo TIPO: Conocimientos o contenidos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000032/2025-26/HAB22.CT5.> a ns1:Competency ;
    ns1:competencyCode "HAB22.CT5." ;
    ns1:competencyDescription "Generar aptitudes relacionadas con la gestión de la información. TIPO: Habilidades o destrezas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000032/2025-26/RA112> a ns1:LearningResult ;
    ns1:learningResultCode "RA112" ;
    ns1:learningResultDescription "Saber presentar la evolución histórica de la representación gráfica y artística."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000032/2025-26/RA113> a ns1:LearningResult ;
    ns1:learningResultCode "RA113" ;
    ns1:learningResultDescription "Transmitir el razonamiento gráfico como método científico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000032/2025-26/RA114> a ns1:LearningResult ;
    ns1:learningResultCode "RA114" ;
    ns1:learningResultDescription "Saber proponer actividades docentes que permitan la utilización de dicho método."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000032/2025-26/RA115> a ns1:LearningResult ;
    ns1:learningResultCode "RA115" ;
    ns1:learningResultDescription "Despertar en sus discentes el razonamiento gráfico y el dominio de las técnicas de expresión artística, el sentido crítico y la curiosidad por la demostración gráfica de determinados diseños y elementos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000032/2025-26/RA116> a ns1:LearningResult ;
    ns1:learningResultCode "RA116" ;
    ns1:learningResultDescription "Aprender a analizar gráficamente los problemas antes de su resolución gráfica."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000032/2025-26/RA195> a ns1:LearningResult ;
