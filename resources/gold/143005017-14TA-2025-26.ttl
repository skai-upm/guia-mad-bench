<https://guia-kg.skai.etsisi.upm.es/resource/143005017/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Tema 1. INTRODUCCIÓN."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005017/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. 1.1. Introducción general de la situación técnica y económica del transporte aéreo mundial. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005017/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "4.4. 4.4. El soleamiento de las edificaciones. Soleamiento en función de la latitud y la época del año. Medidas de captación y medidas de protección frente a la luz solar. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005017/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "5. Tema 5. EFICIENCIA ENERGÉTICA DE LAS EDIFICACIONES."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005017/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "5.1. 5.1. Consumo energético de las edificaciones. Demanda energética y eficiencia de las instalaciones. Estrategias de ahorro Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005017/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "5.2. 5.2. El Documento Básico de Ahorro de Energía del Código Técnico. Definición de la envolvente del edificio y limitación de la demanda energética Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005017/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "5.3. 5.3. Eficiencia energética de las instalaciones. Instalaciones de aprovechamiento de la energía solar. Otras energías renovables y su aprovechamiento en las edificaciones. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005017/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "5.4. 5.4. Certificación energética de las edificaciones Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005017/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "6. Tema 6. MARCO REGULADOR INTERNACIONAL."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005017/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "6.1. 6.1. Marco regulador internacional. 6.2. Marco regulador en la Unión Europea y su desarrollo. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005017/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "7. Tema 7. MÉTODOS DE REDUCCIÓN DE IMPACTO AMBIENTAL."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005017/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "7.1. 7.1. Principales métodos tecnológicos de reducción de impacto ambiental. 7.2. Métodos económicos de reducción de impacto ambiental Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005017/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "2. Tema 2. PRINCIPALES IMPACTOS AMBIENTALES."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005017/2025-26/syllabus/20> a ns1:SyllabusItem ;
    ns1:itemIndex 20 ;
    ns1:syllabusDescription "8. Tema 8. SISTEMAS DE GESTIÓN DE IMPACTO AMBIENTAL."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005017/2025-26/syllabus/21> a ns1:SyllabusItem ;
    ns1:itemIndex 21 ;
    ns1:syllabusDescription "8.1. 8.1. Estudio de los sistemas de gestión de impacto ambiental. 8.2. Desarrollo sostenible y responsabilidad social corporativa Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005017/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "2.1. 2.1. Efectos locales: el ruido, el deterioro de la calidad de aire global, el uso de suelo y las afecciones sobre el hábitat. 2.2. Efectos globales: el cambio climático y el consumo de materias no renovables Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005017/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "3. Tema 3. SOSTENIBILIDAD DE LAS EDIFICACIONES."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005017/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "3.1. 3.1. Gasto energético de los edificios. Emisiones contaminantes. 3.2. El clima y el diseño de los edificios. Factores climáticos. Construcción bioclimática Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005017/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "4. Tema 4. EL CONFORT EN LAS EDIFICACIONES."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005017/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "4.1. 4.1. Factores de confort y consumo energético. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005017/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "4.2. 4.2. Confort acústico. Aislamiento y acondicionamiento acústico. El Documento Básico de Protección Frente al Ruido del Código Técnico. Medidas de mejora del confort acústico. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005017/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "4.3. 4.3. Confort luminoso. Actividad y niveles de iluminación. Medidas de aprovechamiento de la luz natural Sin subniveles"@es .

