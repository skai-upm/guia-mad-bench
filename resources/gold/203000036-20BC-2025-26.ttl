<https://guia-kg.skai.etsisi.upm.es/resource/203000036> a ns1:Course ;
    ns1:courseType "Optativa"@es ;
    ns1:courseYear 1 ;
    ns1:semester "Segundo semestre"@es ;
    schema:courseCode 203000036 ;
    schema:hasCourseInstance <https://guia-kg.skai.etsisi.upm.es/resource/203000036/2025-26> ;
    schema:name "Proffesional Development And Technology Transfer"@en,
        "Desarrollo Profesional y Transferencia Tecnológica"@es ;
    schema:numberOfCredits 3.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/203000036/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/203000036/2025-26/CE06>,
        <https://guia-kg.skai.etsisi.upm.es/resource/203000036/2025-26/CG06>,
        <https://guia-kg.skai.etsisi.upm.es/resource/203000036/2025-26/CT02>,
        <https://guia-kg.skai.etsisi.upm.es/resource/203000036/2025-26/CT03> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/203000036/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/203000036/2025-26/didactic_resource/2> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/203000036/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/203000036/2025-26/RA53>,
        <https://guia-kg.skai.etsisi.upm.es/resource/203000036/2025-26/RA54>,
        <https://guia-kg.skai.etsisi.upm.es/resource/203000036/2025-26/RA55> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/203000036/2025-26/syllabus> ;
    ns1:inpersonHours "35 horas y 15 minutos (45.2%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation """This Subject will contribute to the following ODS:
Salud y bienestar
Industria, innovación e infraestructura
Reducción de las desigualdades
Ciudades y comunidades sostenibles
Producción y consumo responsables
Alianzas para lograr los objetivos"""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "35 horas y 15 minutos"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/203000036/2025-26/eventSchedule> ;
    schema:description """The aim of this subject is to provide to the students knowledge about the Computational Biology/Big Data profesional market and to train the students in the skills required for their professional career development.
Among the themes to be studied in this topic are the following:
1. Professional Career and Career track skills: Preparation of Professional profile and CV, and development of professional skills.
2. R&D projects: Writing, preparation and application of projects for competitive calls.
3. Management of R&D projects (type of projects, national and international calls, and consortium projects).
4. Innovation concepts and knowledge transfer
5. Intellectual property protection
6. Public presentations of innovation projects and results.
7. Profesional ethics and Data Protection"""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/antonio.molina%40upm.es> ;
    schema:inLanguage "Inglés"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/antonio.molina%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/javier.bajo%40upm.es> ;
    schema:name "Desarrollo Profesional y Transferencia Tecnológica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000036/2025-26/CE06> a ns1:Competency ;
    ns1:competencyCode "CE06" ;
    ns1:competencyDescription "Identificar las necesidades bioinformáticas de los centros de investigación y las empresas del sector de la biotecnología y la biomedicina/ Identifying the bioinformatics needs of research centers and enterprises in the biotechnology and biomedicine sectors."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000036/2025-26/CG06> a ns1:Competency ;
    ns1:competencyCode "CG06" ;
    ns1:competencyDescription "Que los estudiantes posean las habilidades de aprendizaje que les permitan continuar estudiando de un modo que habrá de ser en gran medida autodirigido o autónomo para adaptarse a la rápida evolución prevista en el área de la Biología Computacional/ Provide students with the learning abilities that allow them to study in a largely autodirected and autonomous manner so that they can adapt to the fast evolving nature of the Computational Biology field."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000036/2025-26/CT02> a ns1:Competency ;
    ns1:competencyCode "CT02" ;
    ns1:competencyDescription "Capacidad para aplicar el método científico para la resolución de problemas de forma efectiva y creativa/ Capacity to apply the scientific method to solve problems in an efective and creative way."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000036/2025-26/CT03> a ns1:Competency ;
    ns1:competencyCode "CT03" ;
    ns1:competencyDescription "Tener compromiso bioético y profesional y respeto por la sostenibilidad ambiental/ To have bioethics and professional awareness for environmental sustainability."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000036/2025-26/RA53> a ns1:LearningResult ;
    ns1:learningResultCode "RA53" ;
    ns1:learningResultDescription "Adquirir conocimiento sobre la inversión en I+D+i, incluyendo aspectos relacionados con solicitud y gestión de proyectos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000036/2025-26/RA54> a ns1:LearningResult ;
    ns1:learningResultCode "RA54" ;
    ns1:learningResultDescription "Adquirir conocimientos sobre el análisis y publicación de Big Data y la ética asociada"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000036/2025-26/RA55> a ns1:LearningResult ;
    ns1:learningResultCode "RA55" ;
    ns1:learningResultDescription "Adquirir habilidades profesionales de comunicación escrita y oral"@es .

