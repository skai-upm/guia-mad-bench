<https://guia-kg.skai.etsisi.upm.es/resource/133000206/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/133000206/2025-26/CB08>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000206/2025-26/CG01>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000206/2025-26/CT03> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/133000206/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000206/2025-26/didactic_resource/2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000206/2025-26/didactic_resource/3> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/133000206/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/133000206/2025-26/RA50>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000206/2025-26/RA51> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/133000206/2025-26/syllabus> ;
    ns1:inpersonHours "23 horas (44.2%)"@es ;
    ns1:numberOfCredits 2.0 ;
    ns1:otherInformation """In this course, subjects are taught that contribute to training students to achieve the following Sustainable Development Goals (SDGs):
GOAL 1: NO POVERTY
GOAL 8: DECENT WORK AND ECONOMIC GROWTH
GOAL 9: INDUSTRY, INNOVATION, AND INFRASTRUCTURE"""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "23 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/133000206/2025-26/eventSchedule> ;
    schema:description "Making decisions with less risk and anticipating change is a great competitive advantage and strengthens management in a company. Science and technology can help to capture, select, analyse, disseminate and communicate external information. In this subject, the principles and tools necessary to do so will be presented."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/francisco.ayuga%40upm.es> ;
    schema:inLanguage "Inglés/Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/francisco.ayuga%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/justo.gnavarro%40upm.es> ;
    schema:name "Vigilancia Tecnologica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000206/2025-26/CB08> a ns1:Competency ;
    ns1:competencyCode "CB08" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de integrar conocimientos y enfrentarse a la complejidad de formular juicios a partir de una información que, siendo incompleta o limitada, incluya reflexiones sobre las responsabilidades sociales y éticas vinculadas a la aplicación de sus conocimientos y juicios"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000206/2025-26/CG01> a ns1:Competency ;
    ns1:competencyCode "CG01" ;
    ns1:competencyDescription "El alumno tendrá capacidad para analizar y evaluar las implicaciones de implantar un modelo de economía circular desde el punto de vista normativo, económico, industrial y tecnológico."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000206/2025-26/CT03> a ns1:Competency ;
    ns1:competencyCode "CT03" ;
    ns1:competencyDescription "El alumno tendrá capacidad para gestionar la información procedente de diversas fuentes, valorando su relevancia, fiabilidad y pertinencia para un propósito determinado, analizándola y organizándola."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000206/2025-26/RA50> a ns1:LearningResult ;
    ns1:learningResultCode "RA50" ;
    ns1:learningResultDescription ""@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000206/2025-26/RA51> a ns1:LearningResult ;
    ns1:learningResultCode "RA51" ;
    ns1:learningResultDescription "Elaborar una estrategia de búsqueda de información útil para la empresa en el ámbito de la economía circular"@es .

