    schema:courseCode 53001403 ;
    schema:hasCourseInstance <https://guia-kg.skai.etsisi.upm.es/resource/53001403/2025-26> ;
    schema:name "Production Management"@en,
        "Gestión de la Producción"@es ;
    schema:numberOfCredits 3.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/53001403/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/53001403/2025-26/CB7>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001403/2025-26/CE3>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001403/2025-26/CE7>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001403/2025-26/CG5>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001403/2025-26/CT4> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/53001403/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001403/2025-26/didactic_resource/2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001403/2025-26/didactic_resource/3>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001403/2025-26/didactic_resource/4> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/53001403/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/53001403/2025-26/RA120>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001403/2025-26/RA13> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/53001403/2025-26/syllabus> ;
    ns1:inpersonHours "35 horas (44.9%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation """La docencia se plantea presencial.
La asignatura de Gestión de la Producción tiene como objetivo la maximización de la eficiencia de todos los recursos productivos, en particular equipos, recursos humanos, energéticos. Por tanto se relaciona de forma directa con el cumplimiento de los objetivos ODS:
ODS 9: Construir infraestructuras resilientes, promover la industrialización sostenible y fomentar la innovación
https://www.un.org/sustainabledevelopment/es/infrastructure/
ODS 12: Garantizar modalidades de consumo y producción sostenibles.
https://www.un.org/sustainabledevelopment/es/sustainable-consumption-production/"""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "35 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/53001403/2025-26/eventSchedule> ;
    schema:description "Esta asignatura se considera introductoria a la gestión de las operaciones productivas, y se centra en los aspectos relacionados con el sistema de planificación y control de la producción: la previsión de la demanda, la gestión de los inventarios, y la propia programación y control de la producción, incluyendo las técnicas derivadas del Lean Manufacturing. Se pretende que el alumno adquiera los fundamentos de las técnicas de organización de los sistemas productivos de bienes y servicios, incluyendo la selección y aplicación para la toma de distintas decisiones tácticas y operativas."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/miguel.gutierrez%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/luisjavier.escobar%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/miguel.gutierrez%40upm.es> ;
    schema:name "Gestión de la Producción"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001403/2025-26/CB7> a ns1:Competency ;
    ns1:competencyCode "CB7" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en entornos nuevos o poco conocidos dentro de contextos más amplios (o multidisciplinares) relacionados con su área de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001403/2025-26/CE3> a ns1:Competency ;
    ns1:competencyCode "CE3" ;
    ns1:competencyDescription "Conceptualizar modelos de ingeniería, aplicar métodos innovadores en la resolución de problemas y aplicaciones informáticas adecuadas, para el diseño, simulación, optimización y control de procesos y sistemas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001403/2025-26/CE7> a ns1:Competency ;
    ns1:competencyCode "CE7" ;
    ns1:competencyDescription "Dirigir y organizar empresas, así como sistemas de producción y servicios, aplicando conocimientos y capacidades de organización industrial, estrategia comercial, planificación y logística, legislación mercantil y laboral, contabilidad financiera y de costes."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001403/2025-26/CG5> a ns1:Competency ;
    ns1:competencyCode "CG5" ;
    ns1:competencyDescription "Saber establecer modelos matemáticos y desarrollarlos mediante la informática apropiada, como base científica y tecnológica para el diseño de nuevos productos, procesos, sistemas y servicios, y para la optimización de otros ya desarrollados"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001403/2025-26/CT4> a ns1:Competency ;
    ns1:competencyCode "CT4" ;
    ns1:competencyDescription "Organización y planificación"@es .

