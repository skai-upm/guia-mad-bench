    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/55000404/2025-26/syllabus> ;
    ns1:inpersonHours "47 horas (40.2%)"@es ;
    ns1:numberOfCredits 4.5 ;
    ns1:otherInformation "La asignatura se relaciona con el ODS4 y el ODS9"@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "118 horas"@es ;
    schema:activitiesWorkload "110%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/55000404/2025-26/eventSchedule> ;
    schema:description """La asignatura tiene por objeto presentar los fundamentos teóricos de las herramientas de simulación dinámica usadas en el ámbito de la ingeniería mecánica. Comprende dos grandes bloques.
El primer bloque es simulación de mecanismos tando por ecuaciones de Newton-Euler como por ecuaciones de Lagrange. Por alcance de la asignatura se limita a mecanismos planos.
El segundo bloque es la simulación multidominio mediante la técnica de bond graph. Se incluye su aplicación a mecánica, hidráulica y electricidad y a combinación de estos dominios
Como resultado de lo visto en la asibnatura, se construirá y analizará un modelo complejo de un sistema mecánico integrado con un modelo hidraulico y/o electrico"""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/jesus.felez%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/jesus.felez%40upm.es> ;
    schema:name "Simulacion de Sistemas Mecanicos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000404/2025-26/CE21C> a ns1:Competency ;
    ns1:competencyCode "CE21C" ;
    ns1:competencyDescription "Conocimientos y capacidades para el cálculo, diseño y ensayo de máquinas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000404/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Conocer y aplicar conocimientos de ciencias y tecnologías básicas a la práctica de la Ingeniería Industrial."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000404/2025-26/CG2> a ns1:Competency ;
    ns1:competencyCode "CG2" ;
    ns1:competencyDescription "Poseer capacidad para diseñar, desarrollar, implementar, gestionar y mejorar productos, sistemas y procesos en los distintos ámbitos industriales, usando técnicas analíticas, computacionales o experimentales apropiadas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000404/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Aplicar los conocimientos adquiridos para identificar, formular y resolver problemas dentro de contextos amplios y multidisciplinarios, siendo capaces de integrar conocimientos, trabajando en equipos multidisciplinares."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000404/2025-26/CG6> a ns1:Competency ;
    ns1:competencyCode "CG6" ;
    ns1:competencyDescription "Poseer habilidades de aprendizaje que permitan continuar estudiando a lo largo de la vida para su adecuado desarrollo profesional."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000404/2025-26/CG7> a ns1:Competency ;
    ns1:competencyCode "CG7" ;
    ns1:competencyDescription "Incorporar nuevas tecnologías y herramientas de la Ingeniería Industrial en sus actividades profesionales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000404/2025-26/RA198> a ns1:LearningResult ;
    ns1:learningResultCode "RA198" ;
    ns1:learningResultDescription "Analizar y relacionar los componentes fundamentales de un mecanismo o de un sistema perteneciente a dominios eléctricos o hidráulicos, o combinaciones de éstos, para poderlo modelizar, interpretar y definir correctamente."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000404/2025-26/RA199> a ns1:LearningResult ;
    ns1:learningResultCode "RA199" ;
    ns1:learningResultDescription "Analizar los resultados de simulaciones y conocer las posibilidades y limitaciones de éstas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000404/2025-26/RA200> a ns1:LearningResult ;
    ns1:learningResultCode "RA200" ;
    ns1:learningResultDescription "Utilizar herramientas informáticas para abordar la simulación del trabajo anterior."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000404/2025-26/RA488> a ns1:LearningResult ;
    ns1:learningResultCode "RA488" ;
    ns1:learningResultDescription "Ser capaz de analizar y relacionar los componentes fundamentales de un mecanismo o de un esquema perteneciente a otros dominios para poderlo interpretar y definir correctamente."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000404/2025-26/RA489> a ns1:LearningResult ;
    ns1:learningResultCode "RA489" ;
    ns1:learningResultDescription "Ser capaz de construir un modelo dinámico de un sistema mecánico, de un sistema otros dominios, o combinación de varios dominios."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000404/2025-26/RA491> a ns1:LearningResult ;
    ns1:learningResultCode "RA491" ;
    ns1:learningResultDescription "Utilizar herramientas informáticas para abordar la modelización y simulación de un sistema dinámico."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000404/2025-26/RA492> a ns1:LearningResult ;
    ns1:learningResultCode "RA492" ;
    ns1:learningResultDescription "Se capaz de analizar los resultados de simulaciones y conocer las posibilidades y limitaciones de éstas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000404/2025-26/RA90> a ns1:LearningResult ;
    ns1:learningResultCode "RA90" ;
    ns1:learningResultDescription "Incorporar el uso de términos técnicos en el lenguaje."@es .

