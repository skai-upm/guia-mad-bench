    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/23000401/2025-26/eventSchedule> ;
    schema:description "La asignatura se compone de un ciclo de conferencias monográficas y visitas, en el que distintos profesionales vinculados a asociaciones, empresas privadas y organismos públicos, exponen a los estudiantes las características y peculiaridades de las empresas, su organización, su estructura, equipos humanos, etc."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/raquel.casas%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/raquel.casas%40upm.es> ;
    schema:name "Empresas de Jardineria"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000401/2025-26/C1> a ns1:Competency ;
    ns1:competencyCode "C1" ;
    ns1:competencyDescription "Capacidad de reconocer y describir los elementos característicos de un área verde o actuación paisajística y organizar la información significativa, aplicando el pensamiento crítico, con el objeto de emitir juicios técnicos y contribuir a la solución de problemas complejos. TIPO: Competencias."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000401/2025-26/K6> a ns1:Competency ;
    ns1:competencyCode "K6" ;
    ns1:competencyDescription "Conocer las características y peculiaridades de las empresas y entidades vinculadas a las actividades de jardinería y paisajismo, y cómo organizar el trabajo en equipo y participar en las actuaciones ejecutivas y directivas. TIPO: Conocimientos o contenidos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000401/2025-26/RA101> a ns1:LearningResult ;
    ns1:learningResultCode "RA101" ;
    ns1:learningResultDescription "S3"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000401/2025-26/RA107> a ns1:LearningResult ;
    ns1:learningResultCode "RA107" ;
    ns1:learningResultDescription "K6"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000401/2025-26/S3> a ns1:Competency ;
    ns1:competencyCode "S3" ;
    ns1:competencyDescription "Habilidad para comunicar ideas, problemas y soluciones, así como los conocimientos y razones que los sustentan tanto a público especializado como no especializado de forma clara. TIPO: Habilidades o destrezas."@es .

