    ns1:gradePercentage "40%"@es ;
    ns1:hasScheduleEvent <https://guia-kg.skai.etsisi.upm.es/resource/23000401/2025-26/eventSchedule/16> ;
    ns1:involvesCompetency <https://guia-kg.skai.etsisi.upm.es/resource/C1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/S3> ;
    ns1:minimumScore "5 / 10"@es ;
