    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation "La asignatura aborda de lleno la Agenda 2030, con especial atención a su carácter sistémico, y a las implicaciones para las organizaciones empresariales y sus profesionales. Asimismo, se dedica atención especial al ODS 17, por su interés para el alumnado de la especialidad de organización."@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "52 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/55000610/2025-26/eventSchedule> ;
    schema:description """El contenido de la asignatura se estructura en torno a tres temas relacionados entre sí:
1.- Sistemas de gestión de calidad
2.- Sistemas de seguridad y prevención de riesgos
3.- Sostenibilidad: grandes tendencias y su impacto en las organizaciones"""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/carlos.mataix%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/carlos.mataix%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/javier.mazorra%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/ma.huerta%40upm.es> ;
    schema:name "Gestion de la Calidad, la Prevencion y la Sostenibilidad"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000610/2025-26/CE24F> a ns1:Competency ;
    ns1:competencyCode "CE24F" ;
    ns1:competencyDescription "Capacidad para diseÃ±ar sistemas de gestiÃ³n de calidad conforme a criterios reconocidos internacionalmente. Conocimiento de las causas de riesgos laborales y capacidad para el diseÃ±o de sistemas de prevenciÃ³n. Conocimiento de los enfoques de gestiÃ³n medioambiental que promueven la sostenibilidad de las actividades productivas de la empresa."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000610/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Conocer y aplicar conocimientos de ciencias y tecnologías básicas a la práctica de la Ingeniería Industrial."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000610/2025-26/CG2> a ns1:Competency ;
    ns1:competencyCode "CG2" ;
    ns1:competencyDescription "Poseer capacidad para diseñar, desarrollar, implementar, gestionar y mejorar productos, sistemas y procesos en los distintos ámbitos industriales, usando técnicas analíticas, computacionales o experimentales apropiadas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000610/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Aplicar los conocimientos adquiridos para identificar, formular y resolver problemas dentro de contextos amplios y multidisciplinarios, siendo capaces de integrar conocimientos, trabajando en equipos multidisciplinares."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000610/2025-26/CG4> a ns1:Competency ;
    ns1:competencyCode "CG4" ;
    ns1:competencyDescription "Comprender el impacto de la ingeniería industrial en el medio ambiente, el desarrollo sostenible de la sociedad y la importancia de trabajar en un entorno profesional y responsable."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000610/2025-26/CG5> a ns1:Competency ;
    ns1:competencyCode "CG5" ;
    ns1:competencyDescription "Saber comunicar los conocimientos y conclusiones, de forma oral, escrita y gráfica, a públicos especializados y no especializados de un modo claro y sin ambigüedades."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000610/2025-26/CG7> a ns1:Competency ;
    ns1:competencyCode "CG7" ;
    ns1:competencyDescription "Incorporar nuevas tecnologías y herramientas de la Ingeniería Industrial en sus actividades profesionales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000610/2025-26/CG9> a ns1:Competency ;
    ns1:competencyCode "CG9" ;
    ns1:competencyDescription "Organización y planificación en el ámbito de la empresa, y otras instituciones y organizaciones de proyectos y equipos humanos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000610/2025-26/RA311> a ns1:LearningResult ;
    ns1:learningResultCode "RA311" ;
    ns1:learningResultDescription "Implementar y mejorar sistemas de gestión especializados, conformes a normas internaciones y facilitar su integración"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000610/2025-26/RA312> a ns1:LearningResult ;
    ns1:learningResultCode "RA312" ;
    ns1:learningResultDescription "Identificar las regulaciones legales aplicables y delimitar las responsabilidades legales de las personas y organizaciones"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000610/2025-26/RA313> a ns1:LearningResult ;
    ns1:learningResultCode "RA313" ;
    ns1:learningResultDescription "Evaluar y aplicar diferentes instrumentos de gestión ambiental y evaluar su impacto sobre la empresa"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000610/2025-26/RA459> a ns1:LearningResult ;
    ns1:learningResultCode "RA459" ;
    ns1:learningResultDescription "Facilitar una visión integrada de la gestión empresarial, conforme con los principios básicos de sostenibilidad"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000610/2025-26/RA77> a ns1:LearningResult ;
    ns1:learningResultCode "RA77" ;
    ns1:learningResultDescription "Analizar las relaciones entre componentes de un sistema y su efecto global, asi como con el entorno."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000610/2025-26/RA81> a ns1:LearningResult ;
    ns1:learningResultCode "RA81" ;
    ns1:learningResultDescription "Reconocer las posibles consecuencias de la organización de un sistema productivo sobre sus integrantes y sobre el entorno."@es .

