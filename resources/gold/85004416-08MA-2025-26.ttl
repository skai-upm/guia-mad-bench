        <https://guia-kg.skai.etsisi.upm.es/resource/joseandres.somolinos%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/l.delhorno%40upm.es> ;
    schema:name "Electrónica e Instrumentación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85004416/2025-26/CB2> a ns1:Competency ;
    ns1:competencyCode "CB2" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar sus conocimientos a su trabajo o vocación de una forma profesional y posean las competencias que suelen demostrarse por medio de la elaboración y defensa de argumentos y la resolución de problemas dentro de su área de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85004416/2025-26/CB5> a ns1:Competency ;
    ns1:competencyCode "CB5" ;
    ns1:competencyDescription "Que los estudiantes hayan desarrollado aquellas habilidades de aprendizaje necesarias para emprender estudios posteriores con un alto grado de autonomía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85004416/2025-26/CE10> a ns1:Competency ;
    ns1:competencyCode "CE10" ;
    ns1:competencyDescription "Conocimiento de la teoría de automatismos y métodos de control y de su aplicación a bordo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85004416/2025-26/CE11> a ns1:Competency ;
    ns1:competencyCode "CE11" ;
    ns1:competencyDescription "Conocimiento de las características de los componentes y sistemas electrónicos y de su aplicación a bordo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85004416/2025-26/CE16> a ns1:Competency ;
    ns1:competencyCode "CE16" ;
    ns1:competencyDescription "Capacidad para la realización del cálculo y control de vibraciones y ruidos a bordo de buques y artefactos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85004416/2025-26/CE2> a ns1:Competency ;
    ns1:competencyCode "CE2" ;
    ns1:competencyDescription "Comprensión y dominio de los conceptos básicos sobre las leyes generales de la mecánica, termodinámica, campos y ondas y electromagnetismo y su aplicación para la resolución de problemas propios de la ingeniería"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85004416/2025-26/CE22> a ns1:Competency ;
    ns1:competencyCode "CE22" ;
    ns1:competencyDescription "Capacidad para proyectar sistemas hidráulicos y neumáticos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85004416/2025-26/CE9> a ns1:Competency ;
    ns1:competencyCode "CE9" ;
    ns1:competencyDescription "Conocimiento de la teoría de circuitos y de las características de las maquinas eléctricas y capacidad para realizar cálculos de sistemas en los que intervengan dichos elementos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85004416/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Capacidad para el aprendizaje de nuevos métodos y teorías, y en la versatilidad para adaptarse a nuevas situaciones basándose en los conocimientos adquiridos en materias básicas y tecnológicas propias de la Ingeniería Marítima."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85004416/2025-26/RA159> a ns1:LearningResult ;
    ns1:learningResultCode "RA159" ;
    ns1:learningResultDescription "Conocer los principales circuitos analógicos, digitales y de arquitectura de computadores para su uso en toma y gestión de señales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85004416/2025-26/RA160> a ns1:LearningResult ;
    ns1:learningResultCode "RA160" ;
    ns1:learningResultDescription "Conocer los principales tipos de sensores industriales y marinos, comprendiendo sus formas de instalación, con especial énfasis en las topologías y tecnologías de las redes de datos utilizadas a bordo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85004416/2025-26/RA161> a ns1:LearningResult ;
    ns1:learningResultCode "RA161" ;
    ns1:learningResultDescription "Manejar los circuitos básicos de acondicionamiento de señal y su uso en sistemas de instrumentación y toma de datos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85004416/2025-26/RA162> a ns1:LearningResult ;
    ns1:learningResultCode "RA162" ;
    ns1:learningResultDescription "Conocer los principios y aplicación de la instrumentación virtual"@es .

