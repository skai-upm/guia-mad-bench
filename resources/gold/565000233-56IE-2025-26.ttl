    ns1:itemIndex 15 ;
    ns1:syllabusDescription "3.3. Diagrama de momentos flectores y de esfuerzos cortantes Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000233/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "3.4. Ecuación de resistencia. Cálculo de perfiles Sin subniveles"@es .

