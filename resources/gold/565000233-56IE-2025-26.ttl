    ns1:itemIndex 13 ;
    ns1:syllabusDescription "3.1. Flexión pura. Hipótesis simplificativas. Flexión simple y flexión simétrica Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000233/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "3.2. Distribución de tensiones normales: Ley de Navier. Tensiones tangenciales Sin subniveles"@es .

