    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/595000134/2025-26/eventSchedule> ;
    schema:description "Esta asignatura aborda el funcionamiento, diseño, medición y manejo de los transductores electroacústicos (micrófonos y altavoces profesionales) y de los sistemas de conexionado, procesamiento y amplificación relacionados con los mismos. También se estudian las teorías acústicas básicas relacionadas con el refuerzo sonoro en espacios, abiertos o cerrados, y se analiza el campo sonoro dentro de un local. Por otra parte, se estudia el diseño y las herramientas de diseño, el ajuste y la medición de los sistemas de refuerzo sonoro, así como la familiarización con las instalaciones y sonorizaciones tipo existentes. Por último, el alumno debe llevar a cabo un proyecto de refuerzo sonoro de un local."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/joseluis.sanchez.bote%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/francisco.aznar%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/joseluis.sanchez.bote%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/r.fraile%40upm.es> ;
    schema:name "Sistemas Electroacusticos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000134/2025-26/CE%20SO04> a ns1:Competency ;
    ns1:competencyCode "CE SO04" ;
    ns1:competencyDescription "Capacidad para realizar proyectos de ingeniería acústica sobre: aislamiento y acondicionamiento acústico de locales; instalaciones de megafonía; especificación, análisis y selección de transductores electroacústicos; sistemas de medida, análisis y control de ruido y vibraciones; acústica medioambiental; sistemas de acústica submarina."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000134/2025-26/CE%20TEL09> a ns1:Competency ;
    ns1:competencyCode "CE TEL09" ;
    ns1:competencyDescription "Capacidad para comprender los mecanismos de propagación y transmisión de ondas electromagnéticas y acústicas, y sus correspondientes dispositivos emisores y receptores."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000134/2025-26/CG%2002> a ns1:Competency ;
    ns1:competencyCode "CG 02" ;
    ns1:competencyDescription "Capacidad de búsqueda y selección de información, de razonamiento crítico y de elaboración y defensa de argumentos dentro del área."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000134/2025-26/CG%2004> a ns1:Competency ;
    ns1:competencyCode "CG 04" ;
    ns1:competencyDescription "Capacidad de abstracción, de análisis y de síntesis y de resolución de problemas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000134/2025-26/CG%2010> a ns1:Competency ;
    ns1:competencyCode "CG 10" ;
    ns1:competencyDescription "Capacidad para manejar especificaciones, reglamentos y normativas y la aplicación de las mismas en el desarrollo de la profesión."@es .

