    ns1:learningResultCode "RA267" ;
    ns1:learningResultDescription "8. Modelar problemas físicos a través de ecuaciones diferenciales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35001204/2025-26/RA268> a ns1:LearningResult ;
