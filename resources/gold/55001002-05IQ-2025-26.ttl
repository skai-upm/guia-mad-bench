<https://guia-kg.skai.etsisi.upm.es/resource/55001002/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Espacios vectoriales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001002/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Números complejos: aritmética básica. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001002/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "3.1. Producto escalar y norma asociada. Desigualdades de Cauchy-Schwarz y triangular. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001002/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "3.2. Ortogonalidad. El suplementario ortogonal. El teorema de la proyección ortogonal. El método de ortonormalización de Gram-Schmidt. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001002/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "3.3. Transformaciones ortogonales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001002/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "3.3.1. Matriz de proyección ortogonal y problema de mínimos cuadrados. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001002/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "3.3.2. Simetrías y giros. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001002/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "4. Diagonalización."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001002/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "4.1. Semejanza de matrices. Matrices diagonalizables. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001002/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "4.2. Valores y vectores propios. Polinomio característico. Diagonalización. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001002/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "5. Formas bilineales y cuadráticas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001002/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "5.1. Representación matricial. Congruencia de matrices. Formas bilineales simétricas: reducción a suma de cuadrados. Ley de inercia de Sylvester. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001002/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Espacios vectoriales reales y complejos. Subespacios vectoriales. Intersección y suma. Suma directa. Subespacios suplementarios. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001002/2025-26/syllabus/20> a ns1:SyllabusItem ;
    ns1:itemIndex 20 ;
    ns1:syllabusDescription "5.2. Diagonalización ortogonal de matrices simétricas. Cociente de Rayleigh. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001002/2025-26/syllabus/21> a ns1:SyllabusItem ;
    ns1:itemIndex 21 ;
    ns1:syllabusDescription "5.3. Clasificación de formas cuadráticas. Criterio de Sylvester. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001002/2025-26/syllabus/22> a ns1:SyllabusItem ;
    ns1:itemIndex 22 ;
    ns1:syllabusDescription "6. Algunas aplicaciones del Álgebra Lineal."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001002/2025-26/syllabus/23> a ns1:SyllabusItem ;
    ns1:itemIndex 23 ;
    ns1:syllabusDescription "6.1. Número de condición espectral de una matriz: acotación de errores. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001002/2025-26/syllabus/24> a ns1:SyllabusItem ;
    ns1:itemIndex 24 ;
    ns1:syllabusDescription "6.2. Clasificación de cónicas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001002/2025-26/syllabus/25> a ns1:SyllabusItem ;
    ns1:itemIndex 25 ;
    ns1:syllabusDescription "6.3. Sistemas de ecuaciones diferenciales lineales de primer orden homogéneos con coeficientes constantes. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001002/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "1.3. Combinaciones lineales. Clausura lineal. Dependencia e independencia lineal. Generadores y bases. Dimensión. La relación de Grassmann. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001002/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "2. Matrices y sistemas lineales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001002/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "2.1. Matrices. Aplicaciones lineales. Composición de aplicaciones lineales y producto matricial. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001002/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "2.2. Imagen y núcleo de una matriz. Rango. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001002/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "2.3. Matriz de cambio de base. Matriz de una aplicación respecto a una base. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001002/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "2.4. Sistemas lineales. Estructura de las soluciones. Teorema de Rouché-Frobenius. Resolución de sistemas por reducción gaussiana. Factorización LU. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55001002/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "3. El espacio vectorial euclídeo."@es .

