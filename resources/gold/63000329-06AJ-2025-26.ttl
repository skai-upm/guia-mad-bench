    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/63000329/2025-26/eventSchedule> ;
    schema:description "En esta asignatura el alumno conocerá el marco teórico de la mecánica aplicada a cuerpos o materias, entendidos como un medio continuo, que se deforman bajo el efecto de las fuerzas ejercidas sobre ellos. Se estudian los movimientos, las deformaciones y las tensiones que experimentan, junto con su descripción matemática, y las ecuaciones que gobiernan su interrelación y el comportamiento mecánico del medio. La puesta en práctica de estos conocimientos se realizará a través de un proyecto de modelización mediante un programa de elementos finitos."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/josejoaquin.ortega%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/jose.merodo%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/josejoaquin.ortega%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/tasio.santos%40upm.es> ;
    schema:name "Mecánica de Medios Continuos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000329/2025-26/CB06> a ns1:Competency ;
    ns1:competencyCode "CB06" ;
    ns1:competencyDescription "Poseer y comprender conocimientos que aporten una base u oportunidad de ser originales en el desarrollo y/o aplicación de ideas, a menudo en un contexto de investigación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000329/2025-26/CB07> a ns1:Competency ;
    ns1:competencyCode "CB07" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en entornos nuevos o poco conocidos dentro de contextos más amplios (o multidisciplinares) relacionados con su área de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000329/2025-26/CB08> a ns1:Competency ;
    ns1:competencyCode "CB08" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de integrar conocimientos y enfrentarse a la complejidad de formular juicios a partir de una información que, siendo incompleta o limitada, incluya reflexiones sobre las responsabilidades sociales y éticas vinculadas a la aplicación de sus conocimientos y juicios"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000329/2025-26/CB09> a ns1:Competency ;
    ns1:competencyCode "CB09" ;
    ns1:competencyDescription "Que los estudiantes sepan comunicar sus conclusiones y los conocimientos y razones últimas que las sustentan a públicos especializados y no especializados de un modo claro y sin ambigüedades"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000329/2025-26/CB10> a ns1:Competency ;
    ns1:competencyCode "CB10" ;
    ns1:competencyDescription "Que los estudiantes posean las habilidades de aprendizaje que les permitan continuar estudiando de un modo que habrá de ser en gran medida autodirigido o autónomo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000329/2025-26/CE07> a ns1:Competency ;
    ns1:competencyCode "CE07" ;
    ns1:competencyDescription "Conocer los principìos básicos de los medios continuos y sus deformaciones, analizando el comportamiento 2D y 3D de materiales elásticos, inelásticos y reológicos; aplicar la mecánica de medios continuos a problemas geológicos y simularla mediante elementos finitos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000329/2025-26/CE12> a ns1:Competency ;
    ns1:competencyCode "CE12" ;
    ns1:competencyDescription "Capacidad de realizar un trabajo o proyecto integrando y relacionando las competencias adquiridas en las distintas asignaturas del máster, junto con la capacidad de defenderlo en público ante un grupo de personas expertas en el tema del trabajo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000329/2025-26/CG01> a ns1:Competency ;
    ns1:competencyCode "CG01" ;
    ns1:competencyDescription "Capacidad para aplicar los conocimientos teóricos y prácticos adquiridos a lo largo del Máster para resolver problemas concretos relacionados con la Ingeniería Geológica y la Geotecnia en cualquier tipo de proyectos, incluidos aquellos que presentan problemas nuevos o afectan a entornos o medios poco conocidos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000329/2025-26/CG03> a ns1:Competency ;
    ns1:competencyCode "CG03" ;
    ns1:competencyDescription "Capacidad para adquirir habilidades y predisposición para el aprendizaje autónomo o dirigido en Ingeniería Geológica que permitan la formación continua, ya sea en el ámbito de la investigación (Doctorado) o del perfeccionamiento profesional."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000329/2025-26/CT01> a ns1:Competency ;
    ns1:competencyCode "CT01" ;
    ns1:competencyDescription "Capacidad de uso de la lengua inglesa para el trabajo en contextos internacionales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000329/2025-26/CT03> a ns1:Competency ;
    ns1:competencyCode "CT03" ;
    ns1:competencyDescription "Creatividad, iniciativa y capacidad emprendedora."@es .

