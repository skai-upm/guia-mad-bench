<https://guia-kg.skai.etsisi.upm.es/resource/65004018/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Componentes de los circuitos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004018/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Variables eléctricas fundamentales. Simbología. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004018/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "2.1. Resolución de circuitos en corriente continua. Aplicación de las leyes de Kirchhoff. Planteamiento de las ecuaciones. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004018/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "2.2. Circuitos equivalentes de Thevenin y de Norton, rendimiento y máxima potencia transferida. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004018/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "2.3. Medida de magnitudes eléctricas en corriente continua Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004018/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "3. Análisis de los circuitos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004018/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "3.1. Funciones excitación. Expresión operacional Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004018/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "3.2. Funciones periódicas. Valor medio y eficaz. Factor de forma Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004018/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "3.3. Planteamiento y resolución de las ecuaciones de los circuitos. Respuesta transitoria y estacionaria Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004018/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "3.4. Aplicación del cálculo operacional. Función de transferencia. Interpretación Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004018/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "4. Circuitos en corriente alterna"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004018/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "4.1. Fuentes de tensión y corriente senoidales. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004018/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Modelos y ecuaciones para los componentes pasivos de dos terminales eléctricos: resistencia, inductancia y capacidad. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004018/2025-26/syllabus/20> a ns1:SyllabusItem ;
    ns1:itemIndex 20 ;
    ns1:syllabusDescription "4.2. Ecuaciones en régimen estacionario senoidal. Cálculo simbólico. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004018/2025-26/syllabus/21> a ns1:SyllabusItem ;
    ns1:itemIndex 21 ;
    ns1:syllabusDescription "4.3. Representación vectorial de las magnitudes eléctricas. Impedancia y admitancia complejas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004018/2025-26/syllabus/22> a ns1:SyllabusItem ;
    ns1:itemIndex 22 ;
    ns1:syllabusDescription "4.4. Potencia en circuitos eléctricos en corriente alterna. Conceptos de potencia activa, reactiva y aparente. Factor de potencia y su compensación. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004018/2025-26/syllabus/23> a ns1:SyllabusItem ;
    ns1:itemIndex 23 ;
    ns1:syllabusDescription "4.5. Medida de magnitudes eléctricas. Medida de potencia y de la energía eléctrica. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004018/2025-26/syllabus/24> a ns1:SyllabusItem ;
    ns1:itemIndex 24 ;
    ns1:syllabusDescription "4.6. Planteamiento y resolución de circuitos en corriente alterna. Efectos térmicos de la electricidad, modelo matemático e interpretación Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004018/2025-26/syllabus/25> a ns1:SyllabusItem ;
    ns1:itemIndex 25 ;
    ns1:syllabusDescription "5. Circuitos trifásicos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004018/2025-26/syllabus/26> a ns1:SyllabusItem ;
    ns1:itemIndex 26 ;
    ns1:syllabusDescription "5.1. Circuitos trifásicos: equilibrados y no equilibrados. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004018/2025-26/syllabus/27> a ns1:SyllabusItem ;
    ns1:itemIndex 27 ;
    ns1:syllabusDescription "5.2. Conexiones: estrella y triángulo. Magnitudes simples y compuestas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004018/2025-26/syllabus/28> a ns1:SyllabusItem ;
    ns1:itemIndex 28 ;
    ns1:syllabusDescription "5.3. Potencia y energía en circuitos trifásicos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004018/2025-26/syllabus/29> a ns1:SyllabusItem ;
    ns1:itemIndex 29 ;
    ns1:syllabusDescription "5.4. Medida de magnitudes eléctricas en circuitos monofásicos y trifásicos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004018/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "1.3. Modelos y ecuaciones para los componentes pasivos de cuatro terminales eléctricos: bobinas acopladas, el transformador ideal. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004018/2025-26/syllabus/30> a ns1:SyllabusItem ;
    ns1:itemIndex 30 ;
    ns1:syllabusDescription "5.5. Circuito monofásico equivalente. Resolución de circuitos trifásicos equilibrados. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004018/2025-26/syllabus/31> a ns1:SyllabusItem ;
    ns1:itemIndex 31 ;
    ns1:syllabusDescription "5.6. Transformador trifásico de potencia. Circuito monofásico equivalente Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004018/2025-26/syllabus/32> a ns1:SyllabusItem ;
    ns1:itemIndex 32 ;
    ns1:syllabusDescription "5.7. Resolución de circuitos trifásicos con transformadores. Rendimiento de transformadores. Sin subniveles"@es .

