    ns1:otherInformation """La plataforma Moodle será el canal oficial de comunicación con los profesores y la plataforma de entrega de tareas y de documentación.
En caso de que los acontecimientos obligasen a realizar clases no presenciales, se realizarían sesiones a través de la plataforma TEAMS o similar."""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
