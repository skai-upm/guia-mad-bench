<https://guia-kg.skai.etsisi.upm.es/resource/23000388/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/23000388/2025-26/C10>,
        <https://guia-kg.skai.etsisi.upm.es/resource/23000388/2025-26/K8>,
