    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/123000728/2025-26/eventSchedule> ;
    schema:description """Descripción de la asignatura:
Asignatura dedicada a la topografía de infraestructuras y superestructuras, con estudio detallado de carreteras, ferrocarriles, túneles, aeropuertos y edificios.
Técnicas de replanteo. Conocimientos básicos de los trabajos con BIM"""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/juanf.prieto%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/antonio.mora-rey%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/juanf.prieto%40upm.es> ;
    schema:name "Ingeniería Geodésica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/123000728/2025-26/CB9> a ns1:Competency ;
    ns1:competencyCode "CB9" ;
    ns1:competencyDescription "Que los estudiantes sepan comunicar sus conclusiones y los conocimientos y razones últimas que las sustentan a públicos especializados y no especializados de un modo claro y sin ambigüedades"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/123000728/2025-26/CE10> a ns1:Competency ;
    ns1:competencyCode "CE10" ;
    ns1:competencyDescription "Aplicar los métodos existentes de diseño de control de infraestructuras de ingeniería civil y arquitectura, así como su desarrollo con equipos multidisciplinares."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/123000728/2025-26/CE5> a ns1:Competency ;
    ns1:competencyCode "CE5" ;
    ns1:competencyDescription "Realizar proyectos utilizando tecnologías avanzadas de adquisición, representación, visualización y gestión de infraestructuras de datos del territorio, y de su ordenación urbanística, rural y patrimonial."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/123000728/2025-26/CG5> a ns1:Competency ;
    ns1:competencyCode "CG5" ;
    ns1:competencyDescription "Desarrollar la capacidad de razonamiento, dominar y aplicar en la práctica los conocimientos avanzados en Geodesia, Fotogrametría y Teledetección y Cartografía."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/123000728/2025-26/CT3> a ns1:Competency ;
    ns1:competencyCode "CT3" ;
    ns1:competencyDescription "Ser capaz de resolver de forma nueva y original situaciones o problemas en el ámbito de la Ingeniería (Creatividad)."@es .

