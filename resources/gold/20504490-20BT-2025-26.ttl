    ns1:courseType "Optativa"@es ;
    ns1:courseYear 4 ;
    ns1:semester "Séptimo semestre"@es ;
    schema:courseCode 20504490 ;
    schema:hasCourseInstance <https://guia-kg.skai.etsisi.upm.es/resource/20504490/2025-26> ;
    schema:name "Statistics For Bioinformatics"@en,
        "Estadística para Bioinformática"@es ;
    schema:numberOfCredits 4.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/20504490/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/20504490/2025-26/CB05>,
        <https://guia-kg.skai.etsisi.upm.es/resource/20504490/2025-26/CE12> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/20504490/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/20504490/2025-26/didactic_resource/2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/20504490/2025-26/didactic_resource/3> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/20504490/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/20504490/2025-26/RA43>,
        <https://guia-kg.skai.etsisi.upm.es/resource/20504490/2025-26/RA44>,
        <https://guia-kg.skai.etsisi.upm.es/resource/20504490/2025-26/RA45>,
        <https://guia-kg.skai.etsisi.upm.es/resource/20504490/2025-26/RA46> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/20504490/2025-26/syllabus> ;
    ns1:inpersonHours "34 horas y 30 minutos (33.2%)"@es ;
    ns1:numberOfCredits 4.0 ;
    ns1:otherInformation ""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "34 horas y 30 minutos"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/20504490/2025-26/eventSchedule> ;
    schema:description """Esta asignatura, por una parte, profundiza y consolida las bases estadísticas de los métodos bioinformáticos, y por otra, ofrece conocimientos prácticos de programación necesarios para el acceso y análisis de bases de datos biológicos.
Este curso proporciona una introducción a los métodos estadísticos comúnmente utilizados en la bioinformática. El curso revisa brevemente el cálculo de probabilidades básico, las variables aleatorias, las distribuciones de probabilidad e inferencia estadística. Luego se procede a temas más específicos de la investigación bioinformática, incluyendo cadenas de Markov, modelos ocultos de Markov. Los estudiantes aprenderán los principios de estos métodos estadísticos y cómo se pueden aplicar para analizar secuencias y datos biológicos."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/miguel.ibanez%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/miguel.ibanez%40upm.es> ;
    schema:name "Estadística para Bioinformática"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504490/2025-26/CB05> a ns1:Competency ;
    ns1:competencyCode "CB05" ;
    ns1:competencyDescription "Que los estudiantes hayan desarrollado aquellas habilidades de aprendizaje necesarias para emprender estudios posteriores con un alto grado de autonomía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504490/2025-26/CE12> a ns1:Competency ;
    ns1:competencyCode "CE12" ;
    ns1:competencyDescription "Ser capaz de conocer y aplicar procedimientos computacionales para el análisis de las secuencias biológicas y la construcción de modelos de sistemas biológicos a diferentes niveles de complejidad."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504490/2025-26/RA43> a ns1:LearningResult ;
    ns1:learningResultCode "RA43" ;
    ns1:learningResultDescription "Manejar e integrar el sofftware existente para el análisis de secuencias biológicas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504490/2025-26/RA44> a ns1:LearningResult ;
    ns1:learningResultCode "RA44" ;
    ns1:learningResultDescription "Conocer los fundamentos estadísticos de los principales métodos de tratamientos de secuencias biológicas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504490/2025-26/RA45> a ns1:LearningResult ;
    ns1:learningResultCode "RA45" ;
    ns1:learningResultDescription "Adquirir la capacidad de escribir scripts para el análisis automatizado de secuencias biológicas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504490/2025-26/RA46> a ns1:LearningResult ;
    ns1:learningResultCode "RA46" ;
    ns1:learningResultDescription "Conocer los fundamentos estadísticos y saber aplicarlos al análisis de microarrays y RNA"@es .

