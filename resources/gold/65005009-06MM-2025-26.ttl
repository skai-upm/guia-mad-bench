        <https://guia-kg.skai.etsisi.upm.es/resource/65005009/2025-26/didactic_resource/5>,
        <https://guia-kg.skai.etsisi.upm.es/resource/65005009/2025-26/didactic_resource/6> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/65005009/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/65005009/2025-26/RA92>,
        <https://guia-kg.skai.etsisi.upm.es/resource/65005009/2025-26/RA93>,
        <https://guia-kg.skai.etsisi.upm.es/resource/65005009/2025-26/RA94>,
        <https://guia-kg.skai.etsisi.upm.es/resource/65005009/2025-26/RA95>,
        <https://guia-kg.skai.etsisi.upm.es/resource/65005009/2025-26/RA96> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/65005009/2025-26/syllabus> ;
    ns1:inpersonHours "50 horas (42.7%)"@es ;
    ns1:numberOfCredits 4.5 ;
    ns1:otherInformation """La asignatura se relaciona con el ODS9 y el ODS12
En caso de tener que impartir docencia no presencial se utilizará la plataforma TEAMS para la impartición de las clases y tutorías. Las tutorías pueden ser acordadas con el profesor mediante correo electrónico.
El profesor solo puede atender a un máximo de 10 alumnos en las prácticas de laboratorio."""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "50 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/65005009/2025-26/eventSchedule> ;
    schema:description "La asignatura pretende recoger los principios elementales de la Ingeniería de la Ingeniería de la Corrosión, desde los fundamentos teóricos hasta una aplicación práctica de procesos de selección materiales y métodos de protección frente a condiciones de servicio concretas."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/josemanuel.ruizr%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/josemanuel.ruizr%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/luis.gcambronero%40upm.es> ;
    schema:name "Ingeniería de la Corrosión"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65005009/2025-26/C12> a ns1:Competency ;
    ns1:competencyCode "C12" ;
    ns1:competencyDescription "Utilizar metodologías de mejora de la sostenibilidad mediante la Ingeniería de la Corrosión. TIPO: Competencias"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65005009/2025-26/C9> a ns1:Competency ;
    ns1:competencyCode "C9" ;
    ns1:competencyDescription "Aplicar la tecnología del tratamiento de superficies y soldaduras. TIPO: Competencias"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65005009/2025-26/CON14> a ns1:Competency ;
    ns1:competencyCode "CON14" ;
    ns1:competencyDescription "Capacidad para conocer, comprender y utilizar los principios de la ingeniería mineralúrgica, metalúrgica y de la Tecnología de Materiales.TIPO: Conocimientos o contenidos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65005009/2025-26/HAB6> a ns1:Competency ;
    ns1:competencyCode "HAB6" ;
    ns1:competencyDescription "Capacidad para aplicar metodologías de estudios y evaluaciones de impacto ambiental y, en general, de tecnologías ambientales, sostenibilidad y tratamiento de residuos. TIPO: Habilidades o destrezas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65005009/2025-26/HAB8> a ns1:Competency ;
    ns1:competencyCode "HAB8" ;
    ns1:competencyDescription "Aplicar los conocimientos adquiridos para identificar, formular y resolver problemas dentro de contextos amplios y multidisciplinarios, siendo capaces de integrar conocimientos, trabajando en equipos multidisciplinares. TIPO: Habilidades o destrezas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65005009/2025-26/HAB9> a ns1:Competency ;
    ns1:competencyCode "HAB9" ;
    ns1:competencyDescription "Saber comunicar los conocimientos y conclusiones, tanto de forma oral, escrita y gráfica, a públicos especializados y no especializados de un modo claro y sin ambigüedades. TIPO: Habilidades o destrezas"@es .

