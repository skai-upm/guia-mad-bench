<https://guia-kg.skai.etsisi.upm.es/resource/145016001/2025-26/CE04> a ns1:Competency ;
    ns1:competencyCode "CE04" ;
    ns1:competencyDescription "Conocimiento adecuado del concepto de empresa, marco institucional y jurídico de la empresa. Organización y gestión de empresas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145016001/2025-26/CE11> a ns1:Competency ;
    ns1:competencyCode "CE11" ;
    ns1:competencyDescription "Conocimiento de las diferentes actividades en el sector aeroespacial y sus correspondencia con las especialidades de la titulación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145016001/2025-26/CG04> a ns1:Competency ;
    ns1:competencyCode "CG04" ;
    ns1:competencyDescription "Capacidad para analizar implicaciones económicas, administrativas, sociales o medioambientales ligadas a la aplicación de nuevos conceptos y técnicas en el ámbito de la Gestión y Operación del Transporte Aéreo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145016001/2025-26/CG05> a ns1:Competency ;
