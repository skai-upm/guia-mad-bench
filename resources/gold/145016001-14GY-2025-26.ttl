    ns1:competencyDescription "Capacidad para la búsqueda y utilización de la normativa y reglamentación relativa a su ámbito de actuación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145016001/2025-26/CG06> a ns1:Competency ;
    ns1:competencyCode "CG06" ;
    ns1:competencyDescription "Capacidad para la gestión y dirección de organizaciones relacionadas con los procesos del transporte aéreo"@es .

