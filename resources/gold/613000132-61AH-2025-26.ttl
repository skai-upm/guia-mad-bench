    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/613000132/2025-26/eventSchedule> ;
    schema:description "Esta asignatura aborda la intersección entre el aprendizaje automático y la ciberseguridad. La asignatura trata ambos temas desde dos perspectivas principales: la utilización del aprendizaje automático en el ámbito de la ciberseguridad y la incorporación de fundamentos de seguridad de la información en las propias tareas de aprendizaje automático. En particular, se tratarán diversos problemas en el ámbito de la ciberseguridad que pueden ser abordados mediante la utilización de técnicas de aprendizaje automático como la detección de intrusiones o malware. Además, la asignatura también revisará como los requisitos de seguridad y privacidad pueden afectar a las tareas de aprendizaje automático."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/jorge.blasco.alis%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/jorge.blasco.alis%40upm.es> ;
    schema:name "Seguridad y Privacidad de los Datos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000132/2025-26/CB10> a ns1:Competency ;
    ns1:competencyCode "CB10" ;
    ns1:competencyDescription "Que los estudiantes posean las habilidades de aprendizaje que les permitan continuar estudiando de un modo que habrá de ser en gran medida autodirigido o autónomo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000132/2025-26/CB6> a ns1:Competency ;
    ns1:competencyCode "CB6" ;
    ns1:competencyDescription "Poseer y comprender conocimientos que aporten una base u oportunidad de ser originales en el desarrollo y/o aplicación de ideas, a menudo en un contexto de investigación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000132/2025-26/CB7> a ns1:Competency ;
    ns1:competencyCode "CB7" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en entornos nuevos o poco conocidos dentro de contextos más amplios (o multidisciplinares) relacionados con su área de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000132/2025-26/CB8> a ns1:Competency ;
    ns1:competencyCode "CB8" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de integrar conocimientos y enfrentarse a la complejidad de formular juicios a partir de una información que, siendo incompleta o limitada, incluya reflexiones sobre las responsabilidades sociales y éticas vinculadas a la aplicación de sus conocimientos y juicios"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000132/2025-26/CB9> a ns1:Competency ;
    ns1:competencyCode "CB9" ;
    ns1:competencyDescription "Que los estudiantes sepan comunicar sus conclusiones y los conocimientos y razones últimas que las sustentan a públicos especializados y no especializados de un modo claro y sin ambigüedades"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000132/2025-26/CE09> a ns1:Competency ;
    ns1:competencyCode "CE09" ;
    ns1:competencyDescription "Entender y valorar las implicaciones éticas, legales y sociales de la inteligencia artificial, así como la seguridad y privacidad de los datos masivos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000132/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Capacidad para aplicar el método científico y saber organizar y planificar experimentos con rigor metodológico en el ámbito del aprendizaje automático y los datos masivos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000132/2025-26/CG2> a ns1:Competency ;
    ns1:competencyCode "CG2" ;
    ns1:competencyDescription "Participar en la aplicación de mecanismos de descripción, cuantificación, análisis, interpretación y evaluación de resultados experimentales del ámbito de los datos masivos y el aprendizaje automático"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000132/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Capacidad para reunir e interpretar datos masivos relevantes para emitir juicios que incluyan una reflexión sobre temas importantes de índole científico, social o ético en el ámbito del aprendizaje automático y los datos masivos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000132/2025-26/CG4> a ns1:Competency ;
    ns1:competencyCode "CG4" ;
    ns1:competencyDescription "Capacidad de aplicar iniciativa, integración, colaboración y potenciación de la discusión crítica en el ámbito del trabajo en equipo dentro del ámbito del aprendizaje automático y datos masivos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000132/2025-26/CG5> a ns1:Competency ;
    ns1:competencyCode "CG5" ;
    ns1:competencyDescription "Participar en la transmisión de la información generada, las ideas, los problemas y las soluciones de forma oral y escrita para un público tanto especializado como no especializado"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000132/2025-26/CT1> a ns1:Competency ;
    ns1:competencyCode "CT1" ;
    ns1:competencyDescription "Creatividad"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000132/2025-26/CT2> a ns1:Competency ;
    ns1:competencyCode "CT2" ;
    ns1:competencyDescription "Organización y planificación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000132/2025-26/CT3> a ns1:Competency ;
    ns1:competencyCode "CT3" ;
    ns1:competencyDescription "Gestión de la información"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000132/2025-26/CT4> a ns1:Competency ;
    ns1:competencyCode "CT4" ;
    ns1:competencyDescription "Liderazgo de equipos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000132/2025-26/CT5> a ns1:Competency ;
    ns1:competencyCode "CT5" ;
    ns1:competencyDescription "Trabajo en contextos internacionales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000132/2025-26/K05> a ns1:Competency ;
    ns1:competencyCode "K05" ;
    ns1:competencyDescription "El alumno analiza las distintas arquitecturas para el almacenamiento y procesado de datos masivos de altas prestaciones"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000132/2025-26/RA33> a ns1:LearningResult ;
    ns1:learningResultCode "RA33" ;
    ns1:learningResultDescription "Conocer y evaluar las técnicas para proteger los sistemas informáticos frente a ataques y software malintencionado"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000132/2025-26/RA34> a ns1:LearningResult ;
    ns1:learningResultCode "RA34" ;
    ns1:learningResultDescription "· Dominar los principales criptosistemas y los algoritmos de cifrado actuales más característicos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000132/2025-26/RA35> a ns1:LearningResult ;
    ns1:learningResultCode "RA35" ;
    ns1:learningResultDescription "· Conocer y aplicar procedimientos de anonimización de datos personales y sensibles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000132/2025-26/RA36> a ns1:LearningResult ;
    ns1:learningResultCode "RA36" ;
    ns1:learningResultDescription "· Analizar riesgos de pérdida de privacidad y robo de información y diseñar las soluciones adecuadas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000132/2025-26/S02> a ns1:Competency ;
    ns1:competencyCode "S02" ;
    ns1:competencyDescription "El alumno planifica y ejecuta la gestión y el despliegue de infraestructuras de datos masivos"@es .

