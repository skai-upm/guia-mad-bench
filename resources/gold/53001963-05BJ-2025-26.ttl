    schema:hasCourseInstance <https://guia-kg.skai.etsisi.upm.es/resource/53001963/2025-26> ;
    schema:name "Basis For Prevention Of Environmental Pollution"@en,
        "Fundamentos para la Prevención de la Contaminación Ambiental"@es ;
    schema:numberOfCredits 3.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/53001963/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/53001963/2025-26/CE01>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001963/2025-26/CE02>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001963/2025-26/CE05>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001963/2025-26/CE08>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001963/2025-26/CG01>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001963/2025-26/CT01>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001963/2025-26/CT05> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/53001963/2025-26/didactic_resource/1> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/53001963/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/53001963/2025-26/RA16>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001963/2025-26/RA21>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001963/2025-26/RA24>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001963/2025-26/RA26>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001963/2025-26/RA36> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/53001963/2025-26/syllabus> ;
    ns1:inpersonHours "35 horas (44.9%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation """Se recomienda a los alumnos llevar un seguimiento continuo de la asignatura dedicando el tiempo suficiente (desde el inicio de las clases) a repasar la teoría y los ejercicios realizados en clase.
La información que se muestra en esta guía podrá sufrir pequeñas modificaciones una vez se defina el Plan de Organización docente definitivo o por motivos de actualización del temario. Cualquier modificación que se produzca será recogida en el Tema 0 de la asignatura y convenientemente explicada al inicio del curso.
La asignatura se impartirá de manera PRESENCIAL.
De forma general, los temas de la asignatura y cualquier otra documentación de interés se subirán a la plataforma moodle. Dicha plataforma también será utilizada como vía principal de comunicación con los alumnos.
Esta asignatura, debido a lo amplio de su temario, está alineada con numerosos Objetivos de Desarrollo Sostenible (ODS), entre los que destacan, entre otros:
- ODS 6: Agua limpia y saneamiento
- ODS 7: Energía asequible y no contaminante
- ODS 12: Producción y consumo responsables
- ODS 13: Acción por el clima"""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "35 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/53001963/2025-26/eventSchedule> ;
    schema:description "La asignatura se divide en 2 grandes bloques y esos bloques son liberables y también recuperables el día reservado para el examen global. El bloque 1 está constituido por los temas 1 a 3, y el bloque 2 constituido por los temas 4 a 6. Cada prueba de evaluación intermedia escrita, permite liberar cada bloque, si se llega a la calificación mínima de 4 puntos sobre 10."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/juanmanuel.deandres%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/jorge.rodriguez.chueca%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/juanmanuel.deandres%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/julio.lumbreras%40upm.es> ;
    schema:name "Fundamentos para la Prevención de la Contaminación Ambiental"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001963/2025-26/CE01> a ns1:Competency ;
    ns1:competencyCode "CE01" ;
    ns1:competencyDescription "Capacidad para aplicar técnicas numéricas a la modelización, cuantificación de impactos y resolución de problemas de calidad y gestión de aire, agua y suelos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001963/2025-26/CE02> a ns1:Competency ;
    ns1:competencyCode "CE02" ;
    ns1:competencyDescription "Habilidad para profundizar en los conocimientos relativos a la emisión y dispersión de contaminantes atmosféricos y sus impactos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001963/2025-26/CE05> a ns1:Competency ;
    ns1:competencyCode "CE05" ;
    ns1:competencyDescription "Capacidad para adquirir conocimientos adecuados para aplicar las mejores técnicas disponibles en la gestión del agua, incluyendo su evaluación y gestión."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001963/2025-26/CE08> a ns1:Competency ;
    ns1:competencyCode "CE08" ;
    ns1:competencyDescription "Capacidad de comprensión y dominio de la legislación y normativa nacional e internacional y su aplicación para la resolución de problemas propios de la ingeniería ambiental."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001963/2025-26/CG01> a ns1:Competency ;
    ns1:competencyCode "CG01" ;
    ns1:competencyDescription "Capacidad de analizar, evaluar y sintetizar algunas ideas nuevas y complejas de una manera crítica en la rama de la ingeniería ambiental."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001963/2025-26/CT01> a ns1:Competency ;
    ns1:competencyCode "CT01" ;
    ns1:competencyDescription "Aplica. Habilidad para aplicar conocimientos científicos, matemáticos y tecnológicos en sistemas relacionados con la práctica de la ingeniería ambiental."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001963/2025-26/CT05> a ns1:Competency ;
    ns1:competencyCode "CT05" ;
    ns1:competencyDescription "Resuelve. Habilidad para identificar, formular y resolver problemas de ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001963/2025-26/RA16> a ns1:LearningResult ;
    ns1:learningResultCode "RA16" ;
    ns1:learningResultDescription "Ser capaz de aplicar técnicas para la valorización energética de los residuos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001963/2025-26/RA21> a ns1:LearningResult ;
    ns1:learningResultCode "RA21" ;
    ns1:learningResultDescription "Estar en disposición de evaluar los impactos ambientales de las diferentes alternativas de gestión del agua"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001963/2025-26/RA24> a ns1:LearningResult ;
    ns1:learningResultCode "RA24" ;
    ns1:learningResultDescription "Conocer el contexto multidisciplinar de la asignatura."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001963/2025-26/RA26> a ns1:LearningResult ;
    ns1:learningResultCode "RA26" ;
    ns1:learningResultDescription "Evaluación de la calidad de los diferentes tipos de aguas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001963/2025-26/RA36> a ns1:LearningResult ;
    ns1:learningResultCode "RA36" ;
    ns1:learningResultDescription "Identificar, formular y resolver problemas de ingeniería."@es .

