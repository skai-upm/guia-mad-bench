    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/55000202/2025-26/syllabus> ;
    ns1:inpersonHours "39 horas y 30 minutos (50.6%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation "La asignatura está muy relacionada con el ODS 7: Energía Asequible y no contaminante."@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "39 horas y 30 minutos"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/55000202/2025-26/eventSchedule> ;
    schema:description "La asignatura cubre los principios básicos de la electrónica de potencia, en especial los circuitos para la transformación de la energía eléctrica. El curso aborda tanto los elementos específicos que se utilizan como elementos pasivos y semiconductores de potencia como las topologías para transformar la energía entre alterna y continua. Se incluye un capítulo para tratar aplicaciones industriales reales donde se ponen en práctica los conocimientos aprendidos sobre circuitos."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/regina.ramos%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/regina.ramos%40upm.es> ;
    schema:name "Electronica Industrial"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000202/2025-26/CE25B> a ns1:Competency ;
    ns1:competencyCode "CE25B" ;
    ns1:competencyDescription "Conocimiento sobre sistemas eléctricos de potencia y sus aplicaciones."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000202/2025-26/CE27B> a ns1:Competency ;
    ns1:competencyCode "CE27B" ;
    ns1:competencyDescription "Conocimiento aplicado de la electrónica de potencia."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000202/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Conocer y aplicar conocimientos de ciencias y tecnologías básicas a la práctica de la Ingeniería Industrial."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000202/2025-26/CG2> a ns1:Competency ;
    ns1:competencyCode "CG2" ;
    ns1:competencyDescription "Poseer capacidad para diseñar, desarrollar, implementar, gestionar y mejorar productos, sistemas y procesos en los distintos ámbitos industriales, usando técnicas analíticas, computacionales o experimentales apropiadas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000202/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Aplicar los conocimientos adquiridos para identificar, formular y resolver problemas dentro de contextos amplios y multidisciplinarios, siendo capaces de integrar conocimientos, trabajando en equipos multidisciplinares."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000202/2025-26/CG4> a ns1:Competency ;
    ns1:competencyCode "CG4" ;
    ns1:competencyDescription "Comprender el impacto de la ingeniería industrial en el medio ambiente, el desarrollo sostenible de la sociedad y la importancia de trabajar en un entorno profesional y responsable."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000202/2025-26/RA140> a ns1:LearningResult ;
    ns1:learningResultCode "RA140" ;
    ns1:learningResultDescription "Conocimientos de componentes electrónicos para aplicaciones de conversión de energía eléctrica."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000202/2025-26/RA141> a ns1:LearningResult ;
    ns1:learningResultCode "RA141" ;
    ns1:learningResultDescription "Capacidad de análisis de topologías para conversión de energía mediante circuitos electrónicos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000202/2025-26/RA17> a ns1:LearningResult ;
    ns1:learningResultCode "RA17" ;
    ns1:learningResultDescription "Capacidad de análisis de Sistemas de Alimentación que se utilizan en la industria"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000202/2025-26/RA498> a ns1:LearningResult ;
    ns1:learningResultCode "RA498" ;
    ns1:learningResultDescription "Valoración de la eficiencia energética de los sistemas de potencia"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000202/2025-26/didactic_resource/1> a ns1:DidacticResource ;
    ns1:bibliographyDescription "Libro de referencia de la asignatura"@es ;
    ns1:bibliographyTitle "Power Electronics. Converters, applications and design. Mohan, Undeland, Robbins. John Wiley 2003"@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000202/2025-26/didactic_resource/2> a ns1:DidacticResource ;
    ns1:bibliographyDescription "Libro de referencia"@es ;
    ns1:bibliographyTitle "Power Electronics. Circuits, devices and applications. M. Rashid. Prentice Hall 1993"@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000202/2025-26/didactic_resource/3> a ns1:DidacticResource ;
