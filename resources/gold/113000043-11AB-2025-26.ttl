    schema:hasCourseInstance <https://guia-kg.skai.etsisi.upm.es/resource/113000043/2025-26> ;
    schema:name "Sport Performance Study By Biomechanic Analysis"@en,
        "Estudio del Rendimiento Deportivo Mediante Analisis Biomecanico"@es ;
    schema:numberOfCredits 3.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/113000043/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/113000043/2025-26/CB10>,
        <https://guia-kg.skai.etsisi.upm.es/resource/113000043/2025-26/CB6>,
        <https://guia-kg.skai.etsisi.upm.es/resource/113000043/2025-26/CB9>,
        <https://guia-kg.skai.etsisi.upm.es/resource/113000043/2025-26/CE1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/113000043/2025-26/CE3>,
        <https://guia-kg.skai.etsisi.upm.es/resource/113000043/2025-26/CG2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/113000043/2025-26/CG6>,
        <https://guia-kg.skai.etsisi.upm.es/resource/113000043/2025-26/T5>,
        <https://guia-kg.skai.etsisi.upm.es/resource/113000043/2025-26/T6> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/113000043/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/113000043/2025-26/didactic_resource/2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/113000043/2025-26/didactic_resource/3> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/113000043/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/113000043/2025-26/RA12>,
        <https://guia-kg.skai.etsisi.upm.es/resource/113000043/2025-26/RA14>,
        <https://guia-kg.skai.etsisi.upm.es/resource/113000043/2025-26/RA17>,
        <https://guia-kg.skai.etsisi.upm.es/resource/113000043/2025-26/RA18>,
        <https://guia-kg.skai.etsisi.upm.es/resource/113000043/2025-26/RA32>,
        <https://guia-kg.skai.etsisi.upm.es/resource/113000043/2025-26/RA81> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/113000043/2025-26/syllabus> ;
    ns1:inpersonHours "32 horas (41%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation """Por imprevistos ajenos al departamento, el profesorado, el cronograma y/o el sistema de evaluación reflejados en esta guía podrán sufrir modificaciones que se notificarán con la máxima antelación posible y por escrito, al estudiantado.
Se trabajarán algunos de los Objetivos de Desarrollo Sostenible (ODS) establecidos por Naciones Unidas y que pueden consultarse en:
https://www.un.org/sustainabledevelopment/es/objetivos-de-desarrollo-sostenible/ .
Concretamente en esta asignatura se trabajan:
- ODS3 Salud y Bienestar: por la relación directa que tiene la recuperación funcional de la persona con la salud y la calidad de vida.
- ODS5 Igualdad de Género: por el abordaje que se realiza de las diferencias morfológicas y su relación con la incidencia de lesión y la recuperación, desde una perspectiva de igualdad de género."
Los exámenes se realizarán con la plataforma Moodle de forma presencial. Cada alumno utilizará su propio ordenador o tablet."""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "32 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/113000043/2025-26/eventSchedule> ;
    schema:description "La asignatura trata de aplicar las diferentes técnicas y tecnologías del ámbito de la biomecánica deportiva para medir, analizar y evaluar el rendimiento humano. Se trata por tanto de una asignatura de carácter eminentemente práctico en la que se aborda la investigación en biomecánica deportiva desde diferentes puntos de vista."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/archit.navandar%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/archit.navandar%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/enrique.navarro%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/javier.ruedao%40upm.es> ;
    schema:name "Estudio del Rendimiento Deportivo Mediante Analisis Biomecanico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000043/2025-26/CB10> a ns1:Competency ;
    ns1:competencyCode "CB10" ;
    ns1:competencyDescription "Que los estudiantes posean las habilidades de aprendizaje que les permitan continuar estudiando de un modo que habrá de ser en gran medida autodirigido o autónomo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000043/2025-26/CB6> a ns1:Competency ;
    ns1:competencyCode "CB6" ;
    ns1:competencyDescription "Poseer y comprender conocimientos que aporten una base u oportunidad de ser originales en el desarrollo y/o aplicación de ideas, a menudo en un contexto de investigación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000043/2025-26/CB9> a ns1:Competency ;
    ns1:competencyCode "CB9" ;
    ns1:competencyDescription "Que los estudiantes sepan comunicar sus conclusiones y los conocimientos y razones últimas que las sustentan a públicos especializados y no especializados de un modo claro y sin ambigüedades"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000043/2025-26/CE1> a ns1:Competency ;
    ns1:competencyCode "CE1" ;
    ns1:competencyDescription "Conocimiento de los aspectos más relevantes del conocimiento científico y su relación con las CC de la Actividad Física y del Deporte."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000043/2025-26/CE3> a ns1:Competency ;
    ns1:competencyCode "CE3" ;
    ns1:competencyDescription "Capacidad para la búsqueda, recuperación y análisis de información y documentación científica a través del conocimiento de los sistemas, procesos y recursos de información en Ciencias de la Actividad Física y del Deporte."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000043/2025-26/CG2> a ns1:Competency ;
    ns1:competencyCode "CG2" ;
    ns1:competencyDescription "Desarrollo de las habilidades instrumentales básicas para la comunicación oral y escrita en un marco científico, siendo capaces de exponer reflexiones, ideas y conclusiones de manera sintética y ante diversos públicos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000043/2025-26/CG6> a ns1:Competency ;
    ns1:competencyCode "CG6" ;
    ns1:competencyDescription "Capacidad para comunicarse y relacionarse en un ámbito científico en la lengua inglesa."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000043/2025-26/RA12> a ns1:LearningResult ;
    ns1:learningResultCode "RA12" ;
    ns1:learningResultDescription "Utilización de los modelos estadísticos básicos con ayuda de un programa informático (SPSS o Statgraphics). Interpretación y crítica de resultados estadísticos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000043/2025-26/RA14> a ns1:LearningResult ;
    ns1:learningResultCode "RA14" ;
    ns1:learningResultDescription "Conocer los recursos de información existentes, documentales e institucionales, y los mecanismos de acceso a la información."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000043/2025-26/RA17> a ns1:LearningResult ;
    ns1:learningResultCode "RA17" ;
    ns1:learningResultDescription "Ejercitarse en el uso de las herramientas electrónicas y de las posibilidades de los recursos de información ofrecidos por las universidades, y aproximarse a los repositorios como nuevas formas de gestionar, acceder y comunicar la información científica."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000043/2025-26/RA18> a ns1:LearningResult ;
    ns1:learningResultCode "RA18" ;
    ns1:learningResultDescription "Adquirir los conocimientos y mecanismos adecuados para organizar, sistematizar y difundir la información científica."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000043/2025-26/RA32> a ns1:LearningResult ;
    ns1:learningResultCode "RA32" ;
    ns1:learningResultDescription "Desarrollo de las habilidades instrumentales básicas para la comunicación oral y escrita en un marco científico, siendo capaces de exponer reflexiones, ideas y conclusiones de manera sintética y ante diversos públicos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000043/2025-26/RA81> a ns1:LearningResult ;
    ns1:learningResultCode "RA81" ;
    ns1:learningResultDescription "Conocer y saber aplicar la metodología de análisis biomecánico, mediante los enfoques cualitativo y cuantitativo, y las técnicas de análisis cinemático y cinético de habilidades y técnicas deportivas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000043/2025-26/T5> a ns1:Competency ;
    ns1:competencyCode "T5" ;
    ns1:competencyDescription "Capacidad de comunicarse de forma efectiva con los compañeros, usuarios (potenciales) y el público en general acerca de cuestiones reales y problemas relacionados con las Ciencias de la Actividad Física y del Deporte."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000043/2025-26/T6> a ns1:Competency ;
    ns1:competencyCode "T6" ;
    ns1:competencyDescription "Capacidad para usar las tecnologías de la información y la comunicación."@es .

