    schema:courseCode 53001634 ;
    schema:hasCourseInstance <https://guia-kg.skai.etsisi.upm.es/resource/53001634/2025-26> ;
    schema:name "Digital Signal Processing"@en,
        "Procesamiento Digital de Señal"@es ;
    schema:numberOfCredits 3.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/53001634/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/53001634/2025-26/MUII.%20%28e%29> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/53001634/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001634/2025-26/didactic_resource/2>,
