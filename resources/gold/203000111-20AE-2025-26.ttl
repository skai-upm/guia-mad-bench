    ns1:competencyDescription "Capacidad de trabajo en equipo o su liderazgo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000111/2025-26/CT03> a ns1:Competency ;
    ns1:competencyCode "CT03" ;
    ns1:competencyDescription "Creatividad."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000111/2025-26/CT04> a ns1:Competency ;
    ns1:competencyCode "CT04" ;
    ns1:competencyDescription "Organización y planificación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000111/2025-26/CT05> a ns1:Competency ;
    ns1:competencyCode "CT05" ;
    ns1:competencyDescription "Gestión de la información."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000111/2025-26/CT06> a ns1:Competency ;
    ns1:competencyCode "CT06" ;
    ns1:competencyDescription "Gestión económica y administrativa."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000111/2025-26/CT07> a ns1:Competency ;
    ns1:competencyCode "CT07" ;
    ns1:competencyDescription "Capacidad de adaptación y de trabajo en entornos internacionales y multiculturales."@es .

