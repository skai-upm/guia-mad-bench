    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/95000316/2025-26/eventSchedule> ;
    schema:description "Curso de mecánica de medios continuos orientado a la aplicación biomédica. Se desarrolla en primer lugar el concepto de medio continuo y el encaje dentro de dicho modelo del estudio de los tejidos del cuerpo humano y prótesis. A continuación se repasan brevemente los conceptos de álgebra vectorial y tensorial y de cálculo necesarios para la asignatura. Se desarrollan los conceptos de fuerzas en un medio continuo, con especial hincapié en las fuerzas internas o tensiones; la medida del movimiento a través de las deformaciones, con énfasis en las deformaciones infinitesimales pero explicando también las grandes deformaciones; las ecuaciones de comportamiento de los materiales, principalmente la elasticidad; las ecuaciones de balance y conservación, en especial las de equilibrio de tensiones; el comportamiento de los fluidos; las aplicaciones a tejidos blandos y duros humanos, desde el punto de vista conceptual y práctico mediante cálculo por elementos finitos."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/pedro.navas%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/javier.garciag%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/jose.goicolea%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/m.molinos%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/pedro.navas%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/sergio.blanco%40upm.es> ;
    schema:name "Biomecánica de Medios Continuos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000316/2025-26/CE06> a ns1:Competency ;
    ns1:competencyCode "CE06" ;
    ns1:competencyDescription "Comprender y saber calcular el equilibrio y la dinámica de sistemas mecánicos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000316/2025-26/CE07> a ns1:Competency ;
    ns1:competencyCode "CE07" ;
    ns1:competencyDescription "Saber aplicar las ecuaciones elementales de la mecánica de fluidos en el cálculo de sistemas de conducción convencionales macroscópicos y en microfluídica."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000316/2025-26/CE44> a ns1:Competency ;
    ns1:competencyCode "CE44" ;
    ns1:competencyDescription "Conocer las principales propiedades y comportamiento mecánico de los tejidos y sistemas fisiológicos animales, especialmente humanos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000316/2025-26/CG01> a ns1:Competency ;
    ns1:competencyCode "CG01" ;
    ns1:competencyDescription "Desarrollar las habilidades de aprendizaje necesarias para emprender actividades o estudios posteriores de forma autónoma y con confianza."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000316/2025-26/CG07> a ns1:Competency ;
    ns1:competencyCode "CG07" ;
    ns1:competencyDescription "Ser capaz de utilizar el método científico."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000316/2025-26/CG11> a ns1:Competency ;
    ns1:competencyCode "CG11" ;
    ns1:competencyDescription "Elaborar y defender argumentos y resolver los problemas de forma efectiva y creativa."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000316/2025-26/CG15> a ns1:Competency ;
    ns1:competencyCode "CG15" ;
    ns1:competencyDescription "Transmitir la información adquirida, las ideas, los problemas y las soluciones de forma oral y escrita en castellano e inglés."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000316/2025-26/RA206> a ns1:LearningResult ;
    ns1:learningResultCode "RA206" ;
    ns1:learningResultDescription "Conocimiento de los fundamentos de la mecánica de los sólidos reales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000316/2025-26/RA207> a ns1:LearningResult ;
    ns1:learningResultCode "RA207" ;
    ns1:learningResultDescription "Conocer los tipos de tejidos del cuerpo humano y comprender su comportamiento mecánico, incluyendo los tejidos duros y blandos así como los el flujo sanguíneo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000316/2025-26/RA208> a ns1:LearningResult ;
    ns1:learningResultCode "RA208" ;
    ns1:learningResultDescription "Conocer y comprender el concepto de medio continuo, así como comprender y analizar las tensiones como fuerzas internas en el mismo, sabiendo calcular sus distintas componentes y medidas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000316/2025-26/RA209> a ns1:LearningResult ;
    ns1:learningResultCode "RA209" ;
    ns1:learningResultDescription "Conocer, comprender y analizar las ecuaciones de la elasticidad como relaciones básicas del comportamiento de los sólidos y tejidos biológicos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000316/2025-26/RA210> a ns1:LearningResult ;
    ns1:learningResultCode "RA210" ;
    ns1:learningResultDescription "Conocer, aplicar y analizar las distribuciones de tensiones y deformaciones en problemas bidimensionales de elasticidad"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000316/2025-26/RA211> a ns1:LearningResult ;
    ns1:learningResultCode "RA211" ;
    ns1:learningResultDescription "Conocer comprender y analizar los modelos de materiales que dependen de la velocidad de deformación como los sólidos viscoelásticos y los fluidos Newtonianos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000316/2025-26/RA212> a ns1:LearningResult ;
    ns1:learningResultCode "RA212" ;
    ns1:learningResultDescription "Conocer, comprender y analizar las ecuaciones de balance y principios de conservación que rigen el equilibrio y la dinámica en los medios continuos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000316/2025-26/RA213> a ns1:LearningResult ;
    ns1:learningResultCode "RA213" ;
    ns1:learningResultDescription "Comportamiento mecánico de los materiales biológicos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000316/2025-26/RA214> a ns1:LearningResult ;
    ns1:learningResultCode "RA214" ;
    ns1:learningResultDescription "Conocimiento de la estructura y propiedades y mecánicas más importantes de los tejidos del cuerpo humano, y su relevancia para la función fisiológica y en el desarrollo de patologías."@es .

