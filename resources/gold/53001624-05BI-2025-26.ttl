    ns1:numberOfCredits 12.0 ;
    ns1:otherInformation "Como la asignatura planteada está en su segundo año, el planteamiento será flexible para corregir los problemas que han surgido el primer curso e ir adaptándose según las necesidades."@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Junio"@es ;
