    ns1:bibliographyTitle "S.L. Salas, E. Hille y G.J. Etgen, Calculus: una y varias variales, vol. 1, Reverté, 2002."@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000003/2025-26/didactic_resource/5> a ns1:DidacticResource ;
