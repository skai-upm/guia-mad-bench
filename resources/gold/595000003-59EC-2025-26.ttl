    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/595000003/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/595000003/2025-26/RA1082>,
        <https://guia-kg.skai.etsisi.upm.es/resource/595000003/2025-26/RA1085>,
        <https://guia-kg.skai.etsisi.upm.es/resource/595000003/2025-26/RA1087>,
        <https://guia-kg.skai.etsisi.upm.es/resource/595000003/2025-26/RA1088>,
        <https://guia-kg.skai.etsisi.upm.es/resource/595000003/2025-26/RA1100> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/595000003/2025-26/syllabus> ;
    ns1:inpersonHours "60 horas (38.5%)"@es ;
    ns1:numberOfCredits 6.0 ;
    ns1:otherInformation ""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "60 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/595000003/2025-26/eventSchedule> ;
    schema:description "En esta asignatura se pretende afianzar y dar rigor a los conocimientos de cálculo infinitesimal que el estudiante adquirió en el Bachillerato: límites, continuidad, derivabilidad e integrabilidad. A continuación se introducen otros conceptos novedosos para el estudiante como son las ecuaciones diferenciales, las sucesiones y series de números reales y las series de funciones."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/mp.velasco%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/jeronimo.lopezsalazar%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/julia.gluengo%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/mp.velasco%40upm.es> ;
    schema:name "Calculo I"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000003/2025-26/CE%20B1> a ns1:Competency ;
    ns1:competencyCode "CE B1" ;
    ns1:competencyDescription "Capacidad para la resolución de los problemas matemáticos que puedan plantearse en la ingeniería. Aptitud para aplicar los conocimientos sobre: álgebra lineal; geometría; geometría diferencial; cálculo diferencial e integral; ecuaciones diferenciales y en derivadas parciales; métodos numéricos; algorítmica numérica; estadística y optimización."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000003/2025-26/CG%2004> a ns1:Competency ;
    ns1:competencyCode "CG 04" ;
    ns1:competencyDescription "Capacidad de abstracción, de análisis y de síntesis y de resolución de problemas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000003/2025-26/RA1082> a ns1:LearningResult ;
    ns1:learningResultCode "RA1082" ;
    ns1:learningResultDescription "Conocer los conceptos de continuidad y derivabilidad de una función de una variable real y los teoremas fundamentales asociados."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000003/2025-26/RA1085> a ns1:LearningResult ;
    ns1:learningResultCode "RA1085" ;
    ns1:learningResultDescription "Resolver los ejemplos básicos de ecuaciones diferenciales ordinarias."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000003/2025-26/RA1087> a ns1:LearningResult ;
    ns1:learningResultCode "RA1087" ;
    ns1:learningResultDescription "Analizar la convergencia de series numéricas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000003/2025-26/RA1088> a ns1:LearningResult ;
    ns1:learningResultCode "RA1088" ;
    ns1:learningResultDescription "Desarrollar funciones elementales en series de potencias."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000003/2025-26/RA1100> a ns1:LearningResult ;
    ns1:learningResultCode "RA1100" ;
    ns1:learningResultDescription "Conocer el teorema fundamental del Cálculo"@es .

