    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000003/2025-26/evaluation> a ns1:EvaluationSystem ;
    ns1:evaluationDescription """La calificación en la convocatoria ordinaria se obtendrá mediante la fórmula siguiente:
Máximo {0,40 × P + 0,60 × G; G},
donde P representa la nota del examen parcial y G representa la nota del examen global. Para aprobar la asignatura, la calificación final debe ser al menos de 5 puntos.
En la convocatoria extraordinaria se realizará un único examen."""@es ;
    ns1:hasEvaluationTrial <https://guia-kg.skai.etsisi.upm.es/resource/595000003/2025-26/evaluation/trial1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/595000003/2025-26/evaluation/trial2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/595000003/2025-26/evaluation/trial3>,
        <https://guia-kg.skai.etsisi.upm.es/resource/595000003/2025-26/evaluation/trial4> .

