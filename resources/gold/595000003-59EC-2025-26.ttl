    ns1:bibliographyTitle "A. García, F. García, A. Gutiérrez, A. López, G. Rodríguez y A. Villa, Cálculo I: teoría y problemas de análisis matemático en una variable, CLAGSA, 2007."@es ;
    ns1:bibliographyType "Bibliografía"@es .

