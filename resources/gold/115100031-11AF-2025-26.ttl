    ns1:semester """Séptimo semestre
Octavo semestre"""@es ;
    schema:courseCode 115100031 ;
    schema:hasCourseInstance <https://guia-kg.skai.etsisi.upm.es/resource/115100031/2025-26> ;
    schema:name "English For Professional And Academic Communication In Sports"@en,
        "Inglés para Comunicación Profesional y Académica en Deporte"@es ;
    schema:numberOfCredits 6.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/115100031/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/115100031/2025-26/CG12>,
        <https://guia-kg.skai.etsisi.upm.es/resource/115100031/2025-26/CG13> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/115100031/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/115100031/2025-26/didactic_resource/2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/115100031/2025-26/didactic_resource/3> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/115100031/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/115100031/2025-26/RA1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/115100031/2025-26/RA2> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/115100031/2025-26/syllabus> ;
    ns1:inpersonHours "64 horas y 45 minutos (41.5%)"@es ;
    ns1:numberOfCredits 6.0 ;
    ns1:otherInformation """THE SUBJECT INCLUDES CONTENT RELATED TO SUSTAINABILITY AND SPORT THROUGHOUT THE SEMESTER:
Doing sport is one of people's main resolutions every beginning of the year. However, do you know, for example, how much pollution a Marathon creates? And a major sporting event like the football world cup? Some sports activities can also damage the environment and you should know about this to keep their effects to a minimum.
Bet on sustainable sport!"""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "65 horas y 45 minutos"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/115100031/2025-26/eventSchedule> ;
    schema:description "With this course the student works the necessary skills in English to manage in a professional and academic communication environment related to sports and physical activity."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/maria.gomez.ortiz%40upm.es> ;
    schema:inLanguage "Inglés"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/maria.gomez.ortiz%40upm.es> ;
    schema:name "Inglés para Comunicación Profesional y Académica en Deporte"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100031/2025-26/CG12> a ns1:Competency ;
    ns1:competencyCode "CG12" ;
    ns1:competencyDescription "Comprender y manejar la literatura científica del ámbito de la actividad física y el deporte en lengua inglesa y en otras lenguas de presencia significativa en el ámbito científico y específico de conocimiento."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100031/2025-26/CG13> a ns1:Competency ;
    ns1:competencyCode "CG13" ;
    ns1:competencyDescription "Desarrollar habilidades adecuadas de comunicación oral y escrita en lengua inglesa y en otras lenguas de presencia significativa en el ámbito científico y específico de conocimiento, que permitan la adecuada comunicación y transferencia de conocimientos."@es .

