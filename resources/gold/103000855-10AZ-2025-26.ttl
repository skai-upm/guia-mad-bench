    schema:hasCourseInstance <https://guia-kg.skai.etsisi.upm.es/resource/103000855/2025-26> ;
    schema:name "Data Science Seminars"@en,
        "Data Science Seminars"@es ;
    schema:numberOfCredits 4.5 .

<https://guia-kg.skai.etsisi.upm.es/resource/103000855/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/103000855/2025-26/CB06>,
        <https://guia-kg.skai.etsisi.upm.es/resource/103000855/2025-26/CG03> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/103000855/2025-26/didactic_resource/1>,
