<https://guia-kg.skai.etsisi.upm.es/resource/20504125/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "3.1. Revisión de conceptos: potencial redox. Células electroquímicas. Celdas de biocombustible. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504125/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "3.2. Variación de los potenciales con la concentración: ecuación de Nernst. Espontaneidad y equilibrio. Influencia del pH en el potencial eléctrico. Tipos de electrodos. Potenciales de reducción en condiciones biológicas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504125/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "3.3. Interdependencia de equilibrios. Ejercicios relacionados con la biotecnología. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504125/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "3.4. Termodinámica de los procesos redox de interés en los seres vivos. Reacciones acopladas, diagramas energéticos y entrópicos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504125/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "3.5. Práctica 3. Estudio de reacciones de oxidación-reducción implicadas en la cuantificación de vitamina C en bebidas energéticas, complejos vitamínicos y medicamentos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504125/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "3.6. Práctica 4. Variación del poder rotario de un enantiómeros de características reductoras con el pH en biomoléculas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504125/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Entropía. Diagramas entrópicos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504125/2025-26/syllabus/20> a ns1:SyllabusItem ;
    ns1:itemIndex 20 ;
    ns1:syllabusDescription "4. Equilibrios en disolución de formación de precipitados"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504125/2025-26/syllabus/21> a ns1:SyllabusItem ;
    ns1:itemIndex 21 ;
    ns1:syllabusDescription "4.1. Constante del producto de solubilidad y su relación con la solubilidad. Equilibrios de formación de precipitados. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504125/2025-26/syllabus/22> a ns1:SyllabusItem ;
    ns1:itemIndex 22 ;
    ns1:syllabusDescription "4.2. Termodinámica de los procesos de precipitación de interés en los seres vivos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504125/2025-26/syllabus/23> a ns1:SyllabusItem ;
    ns1:itemIndex 23 ;
    ns1:syllabusDescription "4.3. Interdependencia de equilibrios. Ejercicios relacionados con la biotecnología. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504125/2025-26/syllabus/24> a ns1:SyllabusItem ;
    ns1:itemIndex 24 ;
    ns1:syllabusDescription "4.4. Práctica 5. Equilibrios de precipitación. Estudio de interdependencia entre reacciones de precipitación y reacciones de oxidación-reducción, ácido-base y formación de complejos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504125/2025-26/syllabus/25> a ns1:SyllabusItem ;
    ns1:itemIndex 25 ;
    ns1:syllabusDescription "5. Equilibrios en disolución de formación de complejos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504125/2025-26/syllabus/26> a ns1:SyllabusItem ;
    ns1:itemIndex 26 ;
    ns1:syllabusDescription "5.1. Compuestos de coordinación. Equilibrios de formación de complejos Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504125/2025-26/syllabus/27> a ns1:SyllabusItem ;
    ns1:itemIndex 27 ;
    ns1:syllabusDescription "5.2. Termodinámica de los procesos de formación de complejos de interés en los seres vivos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504125/2025-26/syllabus/28> a ns1:SyllabusItem ;
    ns1:itemIndex 28 ;
    ns1:syllabusDescription "5.3. Interdependencia de equilibrios. Ejercicios relacionados con la biotecnología. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504125/2025-26/syllabus/29> a ns1:SyllabusItem ;
    ns1:itemIndex 29 ;
    ns1:syllabusDescription "5.4. Práctica 6. Formación de quelatos estables mediante el uso de un agente quelante: aplicación a la determinación de cationes metálicos en fármacos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504125/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "1.3. Energía libre de Gibbs. Diagramas energéticos. Aprovechamiento de energía en los seres vivos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504125/2025-26/syllabus/30> a ns1:SyllabusItem ;
    ns1:itemIndex 30 ;
    ns1:syllabusDescription "6. Propiedades coligativas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504125/2025-26/syllabus/31> a ns1:SyllabusItem ;
    ns1:itemIndex 31 ;
    ns1:syllabusDescription "6.1. Fundamento termodinámico del proceso de disolución. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504125/2025-26/syllabus/32> a ns1:SyllabusItem ;
    ns1:itemIndex 32 ;
    ns1:syllabusDescription "6.2. Propiedades coligativas: descenso presión vapor, descenso crioscópico, aumento ebulloscópico y presión osmótica. Efecto de la ionización del soluto en las propiedades coligativas. Ósmosis y ósmosis inversa. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504125/2025-26/syllabus/33> a ns1:SyllabusItem ;
    ns1:itemIndex 33 ;
    ns1:syllabusDescription "6.3. Aplicaciones en la Biotecnología de las propiedades coligativas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504125/2025-26/syllabus/34> a ns1:SyllabusItem ;
    ns1:itemIndex 34 ;
    ns1:syllabusDescription "7. Dispersiones coloidales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504125/2025-26/syllabus/35> a ns1:SyllabusItem ;
    ns1:itemIndex 35 ;
    ns1:syllabusDescription "7.1. Clasificación y caracterización de los sistemas coloidales.Coloides liófilos y liófobos. Concentración Micelar Crítica. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504125/2025-26/syllabus/36> a ns1:SyllabusItem ;
    ns1:itemIndex 36 ;
    ns1:syllabusDescription "7.2. Formación de coloides y estabilidad.Fenómenos de adsorción en coloides. Doble capa eléctrica. Potencial Z. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504125/2025-26/syllabus/37> a ns1:SyllabusItem ;
    ns1:itemIndex 37 ;
    ns1:syllabusDescription "7.3. Coagulación.Tensioactivos.Aplicaciones de interés. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504125/2025-26/syllabus/38> a ns1:SyllabusItem ;
    ns1:itemIndex 38 ;
    ns1:syllabusDescription "7.4. Propiedades de las dispersiones coloidales. Preparación de geles de contacto y queralíticos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504125/2025-26/syllabus/39> a ns1:SyllabusItem ;
    ns1:itemIndex 39 ;
    ns1:syllabusDescription "7.5. Práctica 7. Disoluciones y coloides.Tipos y propiedades. Preparación de emulsiones. Preparación de geles. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504125/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "1.4. Cociente de reacción. Equilibrio químico y constante de equilibrio. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504125/2025-26/syllabus/40> a ns1:SyllabusItem ;
    ns1:itemIndex 40 ;
    ns1:syllabusDescription "8. Operaciones básicas aplicables a la Industría Biotecnológica"@es .

