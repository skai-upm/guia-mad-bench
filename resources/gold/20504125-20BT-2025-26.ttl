        <https://guia-kg.skai.etsisi.upm.es/resource/jesus.novillo%40upm.es> ;
    schema:name "Ampliación de Química"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504125/2025-26/CB01> a ns1:Competency ;
    ns1:competencyCode "CB01" ;
    ns1:competencyDescription "Que los estudiantes hayan demostrado poseer y comprender conocimientos en un área de estudio que parte de la base de la educación secundaria general, y se suele encontrar a un nivel que, si bien se apoya en libros de texto avanzados, incluye también algunos aspectos que implican conocimientos procedentes de la vanguardia de su campo de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504125/2025-26/CB05> a ns1:Competency ;
    ns1:competencyCode "CB05" ;
    ns1:competencyDescription "Que los estudiantes hayan desarrollado aquellas habilidades de aprendizaje necesarias para emprender estudios posteriores con un alto grado de autonomía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504125/2025-26/CE01> a ns1:Competency ;
    ns1:competencyCode "CE01" ;
    ns1:competencyDescription "Capacidad para conocer las propiedades de la materia, los principios termodinámicos y sus aplicaciones prácticas, así como las características comunes de los procesos físicoquímicos de interés biotecnológico a escala de laboratorio e industrial."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504125/2025-26/CE02> a ns1:Competency ;
    ns1:competencyCode "CE02" ;
    ns1:competencyDescription "Conocimientos básicos de la química inorgánica y los principales grupos funcionales orgánicos, las reacciones de síntesis, los tipos de isomerías y las técnicas de separación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504125/2025-26/CG02> a ns1:Competency ;
    ns1:competencyCode "CG02" ;
    ns1:competencyDescription "Familiarizarse con el trabajo en el laboratorio, la instrumentación y los métodos experimentales. Además, ser capaz de realizar experimentos y/o diseñar aplicaciones de forma independiente y describir, cuantificar, analizar y evaluar críticamente los resultados obtenidos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504125/2025-26/CT01> a ns1:Competency ;
    ns1:competencyCode "CT01" ;
    ns1:competencyDescription "Aplicar de forma profesional a su trabajo los conocimientos adquiridos considerando sus impactos en un contexto global y social."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504125/2025-26/RA1> a ns1:LearningResult ;
    ns1:learningResultCode "RA1" ;
    ns1:learningResultDescription "Saber realizar ajustes estequiométricos de reacciones químicas y manejar con soltura herramientas básicas de la química como el concepto de mol y peso molecular."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504125/2025-26/RA2> a ns1:LearningResult ;
    ns1:learningResultCode "RA2" ;
    ns1:learningResultDescription "Saber preparar disoluciones ajustadas en volumen, concentración y con pH determinados."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504125/2025-26/RA3> a ns1:LearningResult ;
    ns1:learningResultCode "RA3" ;
    ns1:learningResultDescription "Saber interpretar y utilizar un diagrama de fases, así como realizar cálculos básicos para describir transiciones de fase en sistemas puros y mezclas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504125/2025-26/RA4> a ns1:LearningResult ;
    ns1:learningResultCode "RA4" ;
    ns1:learningResultDescription "Saber calcular entalpías y balances de energía libre de reacciones químicas a partir de datos termodinámicos tabulados y a partir de ahí saber predecir la eficacia de un proceso químico."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504125/2025-26/RA5> a ns1:LearningResult ;
    ns1:learningResultCode "RA5" ;
    ns1:learningResultDescription "Saber calcular y utilizar con soltura constantes de equilibrio a partir de datos termodinámicos y predecir cómo afectará al equilibrio las condiciones de operación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504125/2025-26/RA6> a ns1:LearningResult ;
    ns1:learningResultCode "RA6" ;
    ns1:learningResultDescription "Saber predecir el comportamiento de una reacción de transferencia protónica y saber calcular el pH de disoluciones acuosas de compuestos inorgánicos y orgánicos relevantes en biología."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504125/2025-26/RA7> a ns1:LearningResult ;
    ns1:learningResultCode "RA7" ;
    ns1:learningResultDescription "Saber ajustar una reacción de transferencia electrónica y predecir su comportamiento."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504125/2025-26/RA8> a ns1:LearningResult ;
    ns1:learningResultCode "RA8" ;
    ns1:learningResultDescription "Saber distinguir entre la eficacia de un proceso químico desde el punto de vista termodinámico."@es .

