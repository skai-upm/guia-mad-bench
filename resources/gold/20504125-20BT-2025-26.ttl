    ns1:itemIndex 41 ;
    ns1:syllabusDescription "8.1. Fundamentos de ingeniería química. Operaciones básicas de interés biotecnológico. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504125/2025-26/syllabus/42> a ns1:SyllabusItem ;
