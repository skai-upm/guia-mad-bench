        <https://guia-kg.skai.etsisi.upm.es/resource/ismael.mguardado%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/javier.modrego%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/luis.garceso%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/margarita.perez%40upm.es> ;
    schema:name "Fisiología Humana"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100014/2025-26/CE02> a ns1:Competency ;
    ns1:competencyCode "CE02" ;
    ns1:competencyDescription "Aplicar, de manera fundamentada y argumentada, los principios fisiológicos, biomecánicos, comportamentales y sociales en el diseño y puesta en práctica de propuestas y programas de Educación Física en el contexto educativo. Nivel 3."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100014/2025-26/CE06> a ns1:Competency ;
    ns1:competencyCode "CE06" ;
    ns1:competencyDescription "Promover y evaluar la formación de hábitos perdurables y autónomos de práctica actividad física y del deporte entre la población escolar. Nivel 3."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100014/2025-26/CE08> a ns1:Competency ;
    ns1:competencyCode "CE08" ;
    ns1:competencyDescription "Aplicar de manera fundamentada y argumentada los principios fisiológicos, biomecánicos, comportamentales y sociales, durante la dirección del entrenamiento deportivo. Nivel 3."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100014/2025-26/CG02> a ns1:Competency ;
    ns1:competencyCode "CG02" ;
    ns1:competencyDescription "Desarrollar habilidades y estrategias que incidan en la capacidad para trabajar en forma autónoma."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100014/2025-26/CG05> a ns1:Competency ;
    ns1:competencyCode "CG05" ;
    ns1:competencyDescription "Gestionar con eficacia y eficiencia la información procedente de diferentes fuentes integrando sus aspectos relevantes para el cumplimiento de los objetivos propuestos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100014/2025-26/CG12> a ns1:Competency ;
    ns1:competencyCode "CG12" ;
    ns1:competencyDescription "Comprender y manejar la literatura científica del ámbito de la actividad física y el deporte en lengua inglesa y en otras lenguas de presencia significativa en el ámbito científico y específico de conocimiento."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100014/2025-26/CG14> a ns1:Competency ;
    ns1:competencyCode "CG14" ;
    ns1:competencyDescription "Utilizar y aplicar las tecnologías de la información y comunicación (TIC) al ámbito de las Ciencias de la Actividad Física y del Deporte, usando las principales fuentes de información científica disponibles."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100014/2025-26/RA13> a ns1:LearningResult ;
    ns1:learningResultCode "RA13" ;
    ns1:learningResultDescription "Asimilar los conocimientos teóricos desarrollando herramientas prácticas que sean de uso cotidiano en la actividad profesional del graduado, sin olvidar el carácter integrado de la respuesta conductual humana"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100014/2025-26/RA164> a ns1:LearningResult ;
    ns1:learningResultCode "RA164" ;
    ns1:learningResultDescription "Capacidad de análisis de las estructuras y sistemas del movimiento físico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100014/2025-26/RA230> a ns1:LearningResult ;
    ns1:learningResultCode "RA230" ;
    ns1:learningResultDescription "Conocer los componentes de la condición biológica y sus características fundamentales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100014/2025-26/RA231> a ns1:LearningResult ;
    ns1:learningResultCode "RA231" ;
    ns1:learningResultDescription "Conocer y comprender los factores fisiológicos entre los que se encuentra la nutrición (e hidratación) que podría condicionar la práctica y/o el rendimiento de la actividad física y el deporte y establecer las pautas nutricionales más adecuadas en función de la actividad física"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100014/2025-26/RA232> a ns1:LearningResult ;
    ns1:learningResultCode "RA232" ;
    ns1:learningResultDescription "Conocer, analizar y aplicar pruebas de valoración de la condición anatómica y de la condición fisiológica aeróbica y anaeróbica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100014/2025-26/RA488> a ns1:LearningResult ;
    ns1:learningResultCode "RA488" ;
    ns1:learningResultDescription "Describir la estructura y función de los principales órganos, sistemas y aparatos del ser humano."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100014/2025-26/RA489> a ns1:LearningResult ;
    ns1:learningResultCode "RA489" ;
    ns1:learningResultDescription "Conocer el funcionamiento de los diferentes sistemas y aparatos que componen el organismo, así como su regulación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100014/2025-26/RA490> a ns1:LearningResult ;
    ns1:learningResultCode "RA490" ;
    ns1:learningResultDescription "Tener una visión integrada del funcionamiento del organismo, así como la capacidad del mismo para adaptarse a los cambios del medio interno y/o externo."@es .

