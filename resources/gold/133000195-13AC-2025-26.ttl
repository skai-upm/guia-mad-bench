<https://guia-kg.skai.etsisi.upm.es/resource/133000195/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/133000195/2025-26/CB08>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000195/2025-26/CB09>,
