    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/93001023/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/93001023/2025-26/RA119>,
        <https://guia-kg.skai.etsisi.upm.es/resource/93001023/2025-26/RA120>,
        <https://guia-kg.skai.etsisi.upm.es/resource/93001023/2025-26/RA46>,
        <https://guia-kg.skai.etsisi.upm.es/resource/93001023/2025-26/RA47>,
        <https://guia-kg.skai.etsisi.upm.es/resource/93001023/2025-26/RA48>,
        <https://guia-kg.skai.etsisi.upm.es/resource/93001023/2025-26/RA49>,
        <https://guia-kg.skai.etsisi.upm.es/resource/93001023/2025-26/RA50>,
        <https://guia-kg.skai.etsisi.upm.es/resource/93001023/2025-26/RA51> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/93001023/2025-26/syllabus> ;
    ns1:inpersonHours "47 horas (45.2%)"@es ;
    ns1:numberOfCredits 4.0 ;
    ns1:otherInformation """La asignatura se relaciona con el ODS4, el ODS7 y ODS9
-ODS4.4 Aumentar considerablemente el número de jóvenes y adultos que tienen las competencias necesarias, en particular técnicas y profesionales, para acceder al empleo...
-ODS7.b Ampliar la infraestructura y mejorar la tecnología para prestar servicios energéticos modernos y sostenibles para todos en los países en desarrollo...
-ODS9.1 Desarrollar infraestructuras fiables, sostenibles, resilientes y de calidad...
-ODS9.4 Modernizar la infraestructura y reconvertir las industrias para que sean sostenibles, utilizando los recursos con mayor eficacia y promoviendo la adopción de tecnologías y procesos industriales limpios y ambientalmente racionales.."""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "47 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/93001023/2025-26/eventSchedule> ;
    schema:description "El objetivo de la asignatura es que el alumno tenga los conocimientos y los criterios necesarios para la toma de decisiones en el diseño de equipos y terminales de usuario. Este objetivo se concreta en cinco temas principales que abordan los siguientes aspectos en sistemas electrónicos: desarrollo de un sistema electrónico como producto final, compatibilidad electromagnética, diseño de PCBs, aspectos de fiabilidad y pruebas, y finalmente, sistemas electrónicos para la interacción persona-equipo."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/m.lopez.vallejo%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/juanmanuel.montero%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/m.lopez.vallejo%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/samuel.lopez.asuncion%40upm.es> ;
    schema:name "Diseño Electrónico Orientado a Producto"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93001023/2025-26/CE01> a ns1:Competency ;
    ns1:competencyCode "CE01" ;
    ns1:competencyDescription "Capacidad para evaluar las ventajas e inconvenientes de las alternativas tecnológicas en el diseño o fabricación de sistemas electrónicos analógicos, digitales, centrales o distribuidos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93001023/2025-26/CE02> a ns1:Competency ;
    ns1:competencyCode "CE02" ;
    ns1:competencyDescription "Capacidad para aplicar herramientas, técnicas y metodologías avanzadas de diseño de sistemas o subsistemas electrónicos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93001023/2025-26/CE03> a ns1:Competency ;
    ns1:competencyCode "CE03" ;
    ns1:competencyDescription "Capacidad para gestionar el diseño, fabricación e implantación de sistemas electrónicos complejos teniendo en cuenta los aspectos económicos, las normativas o los aspectos de negociación, planificación y control de proyectos y soporte."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93001023/2025-26/RA119> a ns1:LearningResult ;
    ns1:learningResultCode "RA119" ;
    ns1:learningResultDescription "Capacidad para analizar nuevos y complejos productos, procesos y sistemas de ingeniería dentro de un contexto más amplio; seleccionar y aplicar los métodos más adecuados de análisis, de cálculo y experimentales ya establecidos, así como métodos innovadores e interpretar de forma crítica los resultados de dichos análisis."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93001023/2025-26/RA120> a ns1:LearningResult ;
    ns1:learningResultCode "RA120" ;
    ns1:learningResultDescription "La capacidad de concebir nuevos productos, procesos y sistemas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93001023/2025-26/RA46> a ns1:LearningResult ;
    ns1:learningResultCode "RA46" ;
    ns1:learningResultDescription "Analizar y diseñar sistemas electrónicos teniendo en cuenta aspectos de compatibilidad electromagnética"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93001023/2025-26/RA47> a ns1:LearningResult ;
    ns1:learningResultCode "RA47" ;
    ns1:learningResultDescription "Analizar la fiabilidad de un sistema electrónico y diseñar sistemas en base a restricciones de fiabilidad"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93001023/2025-26/RA48> a ns1:LearningResult ;
    ns1:learningResultCode "RA48" ;
    ns1:learningResultDescription "Comprensión de las metodologías de diseño y modelado de usuario y Evaluación de sistemas de diálogo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93001023/2025-26/RA49> a ns1:LearningResult ;
    ns1:learningResultCode "RA49" ;
    ns1:learningResultDescription "Colocación y rutado de componentes en una PCB"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93001023/2025-26/RA50> a ns1:LearningResult ;
    ns1:learningResultCode "RA50" ;
    ns1:learningResultDescription "Analizar y diseñar la interfaz de usuario en sistemas electrónicos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93001023/2025-26/RA51> a ns1:LearningResult ;
    ns1:learningResultCode "RA51" ;
    ns1:learningResultDescription "Verificación de trazado"@es .

