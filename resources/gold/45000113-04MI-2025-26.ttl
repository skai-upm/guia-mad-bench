<https://guia-kg.skai.etsisi.upm.es/resource/45000113/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/45000113/2025-26/CE%202.>,
        <https://guia-kg.skai.etsisi.upm.es/resource/45000113/2025-26/CE%207.>,
        <https://guia-kg.skai.etsisi.upm.es/resource/45000113/2025-26/CE%208.>,
        <https://guia-kg.skai.etsisi.upm.es/resource/45000113/2025-26/CG%2011>,
