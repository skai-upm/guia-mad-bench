        <https://guia-kg.skai.etsisi.upm.es/resource/45000113/2025-26/didactic_resource/2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/45000113/2025-26/didactic_resource/3>,
        <https://guia-kg.skai.etsisi.upm.es/resource/45000113/2025-26/didactic_resource/4>,
        <https://guia-kg.skai.etsisi.upm.es/resource/45000113/2025-26/didactic_resource/5> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/45000113/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/45000113/2025-26/RA127>,
        <https://guia-kg.skai.etsisi.upm.es/resource/45000113/2025-26/RA64>,
        <https://guia-kg.skai.etsisi.upm.es/resource/45000113/2025-26/RA65> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/45000113/2025-26/syllabus> ;
    ns1:inpersonHours "51 horas (39.2%)"@es ;
    ns1:numberOfCredits 5.0 ;
    ns1:otherInformation """Es importante y formativo resolver los cuestionarios de autoevaluación que se proponen en Moodle para cada tema.
BIBLIOGRAFÍA COMPLEMENTARIA (para ampliar conocimientos): "ASM Handbook. Vol 13 A. Corrosion: Fundamentals, Testing and Protection"; ASM International, 2003./ "Control de la corrosión. Estudio y medida por técnicas electroquímicas." J.A. González Fernández; CSIC, CENIM; 1989./ "Corrosión y protección metálicas." (2 vols.). S. Feliu y M.C. Andrade (coord); CSIC; 1991./ "Corrosiones metálicas." U.R. Evans; Ed Reverté; 1987./ "Corrosion and protection of metals." G. Wraglén; Chapman and Hall; 1985./ "Teoría y Práctica de la lucha contra la corrosión." J.A. González Fernández (coord). CSIC, CENIM; 1984./ "Engineered Materials Handbook. Vol 1. Composites." ASM International; 1987."""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "135 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/45000113/2025-26/eventSchedule> ;
    schema:description "Esta materia trata de los procesos de degradación química de las superficies de los metales. Se explican los mecanismos de los procesos de corrosión, de oxidación directa y de corrosión electroquímica. Se detallan diferentes tipos de ataques y fallos por corrosión, así como distintas técnicas de ensayos de corrosión. Finalmente, se analizan los métodos de protección frente a la corrosión más habitualmente utilizados."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/javier.onoro%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/gerardo.romani%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/javier.onoro%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/santiago.isidro%40upm.es> ;
    schema:name "Química de Superficies"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000113/2025-26/CE%202.> a ns1:Competency ;
    ns1:competencyCode "CE 2." ;
    ns1:competencyDescription "Saber modelizar el comportamiento (mecánico, electrónico, químico o biológico) de los materiales y su integración en componentes y dispositivos./ Know how to model the behavior (mechanical, electronic, chemical or biological) of materials and their integration into components and devices."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000113/2025-26/CE%207.> a ns1:Competency ;
    ns1:competencyCode "CE 7." ;
    ns1:competencyDescription "Saber diseñar, desarrollar y controlar los procesos de producción y transformación de materiales / Know how to design, develop and control the processes of production and transformation of materials"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000113/2025-26/CE%208.> a ns1:Competency ;
    ns1:competencyCode "CE 8." ;
    ns1:competencyDescription "Saber diseÃ±ar y gestionar la utilizaciÃ³n y durabilidad de componentes y dispositivos con materiales, con especial cuidado en el deterioro de materiales y siendo respetuosos con el medio ambiente / Know how to design and manage the use and durability of components and devices with materials, with special care in the deterioration of materials and being respectful with the environment"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000113/2025-26/CG%2011> a ns1:Competency ;
    ns1:competencyCode "CG 11" ;
    ns1:competencyDescription "Responsabilidad y ética profesional/ Responsibility and professional ethics"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000113/2025-26/CG%203> a ns1:Competency ;
    ns1:competencyCode "CG 3" ;
    ns1:competencyDescription "Comunicación oral y escrita"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000113/2025-26/CG%209> a ns1:Competency ;
    ns1:competencyCode "CG 9" ;
    ns1:competencyDescription "Capacidad de trabajo interdisciplinar/ Capacity for interdisciplinary work"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000113/2025-26/RA127> a ns1:LearningResult ;
    ns1:learningResultCode "RA127" ;
    ns1:learningResultDescription "Conocer la cinética y los mecanismos de la interacción de los materiales metálicos con el medio ambiente."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000113/2025-26/RA64> a ns1:LearningResult ;
    ns1:learningResultCode "RA64" ;
    ns1:learningResultDescription "Entender, asimilar y manejar los conceptos básicos que describen el comportamiento químico y biológico de los materiales en su interacción con el entorno. Conocer y saber relacionar dicho comportamiento con la estructura del material y su jerarquización a diferentes escalas atómico, molecular y macroscópico."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000113/2025-26/RA65> a ns1:LearningResult ;
    ns1:learningResultCode "RA65" ;
    ns1:learningResultDescription "Conocer y saber calcular mediante las teorías más relevantes la degradación y corrosión química y biológica de los materiales. Conocer y saber aplicar las técnicas de protección y durabilidad."@es .

