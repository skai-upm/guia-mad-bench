<https://guia-kg.skai.etsisi.upm.es/resource/45000113/2025-26/syllabus> a ns1:Syllabus ;
    ns1:hasItem <https://guia-kg.skai.etsisi.upm.es/resource/45000113/2025-26/syllabus/0>,
        <https://guia-kg.skai.etsisi.upm.es/resource/45000113/2025-26/syllabus/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/45000113/2025-26/syllabus/10>,
        <https://guia-kg.skai.etsisi.upm.es/resource/45000113/2025-26/syllabus/11>,
        <https://guia-kg.skai.etsisi.upm.es/resource/45000113/2025-26/syllabus/2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/45000113/2025-26/syllabus/3>,
        <https://guia-kg.skai.etsisi.upm.es/resource/45000113/2025-26/syllabus/4>,
        <https://guia-kg.skai.etsisi.upm.es/resource/45000113/2025-26/syllabus/5>,
        <https://guia-kg.skai.etsisi.upm.es/resource/45000113/2025-26/syllabus/6>,
        <https://guia-kg.skai.etsisi.upm.es/resource/45000113/2025-26/syllabus/7>,
        <https://guia-kg.skai.etsisi.upm.es/resource/45000113/2025-26/syllabus/8>,
        <https://guia-kg.skai.etsisi.upm.es/resource/45000113/2025-26/syllabus/9> .

<https://guia-kg.skai.etsisi.upm.es/resource/45000113/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Introducción."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000113/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Definición. Importancia de la corrosión. Clasificación de los procesos de corrosión. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000113/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "6. Protección contra la corrosión."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000113/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "6.1. Material (composición, estructura, condición superficial). Diseño. Medio (supresión de agentes corrosivos; inhibidores). Cambio de potencial metal/medio (protecciones anódica y catódicas). Recubrimientos (metálicos; no metálicos inorgánicos; pinturas). Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000113/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "2. Oxidación directa."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000113/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "2.1. Generalidades. Termodinámica de la corrosión seca. Formación y características de las capas de óxido. Relación de Pilling-Bedworth. Cinética de la corrosión seca. Teorías electrónicas. Métodos de protección contra la corrosión seca. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000113/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "3. Ataques y fallos por corrosión."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000113/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "3.1. Corrosión: generalizada; localizada; atmosférica; galvánica; por corrientes vagabundas; filiforme; en resquicios; por picaduras; inducida por microorganismos; intergranular; selectiva; -erosión; -fricción; -cavitación; -fatiga; bajo tensión. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000113/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "4. Corrosión electroquímica."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000113/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "4.1. Consideraciones termodinámicas. Potenciales de electrodo. Serie electroquímica. Electrodos de referencia. Polarización. Series galvánicas. Diagramas de Evans. Curvas de polarización. Pasivación. Potencial de Flade. Diagramas de Pourbaix. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000113/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "5. Ensayos de corrosión."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000113/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "5.1. Convencionales: Condiciones; tipos; factores de consideración; muestras; resultados. Electroquímicos de corriente: continua (intersección; resistencia de polarización; de corrosión localizada); no estacionaria (EIS; impulsos; ruido electroquímico). Sin subniveles"@es .

