    ns1:itemIndex 11 ;
    ns1:syllabusDescription "6. GUIA DE DESARROLLO DEL CONCEPTO OPERACIONAL."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005003/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "6.1. 5.1. Fases de desarrollo de OCD. 5.2. Aplicación a la definición detallada de elementos del futuro concepto operacional ATM en entorno europeo Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005003/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. 1.3. Definición de rutas. Organización y clasificación del espacio aéreo. Gestión de flujos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005003/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "2. DESARROLLO DEL CONCEPTO DE OPERACIÓN Y OCD."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005003/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "2.1. 2.1. Definición de concepto de operación. 2.2. Objetivo del OCD. 2.3. Diferentes perspectivas en el análisis del concepto operacional. 2.4. Casos de uso del OCD. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005003/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "3. CONCEPTO OPERACIONAL DE SESAR"@es .

