    ns1:itemIndex 6 ;
    ns1:syllabusDescription "3.1. 3.1. Identificación de nuevos requisites. 3.2. Definición de principios e impulsores de desarrollo. 3.3. Principales elementos del concepto. 3.4. Características de los Sistemas y medios de apoyo Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005003/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "4. CONCEPTO OPERACIONAL DE NEXTGEN."@es .

