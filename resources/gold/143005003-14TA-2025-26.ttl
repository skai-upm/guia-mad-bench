<https://guia-kg.skai.etsisi.upm.es/resource/143005003/2025-26/CE3> a ns1:Competency ;
    ns1:competencyCode "CE3" ;
    ns1:competencyDescription "Establecer las funciones esenciales necesarias para la definición de los escenarios de Gestión del Tránsito Aéreo (ATM)"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005003/2025-26/CE4> a ns1:Competency ;
    ns1:competencyCode "CE4" ;
    ns1:competencyDescription "Identificar las necesidades técnicas y operativas asociadas a la definición de un concepto operacional ATM"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005003/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Poseer y comprender conocimientos que aporten una base u oportunidad de ser originales en el desarrollo de nuevos conceptos y técnicas aplicados al Sistema del Transporte Aéreo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005003/2025-26/CG2> a ns1:Competency ;
    ns1:competencyCode "CG2" ;
    ns1:competencyDescription "Aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en los entornos de evolución previstos en los Sistemas de Transporte Aéreo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005003/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Integrar conocimientos y enfrentarse a la complejidad de formular juicios a partir de una información que, siendo incompleta o limitada, incluya reflexiones sobre las responsabilidades sociales y éticas que puedan estar vinculadas a la aplicación de sus conocimientos y juicios en el marco correspondiente a los Sistemas del Transporte Aéreo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005003/2025-26/CG4> a ns1:Competency ;
    ns1:competencyCode "CG4" ;
    ns1:competencyDescription "Comunicar sus conclusiones y los conocimientos y razones últimas que las sustentan a públicos especializados, y no especializados de un modo claro y sin ambigüedades"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005003/2025-26/CG6> a ns1:Competency ;
    ns1:competencyCode "CG6" ;
    ns1:competencyDescription "Que los estudiantes posean las habilidades de aprendizaje que les permitan continuar estudiando de un modo que habrá de ser en gran medida autodirigido o autónomo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005003/2025-26/CT2> a ns1:Competency ;
    ns1:competencyCode "CT2" ;
    ns1:competencyDescription "Organizar y planificar el trabajo, de forma independiente o como miembro de un equipo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005003/2025-26/CT3> a ns1:Competency ;
    ns1:competencyCode "CT3" ;
    ns1:competencyDescription "Gestionar la información, identificando las fuentes necesarias, los principales tipos de documentos técnicos y científicos que son de aplicación en el entorno de los Sistemas del Transporte Aéreo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005003/2025-26/CT4> a ns1:Competency ;
    ns1:competencyCode "CT4" ;
    ns1:competencyDescription "Analizar implicaciones económicas, administrativas, sociales o medioambientales ligadas a la aplicación de nuevos conceptos y técnicas en el Sistema del Transporte Aéreo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005003/2025-26/RA27> a ns1:LearningResult ;
    ns1:learningResultCode "RA27" ;
    ns1:learningResultDescription "Conocimiento de los sistemas y subsistemas que dan soporte al sistema de Navegación, de los transmisores y receptores integrados en cualquier aeronave o vehículo espacial y de su instalación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005003/2025-26/RA33> a ns1:LearningResult ;
    ns1:learningResultCode "RA33" ;
    ns1:learningResultDescription "Conocer, comprender, analizar y valorar la Organización Aeronáutica nacional e internacional y del funcionamiento de los distintos modos del sistema mundial de transportes, con especial énfasis en el transporte aéreo."@es .

