<https://guia-kg.skai.etsisi.upm.es/resource/565000262/2025-26/syllabus> a ns1:Syllabus ;
    ns1:hasItem <https://guia-kg.skai.etsisi.upm.es/resource/565000262/2025-26/syllabus/0>,
        <https://guia-kg.skai.etsisi.upm.es/resource/565000262/2025-26/syllabus/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/565000262/2025-26/syllabus/10>,
        <https://guia-kg.skai.etsisi.upm.es/resource/565000262/2025-26/syllabus/11>,
        <https://guia-kg.skai.etsisi.upm.es/resource/565000262/2025-26/syllabus/2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/565000262/2025-26/syllabus/3>,
        <https://guia-kg.skai.etsisi.upm.es/resource/565000262/2025-26/syllabus/4>,
        <https://guia-kg.skai.etsisi.upm.es/resource/565000262/2025-26/syllabus/5>,
        <https://guia-kg.skai.etsisi.upm.es/resource/565000262/2025-26/syllabus/6>,
        <https://guia-kg.skai.etsisi.upm.es/resource/565000262/2025-26/syllabus/7>,
        <https://guia-kg.skai.etsisi.upm.es/resource/565000262/2025-26/syllabus/8>,
        <https://guia-kg.skai.etsisi.upm.es/resource/565000262/2025-26/syllabus/9> .

<https://guia-kg.skai.etsisi.upm.es/resource/565000262/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Tema 1: Introducción y generalidades sobre metrología."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000262/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Definiciones y conceptos básicos. Variabilidad en las medidas. Fuentes de incertidumbre. Métodos para la evaluación de la incertidumbre de medida. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000262/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "6. Tema 6: Medidas de potencia y energía."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000262/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "6.1. Métodos para la medida de la potencia activa y reactiva. Análisis teórico. Aplicaciones. Evaluación de la incertidumbre. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000262/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "2. Tema 2: Calibrado y verificación de equipos de medida eléctricos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000262/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "2.1. La cadena de trazabilidad. Aparatos patrones, de laboratorio y de uso industrial. División en clases. Calibrado y verificación de aparatos. Evaluación de la incertidumbre. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000262/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "3. Tema 3: Adaptadores y transductores para medidas eléctricas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000262/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "3.1. Adaptación de señales eléctricas. Divisores de tensión e intensidad. Transformadores y sondas de medida. Calibrado y verificación de adaptadores y sensores. Evaluación de la incertidumbre. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000262/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "4. Tema 4: Medida de tensiones, intensidades y resistencias."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000262/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "4.1. Métodos y procedimientos de medida. Análisis teórico. Aplicaciones. Limitaciones. Correcciones a aplicar. Evaluación de la incertidumbre. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000262/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "5. Tema 5: Medida de impedancias, capacidades y autoinducciones."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000262/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "5.1. Métodos industriales y de laboratorio. Análisis teórico. Aplicaciones. Evaluación de la incertidumbre. Sin subniveles"@es .

