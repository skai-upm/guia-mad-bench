<https://guia-kg.skai.etsisi.upm.es/resource/205000089/2025-26/RA141> a ns1:LearningResult ;
    ns1:learningResultCode "RA141" ;
    ns1:learningResultDescription "Identificar y utilizar los instrumentos, métodos y técnicas topográficas, cartográficas y fotogramétricas en el ámbito agrario."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000089/2025-26/RA142> a ns1:LearningResult ;
    ns1:learningResultCode "RA142" ;
    ns1:learningResultDescription "Describir la forma y dimensiones de la Tierra y sus formas de representación. Identificar los sistemas de referencia y su materialización mediante redes geodésicas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000089/2025-26/RA143> a ns1:LearningResult ;
    ns1:learningResultCode "RA143" ;
    ns1:learningResultDescription "Utilizar de forma adecuada los instrumentos topográficos en su aplicación a los proyectos de ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000089/2025-26/RA144> a ns1:LearningResult ;
    ns1:learningResultCode "RA144" ;
    ns1:learningResultDescription "Dominar los métodos topográficos planimétricos y altimétricos para la realización de cartografía aplicada a la ingeniería mediante software específico."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000089/2025-26/RA145> a ns1:LearningResult ;
    ns1:learningResultCode "RA145" ;
    ns1:learningResultDescription "Enumerar las aplicaciones de la Topografía en el ámbito de los proyectos agrarios."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000089/2025-26/RA146> a ns1:LearningResult ;
    ns1:learningResultCode "RA146" ;
    ns1:learningResultDescription "Relacionar las características de los distintos tipos de sistemas de proyección cartográficos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000089/2025-26/RA147> a ns1:LearningResult ;
    ns1:learningResultCode "RA147" ;
    ns1:learningResultDescription "Demostrar el manejo adecuado de la cartografía temática y las IDEs."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000089/2025-26/RA148> a ns1:LearningResult ;
    ns1:learningResultCode "RA148" ;
    ns1:learningResultDescription "Definir los Sistemas de Navegación Global por Satélite y ser capaz de utilizar adecuadamente los receptores y software específicos para su aplicación en proyectos de ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000089/2025-26/RA149> a ns1:LearningResult ;
    ns1:learningResultCode "RA149" ;
    ns1:learningResultDescription "Relatar el concepto de Fotogrametría y sus aplicaciones en ingeniería agraria."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000089/2025-26/RA150> a ns1:LearningResult ;
    ns1:learningResultCode "RA150" ;
    ns1:learningResultDescription "Citar los sistemas satelitales de observación terrestre y sus aplicaciones en agricultura."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000089/2025-26/RA151> a ns1:LearningResult ;
    ns1:learningResultCode "RA151" ;
    ns1:learningResultDescription "Nombrar los distintos tipos de SIG, funcionalidad y sus aplicaciones en agricultura."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000089/2025-26/RA163> a ns1:LearningResult ;
    ns1:learningResultCode "RA163" ;
    ns1:learningResultDescription "El alumno es capaz de trabajar en grupo"@es .

