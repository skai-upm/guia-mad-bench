    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/145006402/2025-26/eventSchedule> ;
    schema:description "La asignatura desarrolla el Subsistema de Actividades Aeroportuarias de la Zona de Servicio de un aeropuerto. Se da especial relevancia al diseño funcional de la terminal de pasajeros, que se extiende a lo largo de la mitad del semestre. En la segunda mitad se desarrollan el resto de elementos del subsistema (Zona de carga, industrial, aviación general, asistencia en tierra a aeronaves, sistemas tecnológicos, torres de control, etc.). La asignatura es complementaria con la de Aeródromos, impartida en el primer semestre del curso y que trata principalmente del otro gran subsistema de la Zona de Servicio del Aeropuerto, el Subsistema de Movimiento de Aeronaves."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/angel.paris%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/angel.paris%40upm.es> ;
    schema:name "Edificios e Instalaciones, Urbanizacion y Accesos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145006402/2025-26/CE57> a ns1:Competency ;
    ns1:competencyCode "CE57" ;
    ns1:competencyDescription "Conocimiento adecuado y aplicado a la Ingeniería de: Los materiales utilizados en la edificación; las necesidades y desarrollo de las infraestructuras aeroportuarias y su impacto ambiental; las edificaciones necesarias para la operación y funcionamiento de los aeropuertos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145006402/2025-26/CE58> a ns1:Competency ;
    ns1:competencyCode "CE58" ;
    ns1:competencyDescription "Conocimiento adecuado y aplicado a la Ingeniería de: La normativa específica de edificación; los procedimientos de control y ejecución de obras; el funcionamiento y la gestión del aeropuerto y el transporte aéreo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145006402/2025-26/CE59> a ns1:Competency ;
    ns1:competencyCode "CE59" ;
    ns1:competencyDescription "Conocimiento adecuado y aplicado a la Ingeniería de: Los métodos de cálculo y de desarrollo de las diferentes soluciones de edificación y pavimentación de aeropuertos; el cálculo de los sistemas específicos de los aeropuertos y sus infraestructuras; la evaluación de las actuaciones técnicas y económicas de las aeronaves; el manejo de las técnicas experimentales, equipamiento e instrumentos de medida propios de la disciplina; las técnicas de inspección, de control de calidad y de detección de fallos; los planes de seguridad y control en aeropuertos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145006402/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Capacidad de Organización y de Planificación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145006402/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Capacidad para identificar y resolver problemas aplicando, con creatividad, los conocimientos adquiridos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145006402/2025-26/CG8> a ns1:Competency ;
    ns1:competencyCode "CG8" ;
    ns1:competencyDescription "Capacidad de integrar el respeto al medio ambiente en el desarrollo de sus actividades"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145006402/2025-26/CG9> a ns1:Competency ;
    ns1:competencyCode "CG9" ;
    ns1:competencyDescription "Razonamiento crítico y capacidad de asociación que posibiliten el aprendizaje continuo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145006402/2025-26/RA297> a ns1:LearningResult ;
    ns1:learningResultCode "RA297" ;
    ns1:learningResultDescription "Conocimiento y comprensión de los elementos de la zona de actividades aeroportuaria, su forma de operación y los agentes involucrados en la misma"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145006402/2025-26/RA298> a ns1:LearningResult ;
    ns1:learningResultCode "RA298" ;
    ns1:learningResultDescription "Conocimiento, aplicación y Síntesis para realizar la planificación de la zona de actividades aeroportuarias"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145006402/2025-26/RA299> a ns1:LearningResult ;
    ns1:learningResultCode "RA299" ;
    ns1:learningResultDescription "Conocimiento, aplicación y Síntesis para integrar los diversos sistemas de la zona de actividades aeroportuarias en la zona de movimiento de aeronaves de un aeropuerto; y el lado tierra de un aeropuerto en su entorno"@es .

