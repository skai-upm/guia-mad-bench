    schema:name "Mecanismos Financieros de Adaptacion Al Cambio Climatico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000197/2025-26/CB07> a ns1:Competency ;
    ns1:competencyCode "CB07" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en entornos nuevos o poco conocidos dentro de contextos más amplios (o multidisciplinares) relacionados con su área de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000197/2025-26/CG02> a ns1:Competency ;
    ns1:competencyCode "CG02" ;
    ns1:competencyDescription "El alumno podrá utilizar las herramientas necesarias para llevar a cabo los cambios en la empresa y en la sociedad para adoptar un modelo de economía circular."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000197/2025-26/CG03> a ns1:Competency ;
    ns1:competencyCode "CG03" ;
    ns1:competencyDescription "El alumno tendrá capacidad para evaluar los procesos de producción y consumo que permitan una gestión sostenible de los recursos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000197/2025-26/CT03> a ns1:Competency ;
    ns1:competencyCode "CT03" ;
    ns1:competencyDescription "El alumno tendrá capacidad para gestionar la información procedente de diversas fuentes, valorando su relevancia, fiabilidad y pertinencia para un propósito determinado, analizándola y organizándola."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000197/2025-26/RA15> a ns1:LearningResult ;
    ns1:learningResultCode "RA15" ;
    ns1:learningResultDescription "Analizar los efectos del cambio climático sobre la conservación de la biodiversidad"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000197/2025-26/RA17> a ns1:LearningResult ;
    ns1:learningResultCode "RA17" ;
    ns1:learningResultDescription "Aplicar los mecanismos/fuentes de financiación para combatir el cambio climático"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000197/2025-26/RA18> a ns1:LearningResult ;
    ns1:learningResultCode "RA18" ;
    ns1:learningResultDescription "Capacidad para situar y comprender las bases de los acuerdos supranacionales sobre cambio climático y su incidencia en la normativa español"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000197/2025-26/RA19> a ns1:LearningResult ;
    ns1:learningResultCode "RA19" ;
    ns1:learningResultDescription "Capacidad para aplicar los mecanismos para gestionar la adaptación al cambio climático así como los mecanismos de financiación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000197/2025-26/RA20> a ns1:LearningResult ;
    ns1:learningResultCode "RA20" ;
    ns1:learningResultDescription "Analizar modelos de negocio innovadores basados en una idea emprendedora del emprendimiento"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000197/2025-26/RA23> a ns1:LearningResult ;
    ns1:learningResultCode "RA23" ;
    ns1:learningResultDescription "Que los estudiantes conozcan los fundamentos financieros"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000197/2025-26/RA63> a ns1:LearningResult ;
    ns1:learningResultCode "RA63" ;
    ns1:learningResultDescription "Desarrollar un pensamiento crítico y fundamentado en relación con el aprovechamiento de los recursos naturales"@es .

