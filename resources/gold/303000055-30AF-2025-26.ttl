    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Introducción a los recursos para la didáctica de las ciencias Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000055/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "8. La utilización y realización de maquetas y modelos manipulables, reales y virtuales, como recursos didácticos de las ciencias Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000055/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "9. Búsqueda y uso de applets para la enseñanza de la física y la química Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000055/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "10. Realización de actividades fuera del aula"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000055/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "10.1. Visitas a museos y exposiciones Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000055/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "10.2. Participación en concursos y ferias científicas Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000055/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "10.3. Visitas a industrias y servicios de la comunidad Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000055/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "11. Cuestiones de arte e historia como recursos para el aprendizaje de la ciencia Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000055/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Recursos para introducir a los alumnos en el método científico y promover su motivación Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000055/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "1.3. Introducción a las fuentes de recursos educativos: libros, bases de datos, vídeos, proyectos educativos, revistas, portales de internet, aplicaciones informáticas, applets y otros Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000055/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "2. El conocimiento didáctico del contenido (pedagogical content knowledge) y las ideas previas de los alumnos como recursos para el aprendizaje de las ciencias Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000055/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "3. Resolución de problemas y ejercicios para el aprendizaje de física y química Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000055/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "4. Trabajos prácticos en el laboratorio y en el aula Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000055/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "5. Uso de analogías y comparaciones Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000055/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "6. Generación de recursos contextualizados y con enfoques CTSA (ciencia, tecnología, sociedad y medio ambiente) Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000055/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "7. Los juguetes/ingenios científicos y las demostraciones divulgativas como recursos motivacionales y didácticos Sin subniveles"@es .

