        <https://guia-kg.skai.etsisi.upm.es/resource/53000683/2025-26/RA34> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/53000683/2025-26/syllabus> ;
    ns1:inpersonHours "39 horas (50%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation "En la asignatura se trabajan las diferentes fuentes de energía, su financiación y su contribución a la mejora de las condiciones de vida del hombre y del medio ambiente. Todos estos conocimientos se encuentran cubiertos en los objetivos 7 energía asequible y no contaminante y 13 acción por el clima"@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "39 horas"@es ;
    schema:activitiesWorkload "99.93%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/53000683/2025-26/eventSchedule> ;
    schema:description """The aim of this course is to provide the students with a broad knowledge of the energy markets.

It is focused on commodities (oil,gas and coal) and how commodities are produced and traded. Also how power is produced from different sources and how new needs arised from the shift to a greener and more sustainable world is affecting this markets.

Last but not least students will learn how physical deals work and how energy derivatives are traded."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/mercedes.grijalvo%40upm.es> ;
    schema:inLanguage "Inglés/Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/franciscojavier.urbano%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/mercedes.grijalvo%40upm.es> ;
    schema:name "Energy And Commodities Markets"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000683/2025-26/CB08> a ns1:Competency ;
    ns1:competencyCode "CB08" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de integrar conocimientos y enfrentarse a la complejidad de formular juicios a partir de una información que, siendo incompleta o limitada, incluya reflexiones sobre las responsabilidades sociales y éticas vinculadas a la aplicación de sus conocimientos y juicios"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000683/2025-26/CB09> a ns1:Competency ;
    ns1:competencyCode "CB09" ;
    ns1:competencyDescription "Que los estudiantes sepan comunicar sus conclusiones y los conocimientos y razones últimas que las sustentan a públicos especializados y no especializados de un modo claro y sin ambigüedades"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000683/2025-26/CB10> a ns1:Competency ;
    ns1:competencyCode "CB10" ;
    ns1:competencyDescription "Que los estudiantes posean las habilidades de aprendizaje que les permitan continuar estudiando de un modo que habrá de ser en gran medida autodirigido o autónomo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000683/2025-26/CE03> a ns1:Competency ;
    ns1:competencyCode "CE03" ;
    ns1:competencyDescription "Identificar y caracterizar las implicaciones económicas y estratégicas de las decisiones empresariales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000683/2025-26/CE10> a ns1:Competency ;
    ns1:competencyCode "CE10" ;
    ns1:competencyDescription "Comprender y aprovechar la estructura de opciones subyacente en los proyectos de inversión y su aplicación para la valoración de proyectos, empresas y negocios"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000683/2025-26/CE12> a ns1:Competency ;
    ns1:competencyCode "CE12" ;
    ns1:competencyDescription "Conocer las fuentes e instrumentos de financiación empresarial, los mercados de capitales y los fundamentos de las decisiones de financiación corporativa"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000683/2025-26/CT06> a ns1:Competency ;
    ns1:competencyCode "CT06" ;
    ns1:competencyDescription "Es responsable. Comprensión de la responsabilidad ética y profesional"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000683/2025-26/CT07> a ns1:Competency ;
