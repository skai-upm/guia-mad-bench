<https://guia-kg.skai.etsisi.upm.es/resource/53001579/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/53001579/2025-26/CB07>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001579/2025-26/CE05>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001579/2025-26/CG03>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001579/2025-26/CT02>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001579/2025-26/CT11> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/53001579/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001579/2025-26/didactic_resource/2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001579/2025-26/didactic_resource/3>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001579/2025-26/didactic_resource/4>,
