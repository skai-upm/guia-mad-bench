    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/105001042/2025-26/RA115>,
        <https://guia-kg.skai.etsisi.upm.es/resource/105001042/2025-26/RA116>,
        <https://guia-kg.skai.etsisi.upm.es/resource/105001042/2025-26/RA63> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/105001042/2025-26/syllabus> ;
    ns1:inpersonHours "150 horas y 15 minutos (48.2%)"@es ;
    ns1:numberOfCredits 12.0 ;
    ns1:otherInformation """La Oficina de Relaciones con el Exterior dará apoyo y asesoría a la realización del practicum.
Antes de realizar la matrícula, el estudiante debe haber entregado una muestra de interés (en abril para primer semestre), en noviembre (para segundo semestre) junto con certificado de notas y CV.
El estudiante debe iniciar el proceso de búsqueda de destino a través de la Oficina Central de Prácticas Externas de la UPM (https://practicas-externas.upm.es/)
El estudiante debe presentar en la fecha que se le indique una Propuesta de Practicum que evaluará la Comisión de Prácticas Externas del Centro.
Sólo serán válidas las matrículas de practicum cuyas propuestas hayan sido aprobadas previamente por la Comisión."""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "180 horas y 15 minutos"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/105001042/2025-26/eventSchedule> ;
    schema:description """1. Desarrollo de tareas profesionales dentro de un entorno profesional
2. Elaboración de informes
3. Presentación oral"""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/roberto.valle%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/roberto.valle%40upm.es> ;
    schema:name "Practicum"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105001042/2025-26/CB02> a ns1:Competency ;
    ns1:competencyCode "CB02" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar sus conocimientos a su trabajo o vocación de una forma profesional y posean las competencias que suelen demostrarse por medio de la elaboración y defensa de argumentos y la resolución de problemas dentro de su área de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105001042/2025-26/CE21> a ns1:Competency ;
    ns1:competencyCode "CE21" ;
    ns1:competencyDescription "Poseer las destrezas para llevar a cabo un ejercicio original a realizar individualmente y presentar y defender ante un tribunal universitario, consistente en un proyecto multidisciplinar de estudio o diseño de un sistema, aplicación o servicio de ciencia de datos o inteligencia artificial en el ámbito de las tecnologías específicas de la Ingeniería Informática de naturaleza profesional en el que se sinteticen e integren las competencias adquiridas en las enseñanzas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105001042/2025-26/CG01> a ns1:Competency ;
    ns1:competencyCode "CG01" ;
    ns1:competencyDescription "Capacidad de trabajo en equipo, en entornos interdisciplinares y complejos, negociando y resolviendo conflictos, diseñando soluciones eficientes, fiables, robustas y responsables."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105001042/2025-26/RA115> a ns1:LearningResult ;
    ns1:learningResultCode "RA115" ;
    ns1:learningResultDescription "Diseñar y construir sistemas informáticos capaces de resolver problemas para los que no se conoce solución."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105001042/2025-26/RA116> a ns1:LearningResult ;
    ns1:learningResultCode "RA116" ;
    ns1:learningResultDescription "Dado un problema real elegir la tecnología de ciencia de datos o de inteligencia artificial existente en el mercado más apropiada para su solución y diseñar su desarrollo e integración analizando la viabilidad de su solución, lo que se puede y no se puede conseguir a través del estado actual de desarrollo de la tecnología usada, y lo que se espera que avance en el futuro"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105001042/2025-26/RA63> a ns1:LearningResult ;
    ns1:learningResultCode "RA63" ;
    ns1:learningResultDescription "Identificar y describir las áreas funcionales de una empresa y sus responsabilidades, así como el análisis y diseño de los procesos de negocio."@es .

