        "Creación de Empresas y Planes de Negocio"@es ;
    schema:numberOfCredits 3.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/45000270/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/45000270/2025-26/30AD.%20E10>,
        <https://guia-kg.skai.etsisi.upm.es/resource/45000270/2025-26/30AD.%20E13>,
        <https://guia-kg.skai.etsisi.upm.es/resource/45000270/2025-26/30AD.%20G01>,
        <https://guia-kg.skai.etsisi.upm.es/resource/45000270/2025-26/30AD.%20G06> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/45000270/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/45000270/2025-26/didactic_resource/2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/45000270/2025-26/didactic_resource/3>,
        <https://guia-kg.skai.etsisi.upm.es/resource/45000270/2025-26/didactic_resource/4> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/45000270/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/45000270/2025-26/RA12>,
        <https://guia-kg.skai.etsisi.upm.es/resource/45000270/2025-26/RA92> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/45000270/2025-26/syllabus> ;
    ns1:inpersonHours "36 horas y 15 minutos (46.5%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation "Esta asignatura se relaciona con el ODS8 y el ODS9."@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "36 horas y 15 minutos"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/45000270/2025-26/eventSchedule> ;
    schema:description """Los objetivos de la asignatura son:
- Entender los conceptos básicos relacionados con la creación de empresas, estimulando la creatividad y dando a conocer la naturaleza del proceso de creación de empresas y su importancia en una economía de mercado.
- Entender y aplicar herramientas básicas para el análisis y la generación de modelos de negocio.
- Desarrollar la habilidad de identificar, analizar y combinar aspectos técnicos y de negocio a la hora de elaborar un plan de negocio de una empresa de reciente creación, que contemple los principios éticos de la actividad empresarial y pueda apoyarse en los programas institucionales y privados de finaciación y de apoyo al emprendimiento."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/l.garrido%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/juan.molina%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/l.garrido%40upm.es> ;
    schema:name "Creación de Empresas y Planes de Negocio"@es .

