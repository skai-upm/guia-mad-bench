<https://guia-kg.skai.etsisi.upm.es/resource/133000224/2025-26/RA101> a ns1:LearningResult ;
    ns1:learningResultCode "RA101" ;
    ns1:learningResultDescription "Diseñar planes de prevención de incendios orientados a la localización de \"puntos estratégicos de gestión\" en una determinada comarca o monte teniendo en cuenta su vulnerabilidad y la optimización de los recursos disponibles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000224/2025-26/RA102> a ns1:LearningResult ;
    ns1:learningResultCode "RA102" ;
    ns1:learningResultDescription "Evaluar la eficacia de las medidas de prevención propuestas o ejecutadas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000224/2025-26/RA103> a ns1:LearningResult ;
    ns1:learningResultCode "RA103" ;
    ns1:learningResultDescription "Identificar las técnicas y medios de extinción para generar oportunidades de extinción en escenarios de incendios complejos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000224/2025-26/RA104> a ns1:LearningResult ;
    ns1:learningResultCode "RA104" ;
    ns1:learningResultDescription "Elaborar y evaluar planes de extinción integrando equipos y medios de capacidades diversas con especial atención a la evaluación de riesgos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000224/2025-26/RA105> a ns1:LearningResult ;
    ns1:learningResultCode "RA105" ;
    ns1:learningResultDescription "Evaluar el peligro y la vulnerabilidad frente a incendios forestales en un territorio que permitan establecer las zonas de alto riesgo de incendios"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000224/2025-26/RA106> a ns1:LearningResult ;
    ns1:learningResultCode "RA106" ;
    ns1:learningResultDescription "Evaluar el riesgo de extensión del incendio en un interfaz urbano forestal y de las medidas de infraestructura y de prevención que faciliten la posible evacuación y protección contra los incendios forestales que puedan desarrollarse."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000224/2025-26/RA107> a ns1:LearningResult ;
    ns1:learningResultCode "RA107" ;
    ns1:learningResultDescription "Integrar la planificación preventiva en la gestión forestal estratégica del territorio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000224/2025-26/RA98> a ns1:LearningResult ;
    ns1:learningResultCode "RA98" ;
    ns1:learningResultDescription "Capacidad para planificar la prevención y extinción contra grandes incendios forestales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000224/2025-26/RA99> a ns1:LearningResult ;
    ns1:learningResultCode "RA99" ;
    ns1:learningResultDescription "Capacidad para integrar en la gestión forestal las prevención de grandes incendios forestales"@es .

