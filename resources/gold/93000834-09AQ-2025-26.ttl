    ns1:learningResultCode "RA299" ;
    ns1:learningResultDescription "To implement and use software, memory addressing modes and instructions of advanced processors"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000834/2025-26/RA300> a ns1:LearningResult ;
    ns1:learningResultCode "RA300" ;
    ns1:learningResultDescription "To specify the software design process for embedded system programming"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000834/2025-26/RA301> a ns1:LearningResult ;
    ns1:learningResultCode "RA301" ;
    ns1:learningResultDescription "To design and develop input/output and peripherals of an advanced processor"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000834/2025-26/RA302> a ns1:LearningResult ;
    ns1:learningResultCode "RA302" ;
    ns1:learningResultDescription "To design and implement new modules in FPGA using HDL"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000834/2025-26/RA303> a ns1:LearningResult ;
    ns1:learningResultCode "RA303" ;
    ns1:learningResultDescription "To implement applications using a Real"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000834/2025-26/RA304> a ns1:LearningResult ;
    ns1:learningResultCode "RA304" ;
    ns1:learningResultDescription "To design and implement real world applications using hardware platforms based on advanced processors"@es .

