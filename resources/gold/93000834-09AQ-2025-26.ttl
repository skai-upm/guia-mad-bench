    ns1:learningResultCode "RA296" ;
    ns1:learningResultDescription "To analyse and define advanced processor architectures, coding and programming models"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000834/2025-26/RA297> a ns1:LearningResult ;
    ns1:learningResultCode "RA297" ;
    ns1:learningResultDescription "To understand the design of a CPU and the memory unit of an advanced microprocessor"@es .

