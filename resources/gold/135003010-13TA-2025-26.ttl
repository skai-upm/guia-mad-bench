<https://guia-kg.skai.etsisi.upm.es/resource/135003010/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. UT 1.- Edafología."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003010/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Concepto de Edafología y Suelo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003010/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "1.2.1. Fracciones del suelo: sólida, líquida y gaseosa. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003010/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "1.2.2. Componente mineral y orgánico. Complejos órgano-minerales. Balance de materia orgánica. Relación C/N. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003010/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "1.2.3. Componente biológico. Clasificación y funciones de los organismos del suelo. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003010/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "1.3. Propiedades físicas del suelo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003010/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "1.3.1. Textura del suelo: fracciones granulométricas, clases texturales y su relación con otras propiedades del suelo. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003010/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "1.3.2. Estructura del suelo: concepto y formación de agregados. Clasificación morfológica de la estructura. Estabilidad estructural. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003010/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "1.3.3. Porosidad del suelo, densidad real y aparente. Determinación de la densidad. Compactación. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003010/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "1.3.4. El agua del suelo. Contenido: humedad gravimétrica y volumétrica. Potencial del agua en el suelo. Capacidad de campo y punto de marchitez permanente. Capacidad de retención de agua disponible (CRAD) y agua disponible (AD). Infiltración y permeabilidad. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003010/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "1.3.5. Práctica 1.- Edafología (Laboratorio): Determinación de elementos gruesos. Determinación de la humedad de la muestra seca al aire. Color del suelo. Textura del suelo al tacto. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003010/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "1.3.6. Práctica 2.- Edafología (Laboratorio): Propiedades físicas I.- Granulometría del suelo. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003010/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.1.1. El concepto de suelo y sus funciones. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003010/2025-26/syllabus/20> a ns1:SyllabusItem ;
    ns1:itemIndex 20 ;
    ns1:syllabusDescription "1.3.7. Práctica 3.- Edafología (Laboratorio): Propiedades físicas II.- Densidad aparente en muestra disturbada (tierra fina). Porosidad. Capacidad de campo. Cálculo del CRAD. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003010/2025-26/syllabus/21> a ns1:SyllabusItem ;
    ns1:itemIndex 21 ;
    ns1:syllabusDescription "1.4. Propiedades químicas del suelo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003010/2025-26/syllabus/22> a ns1:SyllabusItem ;
    ns1:itemIndex 22 ;
    ns1:syllabusDescription "1.4.1. La fracción coloidal del suelo. Capacidad de intercambio catiónico (T). Carga permanente y carga variable. Ecuaciones de intercambio. Cationes y bases del complejo de de cambio. Concepto de % de saturación de bases (V). Teoría de la doble capa difusa. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003010/2025-26/syllabus/23> a ns1:SyllabusItem ;
    ns1:itemIndex 23 ;
    ns1:syllabusDescription "1.4.2. Reacción del suelo: pH. Influencia sobre la disponibilidad relativa de elementos. Poder tampón del suelo. Tolerancia de las plantas al pH. Encalado de suelos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003010/2025-26/syllabus/24> a ns1:SyllabusItem ;
    ns1:itemIndex 24 ;
    ns1:syllabusDescription "1.4.3. Práctica 4.- Edafología (Laboratorio) Propiedades químicas I.- (1) pH y CE en agua (2) pH en KCl. (3) Determinación del carbonato cálcico equivalente(CaCO3 %). Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003010/2025-26/syllabus/25> a ns1:SyllabusItem ;
    ns1:itemIndex 25 ;
    ns1:syllabusDescription "1.4.4. El aire en el suelo. Química de los procesos de óxido-reducción en el suelo. Suelos hidromorfos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003010/2025-26/syllabus/26> a ns1:SyllabusItem ;
    ns1:itemIndex 26 ;
    ns1:syllabusDescription "1.4.5. Práctica 5.- Edafología (Laboratorio): Propiedades químicas II.- Materia orgánica oxidable (MOS%) por el método de Walkley Black. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003010/2025-26/syllabus/27> a ns1:SyllabusItem ;
    ns1:itemIndex 27 ;
    ns1:syllabusDescription "1.4.6. Concentración de sales y conductividad eléctrica. Salinidad-sodicidad. Diagnóstico y recuperación de suelos: salinos; salino-sódicos y sódicos. Tolerancia de la vegetación a la salinidad. Calidad del agua del riego. Balance de sales. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003010/2025-26/syllabus/28> a ns1:SyllabusItem ;
    ns1:itemIndex 28 ;
    ns1:syllabusDescription "1.4.7. Práctica 6.- Edafología (Laboratorio). Propiedades físico-químicas I.- (1) Pasta saturada: humedad de saturación; extracto de saturación: pH y conductividad eléctrica. (2) Calidad del agua de riego. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003010/2025-26/syllabus/29> a ns1:SyllabusItem ;
    ns1:itemIndex 29 ;
    ns1:syllabusDescription "1.4.8. Práctica 7.- Edafología (Laboratorio) Propiedades físico-químicas II.- Determinación de cationes y aniones en el extracto de saturación (solución) y/o en una agua de riego. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003010/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "1.1.2. Factores formadores del suelo. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003010/2025-26/syllabus/30> a ns1:SyllabusItem ;
    ns1:itemIndex 30 ;
    ns1:syllabusDescription "1.4.9. Práctica 8.- Edafología (Laboratorio). (1) Repetición y verificación de análisis. Interpretación de datos y evaluación para el medio ambiente. Consulta sobre la elaboración del trabajo de curso de edafología. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003010/2025-26/syllabus/31> a ns1:SyllabusItem ;
    ns1:itemIndex 31 ;
    ns1:syllabusDescription "1.5. Génesis y Clasificación de suelos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003010/2025-26/syllabus/32> a ns1:SyllabusItem ;
    ns1:itemIndex 32 ;
    ns1:syllabusDescription "1.5.1. Procesos de formación de suelos principalmente en clima mediterráneo; en otros climas; concepto de paleosuelos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003010/2025-26/syllabus/33> a ns1:SyllabusItem ;
    ns1:itemIndex 33 ;
    ns1:syllabusDescription "1.5.2. Color y temperatura del suelo. Importancias del color del suelo. Regímenes de temperatura del suelo. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003010/2025-26/syllabus/34> a ns1:SyllabusItem ;
    ns1:itemIndex 34 ;
    ns1:syllabusDescription "1.5.3. Horizontes de diagnótico Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003010/2025-26/syllabus/35> a ns1:SyllabusItem ;
    ns1:itemIndex 35 ;
    ns1:syllabusDescription "1.5.4. Regímenes de humedad de los suelos Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003010/2025-26/syllabus/36> a ns1:SyllabusItem ;
    ns1:itemIndex 36 ;
    ns1:syllabusDescription "1.5.5. Bases para la clasificación de suelos: Soil Taxonomy y WRB. Clasificación mediante Soil Taxonomy de los suelos en general (en el mundo), y los más frecuentes en la España (peninsular e insular). Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003010/2025-26/syllabus/37> a ns1:SyllabusItem ;
    ns1:itemIndex 37 ;
    ns1:syllabusDescription "2. UT 2.- Climatología."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003010/2025-26/syllabus/38> a ns1:SyllabusItem ;
    ns1:itemIndex 38 ;
    ns1:syllabusDescription "2.1. Nociones básicas de Meteorología y Climatología."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003010/2025-26/syllabus/39> a ns1:SyllabusItem ;
    ns1:itemIndex 39 ;
    ns1:syllabusDescription "2.1.1. Tiempo y clima. Meteorología y Climatología. Elementos y factores climáticos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003010/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "1.1.3. Relaciones entre los diferentes factores formadores y los suelos: zonalidad; intrazonalidad y azonalidad. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003010/2025-26/syllabus/40> a ns1:SyllabusItem ;
    ns1:itemIndex 40 ;
    ns1:syllabusDescription "2.1.2. Composición de la atmósfera: gases permanentes y variables. Aerosoles. Gases de efecto invernadero. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003010/2025-26/syllabus/41> a ns1:SyllabusItem ;
    ns1:itemIndex 41 ;
    ns1:syllabusDescription "2.1.3. Estructura vertical de la atmósfera: criterio químico; criterio térmico; otros criterios. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003010/2025-26/syllabus/42> a ns1:SyllabusItem ;
    ns1:itemIndex 42 ;
    ns1:syllabusDescription "2.2. Radiación. Calor y temperatura. Otros."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003010/2025-26/syllabus/43> a ns1:SyllabusItem ;
    ns1:itemIndex 43 ;
    ns1:syllabusDescription "2.2.1. Radiación: estimación a nivel de la superficie del suelo. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003010/2025-26/syllabus/44> a ns1:SyllabusItem ;
    ns1:itemIndex 44 ;
    ns1:syllabusDescription "2.2.2. Calor específico y latente. Temperatura. Datos de temperatura (medias, máximas y mínimas) y su nomenclatura. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003010/2025-26/syllabus/45> a ns1:SyllabusItem ;
    ns1:itemIndex 45 ;
    ns1:syllabusDescription "2.2.3. Oscilación diaria y anual de temperatura. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003010/2025-26/syllabus/46> a ns1:SyllabusItem ;
    ns1:itemIndex 46 ;
    ns1:syllabusDescription "2.2.4. Factores reguladores de la temperatura. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003010/2025-26/syllabus/47> a ns1:SyllabusItem ;
    ns1:itemIndex 47 ;
    ns1:syllabusDescription "2.2.5. Continentalidad aplicación de los índices de Gorczynski y Kerner. Otros elementos térmicos, (frío invernal). Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003010/2025-26/syllabus/48> a ns1:SyllabusItem ;
    ns1:itemIndex 48 ;
    ns1:syllabusDescription "2.2.6. Heladas orígen y tipos de heladas. Métodos de estimación de heladas: Emberger y Papadakis. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003010/2025-26/syllabus/49> a ns1:SyllabusItem ;
    ns1:itemIndex 49 ;
    ns1:syllabusDescription "2.3. Elementos climátidcos hídricos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003010/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "1.1.4. El perfil del suelo; pedon o pedion; solum; sequum vertical y horizontal; polipedon o polipedion; paisaje. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003010/2025-26/syllabus/50> a ns1:SyllabusItem ;
    ns1:itemIndex 50 ;
    ns1:syllabusDescription "2.3.1. Aire húmedo y aires seco. Índices de humedad. Humedad relativa. Punto (temperatura) de rocío. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003010/2025-26/syllabus/51> a ns1:SyllabusItem ;
    ns1:itemIndex 51 ;
    ns1:syllabusDescription "2.3.2. Precipitaciones: cantidad. Intensidad. Variabilidad: estimación mediante el método de quintiles (percentiles) Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003010/2025-26/syllabus/52> a ns1:SyllabusItem ;
    ns1:itemIndex 52 ;
    ns1:syllabusDescription "2.3.3. Aplicaciones de los quintiles a casos prácticos en tecnologías ambientales Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003010/2025-26/syllabus/53> a ns1:SyllabusItem ;
    ns1:itemIndex 53 ;
    ns1:syllabusDescription "2.4. Evaporación y Evapotranspiración."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003010/2025-26/syllabus/54> a ns1:SyllabusItem ;
    ns1:itemIndex 54 ;
    ns1:syllabusDescription "2.4.1. Evaporación y evapotranspiración potencial y de referencia. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003010/2025-26/syllabus/55> a ns1:SyllabusItem ;
    ns1:itemIndex 55 ;
    ns1:syllabusDescription "2.4.2. Métodos de estimación de la evapotranspiración. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003010/2025-26/syllabus/56> a ns1:SyllabusItem ;
    ns1:itemIndex 56 ;
    ns1:syllabusDescription "2.4.3. Balance hídrico en suelos: método directo. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003010/2025-26/syllabus/57> a ns1:SyllabusItem ;
    ns1:itemIndex 57 ;
    ns1:syllabusDescription "2.5. Clasificaciones e índices climáticos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003010/2025-26/syllabus/58> a ns1:SyllabusItem ;
    ns1:itemIndex 58 ;
    ns1:syllabusDescription "2.5.1. Índices climáticos. Índice de productividad potencial forestal de Paterson. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003010/2025-26/syllabus/59> a ns1:SyllabusItem ;
    ns1:itemIndex 59 ;
    ns1:syllabusDescription "2.5.2. Clasificaciones climáticas: Köppen. Papadakis. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003010/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "1.1.5. Horizontes genéticos. Nomenclatura. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003010/2025-26/syllabus/60> a ns1:SyllabusItem ;
    ns1:itemIndex 60 ;
    ns1:syllabusDescription "2.5.3. Diagrama ombrotérmico de Gaussen Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003010/2025-26/syllabus/61> a ns1:SyllabusItem ;
    ns1:itemIndex 61 ;
    ns1:syllabusDescription "2.5.4. Diagrama de Holdrige Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003010/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "1.1.6. Descripción de perfiles de suelos en campo. Muestreo de suelos. Estudio de suelos en laboratorio. Propiedades observadas e inferidas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003010/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "1.1.7. Práctica de Campo I: descripción morfológica y muestreo de suelos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003010/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "1.2. Componentes del suelo."@es .

