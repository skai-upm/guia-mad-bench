<https://guia-kg.skai.etsisi.upm.es/resource/45000278/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/45000278/2025-26/30AD.%20E30>,
