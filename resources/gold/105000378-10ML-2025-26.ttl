<https://guia-kg.skai.etsisi.upm.es/resource/105000378/2025-26/C17> a ns1:Competency ;
    ns1:competencyCode "C17" ;
    ns1:competencyDescription "Capacidad de realizar tareas en distintas áreas de aplicación teniendo en cuenta el contexto técnico, económico y social existente. TIPO: Competencias"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000378/2025-26/C2> a ns1:Competency ;
    ns1:competencyCode "C2" ;
    ns1:competencyDescription "Capacidad para el aprendizaje autónomo y la actualización de conocimientos, y reconocimiento de su necesidad en las áreas de la matemática y la informática.TIPO: Competencias."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000378/2025-26/C3> a ns1:Competency ;
    ns1:competencyCode "C3" ;
    ns1:competencyDescription "Saber trabajar en situaciones carentes de información y bajo presión, teniendo nuevas ideas, siendo creativo. TIPO: Competencias."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000378/2025-26/C4> a ns1:Competency ;
    ns1:competencyCode "C4" ;
