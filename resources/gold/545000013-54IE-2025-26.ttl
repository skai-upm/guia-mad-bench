<https://guia-kg.skai.etsisi.upm.es/resource/545000013/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. TITULO PRIMERO.Introducción al Derecho Español"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000013/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Lección 1.- Introducción al derecho español. División de Poderes. Organización Autonómica. Fuentes del derecho y jerarquía normativa. Referencia a la normativa europea en materia de construcción. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000013/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "3.2. Lección 8.- Agentes de la construcción. Funciones, competencias y atribuciones. Régimen de responsabilidad. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000013/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "3.3. Lección 9.- Tipos de obras y clasificación de intervenciones. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000013/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "3.4. Lección 10.- Requisitos básicos de calidad. Seguridad, habitabilidad y funcionalidad. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000013/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "3.5. Lección 11.- Inicio de la promoción. Proyecto .Documentos del proyecto. referencia al presupuesto. Licencia, visado y demás autorizaciones administrativas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000013/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "3.6. Lección 12.- Inicio de la obra desde el punto de vista normativo. Replanteo. Definición y efectos jurídicos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000013/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "3.7. Lección 13.- Seguridad y prevención en la obra. Estudio de seguridad y salud. Plan de seguridad y salud. Libro de incidencias Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000013/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "3.8. Lección 14.- Desarrollo de la obra. Ordenes de la dirección facultativa. Libro de ordenes Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000013/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "3.9. Lección 15.- La documentación de la obra. Libros, actas, certificaciones. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000013/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "3.10. Lección 16.- Fin de obra. Liquidación. Documentación de edificio terminado. Extinción de contratos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000013/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "4. TITULO CUARTO.- CONTRATACIÓN DE OBRA PÚBLICA."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000013/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Lección 2.- introducción al derecho urbanístico, edificatorio e inmobiliario. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000013/2025-26/syllabus/20> a ns1:SyllabusItem ;
    ns1:itemIndex 20 ;
    ns1:syllabusDescription "4.1. Lección 17.- Régimen jurídico para la contratación de obra pública Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000013/2025-26/syllabus/21> a ns1:SyllabusItem ;
    ns1:itemIndex 21 ;
    ns1:syllabusDescription "4.2. Lección 18.- Actuaciones administrativas preparatorias del contrato de obra. Expediente administrativo. Pliego de cláusulas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000013/2025-26/syllabus/22> a ns1:SyllabusItem ;
    ns1:itemIndex 22 ;
    ns1:syllabusDescription "4.3. Lección 19.- Análisis de las clausulas administrativas particulares del pliego. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000013/2025-26/syllabus/23> a ns1:SyllabusItem ;
    ns1:itemIndex 23 ;
    ns1:syllabusDescription "4.4. Lección 20.- Procedimientos y formas de adjudicación. estudio de las bajas temerarias. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000013/2025-26/syllabus/24> a ns1:SyllabusItem ;
    ns1:itemIndex 24 ;
    ns1:syllabusDescription "4.5. Lección 21.- Inicio, desarrollo y ejecución de las obras. Replanteo y Acto de comprobación del replanteo. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000013/2025-26/syllabus/25> a ns1:SyllabusItem ;
    ns1:itemIndex 25 ;
    ns1:syllabusDescription "4.6. Lección 22.- Fin de obra. Liquidación de obra. Periodo de garantía. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000013/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "1.3. Lección 3.- Las Relaciones jurídicas: públicas y privadas. Personas físicas y jurídicas Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000013/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "2. TITULO SEGUNDO.- El urbanismo como fase previa a la edificación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000013/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "2.1. Lección 4.- Régimen estatutario del Suelo. El suelo y la función social de la propiedad. Clases de suelo y categorías. Planes urbanísticos. Gestión y ejecución urbanística. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000013/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "2.2. Lección 5.- Limites y limitaciones en la propiedad del suelo . Derechos reales en la edificación. servidumbres y construcción extralimitada."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000013/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "2.2.1. La propiedad horizontal Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000013/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "3. TITULO TERCERO.- ASPECTOS JURÍDICOS-PRIVADOS DEL PROCESO EDIFICATORIO"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000013/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "3.1. Lección 7.- Introducción al proceso privado. Ley de Ordenación de la Edificación y Código Técnico Sin subniveles"@es .

