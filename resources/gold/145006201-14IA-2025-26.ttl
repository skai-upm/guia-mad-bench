    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/145006201/2025-26/eventSchedule> ;
    schema:description """Se analiza en la asignatura:
- El comportamiento aerodinámico de configuraciones de interés aeronáutico, sobre todo en régimen incompresible y subsónico
- El comportamiento aeroelastico, sobre todo de configuraciones bidimensionales
- La mecánica de vuelo del avión"""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/jose.m.perales%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
