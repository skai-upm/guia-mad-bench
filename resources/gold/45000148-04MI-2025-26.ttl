<https://guia-kg.skai.etsisi.upm.es/resource/45000148> a ns1:Course ;
    ns1:courseType "Optativa"@es ;
    ns1:courseYear 4 ;
    ns1:semester "Octavo semestre"@es ;
    schema:courseCode 45000148 ;
    schema:hasCourseInstance <https://guia-kg.skai.etsisi.upm.es/resource/45000148/2025-26> ;
    schema:name "Advanced Materials For Optoelectronics"@en,
        "Materiales Avanzados para Optoelectronica"@es ;
    schema:numberOfCredits 5.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/45000148/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/45000148/2025-26/CE%201> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/45000148/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/45000148/2025-26/didactic_resource/2> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/45000148/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/45000148/2025-26/RA12>,
        <https://guia-kg.skai.etsisi.upm.es/resource/45000148/2025-26/RA40>,
        <https://guia-kg.skai.etsisi.upm.es/resource/45000148/2025-26/RA42>,
        <https://guia-kg.skai.etsisi.upm.es/resource/45000148/2025-26/RA5> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/45000148/2025-26/syllabus> ;
    ns1:inpersonHours "47 horas y 30 minutos (36.5%)"@es ;
    ns1:numberOfCredits 5.0 ;
    ns1:otherInformation "La asignatura se relaciona con los ODS 3, 4, 6, 7, 11 como conjunto de tecnologías de soporte a sistemas de medida, control, sensado y comunicaciones."@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "47 horas y 30 minutos"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/45000148/2025-26/eventSchedule> ;
    schema:description """El objetivo general de la asignatura es proporcionar conocimientos y capacidad de comprensión de las bases físicas de funcionamiento de la propagación de la radiación óptica a través de los materiales empleados en tecnologías optoelectrónicas y de comunicaciones.
Asmismo se trabajará con estructuras fotónicas realizadas con materiales optoelectrónicos.
El alumno deberá ser capaz de comprender las teorías de la radiación óptica, analizar las propiedades ópticas de los materiales optoelectrónicos y comunicaciones, y comprender los dispositivos optoelectrónicos."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/m.muriel%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/m.muriel%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/x.quintana%40upm.es> ;
    schema:name "Materiales Avanzados para Optoelectronica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000148/2025-26/CE%201> a ns1:Competency ;
    ns1:competencyCode "CE 1" ;
    ns1:competencyDescription "Saber identificar las estructuras de los diversos tipos de materiales, y conocer las tÃ©cnicas de caracterizaciÃ³n y anÃ¡lisis de los materiales/ Know how to identify the structures of the various types of materials, and know the techniques for characterization and analysis of materials"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000148/2025-26/RA12> a ns1:LearningResult ;
    ns1:learningResultCode "RA12" ;
    ns1:learningResultDescription "Utilizar con soltura la comunicación oral y escrita en lengua española e inglesa."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000148/2025-26/RA40> a ns1:LearningResult ;
    ns1:learningResultCode "RA40" ;
    ns1:learningResultDescription "Conocer y comprender los procesos de selección y diseño de las distintas familias de materiales, sabiendo entender de forma integradora los aspectos comunes de las tecnologías utilizadas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000148/2025-26/RA42> a ns1:LearningResult ;
    ns1:learningResultCode "RA42" ;
    ns1:learningResultDescription "Conocer y comprender las técnicas de caracterización en servicio de materiales y su aplicación al diseño de nuevos dispositivos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000148/2025-26/RA5> a ns1:LearningResult ;
    ns1:learningResultCode "RA5" ;
    ns1:learningResultDescription "Saber aplicar las Tecnologías de la Información y de la Comunicación"@es .

