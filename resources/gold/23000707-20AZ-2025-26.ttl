<https://guia-kg.skai.etsisi.upm.es/resource/23000707/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. 1. Sistemas de riego."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000707/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. 1. Introducción."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000707/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "1.3.1. 1. Cálculo hidráulico y simulación de una red de riego con su estación de bombeo. Proyecto y resultados en sus unidades. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000707/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "1.3.2. 2. Proyecto de la red. Bocas de riego: regulador de presión, limitador de gasto y contador. Trazado y dimensionamiento. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000707/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "1.3.3. 3. Selección del material de las tuberías. Selección de bombas. Automatización. Golpe de ariete. Elementos de protección, control, aforo, filtrado. Ejecución del proyecto. Puesta a punto de las instalaciones. Pruebas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000707/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "2. 2. Gestión de recursos hídricos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000707/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "2.1. 4. Introducción"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000707/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "2.1.1. 1. Administración del agua. Planificación hidrológica. Sistema de explotación de recursos. Competencias. Régimen económico del agua de riego: canon y tarifas de agua. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000707/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "2.1.2. Variables y modelos hidrológicos. Instrumentación. Redes de observación. Análisis de datos. Distribución temporal y espacial de la precipitación y la evapotranspiración. Infiltración y recarga. Balance hídrico. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000707/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "2.2. 5. Recursos hídricos superficiales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000707/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "2.2.1. 1. Estaciones de aforo y datos disponibles. Evaluación de recursos hídricos superficiales. Captación. Volumen de embalse y demanda garantizada. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000707/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "2.2.2. 2. Análisis de tormentas. Escorrentía generada por una tormenta. Hidrogramas. Proyecto de desagües, canalizaciones y obras de protección. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000707/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.1.1. 1. Sistemas de distribución. Embalses, azudes y balsas. Pozos. Conducciones. Distribución por turnos y a la demanda. Elementos de control y regulación. Criterios de selección. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000707/2025-26/syllabus/20> a ns1:SyllabusItem ;
    ns1:itemIndex 20 ;
    ns1:syllabusDescription "2.3. 6. Recursos hídricos subterráneos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000707/2025-26/syllabus/21> a ns1:SyllabusItem ;
    ns1:itemIndex 21 ;
    ns1:syllabusDescription "2.3.1. 1. Interconexión aguas superficiales y subterráneas. Red piezométrica. Evaluación de recursos subterráneos. Características y gestión de acuíferos costeros. Explotación de acuíferos. Recarga artificial. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000707/2025-26/syllabus/22> a ns1:SyllabusItem ;
    ns1:itemIndex 22 ;
    ns1:syllabusDescription "2.3.2. 2. Ensayos de bombeo y explotación de pozos. Estimación de los parámetros del acuífero. Superposición de pozos. Descenso y recuperación de niveles. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000707/2025-26/syllabus/23> a ns1:SyllabusItem ;
    ns1:itemIndex 23 ;
    ns1:syllabusDescription "2.4. 7. Gestión integral."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000707/2025-26/syllabus/24> a ns1:SyllabusItem ;
    ns1:itemIndex 24 ;
    ns1:syllabusDescription "2.4.1. 1. Gestión conjunta de aguas superficiales y subterráneas. Otros recursos. Desalación. Depuración y regeneración. Trasvases. Reparto en condiciones de escasez. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000707/2025-26/syllabus/25> a ns1:SyllabusItem ;
    ns1:itemIndex 25 ;
    ns1:syllabusDescription "2.4.2. 2. Contaminación de los recursos. Transporte y difusión de contaminantes. Calidad de las aguas en relación con la demanda o con los ecosistemas naturales, indicadores. Tratamientos. Protección. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000707/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "1.1.2. 2. Instalaciones del regante y resultados potenciales en una unidad de riego. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000707/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "1.1.3. 3. Modernización de regadíos. Demanda de agua. Destinos y retornos del agua aplicada en el riego. Uso y productividad del agua. Viabilidad. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000707/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "1.2. 2. Proyecto y explotación de una red en lámina libre."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000707/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "1.2.1. 1. Ecuaciones del flujo gradualmente variado y variable. Arrastre y proyecto de cauces estables. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000707/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "1.2.2. 2. Sistematización de un tablar para riego por superficie. Proyecto y resultados en los canteros. Caceras e hijuelas. Escorrederos y azarbetas. Obras de derivación. Automatización. Instalaciones de aforo. Desagües. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000707/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "1.2.3. 3. Obras de conducción y paso, de regulación y distribución, de protección, de descarga y de disipación de energía. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000707/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "1.3. 3. Proyecto y explotación de una red a presión."@es .

