    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/133000196/2025-26/eventSchedule> ;
    schema:description "La Conservación de la Biodiversidad es actualmente una necesidad y una de las líneas prioritarias de actuación para muchos Estados. En las últimas décadas se están impulsando desde diferentes sectores políticas encaminadas a la armonización de la conservación y el desarrollo económico. En esta asignatura se da una visión de las principales causas de la actual pérdida de diversidad y de iniciativas de todo tipo que tienen como objetivo detenerla."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/felipe.martinez%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/felipe.martinez%40upm.es> ;
    schema:name "Conservacion de la Biodiversidad"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000196/2025-26/CB06> a ns1:Competency ;
    ns1:competencyCode "CB06" ;
    ns1:competencyDescription "Poseer y comprender conocimientos que aporten una base u oportunidad de ser originales en el desarrollo y/o aplicación de ideas, a menudo en un contexto de investigación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000196/2025-26/CB08> a ns1:Competency ;
    ns1:competencyCode "CB08" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de integrar conocimientos y enfrentarse a la complejidad de formular juicios a partir de una información que, siendo incompleta o limitada, incluya reflexiones sobre las responsabilidades sociales y éticas vinculadas a la aplicación de sus conocimientos y juicios"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000196/2025-26/CB09> a ns1:Competency ;
    ns1:competencyCode "CB09" ;
    ns1:competencyDescription "Que los estudiantes sepan comunicar sus conclusiones y los conocimientos y razones últimas que las sustentan a públicos especializados y no especializados de un modo claro y sin ambigüedades"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000196/2025-26/CB10> a ns1:Competency ;
    ns1:competencyCode "CB10" ;
    ns1:competencyDescription "Que los estudiantes posean las habilidades de aprendizaje que les permitan continuar estudiando de un modo que habrá de ser en gran medida autodirigido o autónomo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000196/2025-26/CE01> a ns1:Competency ;
    ns1:competencyCode "CE01" ;
    ns1:competencyDescription "El alumno conocerá la legislación ambiental y tendrá la capacidad de planificar un modelo de economía circular."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000196/2025-26/CT03> a ns1:Competency ;
    ns1:competencyCode "CT03" ;
    ns1:competencyDescription "El alumno tendrá capacidad para gestionar la información procedente de diversas fuentes, valorando su relevancia, fiabilidad y pertinencia para un propósito determinado, analizándola y organizándola."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000196/2025-26/CT04> a ns1:Competency ;
    ns1:competencyCode "CT04" ;
    ns1:competencyDescription "El alumno tendrá capacidad para proponer alternativas creativas y originales, valorando su viabilidad en la solución de problemas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000196/2025-26/RA15> a ns1:LearningResult ;
    ns1:learningResultCode "RA15" ;
    ns1:learningResultDescription "Analizar los efectos del cambio climático sobre la conservación de la biodiversidad"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000196/2025-26/RA32> a ns1:LearningResult ;
    ns1:learningResultCode "RA32" ;
    ns1:learningResultDescription "Aplicar buenas prácticas para presentaciones orales./ Apply good practices for oral presentations."@es .

