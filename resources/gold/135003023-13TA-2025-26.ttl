    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Causas de la contaminación de suelos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003023/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Concepto de contaminación. Causa naturales y antrópicas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003023/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "3.1. Tipos de contaminantes y sus propiedades. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003023/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "3.2. Persistencia, interacción y movilidad de los contaminantes en el suelo. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003023/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "4. Diagnóstico de suelos contaminados"@es .

