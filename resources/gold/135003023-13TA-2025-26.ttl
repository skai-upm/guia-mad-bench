    ns1:itemIndex 13 ;
    ns1:syllabusDescription "4.1. Muestreo de suelos. Técnicas analíticas para la determinación de la contaminación. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003023/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "4.2. Selección del tipo de análisis en función de las condiciones espefícicas. Interpretación de resultados. Diagnóstico.. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003023/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "4.3. Aplicación del Marco Legislativo y NGR. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003023/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "5. Tecnologías de descontaminación de suelos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003023/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "5.1. Estrategias de descontaminación Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003023/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "5.2. Técnicas de inmovilización Sin subniveles"@es .

