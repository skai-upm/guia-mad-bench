<https://guia-kg.skai.etsisi.upm.es/resource/53001581> a ns1:Course ;
    ns1:courseType "Optativa"@es ;
    ns1:courseYear 1 ;
    ns1:semester "Anual"@es ;
    schema:courseCode 53001581 ;
    schema:hasCourseInstance <https://guia-kg.skai.etsisi.upm.es/resource/53001581/2025-26> ;
    schema:name "Challenges In Automation And Robotics"@en,
        "Retos en Automática y Robótica"@es ;
    schema:numberOfCredits 3.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/53001581/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/53001581/2025-26/CB07>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001581/2025-26/CE07>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001581/2025-26/CG03>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001581/2025-26/CT01>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001581/2025-26/CT04>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001581/2025-26/CT11> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/53001581/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/53001581/2025-26/RA53> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/53001581/2025-26/syllabus> ;
    ns1:inpersonHours "81 horas (100%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation ""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Junio"@es ;
    ns1:totalHours "81 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/53001581/2025-26/eventSchedule> ;
    schema:description """La asignatura se desarolla en base a la participación de los estudiantes por equipos en un reto relacionado con la robótica o la automática de su eleccion ajeno al máster, que debe ser aprobado por el profesor
Ejemplos son : Sener?s Bot Talent, Reto Control CEA , Open CVC AI competition"""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/antonio.barrientos%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/antonio.barrientos%40upm.es> ;
    schema:name "Retos en Automática y Robótica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001581/2025-26/CB07> a ns1:Competency ;
    ns1:competencyCode "CB07" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en entornos nuevos o poco conocidos dentro de contextos más amplios (o multidisciplinares) relacionados con su área de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001581/2025-26/CE07> a ns1:Competency ;
    ns1:competencyCode "CE07" ;
    ns1:competencyDescription "Capacidad para el desarrollo en equipo de trabajos orientados al diseño, construcción y prueba de sistemas autónomos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001581/2025-26/CG03> a ns1:Competency ;
    ns1:competencyCode "CG03" ;
    ns1:competencyDescription "Aplicar los conocimientos adquiridos y resolver problemas en entornos nuevos o poco conocidos dentro de contextos más amplios y multidisciplinares"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001581/2025-26/CT01> a ns1:Competency ;
    ns1:competencyCode "CT01" ;
    ns1:competencyDescription "Aplica. Habilidad para aplicar conocimientos científicos, matemáticos y tecnológicos en sistemas relacionados con la práctica de la ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001581/2025-26/CT04> a ns1:Competency ;
    ns1:competencyCode "CT04" ;
    ns1:competencyDescription "Trabaja en equipo. Habilidad para trabajar en equipos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001581/2025-26/CT11> a ns1:Competency ;
    ns1:competencyCode "CT11" ;
    ns1:competencyDescription "Usa herramientas. Habilidad para usar las técnicas, destrezas y herramientas ingenieriles modernas necesarias para la práctica de la ingeniería"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001581/2025-26/RA53> a ns1:LearningResult ;
    ns1:learningResultCode "RA53" ;
    ns1:learningResultDescription "El alumno debe ser capaz de diseñar un sistema automático y/o robótico que, atendiendo a especificaciones y plazos, sea capaz de superar un conjunto de pruebas y/o hitos específicos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001581/2025-26/evaluation> a ns1:EvaluationSystem ;
    ns1:evaluationDescription """Para aprobar es preciso haber llegado a competir en el reto seleccionado
En el caso de retos que tenga varias fases, será necesario haber cubierto con éxito al menos la mitad de las fases"""@es ;
    ns1:hasEvaluationTrial <https://guia-kg.skai.etsisi.upm.es/resource/53001581/2025-26/evaluation/trial1>,
