        <https://guia-kg.skai.etsisi.upm.es/resource/125000424/2025-26/RA105>,
        <https://guia-kg.skai.etsisi.upm.es/resource/125000424/2025-26/RA106>,
        <https://guia-kg.skai.etsisi.upm.es/resource/125000424/2025-26/RA107> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/125000424/2025-26/syllabus> ;
    ns1:inpersonHours "72 horas y 2 minutos (59.3%)"@es ;
    ns1:numberOfCredits 4.5 ;
    ns1:otherInformation """El cronograma sigue una planificación teórica de la asignatura y puede sufrir modificaciones durante el curso.
El Análisis Espacial, como herramienta de gestión sobre el territorio, se relaciona con absolutamente todos los Objetivos de Desarrollo Sostenibles, desde el ODS1 al ODS17"""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "72 horas y 2 minutos"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/125000424/2025-26/eventSchedule> ;
    schema:description "En la asignatura de Análisis Espacial se plantean las bases de actuación, los procedimientos y las técnicas para realizar el análisis del territorio. Tras una introducción de fundamentos, se considera el análisis de tipo cualitativo y después se abordan las diferentes técnicas geoestadísticas empezando por las más básicas para pasar a las más sofisticadas que abordan la estructuración espacial, el reconocimiento de patrones y procesos de interpolación. Finalmente se concretan casos de aplicaciones de análisis espacial en diferentes ámbitos. Durante el curso se realizan ejercicios con la herramienta estadística (R) y con un software para la gestión de Sistemas de Información Geográfica (Arcgis Pro)."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/i.sinde%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/i.sinde%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/josejuan.arranz%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/y.torres%40upm.es> ;
    schema:name "Analisis Espacial"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125000424/2025-26/CE06> a ns1:Competency ;
    ns1:competencyCode "CE06" ;
    ns1:competencyDescription "Capacidad de usar las tecnologías para diseñar, simular y optimizar procesos de toma de decisiones aplicando análisis espacial sobre información geográfica en distintos ámbitos para obtener productos de calidad."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125000424/2025-26/CE09> a ns1:Competency ;
    ns1:competencyCode "CE09" ;
    ns1:competencyDescription "Conocimiento y aplicación de los procedimientos, técnicas y herramientas para procesar estadística y geoestadística"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125000424/2025-26/CRG02> a ns1:Competency ;
    ns1:competencyCode "CRG02" ;
    ns1:competencyDescription "Conocimiento, aplicación y análisis de los procesos de tratamiento de imágenes digitales e información espacial, procedentes de sensores terrestres, aerotransportados y satélites. Análisis de datos espaciales. Estudio de modelos aplicados a la ingeniería y arquitectura"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125000424/2025-26/CT10> a ns1:Competency ;
    ns1:competencyCode "CT10" ;
    ns1:competencyDescription "ANÁLISIS Y SÍNTESIS Capacidad de reconocer y describir los elementos constitutivos de una realidad y proceder a organizar la información significativa según criterios preestablecidos adecuados a un propósito."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125000424/2025-26/RA104> a ns1:LearningResult ;
    ns1:learningResultCode "RA104" ;
    ns1:learningResultDescription "Distinguir y seleccionar de entre los métodos de análisis espacial el adecuado para un problema"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125000424/2025-26/RA105> a ns1:LearningResult ;
    ns1:learningResultCode "RA105" ;
    ns1:learningResultDescription "Analizar los principales parámetros estadísticos de los datos geoespaciales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125000424/2025-26/RA106> a ns1:LearningResult ;
    ns1:learningResultCode "RA106" ;
    ns1:learningResultDescription "Compresión y uso de las técnicas de análisis espacial de los SIG."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125000424/2025-26/RA107> a ns1:LearningResult ;
    ns1:learningResultCode "RA107" ;
    ns1:learningResultDescription "Aplicar los procedimientos y técnicas de análisis geoestadístico. // Análisis espacial"@es .

