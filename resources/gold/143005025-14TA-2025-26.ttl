        <https://guia-kg.skai.etsisi.upm.es/resource/pedro.blanco%40upm.es> ;
    schema:name "Seguridad y Proteccion de la Aviacion Civil"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005025/2025-26/CE6> a ns1:Competency ;
    ns1:competencyCode "CE6" ;
    ns1:competencyDescription "Interpretar y valorar la normativa y de aplicación en el ámbito de la seguridad operacional"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005025/2025-26/CG4> a ns1:Competency ;
    ns1:competencyCode "CG4" ;
    ns1:competencyDescription "Comunicar sus conclusiones y los conocimientos y razones últimas que las sustentan a públicos especializados, y no especializados de un modo claro y sin ambigüedades"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005025/2025-26/CG5> a ns1:Competency ;
    ns1:competencyCode "CG5" ;
    ns1:competencyDescription "Comprender la importancia de los efectos sobre el medio ambiente en el desarrollo de la actividad de diseño a operación de los Sistemas del Transporte Aéreo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005025/2025-26/CG6> a ns1:Competency ;
    ns1:competencyCode "CG6" ;
    ns1:competencyDescription "Que los estudiantes posean las habilidades de aprendizaje que les permitan continuar estudiando de un modo que habrá de ser en gran medida autodirigido o autónomo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005025/2025-26/CT4> a ns1:Competency ;
    ns1:competencyCode "CT4" ;
    ns1:competencyDescription "Analizar implicaciones económicas, administrativas, sociales o medioambientales ligadas a la aplicación de nuevos conceptos y técnicas en el Sistema del Transporte Aéreo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005025/2025-26/RA28> a ns1:LearningResult ;
    ns1:learningResultCode "RA28" ;
    ns1:learningResultDescription "Conocimiento y comprensión de las particularidades de los actos ilícitos de interferencia en el transporte aéreo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005025/2025-26/RA29> a ns1:LearningResult ;
    ns1:learningResultCode "RA29" ;
    ns1:learningResultDescription "Conocimiento y comprensión de la normativa aplicable en materia de seguridad y protección de la aviación civil"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005025/2025-26/RA30> a ns1:LearningResult ;
    ns1:learningResultCode "RA30" ;
    ns1:learningResultDescription "Conocimiento, comprensión y síntesis de la aplicación de los principios de diseño y aplicación de tecnologías y procedimientos para garantizar la seguridad del transporte aéreo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005025/2025-26/RA43> a ns1:LearningResult ;
    ns1:learningResultCode "RA43" ;
    ns1:learningResultDescription "Identifica el sistema regulador básico en materia de Seguridad Aeroportuaria"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005025/2025-26/RA45> a ns1:LearningResult ;
    ns1:learningResultCode "RA45" ;
    ns1:learningResultDescription "Analiza y resuelve ejercicios prácticos que afectan a la seguridad aeroportuaria"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005025/2025-26/RA65> a ns1:LearningResult ;
    ns1:learningResultCode "RA65" ;
    ns1:learningResultDescription "El alumno conoce y comprende las metodologías para la realización de análisis de seguridad"@es .

