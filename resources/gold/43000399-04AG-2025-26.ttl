        <https://guia-kg.skai.etsisi.upm.es/resource/43000399/2025-26/CT7> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/43000399/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000399/2025-26/didactic_resource/2> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/43000399/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/43000399/2025-26/RA24>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000399/2025-26/RA25> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/43000399/2025-26/syllabus> ;
    ns1:inpersonHours "60 horas y 20 minutos (51.6%)"@es ;
    ns1:numberOfCredits 4.5 ;
    ns1:otherInformation "Esta asignatura esta relacionada con el ODS7."@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "61 horas y 20 minutos"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/43000399/2025-26/eventSchedule> ;
    schema:description """El objetivo de esta asignatura es especializar al alumno en la planificación, proyecto, construcción, explotación y mantenimiento de centrales hidroeléctricas, desarrollando sus conocimientos en lo que se refiere a:
concepción, estudios de viabilidad y anteproyectos de aprovechamientos hidroeléctricos
planificación, promoción y gestión de los correspondientes proyectos
redacción de proyectos de construcción de centrales hidroeléctricas
dirección de la construcción de las mismas
gestión, conservación, explotación y reparación de los aprovechamientos hidroeléctricos."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/joseignacio.sarasua%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/daniel.garcia-lorenzana%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/guillermo.martinez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/joseangel.sanchez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/joseignacio.sarasua%40upm.es> ;
    schema:name "Ingenieria Hidroelectrica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000399/2025-26/CE32> a ns1:Competency ;
    ns1:competencyCode "CE32" ;
    ns1:competencyDescription "Capacidad para aplicar los conocimientos técnicos en la evaluación de proyectos, obras e infraestructuras dentro del ámbito de la ingeniería civil."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000399/2025-26/CE33> a ns1:Competency ;
    ns1:competencyCode "CE33" ;
    ns1:competencyDescription "Capacidad para aplicar los conocimientos técnicos en actividades de I+D+i dentro del ámbito de la ingeniería civil."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000399/2025-26/CE35> a ns1:Competency ;
    ns1:competencyCode "CE35" ;
    ns1:competencyDescription "Capacidad para integrar y aplicar los conocimientos técnicos en asesoría, análisis, mantenimiento, construcción, evaluación técnica, conservación, explotación y modelización matemática de recursos hidráulicos y energéticos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000399/2025-26/CGP01> a ns1:Competency ;
    ns1:competencyCode "CGP01" ;
    ns1:competencyDescription "Capacitación científico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000399/2025-26/CGP06> a ns1:Competency ;
    ns1:competencyCode "CGP06" ;
    ns1:competencyDescription "Conocimiento para aplicar las capacidades técnicas y gestoras en actividades de I+D+i dentro del ámbito de la ingeniería civil. Incorpora las competencias CB6, CB7 y CB8."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000399/2025-26/CT2> a ns1:Competency ;
    ns1:competencyCode "CT2" ;
    ns1:competencyDescription "Polivalencia y capacidad de aprendizaje autónomo. Desarrolla la competencia transversal 5ª del Real Decreto."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000399/2025-26/CT5> a ns1:Competency ;
    ns1:competencyCode "CT5" ;
    ns1:competencyDescription "Capacidad de ejercer las funciones profesionales de proyecto, cálculo, evaluación técnica, planificación y gestión técnica mediante el uso de normativa europea e internacional. Desarrolla la competencia transversal 7ª de la normativa UPM."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000399/2025-26/CT7> a ns1:Competency ;
    ns1:competencyCode "CT7" ;
    ns1:competencyDescription "Capacidad de utilización de los servicios de información y comunicación para el ejercicio de las funciones profesionales del perfil de egreso. Desarrolla la competencia transversal 3ª de la normativa UPM."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000399/2025-26/RA24> a ns1:LearningResult ;
    ns1:learningResultCode "RA24" ;
    ns1:learningResultDescription "Aplica y evalúa modelos avanzados de ingeniería hidráulica y medioambiental en proyecto y explotación de sistemas hidráulicos y energéticos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000399/2025-26/RA25> a ns1:LearningResult ;
    ns1:learningResultCode "RA25" ;
    ns1:learningResultDescription "Aplica y evalúa técnicas avanzadas para la construcción, control y gestión medioambiental de sistemas hidráulicos y energéticos."@es .

