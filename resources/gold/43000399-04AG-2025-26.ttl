<https://guia-kg.skai.etsisi.upm.es/resource/43000399/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/43000399/2025-26/CE32>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000399/2025-26/CE33>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000399/2025-26/CE35>,
