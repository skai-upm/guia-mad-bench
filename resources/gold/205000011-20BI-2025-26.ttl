    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/205000011/2025-26/syllabus> ;
    ns1:inpersonHours "39 horas y 20 minutos (50.4%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation "La asignatura se relaciona con todos los ODS, especialmente el ODS2, ODS6, ODS8, ODS12 y ODS13."@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "39 horas y 20 minutos"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/205000011/2025-26/eventSchedule> ;
    schema:description "El objetivo de la asignatura es introducir a los alumnos en el conocimiento del papel de la agricultura en la sociedad, resaltando los desafíos y los retos tecnológicos a los que se enfrenta para satisfacer las necesidades de alimentar a una población en crecimiento. De forma específica, se analizan las características de los sistemas de producción en España y su relación con la producción de alimentos."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/isabel.bardaji%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/isabel.bardaji%40upm.es> ;
    schema:name "Agricultura y Alimentación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000011/2025-26/CB02> a ns1:Competency ;
    ns1:competencyCode "CB02" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar sus conocimientos a su trabajo o vocación de una forma profesional y posean las competencias que suelen demostrarse por medio de la elaboración y defensa de argumentos y la resolución de problemas dentro de su área de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000011/2025-26/CB04> a ns1:Competency ;
    ns1:competencyCode "CB04" ;
    ns1:competencyDescription "Que los estudiantes puedan transmitir información, ideas, problemas y soluciones a un público tanto especializado como no especializado"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000011/2025-26/CE20> a ns1:Competency ;
    ns1:competencyCode "CE20" ;
    ns1:competencyDescription "Comprender el papel de las empresas, el gobierno y el ciudadano y las interrelaciones entre las distintas perspectivas ecológicas, tecnológicas, económicas y sociales de la producción agraria."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000011/2025-26/CE21> a ns1:Competency ;
    ns1:competencyCode "CE21" ;
    ns1:competencyDescription "Identificar el papel del sector agrario en la sociedad."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000011/2025-26/CG10> a ns1:Competency ;
    ns1:competencyCode "CG10" ;
    ns1:competencyDescription "Familiarizarse con el estudio de las interrelaciones entre las distintas perspectivas ecológicas, tecnológicas, económicas y sociales en relación con las Ciencias Agrarias y la Bioeconomía."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000011/2025-26/CT01> a ns1:Competency ;
    ns1:competencyCode "CT01" ;
    ns1:competencyDescription "Capacidad para aplicar de forma profesional a su trabajo los conocimientos adquiridos considerando sus impactos en un contexto global y social."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000011/2025-26/CT04> a ns1:Competency ;
    ns1:competencyCode "CT04" ;
    ns1:competencyDescription "Capacidad para comunicar a todo tipo de audiencias en lengua castellana e inglesa y tanto de forma oral como escrita."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000011/2025-26/RA75> a ns1:LearningResult ;
