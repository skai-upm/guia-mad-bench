    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/55001001/2025-26/eventSchedule> ;
    schema:description "El temario es el habitual de un curso de cálculo infinitesimal. En esta asignatura se abordan las nociones fundamentales del análisis matemático y se muestra que éste tiene una estructura lógicamente coherente."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/pablo.gomez.mourelo%40upm.es> ;
