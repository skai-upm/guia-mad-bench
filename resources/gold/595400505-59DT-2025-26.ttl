    ns1:itemIndex 12 ;
    ns1:syllabusDescription "3.4. Lagos de Datos y bases de datos: almacenando toda la información. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595400505/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "3.5. Procesado distribuido y aprendizaje automático. Interpretación y visualización de datos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595400505/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "3.6. Ciberseguridad, gobernanza y políticas de usos de datos. Sin subniveles"@es .

