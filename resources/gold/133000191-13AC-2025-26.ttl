    ns1:courseType "Optativa"@es ;
    ns1:courseYear 2 ;
    ns1:semester "Tercer semestre"@es ;
    schema:courseCode 133000191 ;
    schema:hasCourseInstance <https://guia-kg.skai.etsisi.upm.es/resource/133000191/2025-26> ;
    schema:name "Waste Management And Secondary Raw Materials"@en,
        "Gestion de Residuos y Materias Primas Secundarias"@es ;
    schema:numberOfCredits 4.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/133000191/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/133000191/2025-26/CB08> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/133000191/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000191/2025-26/didactic_resource/2> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/133000191/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/133000191/2025-26/RA11> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/133000191/2025-26/syllabus> ;
    ns1:inpersonHours "50 horas (48.1%)"@es ;
    ns1:numberOfCredits 4.0 ;
    ns1:otherInformation """LAS COMPETENCIAS Y LOS RESULTADOS DE APRENDIZAJE DE ESTA ASIGNATURA SON CONFORMES CON LA MEMORIA VERIFICA DEL TÍTULO"
Esta asignatura se imparte en el tercer semestre con un esquema de presencialidad definido. En el caso de un cambio en las condiciones sanitarias que obliguen a un confinamiento total o parcial,habría que hacer una replanificación, con las correspondientes adendas.

ODS que influyen en la asignatiura. 5, 7, 9 , 11, 12, 13"""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "51 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/133000191/2025-26/eventSchedule> ;
    schema:description "La asignatura trata de adentrarse en la gestión de las distintas fracciones de residuos, con el fin de comprender mejor la normativa vigente y los planes de prevención. No se trata de explicar la tecnología como tal de cada proceso, sino los elementos de la gestión operativa que pueden sufrir cambios ante la adaptación y transición hacia una economía circular."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/jv.lopez%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/a.garciai%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/belen.vazquezdequevedo%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/jv.lopez%40upm.es> ;
    schema:name "Gestion de Residuos y Materias Primas Secundarias"@es .

