<https://guia-kg.skai.etsisi.upm.es/resource/53001294/2025-26/CG07> a ns1:Competency ;
    ns1:competencyCode "CG07" ;
    ns1:competencyDescription "Poder ejercer funciones de dirección general, dirección técnica y dirección de proyectos I+D+i en plantas, empresas y centros tecnológicos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001294/2025-26/CG08> a ns1:Competency ;
    ns1:competencyCode "CG08" ;
    ns1:competencyDescription "Aplicar los conocimientos adquiridos y resolver problemas en entornos nuevos o poco conocidos dentro de contextos más amplios y multidisciplinares."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001294/2025-26/CG10> a ns1:Competency ;
    ns1:competencyCode "CG10" ;
    ns1:competencyDescription "Saber comunicar las conclusiones ¿y los conocimientos y razones últimas que las sustentan ¿a públicos especializados y no especializados de un modo claro y sin ambigüedades."@es .

