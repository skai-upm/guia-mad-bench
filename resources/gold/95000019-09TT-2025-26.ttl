    ns1:learningResultDescription "Capacidad para manejar correctamente las funciones de variable compleja y habilidad para resolver problemas que involucren dichas funciones"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000019/2025-26/RA152> a ns1:LearningResult ;
    ns1:learningResultCode "RA152" ;
    ns1:learningResultDescription "Capacidad para manejar adecuadamente las series complejas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000019/2025-26/RA153> a ns1:LearningResult ;
    ns1:learningResultCode "RA153" ;
    ns1:learningResultDescription "Conocimiento y comprensión de la teoría de Cauchy para la resolución de integrales complejas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000019/2025-26/RA154> a ns1:LearningResult ;
    ns1:learningResultCode "RA154" ;
    ns1:learningResultDescription "Habilidad para resolver integrales utilizando residuos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000019/2025-26/RA155> a ns1:LearningResult ;
    ns1:learningResultCode "RA155" ;
    ns1:learningResultDescription "Conocimiento de las transformadas integrales y habilidad para aplicarlas en problemas de ingeniería"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000019/2025-26/RA156> a ns1:LearningResult ;
    ns1:learningResultCode "RA156" ;
    ns1:learningResultDescription "Modelización de fenómenos físicos en términos matemáticos mediante ecuaciones diferenciales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000019/2025-26/RA613> a ns1:LearningResult ;
