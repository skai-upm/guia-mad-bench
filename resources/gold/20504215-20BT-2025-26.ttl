        <https://guia-kg.skai.etsisi.upm.es/resource/stefan.buren%40upm.es> ;
    schema:name "Microbiología"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504215/2025-26/CB03> a ns1:Competency ;
    ns1:competencyCode "CB03" ;
    ns1:competencyDescription "Que los estudiantes tengan la capacidad de reunir e interpretar datos relevantes (normalmente dentro de su área de estudio) para emitir juicios que incluyan una reflexión sobre temas relevantes de índole social, científica o ética"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504215/2025-26/CE25> a ns1:Competency ;
    ns1:competencyCode "CE25" ;
    ns1:competencyDescription "Capacidad para conocer la diversidad estructural y funcional de los microorganismos, los parámetros en el control y cuantificación del crecimiento; y en general su importancia para el desarrollo de aplicaciones biotecnológicas; así como para manejar las técnicas básicas para su observación, cultivo y aislamiento."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504215/2025-26/CG01> a ns1:Competency ;
    ns1:competencyCode "CG01" ;
    ns1:competencyDescription "Ser capaz de evaluar y discernir los diferentes mecanismos moleculares y celulares responsables de las transformaciones que llevan a cabo los seres vivos, así como poder desarrollar soluciones alternativas y novedosas frente a problemas biológicos conocidos y/o emergentes."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504215/2025-26/CG04> a ns1:Competency ;
    ns1:competencyCode "CG04" ;
    ns1:competencyDescription "Adquirir la formación y habilidades para el desarrollo de la investigación biotecnológica (tecnologías y estrategias frontera), de cara a su posterior aplicación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504215/2025-26/CG07> a ns1:Competency ;
    ns1:competencyCode "CG07" ;
    ns1:competencyDescription "Adquirir la formación profesional para cubrir la demanda de las empresas biotecnológicas y para el acceso a estudios de postgrado del área."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504215/2025-26/CT03> a ns1:Competency ;
    ns1:competencyCode "CT03" ;
    ns1:competencyDescription "Tener compromiso ético y profesional y respeto por el medio ambiente."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504215/2025-26/RA106> a ns1:LearningResult ;
    ns1:learningResultCode "RA106" ;
    ns1:learningResultDescription "Distinguir las características de la célula bacteriana, componentes estructurales y sus funciones"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504215/2025-26/RA108> a ns1:LearningResult ;
    ns1:learningResultCode "RA108" ;
    ns1:learningResultDescription "Conocer medios y condiciones de cultivo para diferentes microorganismos, obtener cultivos microbianos puros a partir de mezclas no homogéneas, cuantificar el crecimiento microbiano y realizar e interpretar observaciones al microscopio óptico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504215/2025-26/RA109> a ns1:LearningResult ;
    ns1:learningResultCode "RA109" ;
    ns1:learningResultDescription "Distinguir los principales grupos de microorganismos, y sus relaciones positivas y negativas con el resto de seres vivos y con el medio ambiente"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504215/2025-26/RA110> a ns1:LearningResult ;
    ns1:learningResultCode "RA110" ;
    ns1:learningResultDescription "Conocer la fisiología bacteriana y distinguir los diferentes grupos metabólicos y su potencial biotecnológico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504215/2025-26/RA111> a ns1:LearningResult ;
    ns1:learningResultCode "RA111" ;
    ns1:learningResultDescription "Conocer los principios básicos de la genómica microbiana y transferencia genética en bacterias"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504215/2025-26/RA112> a ns1:LearningResult ;
    ns1:learningResultCode "RA112" ;
    ns1:learningResultDescription "Adquirir conocimientos y destrezas en las técnicas básicas utilizadas en la manipulación de los microorganismos y trasladar los conceptos aprendidos en teoría a la observación experimental"@es .

