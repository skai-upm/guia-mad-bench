    schema:name "Metodo Cientifico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000394/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en entornos nuevos o poco conocidos dentro de contextos más amplios (o multidisciplinares) relacionados con su área de estudio."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000394/2025-26/CG18> a ns1:Competency ;
    ns1:competencyCode "CG18" ;
    ns1:competencyDescription "Capacidad de trabajar y comunicarse también en contextos internacionales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000394/2025-26/CG19> a ns1:Competency ;
    ns1:competencyCode "CG19" ;
    ns1:competencyDescription "Aproximación sistemática a la gestión de riesgos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000394/2025-26/CGI21> a ns1:Competency ;
    ns1:competencyCode "CGI21" ;
    ns1:competencyDescription "Comprender el procedimiento, valor y límites del método científico en el campo de la informática, siendo capaz de identificar, localizar y obtener datos requeridos en un trabajo de investigación, de diseñar y guiar investigaciones analíticas, de modelado y experimentales, así como de evaluar datos de una manera crítica y extraer conclusiones."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000394/2025-26/CGI22> a ns1:Competency ;
    ns1:competencyCode "CGI22" ;
    ns1:competencyDescription "Capacidad para valorar la importancia de las fuentes documentales, manejarlas y buscar la información para el desarrollo de cualquier trabajo de investigación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000394/2025-26/CGI23> a ns1:Competency ;
    ns1:competencyCode "CGI23" ;
    ns1:competencyDescription "Capacidad de leer y comprender publicaciones dentro de su ámbito de estudio/investigación, así como su catalogación y valor científico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000394/2025-26/CGI24> a ns1:Competency ;
    ns1:competencyCode "CGI24" ;
    ns1:competencyDescription "Que el estudiante adquiera el conocimiento necesario sobre los mecanismos de financiación de la investigación y transferencia de la tecnología, y sobre la legislación vigente sobre protección de resultados."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000394/2025-26/RA5> a ns1:LearningResult ;
    ns1:learningResultCode "RA5" ;
    ns1:learningResultDescription "Capacidad de de plantear los requisitos necesarios para poner en práctica un proceso de investigación científicamente riguroso orientado a reducir el espacio existente entre una idea potencialmente prometedora y su validación en el mundo real."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000394/2025-26/RA6> a ns1:LearningResult ;
    ns1:learningResultCode "RA6" ;
    ns1:learningResultDescription "Capacidad de evaluar las distintas opciones, métodos y herramientas científicas y científico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000394/2025-26/RA7> a ns1:LearningResult ;
    ns1:learningResultCode "RA7" ;
    ns1:learningResultDescription "Conocer, aplicar y criticar la bibliografía referente a un tema de investigación con objeto de utilizarla como impulso o cimiento de una idea nueva y de su proceso de investigación asociado."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000394/2025-26/RA81> a ns1:LearningResult ;
    ns1:learningResultCode "RA81" ;
    ns1:learningResultDescription "Capacidad de plantear un proyecto de investigación que detalle el proceso, método, esfuerzos, objetivos, costes, tiempos y riesgos asociados a una tarea de investigación científicamente rigurosa y que tendrá lugar en contextos internacionales de colaboración con otras instituciones, públicas y privadas."@es .

