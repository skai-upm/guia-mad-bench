    ns1:inpersonHours "70 horas (44.9%)"@es ;
    ns1:numberOfCredits 6.0 ;
    ns1:otherInformation """El cronograma es orientativo, en particular la fecha de realización de las clases de problemas. En cada grupo, se avisará con tiempo de los momentos en los que se realizarán dichas clases usando el programa Statgraphics.
En alguna de los problemas se trabajará con datos de los informes de desarrollo humano de Naciones Unidas (ODS 1, 3, 4, 5 y 13)."""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "70 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/615000719/2025-26/eventSchedule> ;
    schema:description """Esta asignatura presenta los conceptos básicos de estadística descriptiva, cálculo de probabilidades e inferencia estadística que todo estudiante de ingeniería debe conocer.
Se pone especial énfasis en algunas distribuciones de probabilidad que tienen aplicación en el ámbito de la informática.
Los conceptos estudiados son necesarios para entender las aplicaciones del análisis de datos (minería de datos, big data, machine learning).."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/rafael.minano%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/a.corral%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/jose.merodio%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/juan.martin.sotoca%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/rafael.minano%40upm.es> ;
    schema:name "Probabilidad y Estadistica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000719/2025-26/CBAS01> a ns1:Competency ;
    ns1:competencyCode "CBAS01" ;
    ns1:competencyDescription "Capacidad para la resolución de los problemas matemáticos que puedan plantarse en la ingeniería. Aptitud para aplicar los conocimientos sobre: algebra, cálculo diferencial e integral y métodos numéricos; estadística y optimización."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000719/2025-26/CT02> a ns1:Competency ;
    ns1:competencyCode "CT02" ;
    ns1:competencyDescription "Resolución de problemas: Identificar, analizar y definir los elementos significativos que constituyen un problema para resolverlo con criterio y de forma efectiva."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000719/2025-26/CT06> a ns1:Competency ;
    ns1:competencyCode "CT06" ;
    ns1:competencyDescription "Razonamiento crítico: La capacidad de pensar de manera crítica implica tres cosas: (1) una actitud de estar dispuesto a considerar de una manera reflexiva los problemas y asuntos que entran dentro del rango de las experiencias de uno, (2) conocimiento de los métodos de investigación lógica y el razonamiento, y (3) una cierta habilidad en la aplicación de esos métodos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000719/2025-26/RA27> a ns1:LearningResult ;
    ns1:learningResultCode "RA27" ;
    ns1:learningResultDescription "Resuelve problemas definiendo los elementos significativos que los constituyen, de manera razonada, expresando con precisión las argumentaciones necesarias y las conclusiones."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000719/2025-26/RA31> a ns1:LearningResult ;
    ns1:learningResultCode "RA31" ;
    ns1:learningResultDescription "Utiliza los conocimientos de cálculo diferencial e integral para la adecuada formulación de la física y la estadística."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000719/2025-26/RA37> a ns1:LearningResult ;
    ns1:learningResultCode "RA37" ;
    ns1:learningResultDescription "Aplica los conceptos y resultados de probabilidad para analizar situaciones modeladas en términos de variables aleatorias"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000719/2025-26/RA38> a ns1:LearningResult ;
    ns1:learningResultCode "RA38" ;
    ns1:learningResultDescription "A partir de un conjunto de datos, infiere y contrasta información tanto sobre los distintos parámetros que intervienen como sobre la validez del modelo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000719/2025-26/RA39> a ns1:LearningResult ;
    ns1:learningResultCode "RA39" ;
    ns1:learningResultDescription "Relaciona muestras de distintas variables aleatorias."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000719/2025-26/RA40> a ns1:LearningResult ;
    ns1:learningResultCode "RA40" ;
    ns1:learningResultDescription "Utiliza adecuadamente software matemático en la resolución de problemas."@es .

