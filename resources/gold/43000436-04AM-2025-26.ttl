    schema:name "Control de Calidad y Rehabilitación de Estructuras"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000436/2025-26/CB10> a ns1:Competency ;
    ns1:competencyCode "CB10" ;
    ns1:competencyDescription "Que los estudiantes posean las habilidades de aprendizaje que les permitan continuar estudiando de un modo que habrá de ser en gran medida autodirigido o autónomo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000436/2025-26/CB6> a ns1:Competency ;
    ns1:competencyCode "CB6" ;
    ns1:competencyDescription "Poseer y comprender conocimientos que aporten una base u oportunidad de ser originales en el desarrollo y/o aplicación de ideas, a menudo en un contexto de investigación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000436/2025-26/CB9> a ns1:Competency ;
    ns1:competencyCode "CB9" ;
    ns1:competencyDescription "Que los estudiantes sepan comunicar sus conclusiones y los conocimientos y razones últimas que las sustentan a públicos especializados y no especializados de un modo claro y sin ambigüedades"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000436/2025-26/CE10> a ns1:Competency ;
    ns1:competencyCode "CE10" ;
    ns1:competencyDescription "Capacidad para la participación en actividades de I+D+i mediante la utilización de recursos de modelización predictiva en Patología y rehabilitación estructural."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000436/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Polivalencia para extender a ámbitos afines las competencias generales adquiridas en el ámbito temático del título."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000436/2025-26/CT1> a ns1:Competency ;
    ns1:competencyCode "CT1" ;
    ns1:competencyDescription "Capacidad de preparar y presentar comunicaciones orales, escritas y gráficas, estructurada y argumentadamente."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000436/2025-26/RA1> a ns1:LearningResult ;
    ns1:learningResultCode "RA1" ;
    ns1:learningResultDescription "Utiliza con eficacia, autonomía y polivalencia recursos de modelización predictiva en la temática de la materia"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000436/2025-26/RA13> a ns1:LearningResult ;
    ns1:learningResultCode "RA13" ;
    ns1:learningResultDescription "Sintetiza e integra con polivalencia y autonomía las competencias específica de formación científico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000436/2025-26/RA14> a ns1:LearningResult ;
    ns1:learningResultCode "RA14" ;
    ns1:learningResultDescription "Interioriza los principios y técnicas de organización y dirección de equipos Presenta y defiende un proyecto o una preinvestigación de Ingeniería estructural, geotécnica o de materiales estructurales ante un tribunal universitario."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000436/2025-26/RA15> a ns1:LearningResult ;
    ns1:learningResultCode "RA15" ;
    ns1:learningResultDescription "Aplica normativa europea e internacional de ingeniería estructural, geotécnica y de materiales estructurales en proyecto, construcción, conservación y evaluación técnica Interioriza los principios de deontología profesional de ingeniería civil"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000436/2025-26/RA17> a ns1:LearningResult ;
    ns1:learningResultCode "RA17" ;
    ns1:learningResultDescription "conocer los fundamentos físicos de los comportamientos macroscópicos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000436/2025-26/RA18> a ns1:LearningResult ;
    ns1:learningResultCode "RA18" ;
    ns1:learningResultDescription "saber aplicar los conocimientos anteriores en diseño, construcción y mantenimiento de estructuras"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000436/2025-26/RA19> a ns1:LearningResult ;
    ns1:learningResultCode "RA19" ;
    ns1:learningResultDescription "familiarizarse con la metodología científica de las disciplinas en que se apoya la asignatura"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000436/2025-26/RA6> a ns1:LearningResult ;
    ns1:learningResultCode "RA6" ;
    ns1:learningResultDescription "Aplica normativa europea e internacional de ingeniería estructural, geotécnica y de materiales estructurales en proyecto, construcción, conservación y evaluación técnica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000436/2025-26/RA60> a ns1:LearningResult ;
    ns1:learningResultCode "RA60" ;
    ns1:learningResultDescription "Aplica la normativa de control y calidad de los materiales de construcción a partir de sus fundamentos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000436/2025-26/RA61> a ns1:LearningResult ;
    ns1:learningResultCode "RA61" ;
    ns1:learningResultDescription "Establece las necesidades de materiales de construcción y de sistemas estructurales en distintas condiciones ambientales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000436/2025-26/RA62> a ns1:LearningResult ;
    ns1:learningResultCode "RA62" ;
    ns1:learningResultDescription "Identifica los mecanismos físico"@es .

