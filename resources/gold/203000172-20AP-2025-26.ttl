    schema:name "Agricultura de Precisión Aplicada a Cultivos Leñosos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000172/2025-26/C3> a ns1:Competency ;
    ns1:competencyCode "C3" ;
    ns1:competencyDescription "Diseñar los medios y las metodologías necesarias para la modelización, análisis y gestión optimizada de sistemas agrarios, y aplicar la información obtenida en la toma de decisiones de la producción con criterios ingenieriles, económicos y de sostenibilidad medioambiental"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000172/2025-26/CEH2> a ns1:Competency ;
    ns1:competencyCode "CEH2" ;
    ns1:competencyDescription "Poseer conocimiento avanzado y ser capaz de desarrollar tecnología en gestión de equipos e instalaciones que se integren en los procesos y sistemas de producción agroalimentaria."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000172/2025-26/CEH6> a ns1:Competency ;
    ns1:competencyCode "CEH6" ;
    ns1:competencyDescription "Poseer conocimiento avanzado y ser capaz de desarrollar tecnología en sistemas de producción vegetal y en sistemas integrados de protección de cultivos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000172/2025-26/CT05> a ns1:Competency ;
    ns1:competencyCode "CT05" ;
    ns1:competencyDescription "Trabajo en equipo y liderazgo: capacidad para dirigir, coordinar, motivar e integrarse en equipos multidisciplinares de forma activa en pro de la consecución de objetivos comunes respetando el principio de igualdad de trato y no discriminación en contextos multiculturales e internacionales."@es .

