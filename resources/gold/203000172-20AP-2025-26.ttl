<https://guia-kg.skai.etsisi.upm.es/resource/203000172/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/203000172/2025-26/C3>,
        <https://guia-kg.skai.etsisi.upm.es/resource/203000172/2025-26/CEH2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/203000172/2025-26/CEH6>,
