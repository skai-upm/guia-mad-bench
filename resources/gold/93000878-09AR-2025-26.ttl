    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/93000878/2025-26/eventSchedule> ;
    schema:description """El objetivo de la disciplina científica, Reconocimiento de Patrones, es la clasificación de "objetos" ( caracteres escritos, imágenes médicas, imágenes térmicas, señales biomédicas, personas, ...) en categorías o clases. A estos objetos los denominamos patrones. El reconocimiento de patrones constituye una parte muy importante de los sistemas inteligentes y aprendizaje automático que conllevan toma de decisiones.
El temario de la asignatura cubre las distintas fases de un sistema de reconocimiento de patrones, a saber: obtención de muestras a través de unos sensores, generación de características, selección de características, diseño del clasificador y por último evaluación del mismo."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/anamaria.ugena%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/anamaria.ugena%40upm.es> ;
    schema:name "Tecnicas de Reconocimiento de Patrones"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000878/2025-26/CE2> a ns1:Competency ;
    ns1:competencyCode "CE2" ;
    ns1:competencyDescription "Capacidad para planificar la resolución de un problema en función de las herramientas de que se disponga y, en su caso, de las restricciones de tiempo y recursos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000878/2025-26/CE3> a ns1:Competency ;
    ns1:competencyCode "CE3" ;
    ns1:competencyDescription "Capacidad para utilizar aplicaciones informáticas estadísticas, de cálculo numérico y simbólico, visualización gráfica, optimización u otras para resolver problemas con un elevado grado de complejidad"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000878/2025-26/CE4> a ns1:Competency ;
    ns1:competencyCode "CE4" ;
    ns1:competencyDescription "Desarrollar habilidades de aprendizaje en Estadística Computacional y Matemáticas, así como en sus respectivas aplicaciones, que permitan al alumno continuar estudiando y profundizando en la materia de modo autónomo, así como el desarrollo profesional con un alto grado de independencia."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000878/2025-26/CE5> a ns1:Competency ;
    ns1:competencyCode "CE5" ;
    ns1:competencyDescription "Resolver problemas y casos reales planteados en el tratamiento estadístico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000878/2025-26/CE6> a ns1:Competency ;
    ns1:competencyCode "CE6" ;
    ns1:competencyDescription "Desarrollar programas que resuelvan problemas matemáticos utilizando para cada caso el entorno computacional adecuado."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000878/2025-26/CE7> a ns1:Competency ;
    ns1:competencyCode "CE7" ;
    ns1:competencyDescription "Capacidad de utilización de herramientas de búsqueda de recursos bibliográficos así como manejo, gestión y análisis de grandes bases de datos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000878/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Aprender a aplicar los conocimientos adquiridos y a explotar su potencial para la resolución de problemas en entornos nuevos o poco conocidos dentro de contextos más amplios (o multidisciplinares) en el tratamiento estadístico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000878/2025-26/CG2> a ns1:Competency ;
    ns1:competencyCode "CG2" ;
    ns1:competencyDescription "Elaborar adecuadamente y con originalidad argumentos motivados y proyectos de trabajo, redactar planes, así como formular hipótesis y conjeturas razonables en su área de especialización."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000878/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Integrar los conocimientos adecuados y enfrentarse a la complejidad de emitir juicios en función de criterios, de normas externas o de reflexiones personales justificadas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000878/2025-26/CG4> a ns1:Competency ;
    ns1:competencyCode "CG4" ;
    ns1:competencyDescription "Comunicar y presentar públicamente ideas, procedimientos o informes de investigación, así como asesorar a personas u organizaciones en el tratamiento estadístico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000878/2025-26/CG5> a ns1:Competency ;
    ns1:competencyCode "CG5" ;
    ns1:competencyDescription "Comprender y utilizar el lenguaje y las herramientas matemáticas para modelizar y resolver problemas complejos, reconociendo y valorando las situaciones y problemas susceptibles de ser tratados matemáticamente."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000878/2025-26/CG6> a ns1:Competency ;
    ns1:competencyCode "CG6" ;
    ns1:competencyDescription "Conocer los modelos, métodos y técnicas relevantes en distintas áreas de aplicación de la Estadística matemática participando en la creación de nuevas tecnologías que contribuyan al desarrollo de la Sociedad de la Información."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000878/2025-26/CG7> a ns1:Competency ;
    ns1:competencyCode "CG7" ;
    ns1:competencyDescription "Saber abstraer en un modelo matemático las propiedades y características esenciales de un problema real reconociendo su rango de aplicabilidad y limitaciones"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000878/2025-26/CT1> a ns1:Competency ;
    ns1:competencyCode "CT1" ;
    ns1:competencyDescription "Saber aplicar sus conocimientos a su trabajo o vocación de una forma profesional y poseer las competencias que suelen demostrarse por medio de la elaboración y defensa de argumentos y en la resolución de problemas y estudio de casos. Esto implica, más concretamente: Integrar creativamente conocimientos y aplicarlos a la resolución de problemas complejos, perseguir objetivos de calidad en el desarrollo de su actividad profesional, adquirir capacidad para la toma de decisiones y de dirección de recursos humanos, ser capaz de mostrar creatividad, iniciativa y espíritu emprendedor para afrontar los retos de su actividad, valorar la importancia de los métodos estadístico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000878/2025-26/CT2> a ns1:Competency ;
    ns1:competencyCode "CT2" ;
    ns1:competencyDescription "Tener la capacidad de reunir e interpretar datos relevantes para emitir juicios que incluyan una reflexión sobre temas relevantes de índole científica, tecnológica y empresarial. Demostrar razonamiento crítico y gestionar información científica y técnica de calidad, bibliografía, bases de datos especializadas y recursos accesibles a través de Internet."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000878/2025-26/RA1> a ns1:LearningResult ;
    ns1:learningResultCode "RA1" ;
    ns1:learningResultDescription "1. Capacidad para saber el procedimiento a seguir en la tarea de reconocimiento de patrones"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000878/2025-26/RA13> a ns1:LearningResult ;
    ns1:learningResultCode "RA13" ;
    ns1:learningResultDescription "Saber en qué consisten y saber aplicar las técnicas de reconocimiento de patrones vistas a lo largo del curso"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000878/2025-26/RA29> a ns1:LearningResult ;
    ns1:learningResultCode "RA29" ;
    ns1:learningResultDescription "Conocerán los conceptos y técnicas relacionados con el reconocimiento de patrones y su formalismo matemático, los fundamentos de los sistemas biométricos, y la aplicación de las técnicas de reconocimiento de patrones en el diseño de sistemas biométricos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000878/2025-26/RA30> a ns1:LearningResult ;
    ns1:learningResultCode "RA30" ;
    ns1:learningResultDescription "Serán capaces de determinar los ingredientes de un problema para diseñar la arquitectura que mejor se adecua a su resolución."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000878/2025-26/RA31> a ns1:LearningResult ;
    ns1:learningResultCode "RA31" ;
    ns1:learningResultDescription "Serán capaces de resolver problemas colaborando con compañeros, y de exponer sus resultados"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000878/2025-26/RA6> a ns1:LearningResult ;
    ns1:learningResultCode "RA6" ;
    ns1:learningResultDescription "Sabrán modelar sistemas reales utilizando estas teorías"@es .

