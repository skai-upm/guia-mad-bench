<https://guia-kg.skai.etsisi.upm.es/resource/23000531/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/23000531/2025-26/CE4>,
        <https://guia-kg.skai.etsisi.upm.es/resource/23000531/2025-26/CG1>,
