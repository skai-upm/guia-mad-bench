<https://guia-kg.skai.etsisi.upm.es/resource/115100065/2025-26/CE06> a ns1:Competency ;
    ns1:competencyCode "CE06" ;
    ns1:competencyDescription "Promover y evaluar la formación de hábitos perdurables y autónomos de práctica actividad física y del deporte entre la población escolar. Nivel 3."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100065/2025-26/CE12> a ns1:Competency ;
    ns1:competencyCode "CE12" ;
    ns1:competencyDescription "Planificar, desarrollar y evaluar la realización de programas de actividades físico deportivas orientadas a la prevención y mejora de la salud. Nivel 3."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100065/2025-26/CE13> a ns1:Competency ;
    ns1:competencyCode "CE13" ;
    ns1:competencyDescription "Aplicar, de manera fundamentada y argumentada, los principios fisiológicos, biomecánicos, comportamentales y sociales al campo de la actividad física y salud. Nivel 3."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100065/2025-26/CE14> a ns1:Competency ;
    ns1:competencyCode "CE14" ;
    ns1:competencyDescription "Evaluar la condición física y prescribir ejercicios físicos orientados hacia la salud. Nivel 2."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100065/2025-26/CE15> a ns1:Competency ;
    ns1:competencyCode "CE15" ;
    ns1:competencyDescription "Identificar y prevenir los riesgos que se derivan para la salud, de la práctica de actividades físicas inadecuadas, entre la población que realiza práctica física orientada a la salud. Nivel 3."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100065/2025-26/CE16> a ns1:Competency ;
    ns1:competencyCode "CE16" ;
    ns1:competencyDescription "Seleccionar y saber utilizar el material y equipamiento deportivo, adecuado para cada tipo de actividad que practique la población de jóvenes, adultos, mayores y personas con discapacidad. Nivel 3."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100065/2025-26/CE17> a ns1:Competency ;
    ns1:competencyCode "CE17" ;
    ns1:competencyDescription "Promover y evaluar la formación de hábitos perdurables y autónomos de práctica de actividad físico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100065/2025-26/CE23> a ns1:Competency ;
    ns1:competencyCode "CE23" ;
    ns1:competencyDescription "Identificar y prevenir los riesgos que se derivan para la salud de la práctica de actividades físicas inadecuadas o realizadas incorrectamente en los practicantes de actividad física recreativa. Nivel 2."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100065/2025-26/CE24> a ns1:Competency ;
    ns1:competencyCode "CE24" ;
    ns1:competencyDescription "Elaborar y comunicar, de manera crítica y fundamentada, argumentos y juicios sobre el valor de la actividad física y el deporte, y sobre sus posibilidades de contribuir al desarrollo y bienestar de las personas y de la sociedad, y al desarrollo sostenible, así como sobre su especial relación con la salud y la calidad de vida. Nivel 3."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100065/2025-26/CE26> a ns1:Competency ;
    ns1:competencyCode "CE26" ;
    ns1:competencyDescription "Presentar de forma oral y escrita, información clara y detallada de una amplia serie de temas relacionados con la especialidad del alumno, utilizando el lenguaje específico de cada campo académico y profesional."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100065/2025-26/CG03> a ns1:Competency ;
    ns1:competencyCode "CG03" ;
    ns1:competencyDescription "Organizar y planificar propuestas de acción, programas y actividades propias de su campo profesional en sus diferentes ámbitos de aplicación y desarrollo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100065/2025-26/CG08> a ns1:Competency ;
    ns1:competencyCode "CG08" ;
    ns1:competencyDescription "Aplicar los conocimientos adquiridos en los procesos de formación en la práctica profesional, en diferentes contextos y situaciones."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100065/2025-26/CG09> a ns1:Competency ;
    ns1:competencyCode "CG09" ;
    ns1:competencyDescription "Resolver con eficacia, creatividad y eficiencia problemas inherentes a su campo de conocimiento y profesional utilizando estrategias y técnicas adecuadas y, si procede, innovadoras."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100065/2025-26/CG10> a ns1:Competency ;
    ns1:competencyCode "CG10" ;
    ns1:competencyDescription "Mostrar capacidad de aprender nuevos conocimientos y habilidades a lo largo de su vida profesional y personal."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100065/2025-26/CG11> a ns1:Competency ;
    ns1:competencyCode "CG11" ;
    ns1:competencyDescription "Adoptar y mostrar una actitud favorable a la búsqueda de la calidad en el desempeño de sus funciones profesionales, sea cual sea su ámbito de acción e intervención, incluyendo un alto nivel sistemático de reflexión crítica sobre su propia práctica profesional."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100065/2025-26/CG12> a ns1:Competency ;
    ns1:competencyCode "CG12" ;
    ns1:competencyDescription "Comprender y manejar la literatura científica del ámbito de la actividad física y el deporte en lengua inglesa y en otras lenguas de presencia significativa en el ámbito científico y específico de conocimiento."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100065/2025-26/RA101> a ns1:LearningResult ;
    ns1:learningResultCode "RA101" ;
    ns1:learningResultDescription "Aplicación de habilidades, técnicas y metodologías adquiridas en los módulos básicos para el correcto desempeño de la profesión según el itinerario elegido"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100065/2025-26/RA102> a ns1:LearningResult ;
    ns1:learningResultCode "RA102" ;
    ns1:learningResultDescription "Capacidad de programar ejercicio físico para mejorar la calidad de vida de los ciudadanos y disminuir los gastos sanitarios"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100065/2025-26/RA138> a ns1:LearningResult ;
    ns1:learningResultCode "RA138" ;
    ns1:learningResultDescription "RA39"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100065/2025-26/RA18> a ns1:LearningResult ;
    ns1:learningResultCode "RA18" ;
    ns1:learningResultDescription "Desarrollar la capacidad de análisis y adaptación para la aplicación de programas de actividad física en personas con circunstancias especiales, edad, género, patología"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100065/2025-26/RA19> a ns1:LearningResult ;
    ns1:learningResultCode "RA19" ;
    ns1:learningResultDescription "Adquirir la formación científica básica aplicada a la actividad física y al deporte, fomentando el autoaprendizaje, intentando comprender los fundamentos de la fisiología y la fisiopatología"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100065/2025-26/RA190> a ns1:LearningResult ;
    ns1:learningResultCode "RA190" ;
    ns1:learningResultDescription "Identificar la función de cualquier ejercicio físico y saber aplicar los mismos para el desarrollo y mantenimiento de la condición física en cualquier ámbito y etapa de la vida."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100065/2025-26/RA206> a ns1:LearningResult ;
    ns1:learningResultCode "RA206" ;
    ns1:learningResultDescription "Distinguir los diferentes ámbitos de la discapacidad y otros trastornos crónicos de la salud, conociendo las principales características de las mismas, sus potencialidades y limitaciones, y relacionándolos especialmente con las cualidades perceptivo motrices."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100065/2025-26/RA21> a ns1:LearningResult ;
    ns1:learningResultCode "RA21" ;
    ns1:learningResultDescription "Discriminar entre los ajustes y las adaptaciones que el ejercicio induce en los diferentes sistemas orgánicos, más concretamente sobre el sistema cardiovascular, respiratorio y hormonal"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100065/2025-26/RA24> a ns1:LearningResult ;
    ns1:learningResultCode "RA24" ;
    ns1:learningResultDescription "Identificar y programar actividades en función de la composición corporal calculando el balance energético del individuo, proponiéndole actividades que puedan ser cuantificadas por el propio alumno."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100065/2025-26/RA263> a ns1:LearningResult ;
    ns1:learningResultCode "RA263" ;
    ns1:learningResultDescription "Dominio de habilidades y técnicas para dirigir y organizar grupos en contextos de salud, recreación, gestión, ocio, rendimiento y educación en función del itinerario elegido."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100065/2025-26/RA271> a ns1:LearningResult ;
    ns1:learningResultCode "RA271" ;
    ns1:learningResultDescription "Conocer las patologías urgentes mas frecuentes, su prevención y forma de actuar ante ellas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100065/2025-26/RA28> a ns1:LearningResult ;
    ns1:learningResultCode "RA28" ;
    ns1:learningResultDescription "Comprender y establecer los mecanismos de colaboración en un equipo multidisciplinar para el tratamiento de patologías agudas y crónicas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100065/2025-26/RA310> a ns1:LearningResult ;
    ns1:learningResultCode "RA310" ;
    ns1:learningResultDescription "Aplicar los principios básicos adquiridos en los módulos de Ciencias Sociales y Ciencias de la Salud a las actividades físico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100065/2025-26/RA376> a ns1:LearningResult ;
    ns1:learningResultCode "RA376" ;
    ns1:learningResultDescription "Comprender la deontología y ejercicio profesional en la promoción y organización de actividades físico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100065/2025-26/RA4> a ns1:LearningResult ;
    ns1:learningResultCode "RA4" ;
    ns1:learningResultDescription "Conocimiento de los sistemas y bases del funcionamiento del cuerpo humano"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100065/2025-26/RA40> a ns1:LearningResult ;
    ns1:learningResultCode "RA40" ;
    ns1:learningResultDescription "Conocer la exigencia de la actividad física propuesta atendiendo a la edad y características individuales de los practicantes"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100065/2025-26/RA55> a ns1:LearningResult ;
    ns1:learningResultCode "RA55" ;
    ns1:learningResultDescription "Conocer las características evolutivas del sujeto con respecto a las aptitudes perceptivo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100065/2025-26/RA7> a ns1:LearningResult ;
    ns1:learningResultCode "RA7" ;
    ns1:learningResultDescription "Desenvolvimiento eficiente en un contexto profesional real según el itinerario elegido"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100065/2025-26/RA70> a ns1:LearningResult ;
    ns1:learningResultCode "RA70" ;
    ns1:learningResultDescription "Saber identificar y corregir errores en las prácticas motrices para la prevención de riesgos a la hora de aplicarlas en diferentes colectivos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100065/2025-26/RA82> a ns1:LearningResult ;
    ns1:learningResultCode "RA82" ;
    ns1:learningResultDescription "Conocer los condicionantes de la actividad física en el ámbito de la salud."@es .

