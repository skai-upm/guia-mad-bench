<https://guia-kg.skai.etsisi.upm.es/resource/23000618/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/23000618/2025-26/CB7>,
        <https://guia-kg.skai.etsisi.upm.es/resource/23000618/2025-26/CB9>,
        <https://guia-kg.skai.etsisi.upm.es/resource/23000618/2025-26/CE2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/23000618/2025-26/CG4>,
        <https://guia-kg.skai.etsisi.upm.es/resource/23000618/2025-26/CT4>,
        <https://guia-kg.skai.etsisi.upm.es/resource/23000618/2025-26/CT5> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/23000618/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/23000618/2025-26/didactic_resource/2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/23000618/2025-26/didactic_resource/3> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/23000618/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/23000618/2025-26/RA36>,
        <https://guia-kg.skai.etsisi.upm.es/resource/23000618/2025-26/RA37> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/23000618/2025-26/syllabus> ;
    ns1:inpersonHours "62 horas y 30 minutos (57.9%)"@es ;
    ns1:numberOfCredits 4.0 ;
    ns1:otherInformation """La asignatura se relaciona con los Objetivos de Desarrollo Sostenible:
ODS 8: Trabajo decente y crecimiento económico
ODS12: Garantizar modalidades de consumo y producción sostenibles"""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "65 horas y 30 minutos"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/23000618/2025-26/eventSchedule> ;
    schema:description """El objetivo general de esta asignatura es proporcionar a los alumnos una visión práctica y actual sobre algunos de los principales elementos a los que se enfrentan los profesionales que desarrollan su actividad en el ámbito financiero de una empresa. Así, se espera que los alumnos adquieran una visión y un conjunto de destrezas relacionadas con diversos aspectos de la función financiera en la empresa, como son la información financiera y el análisis contable, el diagnóstico y previsión de las necesidades financieras de la empresa y las posibles fuentes de financiación, profundizando especialmente en los mercados financieros que permiten a las empresas invertir los excedentes de tesorería u obtener la financiación necesaria en caso de déficit.
La asignatura se enfoca bajo un planteamiento que combina la clase magistral, con clases prácticas de resolución de problemas y casos prácticos y con la exposición de trabajos de los alumnos."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/sonia.benito%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/beatriz.encinas%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/sonia.benito%40upm.es> ;
    schema:name "Direccion Financiera de la Empresa"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000618/2025-26/CB7> a ns1:Competency ;
    ns1:competencyCode "CB7" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en entornos nuevos o poco conocidos dentro de contextos más amplios (o multidisciplinares) relacionados con su área de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000618/2025-26/CB9> a ns1:Competency ;
    ns1:competencyCode "CB9" ;
    ns1:competencyDescription "Que los estudiantes sepan comunicar sus conclusiones y los conocimientos y razones últimas que las sustentan a públicos especializados y no especializados de un modo claro y sin ambigüedades"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000618/2025-26/CE2> a ns1:Competency ;
    ns1:competencyCode "CE2" ;
    ns1:competencyDescription ""@es .

