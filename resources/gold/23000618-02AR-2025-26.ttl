    ns1:competencyDescription "Capacidad para administrar y gestionar empresas agrarias y alimentarias."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000618/2025-26/CT4> a ns1:Competency ;
    ns1:competencyCode "CT4" ;
    ns1:competencyDescription "Capacidad para trabajar de forma efectiva como individuo, organizando y planificando su propio trabajo, de forma independiente o como miembro de un equipo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000618/2025-26/CT5> a ns1:Competency ;
    ns1:competencyCode "CT5" ;
    ns1:competencyDescription "Capacidad para gestionar la información, identificando las fuentes necesarias, los principales tipos de documentos técnicos y científicos, de una manera adecuada y eficiente"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000618/2025-26/RA36> a ns1:LearningResult ;
    ns1:learningResultCode "RA36" ;
    ns1:learningResultDescription "Conocer los mercados financieros y el mercado monetario"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000618/2025-26/RA37> a ns1:LearningResult ;
