<https://guia-kg.skai.etsisi.upm.es/resource/135004204/2025-26/CE%201.5> a ns1:Competency ;
    ns1:competencyCode "CE 1.5" ;
    ns1:competencyDescription "Comprensión y dominio de los conceptos básicos sobre las leyes generales de la mecánica, termodinámica, campos y ondas y electromagnetismo y su aplicación para la resolución de problemas propios de la ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004204/2025-26/CG01> a ns1:Competency ;
    ns1:competencyCode "CG01" ;
    ns1:competencyDescription "Capacidad para comprender los fundamentos biológicos, químicos, físicos, matemáticos y de los sistemas de representación necesarios para el desarrollo de la actividad profesional, así como para identificar los diferentes elementos bióticos y físicos del medio forestal y los recursos naturales renovables susceptibles de protección, conservación y aprovechamientos en el ámbito forestal."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004204/2025-26/CT2> a ns1:Competency ;
    ns1:competencyCode "CT2" ;
    ns1:competencyDescription "Resolución de Problemas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004204/2025-26/RA3> a ns1:LearningResult ;
    ns1:learningResultCode "RA3" ;
    ns1:learningResultDescription "RA246"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004204/2025-26/RA311> a ns1:LearningResult ;
    ns1:learningResultCode "RA311" ;
    ns1:learningResultDescription "Analizar las posibles analogías en casos que son físicamente diferentes y de aplicar soluciones conocidas a nuevos problemas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004204/2025-26/RA312> a ns1:LearningResult ;
    ns1:learningResultCode "RA312" ;
    ns1:learningResultDescription "Identificar los elementos esenciales de un fenómeno físico, construir o modificar un modelo que permita describirlo, realizar predicciones y comprobar la validez del mismo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004204/2025-26/RA313> a ns1:LearningResult ;
    ns1:learningResultCode "RA313" ;
    ns1:learningResultDescription "Realizar experimentos de manera independiente describiendo, analizando y evaluando críticamente los resultados."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004204/2025-26/RA314> a ns1:LearningResult ;
    ns1:learningResultCode "RA314" ;
    ns1:learningResultDescription "Desarrollar actividades de aprendizaje necesarias para emprender estudios posteriores con un alto grado de autono"@es .

