    ns1:numberOfCredits 6.0 ;
    ns1:otherInformation """Las competencias y los resultados de aprendizaje de esta asignatura son los acordes con la memoria Verifica del título.
El cronograma sigue una planificación teórica de la asignatura y puede sufrir modificaciones durante el curso, las cuales serán anunciadas con la debida antelación."""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "83 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/135003001/2025-26/eventSchedule> ;
    schema:description "En esta asignatura se estudian los fundamentos de mecánica y fluidos necesarios para la formación de un ingeniero en Tecnologías Ambientales. Asimismo se estudian los fundamentos del cálculo de incertidumbres y los conocimientos básicos necesarios para realizar prácticas en un laboratorio de Física."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/teresa.martin%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/ana.serrano%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/emilio.manrique%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/teresa.martin%40upm.es> ;
    schema:name "Fisica I"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003001/2025-26/CE4> a ns1:Competency ;
    ns1:competencyCode "CE4" ;
    ns1:competencyDescription "Comprensión y dominio de los conceptos básicos sobre las leyes generales de la mecánica, termodinámica, campos, y ondas y electromagnetismo y su aplicación para la resolución de problemas propios de la ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003001/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Capacidad para comprender los fundamentos biológicos, químicos, físicos, matemáticos y de los sistemas de representación necesarios para el desarrollo de la actividad profesional en el ámbito de la ingeniería ambiental."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003001/2025-26/CT2> a ns1:Competency ;
    ns1:competencyCode "CT2" ;
    ns1:competencyDescription "Habilidad para identificar, formular y resolver problemas de ingeniería"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003001/2025-26/RA7> a ns1:LearningResult ;
    ns1:learningResultCode "RA7" ;
    ns1:learningResultDescription "Medir y analizar datos experimentales y aplicar técnicas experimentales relacionadas a los principios físicos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003001/2025-26/RA95> a ns1:LearningResult ;
    ns1:learningResultCode "RA95" ;
    ns1:learningResultDescription "Conocer las leyes y modelos de la física(mecánica y fluidos) y sus límites de aplicabilidad"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135003001/2025-26/RA96> a ns1:LearningResult ;
    ns1:learningResultCode "RA96" ;
    ns1:learningResultDescription "Identificar los elementos esenciales de un problema,utilizando estrategias y modelos conocidos para resolverlo."@es .

