<https://guia-kg.skai.etsisi.upm.es/resource/205000194/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/205000194/2025-26/CE11>,
        <https://guia-kg.skai.etsisi.upm.es/resource/205000194/2025-26/CG01>,
