<https://guia-kg.skai.etsisi.upm.es/resource/55000045/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Celebraciones e invitaciones"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000045/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Escribir invitaciones. Proponer regalos. Organizar celebraciones. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000045/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "4.1. Especialidades médicas. Petición de citas, en consulta con el médico. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000045/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "4.2. Oraciones subordinadas \"seit(dem)\" y \"bis\". Oraciones subordinadas \"darum\", \"deshalb\", \"deswegen\", \"daher\". Infinitivsätze. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000045/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "5. Prendas de vestir . Colores. Materiales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000045/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "5.1. Descripción de prendas de vestir. Colores. Materiales Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000045/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "5.2. Diminutivo. Artículos demostrativos. Oraciones interrogativas. Pronombres interrogativos. Voz pasiva. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000045/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "6. Orientarse en una ciudad"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000045/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "6.1. Indicaciones. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000045/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "6.2. Konjunktiv II. Genitiv. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000045/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. n- Deklination (Nom./Akk./Dat). Pronombres personales dativo. Artículos determinados e indeterminados. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000045/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "2. La vivienda. Mudarse a una nueva ciudad"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000045/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "2.1. Búsqueda de una vivienda, alquiler, distribución, mobiliario. Estudiar en el extranjero. Compartir piso. Turismo Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000045/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "2.2. Adjetivos comparativos - superlativos. Pronombres posesivos. Preposiciones del dativo y acusativo. Oraciones subordinadas \"weil\", \"dass\", \"das\". Pronombres personales y reflexivos Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000045/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "3. Temas Bancarios"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000045/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "3.1. Abrir una cuenta. Características de las cuentas bancarias. Objetos perdidos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000045/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "3.2. Oraciones subordinadas \"wenn\" y \"als\". \"Präteritum\" verbos regulares / irregulares. Modalverben. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000045/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "4. Salud"@es .

