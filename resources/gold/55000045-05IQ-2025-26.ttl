    schema:numberOfCredits 3.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/55000045/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/55000045/2025-26/CG%205>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55000045/2025-26/CG%206> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/55000045/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55000045/2025-26/didactic_resource/2> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/55000045/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/55000045/2025-26/RA322>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55000045/2025-26/RA57> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/55000045/2025-26/syllabus> ;
    ns1:inpersonHours "34 horas y 30 minutos (44.2%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation ""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "34 horas y 30 minutos"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/55000045/2025-26/eventSchedule> ;
    schema:description """La asignatura de Alemán 2 tiene como finalidad capacitar al alumnado para usar el idioma de manera suficiente, receptiva y productivamente, tanto en forma hablada como escrita, así como para mediar entre hablantes en alemán, en situaciones cotidianas y de inmediata necesidad que requieran comprender y producir textos o discursos breves, en diversos registros y en lengua estándar, que traten de aspectos básicos concretos de temas generales y que contengan expresiones, léxico y estructuras de uso frecuente.
La asignatura de Alemán 2 presenta las características del nivel de competencia A2 según se define en el Marco Común Europeo de Referencia para las Lenguas"""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/ismael.arinas%40upm.es> ;
    schema:inLanguage "Alemán/Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/elena.zapatero%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/ismael.arinas%40upm.es> ;
    schema:name "Aleman II"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000045/2025-26/CG%205> a ns1:Competency ;
    ns1:competencyCode "CG 5" ;
    ns1:competencyDescription "Comunicar conocimientos y conclusiones, tanto de forma oral como escrita, a públicos especializados y no especializados de modo claro y sin ambigüedades"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000045/2025-26/CG%206> a ns1:Competency ;
    ns1:competencyCode "CG 6" ;
    ns1:competencyDescription "Poseer las habilidades de aprendizaje que permitan continuar estudiando a lo largo de toda la vida para un desarrollo profesional adecuado"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000045/2025-26/RA322> a ns1:LearningResult ;
    ns1:learningResultCode "RA322" ;
    ns1:learningResultDescription "Poseer habilidades de aprendizaje que permitan continuar estudiando a lo largo de la vida para su adecuado desarrollo profesional."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000045/2025-26/RA57> a ns1:LearningResult ;
    ns1:learningResultCode "RA57" ;
    ns1:learningResultDescription "Capacidad de resolver de forma autónoma problemas lingüísticos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000045/2025-26/didactic_resource/1> a ns1:DidacticResource ;
    ns1:bibliographyDescription "Die Lektionen im Kursbuch enthalten jeweils eine sich abgeschlossenen Lektionsgeschichte. Im Mittelpunkt stehen Personen, die sich in Situationen befinden, die das Agieren im deutschsprachigen Umfeld erlauben."@es ;
    ns1:bibliographyTitle "DaF kompakt A 2Kurs"@es ;
    ns1:bibliographyType "Otros"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000045/2025-26/didactic_resource/2> a ns1:DidacticResource ;
    ns1:bibliographyDescription "Das Buch richtet sich an Erwachsene, die Deutsch lernen. Dabei wird Grammatik in sprachliches Handeln integriert."@es ;
    ns1:bibliographyTitle "studio d A2"@es ;
    ns1:bibliographyType "Otros"@es .

