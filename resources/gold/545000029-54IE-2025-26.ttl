<https://guia-kg.skai.etsisi.upm.es/resource/545000029/2025-26/CE10> a ns1:Competency ;
    ns1:competencyCode "CE10" ;
    ns1:competencyDescription "Conocimiento de los procedimientos y métodos infográficos y cartográficos en el campo de la edificación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000029/2025-26/CE11> a ns1:Competency ;
    ns1:competencyCode "CE11" ;
    ns1:competencyDescription "Aptitud para trabajar con la instrumentación topográfica y proceder al levantamiento gráfico de solares y edificios, y su replanteo en el terreno"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000029/2025-26/CG01> a ns1:Competency ;
    ns1:competencyCode "CG01" ;
    ns1:competencyDescription "Dirigir la ejecución material de las obras de edificación, de sus instalaciones y elementos, llevando a cabo el control cualitativo y cuantitativo de lo construido mediante el establecimiento y gestión de los planes de control de materiales, sistemas y ejecución de obra, elaborando los correspondientes registros para su incorporación al Libro del Edificio."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000029/2025-26/CT01> a ns1:Competency ;
