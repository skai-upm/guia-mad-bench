    schema:activitiesWorkload "70%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/53002092/2025-26/eventSchedule> ;
    schema:description "En esta asignatura se imparten contenidos teórico-prácticos sobre aprendizaje automático de utilidad para los alumnos en su futuro profesional. Más concretamente, se abordan problemas de regresión y clasificación y algunas de las técnicas más recientes relacionadas con procesamiento del lenguaje algunos problemas que surgen en Ingeniería como: análisis espectral, muestreo de señales, extracción de ruido, etc, y se aportan herramientas matemáticas como el Análisis de Fourier y la Transformada Wavelet para su resolución. Los contenidos teóricos de la asignatura se complementan con ejemplos prácticos en ordenador."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/aurelien.decelle%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/aurelien.decelle%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/carlos.gguillen%40upm.es> ;
    schema:name "Machine Learning en la Ingeniería Industrial"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002092/2025-26/%28a%29> a ns1:Competency ;
    ns1:competencyCode "(a)" ;
    ns1:competencyDescription "APLICA. Habilidad para aplicar conocimientos científicos, matemáticos y tecnológicos en sistemas relacionados con la práctica de la ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002092/2025-26/%28b%29> a ns1:Competency ;
    ns1:competencyCode "(b)" ;
    ns1:competencyDescription "EXPERIMENTA. Habilidad para diseñar y realizar experimentos así como analizar e interpretar datos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002092/2025-26/%28e%29> a ns1:Competency ;
    ns1:competencyCode "(e)" ;
    ns1:competencyDescription "RESUELVE. Habilidad para identificar, formular y resolver problemas de ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002092/2025-26/%28i%29> a ns1:Competency ;
    ns1:competencyCode "(i)" ;
    ns1:competencyDescription "SE ACTUALIZA. Reconocimiento de la necesidad y la habilidad para comprometerse al aprendizaje continuo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002092/2025-26/CG01> a ns1:Competency ;
    ns1:competencyCode "CG01" ;
    ns1:competencyDescription "Tener conocimientos adecuados de los aspectos científicos y tecnológicos de: métodos matemáticos, analíticos y numéricos en la ingeniería, ingeniería eléctrica, ingeniería energética, ingeniería química, ingeniería mecánica, mecánica de medios continuos, electrónica industrial, automática, fabricación, materiales, métodos cuantitativos de gestión, informática industrial, urbanismo, infraestructuras, etc."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002092/2025-26/CG11> a ns1:Competency ;
    ns1:competencyCode "CG11" ;
    ns1:competencyDescription "Poseer las habilidades de aprendizaje que permitan continuar estudiando de un modo autodirigido o autónomo."@es .

