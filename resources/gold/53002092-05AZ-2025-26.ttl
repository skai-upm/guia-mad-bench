    ns1:learningResultCode "RA452" ;
    ns1:learningResultDescription "Utilizar herramientas de software de aprendizaje automatico aplicados a problemas prácticos en la ingeniería industrial"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002092/2025-26/RA453> a ns1:LearningResult ;
