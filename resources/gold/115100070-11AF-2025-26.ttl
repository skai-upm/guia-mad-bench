<https://guia-kg.skai.etsisi.upm.es/resource/115100070/2025-26/CE07> a ns1:Competency ;
    ns1:competencyCode "CE07" ;
    ns1:competencyDescription "Planificar, desarrollar y evaluar la realización de programas y procesos de entrenamiento deportivo en sus distintos niveles. Nivel 3."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100070/2025-26/CE08> a ns1:Competency ;
    ns1:competencyCode "CE08" ;
    ns1:competencyDescription "Aplicar de manera fundamentada y argumentada los principios fisiológicos, biomecánicos, comportamentales y sociales, durante la dirección del entrenamiento deportivo. Nivel 3."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100070/2025-26/CE09> a ns1:Competency ;
    ns1:competencyCode "CE09" ;
    ns1:competencyDescription "Identificar y prevenir los riesgos que se derivan para la salud de los deportistas por la práctica de actividades físicas inadecuadas, en el contexto del entrenamiento deportivo. Nivel 2."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100070/2025-26/CE10> a ns1:Competency ;
    ns1:competencyCode "CE10" ;
    ns1:competencyDescription "Seleccionar y saber utilizar el material y equipamiento deportivo adecuado para cada tipo de actividad de entrenamiento deportivo. Nivel 3."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100070/2025-26/RA100> a ns1:LearningResult ;
    ns1:learningResultCode "RA100" ;
    ns1:learningResultDescription "Aplicación de tecnologías avanzadas en el ejercicio profesional"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100070/2025-26/RA101> a ns1:LearningResult ;
    ns1:learningResultCode "RA101" ;
    ns1:learningResultDescription "Aplicación de habilidades, técnicas y metodologías adquiridas en los módulos básicos para el correcto desempeño de la profesión según el itinerario elegido"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100070/2025-26/RA16> a ns1:LearningResult ;
    ns1:learningResultCode "RA16" ;
    ns1:learningResultDescription "Saber adaptar métodos, cargas y procedimientos en función de la edad para un entrenamiento correcto"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100070/2025-26/RA17> a ns1:LearningResult ;
    ns1:learningResultCode "RA17" ;
    ns1:learningResultDescription "Interpretar los resultados de las pruebas de valoración tras diferentes tipos de esfuerzos"@es .

