<https://guia-kg.skai.etsisi.upm.es/resource/305000108/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Ecuaciones diferenciales ordinarias (EDOs) lineales y sistemas de ecuaciones diferenciales ordinarias lineales de orden 1"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000108/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Espacio de las funciones continuas - Lema de las contracciones - Teorema de existencia y unicidad para sistemas de EDOs lineales de orden 1 Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000108/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "3.1. Definición de la transformada de Laplace y sus principales propiedades Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000108/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "3.2. Transformada de Laplace de funciones elementales Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000108/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "3.3. Transformada inversa de Laplace Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000108/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "3.4. Aplicación de la transformada de Laplace para la resolución de ecuaciones diferenciales, integrales e integro-diferenciales Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000108/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "3.5. Ejemplos de tratamiento de coeficientes con discontinuidades Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000108/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "4. Teoría de Cauchy-Lipschitz"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000108/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "4.1. Teoremas local y global de existencia y unicidad de Cauchy-Lipschitz para sistemas de orden 1 Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000108/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "4.2. Principales métodos de resolución de ecuaciones de primer orden (ecuaciones de variables separables, ecuaciones homogéneas, ecuaciones exactas, factores integrantes) Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000108/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "4.3. Prolongabilidad de la solución Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000108/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "4.4. Introducción al estudio cualitativo de ecuaciones autónomas de orden 1 Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000108/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Estructura lineal del conjunto de soluciones - Determinación de su dimensión y obtención de bases Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000108/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "1.3. Ecuaciones diferenciales ordinarias lineales de orden n Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000108/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "1.4. Ecuaciones de segundo orden de coeficientes constantes - Osciladores armónicos simples, amortiguados, forzados Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000108/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "2. Sistemas de ecuaciones diferenciales ordinarias de coeficientes constantes"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000108/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "2.1. Repaso de la forma canónica de Jordan de un endomorfismo de R^N Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000108/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "2.2. Matriz exponencial: definición y cálculo Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000108/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "2.3. Análisis del comportamiento cualitativo de los sistemas lineales de 2 y 3 ecuaciones de primer orden Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000108/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "3. Resolución de ecuaciones diferenciales ordinarias mediante la transformada de Laplace"@es .

