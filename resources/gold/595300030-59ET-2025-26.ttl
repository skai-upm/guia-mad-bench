    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/595300030/2025-26/eventSchedule> ;
    schema:description """La asignatura de Sistemas Audiovisuales pretende dar conocimientos básicos de las señales de audio y vídeo, de sus dispositivos de captación y reproducción, de sus sistemas de codificación y almacenamiento, así como de los sistemas de transmisión. Esta asignatura permite tener una visión general de los sistemas de comunicaciones para audio y vídeo. Es una asignatura teórica.
El orden del temario puede ser modificado dependiendo del curso."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/elena.blanco%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/elena.blanco%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/jl.rodriguez.vazquez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/josemanuel.diaz%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/martina.eckert%40upm.es> ;
    schema:name "Sistemas Audiovisuales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595300030/2025-26/CE%20TEL04> a ns1:Competency ;
    ns1:competencyCode "CE TEL04" ;
    ns1:competencyDescription "Capacidad de analizar y especificar los parámetros fundamentales de un sistema de comunicaciones."@es .

