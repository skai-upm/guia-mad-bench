    ns1:itemIndex 20 ;
    ns1:syllabusDescription "3.5. Representación matricial de una aplicación respecto de bases. Composición de aplicaciones. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000100/2025-26/syllabus/21> a ns1:SyllabusItem ;
    ns1:itemIndex 21 ;
    ns1:syllabusDescription "3.6. Cambio de base. Equivalencia y semejanza de matrices. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000100/2025-26/syllabus/22> a ns1:SyllabusItem ;
    ns1:itemIndex 22 ;
    ns1:syllabusDescription "3.7. Determinantes. Formas multilineales alternadas. Sin subniveles"@es .

