    ns1:itemIndex 10 ;
    ns1:syllabusDescription "2.5. Coordenadas. Descripción de subespacios: ecuaciones paramétricas e implícitas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000100/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "2.6. Operaciones con subespacios: intersección y suma. Suma directa y subespacios complementarios. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000100/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "2.7. Fórmula de Grassmann. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000100/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "2.8. Espacios vectoriales de tipo no finito. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000100/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "2.9. El espacio vectorial cociente. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000100/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "3. Aplicaciones lineales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000100/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "3.1. Definición. Primeras propiedades. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000100/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "3.2. Núcleo e imagen de una aplicación lineal. Teorema del Rango-Nulidad. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000100/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "3.3. Inyectividad, sobreyectividad y biyectividad. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000100/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "3.4. Isomorfismos. Aplicación coordenada y producto cartesiano. Aplicación inversa. Sin subniveles"@es .

