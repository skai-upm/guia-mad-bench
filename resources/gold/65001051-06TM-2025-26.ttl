    ns1:inpersonHours "30 horas y 15 minutos (38.8%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation """CALENDARIO DE PRACTICAS TITULO TEMA FECHAS
1 Clasificación para transporte 2 Febrero
2 Temperaturas de inflamación 5 Febrero

RECUPERACION DE FALTAS


La asignatura se relaciona con el ODS 7 (Energía asequible y no contaminante), con el ODS 8 (Trabajo decente y crecimiento económico) y con el ODS 9 (Industria, innovación e infraestructuras)"""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "30 horas y 15 minutos"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/65001051/2025-26/eventSchedule> ;
    schema:description "La asignatura presenta una visión actual de la seguridad industrial, incluyendo los fundamentos generales de la evaluación de riesgos y su aplicación a diversos sectores industriales. Se presentan las reglamentaciones europeas y nacionales y se plantean los principios básicos y las soluciones técnicas aplicables a la seguridad frente a riesgos químicos, maquinaria, incendios y atmósferas explosivas."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/javier.garciat%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/b.castells%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/isabel.amez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/javier.garciat%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/liliana.medic%40upm.es> ;
    schema:name "Seguridad Industrial"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001051/2025-26/CG%201> a ns1:Competency ;
    ns1:competencyCode "CG 1" ;
    ns1:competencyDescription "Conocer y aplicar conocimientos de ciencias y tecnologías básicas a la práctica de la Tecnología Minera."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001051/2025-26/CG%202> a ns1:Competency ;
    ns1:competencyCode "CG 2" ;
    ns1:competencyDescription "Poseer capacidad para diseñar, analizar, calcular, proyectar, construir, mantener, conservar, explotar, desarrollar, implementar, gestionar y mejorar productos, sistemas y procesos en los distintos ámbitos de las Tecnologías Mineras, usando técnicas analíticas, computacionales o experimentales apropiadas, incluyendo la función de asesoría en estos campos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001051/2025-26/CG%203> a ns1:Competency ;
    ns1:competencyCode "CG 3" ;
    ns1:competencyDescription "Aplicar los conocimientos adquiridos para identificar, formular y resolver problemas dentro de contextos amplios y multidisciplinarios, siendo capaces de integrar conocimientos, trabajando en equipos multidisciplinares."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001051/2025-26/CG%204> a ns1:Competency ;
    ns1:competencyCode "CG 4" ;
    ns1:competencyDescription "Comprender el impacto de la tecnología minera en el medio ambiente, el desarrollo sostenible de la sociedad. desarrollando la capacidad para la realización de estudios de ordenación del territorio y de los aspectos medioambientales relacionados con los proyectos, plantas e instalaciones, en su ámbito"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001051/2025-26/CG%205> a ns1:Competency ;
    ns1:competencyCode "CG 5" ;
    ns1:competencyDescription "Saber comunicar los conocimientos y conclusiones, tanto de forma oral, escrita y gráfica, a públicos especializados y no especializados de un modo claro y sin ambigüedades."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001051/2025-26/CG%206> a ns1:Competency ;
    ns1:competencyCode "CG 6" ;
    ns1:competencyDescription "Poseer habilidades de aprendizaje que permitan continuar estudiando a lo largo de la vida para su adecuado desarrollo profesional"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001051/2025-26/F16> a ns1:Competency ;
    ns1:competencyCode "F16" ;
    ns1:competencyDescription "Capacidad de análisis de la problemática de la seguridad y salud en los proyectos, plantas o instalaciones."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001051/2025-26/RA250> a ns1:LearningResult ;
    ns1:learningResultCode "RA250" ;
    ns1:learningResultDescription "Analizar las situaciones industriales en las que pueden existir o generarse riesgos industriales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001051/2025-26/RA251> a ns1:LearningResult ;
    ns1:learningResultCode "RA251" ;
    ns1:learningResultDescription "Aplicar las técnicas de análisis y evaluación de riesgos a industrias de proceso."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001051/2025-26/RA252> a ns1:LearningResult ;
    ns1:learningResultCode "RA252" ;
    ns1:learningResultDescription "Aplicar las reglamentaciones específicas a instalaciones con riesgos industriales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001051/2025-26/RA253> a ns1:LearningResult ;
    ns1:learningResultCode "RA253" ;
    ns1:learningResultDescription "Diseñar conjuntos de medidas de prevención y protección contra los riesgos industriales."@es .

