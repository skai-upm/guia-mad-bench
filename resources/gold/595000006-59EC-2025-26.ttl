    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/595000006/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/595000006/2025-26/RA162>,
        <https://guia-kg.skai.etsisi.upm.es/resource/595000006/2025-26/RA163>,
