    ns1:itemIndex 3 ;
    ns1:syllabusDescription "2.1. Generalidades. Reacciones monosustrato y bisustrato, Influencia de factores ambientales. Activación e inhibición. Mecanismos de reacciones enzimáticas. Inmovilización de enzimas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001428/2025-26/syllabus/4> a ns1:SyllabusItem ;
