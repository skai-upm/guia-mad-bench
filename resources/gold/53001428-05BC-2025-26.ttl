<https://guia-kg.skai.etsisi.upm.es/resource/53001428/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Introducción, Clasificación y nomenclatura de enzimas. Características. Mecanismos de unión enzima sustrato. Sin subniveles"@es .

