<https://guia-kg.skai.etsisi.upm.es/resource/43000435> a ns1:Course ;
    ns1:courseType "Optativa"@es ;
    ns1:courseYear 1 ;
    ns1:semester "Primer semestre"@es ;
    schema:courseCode 43000435 ;
    schema:hasCourseInstance <https://guia-kg.skai.etsisi.upm.es/resource/43000435/2025-26> ;
    schema:name "Mechanical Behaviour Of Materials"@en,
        "Comportamiento Mecánico de Materiales"@es ;
    schema:numberOfCredits 4.5 .

<https://guia-kg.skai.etsisi.upm.es/resource/43000435/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/43000435/2025-26/CB10>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000435/2025-26/CE9>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000435/2025-26/CG1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000435/2025-26/CT1> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/43000435/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/43000435/2025-26/RA1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000435/2025-26/RA13>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000435/2025-26/RA16>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000435/2025-26/RA17>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000435/2025-26/RA20>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000435/2025-26/RA21>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000435/2025-26/RA34> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/43000435/2025-26/syllabus> ;
    ns1:inpersonHours "53 horas y 5 minutos (45.4%)"@es ;
    ns1:numberOfCredits 4.5 ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "55 horas y 15 minutos"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/43000435/2025-26/eventSchedule> ;
    schema:description """En caso de necesidad por razones sanitarias, las actividades docentes y de evaluación pasarán a tener lugar en modalidad telemática.
Objetivos:
- Conocer, interpretar y aplicar los modelos teóricos que describen y cuantifican el movimiento en pequeñas deformaciones y las fuerzas internas en los materiales estructurales;
- Conocer, interpretar y aplicar los modelos teóricos que describen las ecuaciones constitutivas y las simetrías de los materiales hookeanos, viscoelásticos y elastoplásticos;
- Aplicar conjuntamente las ecuaciones generales de la Mecánica de Medios Continuos y las ecuaciones constitutivas al análisis estructural de sólidos hookeanos, sólidos viscoelásticos y sólidos elástoplásticos."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/m.deabreu%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/m.deabreu%40upm.es> ;
    schema:name "Comportamiento Mecánico de Materiales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000435/2025-26/CB10> a ns1:Competency ;
    ns1:competencyCode "CB10" ;
    ns1:competencyDescription "Que los estudiantes posean las habilidades de aprendizaje que les permitan continuar estudiando de un modo que habrá de ser en gran medida autodirigido o autónomo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000435/2025-26/CE9> a ns1:Competency ;
    ns1:competencyCode "CE9" ;
    ns1:competencyDescription "Capacidad para la participación en actividades de I+D+i mediante la utilización de recursos de modelización predictiva en Comportamiento mecánico de materiales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000435/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Polivalencia para extender a ámbitos afines las competencias generales adquiridas en el ámbito temático del título."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000435/2025-26/CT1> a ns1:Competency ;
    ns1:competencyCode "CT1" ;
    ns1:competencyDescription "Capacidad de preparar y presentar comunicaciones orales, escritas y gráficas, estructurada y argumentadamente."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000435/2025-26/RA1> a ns1:LearningResult ;
    ns1:learningResultCode "RA1" ;
    ns1:learningResultDescription "Utiliza con eficacia, autonomía y polivalencia recursos de modelización predictiva en la temática de la materia"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000435/2025-26/RA13> a ns1:LearningResult ;
    ns1:learningResultCode "RA13" ;
    ns1:learningResultDescription "Sintetiza e integra con polivalencia y autonomía las competencias específica de formación científico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000435/2025-26/RA16> a ns1:LearningResult ;
    ns1:learningResultCode "RA16" ;
    ns1:learningResultDescription "conocer los modelos teóricos de comportamiento mecánico en rotura de mayor interés aplicables a los materiales estructurales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000435/2025-26/RA17> a ns1:LearningResult ;
    ns1:learningResultCode "RA17" ;
    ns1:learningResultDescription "conocer los fundamentos físicos de los comportamientos macroscópicos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000435/2025-26/RA20> a ns1:LearningResult ;
    ns1:learningResultCode "RA20" ;
    ns1:learningResultDescription "Conoce las causas de no linealidad geométrica en estructuras y los métodos de cálculo en los distintos niveles."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000435/2025-26/RA21> a ns1:LearningResult ;
    ns1:learningResultCode "RA21" ;
    ns1:learningResultDescription "Conoce las causas de no linealidad debida al material en estructuras, sus leyes constitutivas y los métodos de cálculo estructural aplicables."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000435/2025-26/RA34> a ns1:LearningResult ;
    ns1:learningResultCode "RA34" ;
    ns1:learningResultDescription "Conoce y sabe aplicar la mecánica de medios continuos no lineal, incluyendo grandes rotaciones y deformaciones, y comportamiento no lineal de los materiales"@es .

