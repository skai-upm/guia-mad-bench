<https://guia-kg.skai.etsisi.upm.es/resource/63000155> a ns1:Course ;
    ns1:courseType "Optativa"@es ;
    ns1:courseYear 2 ;
    ns1:semester "Cuarto semestre"@es ;
    schema:courseCode 63000155 ;
    schema:hasCourseInstance <https://guia-kg.skai.etsisi.upm.es/resource/63000155/2025-26> ;
    schema:name "Reservoir Simulation"@en,
        "Simulacion Numerica de Yacimientos de Hidrocarburos"@es ;
    schema:numberOfCredits 3.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/63000155/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/63000155/2025-26/CE01>,
        <https://guia-kg.skai.etsisi.upm.es/resource/63000155/2025-26/CG18> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/63000155/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/63000155/2025-26/didactic_resource/2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/63000155/2025-26/didactic_resource/3>,
        <https://guia-kg.skai.etsisi.upm.es/resource/63000155/2025-26/didactic_resource/4> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/63000155/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/63000155/2025-26/RA105>,
        <https://guia-kg.skai.etsisi.upm.es/resource/63000155/2025-26/RA106>,
        <https://guia-kg.skai.etsisi.upm.es/resource/63000155/2025-26/RA107>,
        <https://guia-kg.skai.etsisi.upm.es/resource/63000155/2025-26/RA108>,
        <https://guia-kg.skai.etsisi.upm.es/resource/63000155/2025-26/RA109>,
        <https://guia-kg.skai.etsisi.upm.es/resource/63000155/2025-26/RA110> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/63000155/2025-26/syllabus> ;
    ns1:inpersonHours "32 horas (41%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation """The software lab practices and work will be developed in the computer room (M2, CEPSA Fundation Lab). Reservoir dynamic software (ECLIPSE ) will be used thanks to the partnership of Schlumberger.
If possible, tests will be carried out in the laboratory to determine the permeability of different rock samples."""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "32 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/63000155/2025-26/eventSchedule> ;
    schema:description "This subject allows an approach to the reservoir simulation and gas storage. For that purpose, after knowing the fundamentals and the mathematic formulation of the main involved processes that appear in the reservoir simulation, numerical techniques are applied for the resolution of two phase and three phase flow problems in a porous media. For this task, commercial software is used, as it is done in the oil & gas industry."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/ramon.rodripons%40upm.es> ;
    schema:inLanguage "Inglés/Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/lauramaria.valle%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/ramon.rodripons%40upm.es> ;
    schema:name "Simulacion Numerica de Yacimientos de Hidrocarburos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000155/2025-26/CE01> a ns1:Competency ;
    ns1:competencyCode "CE01" ;
    ns1:competencyDescription "Capacidad para abordar y resolver problemas matemáticos avanzados de ingeniería, desde el planteamiento del problema hasta el desarrollo de la formulación y su implementación en un programa de ordenador. En particular, capacidad para formular, programar y aplicar modelos analíticos y numéricos avanzados de cálculo, proyectos, planificación y gestión, así como capacidad para la interpretación de los resultados obtenidos, en el contexto de la ingeniería de minas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000155/2025-26/CG18> a ns1:Competency ;
    ns1:competencyCode "CG18" ;
    ns1:competencyDescription "Conocimientos adecuados de los aspectos científicos y tecnológicos de métodos matemáticos, analíticos y numéricos de la ingeniería, mecánica de fluidos, mecánica de medios continuos, cálculo de estructuras, carboquímica, petroquímica y geotecnia"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000155/2025-26/RA105> a ns1:LearningResult ;
    ns1:learningResultCode "RA105" ;
    ns1:learningResultDescription "Comprender los procesos básicos asociados a un yacimiento de hidrocarburos y a un almacenamiento de CO2"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000155/2025-26/RA106> a ns1:LearningResult ;
    ns1:learningResultCode "RA106" ;
    ns1:learningResultDescription "Conocer los parámetros fundamentales para su caracterización"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000155/2025-26/RA107> a ns1:LearningResult ;
    ns1:learningResultCode "RA107" ;
    ns1:learningResultDescription "Comprender los modelos fundamentales de simulación en yacimientos de hidrocarburos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000155/2025-26/RA108> a ns1:LearningResult ;
    ns1:learningResultCode "RA108" ;
    ns1:learningResultDescription "Plantear y desarrollar las ecuaciones diferenciales de flujo de hidrocarburos en medio poroso"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000155/2025-26/RA109> a ns1:LearningResult ;
    ns1:learningResultCode "RA109" ;
    ns1:learningResultDescription "Aplicar el método de diferencias finitas a la simulación del flujo en yacimientos de hidrocarburos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000155/2025-26/RA110> a ns1:LearningResult ;
    ns1:learningResultCode "RA110" ;
    ns1:learningResultDescription "Aplicar la simulación numérica, a través de herramientas informáticas empleadas por la industria, a distintos casos reales de producción y almacenamiento"@es .

