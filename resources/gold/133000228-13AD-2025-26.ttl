    ns1:itemIndex 2 ;
    ns1:syllabusDescription "2.1. Participación, Educación ambiental y Opinión pública Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000228/2025-26/syllabus/3> a ns1:SyllabusItem ;
