    ns1:itemIndex 4 ;
    ns1:syllabusDescription "3. Antecedentes históricos (nacional e internacional) de las políticas del medio natural (desde el inicio de la profesión hasta la Conferencia de Río)"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000228/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "3.1. Siglo XIX Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000228/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "3.2. Siglo XX (1901-1992) Sin subniveles"@es .

