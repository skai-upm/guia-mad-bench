<https://guia-kg.skai.etsisi.upm.es/resource/133000228/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Introducción. Conceptos y enfoques de las políticas forestal y de Conservación de la naturaleza Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000228/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "2. Administración, medio natural y medio socioeconómico en España"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000228/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "4.3. Desarrollo sostenible (Estrategia 2030) y Convenios de Río Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000228/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "5. Políticas Forestal y de Conservación de la Naturaleza REGIONALES: Instituciones e iniciativas Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000228/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "6. Instrumentos de Política Forestal y Conservación Naturaleza de la UNIÓN EUROPEA"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000228/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "6.1. Instituciones de la UE: Comisión, Consejo, Parlamento, etc. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000228/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "6.2. Funcionamiento de la UE: procedimiento legislativo ordinario, presupuesto, etc. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000228/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "6.3. El Pacto Verde europeo Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000228/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "6.4. Política Agrícola Común y desarrollo rural. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000228/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "6.5. Otros instrumentos, políticas y estrategias de la UE sobre desarrollo sostenible, bosques, sector forestal, cambio climático, conservación y restauración de la naturaleza, biodiversidad, suelos, etc. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000228/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "7. Políticas Forestal y de Conservación de la Naturaleza españolas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000228/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "7.1. Instrumentos: Biodiversidad, política forestal, cambio climático y desertificación Sin subniveles"@es .

