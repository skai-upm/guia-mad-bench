    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/145007405/2025-26/eventSchedule> ;
    schema:description """Identificación de los principales elementos que afectan a la operación aeroportuario. Identificación de parámetros, modelización y análisis de influencia de los diferentes elementos en el conjunto de la operación.
Parámetros de diseño, planificación y explotación relacionados con el mantenimiento aeroportuario, con identificación de la influencia del mantenimiento en la operación y explotación aeroportuaria."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/manuel.tarifa%40upm.es> ;
