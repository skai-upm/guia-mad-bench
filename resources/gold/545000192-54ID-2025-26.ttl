    ns1:inpersonHours "36 horas (46.2%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation "La asignatura guarda relación con la Agenda 2030 y el cumplimiento de los Objetivos para el Desarrollo Sostenible (ODS), en concreto con el ODS 8: Promover el crecimiento económico inclusivo y sostenible, el empleo y el trabajo decente para todos y el ODS 9: Industria innovación e infraestructura"@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "36 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/545000192/2025-26/eventSchedule> ;
    schema:description """Esta asignatura tiene como objetivo fundamental profundizar en el aprendizaje de los diversos modelos de competencia en los distintos sectores económicos, así como las principales medidas de regulación en ellos
sugeridas desde la teoría económica. Además se persigue que el alumnado conozca el contexto español y europeo en relación con las diferentes iniciativas y medidas de políticas sectoriales, especialmente en relación con la
competencia, todo lo que pueda interesar y/o impactar en las empresas. Por último, se intenta que los alumnos obtengan información estadística sectorial que les sirva de instrumento para obtener y en la medida de lo posible
explicar la situación actual en los diversos sectores económicos objeto de estudio.

Todo ello se persigue conseguir mediante una combinación de clases teóricas, trabajos individuales y en grupo con información oficial, y/o presentaciones orales y escritas del alumnado y del profesor."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/daniel.fvega%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/daniel.fvega%40upm.es> ;
    schema:name "Políticas Sectoriales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000192/2025-26/CE56> a ns1:Competency ;
    ns1:competencyCode "CE56" ;
    ns1:competencyDescription "Entender el funcionamiento de los mercados financieros nacionales e internacionales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000192/2025-26/CE57> a ns1:Competency ;
    ns1:competencyCode "CE57" ;
    ns1:competencyDescription "Conocer las principales teorías sobre el comportamiento de la economía tanto a nivel individual como agregado."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000192/2025-26/CE58> a ns1:Competency ;
    ns1:competencyCode "CE58" ;
    ns1:competencyDescription "Comprender las bases que configuran la actual estructura de la economía mundial y española."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000192/2025-26/CE59> a ns1:Competency ;
    ns1:competencyCode "CE59" ;
    ns1:competencyDescription "Conocer la determinación de los principales indicadores y agregados económicos, así como su impacto sobre las decisiones de la empresa."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000192/2025-26/CE60> a ns1:Competency ;
    ns1:competencyCode "CE60" ;
    ns1:competencyDescription "Comprender las variables e indicadores que caracterizan la política macroeconómica de un sector y un entorno geográfico."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000192/2025-26/CE61> a ns1:Competency ;
    ns1:competencyCode "CE61" ;
    ns1:competencyDescription "Comprender el contexto económico, regional, nacional e internacional que rodea a la empresa así como interpretar su impacto en la misma."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000192/2025-26/CG14> a ns1:Competency ;
    ns1:competencyCode "CG14" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de comprender, interpretar, sintetizar y evaluar de forma crítica información proveniente de fuentes diversas en el ámbito de la administración y dirección de empresas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000192/2025-26/CG19> a ns1:Competency ;
    ns1:competencyCode "CG19" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de trabajar en equipos multidisciplinares, aplicando los conocimientos adquiridos en el ámbito de la administración y dirección de empresas, fomentando el espíritu de equipo y la coordinación en las tareas de los diversos miembros."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000192/2025-26/CG20> a ns1:Competency ;
    ns1:competencyCode "CG20" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de trabajar en entornos diversos, comprendiendo y adaptándose a situaciones nuevas en el ámbito de la administración y dirección de empresas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000192/2025-26/CG22> a ns1:Competency ;
    ns1:competencyCode "CG22" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de trabajar en el ámbito de la administración y dirección de empresas aplicando criterios de calidad y sostenibilidad."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000192/2025-26/RA124> a ns1:LearningResult ;
    ns1:learningResultCode "RA124" ;
    ns1:learningResultDescription "Entender el funcionamiento de una economía de mercado tanto a nivel microeconómico como macroeconómico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000192/2025-26/RA125> a ns1:LearningResult ;
    ns1:learningResultCode "RA125" ;
    ns1:learningResultDescription "Entender los fundamentos de los intercambios comerciales y del marco monetario que los condiciona, así como sus implicaciones para la adopción de políticas comerciales y macroeconómicas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000192/2025-26/RA127> a ns1:LearningResult ;
    ns1:learningResultCode "RA127" ;
    ns1:learningResultDescription "Saber utilizar correctamente los conceptos e instrumentos básicos del análisis para su aplicación a la realidad económica."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000192/2025-26/RA128> a ns1:LearningResult ;
    ns1:learningResultCode "RA128" ;
    ns1:learningResultDescription "Conocer y gestionar las fuentes de información económica relevante y su contenido. Ser capaz de analizar esa información, y de extraer conclusiones sobre diversos aspectos de la realidad económica."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000192/2025-26/RA311> a ns1:LearningResult ;
    ns1:learningResultCode "RA311" ;
    ns1:learningResultDescription "Poder exponer y comunicar sus ideas y reflexiones, tanto de forma oral como escrita"@es .

