<https://guia-kg.skai.etsisi.upm.es/resource/95000033/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Sesión 1: Familiarización con el laboratorio y las herramientas básicas disponibles Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000033/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "2. Sesiones 2 y 3: implementación en C de la versión 1.0 del sistema (versión de un módulo funcional). Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000033/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "3. Sesiones 4, 5 y 6: nueva versión 2.0 con nuevo módulo funcional del sistema. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000033/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "4. Sesiones 7, 8 y 9: versión 3.0 del sistema con un nuevo módulo funcional del sistema."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000033/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "4.1. Diseño, implementación y verificación del montaje HW de presentación requerido (e.g. LEDs, displays, DAC...) Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000033/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "4.2. Incorporación del HW al sistema, implementación de los mecanismos de temporización necesarios y verificación Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000033/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "4.3. Diseño, implementación y verificación del montaje HW de adquisición y control requerido (e.g. pulsadores, interruptores, ADC, teclados matriciales...) Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000033/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "5. Sesiones 10 y 11: versión 4.0 funcional del sistema e integración y modos de bajo consumo Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000033/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "6. Sesiones 12, 13 y 14: versión 5.0 del sistema con funcionalidades a elección del alumno Sin subniveles"@es .

