    schema:name "Bases de Fisiología Animal"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000008/2025-26/CB01> a ns1:Competency ;
    ns1:competencyCode "CB01" ;
    ns1:competencyDescription "Que los estudiantes hayan demostrado poseer y comprender conocimientos en un área de estudio que parte de la base de la educación secundaria general, y se suele encontrar a un nivel que, si bien se apoya en libros de texto avanzados, incluye también algunos aspectos que implican conocimientos procedentes de la vanguardia de su campo de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000008/2025-26/CB02> a ns1:Competency ;
    ns1:competencyCode "CB02" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar sus conocimientos a su trabajo o vocación de una forma profesional y posean las competencias que suelen demostrarse por medio de la elaboración y defensa de argumentos y la resolución de problemas dentro de su área de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000008/2025-26/CB03> a ns1:Competency ;
    ns1:competencyCode "CB03" ;
    ns1:competencyDescription "Que los estudiantes tengan la capacidad de reunir e interpretar datos relevantes (normalmente dentro de su área de estudio) para emitir juicios que incluyan una reflexión sobre temas relevantes de índole social, científica o ética"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000008/2025-26/CB04> a ns1:Competency ;
    ns1:competencyCode "CB04" ;
    ns1:competencyDescription "Que los estudiantes puedan transmitir información, ideas, problemas y soluciones a un público tanto especializado como no especializado"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000008/2025-26/CB05> a ns1:Competency ;
    ns1:competencyCode "CB05" ;
    ns1:competencyDescription "Que los estudiantes hayan desarrollado aquellas habilidades de aprendizaje necesarias para emprender estudios posteriores con un alto grado de autonomía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000008/2025-26/CE10> a ns1:Competency ;
    ns1:competencyCode "CE10" ;
    ns1:competencyDescription "Conocimiento de los procesos de nutrición, metabolismo y desarrollo en plantas y animales, asi como de la regulación de dichos procesos, y de su incidencia en la producción animal y vegetal."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000008/2025-26/CG02> a ns1:Competency ;
    ns1:competencyCode "CG02" ;
    ns1:competencyDescription "Ser capaces de evaluar y discernir los diferentes mecanismos responsables del desarrollo de plantas y animales con vistas al diseño y utilización de tecnologías y estrategias avanzadas en la producción vegetal y animal."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000008/2025-26/CT06> a ns1:Competency ;
    ns1:competencyCode "CT06" ;
    ns1:competencyDescription "Capacidad para organizar y planificar proyectos, experimentos y, en general, trabajos de índole profesional."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000008/2025-26/RA56> a ns1:LearningResult ;
    ns1:learningResultCode "RA56" ;
    ns1:learningResultDescription "Conocer e identificar órganos y sistemas corporales de los animales de distintas especies."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000008/2025-26/RA57> a ns1:LearningResult ;
    ns1:learningResultCode "RA57" ;
    ns1:learningResultDescription "Comprender los diferentes mecanismos fisiológicos que modulan los procesos digestivos, neuroendocrinos y metabólicos, reproductivos, de crecimiento, de producción de huevos y de leche."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000008/2025-26/RA58> a ns1:LearningResult ;
    ns1:learningResultCode "RA58" ;
    ns1:learningResultDescription "Comprender la aplicación de los conceptos y principios básicos de la anatomía y fisiología animal destinada a optimizar los diferentes sistemas de producción animal."@es .

