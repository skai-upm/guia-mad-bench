    ns1:itemIndex 6 ;
    ns1:syllabusDescription "3.1. Introducción. Aplicaciones de las vibraciones. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000127/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "3.2. Medida de las vibraciones. Definición de nivel de vibración. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000127/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "3.3. Captadores de vibraciones. Sin subniveles"@es .

