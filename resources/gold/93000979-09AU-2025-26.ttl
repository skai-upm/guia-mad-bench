<https://guia-kg.skai.etsisi.upm.es/resource/93000979/2025-26/syllabus> a ns1:Syllabus ;
    ns1:hasItem <https://guia-kg.skai.etsisi.upm.es/resource/93000979/2025-26/syllabus/0>,
        <https://guia-kg.skai.etsisi.upm.es/resource/93000979/2025-26/syllabus/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/93000979/2025-26/syllabus/2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/93000979/2025-26/syllabus/3>,
        <https://guia-kg.skai.etsisi.upm.es/resource/93000979/2025-26/syllabus/4>,
        <https://guia-kg.skai.etsisi.upm.es/resource/93000979/2025-26/syllabus/5>,
        <https://guia-kg.skai.etsisi.upm.es/resource/93000979/2025-26/syllabus/6>,
        <https://guia-kg.skai.etsisi.upm.es/resource/93000979/2025-26/syllabus/7>,
        <https://guia-kg.skai.etsisi.upm.es/resource/93000979/2025-26/syllabus/8>,
        <https://guia-kg.skai.etsisi.upm.es/resource/93000979/2025-26/syllabus/9> .

<https://guia-kg.skai.etsisi.upm.es/resource/93000979/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. P1: Introduction to MATLAB"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000979/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Matlab - Images classification- Medical imaging reading - Images visualization Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000979/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "2. P2: Global processing. Enhancement and intensification of medical imaging"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000979/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "2.1. Histogram: concept, calculus and filtering - Aplication in TC imaging: histogram based segmentation - Contrast enhancement: linear and non-linear - Histogram equalization Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000979/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "3. P3: Local processing. Enhancement and intensification of medical imaging"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000979/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "3.1. - Convolution and mask concepts -Smoothing: average, median and gaussian filtering - Edges detection: Sobel, Roberts and zerocross - Laplacian filter - Aplication on retinophaty images Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000979/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "4. P4: Morphological Image Processing."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000979/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "4.1. - Structuring elements - Erosion and dilation- Opening and closing -Reconstruction filtering Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000979/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "5. P5: Image segmentation."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000979/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "5.1. - Thresholding - Multiple thresholds - Adaptive thresholds - Otsu algorithm- Region growing Sin subniveles"@es .

