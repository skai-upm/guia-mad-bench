<https://guia-kg.skai.etsisi.upm.es/resource/53001599/2025-26/CB08> a ns1:Competency ;
    ns1:competencyCode "CB08" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de integrar conocimientos y enfrentarse a la complejidad de formular juicios a partir de una información que, siendo incompleta o limitada, incluya reflexiones sobre las responsabilidades sociales y éticas vinculadas a la aplicación de sus conocimientos y juicios"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001599/2025-26/CE03> a ns1:Competency ;
    ns1:competencyCode "CE03" ;
    ns1:competencyDescription "Utiliza los datos y sistemas informáticos más empleados tanto en la investigación como en la industria nuclear para los sistemas de fisión y/o fusión"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001599/2025-26/CE04> a ns1:Competency ;
    ns1:competencyCode "CE04" ;
    ns1:competencyDescription "Es capaz de diseñar nuevos sistemas para centrales nucleares de fisión, con todos sus componentes principales, atendiendo en particular a su influencia sobre la seguridad"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001599/2025-26/CE05> a ns1:Competency ;
    ns1:competencyCode "CE05" ;
    ns1:competencyDescription "Entiende a fondo el sistema de regulación de la seguridad, está comprometido con la seguridad y es consciente de la importancia de la cultura de seguridad para las aplicaciones de la energía nuclear, así como las implicaciones ético"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001599/2025-26/CE07> a ns1:Competency ;
    ns1:competencyCode "CE07" ;
    ns1:competencyDescription "Es capaz de trabajar profesionalmente en las empresas del sector nuclear, diseñando, coordinando, dirigiendo e integrando los conocimientos necesarios para participar en la puesta en marcha y apoyo a operación de las instalaciones nucleares"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001599/2025-26/CG04> a ns1:Competency ;
    ns1:competencyCode "CG04" ;
    ns1:competencyDescription "Ser capaz de integrar conocimientos y enfrentarse a la complejidad de formular juicios a partir de una información que, siendo incompleta o limitada, incluya reflexiones sobre las responsabilidades sociales y éticas vinculadas a la aplicación de sus conocimientos y juicios"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001599/2025-26/CG06> a ns1:Competency ;
    ns1:competencyCode "CG06" ;
    ns1:competencyDescription "Poseer las habilidades de aprendizaje que permitan continuar estudiando de un modo autodirigido o autónomo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001599/2025-26/CT01> a ns1:Competency ;
    ns1:competencyCode "CT01" ;
    ns1:competencyDescription "Aplica. Habilidad para aplicar conocimientos científicos, matemáticos y tecnológicos en sistemas relacionados con la práctica de la ingeniería"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001599/2025-26/CT05> a ns1:Competency ;
    ns1:competencyCode "CT05" ;
    ns1:competencyDescription "Resuelve. Habilidad para identificar, formular y resolver problemas de ingeniería"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001599/2025-26/CT11> a ns1:Competency ;
    ns1:competencyCode "CT11" ;
    ns1:competencyDescription "Usa herramientas. Habilidad para usar las técnicas, destrezas y herramientas ingenieriles modernas necesarias para la práctica de la ingeniería"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001599/2025-26/CT12> a ns1:Competency ;
    ns1:competencyCode "CT12" ;
    ns1:competencyDescription "Es bilingüe. Capacidad de trabajar en un entorno bilingüe (inglés/castellano)"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001599/2025-26/RA54> a ns1:LearningResult ;
    ns1:learningResultCode "RA54" ;
    ns1:learningResultDescription "Conocer los fundamentos para el cálculo de probabilidades de fallo y los modelos de fallo más habituales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001599/2025-26/RA55> a ns1:LearningResult ;
    ns1:learningResultCode "RA55" ;
    ns1:learningResultDescription "Analizar mediante métodos probabilistas la fiabilidad y el riesgo de una instalación nuclear"@es .

