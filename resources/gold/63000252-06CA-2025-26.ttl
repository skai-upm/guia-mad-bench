    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/63000252/2025-26/eventSchedule> ;
    schema:description "This course deals with the practical aspects of a soil and groundwater imvestigation, including the sampling design and set up of a conceptual site model; soil, groundwater and soil vapor sampling and preservation; and quality assurance and quality controls procedures."@es ;
