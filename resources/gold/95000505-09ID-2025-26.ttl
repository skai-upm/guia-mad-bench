<https://guia-kg.skai.etsisi.upm.es/resource/95000505/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Ingeniería y economía de datos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000505/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Innovación y emprendimiento, ética y privacidad en la ingeniería de datos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000505/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "2.6. Ciberseguridad, gobernanza y políticas de usos de datos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000505/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "3. Metodologías y modelos de análisis para ingeniería de datos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000505/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "3.1. Definición de problemas de ingeniería en el ámbito de datos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000505/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "3.2. Construcción y tipos de modelos en ingeniería de datos: razonamiento inductivo y deductivo, método científico y modelos de la Física aplicados al contexto de la ciencia de datos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000505/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "3.3. Otros tipos de modelos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000505/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "3.4. Caso de uso y aplicación de métodos y modelado de datos en ingeniería de datos Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000505/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "4. Seminario-Taller sobre técnicas de comunicación escrita en ingeniería de datos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000505/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "4.1. Uso ético de la información (datos, citación y bibliografía). Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000505/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "4.2. Expresión escrita en español para la creación de documentos académico-científicos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000505/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "4.3. Realización de ejercicio de redacción de documento técnico relacionado con ingeniería de datos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000505/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Conceptos de ingeniería de datos: \"data analytics\", \"machine learning\", \"deep learning\", redes neuronales, procesamiento de audio, imágenes y video, NLP, algoritmos de recomendación y búsqueda. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000505/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "1.3. Economía de datos: ecosistema y aplicaciones Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000505/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "2. Tecnologías e infraestructuras para la ingeniería de datos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000505/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "2.1. Introducción a las tareas de la ingeniería de datos: diseño, implementación y despliegue de infraestructura para soluciones. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000505/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "2.2. Big Data: cuando los datos no caben en un solo ordenador. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000505/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "2.3. Captura, ingestión, transmisión y limpieza de datos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000505/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "2.4. Lagos de Datos y bases de datos: almacenando toda la información. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000505/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "2.5. Procesado distribuido y aprendizaje automático. Interpretación y visualización de datos. Sin subniveles"@es .

