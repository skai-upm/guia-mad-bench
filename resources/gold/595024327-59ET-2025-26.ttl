    ns1:inpersonHours "66 horas (42.3%)"@es ;
    ns1:numberOfCredits 6.0 ;
    ns1:otherInformation """Las actividades indicadas en el cronograma son solo MERAMENTE ORIENTATIVAS, y están sujetas a modificaciones importantes en función del calendario laboral y académico y el desarrollo y dinámica de las clases tanto de teoría como de laboratorio.

Importante: Es imprescindible haber cursado y realizado las prácticas de laboratorio de la asignatura Transmisión y Propagación de Ondas para poder cursar y realizar las prácticas de laboratorio de la asignatura Tecnología de Alta Frecuencia"""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "66 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/595024327/2025-26/eventSchedule> ;
    schema:description "En la presente asignatura se buscan dos objetivos principales. El primero consiste en el asentamiento de los conceptos básicos sobre líneas de transmisión y dar a conocer las distintas formas de adaptación que existen. Como segundo objetivo se pretende, partiendo como base de las ecuaciones de Maxwell, realizara el estudio de la propagación de las ondas electromagnéticas en diferentes tipos de estructuras guiadas: guías conductoras, guías dieléctricas y fibra óptica. Estos conocimientos se reafirmarán de forma práctica en el laboratorio."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/ignacio.gomezr%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/ignacio.gomezr%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/joseluis.jimenez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/vicente.gonzalez%40upm.es> ;
    schema:name "Transmision y Propagacion de Ondas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595024327/2025-26/CE%20SC03> a ns1:Competency ;
    ns1:competencyCode "CE SC03" ;
    ns1:competencyDescription "Capacidad de análisis de componentes y sus especificaciones para sistemas de comunicaciones guiadas y no guiadas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595024327/2025-26/CE%20SC05> a ns1:Competency ;
    ns1:competencyCode "CE SC05" ;
    ns1:competencyDescription "Capacidad para la selección de antenas, equipos y sistemas de transmisión, propagación de ondas guiadas y no guiadas, por medios electromagnéticos, de radiofrecuencia u ópticos y la correspondiente gestión del espacio radioeléctrico y asignación de frecuencias."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595024327/2025-26/CE%20TEL03> a ns1:Competency ;
    ns1:competencyCode "CE TEL03" ;
    ns1:competencyDescription "Capacidad para utilizar herramientas informáticas de búsqueda de recursos bibliográficos o de información relacionada con las telecomunicaciones y la electrónica."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595024327/2025-26/CE%20TEL09> a ns1:Competency ;
    ns1:competencyCode "CE TEL09" ;
    ns1:competencyDescription "Capacidad para comprender los mecanismos de propagación y transmisión de ondas electromagnéticas y acústicas, y sus correspondientes dispositivos emisores y receptores."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595024327/2025-26/CG%2002> a ns1:Competency ;
    ns1:competencyCode "CG 02" ;
    ns1:competencyDescription "Capacidad de búsqueda y selección de información, de razonamiento crítico y de elaboración y defensa de argumentos dentro del área."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595024327/2025-26/CG%2004> a ns1:Competency ;
    ns1:competencyCode "CG 04" ;
    ns1:competencyDescription "Capacidad de abstracción, de análisis y de síntesis y de resolución de problemas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595024327/2025-26/CG%2005> a ns1:Competency ;
    ns1:competencyCode "CG 05" ;
    ns1:competencyDescription "Capacidad de trabajo en equipo y en entornos multidisciplinares."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595024327/2025-26/CG%2013> a ns1:Competency ;
    ns1:competencyCode "CG 13" ;
    ns1:competencyDescription "Habilidades de aprendizaje con un alto grado de autonomía."@es .

