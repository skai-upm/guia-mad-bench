    ns1:inpersonHours "39 horas (50%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation "Esta asignatura se relaciona con los Objetivos de Desarrollo Sostenible ODS4 y ODS8"@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "39 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/45000256/2025-26/eventSchedule> ;
    schema:description "En esta asignatura se abordan los diferentes aspectos de la Dirección y Gestión de Recursos Humanos: La creciente importancia de la gestión de los recursos humanos. Los procesos básicos: análisis del puesto y planificación. La incorporación del individuo en las organizaciones: reclutamiento, selección y socialización. El desarrollo de los recursos humanos: formación y carrera profesional. La evaluación, compensación y mantenimiento de los recursos humanos. Gestión de conocimiento y recursos humanos. Conciliación de la vida personal y laboral. Gestión internacional de los recursos humanos. Aprendizaje organizativo en multinacionales. Sociología de las profesiones. Trabajo en equipo y colaboración. Liderazgo. Comunicación. Negociación de conflictos. Toma de decisiones."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/ignacio.menendezpidal%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/ignacio.menendezpidal%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/joaquin.sanzdeojed%40upm.es> ;
    schema:name "Dirección y Gestión de Recursos Humanos"@es .

