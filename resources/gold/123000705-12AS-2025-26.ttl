    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/123000705/2025-26/eventSchedule> ;
    schema:description "El objetivo de esta asignatura es conocer distintos sensores y tipos de datos para su aplicación en el análisis de la amenaza y riesgo sísmico."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/a.staller%40upm.es> ;
