    schema:name "Sensores Remotos Aplicados a la Evaluación del Riesgo Sísmico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/123000705/2025-26/C1> a ns1:Competency ;
    ns1:competencyCode "C1" ;
    ns1:competencyDescription "Poseer capacidad para diseñar, desarrollar, implementar, gestionar y mejorar productos, sistemas y procesos en los distintos ámbitos de la evaluación del riesgo sísmico, usando tecnologías de la información geoespacial.TIPO: Competencias."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/123000705/2025-26/C10> a ns1:Competency ;
    ns1:competencyCode "C10" ;
    ns1:competencyDescription "Organización y planificación.Capacidad de definir el curso de acción y los procedimientos requeridos para alcanzar los objetivos y metas, estableciendo lo que hay que hacer para llegar al estado final deseado.TIPO: Competencias."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/123000705/2025-26/C11> a ns1:Competency ;
    ns1:competencyCode "C11" ;
    ns1:competencyDescription "Gestión de la información.Capacidad de recopilar, generar, analizar, procesar, transformar, almacenar y seleccionar la información relevante para el desarrollo de las actividades de investigación o profesionales.TIPO: Competencias."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/123000705/2025-26/C13> a ns1:Competency ;
    ns1:competencyCode "C13" ;
    ns1:competencyDescription "Trabajo en contextos internacionales.Capacidad de analizar y comprender las circunstancias de otras sociedades y países para desarrollar una labor investigadora y profesional empática y enriquecida.TIPO: Competencias."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/123000705/2025-26/C3> a ns1:Competency ;
    ns1:competencyCode "C3" ;
    ns1:competencyDescription "Conocer y aplicar las TIGs (LIDAR, GNSS, imágenes satelitales y aéreas, UAVs, SIG) en el ámbito de la observación de la Tierra y aplicación en los métodos de investigación del riesgo sísmico.TIPO: Competencias."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/123000705/2025-26/C7> a ns1:Competency ;
    ns1:competencyCode "C7" ;
    ns1:competencyDescription "Uso de la lengua inglesa.Capacidad para comprender material escrito y audiovisual en lengua inglesa.TIPO: Competencias."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/123000705/2025-26/K2> a ns1:Competency ;
    ns1:competencyCode "K2" ;
    ns1:competencyDescription "Definir y caracterizar las fuentes sísmicas usando los datos geológicos, geofísicos y geodésicos y de otras TIGs.TIPO:Conocimientos o contenidos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/123000705/2025-26/RA1> a ns1:LearningResult ;
    ns1:learningResultCode "RA1" ;
    ns1:learningResultDescription "Este plan está adaptado al RD 822/2021.Los resultados del aprendizaje correspondientes a esta asignatura han quedado definidos en el apartado de competencias de este documento, señalando los que corresponden a conocimientos, habilidades y competencias propiamente dichas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/123000705/2025-26/Sk1> a ns1:Competency ;
    ns1:competencyCode "Sk1" ;
    ns1:competencyDescription "Aplicar conocimientos de ciencias de la Tierra y tecnologías de la información geoespacial en la evaluación del riesgo sísmico.TIPO: Habilidades o destrezas."@es .

