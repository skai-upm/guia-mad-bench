<https://guia-kg.skai.etsisi.upm.es/resource/53000552/2025-26/CE02> a ns1:Competency ;
    ns1:competencyCode "CE02" ;
    ns1:competencyDescription "Tener la capacidad para analizar la incidencia de las perturbaciones eléctricas en la calidad del servicio, realizar medidas y establecer las acciones correctoras necesarias."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000552/2025-26/CE04> a ns1:Competency ;
    ns1:competencyCode "CE04" ;
    ns1:competencyDescription "Aplicar los conocimientos adquiridos para diseñar las protecciones de los equipos e instalaciones eléctricas, con unos requisitos nuevos derivados de la incorporación de tecnologías actuales basadas en la electrónica digital."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000552/2025-26/CE05> a ns1:Competency ;
    ns1:competencyCode "CE05" ;
    ns1:competencyDescription "Tener la capacidad necesaria para analizar los transitorios electromagnéticos derivados de maniobras, faltas o incidencias externas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000552/2025-26/CE07> a ns1:Competency ;
    ns1:competencyCode "CE07" ;
    ns1:competencyDescription "Aplicar los conocimientos adquiridos para analizar los sistemas eléctricos en las condiciones de pérdida de estabilidad y las medidas correctoras necesarias."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000552/2025-26/CE08> a ns1:Competency ;
    ns1:competencyCode "CE08" ;
    ns1:competencyDescription "Ser capaces de integrar conocimientos y enfrentarse a los retos derivados de la implantación cada vez mayor de la generación distribuida"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000552/2025-26/CG01> a ns1:Competency ;
    ns1:competencyCode "CG01" ;
    ns1:competencyDescription "Haber demostrado unos conocimientos y una comprensión que se basa en el nivel típicamente asociado a los grados y lo superan y mejoran y que les proporcionan una base o una oportunidad para la originalidad en el desarrollo i/o aplicación de ideas, a menudo en el contexto de la Investigación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000552/2025-26/CG02> a ns1:Competency ;
    ns1:competencyCode "CG02" ;
    ns1:competencyDescription "Ser capaces de aplicar sus conocimientos y su comprensión, así como sus habilidades para resolver problemas, en entornos nuevos o no familiares y en contextos amplios (multidisciplinarios) relativos a su campo de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000552/2025-26/CG04> a ns1:Competency ;
    ns1:competencyCode "CG04" ;
    ns1:competencyDescription "Ser capaces de comunicar sus conclusiones, y los conocimientos y el marco conceptual en que se basan, tanto a audiencias expertas como no expertas y de manera clara y sin ambigüedades."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000552/2025-26/CG05> a ns1:Competency ;
    ns1:competencyCode "CG05" ;
    ns1:competencyDescription "Haber desarrollado habilidades de aprendizaje que les permitan continuar los estudios de manera ampliamente autodirigida o autónoma"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000552/2025-26/RA18> a ns1:LearningResult ;
    ns1:learningResultCode "RA18" ;
    ns1:learningResultDescription "Capacidad para determinar el fasor de la componente fundamental de una señal a partir de muestras de la misma obtenidas a intervalos de tiempo fijo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000552/2025-26/RA19> a ns1:LearningResult ;
    ns1:learningResultCode "RA19" ;
    ns1:learningResultDescription "Capacidad para seleccionar los transformadores de tensión e intensidad para protección"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000552/2025-26/RA20> a ns1:LearningResult ;
    ns1:learningResultCode "RA20" ;
    ns1:learningResultDescription "Capacidad para realizar los ajustes de protecciones de distancia de líneas con y sin comunicación en un relé numérico de última generación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000552/2025-26/RA21> a ns1:LearningResult ;
    ns1:learningResultCode "RA21" ;
    ns1:learningResultDescription "Capacidad para realizar los ajustes de protecciones de sobreintensidad y de conductor roto en un relé numérico de última generación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000552/2025-26/RA22> a ns1:LearningResult ;
    ns1:learningResultCode "RA22" ;
    ns1:learningResultDescription "Capacidad para realizar los ajustes de una protección diferencial de línea en un relé numérico de última generación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000552/2025-26/RA23> a ns1:LearningResult ;
    ns1:learningResultCode "RA23" ;
    ns1:learningResultDescription "Capacidad para realizar los ajustes de una protección diferencial de transformador en un relé numérico de última generación"@es .

