    schema:name "Sport Fishery Management"@en,
        "Gestion de la Pesca Deportiva."@es ;
    schema:numberOfCredits 4.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/133000043/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/133000043/2025-26/CB6>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000043/2025-26/CE6>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000043/2025-26/CG1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000043/2025-26/CG2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000043/2025-26/CT2> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/133000043/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000043/2025-26/didactic_resource/2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000043/2025-26/didactic_resource/3> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/133000043/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/133000043/2025-26/RA23>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000043/2025-26/RA24>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000043/2025-26/RA25>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000043/2025-26/RA26> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/133000043/2025-26/syllabus> ;
    ns1:inpersonHours "52 horas (50%)"@es ;
    ns1:numberOfCredits 4.0 ;
    ns1:otherInformation """Se realizara un esfuerzo para poder tener diversas opiniones de los protagonistas del sector durante la impartición del curso
Esta asignatura empieza su impartición en el primer semestre con un esquema de presencialidad definido. En caso de un cambio en las condiciones sanitarias que obligara a un confinamiento total o parcial, habría que hacer una replanificación con las correspondientes adendas.
LAS COMPETENCIAS Y LOS RESULTADOS DE APRENDIZAJE DE ESTA ASIGNATURA SON LOS ACORDES CON LA MEMORIA VERIFICA DEL TÍTULO"""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "52 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/133000043/2025-26/eventSchedule> ;
    schema:description """La asignatura intenta conocer los antecedentes, la actualidad y el futuro de la actividad de la pesca deportiva.
Se analizaran las gestiones en este sector de la pesca deportiva, en otros países de nuestro entorno cultural.
Se intentara dar a conocer las posibilidades de este sector en el medio rural, como fuente generadora de riqueza.
Se manejaran herramientas de modelización práctica, aplicada a la gestión de la pesca, de la evolución de ecosistemas acuáticos
Se analizaran los procesos de decisión y los aspectos técnicos en la gestión de la pesca deportiva.
Bases de la ordenación de la pesca deportiva
Se hablaran de los sistemas de vigilancia y motorización de las acciones emprendidas
Se describirán las distintas modalidades de pesca deportiva."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/fernando.torrent%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/ca.dove%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/fernando.torrent%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/ricardo.garcia%40upm.es> ;
    schema:name "Gestion de la Pesca Deportiva."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000043/2025-26/CB6> a ns1:Competency ;
    ns1:competencyCode "CB6" ;
    ns1:competencyDescription "Poseer y comprender conocimientos que aporten una base u oportunidad de ser originales en el desarrollo y/o aplicación de ideas, a menudo en un contexto de investigación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000043/2025-26/CE6> a ns1:Competency ;
    ns1:competencyCode "CE6" ;
    ns1:competencyDescription "Conocer y aplicar los conceptos y métodos de la gestión de pesca deportiva sostenible y moderna"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000043/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Capacidad para proponer, dirigir y realizar estudios para la caracterización del estado ecológico de masas de agua, así como de las acciones y obras encaminadas a su rehabilitación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000043/2025-26/CG2> a ns1:Competency ;
    ns1:competencyCode "CG2" ;
    ns1:competencyDescription "Capacidad para ordenar y gestionar los servicios culturales, paisajísticos y de ocio de los ecosistemas acuáticos, y diseñar, proyectar y ejecutar las obras, instalaciones e infraestructuras necesarias."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000043/2025-26/CT2> a ns1:Competency ;
    ns1:competencyCode "CT2" ;
    ns1:competencyDescription "Conocer y utilizar herramientas de gestión administrativa y económica de los recursos humanos, materiales y financieros en la propuesta y ejecución de proyectos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000043/2025-26/RA23> a ns1:LearningResult ;
    ns1:learningResultCode "RA23" ;
    ns1:learningResultDescription "Conocer en un aspecto amplio, las posibilidades de la gestión de la pesca deportiva, como generadora de riqueza."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000043/2025-26/RA24> a ns1:LearningResult ;
    ns1:learningResultCode "RA24" ;
    ns1:learningResultDescription "Aplicar los conocimientos del ecosistema y su funcionamiento, para un uso racional y sostenible del recurso pesca."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000043/2025-26/RA25> a ns1:LearningResult ;
    ns1:learningResultCode "RA25" ;
    ns1:learningResultDescription "Conocer los principios generales de gestión de la pesca deportiva"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000043/2025-26/RA26> a ns1:LearningResult ;
