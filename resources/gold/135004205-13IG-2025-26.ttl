    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/135004205/2025-26/eventSchedule> ;
    schema:description """La asignatura Bioquímica y Biotecnología se ocupa del estudio de los sistemas biológicos desde una perspectiva molecular. Esta perspectiva conduce a principios y mecanismos unificadores, esenciales para comprender la naturaleza de los seres vivos, así como su funcionamiento, organización, complejidad y evolución, entre otros aspectos importantes.
La asignatura está diseñada para proporcionar al estudiante una formación científica general centrada en las bases moleculares de dichos aspectos. Por otra parte, la asignatura pretende orientar al estudiante hacia las aplicaciones tecnológicas de los procesos bioquímicos subyacentes, con especial énfasis en el ámbito forestal. Para ello, el temario de la asignatura está estructurado en tres grandes unidades temáticas (UT):
- UT1: Células, Biomolécula y Catálisis (Temas 1-8)
- UT2: Metabolismo y Bioenergética (Temas 9-16)
- UT3: Genética Molecular y Biotecnología (Temas 17-23)"""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/luis.gomez%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/luis.gomez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/m.berrocal%40upm.es> ;
    schema:name "Bioquimica y Biotecnologia"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004205/2025-26/CE%201.4> a ns1:Competency ;
    ns1:competencyCode "CE 1.4" ;
    ns1:competencyDescription "Conocimientos básicos de la química general, química orgánica e inorgánica y sus aplicaciones en la ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004205/2025-26/CG01> a ns1:Competency ;
    ns1:competencyCode "CG01" ;
    ns1:competencyDescription "Capacidad para comprender los fundamentos biológicos, químicos, físicos, matemáticos y de los sistemas de representación necesarios para el desarrollo de la actividad profesional, así como para identificar los diferentes elementos bióticos y físicos del medio forestal y los recursos naturales renovables susceptibles de protección, conservación y aprovechamientos en el ámbito forestal."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004205/2025-26/CG05> a ns1:Competency ;
    ns1:competencyCode "CG05" ;
    ns1:competencyDescription "Conocimiento de las bases de la mejora forestal y capacidad para su aplicación práctica a la producción de planta y la biotecnología."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004205/2025-26/CT9> a ns1:Competency ;
    ns1:competencyCode "CT9" ;
    ns1:competencyDescription "Utilización de TICs para el trabajo cooperativo y trabajo en equipo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004205/2025-26/RA2> a ns1:LearningResult ;
    ns1:learningResultCode "RA2" ;
    ns1:learningResultDescription "RA247"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004205/2025-26/RA30> a ns1:LearningResult ;
    ns1:learningResultCode "RA30" ;
    ns1:learningResultDescription "Conocer como actúan los enzimas, sus funciones biológicas y sus aplicaciones prácticas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004205/2025-26/RA31> a ns1:LearningResult ;
    ns1:learningResultCode "RA31" ;
    ns1:learningResultDescription "Comprender la naturaleza de la información genética y la forma en que se expresa, así como su relación con las características de los seres vivos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004205/2025-26/RA32> a ns1:LearningResult ;
    ns1:learningResultCode "RA32" ;
    ns1:learningResultDescription "Interpretar y evaluar datos derivados de experimentos y mediciones relacionándolos con la teoría"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004205/2025-26/RA33> a ns1:LearningResult ;
    ns1:learningResultCode "RA33" ;
    ns1:learningResultDescription "Conocer las herramientas y técnicas más relevantes de la genética molecular. Comprender los fundamentos de la manipulación racional de la información genética"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004205/2025-26/RA34> a ns1:LearningResult ;
    ns1:learningResultCode "RA34" ;
    ns1:learningResultDescription "Conocer la estructura y la función de las principales moléculas biológicas. Conocer su importancia para el crecimiento, el desarrollo y la fisiología de los seres vivos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004205/2025-26/RA35> a ns1:LearningResult ;
    ns1:learningResultCode "RA35" ;
    ns1:learningResultDescription "Comprender las bases del metabolismo y de las transferencias de energía en los seres vivos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004205/2025-26/RA36> a ns1:LearningResult ;
    ns1:learningResultCode "RA36" ;
    ns1:learningResultDescription "Conocer los aspectos del metabolismo relacionados con la nutrición de plantas y animales"@es .

