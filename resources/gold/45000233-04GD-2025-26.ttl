        <https://guia-kg.skai.etsisi.upm.es/resource/45000233/2025-26/30AD.%20G02>,
        <https://guia-kg.skai.etsisi.upm.es/resource/45000233/2025-26/30AD.%20G09> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/45000233/2025-26/didactic_resource/1>,
