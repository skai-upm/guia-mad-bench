    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/45000233/2025-26/RA194>,
        <https://guia-kg.skai.etsisi.upm.es/resource/45000233/2025-26/RA195>,
        <https://guia-kg.skai.etsisi.upm.es/resource/45000233/2025-26/RA196> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/45000233/2025-26/syllabus> ;
    ns1:inpersonHours "77 horas y 15 minutos (49.5%)"@es ;
    ns1:numberOfCredits 6.0 ;
    ns1:otherInformation ""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "77 horas y 15 minutos"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/45000233/2025-26/eventSchedule> ;
    schema:description """El objetivo del curso es que los alumnos adquieran la capacidad de:
- Identificar diversos tipos de sistemas productivos y los principales problemas de organización de flujos de materiales y de información que en ellos se manifiestan.
- Conocer en profundidad diferentes técnicas de organización de los sistemas productivos de bienes y servicios, incluyendo la selección y aplicación para la toma de distintas decisiones.
- Conocer en profundidad el ciclo completo de planificación y control de la producción, desde la previsión de necesidades hasta la ejecución en taller."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/l.garrido%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/juan.molina%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/l.garrido%40upm.es> ;
    schema:name "Dirección de Producción"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000233/2025-26/30AD.%20E28> a ns1:Competency ;
    ns1:competencyCode "30AD. E28" ;
    ns1:competencyDescription "Determinar las decisiones estratégicas y tácticas relacionadas con el área de producción / operaciones."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000233/2025-26/30AD.%20E29> a ns1:Competency ;
    ns1:competencyCode "30AD. E29" ;
    ns1:competencyDescription "Comprender los procesos de dirección de operaciones y organización de la producción."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000233/2025-26/30AD.%20G02> a ns1:Competency ;
    ns1:competencyCode "30AD. G02" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de planificar eficientemente los trabajos en el ámbito de la administración y dirección de empresas, priorizando las tareas a desempeñar y evaluando los recursos y el tiempo necesario para llevarlas a cabo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000233/2025-26/30AD.%20G09> a ns1:Competency ;
    ns1:competencyCode "30AD. G09" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de trabajar en el ámbito de la administración y dirección de empresas aplicando criterios de calidad y sostenibilidad."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000233/2025-26/RA194> a ns1:LearningResult ;
    ns1:learningResultCode "RA194" ;
    ns1:learningResultDescription "Conocer los fundamentos de la organización, planificación y control de la producción."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000233/2025-26/RA195> a ns1:LearningResult ;
    ns1:learningResultCode "RA195" ;
    ns1:learningResultDescription "Abordar situaciones nuevas o complejas en colaboración con otros hasta llegar a diseñar un plan coherente con acciones concretas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000233/2025-26/RA196> a ns1:LearningResult ;
    ns1:learningResultCode "RA196" ;
    ns1:learningResultDescription "Participar e integrarse en el desarrollo organizado de un trabajo en grupo, previendo las tareas, tiempos y recursos para conseguir los resultados deseados."@es .

