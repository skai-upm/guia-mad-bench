    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000113/2025-26/didactic_resource/9> a ns1:DidacticResource ;
    ns1:bibliographyDescription """Repositorio público github.
Set of modern Fortran numerical libraries covering: zeroes of Systems of Equations, Lagrange Interpolation, Finite Differences, Cauchy Problems, Boundary Value Problems, and Initial Boundary Value Problems."""@es ;
    ns1:bibliographyTitle "https://github.com/jahrWork/NumericalHUB"@es ;
    ns1:bibliographyType "Recursos web"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143000113/2025-26/evaluation> a ns1:EvaluationSystem ;
    ns1:evaluationDescription """La asignatura consta de dos partes:

1) Una parte teórica con un peso del 40% de la nota final. Se evalúa mediante una presentación oral.
2) Un parte práctica con un peso del 60% asociada a un trabajo grupal que se evalúa mediante la plataforma
GitHub y la realización de hitos semanles. Al final de curso, el grupo realizará una presentacióin oral
con los principales resultados obtenidos y las conclusiones mas relevantes de los hitos asignados o elegidos.

Para aprobar la evaluación continua es necesario aprobar cada parte por separado.
Para aprobar la asignatura en la convocatoria ordinaria, el alumno deberá obtener una nota igual a superior al 5 sobre 10 en el examen.
La evaluación en convocatoria extraordinaria será del mismo tipo que en evaluación ordinaria"""@es ;
    ns1:hasEvaluationTrial <https://guia-kg.skai.etsisi.upm.es/resource/143000113/2025-26/evaluation/trial1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/143000113/2025-26/evaluation/trial2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/143000113/2025-26/evaluation/trial3> .

