        "Técnicas de Análisis Bioeconómico I"@es ;
    schema:numberOfCredits 4.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/205000032/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/205000032/2025-26/CB03>,
        <https://guia-kg.skai.etsisi.upm.es/resource/205000032/2025-26/CE22>,
