    schema:hasCourseInstance <https://guia-kg.skai.etsisi.upm.es/resource/53002080/2025-26> ;
    schema:name "Artificial Intelligence Methods Applied To Structural Engineering"@en,
        "Métodos de Inteligencia Artificial Aplicados a la Ingeniería de Estructuras"@es ;
    schema:numberOfCredits 4.5 .

<https://guia-kg.skai.etsisi.upm.es/resource/53002080/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/53002080/2025-26/%28a%29>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53002080/2025-26/%28b%29>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53002080/2025-26/%28d%29>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53002080/2025-26/%28e%29>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53002080/2025-26/%28g%29>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53002080/2025-26/%28k%29>,
