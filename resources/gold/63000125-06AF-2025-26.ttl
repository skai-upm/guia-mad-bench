    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/63000125/2025-26/eventSchedule> ;
    schema:description "La asignatura pretende familiarizar a estudiantes de distintas procedencias (graduados en Ingeniería de la Energía, Ingeniería Geológica, Ingeniería en Tecnologías Mineras...), con los recursos geológicos, los parámetros científicos, técnicos, económicos, sociales y ambientales que condicionan su explotación y las técnicas más importantes que permiten reconocer dichos recursos, evaluarlos, establecer su valor de mercado y la repercusión social y ambiental de su explotación."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/carlos.lopezj%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/carlos.lopezj%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/isabelkitina.arribas%40upm.es> ;
    schema:name "Investigacion y Gestion de Recursos Minerales y Rocas Industriales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000125/2025-26/CB09> a ns1:Competency ;
    ns1:competencyCode "CB09" ;
    ns1:competencyDescription "Que los estudiantes sepan comunicar sus conclusiones y los conocimientos y razones últimas que las sustentan a públicos especializados y no especializados de un modo claro y sin ambigüedades"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000125/2025-26/CE03> a ns1:Competency ;
    ns1:competencyCode "CE03" ;
    ns1:competencyDescription "Conocimiento adecuado de evaluación de proyectos y análisis de riesgo. Dirección, organización y mantenimiento. Economía y gestión de empresas. Calidad. . Legislación aplicable al medio natural. Gestión del conocimiento"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000125/2025-26/CE04> a ns1:Competency ;
    ns1:competencyCode "CE04" ;
    ns1:competencyDescription "Conocimiento adecuado de modelización, evaluación y gestión de recursos geológicos, incluidas las aguas subterráneas, minerales y termales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000125/2025-26/CE05> a ns1:Competency ;
    ns1:competencyCode "CE05" ;
    ns1:competencyDescription "Conocimiento adecuado de la tecnología de explotación de recursos minerales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000125/2025-26/CE13> a ns1:Competency ;
    ns1:competencyCode "CE13" ;
    ns1:competencyDescription "Capacidad para planificar, diseñar y gestionar instalaciones de tratamientos de recursos minerales, plantas metalúrgicas, siderúrgicas e industrias de materiales de construcción, incluyendo materiales metálicos, cerámicos, sinterizados, refractarios y otros."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000125/2025-26/CE14> a ns1:Competency ;
    ns1:competencyCode "CE14" ;
    ns1:competencyDescription "Realización, presentación y defensa de un trabajo realizado individualmente consistente en un proyecto integral de ingeniería de minas de naturaleza profesional en el que se sinteticen e integren las competencias adquiridas en las enseñanzas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000125/2025-26/CG01> a ns1:Competency ;
    ns1:competencyCode "CG01" ;
    ns1:competencyDescription "Capacitación científico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000125/2025-26/CG02> a ns1:Competency ;
    ns1:competencyCode "CG02" ;
    ns1:competencyDescription "Comprensión de los múltiples condicionamientos de carácter técnicos, legal y de la propiedad que se plantean en el proyectos de una planta o instalación, y capacidad para establecer diferentes alternativas válidas, elegir la óptima y plasmarla adecuadamente, previendo los problemas de su desarrollo, y empleando los métodos y tecnologías más adecuadas, tanto tradicionales como innovadores, con la finalidad de conseguir la mayor eficacia y favorecer el progreso y un desarrollo de la sociedad sostenible y respetuoso con el medio ambiente"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000125/2025-26/CG04> a ns1:Competency ;
    ns1:competencyCode "CG04" ;
    ns1:competencyDescription "Conocimiento de la profesión de Ingeniero de Minas y de las actividades que se puedan realizar en el ámbito de la misma"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000125/2025-26/CG06> a ns1:Competency ;
    ns1:competencyCode "CG06" ;
    ns1:competencyDescription "Capacidad para la exploración, investigación, modelización y evaluación de yacimientos de recursos geológicos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000125/2025-26/CG07> a ns1:Competency ;
    ns1:competencyCode "CG07" ;
    ns1:competencyDescription "Capacidad para planificar, proyectar, inspeccionar y dirigir explotaciones de yacimientos y otros recursos geológicos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000125/2025-26/CT04> a ns1:Competency ;
    ns1:competencyCode "CT04" ;
    ns1:competencyDescription "Capacidad para trabajar de forma efectiva como individuo, organizando y planificando su propio trabajo, de forma independiente o como miembro de un equipo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000125/2025-26/CT05> a ns1:Competency ;
    ns1:competencyCode "CT05" ;
    ns1:competencyDescription "Capacidad para gestionar la información, identificando las fuentes necesarias, los principales tipos de documentos técnicos y científicos, de una manera adecuada y eficiente"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000125/2025-26/CT06> a ns1:Competency ;
    ns1:competencyCode "CT06" ;
    ns1:competencyDescription "Capacidad para emitir juicios sobre implicaciones económicas, administrativas, sociales, éticas y medioambientales ligadas a la aplicación de sus conocimientos"@es .

