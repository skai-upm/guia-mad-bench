<https://guia-kg.skai.etsisi.upm.es/resource/135004537/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Introducción"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004537/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Los hongos en el funcionamiento de los ecosistemas forestales Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004537/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "4. Regulación de la Recolección, Comercialización y Micoturismo Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004537/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Los hongos silvestres en la nutrición y salud de los árboles, y en la estabilidad de los bosques Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004537/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "2. Gestión sostenible del recurso micológico. Micoselvicultura"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004537/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "2.1. Diagnóstico. Principales Hábitats de hongos silvestres comestibles. Inventario. Estimación de la Producción Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004537/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "2.2. Micoselvicultura. Factores para la producción y diversidad micológica. Prácticas de Gestión Micoselvicola Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004537/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "3. El cultivo de los hongos silvestres. Aplicaciones a la gestión forestal y ambiental"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004537/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "3.1. El cultivo de hongos silvestres. Síntesis de ectomicorrizas: tipos de inóculo, técnicas de micorrización Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004537/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "3.2. Truficultura. Perspectivas en otros hongos ectomicorrícicos comestibles Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004537/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "3.3. Aplicaciones de los hongos silvestres. Micorremediación. Micocontrol. \"Mycoforestry\" Sin subniveles"@es .

