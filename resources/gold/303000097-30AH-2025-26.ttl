    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000097/2025-26/didactic_resource/3> a ns1:DidacticResource ;
    ns1:bibliographyDescription "Cambridge University Press, 1995."@es ;
    ns1:bibliographyTitle "A.Katok and B.Hasselblatt, \"Introduction to the Modern Theory of Dynamical Systems\", Encyclopedia Math.Appl., vol. 54,"@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000097/2025-26/didactic_resource/4> a ns1:DidacticResource ;
    ns1:bibliographyTitle "J. Moser and E.J. Zehnder, \"Notes on Dynamical Systems\", Courant Lect. Notes Math., vol.12, copublished by AMS and the Courant Institute of Mathematical Sciences, 2005."@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/303000097/2025-26/didactic_resource/5> a ns1:DidacticResource ;
    ns1:bibliographyTitle "C. Robinson, \"Dynamical Systems: Stability, Symbolic Dynamics and Chaos\", Advanced Studies in Mathematics, CRC Press (1995)."@es ;
