    ns1:learningResultCode "RA51" ;
    ns1:learningResultDescription "RA2. Explica, conoce y tiene conocimientos adecuados de los tratamientos de potabilización, desalación y depuración de aguas, recogida y tratamiento de residuos, así como, diseñar, planificar, gestionar, mantener, conservar y explotar las infraestructuras desde la perspectiva ambiental y sostenible."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000420/2025-26/RA52> a ns1:LearningResult ;
    ns1:learningResultCode "RA52" ;
