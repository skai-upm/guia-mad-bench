<https://guia-kg.skai.etsisi.upm.es/resource/43000420/2025-26/RA50> a ns1:LearningResult ;
    ns1:learningResultCode "RA50" ;
    ns1:learningResultDescription "RA1 Explica, conoce y tiene capacidad para planificar y gestionar recursos hidráulicos y energéticos, incluyendo la gestión integral del ciclo del agua."@es .

