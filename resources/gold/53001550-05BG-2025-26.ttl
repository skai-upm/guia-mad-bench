    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001550/2025-26/didactic_resource/3> a ns1:DidacticResource ;
    ns1:bibliographyTitle "Reconfigurable System Design and Verification. Hsiung, Santambrogio and Huang."@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001550/2025-26/didactic_resource/4> a ns1:DidacticResource ;
    ns1:bibliographyTitle "Dynamically Reconfigurable Systems - Architectures, Design Methods and Applications. Platzner, Teich and Wehn"@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001550/2025-26/didactic_resource/5> a ns1:DidacticResource ;
    ns1:bibliographyTitle "Reconfigurable Computing - Accelerating Computation with Field-Programmable Gate Arrays. Gokhale and Graham."@es ;
    ns1:bibliographyType "Bibliografía"@es .

