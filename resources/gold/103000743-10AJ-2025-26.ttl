<https://guia-kg.skai.etsisi.upm.es/resource/103000743/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/103000743/2025-26/C3>,
        <https://guia-kg.skai.etsisi.upm.es/resource/103000743/2025-26/C4>,
