    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. INTRODUCCIÓN A LAS VIBRACIONES."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005103/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Generalidades sobre sistemas vibratorios Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005103/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "2.3. Sistemas de un grado de libertad. Problema general. Respuesta libre. Respuesta forzada con condiciones iniciales nulas Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005103/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "2.4. Respuesta forzada de un sistema de un grado de libertad cuando la excitación puede expresarse en serie o integral de Fourier Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005103/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "2.5. Respuesta forzada en el dominio del tiempo. Aplicación de la integral de Duhamel a las funciones de memoria y de instalación Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005103/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "3. SISTEMAS DE MÚLTIPLES GRADOS DE LIBERTAD"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005103/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "3.1. Sistemas lineales de g-grados de libertad Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005103/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "3.2. Vibraciones libres de sistemas conservativos Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005103/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "3.3. Vibraciones forzadas de sistemas conservativos Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005103/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "3.4. Resolución numérica de sistemas de varios grados de libertad Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005103/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "3.5. Amortiguamiento estructural. Ciclo histerético para sistemas de un grado de libertad Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005103/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "3.6. Amortiguamiento viscoso en sistemas de varios grados de libertad. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005103/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Ecuaciones de Lagrange para sistemas holonómicos Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005103/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "1.3. Pequeñas vibraciones alrededor de una posición de equilibrio estable Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005103/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "1.4. Linealización del problema Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005103/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "1.5. Sistemas discretos y sistemas continuos Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005103/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "1.6. Métodos aproximados. Vibraciones autoexcitadas y no lineales. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005103/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "2. SISTEMAS DE UN GRADO DE LIBERTAD"@es .

