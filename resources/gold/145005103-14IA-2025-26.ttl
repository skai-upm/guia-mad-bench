    ns1:learningResultCode "RA251" ;
    ns1:learningResultDescription "Conocimiento, comprensión, aplicación, análisis y síntesis de los métodos aplicados al estudio de la respuesta de aeronaves frente a cargas no estacionarias."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005103/2025-26/RA252> a ns1:LearningResult ;
    ns1:learningResultCode "RA252" ;
    ns1:learningResultDescription "Conocimiento, comprensión, aplicación, análisis y síntesis de los sistemas vibratorios de un grado de libertad, de múltiples grados de libertad y continuos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005103/2025-26/RA253> a ns1:LearningResult ;
    ns1:learningResultCode "RA253" ;
    ns1:learningResultDescription "Conocimiento, comprensión, aplicación, análisis y síntesis de los métodos aproximados de cálculo para los sistemas continuos."@es .

