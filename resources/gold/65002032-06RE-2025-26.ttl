<https://guia-kg.skai.etsisi.upm.es/resource/65002032/2025-26/syllabus/26> a ns1:SyllabusItem ;
    ns1:itemIndex 26 ;
    ns1:syllabusDescription "5.3. Protección frente a contactos eléctricos. Regímenes de neutro de las instalaciones y dispositivos de corte de los defectos a tierra. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65002032/2025-26/syllabus/27> a ns1:SyllabusItem ;
    ns1:itemIndex 27 ;
    ns1:syllabusDescription "5.4. Normativa relativa al tema. Sin subniveles"@es .

