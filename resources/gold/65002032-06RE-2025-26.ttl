    ns1:itemIndex 16 ;
    ns1:syllabusDescription "4. APARAMENTA DE MANIOBRA Y PROTECCIÓN: CARACTERÍSTICAS Y ESPECIFICACIONES"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65002032/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "4.1. Introducción. Funciones y mecanismos de la aparamenta. Extinción del arco eléctrico. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65002032/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "4.2. Funcionamiento, tipos y características nominales de la aparamenta industrial de maniobra y protección: seccionadores, interruptores, contactores, fusibles y pararrayos. Criterios de selección de aparamenta. Circuitos de mando. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65002032/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "4.3. Combinación de aparamenta. Transformadores de protección. Subestaciones, configuraciones. Celdas de protección. Transformadores de medida. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65002032/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Estructura y configuraciones típicas de las redes de distribución. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65002032/2025-26/syllabus/20> a ns1:SyllabusItem ;
    ns1:itemIndex 20 ;
    ns1:syllabusDescription "4.4. Protecciones. Perturbaciones en la redes. Funcionamiento y tipos de relés. Relés de sobrecorriente. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65002032/2025-26/syllabus/21> a ns1:SyllabusItem ;
    ns1:itemIndex 21 ;
    ns1:syllabusDescription "4.5. Coordinación y combinación de protecciones. Esquemas típicos de protección de los elementos de las redes. Sin subniveles"@es .

