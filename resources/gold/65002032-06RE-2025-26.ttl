    schema:description """Cálculo y concepción del proyecto eléctrico en baja tensión.
Introducción al estudio de las máquinas eléctricas. Análisis y aplicaciones del motor asíncrono."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/vanesa.valino%40upm.es> ;
