<https://guia-kg.skai.etsisi.upm.es/resource/95000013/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Introducción."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000013/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Revisión del algebra vectorial: Sistemas de coordenadas Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000013/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "3.1. Ecuaciones de la Electrostática. Campo eléctrico en un conductor Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000013/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "3.2. Ley de Gauss. Campo de una carga puntual. Superposición y expresión del campo por aportaciones infinitesimales. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000013/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "3.3. Distribuciones con simetría esférica, cilíndrica o plana. Esfera, línea de carga indefinida y hoja de carga. Ejercicios Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000013/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "3.4. Definición del potencial: Sentido físico y continuidad. Ecuaciones de Poisson y Laplace. Condiciones de contorno para unicidad del potencial Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000013/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "3.5. Integración de la ecuación de Poisson para una carga puntual. Potencial de una carga puntual. Superposición y expresión del potencial por aportaciones infinitesimales. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000013/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "3.6. Campo y potencial de una distribución esférica de carga por el método de Gauss y la integración de Poisson. Potencial de un disco de carga uniforme en el eje, de una línea de carga uniforme y de distribuciones bidimensionales. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000013/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "3.7. Teorema de la media. Potencial y campo de distribuciones multipolares. Dipolo. Desarrollo multipolar del potencial Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000013/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "3.8. Método de las imágenes. Ejercicios Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000013/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "3.9. Sistemas electrostáticos de conductores. Coeficientes de Capacidad; Teorema de Reciprocidad. Capacidad y apantallamiento. Condensador. Ejercicios Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000013/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "3.10. Energía electrostática. Energía de un sistema electrostático de conductores. Energía de formación e interacción. Acciones mecánicas: Fuerzas y Pares. Ejercicios Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000013/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Gradiente, divergencia y rotacional. Teoremas de Gauss y Stokes. El operador Nabla. Ejercicios Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000013/2025-26/syllabus/20> a ns1:SyllabusItem ;
    ns1:itemIndex 20 ;
    ns1:syllabusDescription "4. Corrientes Estacionarias"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000013/2025-26/syllabus/21> a ns1:SyllabusItem ;
    ns1:itemIndex 21 ;
    ns1:syllabusDescription "4.1. Ecuaciones del Campo Estacionario. Propiedades de las Corrientes Estacionarias. Generadores. Fuerza electromotriz. Conductor Perfecto. Condiciones de contorno en interfaces Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000013/2025-26/syllabus/22> a ns1:SyllabusItem ;
    ns1:itemIndex 22 ;
    ns1:syllabusDescription "4.2. Resistencia. Ejemplos. Dualidad R/C. Ejercicios Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000013/2025-26/syllabus/23> a ns1:SyllabusItem ;
    ns1:itemIndex 23 ;
    ns1:syllabusDescription "5. Campo magnético estacionario"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000013/2025-26/syllabus/24> a ns1:SyllabusItem ;
    ns1:itemIndex 24 ;
    ns1:syllabusDescription "5.1. Ecuaciones de la Magnetostática. Definición del Potencial vector magnético. Solución del Potencial vector magnético. Ley de Biott y Savart. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000013/2025-26/syllabus/25> a ns1:SyllabusItem ;
    ns1:itemIndex 25 ;
    ns1:syllabusDescription "5.2. Ejercicios. Campo de la espira circular. Solenoide cilíndrico finito Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000013/2025-26/syllabus/26> a ns1:SyllabusItem ;
    ns1:itemIndex 26 ;
    ns1:syllabusDescription "5.3. Ley de Ampère: Aplicación a la línea de corriente indefinida, a la hoja de corriente, al cable coaxial y al solenoide indefinido Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000013/2025-26/syllabus/27> a ns1:SyllabusItem ;
    ns1:itemIndex 27 ;
    ns1:syllabusDescription "5.4. Potencial vector en puntos alejados. Momento magnético. Campo magnético en puntos alejados. Momento magnético de espiras planas Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000013/2025-26/syllabus/28> a ns1:SyllabusItem ;
    ns1:itemIndex 28 ;
    ns1:syllabusDescription "5.5. Energía del campo magnetostático. Energía en función de las corrientes y Energía de la distribución de corriente filiforme. Energía de formación e interacción. Sistemas de corrientes filiformes y coeficientes de inducción Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000013/2025-26/syllabus/29> a ns1:SyllabusItem ;
    ns1:itemIndex 29 ;
    ns1:syllabusDescription "5.6. Coeficientes de inducción de corrientes no filiformes. Autoinducción interna y externa de una distribución. Fuerzas magnéticas. Ejemplos Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000013/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "2. Ecuaciones Generales del Electromagnetismo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000013/2025-26/syllabus/30> a ns1:SyllabusItem ;
    ns1:itemIndex 30 ;
    ns1:syllabusDescription "6. Electrodinámica y variación temporal lenta"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000013/2025-26/syllabus/31> a ns1:SyllabusItem ;
    ns1:itemIndex 31 ;
    ns1:syllabusDescription "6.1. Ecuaciones de la electrodinámica. Potenciales electrodinámicos. Potencial de una corriente puntual. Onda progresiva y regresiva. Retardo Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000013/2025-26/syllabus/32> a ns1:SyllabusItem ;
    ns1:itemIndex 32 ;
    ns1:syllabusDescription "6.2. Variación temporal lenta.Ley de Faraday. Lemas de Kirchoff. Ejercicios Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000013/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "2.1. Densidad de carga. Densidad de corriente. Ecuación de continuidad Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000013/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "2.2. Ecuaciones de Maxwell. Ecuaciones de Maxwell en forma integral Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000013/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "2.3. Caracterización de medios materiales. Ley de Ohm. Constante de relajación. Unidades y dimensiones Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000013/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "2.4. Definición de los campos E y B. Energía. Condiciones de salto. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000013/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "2.5. Ejercicios Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000013/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "3. Campo Electrostático"@es .

