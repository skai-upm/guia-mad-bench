    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/55000034/2025-26/eventSchedule> ;
    schema:description "La Mecánica de Fluidos II es una asignatura de carácter básico que tiene como objetivo fundamental la aplicación de los principios generales de conservación de masa, cantidad de movimiento y energía en medios fluidos a problemas de interés en ingeniería."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/javier.garciag%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/emilio.migoya%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/javier.garciag%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/juanluis.prieto%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/le.munoz%40upm.es> ;
    schema:name "Mecanica de Fluidos II"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000034/2025-26/CE26C> a ns1:Competency ;
    ns1:competencyCode "CE26C" ;
    ns1:competencyDescription "Conocimiento aplicado de los fundamentos de los sistemas y máquinas fluidomecánicas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000034/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Conocer y aplicar conocimientos de ciencias y tecnologías básicas a la práctica de la Ingeniería Industrial."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000034/2025-26/CG2> a ns1:Competency ;
    ns1:competencyCode "CG2" ;
    ns1:competencyDescription "Poseer capacidad para diseñar, desarrollar, implementar, gestionar y mejorar productos, sistemas y procesos en los distintos ámbitos industriales, usando técnicas analíticas, computacionales o experimentales apropiadas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000034/2025-26/RA429> a ns1:LearningResult ;
    ns1:learningResultCode "RA429" ;
    ns1:learningResultDescription "Conocimientos de los principios básicos de la mecánica de fluidos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000034/2025-26/RA430> a ns1:LearningResult ;
    ns1:learningResultCode "RA430" ;
    ns1:learningResultDescription "Capacidad para caracterizar y comprender el comportamiento de los fluidos en distintas situaciones de interés para el ingeniero industrial"@es .

