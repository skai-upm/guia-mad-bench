    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/53002001/2025-26/eventSchedule> ;
    schema:description """Objetivos generales de la asignatura
El objetivo de la asignatura es introducir al alumno en los conceptos de eficiencia energética e identificar los factores que influyen en la eficiencia energética en la edificación e industria, así como las correspondientes actuaciones de mejora."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/natalia.fonseca%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/daniel.serrano.jimenez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/david.nsimavilla%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/natalia.fonseca%40upm.es> ;
    schema:name "Eficiencia Energética"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002001/2025-26/CB8> a ns1:Competency ;
    ns1:competencyCode "CB8" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de integrar conocimientos y enfrentarse a la complejidad de formular juicios a partir de una información que, siendo incompleta o limitada, incluya reflexiones sobre las responsabilidades sociales y éticas vinculadas a la aplicación de sus conocimientos y juicios/ Students are capable of integrating knowledge and making complex decisions, which, although based on incomplete or limited information, require reflection on social and ethical responsibilities linked to the application of their knowledge and opinions."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002001/2025-26/CB9> a ns1:Competency ;
    ns1:competencyCode "CB9" ;
    ns1:competencyDescription "Que los estudiantes sepan comunicar sus conclusiones y los conocimientos y razones últimas que las sustentan a públicos especializados y no especializados de un modo claro y sin ambigüedades/ Students are capable of clearly and unambiguously communicating their conclusions, and the underlying knowledge and rationale to specialist and non"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002001/2025-26/CE1> a ns1:Competency ;
    ns1:competencyCode "CE1" ;
    ns1:competencyDescription "Ser capaz de aplicar conocimientos y capacidades a estudiar, analizar y auditar programas de optimización energética en los diferentes sectores industriales, residenciales, domésticos, plantas de potencia y a la industria térmica y de fluidos en general, en los ámbitos de la eficiencia, la diversificación y la reducción de su impacto en el medio ambiente./ Application of knowledge and skills to study, analyze and audit energy optimization programs in different industrial, residential, domestic, power plant sectors and the thermal and fluid industry in general, in the fields of efficiency, diversification and reducing its impact on the environment."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002001/2025-26/CE18> a ns1:Competency ;
    ns1:competencyCode "CE18" ;
    ns1:competencyDescription "Entender la optimización de costes en una empresa: coste marginal, coste medio, coste hundido, coste de oportunidad, aplicados al sector de la energía. Analizar costes en el sector de la energía./ Understand the fundamental concepts of cost optimization in a company: marginal cost, average cost, sunk cost, opportunity cost, applied to the energy sector. Analyze costs in the energy sector."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002001/2025-26/CE2> a ns1:Competency ;
    ns1:competencyCode "CE2" ;
    ns1:competencyDescription "Analizar y establecer criterios de mejora energética y económica en instalaciones de generación y de consumo, incluyendo el sector transportes, conducente al diseño de alternativas más eficientes y con menor impacto ambiental./ Analyze and establish criteria for energy and economic improvement in generation and consumption facilities, including the transport sector, leading to the design of more efficient alternatives with less environmental impact"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002001/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Aplicar conocimientos de ciencias y tecnologías avanzadas a la práctica profesional o investigadora de la Ingeniería Energética./ Apply knowledge of advanced science and technology to the professional or research practice of Energy Engineering."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002001/2025-26/CG5> a ns1:Competency ;
    ns1:competencyCode "CG5" ;
    ns1:competencyDescription "Comprender el impacto de la Ingeniería Energética en el medio ambiente, el desarrollo sostenible de la sociedad y la importancia de trabajar en un entorno profesional y responsable./ Understand the impact of Energy Engineering on the environment, the sustainable development of society and the importance of working in a professional and responsible environment."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002001/2025-26/CT1> a ns1:Competency ;
    ns1:competencyCode "CT1" ;
    ns1:competencyDescription "Aplica. Habilidad para aplicar conocimientos científicos, matemáticos y tecnológicos en sistemas relacionados con la práctica de la ingeniería./ Apply. Ability to apply scientific, mathematical and technological knowledge in systems related to the practice of engineering."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002001/2025-26/CT10> a ns1:Competency ;
    ns1:competencyCode "CT10" ;
    ns1:competencyDescription "Conoce. Conocimiento de los temas contemporáneos./ Knowledge of contemporary issues."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002001/2025-26/CT14> a ns1:Competency ;
    ns1:competencyCode "CT14" ;
    ns1:competencyDescription "Idea. Creatividad./ Idea. Creativity."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002001/2025-26/CT3> a ns1:Competency ;
    ns1:competencyCode "CT3" ;
    ns1:competencyDescription "Diseña. Habilidad para diseñar un sistema, componente o proceso que alcance los requisitos deseados teniendo en cuenta restricciones realistas tales como las económicas, medioambientales, sociales, políticas, éticas, de salud y seguridad, de fabricación y de sostenibilidad./ Design. Ability to design a system, component or process that meets the desired requirements taking into account realistic constraints such as economic, environmental, social, political, ethical, health and safety, manufacturing and sustainability."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002001/2025-26/CT4> a ns1:Competency ;
    ns1:competencyCode "CT4" ;
    ns1:competencyDescription "Trabaja en equipo. Habilidad para trabajar en equipos multidisciplinares./ Team work. Ability to work in multidisciplinary teams."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002001/2025-26/CT5> a ns1:Competency ;
    ns1:competencyCode "CT5" ;
    ns1:competencyDescription "Resuelve. Habilidad para identificar, formular y resolver problemas de ingeniería./ Solve. Ability to identify, formulate and solve engineering problems."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002001/2025-26/RA214> a ns1:LearningResult ;
    ns1:learningResultCode "RA214" ;
    ns1:learningResultDescription "Conocer el marco normativo internacional sobre eficiencia energética en la edificación, industria y transporte."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002001/2025-26/RA215> a ns1:LearningResult ;
    ns1:learningResultCode "RA215" ;
    ns1:learningResultDescription "Calcular los factores de eficiencia energética en edificación, industria y transporte."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002001/2025-26/RA216> a ns1:LearningResult ;
    ns1:learningResultCode "RA216" ;
    ns1:learningResultDescription "Identificar los factores que influyen sobre la eficiencia energética en edificación, industria y transporte."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002001/2025-26/RA217> a ns1:LearningResult ;
    ns1:learningResultCode "RA217" ;
    ns1:learningResultDescription "Calcular el ahorro (energía final, energía primaria, de gases de efecto invernadero, etc.) debido a la implantación de medidas de mejora de eficiencia energética en edificación, industria y transporte."@es .

