<https://guia-kg.skai.etsisi.upm.es/resource/105000053/2025-26/Ce%2012/16> a ns1:Competency ;
    ns1:competencyCode "Ce 12/16" ;
    ns1:competencyDescription "Conocer los campos de aplicación de la informática, y tener una apreciación de la necesidad de poseer unos conocimientos técnicos profundos en ciertas áreas de aplicación; apreciación del grado de esta necesidad en, por lo menos, una situación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000053/2025-26/Ce%2013/18> a ns1:Competency ;
    ns1:competencyCode "Ce 13/18" ;
    ns1:competencyDescription "Comprender lo que pueden y no pueden conseguir las tecnologías actuales, y las limitaciones de la informática, que implica distinguir entre lo que, inherentemente, la informática no es capaz de hacer y lo que puede lograrse a través de la ciencia y la tecnología futuras."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000053/2025-26/Ce%2014/15> a ns1:Competency ;
    ns1:competencyCode "Ce 14/15" ;
    ns1:competencyDescription "Conocer el software, el hardware y las aplicaciones existentes en el mercado, así como el uso de sus elementos, y capacidad para familiarizarse con nuevas aplicaciones informáticas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000053/2025-26/Ce%2017> a ns1:Competency ;
    ns1:competencyCode "Ce 17" ;
    ns1:competencyDescription "Conocer los temas informáticos avanzados de modo que permita a los alumnos vislumbrar y entender las fronteras de la disciplina, por medio de la inclusión de experiencias de aprendizaje que dirigen a los alumnos desde los temas elementales a los temas avanzados o los temas de los que se nutren los novísimos desarrollos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000053/2025-26/Ce%2019/20> a ns1:Competency ;
    ns1:competencyCode "Ce 19/20" ;
    ns1:competencyDescription "Conocimiento de los tipos apropiados de soluciones, y comprensión de la complejidad de los problemas informáticos y la viabilidad de su solución."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000053/2025-26/Ce%2044> a ns1:Competency ;
    ns1:competencyCode "Ce 44" ;
    ns1:competencyDescription "Conocimiento de tecnologías punteras relevantes y su aplicación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000053/2025-26/RA277> a ns1:LearningResult ;
    ns1:learningResultCode "RA277" ;
    ns1:learningResultDescription "Dado un problema real elegir la tecnología informática existente en el mercado mas apropiada para su solución y diseñar su desarrollo e integración, analizando la viabilidad de su solución, lo que se puede y no se puede conseguir a través del estado actual de desarrollo de la tecnología usada, y lo que se espera que avance en el futuro."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000053/2025-26/RA278> a ns1:LearningResult ;
    ns1:learningResultCode "RA278" ;
    ns1:learningResultDescription "Desarrollar la solución matemática y algorítmica mas apropiada a un problema informático que requiera un tratamiento especialmente complejo, analizando y exponiendo su viabilidad."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000053/2025-26/RA280> a ns1:LearningResult ;
