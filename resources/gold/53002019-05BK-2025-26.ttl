<https://guia-kg.skai.etsisi.upm.es/resource/53002019/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Introducción a la biomasa energética. Fuentes de biomasa. Estimación del recurso biomasa. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002019/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "2. Caracterización energética de la biomasa. Logística de la biomasa. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002019/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "3. Procesos de transformación energética de la biomasa y sus aplicaciones. Sin subniveles"@es .

