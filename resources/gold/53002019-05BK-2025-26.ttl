    ns1:itemIndex 3 ;
    ns1:syllabusDescription "4. Transformación energética de la biomasa. Aspectos económicos. Estudio técnico-económico del proceso de valorización energética de la biomasa. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002019/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "5. Aplicación de los biocombustibles al transporte. Sin subniveles"@es .

