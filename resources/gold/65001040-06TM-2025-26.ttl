    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/65001040/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/65001040/2025-26/didactic_resource/2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/65001040/2025-26/didactic_resource/3>,
        <https://guia-kg.skai.etsisi.upm.es/resource/65001040/2025-26/didactic_resource/4>,
        <https://guia-kg.skai.etsisi.upm.es/resource/65001040/2025-26/didactic_resource/5>,
        <https://guia-kg.skai.etsisi.upm.es/resource/65001040/2025-26/didactic_resource/6> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/65001040/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/65001040/2025-26/RA195>,
        <https://guia-kg.skai.etsisi.upm.es/resource/65001040/2025-26/RA196>,
        <https://guia-kg.skai.etsisi.upm.es/resource/65001040/2025-26/RA197>,
        <https://guia-kg.skai.etsisi.upm.es/resource/65001040/2025-26/RA198>,
        <https://guia-kg.skai.etsisi.upm.es/resource/65001040/2025-26/RA199>,
        <https://guia-kg.skai.etsisi.upm.es/resource/65001040/2025-26/RA200> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/65001040/2025-26/syllabus> ;
    ns1:inpersonHours "50 horas (42.7%)"@es ;
    ns1:numberOfCredits 4.5 ;
    ns1:otherInformation """La asignatura se relaciona con el ODS 7 y el ODS 9.
REFERENCIA // INDICADOR DE LOGRO RELACIONADO CON LOS RA:
IN_1.- Conocer la definición de minerales y rocas, la morfología cristalina y los fundamentos cristaloquímicos- RA15-RA196
IN_2.- Conocer los conceptos básicos de clasificación mineralógica- RA15-RA196
IN_3.- Conocer e identificar los principales minerales y rocas de visu o con técnicas sencillas- RA16-RA200
IN_4.- Conocer la composición y aplicaciones de los principales grupos de rocas- RA17-RA197
IN_5.- Conocer y aplicar las principales técnicas analíticas para identificación de minerales y rocas- RA17-RA197
IN_6.- Conocer los usos y procesos de obtención de metales a partir de sus minerales- RA17-RA197
IN_7.- Conocer los usos y procesos de obtención de materias primas para la industria química para la fabricación
de aislantes, refractarios, productos cerámicos, abrasivos, lubricantes, fertilizantes, sales y materiales de
construcción- RA19-RA199
IN_8.- Conocer las principales materias primas energéticas- RA20-RA-195
IN_9.- Conocer la distribución de los recursos minerales en el mundo- RA6
IN_10.- Conocer la distribución de los recursos minerales en España- RA15-RA196
IN_11.- Valorar razonadamente el futuro de los recursos minerales para la industria y la metalurgia- RA18-RA198"""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "50 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/65001040/2025-26/eventSchedule> ;
    schema:description """Esta asignatura trata sobre los recursos geológicos en sentido amplio, de forma preferente los minerales y rocas utilizados en la industria, bien como menas o como minerales y rocas industriales.
Se estudiarán sus características, origen y forma de prospección, así como sus aplicaciones en todas las ramas de la industria."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/jorgeluis.costafreda%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/jorgeluis.costafreda%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/joseluis.parra%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/leticia.presa.madrigal%40upm.es> ;
    schema:name "Geologia de Materiales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001040/2025-26/CG%201> a ns1:Competency ;
    ns1:competencyCode "CG 1" ;
    ns1:competencyDescription "Conocer y aplicar conocimientos de ciencias y tecnologías básicas a la práctica de la Tecnología Minera."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001040/2025-26/CG%2010> a ns1:Competency ;
    ns1:competencyCode "CG 10" ;
    ns1:competencyDescription "Creatividad."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001040/2025-26/CG%202> a ns1:Competency ;
    ns1:competencyCode "CG 2" ;
    ns1:competencyDescription "Poseer capacidad para diseñar, analizar, calcular, proyectar, construir, mantener, conservar, explotar, desarrollar, implementar, gestionar y mejorar productos, sistemas y procesos en los distintos ámbitos de las Tecnologías Mineras, usando técnicas analíticas, computacionales o experimentales apropiadas, incluyendo la función de asesoría en estos campos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001040/2025-26/CG%203> a ns1:Competency ;
    ns1:competencyCode "CG 3" ;
    ns1:competencyDescription "Aplicar los conocimientos adquiridos para identificar, formular y resolver problemas dentro de contextos amplios y multidisciplinarios, siendo capaces de integrar conocimientos, trabajando en equipos multidisciplinares."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001040/2025-26/CG%206> a ns1:Competency ;
    ns1:competencyCode "CG 6" ;
    ns1:competencyDescription "Poseer habilidades de aprendizaje que permitan continuar estudiando a lo largo de la vida para su adecuado desarrollo profesional"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001040/2025-26/F24> a ns1:Competency ;
    ns1:competencyCode "F24" ;
    ns1:competencyDescription "Geología general y de detalle."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001040/2025-26/F26> a ns1:Competency ;
    ns1:competencyCode "F26" ;
    ns1:competencyDescription "Ensayos mineralógicos, petrográficos y geotécnicos. Técnicas de muestreo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001040/2025-26/F38> a ns1:Competency ;
    ns1:competencyCode "F38" ;
    ns1:competencyDescription "Composición, estructuras, propiedad y aplicaciones de los Materiales Geológicos Metalúrgicos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001040/2025-26/RA195> a ns1:LearningResult ;
    ns1:learningResultCode "RA195" ;
    ns1:learningResultDescription "Conocer la composición, estructura, propiedades y aplicaciones de los Materiales Geológicos Metalúrgicos y otros."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001040/2025-26/RA196> a ns1:LearningResult ;
    ns1:learningResultCode "RA196" ;
    ns1:learningResultDescription "Aplicar los conocimientos adquiridos en la asignatura Geología a los principales minerales y rocas utilizados en la industria."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001040/2025-26/RA197> a ns1:LearningResult ;
    ns1:learningResultCode "RA197" ;
    ns1:learningResultDescription "Relacionar las propiedades de minerales y rocas con su empleo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001040/2025-26/RA198> a ns1:LearningResult ;
    ns1:learningResultCode "RA198" ;
    ns1:learningResultDescription "Conocer materiales naturales o sintéticos alternativos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001040/2025-26/RA199> a ns1:LearningResult ;
    ns1:learningResultCode "RA199" ;
    ns1:learningResultDescription "Aplicar los datos teóricos de composición y estructura, en casos concretos, a la posibilidad de explotación de estos materiales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001040/2025-26/RA200> a ns1:LearningResult ;
    ns1:learningResultCode "RA200" ;
    ns1:learningResultDescription "Identificar mediante los sentidos y con técnicas sencillas los principales minerales y rocas."@es .

