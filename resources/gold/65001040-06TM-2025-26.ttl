    ns1:bibliographyTitle "Los alumnos dispondrán de una serie de artículos publicados en revistas de prestigio que aluden el proceso de investigación, caracterización, normalización y aplicaciones de los recursos geológicos."@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001040/2025-26/didactic_resource/3> a ns1:DidacticResource ;
