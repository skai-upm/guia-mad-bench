    schema:name "Fisheries And Aquaculture"@en,
        "Pesca y Acuicultura"@es ;
    schema:numberOfCredits 3.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/135004548/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/135004548/2025-26/CB02>,
        <https://guia-kg.skai.etsisi.upm.es/resource/135004548/2025-26/CE%201.01> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/135004548/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/135004548/2025-26/didactic_resource/2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/135004548/2025-26/didactic_resource/3> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/135004548/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/135004548/2025-26/RA1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/135004548/2025-26/RA107>,
        <https://guia-kg.skai.etsisi.upm.es/resource/135004548/2025-26/RA117>,
        <https://guia-kg.skai.etsisi.upm.es/resource/135004548/2025-26/RA122>,
        <https://guia-kg.skai.etsisi.upm.es/resource/135004548/2025-26/RA157>,
        <https://guia-kg.skai.etsisi.upm.es/resource/135004548/2025-26/RA169>,
        <https://guia-kg.skai.etsisi.upm.es/resource/135004548/2025-26/RA177> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/135004548/2025-26/syllabus> ;
    ns1:inpersonHours "57 horas (70.4%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation ".LAS COMPETENCIAS Y LOS RESULTADOS DE APRENDIZAJE DE ESTA ASIGNATURA SON LOS ACORDES CON LA MEMORIA VERIFICA DEL TÍTULO"@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "57 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/135004548/2025-26/eventSchedule> ;
    schema:description """La asignatura trata de profundizar en el conocimiento de la gestión de la pesca deportiva y la acuicultura.
Se tendrá especial énfasis en las repoblaciones, tanto para el posible aumento de la oferta de la pesca deportiva, como la re introducción de especies desaparecidas, etc.
Se describirá el medio acuático en los aspectos básicos, relacionados con las poblaciones acuáticas, que se estén criando.
Se ayudará en la elección de emplazamientos adecuados.
Se describirán los principales elementos que componen una piscifactoría, y su dimensionamiento.
Se profundizará en los aspectos relacionados con la gestión de las producciones, marcaje y su transporte
Se darán los principios básicos de la ordenación de la pesca
Se explicaran las principales técnicas y modalidades de pesca en España"""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/fernando.torrent%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/ca.dove%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/fernando.torrent%40upm.es> ;
    schema:name "Pesca y Acuicultura"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004548/2025-26/CB02> a ns1:Competency ;
    ns1:competencyCode "CB02" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar sus conocimientos a su trabajo o vocación de una forma profesional y posean las competencias que suelen demostrarse por medio de la elaboración y defensa de argumentos y la resolución de problemas dentro de su área de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004548/2025-26/CE%201.01> a ns1:Competency ;
    ns1:competencyCode "CE 1.01" ;
    ns1:competencyDescription "Conocer los campos de aplicación de la Ingeniería del Medio Natural, y tener una apreciación de la necesidad de poseer unos conocimientos técnicos profundos en ciertas áreas de aplicación; apreciación del grado de esta necesidad en, por lo menos, una situación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004548/2025-26/RA1> a ns1:LearningResult ;
    ns1:learningResultCode "RA1" ;
    ns1:learningResultDescription "RA9"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004548/2025-26/RA107> a ns1:LearningResult ;
    ns1:learningResultCode "RA107" ;
    ns1:learningResultDescription "Comprender las relaciones entre los seres vivos y los factores ambientales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004548/2025-26/RA117> a ns1:LearningResult ;
    ns1:learningResultCode "RA117" ;
    ns1:learningResultDescription "Diseñar, dirigir, elaborar, implementar e interpretar proyectos y planes, así como para redactar informes técnicos, memorias de reconocimiento, valoraciones, peritajes y tasaciones."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004548/2025-26/RA122> a ns1:LearningResult ;
    ns1:learningResultCode "RA122" ;
    ns1:learningResultDescription "Estimar el hábitat potencial útil en un tramo de río para distintas especies piscícolas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004548/2025-26/RA157> a ns1:LearningResult ;
    ns1:learningResultCode "RA157" ;
    ns1:learningResultDescription "Capacidad para presentar en público y defender, con argumentos científicos y técnicos, trabajos de caracterización, diagnóstico, evaluación, planificación y gestión de especies protegidas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004548/2025-26/RA169> a ns1:LearningResult ;
    ns1:learningResultCode "RA169" ;
    ns1:learningResultDescription "Conocer la estructura, composición y funcionamiento de los ecosistemas acuáticos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004548/2025-26/RA177> a ns1:LearningResult ;
    ns1:learningResultCode "RA177" ;
    ns1:learningResultDescription "Planificar, ordenar y gestionar de forma sostenible las especies de fauna silvestre"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004548/2025-26/didactic_resource/1> a ns1:DidacticResource ;
    ns1:bibliographyDescription "Funcionamiento de la piscifactoría y todas las labores asociadas a ello."@es ;
    ns1:bibliographyTitle "Piscifactoría de la ETSI de Montes"@es ;
    ns1:bibliographyType "Equipamiento"@es .

