    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/615001051/2025-26/eventSchedule> ;
    schema:description """The subject of this course is the study of the different possibilities to encode information numerically, depending on the intended goal: conciseness (data compression), integrity (error detection codes), or security (cryptography).

The general learning objectives are:
a) Understanding the different mathematical concepts and tools underlying the models under consideration; and
b) Implementing these models, with special attention to efficiency and security issues."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/francisco.gomez%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/francisco.gomez%40upm.es> ;
    schema:name "Codificación de la Información"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615001051/2025-26/CB02> a ns1:Competency ;
    ns1:competencyCode "CB02" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar sus conocimientos a su trabajo o vocación de una forma profesional y posean las competencias que suelen demostrarse por medio de la elaboración y defensa de argumentos y la resolución de problemas dentro de su área de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615001051/2025-26/CT12> a ns1:Competency ;
    ns1:competencyCode "CT12" ;
    ns1:competencyDescription "Uso de tecnologías de la información y las comunicaciones : Usar las tecnologías de la información y las comunicaciones en el ámbito de la ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615001051/2025-26/RA141> a ns1:LearningResult ;
    ns1:learningResultCode "RA141" ;
    ns1:learningResultDescription "Es capaz de trabajar como miembro de un equipo con la finalidad de contribuir a desarrollar proyectos con pragmatismo y sentido de la responsabilidad, asumiendo compromisos y teniendo en cuenta los recursos disponibles. Se desenvuelve de modo que logra generar confianza y credibilidad en un grupo de colaboradores, además del compromiso para el logro de la visión corporativa a través de negociaciones y motivaciones, y no de manera coercitiva e individualista."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615001051/2025-26/RA156> a ns1:LearningResult ;
    ns1:learningResultCode "RA156" ;
    ns1:learningResultDescription "Conoce y aplica métodos y algoritmos matemáticos que se usarán en las implementaciones criptográficas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615001051/2025-26/RA205> a ns1:LearningResult ;
    ns1:learningResultCode "RA205" ;
    ns1:learningResultDescription "Analiza y aplica el algoritmo RSA para la firma digital."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615001051/2025-26/RA397> a ns1:LearningResult ;
    ns1:learningResultCode "RA397" ;
    ns1:learningResultDescription "Conoce y analiza la complejidad de un algoritmo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615001051/2025-26/RA408> a ns1:LearningResult ;
    ns1:learningResultCode "RA408" ;
    ns1:learningResultDescription "Distingue criptosistemas de clave pública y clave privada. Cifra y descifra utilizando los criptosistemas de traslación, afín y matricial afín"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615001051/2025-26/RA409> a ns1:LearningResult ;
    ns1:learningResultCode "RA409" ;
    ns1:learningResultDescription "Determina la complejidad computacional de algoritmos sencillos que involucren operaciones aritméticas elementales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615001051/2025-26/RA410> a ns1:LearningResult ;
    ns1:learningResultCode "RA410" ;
    ns1:learningResultDescription "Aplica los principales resultados de la teoría de números a la Criptología, cifrando y descifrando con los criptosistemas RSA y ElGamal"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615001051/2025-26/RA411> a ns1:LearningResult ;
    ns1:learningResultCode "RA411" ;
    ns1:learningResultDescription "Utiliza adecuadamente software para la resolución de problemas de codificación de la información, describiendo con precisión los protocolos utilizados"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615001051/2025-26/RA413> a ns1:LearningResult ;
    ns1:learningResultCode "RA413" ;
    ns1:learningResultDescription "Comprime ficheros, usando códigos compresores adecuados"@es .

