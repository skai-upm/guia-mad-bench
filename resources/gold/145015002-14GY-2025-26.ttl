        <https://guia-kg.skai.etsisi.upm.es/resource/rafael.alcocer%40upm.es> ;
    schema:name "Gestión Tránsito Aéreo (Atm)"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145015002/2025-26/CE06> a ns1:Competency ;
    ns1:competencyCode "CE06" ;
    ns1:competencyDescription "Capacidad para comprender la globalidad del sistema de navegación aérea y la complejidad del tráfico aéreo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145015002/2025-26/CE14> a ns1:Competency ;
    ns1:competencyCode "CE14" ;
    ns1:competencyDescription "Conocimiento adecuado de los elementos funcionales básicos del Sistema de Navegación y Circulación Aéreas y su impacto ambiental."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145015002/2025-26/CG05> a ns1:Competency ;
    ns1:competencyCode "CG05" ;
    ns1:competencyDescription "Capacidad para la búsqueda y utilización de la normativa y reglamentación relativa a su ámbito de actuación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145015002/2025-26/CT02> a ns1:Competency ;
    ns1:competencyCode "CT02" ;
    ns1:competencyDescription "Capacidad para el uso de la lengua inglesa"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145015002/2025-26/CT07> a ns1:Competency ;
    ns1:competencyCode "CT07" ;
    ns1:competencyDescription "Habilidad para la comunicación oral y escrita"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145015002/2025-26/CT08> a ns1:Competency ;
    ns1:competencyCode "CT08" ;
    ns1:competencyDescription "Capacidad de integrar el respeto al medio ambiente en el desarrollo de sus actividades"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145015002/2025-26/CT09> a ns1:Competency ;
    ns1:competencyCode "CT09" ;
    ns1:competencyDescription "Razonamiento crítico y capacidad de asociación que posibiliten el aprendizaje continuo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145015002/2025-26/RA18> a ns1:LearningResult ;
    ns1:learningResultCode "RA18" ;
    ns1:learningResultDescription "Es capaz de interpretar la normativa específica de aeropuertos y Navegación Aérea y el funcionamiento y la gestión del aeropuerto y el transporte aéreo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145015002/2025-26/RA21> a ns1:LearningResult ;
    ns1:learningResultCode "RA21" ;
    ns1:learningResultDescription "Interpreta las particularidades operativas en los servicios ATS en función de las características de las aeronaves."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145015002/2025-26/RA25> a ns1:LearningResult ;
    ns1:learningResultCode "RA25" ;
    ns1:learningResultDescription "Sabe aplicar los métodos y medios utilizados para el control de la Circulación Aérea."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145015002/2025-26/RA26> a ns1:LearningResult ;
    ns1:learningResultCode "RA26" ;
    ns1:learningResultDescription "Es capaz de explicar el funcionamiento y de los requisitos técnicos y operativos de los sistemas utilizados en la Gestión del Tránsito Aéreo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145015002/2025-26/RA27> a ns1:LearningResult ;
    ns1:learningResultCode "RA27" ;
    ns1:learningResultDescription "Es capaz de interpretar los criterios de diseño del espacio aéreo y de los procedimientos de vuelo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145015002/2025-26/RA64> a ns1:LearningResult ;
    ns1:learningResultCode "RA64" ;
    ns1:learningResultDescription "Es capaz de analizar y clasificar los elementos específicos en los proveedores de servicios de tránsito aérea."@es .

