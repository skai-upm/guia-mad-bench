<https://guia-kg.skai.etsisi.upm.es/resource/115100028/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. La conceptualización del ocio, tiempo libre y actividad física. Aproximación histórica. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100028/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "2. Funciones y beneficios de la actividad físico-deportiva en el tiempo de ocio de la población. Figura del animador de ocio. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100028/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "3. La comunicación, sostenibilidad y seguridad en el ocio de la población. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100028/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "4. La deontología, ejercicio profesional y normativa en el ocio de la población. Target Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100028/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "5. Técnicas, organización y estrategias de dinamización. Proyecto/Evento/Outdoortraining. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100028/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "6. Diseño de jornadas ocio-recreativas. Los elementos, recursos para la promoción y organización de actividades físico-deportiva en el tiempo de ocio. Sin subniveles"@es .

