<https://guia-kg.skai.etsisi.upm.es/resource/133000222/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Energía. Balances energéticos. Las energías renovables, los sistemas híbridos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000222/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "2. Técnicas de planificación energética aplicadas con energías renovables: conceptos y aplicación. Modelos energéticos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000222/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "11. Gasificación y biocombustibles gaseosos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000222/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "12. Prácticas de laboratorio 2.Poderes Caloríficos Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000222/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "13. Generación de calor y de energía eléctrica con biomasa. Estufas, calderas y centrales térmicas de biomasa. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000222/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "14. Prácticas de laboratorio 3. Caracterización físico-química biocombustibles líquidos Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000222/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "15. Análisis de ciclos de vida aplicados a la obtención de biocombustibles Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000222/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "16. Prácticas de laboratorio 3: Extracción de volátiles Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000222/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "3. Cultivos energéticos agrícolas y otras fuentes de biomasa no leñosa. Especies y cultivos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000222/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "4. Cultivos energéticos forestales y otras fuentes de biomasa leñosa. Especies y silvoenergía. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000222/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "5. Maquinaria de obtención de biomasa agroforestal con fines energéticos Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000222/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "6. Biocombustibles sólidos. Paja de cereales, leñas y astillas. Concepto, propiedades físicas y químicas. Obtención. Uso. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000222/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "7. Biocombustibles sólidos. Pelets y briquetas. Concepto, propiedades físicas y químicas. Obtención. Uso. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000222/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "8. Biocombustibles sólidos. Madera torrefactada. Carbón vegetal. Otros biocombustibles sólidos. Concepto, propiedades físicas y químicas. Obtención. Uso. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000222/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "9. Prácticas de laboratorio 1. Caracterización físico-química biocombustibles sólidos Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000222/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
