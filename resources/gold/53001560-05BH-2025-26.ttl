    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/53001560/2025-26/eventSchedule> ;
    schema:description """El objetivo de la asignatura es obtener una visión genérica de las soluciones básicas existentes para la navegación, guiado y planificación del movimiento de vehículos y/o robots. La gestión de la incertidumbre inherente a este tipo de robots en las tareas de localización y modelado del entorno, es punto clave en el desarrollo del temario propuesto.
Como metodología docente, los profesores desarrollarán los temas de forma descriptiva y los alumnos desarrollarán una implementación práctica en MATLAB, aplicando los conocimientos adquiridos."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/fernando.matia%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/fernando.matia%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/miguel.hernando%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/paloma.delapuente%40upm.es> ;
    schema:name "Guiado y Navegación de Robots"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001560/2025-26/CB06> a ns1:Competency ;
    ns1:competencyCode "CB06" ;
    ns1:competencyDescription "Poseer y comprender conocimientos que aporten una base u oportunidad de ser originales en el desarrollo y/o aplicación de ideas, a menudo en un contexto de investigación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001560/2025-26/CE01> a ns1:Competency ;
    ns1:competencyCode "CE01" ;
    ns1:competencyDescription "Capacidad para diseñar, simular y/o implementar soluciones tecnológicas que impliquen el uso de robots manipuladores y vehículos robotizados"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001560/2025-26/CE07> a ns1:Competency ;
    ns1:competencyCode "CE07" ;
    ns1:competencyDescription "Capacidad para el desarrollo en equipo de trabajos orientados al diseño, construcción y prueba de sistemas autónomos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001560/2025-26/CG01> a ns1:Competency ;
    ns1:competencyCode "CG01" ;
    ns1:competencyDescription "Tener conocimientos adecuados de los aspectos científicos y tecnológicos de la automática y la robótica."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001560/2025-26/CT04> a ns1:Competency ;
    ns1:competencyCode "CT04" ;
    ns1:competencyDescription "Trabaja en equipo. Habilidad para trabajar en equipos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001560/2025-26/CT11> a ns1:Competency ;
    ns1:competencyCode "CT11" ;
    ns1:competencyDescription "Usa herramientas. Habilidad para usar las técnicas, destrezas y herramientas ingenieriles modernas necesarias para la práctica de la ingeniería"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001560/2025-26/RA10> a ns1:LearningResult ;
    ns1:learningResultCode "RA10" ;
    ns1:learningResultDescription "El alumno debe conocer y aplicar la algorítmica habitual para la planificación del movimiento de robots móviles y manipuladores así como del agarre de estos últimos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001560/2025-26/RA11> a ns1:LearningResult ;
    ns1:learningResultCode "RA11" ;
    ns1:learningResultDescription "El alumno debe concer técnicas de modelado dinámico del entorno en el que se mueven los robots."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001560/2025-26/RA8> a ns1:LearningResult ;
    ns1:learningResultCode "RA8" ;
    ns1:learningResultDescription "El alumno debe conocer los principios fisicos de los distintos sensores utilizados para la navegación autónoma de robots, y sus contextos de aplicación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001560/2025-26/RA9> a ns1:LearningResult ;
    ns1:learningResultCode "RA9" ;
    ns1:learningResultDescription "El alumno debe conocer y aplicar las técnicas de fusión sensorial necesarias para guiado y navegación de robots móviles"@es .

