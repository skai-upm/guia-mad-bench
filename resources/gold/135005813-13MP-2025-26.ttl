        <https://guia-kg.skai.etsisi.upm.es/resource/135005813/2025-26/RA306>,
        <https://guia-kg.skai.etsisi.upm.es/resource/135005813/2025-26/RA311> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/135005813/2025-26/syllabus> ;
    ns1:inpersonHours "42 horas y 30 minutos (52.5%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation "\"LAS COMPETENCIAS Y LOS RESULTADOS DE APRENDIZAJE DE ESTA ASIGNATURA SON LOS ACORDES CON LA MEMORIA VERIFICA DEL TÍTULO\"."@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "42 horas y 30 minutos"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/135005813/2025-26/eventSchedule> ;
    schema:description "Asignatura transversal que aborda los valores culturales y humanísticos que se precisan en la formación del ingeniero más allá de los propiamente técnicos o tecnológicos. Reflexión sobre cómo se sitúa la ingeniería en la historia, la estética y el entorno físico y social. Análisis de la importancia de transversalidad entre disciplinas: Introducción a la Metodología BIM."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/mariajesus.rosado%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/gabriel.dorado%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/mariajesus.rosado%40upm.es> ;
    schema:name "Humanismo y Transversalidad en Ingeniería. Introducción a la Metodología Bim"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005813/2025-26/CB01> a ns1:Competency ;
    ns1:competencyCode "CB01" ;
    ns1:competencyDescription "Que los estudiantes hayan demostrado poseer y comprender conocimientos en un área de estudio que parte de la base de la educación secundaria general, y se suele encontrar a un nivel que, si bien se apoya en libros de texto avanzados, incluye también algunos aspectos que implican conocimientos procedentes de la vanguardia de su campo de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005813/2025-26/CB03> a ns1:Competency ;
    ns1:competencyCode "CB03" ;
    ns1:competencyDescription "Que los estudiantes tengan la capacidad de reunir e interpretar datos relevantes (normalmente dentro de su área de estudio) para emitir juicios que incluyan una reflexión sobre temas relevantes de índole social, científica o ética"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005813/2025-26/CB04> a ns1:Competency ;
    ns1:competencyCode "CB04" ;
    ns1:competencyDescription "Que los estudiantes puedan transmitir información, ideas, problemas y soluciones a un público tanto especializado como no especializado"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005813/2025-26/CB05> a ns1:Competency ;
    ns1:competencyCode "CB05" ;
    ns1:competencyDescription "Que los estudiantes hayan desarrollado aquellas habilidades de aprendizaje necesarias para emprender estudios posteriores con un alto grado de autonomía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005813/2025-26/CT03> a ns1:Competency ;
    ns1:competencyCode "CT03" ;
    ns1:competencyDescription "Transmitir conocimientos y expresar ideas y argumentos de manera clara, rigurosa y convincente, tanto de forma oral como escrita, utilizando adecuadamente los recursos gráficos y los medios necesarios y adaptándose a las características de la situación y de la audiencia."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005813/2025-26/CT04> a ns1:Competency ;
    ns1:competencyCode "CT04" ;
    ns1:competencyDescription "Aplicar los conocimientos tecnológicos necesarios para desenvolverse adecuadamente y afrontar los retos que la sociedad impone en el quehacer profesional, empleando la informática."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005813/2025-26/CT05> a ns1:Competency ;
    ns1:competencyCode "CT05" ;
    ns1:competencyDescription "Proponer alternativas creativas y originales, valorando su viabilidad en la solución de problemas en el ámbito de la ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005813/2025-26/RA235> a ns1:LearningResult ;
    ns1:learningResultCode "RA235" ;
    ns1:learningResultDescription "Que el estudiante sea capaz de realizar una búsqueda activa de documentación e información técnica y científica. Manejo de bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005813/2025-26/RA236> a ns1:LearningResult ;
    ns1:learningResultCode "RA236" ;
    ns1:learningResultDescription "Que los estudiantes puedan transmitir información, ideas, problemas y soluciones"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005813/2025-26/RA305> a ns1:LearningResult ;
    ns1:learningResultCode "RA305" ;
    ns1:learningResultDescription "Relacionar los conocimientos adquiridos en otras materias de la titulación, con el fin de elaborar trabajos y proyectos multidisciplinares"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005813/2025-26/RA306> a ns1:LearningResult ;
    ns1:learningResultCode "RA306" ;
    ns1:learningResultDescription "Conocer la bibliografía básica en esta materia desde cualquier plataforma"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005813/2025-26/RA311> a ns1:LearningResult ;
    ns1:learningResultCode "RA311" ;
    ns1:learningResultDescription "Producir estudios y preparar informes técnicos y científicos."@es .

