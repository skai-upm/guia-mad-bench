    schema:name "Humanism And Transversality In Engineering. Introduction To Bim Methodology"@en,
        "Humanismo y Transversalidad en Ingeniería. Introducción a la Metodología Bim"@es ;
    schema:numberOfCredits 3.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/135005813/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/135005813/2025-26/CB01>,
