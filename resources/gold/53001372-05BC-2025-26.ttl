    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/53001372/2025-26/RA162>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001372/2025-26/RA26>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001372/2025-26/RA27>,
