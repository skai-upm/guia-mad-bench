    schema:name "Advanced Process Control"@en,
        "Control Avanzado de Procesos"@es ;
    schema:numberOfCredits 3.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/53001372/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/53001372/2025-26/CE3>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001372/2025-26/CE4>,
