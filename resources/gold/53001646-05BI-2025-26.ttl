    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/53001646/2025-26/MUEI.CE02>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001646/2025-26/MUEI.CE04>,
