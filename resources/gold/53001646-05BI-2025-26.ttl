    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/53001646/2025-26/syllabus> ;
    ns1:inpersonHours "36 horas (46.2%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation ""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "42 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/53001646/2025-26/eventSchedule> ;
    schema:description """This course is intended to introduce the students into system-level design techniques and optimization of hardware implementation of digital electronic systems.
The topics covered in the subject go from the languages and tools for system-level design to the implementation of accelerators using high-level synthesis from algorithmic descriptions. Model-based design with matlab/simulink is also included.
The practical part will be done using Xilinx tools like Vivado HLS and implementation in SoPC like ZynQ. We will also use a specific C++ compiler for SystemC descriptions."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/joseandres.otero%40upm.es> ;
    schema:inLanguage "Inglés/Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/jose.miranda%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/joseandres.otero%40upm.es> ;
    schema:name "High Level Description Of Systems"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001646/2025-26/MUEI.CE02> a ns1:Competency ;
    ns1:competencyCode "MUEI.CE02" ;
    ns1:competencyDescription "Ser capaz de desarrollar un proyecto de diseño de un sistema electrónico, identificando sus principales retos, en ámbitos de aplicación tales como el aeroespacial, la automoción, la ingeniería médica, las energías renovables o las comunicaciones."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001646/2025-26/MUEI.CE04> a ns1:Competency ;
    ns1:competencyCode "MUEI.CE04" ;
    ns1:competencyDescription "Utilización de herramientas CAD para la simulación, modelado y diseño de circuitos electrónicos industriales con altas prestaciones y/o restricciones."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001646/2025-26/MUEI.CG04> a ns1:Competency ;
    ns1:competencyCode "MUEI.CG04" ;
    ns1:competencyDescription "Ser capaces de predecir y controlar la evolución de situaciones complejas mediante el desarrollo de nuevas e innovadoras metodologías de trabajo adaptadas al ámbito científico/investigador, tecnológico o profesional concreto, en general multidisciplinar, en el que se desarrolle su actividad."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001646/2025-26/MUEI.CG07> a ns1:Competency ;
    ns1:competencyCode "MUEI.CG07" ;
    ns1:competencyDescription "Ser capaces de asumir la responsabilidad de su propio desarrollo profesional y de su especialización en uno o más campos de estudio."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001646/2025-26/MUII.CE07> a ns1:Competency ;
    ns1:competencyCode "MUII.CE07" ;
    ns1:competencyDescription "Capacidad para diseñar sistemas electrónicos y de instrumentación industrial."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001646/2025-26/RA60> a ns1:LearningResult ;
    ns1:learningResultCode "RA60" ;
    ns1:learningResultDescription "Resolver problemas electrónicos con circuitos y sensores reales."@es .

