    ns1:inpersonHours "87 horas (64.4%)"@es ;
    ns1:numberOfCredits 5.0 ;
    ns1:otherInformation """La asignatura se relaciona con el ODS3
La asignatura se relaciona con el ODS4 (Educación de Calidad)"""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "87 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/143005026/2025-26/eventSchedule> ;
    schema:description "Aportará los conocimientos necesarios en técnicas de simulación y control aplicados a la navegación aérea, capacitando al alumno para el diseño y optimización de sistemas complejos con soluciones creativas y originales. Todo ello aplicando las modernas técnicas de modelado y simulación que permitan el análisis de los sistemas aeroespaciales."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/joseluis.perez%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/jj.aliaga%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/joseluis.perez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/luis.izquierdo%40upm.es> ;
    schema:name "Simulacion de Sistemas Aeronauticos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005026/2025-26/CE10> a ns1:Competency ;
    ns1:competencyCode "CE10" ;
    ns1:competencyDescription "Comprender la problemática propia de los sistemas electrónicos terrestres y embarcados en los diferentes elementos del Sistema del Transporte Aéreo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005026/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Poseer y comprender conocimientos que aporten una base u oportunidad de ser originales en el desarrollo de nuevos conceptos y técnicas aplicados al Sistema del Transporte Aéreo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005026/2025-26/CG4> a ns1:Competency ;
    ns1:competencyCode "CG4" ;
    ns1:competencyDescription "Comunicar sus conclusiones y los conocimientos y razones últimas que las sustentan a públicos especializados, y no especializados de un modo claro y sin ambigüedades"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005026/2025-26/CG6> a ns1:Competency ;
    ns1:competencyCode "CG6" ;
    ns1:competencyDescription "Que los estudiantes posean las habilidades de aprendizaje que les permitan continuar estudiando de un modo que habrá de ser en gran medida autodirigido o autónomo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005026/2025-26/CT3> a ns1:Competency ;
    ns1:competencyCode "CT3" ;
    ns1:competencyDescription "Gestionar la información, identificando las fuentes necesarias, los principales tipos de documentos técnicos y científicos que son de aplicación en el entorno de los Sistemas del Transporte Aéreo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005026/2025-26/RA19> a ns1:LearningResult ;
    ns1:learningResultCode "RA19" ;
    ns1:learningResultDescription "El alumno conoce las técnicas básicas de sistemas complejos aplicables al transporte aéreo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005026/2025-26/RA23> a ns1:LearningResult ;
    ns1:learningResultCode "RA23" ;
    ns1:learningResultDescription "El alumno sabe realizar simulaciones de procesos asociados al transporte aéreo"@es .

