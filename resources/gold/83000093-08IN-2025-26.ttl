    ns1:otherInformation "La asignatura tiene previstas prácticas en la parte de fabricación, que son voluntarias y no computan en la calificación final."@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
