<https://guia-kg.skai.etsisi.upm.es/resource/43000526/2025-26/MICCPCB07> a ns1:Competency ;
    ns1:competencyCode "MICCPCB07" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en entornos nuevos o poco conocidos dentro de contextos más amplios (o multidisciplinares) relacionados con su área de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000526/2025-26/MICCPCB08> a ns1:Competency ;
    ns1:competencyCode "MICCPCB08" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de integrar conocimientos y enfrentarse a la complejidad de formular juicios a partir de una información que, siendo incompleta o limitada, incluya reflexiones sobre las responsabilidades sociales y éticas vinculadas a la aplicación de sus conocimientos y juicios"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000526/2025-26/MICCPCB09> a ns1:Competency ;
    ns1:competencyCode "MICCPCB09" ;
    ns1:competencyDescription "Que los estudiantes sepan comunicar sus conclusiones y los conocimientos y razones últimas que las sustentan a públicos especializados y no especializados de un modo claro y sin ambigüedades"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000526/2025-26/MICCPCB10> a ns1:Competency ;
    ns1:competencyCode "MICCPCB10" ;
    ns1:competencyDescription "Que los estudiantes posean las habilidades de aprendizaje que les permitan continuar estudiando de un modo que habrá de ser en gran medida autodirigido o autónomo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000526/2025-26/MICCPCE32> a ns1:Competency ;
    ns1:competencyCode "MICCPCE32" ;
    ns1:competencyDescription "Capacidad para aplicar los conocimientos técnicos en la evaluación de proyectos, obras e infraestructuras dentro del ámbito de la ingeniería civil."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000526/2025-26/MICCPCGP02> a ns1:Competency ;
    ns1:competencyCode "MICCPCGP02" ;
    ns1:competencyDescription "alternativas válidas, elegir la óptima y plasmarla adecuadamente, previendo los problemas de su construcción, y empleando los métodos y tecnologías más adecuadas, tanto tradicionales como innovadores, con la finalidad de conseguir la mayor eficacia y favorecer el progreso y un desarrollo de la sociedad sostenible y respetuoso con el medio ambiente. Incorpora las competencias CB6, CB7 y CB8."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000526/2025-26/MICCPCGP03> a ns1:Competency ;
    ns1:competencyCode "MICCPCGP03" ;
    ns1:competencyDescription "Conocimiento, comprensión y capacidad para aplicar la legislación necesaria en el ejercicio de la profesión de Ingeniero de Caminos, Canales y Puertos. Incorpora las competencias CB6, CB7 y CB8."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000526/2025-26/MICCPCGP04> a ns1:Competency ;
    ns1:competencyCode "MICCPCGP04" ;
    ns1:competencyDescription "Conocimiento de la historia de la ingeniería civil y capacitación para analizar y valorar las obras públicas en particular y de la construcción en general. Incorpora las competencias CB6, CB7 y CB8."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000526/2025-26/MICCPCGP05> a ns1:Competency ;
    ns1:competencyCode "MICCPCGP05" ;
    ns1:competencyDescription "Conocimiento de la profesión de Ingeniero de Caminos, Canales y Puertos y de las actividades que se pueden realizar en el ámbito de la ingeniería civil. Incorpora las competencias CB6, CB7 y CB8."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000526/2025-26/MICCPCGP10> a ns1:Competency ;
    ns1:competencyCode "MICCPCGP10" ;
    ns1:competencyDescription "Capacidad para la realización de estudios de planificación territorial, del medio litoral, de la ordenación y defensa de costas y de los aspectos medioambientales relacionados con las infraestructuras. Incorpora las competencias CB6, CB7 y CB8."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000526/2025-26/MICCPCGP15> a ns1:Competency ;
    ns1:competencyCode "MICCPCGP15" ;
    ns1:competencyDescription "Capacidad para evaluar y acondicionar medioambientalmente las obras de infraestructuras en proyectos, construcción, rehabilitación y conservación. Incorpora las competencias CB6, CB7 y CB8."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000526/2025-26/MICCPCT01> a ns1:Competency ;
    ns1:competencyCode "MICCPCT01" ;
    ns1:competencyDescription "Capacidad de preparar y presentar comunicaciones orales, escritas y gráficas, estructurada y argumentadamente. Desarrolla la competencia CB9."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000526/2025-26/MICCPCT02> a ns1:Competency ;
    ns1:competencyCode "MICCPCT02" ;
    ns1:competencyDescription "Polivalencia y capacidad de aprendizaje autónomo. Desarrolla la competencia CB10."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000526/2025-26/MICCPCT04> a ns1:Competency ;
    ns1:competencyCode "MICCPCT04" ;
    ns1:competencyDescription "Capacidad de organizar y dirigir los esfuerzos de un equipo. Desarrolla la competencia transversal 5ª de la normativa UPM."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000526/2025-26/MICCPCT05> a ns1:Competency ;
    ns1:competencyCode "MICCPCT05" ;
    ns1:competencyDescription "Capacidad de ejercer las funciones profesionales de proyecto, cálculo, evaluación técnica, planificación y gestión técnica mediante el uso de normativa europea e internacional. Desarrolla la competencia transversal 7ª de la normativa UPM."@es .

