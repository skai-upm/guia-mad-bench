    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/gustavo.alonso%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/sergio.jimenez%40upm.es> ;
    schema:name "Planificación de Flotas de Compañías Aéreas"@es .

