    schema:numberOfCredits 6.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/55000636/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/55000636/2025-26/CG1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55000636/2025-26/CG10>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55000636/2025-26/CG3>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55000636/2025-26/CG4>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55000636/2025-26/CG5>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55000636/2025-26/CG6>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55000636/2025-26/CG9> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/55000636/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55000636/2025-26/didactic_resource/2> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/55000636/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/55000636/2025-26/RA43>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55000636/2025-26/RA44> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/55000636/2025-26/syllabus> ;
    ns1:inpersonHours "68 horas y 30 minutos (43.9%)"@es ;
    ns1:numberOfCredits 6.0 ;
    ns1:otherInformation """Se combinará la docencia invertida (en particular, para siguiendo los temas de 'Economics Core' combinados con presentaciones, debates, exposiciones de profesores, alumnos e invitados exteriores y el uso de simuladores empresariales.

Las herramientas de análisis estratégico implica una consideración transversal de los ODS como condicionantes o metas de las empresas, con relación más directa con los de contenido económico como son el 8, 9, 10 y 12."""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "68 horas y 30 minutos"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/55000636/2025-26/eventSchedule> ;
    schema:description """Esta asignatura pretende ofrecer una visión integrada del papel de las empresas dentro del entorno económico, partiendo del conocimiento de las grandes cuestiones que la sociedad se plantea respecto a su desempeño actual, presentando las teorías que buscan explicar su funcionamiento y analizando los cambios que podrían tener lugar en los próximos años.
Aunque se realizarán numerosas idas y venidas conceptuales del ámbito económico al más específico de la empresa, en el primero pueden destacarse 6 objetos principales de estudio:
- homo economicus,
- relaciones e interacciones económicas,
- mercados,
- dinámica del mercado,
- efectos agregados a corto y medio plazo,
- prospectiva económica.

Y en el de administración de empresas los siguientes 6 ámbitos de atención prioritaria:
- la empresa como organización,
- estrategia, innovación y producción,
- recursos humanos,
- financiación e inversión,
- marketing,
- dimensión legal."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/victor.gomez.frias%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/jesus.salgado%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/victor.gomez.frias%40upm.es> ;
    schema:name "Empresa y su Entorno"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000636/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Conocer y aplicar conocimientos de ciencias y tecnologías básicas a la práctica de la Ingeniería de organización"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000636/2025-26/CG10> a ns1:Competency ;
    ns1:competencyCode "CG10" ;
    ns1:competencyDescription "Capacidad para generar nuevas ideas (Creatividad)."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000636/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Aplicar los conocimientos adquiridos para identificar, formular y resolver problemas dentro de contextos amplios y multidisciplinarios, siendo capaces de integrar conocimientos, trabajando en equipos multidisciplinarios."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000636/2025-26/CG4> a ns1:Competency ;
    ns1:competencyCode "CG4" ;
    ns1:competencyDescription "Comprender el impacto de la ingeniería de organización en el medio ambiente, el desarrollo sostenible de la sociedad y la importancia de trabajar en un entorno profesional y responsable."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000636/2025-26/CG5> a ns1:Competency ;
    ns1:competencyCode "CG5" ;
    ns1:competencyDescription "Saber comunicar los conocimientos y conclusiones, tanto de forma oral, escrita y gráfica, a públicos especializados y no especializados de un modo claro y sin ambigüedades"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000636/2025-26/CG6> a ns1:Competency ;
    ns1:competencyCode "CG6" ;
    ns1:competencyDescription "Poseer habilidades de aprendizaje que permitan continuar estudiando a lo largo de la vida para su adecuado desarrollo profesional"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000636/2025-26/CG9> a ns1:Competency ;
    ns1:competencyCode "CG9" ;
    ns1:competencyDescription "Organización y planificación en el ámbito de la empresa, y otras instituciones y organizaciones de proyectos y equipos humanos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000636/2025-26/RA43> a ns1:LearningResult ;
    ns1:learningResultCode "RA43" ;
    ns1:learningResultDescription "Observar, identificar, analizar e interpretar el comportamiento de variables económicas fundamentales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000636/2025-26/RA44> a ns1:LearningResult ;
    ns1:learningResultCode "RA44" ;
    ns1:learningResultDescription "Aprender conocimientos teóricos básicos para la dirección de las organizaciones"@es .

