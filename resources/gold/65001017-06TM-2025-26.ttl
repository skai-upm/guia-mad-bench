    ns1:inpersonHours "38 horas (48.7%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation "La asignatura se relaciona con el ODS7 (Garantizar el acceso a una energía asequible, segura, sostenible y moderna), ODS8 (Promover el crecimiento económico inclusivo y sostenible, el empleo y el trabajo decente para todos) y ODS9 (Construir infraestructuras resilientes, promover la industrialización sostenible y fomentar la innovación)."@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "38 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/65001017/2025-26/eventSchedule> ;
    schema:description """La asignatura de ingeniería de proyectos te acerca y da conocer un proyecto de ingeniería. Conocerás los tipos de proyectos y sus modalidades de contratación. Reúne las técnicas de programación de un proyecto de ingeniería,
contemplando: los límites tiempo, coste y alcance técnico.
Adicionalmente, se contemplan las teorías de gestión y dirección técnica y económica de proyectos: contemplando la cultura, el liderazgo, los riesgos y la gestión económica y de personas.
Por último, se contemplan las técnicas prácticas de planificación temporal, diagramas habitualmente considerados Barras y Redes, así como, la práctica de la planificación financiera: costes e ingresos."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/juan.pous%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/juan.pous%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/maria.chiquito%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/marta.fernandezh%40upm.es> ;
    schema:name "Ingenieria de Proyectos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001017/2025-26/CG%201> a ns1:Competency ;
    ns1:competencyCode "CG 1" ;
    ns1:competencyDescription "Conocer y aplicar conocimientos de ciencias y tecnologías básicas a la práctica de la Tecnología Minera."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001017/2025-26/CG%202> a ns1:Competency ;
    ns1:competencyCode "CG 2" ;
    ns1:competencyDescription "Poseer capacidad para diseñar, analizar, calcular, proyectar, construir, mantener, conservar, explotar, desarrollar, implementar, gestionar y mejorar productos, sistemas y procesos en los distintos ámbitos de las Tecnologías Mineras, usando técnicas analíticas, computacionales o experimentales apropiadas, incluyendo la función de asesoría en estos campos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001017/2025-26/CG%203> a ns1:Competency ;
    ns1:competencyCode "CG 3" ;
    ns1:competencyDescription "Aplicar los conocimientos adquiridos para identificar, formular y resolver problemas dentro de contextos amplios y multidisciplinarios, siendo capaces de integrar conocimientos, trabajando en equipos multidisciplinares."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001017/2025-26/CG%204> a ns1:Competency ;
    ns1:competencyCode "CG 4" ;
    ns1:competencyDescription "Comprender el impacto de la tecnología minera en el medio ambiente, el desarrollo sostenible de la sociedad. desarrollando la capacidad para la realización de estudios de ordenación del territorio y de los aspectos medioambientales relacionados con los proyectos, plantas e instalaciones, en su ámbito"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001017/2025-26/CG%205> a ns1:Competency ;
    ns1:competencyCode "CG 5" ;
    ns1:competencyDescription "Saber comunicar los conocimientos y conclusiones, tanto de forma oral, escrita y gráfica, a públicos especializados y no especializados de un modo claro y sin ambigüedades."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001017/2025-26/CG%206> a ns1:Competency ;
    ns1:competencyCode "CG 6" ;
    ns1:competencyDescription "Poseer habilidades de aprendizaje que permitan continuar estudiando a lo largo de la vida para su adecuado desarrollo profesional"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001017/2025-26/CG%209> a ns1:Competency ;
    ns1:competencyCode "CG 9" ;
    ns1:competencyDescription "Organización y planificación en el ámbito de la empresa, y otras instituciones y organizaciones de proyectos y equipos humanos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001017/2025-26/F16> a ns1:Competency ;
    ns1:competencyCode "F16" ;
    ns1:competencyDescription "Capacidad de análisis de la problemática de la seguridad y salud en los proyectos, plantas o instalaciones."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001017/2025-26/F19> a ns1:Competency ;
    ns1:competencyCode "F19" ;
    ns1:competencyDescription "Capacidad de planificación y gestión integral de obras, mediciones, replanteos, control y seguimiento."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001017/2025-26/F21> a ns1:Competency ;
    ns1:competencyCode "F21" ;
    ns1:competencyDescription "Conocimiento de la metodología, gestión y organización de proyectos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001017/2025-26/RA89> a ns1:LearningResult ;
    ns1:learningResultCode "RA89" ;
    ns1:learningResultDescription "Aplicar los fundamentos básicos de la Ingeniería de Proyectos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001017/2025-26/RA90> a ns1:LearningResult ;
    ns1:learningResultCode "RA90" ;
    ns1:learningResultDescription "Aplicar la metodología y las técnicas necesarias para desarrollar un proyecto, incluidas las fases de planificación, desarrollo y puesta en marcha."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001017/2025-26/RA91> a ns1:LearningResult ;
    ns1:learningResultCode "RA91" ;
    ns1:learningResultDescription "Aplicar la normativa técnica y la legislación vigente relacionadas con el desarrollo y ejecución de un proyecto."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001017/2025-26/RA92> a ns1:LearningResult ;
    ns1:learningResultCode "RA92" ;
    ns1:learningResultDescription "Analizar alternativas y tomar decisiones para la realización de un proyecto, estableciendo previamente criterios de valoración técnicos, económicos, sociales y ambientales."@es .

