    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/93000812/2025-26/eventSchedule> ;
    schema:description """The general objective of the subject is to provide students with the ability to understand, analyze, and design, as well as the associated knowledge, in present fiber optic communications systems and in recent technological advances defining the future evolution.
To achieve this general objective, the different types of components and current systems will be studied (new modulation formats, coherent communications, high spectral efficiency, etc.) with emphasis on their behavior from the point of view of optical signal and their channel performance.

1. THEORETICAL LECTURES: These lectures will be used for the presentation of the contents of the theoretical basements of these technologies.
2. EXPERIMENTAL SESSIONS: Some topics will be clarified by numerical modeling and development of simulations.
3. DEVELOPMENT AND PRESENTATION OF A TECHNICAL WORK: Each student, under the direct advising of a professor, will write and present a technical document in this subject."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/francisco.lopez.hernandez%40upm.es> ;
    schema:inLanguage "Inglés/Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/clara.quevedo.galan%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/francisco.lopez.hernandez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/m.muriel%40upm.es> ;
    schema:name "Temas Avanzados en Comunicaciones ópticas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000812/2025-26/CE13> a ns1:Competency ;
    ns1:competencyCode "CE13" ;
    ns1:competencyDescription "Capacidad para aplicar conocimientos avanzados de fotónica y optoelectrónica, así como electrónica de alta frecuencia."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000812/2025-26/CE3> a ns1:Competency ;
    ns1:competencyCode "CE3" ;
    ns1:competencyDescription "Capacidad para implementar sistemas por cable, línea, satélite en entornos de comunicaciones fijas y móviles."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000812/2025-26/CG4> a ns1:Competency ;
    ns1:competencyCode "CG4" ;
    ns1:competencyDescription "Que los estudiantes sepan comunicar sus conclusiones ?y los conocimientos y razones últimas que las sustentan? a públicos especializados y no especializados de un modo claro y sin ambigüedades."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000812/2025-26/CG5> a ns1:Competency ;
    ns1:competencyCode "CG5" ;
    ns1:competencyDescription "Que los estudiantes posean las habilidades de aprendizaje que les permitan continuar estudiando de un modo que habrá de ser en gran medida autodirigido o autónomo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000812/2025-26/CT4> a ns1:Competency ;
    ns1:competencyCode "CT4" ;
    ns1:competencyDescription "Capacidad para trabajar de forma efectiva como individuo, organizando y planificando su propio trabajo, de forma independiente o como miembro de un equipo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000812/2025-26/RA10> a ns1:LearningResult ;
    ns1:learningResultCode "RA10" ;
    ns1:learningResultDescription "Saber realizar una presentación de carácter técnico, ante una audiencia de pares, que describa el trabajo realizado y sus resultados, de forma clara y bien estructurada, en el tiempo establecido, y usando un lenguaje preciso"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000812/2025-26/RA66> a ns1:LearningResult ;
    ns1:learningResultCode "RA66" ;
    ns1:learningResultDescription "Capacidad de analizar, diseñar, implementar y caracterizar sistemas avanzados de comunicaciones ópticas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000812/2025-26/RA67> a ns1:LearningResult ;
    ns1:learningResultCode "RA67" ;
    ns1:learningResultDescription "Capacidad de utilizar dispositivos e instrumentos relacionados con comunicaciones ópticas avanzadas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93000812/2025-26/RA68> a ns1:LearningResult ;
    ns1:learningResultCode "RA68" ;
    ns1:learningResultDescription "Compresión de los procesos físicos que afectan las prestaciones de los sistemas avanzados de comunicaciones ópticas"@es .

