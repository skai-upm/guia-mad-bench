<https://guia-kg.skai.etsisi.upm.es/resource/145031002/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. LOS NÚMEROS REALES Y COMPLEJOS"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145031002/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Introducción: Conjunto de los naturales, enteros, racionales e irracionales. El cuerpo ordenado de los números reales. Definición axiomática del conjunto de los números reales: Axioma del supremo. La Recta Real. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145031002/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "3.3. Propiedades de los límites. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145031002/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "3.4. Límites indeterminados. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145031002/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "3.5. Cálculo de límites. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145031002/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "3.6. Definiciones y propiedades de las funciones continuas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145031002/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "3.7. Composición de funciones continuas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145031002/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "3.8. Propiedades globales de la continuidad. Teorema del valor intermedio, de Bolzano y de Weierstrass. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145031002/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "3.9. Continuidad uniforme. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145031002/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "4. DERIVACIÓN DE FUNCIONES DE UNA VARIABLE."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145031002/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "4.1. Derivada de una función en un punto: definición, interpretación geométrica y propiedades. Función derivada. Derivadas sucesivas. Continuidad y derivabilidad. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145031002/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "4.2. Derivadas de la función compuesta e inversa. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145031002/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Desigualdades. Intervalos. Valor absoluto. Distancia. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145031002/2025-26/syllabus/20> a ns1:SyllabusItem ;
    ns1:itemIndex 20 ;
    ns1:syllabusDescription "4.3. Funciones Hiperbólicas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145031002/2025-26/syllabus/21> a ns1:SyllabusItem ;
    ns1:itemIndex 21 ;
    ns1:syllabusDescription "4.4. Extremos relativos. Puntos críticos. Teoremas del valor extremo y de Fermat. Teoremas de Rolle y de Lagrange. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145031002/2025-26/syllabus/22> a ns1:SyllabusItem ;
    ns1:itemIndex 22 ;
    ns1:syllabusDescription "4.5. Desarrollo limitado de Taylor. Cálculo de desarrollos limitados. Aplicaciones. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145031002/2025-26/syllabus/23> a ns1:SyllabusItem ;
    ns1:itemIndex 23 ;
    ns1:syllabusDescription "4.6. Fórmula de Taylor. Estudio local de una función. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145031002/2025-26/syllabus/24> a ns1:SyllabusItem ;
    ns1:itemIndex 24 ;
    ns1:syllabusDescription "5. SERIES DE NUMEROS REALES Y SERIES DE POTENCIAS."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145031002/2025-26/syllabus/25> a ns1:SyllabusItem ;
    ns1:itemIndex 25 ;
    ns1:syllabusDescription "5.1. Series de términos reales: Concepto de serie. Series de términos positivos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145031002/2025-26/syllabus/26> a ns1:SyllabusItem ;
    ns1:itemIndex 26 ;
    ns1:syllabusDescription "5.2. Series de potencias: Definición. Radio de convergencia. Regularidad de la suma de una serie de potencias. Unicidad. Serie de Taylor. Existencia del desarrollo en serie de Taylor. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145031002/2025-26/syllabus/27> a ns1:SyllabusItem ;
    ns1:itemIndex 27 ;
    ns1:syllabusDescription "6. INTEGRAL SIMPLE. CÁLCULO DE PRIMITIVAS"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145031002/2025-26/syllabus/28> a ns1:SyllabusItem ;
    ns1:itemIndex 28 ;
    ns1:syllabusDescription "6.1. Funciones integrables. Propiedades de las funciones integrables. Integral simple. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145031002/2025-26/syllabus/29> a ns1:SyllabusItem ;
    ns1:itemIndex 29 ;
    ns1:syllabusDescription "6.2. Teorema fundamental del Cálculo. Regla de Barrow. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145031002/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "1.3. Definición de un número complejo. Representación: el plano complejo. Propiedades algebraicas. Interpretación geométrica. Conjugado de un número complejo. Módulo y argumento. Forma polar y trigonométrica. Forma exponencial. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145031002/2025-26/syllabus/30> a ns1:SyllabusItem ;
    ns1:itemIndex 30 ;
    ns1:syllabusDescription "6.3. Integral indefinida. Integración por cambio de variable. Integración por partes. Integración de funciones racionales. Integración de funciones trigonométricas Integración por sustitución trigonométrica de algunas funciones irracionales. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145031002/2025-26/syllabus/31> a ns1:SyllabusItem ;
    ns1:itemIndex 31 ;
    ns1:syllabusDescription "6.4. Aplicaciones geométricas de la integral simple. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145031002/2025-26/syllabus/32> a ns1:SyllabusItem ;
    ns1:itemIndex 32 ;
    ns1:syllabusDescription "6.5. Integrales en intervalos no compactos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145031002/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "1.4. Operaciones elementales. Función exponencial. Logaritmo. Potencias. Fórmula de Moivre. Raíces. Polinomios complejos. Teorema fundamental del álgebra. Factorización de polinomios reales. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145031002/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "2. SUCESIONES DE NÚMEROS REALES."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145031002/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "2.1. Límites de sucesiones; propiedades: Definición de sucesión y límite. Límite de sucesiones monótonas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145031002/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "3. LÍMITES Y CONTINUIDAD DE FUNCIONES DE UNA VARIABLE."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145031002/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "3.1. Funciones. Definiciones y propiedades básicas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145031002/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "3.2. Definición de límite, límites laterales, límites infinitos. Sin subniveles"@es .

