<https://guia-kg.skai.etsisi.upm.es/resource/145023002/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/145023002/2025-26/CB2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/145023002/2025-26/CFB1>,
