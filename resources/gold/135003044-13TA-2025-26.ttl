    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/135003044/2025-26/RA166>,
        <https://guia-kg.skai.etsisi.upm.es/resource/135003044/2025-26/RA175>,
        <https://guia-kg.skai.etsisi.upm.es/resource/135003044/2025-26/RA176>,
