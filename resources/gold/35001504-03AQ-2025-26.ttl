<https://guia-kg.skai.etsisi.upm.es/resource/35001504/2025-26/RA106> a ns1:LearningResult ;
    ns1:learningResultCode "RA106" ;
    ns1:learningResultDescription "Analizar, a través de la documentación encontrada o suministrada, aspectos relevantes de un edificio o de la obra de un arquitecto determinado"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35001504/2025-26/RA11> a ns1:LearningResult ;
    ns1:learningResultCode "RA11" ;
    ns1:learningResultDescription "El alumno será capaz de encontrar documentación fiable (textual, gráfica, fotográfica e infográfica) de un tema, edificio, periodo o arquitecto determinados."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35001504/2025-26/RA110> a ns1:LearningResult ;
    ns1:learningResultCode "RA110" ;
    ns1:learningResultDescription "Entender y aplicar las relaciones entre las distintas dimensiones de la arquitectura y su papel simbólico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35001504/2025-26/RA12> a ns1:LearningResult ;
    ns1:learningResultCode "RA12" ;
    ns1:learningResultDescription "El alumno será capaz de analizar la documentación encontrada para extraer la información relevante para su estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35001504/2025-26/RA13> a ns1:LearningResult ;
    ns1:learningResultCode "RA13" ;
    ns1:learningResultDescription "El alumno será capaz de entender y explicar la incidencia de las cuestiones técnicas, funcionales y formales en el conjunto de la obra de arquitectura."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35001504/2025-26/RA14> a ns1:LearningResult ;
    ns1:learningResultCode "RA14" ;
    ns1:learningResultDescription "El alumno será capaz de entender y explicar los elementos y relaciones fundamentales (técnicos, funcionales y formales) de la arquitectura de cada uno de los periodos históricos expuestos en clase"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35001504/2025-26/RA174> a ns1:LearningResult ;
    ns1:learningResultCode "RA174" ;
    ns1:learningResultDescription "El alumno sabrá identificar las características distintivas de cada periodo histórico de la arquitectura occidental. El alumno sabrá identificar las características distintivas de cada periodo del arte occidental"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35001504/2025-26/RA181> a ns1:LearningResult ;
    ns1:learningResultCode "RA181" ;
    ns1:learningResultDescription "Aprendizaje del léxico arquitectónico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35001504/2025-26/RA55> a ns1:LearningResult ;
    ns1:learningResultCode "RA55" ;
    ns1:learningResultDescription "Conocimiento adecuado de las tradiciones arquitectónicas, urbanísticas y paisajísticas de la cultura occidental, así como de sus fundamentos técnicos, climáticos, económicos, sociales e ideológicos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/35001504/2025-26/RA58> a ns1:LearningResult ;
    ns1:learningResultCode "RA58" ;
    ns1:learningResultDescription "Conocimiento de la historia de la ciudad y el urbanismo"@es .

