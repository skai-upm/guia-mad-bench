    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/305000152/2025-26/eventSchedule> ;
    schema:description """La asignatura consta de 2 módulos.

MÓDULO A. CAS (Computer Algebra Systems). Herramientas para la Divulgación matemática
MÓDULO B. Machine Learning. Redes neuronales

Cada módulo se estructura en:
Temas de carácter teórico-práctico
2 Casos de estudio.
En todas las clases se compaginan la exposición de los conceptos con el desarrollo e implementación inmediata de los mismos, por lo que, el alumno va a utilizar su portátil en todas las clases."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/makrina.agaoglou%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/makrina.agaoglou%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/manuel.mendoza%40upm.es> ;
    schema:name "Recursos Tecnológicos para las Matemáticas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000152/2025-26/CE1> a ns1:Competency ;
    ns1:competencyCode "CE1" ;
    ns1:competencyDescription "Comprender y utilizar el lenguaje matemático. Adquirir la capacidad para enunciar propiedades en distintos campos de la Matemática, para construir argumentaciones, elaborar cálculos y para transmitir los conocimientos matemáticos adquiridos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000152/2025-26/CE2> a ns1:Competency ;
    ns1:competencyCode "CE2" ;
    ns1:competencyDescription "Conocer y comprender demostraciones rigurosas de los principales teoremas de cada área de la Matemática y extraer de ellos corolarios mediante la particularización a casos concretos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000152/2025-26/CE3> a ns1:Competency ;
    ns1:competencyCode "CE3" ;
    ns1:competencyDescription "Asimilar la definición de un nuevo objeto matemático, en términos de otros ya conocidos, y ser capaz de utilizar este objeto en diferentes contextos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000152/2025-26/CE4> a ns1:Competency ;
    ns1:competencyCode "CE4" ;
    ns1:competencyDescription "Abstraer las propiedades estructurales de objetos matemáticos, de la realidad observada o de otros ámbitos distinguiéndolas de aquellas puramente ocasionales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000152/2025-26/CE5> a ns1:Competency ;
    ns1:competencyCode "CE5" ;
    ns1:competencyDescription "Comprobar con demostraciones hipótesis sobre un objeto matemático o refutarlas con contraejemplos, así como identificar errores en razonamientos incorrectos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000152/2025-26/CE7> a ns1:Competency ;
    ns1:competencyCode "CE7" ;
    ns1:competencyDescription "Resolver problemas de Matemáticas, mediante habilidades de cálculo básico y tecnologías de computación, planificando su resolución en función de las herramientas de que se disponga y de las restricciones de tiempo y recursos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000152/2025-26/CE8> a ns1:Competency ;
    ns1:competencyCode "CE8" ;
    ns1:competencyDescription "Utilizar aplicaciones informáticas de análisis estadístico, cálculo numérico y simbólico, visualización gráfica, optimización u otras para experimentar en Matemáticas, buscar soluciones y resolver modelos matemáticos de sistemas reales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000152/2025-26/CG2> a ns1:Competency ;
    ns1:competencyCode "CG2" ;
    ns1:competencyDescription "Reconocer la presencia de la Matemática subyacente en la Naturaleza, en la Ciencia, en la Tecnología y en el Arte. Reconocer a la Matemática como parte integrante de la Educación y la Cultura."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000152/2025-26/CG4> a ns1:Competency ;
    ns1:competencyCode "CG4" ;
    ns1:competencyDescription "Utilizar los conocimientos teóricos y prácticos adquiridos en la definición y planteamiento de problemas y en la búsqueda de sus soluciones tanto en contextos académicos como profesionales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000152/2025-26/CG5> a ns1:Competency ;
    ns1:competencyCode "CG5" ;
    ns1:competencyDescription "Sintetizar conocimientos y habilidades adquiridas en el campo de la matemática en diferentes materias del plan de estudios para enfocarlas en posteriores estudios especializados, tanto en una disciplina matemática como en cualquiera de las ciencias que requieran buenos fundamentos matemáticos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000152/2025-26/RA102> a ns1:LearningResult ;
    ns1:learningResultCode "RA102" ;
    ns1:learningResultDescription "Utilizar software específico de análisis estadístico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000152/2025-26/RA110> a ns1:LearningResult ;
    ns1:learningResultCode "RA110" ;
    ns1:learningResultDescription "Analizar la complejidad de algoritmos básicos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000152/2025-26/RA139> a ns1:LearningResult ;
    ns1:learningResultCode "RA139" ;
    ns1:learningResultDescription "Conocer y seleccionar adecuadamente las herramientas matemáticas necesarias para formular, analizar y simular modelos matemáticos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000152/2025-26/RA140> a ns1:LearningResult ;
    ns1:learningResultCode "RA140" ;
    ns1:learningResultDescription "Plantear, resolver e interpretar modelos matemáticos de problemas aplicados"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000152/2025-26/RA147> a ns1:LearningResult ;
    ns1:learningResultCode "RA147" ;
    ns1:learningResultDescription "Conocer y manejar las herramientas de visualización de resultados que más se adapten a cada situación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000152/2025-26/RA178> a ns1:LearningResult ;
    ns1:learningResultCode "RA178" ;
    ns1:learningResultDescription "Construir un modelo matemático de un fenómeno real. Identificar todos los componentes de este. Evaluar la calidad del modelo e interpretar los resultados."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000152/2025-26/RA266> a ns1:LearningResult ;
    ns1:learningResultCode "RA266" ;
    ns1:learningResultDescription "Comprender e interpretar los principales elementos de la codificación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000152/2025-26/RA271> a ns1:LearningResult ;
    ns1:learningResultCode "RA271" ;
    ns1:learningResultDescription "Resolución de ecuaciones diferenciales mediante cálculo simbólico. Simetrías de Lie"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000152/2025-26/RA272> a ns1:LearningResult ;
    ns1:learningResultCode "RA272" ;
    ns1:learningResultDescription "Uso de librerías para entrenamiento de redes neuronales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000152/2025-26/RA273> a ns1:LearningResult ;
    ns1:learningResultCode "RA273" ;
    ns1:learningResultDescription "Conocer los fundamentos matemáticos de las redes neuronales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000152/2025-26/RA274> a ns1:LearningResult ;
    ns1:learningResultCode "RA274" ;
    ns1:learningResultDescription "Conocer la estructura de las redes neuronales convolucionales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000152/2025-26/RA70> a ns1:LearningResult ;
    ns1:learningResultCode "RA70" ;
    ns1:learningResultDescription "Programar algoritmos sencillos de resolución de modelos matemáticos con las habilidades de programación adquiridas en la asignatura de programación."@es .

