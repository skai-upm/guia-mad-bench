<https://guia-kg.skai.etsisi.upm.es/resource/65001042/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. ACEROS ALEADOS O ESPECIALES"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001042/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Aceros de Construcción. Aceros de construcción. Aceros microaleados: HSLA y DPLA. Aceros de construcción tratados termicámente. Aceros de alta resistencia. Aceros maraging. Tratamientos termomecánicos. Aceros TRIP Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001042/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "2.4. Normalización y selección Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001042/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "3. ALEACIONES LIGERAS"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001042/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "3.1. Aluminio. Aleaciones para moldeo y forja. Tratamientos Térmicos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001042/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "3.2. Aleaciones de titanio, magnesio y berilio .Tratamientos térmicos Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001042/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "3.3. Normalización y selección Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001042/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "4. ALEACIONES NO FERREAS"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001042/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "4.1. Cobre, Latones y Bronces. Aleaciones cobre-aluminio, cobre-berilio y cobre-silicio. Aleaciones de Cu-Ni, Cu-Ni-Zn, Cu-Pb y Cu-Mn Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001042/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "4.2. Níquel, Cobalto, Cromo, Manganeso y sus aleaciones, Superaleaciones Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001042/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "4.3. Zinc, Plomo, Estaño y sus aleaciones Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001042/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "4.4. Materiales con propiedades especiales Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001042/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Aceros de cementación y nitruración. Aceros de facil mecanización Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001042/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "1.3. Aceros de herramientas. Aceros de herramientas para trabajos en frío y en caliente Aceros rápidos. Aceros de herramientas para usos varios Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001042/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "1.4. Aceros inoxidables. Aceros inoxidables ferrítico y martensíticos. Aceros inoxidables austeníticos y austenoferríticos . Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001042/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "1.5. Normalización y Selección. Sin subniveles"@es .

