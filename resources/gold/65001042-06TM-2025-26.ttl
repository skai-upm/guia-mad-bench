    ns1:syllabusDescription "2.1. Fundiciones grises. Tratamientos térmicos Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001042/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "2.2. Fundiciones maleables Sin subniveles"@es .

