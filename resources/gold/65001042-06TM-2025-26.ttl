    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/65001042/2025-26/syllabus> ;
    ns1:inpersonHours "47 horas (40.2%)"@es ;
    ns1:numberOfCredits 4.5 ;
    ns1:otherInformation """El profesor solo puede atender a un maximo de 10 alumnos en el laboratorio.
La asignatura se relaciona con el ODS 12: Producción y consumo sostenibles. Se APLICARAN CRITERIOS DE RECICLABILIDAD Y SOSTENIBILIDAD en la SELECCION DE MATERIALES"""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "47 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/65001042/2025-26/eventSchedule> ;
    schema:description "La extraccion de minerales metalicos, su tratamiento mineralurgico y metalurgico permite disponer de un conjunto de metales y aleaciones mertalicas de aplicación industrial. En esta asignatura se estudian las familias de aceros, fundicones de hierros, aleciones ligeras y aleciones no ferreas. Otros materiales no metalicos, son objeto de la asignatura Ceramicos, plasticos y compuestos del siguiente semestre."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/luis.gcambronero%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/josemanuel.ruizr%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/luis.gcambronero%40upm.es> ;
    schema:name "Materiales para la Industria"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001042/2025-26/CG%201> a ns1:Competency ;
    ns1:competencyCode "CG 1" ;
    ns1:competencyDescription "Conocer y aplicar conocimientos de ciencias y tecnologías básicas a la práctica de la Tecnología Minera."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001042/2025-26/CG%202> a ns1:Competency ;
    ns1:competencyCode "CG 2" ;
    ns1:competencyDescription "Poseer capacidad para diseñar, analizar, calcular, proyectar, construir, mantener, conservar, explotar, desarrollar, implementar, gestionar y mejorar productos, sistemas y procesos en los distintos ámbitos de las Tecnologías Mineras, usando técnicas analíticas, computacionales o experimentales apropiadas, incluyendo la función de asesoría en estos campos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001042/2025-26/CG%203> a ns1:Competency ;
    ns1:competencyCode "CG 3" ;
    ns1:competencyDescription "Aplicar los conocimientos adquiridos para identificar, formular y resolver problemas dentro de contextos amplios y multidisciplinarios, siendo capaces de integrar conocimientos, trabajando en equipos multidisciplinares."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001042/2025-26/CG%204> a ns1:Competency ;
    ns1:competencyCode "CG 4" ;
    ns1:competencyDescription "Comprender el impacto de la tecnología minera en el medio ambiente, el desarrollo sostenible de la sociedad. desarrollando la capacidad para la realización de estudios de ordenación del territorio y de los aspectos medioambientales relacionados con los proyectos, plantas e instalaciones, en su ámbito"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001042/2025-26/CG%205> a ns1:Competency ;
    ns1:competencyCode "CG 5" ;
    ns1:competencyDescription "Saber comunicar los conocimientos y conclusiones, tanto de forma oral, escrita y gráfica, a públicos especializados y no especializados de un modo claro y sin ambigüedades."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001042/2025-26/CG%206> a ns1:Competency ;
    ns1:competencyCode "CG 6" ;
    ns1:competencyDescription "Poseer habilidades de aprendizaje que permitan continuar estudiando a lo largo de la vida para su adecuado desarrollo profesional"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001042/2025-26/CG%207> a ns1:Competency ;
    ns1:competencyCode "CG 7" ;
    ns1:competencyDescription "Incorporar nuevas tecnologías y herramientas de la ingeniería en tecnología minera en sus actividades profesionales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001042/2025-26/F36> a ns1:Competency ;
    ns1:competencyCode "F36" ;
    ns1:competencyDescription "Ingeniería de los materiales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001042/2025-26/F37> a ns1:Competency ;
    ns1:competencyCode "F37" ;
    ns1:competencyDescription "Metalurgia y tratamiento de concentrados minerales, metales y aleaciones: Industria metalurgia férrea y no férrea, aleaciones especiales, ensayos metalotécnicos, etc"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001042/2025-26/F39> a ns1:Competency ;
    ns1:competencyCode "F39" ;
    ns1:competencyDescription "Tratamiento de superficies y soldaduras."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001042/2025-26/F40> a ns1:Competency ;
    ns1:competencyCode "F40" ;
    ns1:competencyDescription "Ensayos y control de calidad de materiales metálicos y no metálicos, materiales cerámicos y plásticos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001042/2025-26/RA204> a ns1:LearningResult ;
    ns1:learningResultCode "RA204" ;
    ns1:learningResultDescription "Seleccionar las aleaciones adecuadas para las diversas condiciones de servicio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001042/2025-26/RA205> a ns1:LearningResult ;
    ns1:learningResultCode "RA205" ;
    ns1:learningResultDescription "Conocer los distintos tipos de aleaciones y sus posibles aplicaciones."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001042/2025-26/RA206> a ns1:LearningResult ;
    ns1:learningResultCode "RA206" ;
    ns1:learningResultDescription "Comprender, en cada aleación, los procedimientos para modificar su estructura y, en consecuencia, sus propiedades"@es .

