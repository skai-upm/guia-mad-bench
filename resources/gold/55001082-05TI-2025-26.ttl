    schema:hasCourseInstance <https://guia-kg.skai.etsisi.upm.es/resource/55001082/2025-26> ;
    schema:name "Partial Differential Equations And Fourier Analysis"@en,
        "Ecuaciones en Derivadas Parciales y Análisis de Fourier"@es ;
    schema:numberOfCredits 6.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/55001082/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/55001082/2025-26/CE21I>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55001082/2025-26/CG10>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55001082/2025-26/CG2>,
