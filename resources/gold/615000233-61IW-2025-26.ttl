    ns1:otherInformation "Dentro del proyecto de evaluación de competencias transversales de esta Escuela, esta asignatura se encarga de la evaluación de la competencia de Comunicación Escrita."@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
