    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/615000233/2025-26/eventSchedule> ;
    schema:description """Esta asignatura es de carácter práctico.
En ella se introduce el sistema operativo Linux/Unix mediante la utilización del intérprete de comandos.
Al final de la asignatura los usuarios serán capaces de distinguir los principales objetos de un sistema operativo Linux/Unix, además de interactuar con algunos de ellos mediante el intérprete de comandos y los diferentes programas disponibles en este tipo de sistemas."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/andres.sevilla%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/andres.sevilla%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/ernesto.jimenez.merino%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/pilar.manzano%40upm.es> ;
    schema:name "Taller de Sistemas Operativos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000233/2025-26/CB4> a ns1:Competency ;
    ns1:competencyCode "CB4" ;
    ns1:competencyDescription "Conocimiento de los fundamentos del uso y programación de los computadores, los sistemas operativos, las bases de datos y, en general, los programas informáticos con aplicación en ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000233/2025-26/CC10> a ns1:Competency ;
    ns1:competencyCode "CC10" ;
    ns1:competencyDescription "Conocimiento de las características, funcionalidades y estructura de los Sistemas Operativos y diseñar e implementar aplicaciones basadas en sus servicios."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000233/2025-26/CT4> a ns1:Competency ;
    ns1:competencyCode "CT4" ;
    ns1:competencyDescription "Comunicación escrita: Relacionarse eficazmente con otras personas a través de la expresión clara de lo que se piensa, mediante la escritura y los apoyos gráficos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000233/2025-26/RA15> a ns1:LearningResult ;
    ns1:learningResultCode "RA15" ;
    ns1:learningResultDescription "Redacta textos de complejidad y longitud moderada para explicar razonadamente algún tema, aplicando principios básicos de comunicación escrita y organizando las distintas partes del texto"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000233/2025-26/RA157> a ns1:LearningResult ;
    ns1:learningResultCode "RA157" ;
    ns1:learningResultDescription "Identifica los principales objetos de un sistema operativo Unix/Linux"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000233/2025-26/RA158> a ns1:LearningResult ;
    ns1:learningResultCode "RA158" ;
    ns1:learningResultDescription "Automatiza la construcción de programas a partir de los ficheros fuente"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615000233/2025-26/RA88> a ns1:LearningResult ;
    ns1:learningResultCode "RA88" ;
    ns1:learningResultDescription "Utiliza los mecanismos de usuario de la interfaz de línea de comandos de unix y linux: lenguaje de shell, filtros, redirección, make, expresiones regulares y otros comandos de uso común."@es .

