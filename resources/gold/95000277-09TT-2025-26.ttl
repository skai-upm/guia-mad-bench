    ns1:inpersonHours "46 horas (39.3%)"@es ;
    ns1:numberOfCredits 4.5 ;
    ns1:otherInformation "La asignatura se relaciona directamente con los ODS 11 y 12: \"Lograr que las ciudades y los asentamientos humanos sean inclusivos, seguros, resilientes y sostenibles\" y \"Garantizar modalidades de consumo y producción sostenibles\" porque las técnicas que en ella se presentan sirven para preservar la privacidad y asegurar que cualquier tipo de transacciones informáticas pueda realizarse de forma segura y eficiente."@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "46 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/95000277/2025-26/eventSchedule> ;
    schema:description """La asignatura comienza con una breve introducción a la Matemática discreta, la teoría de números y los cuerpos finitos donde se exponen los conceptos y resultados necesarios para comprender y manejar las técnicas y estrategias propias de la Criptografía actual.
A continuación se estudian los sistemas criptográficos simétricos y asimétricos basados en el conocimiento o desconocimiento público de las claves. Se hace especial mención a la seguridad de las firmas digitales y se concluye analizando la situación actual de la criptografía post-cuántica y a los métodos criptográficos utilizados en blockchain."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/lorenzojavier.martin%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/carmen.sanchez.avila%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/lorenzojavier.martin%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/vicente.jara%40upm.es> ;
    schema:name "Criptografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000277/2025-26/CEB1> a ns1:Competency ;
    ns1:competencyCode "CEB1" ;
    ns1:competencyDescription "Capacidad para la resolución de los problemas matemáticos que puedan plantearse en la ingeniería. Aptitud para aplicar los conocimientos sobre: álgebra lineal; geometría; geometría diferencial; cálculo diferencial e integral; ecuaciones diferenciales y en derivadas parciales; métodos numéricos; algorítmica numérica; estadística y optimización"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000277/2025-26/CEB2> a ns1:Competency ;
    ns1:competencyCode "CEB2" ;
    ns1:competencyDescription "Conocimientos básicos sobre el uso y programación de los ordenadores, sistemas operativos, bases de datos y programas informáticos con aplicación en ingeniería"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000277/2025-26/CG10> a ns1:Competency ;
    ns1:competencyCode "CG10" ;
    ns1:competencyDescription "Creatividad"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000277/2025-26/CG5> a ns1:Competency ;
    ns1:competencyCode "CG5" ;
    ns1:competencyDescription "Que los estudiantes hayan desarrollado aquellas habilidades de aprendizaje necesarias para emprender estudios posteriores con un alto grado de autonomía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000277/2025-26/CG9> a ns1:Competency ;
    ns1:competencyCode "CG9" ;
    ns1:competencyDescription "Uso de Tecnologías de la Información y de las Comunicaciones"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000277/2025-26/RA45> a ns1:LearningResult ;
    ns1:learningResultCode "RA45" ;
    ns1:learningResultDescription "Conocimientos y habilidades de las temáticas científico tecnológicas desarrolladas en las asignaturas ofertadas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000277/2025-26/RA722> a ns1:LearningResult ;
    ns1:learningResultCode "RA722" ;
    ns1:learningResultDescription "Comprender, interpretar y aplicar teoremas, propiedades y técnicas de la teoría de números, principalmente los relacionados con los números primos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000277/2025-26/RA723> a ns1:LearningResult ;
    ns1:learningResultCode "RA723" ;
    ns1:learningResultDescription "Manejar con soltura las operaciones en cuerpos finitos y en sus anillos de polinomios"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000277/2025-26/RA724> a ns1:LearningResult ;
    ns1:learningResultCode "RA724" ;
    ns1:learningResultDescription "Operar fluidamente en la aritmética entera y modular"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000277/2025-26/RA725> a ns1:LearningResult ;
    ns1:learningResultCode "RA725" ;
    ns1:learningResultDescription "Comprender y operar con soltura diversos sistemas criptográficos fundamentales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000277/2025-26/RA726> a ns1:LearningResult ;
    ns1:learningResultCode "RA726" ;
    ns1:learningResultDescription "Comprender y manejar primitivas y esquemas básicos de mantenimiento de la integridad (funciones hash) y de autenticación (firmas digitales) de la información"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000277/2025-26/RA727> a ns1:LearningResult ;
    ns1:learningResultCode "RA727" ;
    ns1:learningResultDescription "Comprender la diversa fundamentación de la criptografía no cuántica frente a la variante cuántica y algunos sistemas post"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000277/2025-26/RA728> a ns1:LearningResult ;
    ns1:learningResultCode "RA728" ;
    ns1:learningResultDescription "Comprender e interpretar la utilización y necesidad de la criptografía en de la tecnología blockchain"@es .

