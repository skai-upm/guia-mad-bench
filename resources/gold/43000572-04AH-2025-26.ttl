    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/43000572/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/43000572/2025-26/RA100>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000572/2025-26/RA21>,
        <https://guia-kg.skai.etsisi.upm.es/resource/43000572/2025-26/RA25> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/43000572/2025-26/syllabus> ;
    ns1:inpersonHours "60 horas y 20 minutos (51.6%)"@es ;
    ns1:numberOfCredits 4.5 ;
    ns1:otherInformation "Esta asignatura esta relacionada con el ODS7."@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "61 horas y 20 minutos"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/43000572/2025-26/eventSchedule> ;
    schema:description """El objetivo de esta asignatura es especializar al alumno en la planificación, proyecto, construcción, explotación y mantenimiento de centrales hidroeléctricas, desarrollando sus conocimientos en lo que se refiere a:
concepción, estudios de viabilidad y anteproyectos de aprovechamientos hidroeléctricos
planificación, promoción y gestión de los correspondientes proyectos
redacción de proyectos de construcción de centrales hidroeléctricas
dirección de la construcción de las mismas
gestión, conservación, explotación y reparación de los aprovechamientos hidroeléctricos."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/joseangel.sanchez%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/daniel.garcia-lorenzana%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/guillermo.martinez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/joseangel.sanchez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/joseignacio.sarasua%40upm.es> ;
    schema:name "Ingenieria Hidroelectrica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000572/2025-26/CB10> a ns1:Competency ;
    ns1:competencyCode "CB10" ;
    ns1:competencyDescription "Que los estudiantes posean las habilidades de aprendizaje que les permitan continuar estudiando de un modo que habrá de ser en gran medida autodirigido o autónomo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000572/2025-26/CB9> a ns1:Competency ;
    ns1:competencyCode "CB9" ;
    ns1:competencyDescription "Que los estudiantes sepan comunicar sus conclusiones y los conocimientos y razones últimas que las sustentan a públicos especializados y no especializados de un modo claro y sin ambigüedades"@es .

