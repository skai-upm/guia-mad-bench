    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/43000673/2025-26/eventSchedule> ;
    schema:description "Esta asignatura pretende dotar a los alumnos de las herramientas necesarias para intervenir en la estructuras de madera o fábrica, tanto en el diseño de estructuras de nueva construcción como en la conservación, rehabilitación y refuerzo de estructuras históricas. La asignatura está dividida en dos bloques, uno para cada tipo de estructura. En cada bloque se dividirá en dos partes. En primer lugar, se presentarán los métodos de diseño y comprobación de estas estructuras. Posteriormente, se tratarán las patologías y métodos de rehabilitación y refuerzo, con ejemplos prácticos de aplicaciones reales de estructuras históricas."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/g.ulzurrun%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/alvaro.serrano%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/g.ulzurrun%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/leonardo.todisco%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/luis.matute%40upm.es> ;
    schema:name "Estructuras de Madera y Fábrica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000673/2025-26/C12> a ns1:Competency ;
    ns1:competencyCode "C12" ;
    ns1:competencyDescription "[ligada al Itinerario en Mantenimiento y rehabilitación de estructuras, y sus cimentaciones y materiales]: Capacidad para la investigación de alta especialización o predoctoral en mantenimiento y conservación de estructuras, sus cimentaciones y sus materiales TIPO: Competencias"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000673/2025-26/C3> a ns1:Competency ;
    ns1:competencyCode "C3" ;
    ns1:competencyDescription "[Proviene de las competencias CE3 y CE9]: Capacidad para la resolución de problemas ligados al diseño, construcción, conservación y evaluación técnica de infraestructuras que requieran la aplicación de las propiedades mecánicas y de fractura de los materiales estructurales TIPO: Competencias"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000673/2025-26/C9> a ns1:Competency ;
    ns1:competencyCode "C9" ;
    ns1:competencyDescription "[Proviene de las competencias CE9"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000673/2025-26/K1> a ns1:Competency ;
    ns1:competencyCode "K1" ;
    ns1:competencyDescription "[Proviene parcialmente de la competencia CG1]: Aplica e integra conocimientos científicos avanzados de tipo mecánico, físico y matemático en contextos de investigación científica y tecnológica en el ámbito de las estructuras, las cimentaciones y los materiales TIPO: Conocimientos o contenidos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000673/2025-26/K2> a ns1:Competency ;
    ns1:competencyCode "K2" ;
    ns1:competencyDescription "[Proviene de la competencia CG2]: Identifica los componentes determinantes para ejercer las funciones de diseño, construcción, conservación y evaluación técnica de estructuras, cimentaciones y materiales, mediante el uso de normativa y documentación científica nacional e internacional. TIPO: Conocimientos o contenidos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000673/2025-26/K3> a ns1:Competency ;
    ns1:competencyCode "K3" ;
    ns1:competencyDescription "[Proviene de la competencia CG3]: Identifica y explica los aspectos determinantes para diseñar, analizar e interpretar experimentos relevantes, así como usar varios lenguajes de computación, programas de análisis y simulación, y modelos avanzados en ingeniería estructural, geotécnica y de materiales estructurales. TIPO: Conocimientos o contenidos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000673/2025-26/RA47> a ns1:LearningResult ;
    ns1:learningResultCode "RA47" ;
    ns1:learningResultDescription "Los resultados del aprendizaje correspondientes a esta asignatura han quedado definidos en el apartado de competencias de este documento, señalando los que corresponden a conocimientos, habilidades y competencias propiamente dichas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000673/2025-26/Sk3> a ns1:Competency ;
    ns1:competencyCode "Sk3" ;
    ns1:competencyDescription "[Proviene de la competencia CB8]: Integra los conocimientos adquiridos para formular juicios e introducir innovaciones tecnológicas a partir de una información que, siendo incompleta o limitada, incluya reflexiones sobre las responsabilidades sociales y éticas vinculadas a la aplicación de sus conocimientos y juicios TIPO: Habilidades o destrezas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000673/2025-26/Sk4> a ns1:Competency ;
    ns1:competencyCode "Sk4" ;
    ns1:competencyDescription "[Proviene de la competencia CB10]: Demuestra que puede adquirir conocimientos complejos y continuar estudiando de un modo que habrá de ser en gran medida auto"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000673/2025-26/Sk5> a ns1:Competency ;
    ns1:competencyCode "Sk5" ;
    ns1:competencyDescription "[Proviene de la competencia CG4]: Utiliza la lengua inglesa para expresar conocimiento técnico y científico, de forma oral y escrita. TIPO: Habilidades o destrezas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000673/2025-26/Sk6> a ns1:Competency ;
    ns1:competencyCode "Sk6" ;
    ns1:competencyDescription "[Proviene de la competencia CG5]: Aplica los servicios de comunicación y de obtención de información para su transformación en conocimiento aplicable al ejercicio de las competencias en ingeniería de estructuras, cimentaciones y materiales. TIPO: Habilidades o destrezas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000673/2025-26/Sk7> a ns1:Competency ;
    ns1:competencyCode "Sk7" ;
    ns1:competencyDescription "[Proviene de las competencias CB9 y CT1]: Prepara y presenta comunicaciones orales, escritas y gráficas, estructurada y argumentadamente, y es capaz de discutirlas con otras personas. TIPO: Habilidades o destrezas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000673/2025-26/Sk8> a ns1:Competency ;
    ns1:competencyCode "Sk8" ;
    ns1:competencyDescription "[Proviene de la competencia CT2]: Planifica, organiza y dirige los esfuerzos de un equipo de personas TIPO: Habilidades o destrezas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000673/2025-26/Sk9> a ns1:Competency ;
    ns1:competencyCode "Sk9" ;
    ns1:competencyDescription "[Proviene de la competencia CT3]: Aplica los estándares de deontología en la investigación avanzada TIPO: Habilidades o destrezas"@es .

