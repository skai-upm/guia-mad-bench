    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/135004809/2025-26/RA315>,
        <https://guia-kg.skai.etsisi.upm.es/resource/135004809/2025-26/RA475>,
        <https://guia-kg.skai.etsisi.upm.es/resource/135004809/2025-26/RA557>,
        <https://guia-kg.skai.etsisi.upm.es/resource/135004809/2025-26/RA559>,
