<https://guia-kg.skai.etsisi.upm.es/resource/135004809/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/135004809/2025-26/CB05>,
        <https://guia-kg.skai.etsisi.upm.es/resource/135004809/2025-26/CE%202.7>,
        <https://guia-kg.skai.etsisi.upm.es/resource/135004809/2025-26/CG08> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/135004809/2025-26/didactic_resource/1>,
