    schema:name "Transporte Sostenible."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001968/2025-26/CB07> a ns1:Competency ;
    ns1:competencyCode "CB07" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en entornos nuevos o poco conocidos dentro de contextos más amplios (o multidisciplinares) relacionados con su área de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001968/2025-26/CB08> a ns1:Competency ;
    ns1:competencyCode "CB08" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de integrar conocimientos y enfrentarse a la complejidad de formular juicios a partir de una información que, siendo incompleta o limitada, incluya reflexiones sobre las responsabilidades sociales y éticas vinculadas a la aplicación de sus conocimientos y juicios"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001968/2025-26/CE02> a ns1:Competency ;
    ns1:competencyCode "CE02" ;
    ns1:competencyDescription "Habilidad para profundizar en los conocimientos relativos a la emisión y dispersión de contaminantes atmosféricos y sus impactos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001968/2025-26/CE04> a ns1:Competency ;
    ns1:competencyCode "CE04" ;
    ns1:competencyDescription "Habilidad para profundizar en conocimientos relativos a la evaluación y gestión del ruido ambiental y aplicar técnicas para su control."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001968/2025-26/CE06> a ns1:Competency ;
    ns1:competencyCode "CE06" ;
    ns1:competencyDescription "Capacidad para aplicar las teorías de diseño sostenible a los procesos de diseño de productos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001968/2025-26/CE07> a ns1:Competency ;
    ns1:competencyCode "CE07" ;
    ns1:competencyDescription "Habilidad para profundizar en el conocimiento del aprovechamiento de los recursos energéticos y sus implicaciones."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001968/2025-26/CE08> a ns1:Competency ;
    ns1:competencyCode "CE08" ;
    ns1:competencyDescription "Capacidad de comprensión y dominio de la legislación y normativa nacional e internacional y su aplicación para la resolución de problemas propios de la ingeniería ambiental."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001968/2025-26/CG06> a ns1:Competency ;
    ns1:competencyCode "CG06" ;
    ns1:competencyDescription "Capacidad para integrar conocimientos procedentes de distintas disciplinas: legales, técnicas, científicas, etc."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001968/2025-26/CT05> a ns1:Competency ;
    ns1:competencyCode "CT05" ;
    ns1:competencyDescription "Resuelve. Habilidad para identificar, formular y resolver problemas de ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001968/2025-26/RA46> a ns1:LearningResult ;
    ns1:learningResultCode "RA46" ;
    ns1:learningResultDescription "Aprender sobre las soluciones técnicas y no técnicas para la reducción del consumo y de emisiones contaminantes, desde sus fuentes de emisión"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001968/2025-26/RA47> a ns1:LearningResult ;
    ns1:learningResultCode "RA47" ;
    ns1:learningResultDescription "Entender las características de los combustibles alternativos y de otras fuentes de energía y su aplicación al transporte, analizando rendimientos y su ciclo de vida"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001968/2025-26/RA48> a ns1:LearningResult ;
    ns1:learningResultCode "RA48" ;
    ns1:learningResultDescription "Conocer el problema energético e impacto medioambiental de los distintos modos de transporte, su legislación y normalización"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001968/2025-26/RA49> a ns1:LearningResult ;
    ns1:learningResultCode "RA49" ;
    ns1:learningResultDescription "Aprender sobre el dimensionamiento de los diferentes trenes de propulsión híbridos y eléctricos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001968/2025-26/RA50> a ns1:LearningResult ;
    ns1:learningResultCode "RA50" ;
    ns1:learningResultDescription "Conocer las tecnologías relacionadas con la electromovilidad urbana e interurbana"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001968/2025-26/RA51> a ns1:LearningResult ;
    ns1:learningResultCode "RA51" ;
    ns1:learningResultDescription "Conocer los principios de funcionamiento de la pila de combustible y del sistema"@es .

