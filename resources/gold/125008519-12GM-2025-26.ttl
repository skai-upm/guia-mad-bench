    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/125008519/2025-26/eventSchedule> ;
    schema:description "Una de las aplicaciones de la topografía, es el diseño y control geométrico de obras civiles, lo que implica el conocimiento de instrumentación y metodología topográfica para llevar a cabo el desarrollo de este tipo de proyectos de construcción. Esta asignatura utiliza y ensambla conocimientos de otras asignaturas de la ingeniería geomática cursadas por los alumnos para aplicarlos en el desarrollo topográfico de una obra de ingeniería."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/enrique.priego%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/angel.navarro%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/enrique.priego%40upm.es> ;
    schema:name "Topografía Aplicada a la Ingeniería Civil"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125008519/2025-26/CG03> a ns1:Competency ;
    ns1:competencyCode "CG03" ;
    ns1:competencyDescription "Comprender los problemas de implantación en el terreno de las infraestructuras, construcciones y edificaciones proyectadas desde las distintas especialidades de la ingeniería, analizar los mismos y proceder a su implantación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125008519/2025-26/CG05> a ns1:Competency ;
    ns1:competencyCode "CG05" ;
    ns1:competencyDescription "Determinar, medir, evaluar y representar el terreno, objetos tridimensionales, puntos y trayectorias"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125008519/2025-26/CG08> a ns1:Competency ;
    ns1:competencyCode "CG08" ;
    ns1:competencyDescription "Planificación, proyecto, dirección, ejecución, y gestión de procesos de medida, sistemas de información, explotación de imágenes, posicionamiento y navegación; modelización, representación y visualización de la información territorial en, bajo y sobre la superficie terrestre"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125008519/2025-26/CT09> a ns1:Competency ;
    ns1:competencyCode "CT09" ;
    ns1:competencyDescription "RESOLUCIÓN DE PROBLEMAS Desarrollar en los alumnos una actitud mental mediante la aplicación de procedimientos estructurados de resolución de problemas que promueva su capacidad de aprender, comprender y aplicar conocimientos de forma autónoma."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125008519/2025-26/RA100> a ns1:LearningResult ;
    ns1:learningResultCode "RA100" ;
    ns1:learningResultDescription "Trazado de carreteras"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125008519/2025-26/RA101> a ns1:LearningResult ;
    ns1:learningResultCode "RA101" ;
    ns1:learningResultDescription "Aplicación de la normativa en el trazado de carreteras (tipo de carretera, enlaces, glorietas¿)"@es .

