    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/juanpedro.brito%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/santiago.tapia%40upm.es> ;
    schema:name "Desarrollo de Aplicaciones Distribuidas en Tiempo Real"@es .

