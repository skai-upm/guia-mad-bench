    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/95000331/2025-26/eventSchedule> ;
    schema:description "La asignatura tiene como objetivo la modelización de mecanismos y esquemas que se corresponden con dispositivos y circuitos biomédicos, a partir del análisis de elementos de comportamiento análogo y su aplicación a diferentes dominios de la física, todo ello con objeto de obtener el sistema de ecuaciones ODE / DAE asociado a un modelo dinámico y su posterior simulación."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/gregorio.romero%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/gregorio.romero%40upm.es> ;
    schema:name "Modelado y Simulación Dinámica Aplicada a la Biomedicina"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000331/2025-26/CG01> a ns1:Competency ;
    ns1:competencyCode "CG01" ;
    ns1:competencyDescription "Desarrollar las habilidades de aprendizaje necesarias para emprender actividades o estudios posteriores de forma autónoma y con confianza."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000331/2025-26/CG06> a ns1:Competency ;
    ns1:competencyCode "CG06" ;
    ns1:competencyDescription "Adoptar una actitud ante los problemas de su competencia que considere que su papel no es exclusivamente aportar soluciones sino, siempre que sea posible, participar además en la propia identificación u definición de dichos problemas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000331/2025-26/CG09> a ns1:Competency ;
    ns1:competencyCode "CG09" ;
    ns1:competencyDescription "Tener capacidad de descripción, cuantificación, análisis y evaluación de resultados experimentales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000331/2025-26/RA190> a ns1:LearningResult ;
    ns1:learningResultCode "RA190" ;
    ns1:learningResultDescription "Conocer los modelos de resolución de sistemas de ecuaciones algebraicas lineales y no lineales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000331/2025-26/RA5> a ns1:LearningResult ;
    ns1:learningResultCode "RA5" ;
    ns1:learningResultDescription "Formular problemas de ingeniería mediante modelos de ecuaciones diferenciales y saber obtener su solución."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000331/2025-26/RA82> a ns1:LearningResult ;
    ns1:learningResultCode "RA82" ;
    ns1:learningResultDescription "Resolución de problemas de álgebra lineal, cálculo diferencial e integral, ecuaciones diferenciales y métodos numéricos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000331/2025-26/RA84> a ns1:LearningResult ;
    ns1:learningResultCode "RA84" ;
    ns1:learningResultDescription "Resolver sistemas de ecuaciones lineales y extraer la información algebraica de ellos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000331/2025-26/RA95> a ns1:LearningResult ;
    ns1:learningResultCode "RA95" ;
    ns1:learningResultDescription "Conocimientos básicos sobre el funcionamiento e interacción de los diferentes sistemas característicos de la fisiología humana."@es .

