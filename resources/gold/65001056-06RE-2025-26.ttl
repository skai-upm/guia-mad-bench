    ns1:inpersonHours "67 horas (42.9%)"@es ;
    ns1:numberOfCredits 6.0 ;
    ns1:otherInformation "La asignatura está relacionada con el ODS 3.9 (reducir sustancialmente el número de muertes y enfermedades producidas por productos químicos peligrosos y la contaminación del aire, el agua y el suelo) y el ODS 12.4 (lograr la gestión ecológicamente racional de los productos químicos y de todos los desechos a lo largo de su ciclo de vida, de conformidad con los marcos internacionales convenidos, y reducir de manera significativa su liberación a la atmósfera, el agua y el suelo a fin de reducir al mínimo sus efectos adversos en la salud humana y el medio ambiente)."@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "67 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/65001056/2025-26/eventSchedule> ;
    schema:description "El objetivo de la asignatura es homogeneizar los conocimientos de química general de alumnos de muy diversa procedencia y proporcionar los conocimientos básicos de química necesarios para abordar los estudios de grado de Ingeniería de los Recursos Energéticos, Combustibles y Explosivos"@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/david.bolonio%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/b.castells%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/david.bolonio%40upm.es>,
