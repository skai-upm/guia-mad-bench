<https://guia-kg.skai.etsisi.upm.es/resource/65001056/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Conocer y aplicar conocimientos de ciencias y tecnologías básicas a la práctica de la Ingeniería de los Recursos Energéticos, Combustibles y Explosivos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001056/2025-26/CG10> a ns1:Competency ;
    ns1:competencyCode "CG10" ;
    ns1:competencyDescription "Creatividad."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001056/2025-26/CG2> a ns1:Competency ;
    ns1:competencyCode "CG2" ;
    ns1:competencyDescription "Poseer capacidad para diseñar, analizar, calcular, proyectar, construir, mantener, conservar, explotar, desarrollar, implementar, gestionar y mejorar productos, sistemas y procesos en los distintos ámbitos de las Tecnologías Mineras, usando técnicas analíticas, computacionales o experimentales apropiadas, incluyendo la función de asesoría en estos campos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001056/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Aplicar los conocimientos adquiridos para identificar, formular y resolver problemas dentro de contextos amplios y multidisciplinarios, siendo capaces de integrar conocimientos, trabajando en equipos multidisciplinares."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001056/2025-26/CG6> a ns1:Competency ;
    ns1:competencyCode "CG6" ;
    ns1:competencyDescription "Poseer habilidades de aprendizaje que permitan continuar estudiando a lo largo de la vida para su adecuado desarrollo profesional."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001056/2025-26/RA220> a ns1:LearningResult ;
    ns1:learningResultCode "RA220" ;
    ns1:learningResultDescription "Aplicar los conocimientos generales de Química a la resolución de problemas relacionados con la Ingeniería en Tecnología Minera."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001056/2025-26/RA221> a ns1:LearningResult ;
    ns1:learningResultCode "RA221" ;
    ns1:learningResultDescription "Aplicar métodos químicos experimentales y deducir resultados de experimentos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001056/2025-26/RA222> a ns1:LearningResult ;
    ns1:learningResultCode "RA222" ;
    ns1:learningResultDescription "Relacionar datos experimentales con teorías y conceptos de química en situaciones sencillas."@es .

