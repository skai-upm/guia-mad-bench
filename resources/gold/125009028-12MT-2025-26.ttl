<https://guia-kg.skai.etsisi.upm.es/resource/125009028/2025-26/CT1> a ns1:Competency ;
    ns1:competencyCode "CT1" ;
    ns1:competencyDescription "COMUNICACIÓN ORAL Y ESCRITA Capacidad para transmitir conocimientos y expresar ideas y argumentos de manera clara, rigurosa y convincente, tanto de forma oral como escrita, utilizando los recursos gráficos y los medios necesarios adecuadamente y adaptándose a las características de la situación y de la audiencia."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125009028/2025-26/CT2> a ns1:Competency ;
    ns1:competencyCode "CT2" ;
    ns1:competencyDescription "USO DE LAS TIC Capacidad sobre conocimientos tecnológicos que permitan desenvolverse cómodamente y así afrontar los retos que la sociedad le va a imponer en su quehacer profesional en permanente autoformación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125009028/2025-26/RA139> a ns1:LearningResult ;
    ns1:learningResultCode "RA139" ;
    ns1:learningResultDescription "Aplicar conocimientos de semiología gráfica al diseño de simbologías para mapas de distintas escalas y propósitos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125009028/2025-26/RA141> a ns1:LearningResult ;
    ns1:learningResultCode "RA141" ;
    ns1:learningResultDescription "Desarrollar capacidades en comunicación gráfica y visualización aplicadas a la Información Geográfica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125009028/2025-26/RA143> a ns1:LearningResult ;
    ns1:learningResultCode "RA143" ;
    ns1:learningResultDescription "Identificar y utilizar las fuentes de información geográfica existentes en procesos de compilación cartográfica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125009028/2025-26/RA183> a ns1:LearningResult ;
    ns1:learningResultCode "RA183" ;
    ns1:learningResultDescription "Conocer las técnicas de representación del relieve. Seleccionar las adecuadas según propósito y escala del mapa."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125009028/2025-26/RA184> a ns1:LearningResult ;
    ns1:learningResultCode "RA184" ;
    ns1:learningResultDescription "Seleccionar y aplicar los modos de color adecuados al dispositivo final. Conocer el proceso de gestión de color en el flujo de producción cartográfica."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125009028/2025-26/RA190> a ns1:LearningResult ;
    ns1:learningResultCode "RA190" ;
    ns1:learningResultDescription "Conocer las principales teorías de la imagen y los procesos de percepción visual."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125009028/2025-26/RA191> a ns1:LearningResult ;
    ns1:learningResultCode "RA191" ;
    ns1:learningResultDescription "Conocer el concepto de generalización cartográfica y su aplicación al diseño de simbologías para mapas multiescala"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125009028/2025-26/RA202> a ns1:LearningResult ;
    ns1:learningResultCode "RA202" ;
    ns1:learningResultDescription "Conocer y aplicar los principios de la gramática visual a la elaboración de imágenes cartográficas adecuadas al mensaje, el medio y el usuario."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125009028/2025-26/RA203> a ns1:LearningResult ;
    ns1:learningResultCode "RA203" ;
    ns1:learningResultDescription "Conocer y aplicar el concepto de jerarquía visual al diseño de imágenes cartográficas así como a la composición de la imagen"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125009028/2025-26/RA204> a ns1:LearningResult ;
    ns1:learningResultCode "RA204" ;
    ns1:learningResultDescription "Proponer sistemas de etiquetado cartográfico coherentes con las clasificaciones de los datos a identificar"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125009028/2025-26/RA205> a ns1:LearningResult ;
    ns1:learningResultCode "RA205" ;
    ns1:learningResultDescription "Proponer sistemas de símbolos cartográficos coherentes con las clasificaciones de los datos a representar"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125009028/2025-26/RA206> a ns1:LearningResult ;
    ns1:learningResultCode "RA206" ;
    ns1:learningResultDescription "Analizar el diseño de interacción en cartografía y el diseño de la interfaz de un sistema cartográfico interactivo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125009028/2025-26/RA207> a ns1:LearningResult ;
    ns1:learningResultCode "RA207" ;
    ns1:learningResultDescription "Comprender los principios de coherencia y consistencia en el diseño de un sistema cartográfico"@es .

