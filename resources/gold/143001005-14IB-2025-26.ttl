    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/143001005/2025-26/eventSchedule> ;
    schema:description "La asignatura trata de proporcionar los conocimientos y capacidades adecuados para la selección y utilización de los Materiales Metálicos y Materiales Compuestos utilizados en la industria aeroespacial así como comprender y realizar los Procesos de Fabricación y Organización de la Producción asociados a dicha industria"@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/antonio.fernandez.lopez%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/antonio.fernandez.lopez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/daniel.barba%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/jm.ezquerro%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/jose.m.menendez%40upm.es>,
