    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Componentes de los circuitos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001013/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Variables eléctricas fundamentales. Simbología. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001013/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "2.2. Representación vectorial de las magnitudes eléctricas. Impedancia y admitancia complejas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001013/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "2.3. Potencia en circuitos eléctricos en corriente alterna. Conceptos de potencia activa, reactiva y aparente. Factor de potencia y su compensación. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001013/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "2.4. Planteamiento y resolución de circuitos en corriente alterna. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001013/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "2.5. Medida de magnitudes eléctricas. Medida de potencia y de la energía eléctrica. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001013/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "2.6. Efectos térmicos de la electricidad, modelo matemático: interpretación y aplicación. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001013/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "3. Circuitos trifásicos"@es .

