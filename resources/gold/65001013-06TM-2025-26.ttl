    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/65001013/2025-26/eventSchedule> ;
    schema:description """Esta asignatura tiene como finalidad proporcionar al alumno los conocimientos básicos sobre instalaciones eléctricas y las herramientas necesarias para su dimensionamiento y cálculo.
Se parte del aprendizaje de la teoría de circuitos para aplicarlo al estudio básico e introductorios de máquinas e instalaciones eléctricas, desde la generación al consumo, incluyendo cálculos de instalaciones simples en el marco de la reglamentación aplicable."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/eduardo.conde%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/daniel.serrano.jimenez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/eduardo.conde%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/luisjavier.sanjose%40upm.es> ;
    schema:name "Electrotecnia"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001013/2025-26/CG%201> a ns1:Competency ;
    ns1:competencyCode "CG 1" ;
    ns1:competencyDescription "Conocer y aplicar conocimientos de ciencias y tecnologías básicas a la práctica de la Tecnología Minera."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001013/2025-26/CG%202> a ns1:Competency ;
    ns1:competencyCode "CG 2" ;
    ns1:competencyDescription "Poseer capacidad para diseñar, analizar, calcular, proyectar, construir, mantener, conservar, explotar, desarrollar, implementar, gestionar y mejorar productos, sistemas y procesos en los distintos ámbitos de las Tecnologías Mineras, usando técnicas analíticas, computacionales o experimentales apropiadas, incluyendo la función de asesoría en estos campos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001013/2025-26/CG%203> a ns1:Competency ;
    ns1:competencyCode "CG 3" ;
    ns1:competencyDescription "Aplicar los conocimientos adquiridos para identificar, formular y resolver problemas dentro de contextos amplios y multidisciplinarios, siendo capaces de integrar conocimientos, trabajando en equipos multidisciplinares."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001013/2025-26/CG%206> a ns1:Competency ;
    ns1:competencyCode "CG 6" ;
    ns1:competencyDescription "Poseer habilidades de aprendizaje que permitan continuar estudiando a lo largo de la vida para su adecuado desarrollo profesional"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001013/2025-26/CG%207> a ns1:Competency ;
    ns1:competencyCode "CG 7" ;
    ns1:competencyDescription "Incorporar nuevas tecnologías y herramientas de la ingeniería en tecnología minera en sus actividades profesionales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001013/2025-26/F17> a ns1:Competency ;
    ns1:competencyCode "F17" ;
    ns1:competencyDescription "Conocimientos fundamentales sobre el sistema eléctrico de potencia: generación de energía, red de transporte, reparto y distribución, así como sobre tipos de líneas y conductores. Conocimiento de la normativa sobre baja y alta tensión. Conocimiento de electrónica básica y sistemas de control."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001013/2025-26/RA74> a ns1:LearningResult ;
    ns1:learningResultCode "RA74" ;
    ns1:learningResultDescription "Comprender los fundamentos del sistema eléctrico de potencia"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001013/2025-26/RA75> a ns1:LearningResult ;
    ns1:learningResultCode "RA75" ;
    ns1:learningResultDescription "Plantear las ecuaciones de los sistemas eléctricos y resolverlas en diversos regímenes de funcionamiento"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001013/2025-26/RA76> a ns1:LearningResult ;
