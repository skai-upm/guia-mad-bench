    ns1:learningResultDescription "Calcular flujos de potencia y energía de circuitos eléctricos en régimen armónico senoidal"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001013/2025-26/RA77> a ns1:LearningResult ;
    ns1:learningResultCode "RA77" ;
    ns1:learningResultDescription "Comprender el funcionamiento y la aplicación de las máquinas eléctricas: transformadores y motores"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001013/2025-26/RA78> a ns1:LearningResult ;
