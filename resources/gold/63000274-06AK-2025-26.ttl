    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Explosive-rock interaction. II: Mechanisms of rock fragmentation / La interacción explosivo-roca. II: Mecanismos de fragmentación de la roca Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000274/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "1.3. Particle size distributions / Distribuciones granulométricas Sin subniveles"@es .

