    ns1:itemIndex 12 ;
    ns1:syllabusDescription "3.2. Airblast and safety engineering / Onda aérea e ingeniería de seguridad Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000274/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "3.3. Detonation products. Carbon footprint and life cycle of blasting / Productos de detonación. Huella de carbono y ciclo de vida de la voladura Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000274/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "4. Downstream impact of blasting in the overall mine operation: Mine-to-mill optimization / La voladura en la operación minera: Optimización mina-planta"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000274/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "4.1. Rock damage and wall control / Daño a la roca y control del talud Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000274/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "4.2. Ore dilution control / Control de dilución del mineral Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000274/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "4.3. Mine-to-plant optimization / Optimización de la operación mina-planta Sin subniveles"@es .

