    ns1:bibliographyTitle "Equipos de medida y análisis de voladuras (II)"@es ;
    ns1:bibliographyType "Equipamiento"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000274/2025-26/didactic_resource/8> a ns1:DidacticResource ;
    ns1:bibliographyDescription """- Blastmetrix + Shapemetrix 3GSM software suite
- JK-Simblast.
- I-Blast 6
- Face 3D.
- Blastware.
