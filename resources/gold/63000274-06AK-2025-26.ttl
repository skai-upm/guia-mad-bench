    ns1:itemIndex 6 ;
    ns1:syllabusDescription "2. Blast design and control. Field lab and design tools / Diseño de voladuras. Laboratorio en campo y herramientas de diseño"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000274/2025-26/syllabus/7> a ns1:SyllabusItem ;
