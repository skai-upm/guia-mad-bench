<https://guia-kg.skai.etsisi.upm.es/resource/63000274/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Fragmentation by blasting / Fragmentación por voladura"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000274/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Explosive-rock interaction: I: Principles of explosive behavior / La interacción explosivo-roca. I: Principios de funcionamiento de los explosivos Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000274/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "3. Monitoring, control and mitigation of the environmental impact of blasting / Métodos de medida, control y mitigación del impacto ambiental de la voladura"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/63000274/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "3.1. Vibrations / Vibraciones Sin subniveles"@es .

