    schema:courseCode 55000657 ;
    schema:hasCourseInstance <https://guia-kg.skai.etsisi.upm.es/resource/55000657/2025-26> ;
    schema:name "Communications Technology"@en,
        "Tecnologías de las Comunicaciones"@es ;
    schema:numberOfCredits 3.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/55000657/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/55000657/2025-26/CE24>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55000657/2025-26/CG1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55000657/2025-26/CG2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55000657/2025-26/CG3>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55000657/2025-26/CG5>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55000657/2025-26/CG6> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/55000657/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55000657/2025-26/didactic_resource/2> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/55000657/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/55000657/2025-26/RA109>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55000657/2025-26/RA110> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/55000657/2025-26/syllabus> ;
    ns1:inpersonHours "32 horas (41%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation ""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "34 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/55000657/2025-26/eventSchedule> ;
    schema:description "Esta asignatura trata sobre las tecnologías necesarias para la transmisión de datos y las comunicaciones. Se estructura en tres módulos principales. El primero de ellos está dedicado a la transmisión de datos, y aborda aspectos como las modulaciones, la codificación o la multiplexación para el acceso a medios compartidos. El segundo módulo aborda las redes de ordenadores, principalmente ethernet y los protocolos TCP e IP. El último módulo describe sistemas de comunicaciones específicos, tanto sistemas muy consolidados como el 3G o el 4G para comunicaciones móviles, como otros más avanzados, como el 5G. Se aborda en este tema, de manera especifica, sistemas habilitadores de muchas aplicaciones, como el RFID y los sistemas de posicionamiento basados en satélites."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/alfonso.rodriguezm%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/alfonso.rodriguezm%40upm.es> ;
    schema:name "Tecnologías de las Comunicaciones"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000657/2025-26/CE24> a ns1:Competency ;
    ns1:competencyCode "CE24" ;
    ns1:competencyDescription "Conocimientos generales Modelo OSI de comunicaciones. Redes Ethernet. TCP/IP. Servicios de Internet. Redes móviles. Redes locales inalámbricas. Identificación electrónica. Aplicaciones de las micro, bio y nanotecnologías."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000657/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Conocer y aplicar conocimientos de ciencias y tecnologías básicas a la práctica de la Ingeniería de organización"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000657/2025-26/CG2> a ns1:Competency ;
    ns1:competencyCode "CG2" ;
    ns1:competencyDescription "Poseer capacidad para diseñar, desarrollar, implementar, gestionar y mejorar productos, sistemas y procesos en los distintos ámbitos industriales, usando técnicas analíticas, computacionales o experimentales apropiadas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000657/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Aplicar los conocimientos adquiridos para identificar, formular y resolver problemas dentro de contextos amplios y multidisciplinarios, siendo capaces de integrar conocimientos, trabajando en equipos multidisciplinarios."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000657/2025-26/CG5> a ns1:Competency ;
    ns1:competencyCode "CG5" ;
    ns1:competencyDescription "Saber comunicar los conocimientos y conclusiones, tanto de forma oral, escrita y gráfica, a públicos especializados y no especializados de un modo claro y sin ambigüedades"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000657/2025-26/CG6> a ns1:Competency ;
    ns1:competencyCode "CG6" ;
    ns1:competencyDescription "Poseer habilidades de aprendizaje que permitan continuar estudiando a lo largo de la vida para su adecuado desarrollo profesional"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000657/2025-26/RA109> a ns1:LearningResult ;
    ns1:learningResultCode "RA109" ;
    ns1:learningResultDescription "Conocer los aspectos básicos de las redes de comunicaciones y los principales estándares"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000657/2025-26/RA110> a ns1:LearningResult ;
    ns1:learningResultCode "RA110" ;
    ns1:learningResultDescription "Valorar las semejanzas y diferencias para tener criterios de selección entre diversas redes de comunicaciones"@es .

