<https://guia-kg.skai.etsisi.upm.es/resource/115100003/2025-26/CE01> a ns1:Competency ;
    ns1:competencyCode "CE01" ;
    ns1:competencyDescription "Diseñar, desarrollar y evaluar los procesos de enseñanza¿aprendizaje relativos a la actividad física y el deporte con atención a las características individuales y contextuales de las personas. Nivel 3."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100003/2025-26/CE24> a ns1:Competency ;
    ns1:competencyCode "CE24" ;
    ns1:competencyDescription "Elaborar y comunicar, de manera crítica y fundamentada, argumentos y juicios sobre el valor de la actividad física y el deporte, y sobre sus posibilidades de contribuir al desarrollo y bienestar de las personas y de la sociedad, y al desarrollo sostenible, así como sobre su especial relación con la salud y la calidad de vida. Nivel 3."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100003/2025-26/CE25> a ns1:Competency ;
    ns1:competencyCode "CE25" ;
    ns1:competencyDescription "Analizar e interpretar los diferentes estudios referidos a las prácticas de actividad físico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100003/2025-26/CG14> a ns1:Competency ;
    ns1:competencyCode "CG14" ;
    ns1:competencyDescription "Utilizar y aplicar las tecnologías de la información y comunicación (TIC) al ámbito de las Ciencias de la Actividad Física y del Deporte, usando las principales fuentes de información científica disponibles."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100003/2025-26/CG16> a ns1:Competency ;
    ns1:competencyCode "CG16" ;
    ns1:competencyDescription "Desarrollar la conciencia de respeto e igualdad entre géneros, igualdad democrática y atención a la diversidad, como principios éticos necesarios para el correcto ejercicio profesional en las Ciencias de la Actividad Física y del Deporte."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100003/2025-26/RA10> a ns1:LearningResult ;
    ns1:learningResultCode "RA10" ;
    ns1:learningResultDescription "Actitudes flexibles y capacidad de adaptación en una sociedad en constante evolución"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100003/2025-26/RA13> a ns1:LearningResult ;
    ns1:learningResultCode "RA13" ;
    ns1:learningResultDescription "Asimilar los conocimientos teóricos desarrollando herramientas prácticas que sean de uso cotidiano en la actividad profesional del graduado, sin olvidar el carácter integrado de la respuesta conductual humana"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100003/2025-26/RA3> a ns1:LearningResult ;
    ns1:learningResultCode "RA3" ;
    ns1:learningResultDescription "Capacidad de análisis de las estructuras y sistemas del movimiento físico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100003/2025-26/RA31> a ns1:LearningResult ;
    ns1:learningResultCode "RA31" ;
    ns1:learningResultDescription "Comprender la importancia dela competición y adaptación de las reglas para el proceso formativo y desarrollo de valores"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100003/2025-26/RA310> a ns1:LearningResult ;
    ns1:learningResultCode "RA310" ;
    ns1:learningResultDescription "Aplicar los principios básicos adquiridos en los módulos de Ciencias Sociales y Ciencias de la Salud a las actividades físico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100003/2025-26/RA311> a ns1:LearningResult ;
    ns1:learningResultCode "RA311" ;
    ns1:learningResultDescription "Diseño de propuestas de enseñanza"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100003/2025-26/RA312> a ns1:LearningResult ;
    ns1:learningResultCode "RA312" ;
    ns1:learningResultDescription "Aplicar las habilidades físicas básicas a la acción educativa en educación física y deporte"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100003/2025-26/RA4> a ns1:LearningResult ;
    ns1:learningResultCode "RA4" ;
    ns1:learningResultDescription "Conocimiento de los sistemas y bases del funcionamiento del cuerpo humano"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100003/2025-26/RA9> a ns1:LearningResult ;
    ns1:learningResultCode "RA9" ;
    ns1:learningResultDescription "Capacidad de trabajar en equipo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100003/2025-26/RA99> a ns1:LearningResult ;
    ns1:learningResultCode "RA99" ;
    ns1:learningResultDescription "Poner en práctica habilidades de expresión y comunicación oral y escrita en el contexto profesional"@es .

