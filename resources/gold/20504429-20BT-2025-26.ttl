        <https://guia-kg.skai.etsisi.upm.es/resource/20504429/2025-26/syllabus/5>,
        <https://guia-kg.skai.etsisi.upm.es/resource/20504429/2025-26/syllabus/6>,
        <https://guia-kg.skai.etsisi.upm.es/resource/20504429/2025-26/syllabus/7>,
        <https://guia-kg.skai.etsisi.upm.es/resource/20504429/2025-26/syllabus/8>,
        <https://guia-kg.skai.etsisi.upm.es/resource/20504429/2025-26/syllabus/9> .

<https://guia-kg.skai.etsisi.upm.es/resource/20504429/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. 1. INTRODUCCIÓN A LA INGENIERÍA DE TEJIDOS. Conceptos básicos y dianas para su aplicación Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504429/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "2. 2. INTERFAZ MATERIAL-SISTEMA BIOLÓGICO. Reacción del cuerpo a los materiales. Paradigma de Biocompatibilidad. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504429/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "11. 10. APLICACIONES DE LA INGENIERÍA DE TEJIDOS: REGENERACIÓN DE LA PIEL. Anatomía y fisiologia de la piel. Estrategias en Ingeniería de Tejidos para la regeneración de piel. Aplicaciones clínicas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504429/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "12. 11. INTERACCIÓN ENTRE LA SANGRE Y LOS BIOMATERIALES.Angiogénesis. Vascularización. Aplicaciones en Ingeniería de Tejidos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504429/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "3. 3. ARQUITECTURA MOLECULAR Y MICROESTRUCTURAS JERARQUIZADAS. Definición de arquitectura molecular. Autoensamblaje. Microestructura jerarquizada. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504429/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "4. 4. BIOFUNCIONALIZACIÓN. Agentes entrecruzanes. Fluoróforos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504429/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "5. 5. CÉLULAS MADRE Y REGENERACIÓN. Propiedades de las células madre. Células madre embrionarias. Células madre adultas.Mecanismos de regeneración. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504429/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "6. 6. INGENIERÍA DE TEJIDOS Y BIOTECNOLOGÍA REGENERATIVA. Estrategias de sembrado celular. Mantenimiento e implante de las células en Ingeniería de Tejidos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504429/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "7. 6. MATRIZ EXTRACELULAR. Definición de matriz extracelular. Elementos constituyentes de la matriz extracelular. Tejido conjuntivo y tejido epitelial. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504429/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "8. 7. INTERACCIONES CÉLULA-CÉLULA Y CÉLULA-MATRIZ EXTRACELULAR. Tipos de uniones entre la célula y su entorno. Proteínas que intervienen en las interacciones celulares con su entorno. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504429/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "9. 8. COMPORTAMIENTO MECÁNICO DE LOS TEJIDOS. Comportamiento elástico. Estructura jerarquizada de los materiales biológicos. Comportamiento viscoelástico. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504429/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "10. 9. ANDAMIOS TISULARES: MATERIALES Y PROCESADO. Materiales empleados en Ingeniería de Tejidos. Técnicas de procesamiento de materiales en Ingeniería de Tejidos. Funcionalización. Sin subniveles"@es .

