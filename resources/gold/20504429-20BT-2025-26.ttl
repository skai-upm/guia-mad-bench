        <https://guia-kg.skai.etsisi.upm.es/resource/20504429/2025-26/syllabus/11>,
        <https://guia-kg.skai.etsisi.upm.es/resource/20504429/2025-26/syllabus/2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/20504429/2025-26/syllabus/3>,
