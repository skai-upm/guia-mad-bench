<https://guia-kg.skai.etsisi.upm.es/resource/145009002/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "3.7. 3.7. Definir condiciones de contorno. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145009002/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "3.8. 3.8. Monitorización del cálculo. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145009002/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "3.9. 3.9. Métodos de cálculo y controles de la solución.. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145009002/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "3.10. 3.9. Cálculo y análisis de resultados. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145009002/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "3.11. 3.11. Adaptación de la malla. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145009002/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "3.12. 3.12. Postproceso."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145009002/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "2. Tema 2. PREPROCESO. CREACIÓN DE GEOMETRÍA Y MALLADO."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145009002/2025-26/syllabus/20> a ns1:SyllabusItem ;
    ns1:itemIndex 20 ;
    ns1:syllabusDescription "3.12.1. Visualización de los valores de las propiedades del fluido. Vectores de velocidad. Líneas de corriente. Resultante de fuerzas y momentos Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145009002/2025-26/syllabus/21> a ns1:SyllabusItem ;
    ns1:itemIndex 21 ;
    ns1:syllabusDescription "3.13. Turbulencia. ¿Qué es? y su tratamiento."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145009002/2025-26/syllabus/22> a ns1:SyllabusItem ;
    ns1:itemIndex 22 ;
    ns1:syllabusDescription "3.13.1. Introducción. Clasificación del movimiento. Efecto de la viscosidad. ¿Qué es la turbulencia?. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145009002/2025-26/syllabus/23> a ns1:SyllabusItem ;
    ns1:itemIndex 23 ;
    ns1:syllabusDescription "3.13.2. Descripción de la turbulencia. Cascada de energía. Escalas. Métodos de predicción de la turbulencia. DNS, RANS y LES. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145009002/2025-26/syllabus/24> a ns1:SyllabusItem ;
    ns1:itemIndex 24 ;
    ns1:syllabusDescription "3.13.3. DNS (Direct Numerical Simulation). Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145009002/2025-26/syllabus/25> a ns1:SyllabusItem ;
    ns1:itemIndex 25 ;
    ns1:syllabusDescription "3.13.4. RANS (Reynolds Averaged Navier-Stokes). Boussinesq. Una-Ecuación: Spalart-Allmaras. Dos-Ecuaciones: k-? (Standard, RNG y Realizable), k-?, k-L. RSM (Reynolds Stress Modeling). Modelizado cerca de la pared. Función de pared, Dos-Zonas, Bajo-Re. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145009002/2025-26/syllabus/26> a ns1:SyllabusItem ;
    ns1:itemIndex 26 ;
    ns1:syllabusDescription "3.13.5. LES (Large Eddy Simulation). Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145009002/2025-26/syllabus/27> a ns1:SyllabusItem ;
    ns1:itemIndex 27 ;
    ns1:syllabusDescription "4. Tema 4. CONVECCIÓN NATURAL. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145009002/2025-26/syllabus/28> a ns1:SyllabusItem ;
    ns1:itemIndex 28 ;
    ns1:syllabusDescription "5. Tema 5. ESTUDIO DE PROBLEMAS NO ESTACIONARIOS. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145009002/2025-26/syllabus/29> a ns1:SyllabusItem ;
    ns1:itemIndex 29 ;
    ns1:syllabusDescription "6. Tema 6. ESTUDIO DE UN PERFIL AERODINÁMICO. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145009002/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "2.1. 2.1. Introducción. Proceso de trabajo en CFD (Computational Fluid Dynamics). Entorno de trabajo en ANSYS (Workbench). Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145009002/2025-26/syllabus/30> a ns1:SyllabusItem ;
    ns1:itemIndex 30 ;
    ns1:syllabusDescription "7. Tema 7. ESTUDIO CON GEOMETRíA MÓVIL. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145009002/2025-26/syllabus/31> a ns1:SyllabusItem ;
    ns1:itemIndex 31 ;
    ns1:syllabusDescription "8. Tema 8. DISEÑO DE EXPERIMENTOS Y OPTIMIZACIÓN Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145009002/2025-26/syllabus/32> a ns1:SyllabusItem ;
    ns1:itemIndex 32 ;
    ns1:syllabusDescription "9. Tema 9. ESTUDIO DE UN AVIÓN. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145009002/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "2.2. 2.2. Diseño (DesignModeler). Interfase de usuario (GUI). Pantalla, ratón, selección de entidades. Modelado 2D. Sketcher. Geometría 2D, restricciones, dimensiones. Modelado 3D. Cuerpos 3D, operaciones entre cuerpos, primitivas, geometría para fluidos Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145009002/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "2.3. 2.3. Mallado (Meshing). Discretización del fluido. Tipos de celdas, tipos de mallas, nomenclatura. Métodos de mallado 2D. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145009002/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "2.4. 2.4. Métodos de Mallado 3D. Control de la malla, Control local de la malla. Estadísticas. Número de elementos, calidad de la malla. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145009002/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "3. Tema 3. CÁLCULO."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145009002/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "3.1. 3.1. Capacidades y aplicaciones del programa FLUENT Interface de usuario. Planificación del análisis con FLUENT. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145009002/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "3.2. 3.2. Mallado: Leer y chequear la malla. Suavizar y modificar la malla. Sin subniveles"@es .

