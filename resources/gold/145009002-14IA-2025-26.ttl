<https://guia-kg.skai.etsisi.upm.es/resource/145009002/2025-26/didactic_resource/2> a ns1:DidacticResource ;
    ns1:bibliographyDescription "Fundamental"@es ;
    ns1:bibliographyTitle "Guiones de ejercicios."@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145009002/2025-26/didactic_resource/3> a ns1:DidacticResource ;
    ns1:bibliographyDescription "Texto muy completo y actualizado de CFD."@es ;
    ns1:bibliographyTitle "JIYUAN TU, GUAN HENG YEOH Y CHAOQUN LIU. ELSEVIER. \"Computational Fluid Dynamics. A Practical Approach\". 2008."@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145009002/2025-26/didactic_resource/4> a ns1:DidacticResource ;
    ns1:bibliographyDescription "Texto muy práctico de la aplicación de los métodos numéricos en la resolución de problemas aerodinámicos"@es ;
    ns1:bibliographyTitle "FERNANDO GANDÍA, J. GONZALO, X. MARGOT Y J. MESEGUER. \"Fundamentos de los Métodos Numéricos en Aerodinámica\". Ed. Gaceta, 1ª edición, 2013."@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145009002/2025-26/didactic_resource/5> a ns1:DidacticResource ;
    ns1:bibliographyDescription "Texto de referencia de conocimientos básicos de aerodinámica."@es ;
    ns1:bibliographyTitle "JOSÉ MESEGUER Y ÁNGEL SANZ. \"Aerodinámica Básica\". Gaceta, 2ª edición, 2010."@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145009002/2025-26/didactic_resource/6> a ns1:DidacticResource ;
    ns1:bibliographyDescription "Texto complementario de fundamentos de aerodinámica"@es ;
    ns1:bibliographyTitle "JOHN D. ANDERSON, JR. \"Fundamentals of Aerodynamics\". Ed. Mc Graw-Hill, 2ª edición, 1999."@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145009002/2025-26/didactic_resource/7> a ns1:DidacticResource ;
    ns1:bibliographyDescription "Texto práctico de para la resolución de problemas aerodinámicos."@es ;
    ns1:bibliographyTitle "JOHN J. BERTIN, MICHEL L. SMITH. \"Aerodynamics for Engineers\". Ed. Mc Graw-Hill."@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145009002/2025-26/didactic_resource/8> a ns1:DidacticResource ;
    ns1:bibliographyDescription "Texto que recopila las distintas formas de abordar problemas aerodinámicos a baja velocidad."@es ;
    ns1:bibliographyTitle "KATZ AND PLOTKIN. \"Low-Speed Aerodynamics, From Wind Theory to Panel Methods\". Ed. Mc Graw-Hill, 1991."@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145009002/2025-26/didactic_resource/9> a ns1:DidacticResource ;
    ns1:bibliographyDescription "Texto muy completo y variado de mecánica de fluidos."@es ;
    ns1:bibliographyTitle "P. GERHART, R. GROSS, J. HOCHSTEIN. \"Fundamentos de Mecánica de Fluidos\". Ed. Addison-Wesley Iberomericana, 2ª edición, 1995."@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145009002/2025-26/evaluation> a ns1:EvaluationSystem ;
    ns1:evaluationDescription """Se establecerá una evaluación progresiva en la cual se consideran los trabajos personales individualizados. Los trabajos individualizados resueltos satisfactoriamente, son de obligado cumplimiento.

Se evaluarán los trabajos realizados durante el curso, así como el trabajo final de la asignatura.

Sistema de calificación de la asignatura:
La calificación obtenida por el alumno será la siguiente: NF = 0,2 TC + 0,8 TF, dónde:
NF: Nota Final,.
TC: Nota media de los Trabajos realizados durante el Curso.
TF: Nota del Trabajo Final."""@es ;
