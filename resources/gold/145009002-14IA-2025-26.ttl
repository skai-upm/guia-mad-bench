    ns1:numberOfCredits 6.0 ;
    ns1:otherInformation """Si procede, EL NÚMERO MÁXIMO DE ALUMNOS QUE PUEDEN CURSAR LA ASIGNATURA ES: 20
Tipo de aula: Aula de informática con 20 puestos con PC + PC profesor.
Horario prioritario: martes y jueves de 8:30 a 10:30, por compatibilidad de los profesores con docencia de otras asignaturas."""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "61 horas y 30 minutos"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/145009002/2025-26/eventSchedule> ;
    schema:description "Aplicación de métodos numéricos, mediante la resolución numérica de las ecuaciones de Navier-Stokes, para resolver problemas de aerodinámica, mediante la herramienta ANSYS-Fluent."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/rodolfo.sant%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/alejandro.martinezcava%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/angel.sanz.andres%40upm.es>,
