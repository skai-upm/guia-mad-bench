        <https://guia-kg.skai.etsisi.upm.es/resource/rodolfo.sant%40upm.es> ;
    schema:name "Aplicacion Practica de Aerodinamica Computacional (Ansys-Fluent)"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145009002/2025-26/CE03> a ns1:Competency ;
    ns1:competencyCode "CE03" ;
    ns1:competencyDescription "Conocimientos básicos sobre el uso y programación de los ordenadores, sistemas operativos, bases de datos y programas informáticos con aplicación en ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145009002/2025-26/CE24> a ns1:Competency ;
    ns1:competencyCode "CE24" ;
    ns1:competencyDescription "Conocimiento adecuado y aplicado a la Ingeniería de: Los fundamentos de la mecánica de fluidos que describen el flujo en todos los regímenes, para determinar las distribuciones de presiones y las fuerzas sobre las aeronaves."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145009002/2025-26/CE28> a ns1:Competency ;
    ns1:competencyCode "CE28" ;
    ns1:competencyDescription "Conocimiento aplicado de: aerodinámica; mecánica y termodinámica, mecánica del vuelo, ingeniería de aeronaves (ala fija y alas rotatorias), teoría de estructuras."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145009002/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Capacidad para identificar y resolver problemas aplicando, con creatividad, los conocimientos adquiridos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145009002/2025-26/CG9> a ns1:Competency ;
    ns1:competencyCode "CG9" ;
    ns1:competencyDescription "Razonamiento crítico y capacidad de asociación que posibiliten el aprendizaje continuo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145009002/2025-26/RA10> a ns1:LearningResult ;
    ns1:learningResultCode "RA10" ;
    ns1:learningResultDescription "Conocimiento y comprensión de la Aerodinámica de las aeronaves."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145009002/2025-26/RA214> a ns1:LearningResult ;
    ns1:learningResultCode "RA214" ;
    ns1:learningResultDescription "Redactar informes técnicos y hacer exposiciones orales técnicas relacionadas con lo anterior."@es .

