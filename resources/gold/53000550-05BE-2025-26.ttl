    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/53000550/2025-26/eventSchedule> ;
    schema:description """1.- Introducción. Nomenclatura y conceptos fundamentales
2.- Circuitos en régimen permanente y transitorio
3.- Circuitos trifásicos desequilibrados. Componentes simétricas
4.- Modelos de los componentes de los sistemas de energía eléctrica
5.- Flujos de cargas
6.- Cortocircuitos
7.- Estabilidad
8.- Estimación de estado
9.- Control"""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/angel.gprieto%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/angel.gprieto%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/roberto.loiero%40upm.es> ;
    schema:name "Analisis de Sistemas Electricos de Potencia"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000550/2025-26/CE07> a ns1:Competency ;
    ns1:competencyCode "CE07" ;
    ns1:competencyDescription "Aplicar los conocimientos adquiridos para analizar los sistemas eléctricos en las condiciones de pérdida de estabilidad y las medidas correctoras necesarias."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000550/2025-26/CG01> a ns1:Competency ;
    ns1:competencyCode "CG01" ;
    ns1:competencyDescription "Haber demostrado unos conocimientos y una comprensión que se basa en el nivel típicamente asociado a los grados y lo superan y mejoran y que les proporcionan una base o una oportunidad para la originalidad en el desarrollo i/o aplicación de ideas, a menudo en el contexto de la Investigación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000550/2025-26/CG02> a ns1:Competency ;
    ns1:competencyCode "CG02" ;
    ns1:competencyDescription "Ser capaces de aplicar sus conocimientos y su comprensión, así como sus habilidades para resolver problemas, en entornos nuevos o no familiares y en contextos amplios (multidisciplinarios) relativos a su campo de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000550/2025-26/CG03> a ns1:Competency ;
    ns1:competencyCode "CG03" ;
    ns1:competencyDescription "Tener habilidad de integrar conocimientos y de afrontar la complejidad y también de formular juicios a partir de información incompleta o limitada, pero que incluye reflexiones sobre las responsabilidades sociales y éticas ligadas a la aplicación de sus conocimientos y juicios"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000550/2025-26/CG05> a ns1:Competency ;
    ns1:competencyCode "CG05" ;
    ns1:competencyDescription "Haber desarrollado habilidades de aprendizaje que les permitan continuar los estudios de manera ampliamente autodirigida o autónoma"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000550/2025-26/CT01> a ns1:Competency ;
    ns1:competencyCode "CT01" ;
    ns1:competencyDescription "Uso de la lengua inglesa"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000550/2025-26/CT04> a ns1:Competency ;
    ns1:competencyCode "CT04" ;
    ns1:competencyDescription "Organización y planificación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000550/2025-26/CT07> a ns1:Competency ;
    ns1:competencyCode "CT07" ;
    ns1:competencyDescription "Trabajo en contextos internacionales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000550/2025-26/RA1> a ns1:LearningResult ;
    ns1:learningResultCode "RA1" ;
    ns1:learningResultDescription "Utilizar los conocimientos adquiridos altamente especializados en el análisis de sistemas eléctricos de potencia como base para afrontar problemas nuevos, complejos o de investigación en dicho campo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000550/2025-26/RA2> a ns1:LearningResult ;
    ns1:learningResultCode "RA2" ;
    ns1:learningResultDescription "Valorar con conciencia crítica cuestiones relacionadas con el análisis de sistemas de energía eléctrica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000550/2025-26/RA3> a ns1:LearningResult ;
    ns1:learningResultCode "RA3" ;
    ns1:learningResultDescription "Resolver problemas de innovación o investigación en el desarrollo de nuevos conocimientos y procedimientos en el análisis de sistemas eléctricos de potencia"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000550/2025-26/RA4> a ns1:LearningResult ;
    ns1:learningResultCode "RA4" ;
    ns1:learningResultDescription "Gestionar y transformar contextos de trabajo o estudio complejos, imprevisibles y que requieran nuevos planteamientos en el ámbito del análisis de los sistemas de energía eléctrica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000550/2025-26/RA5> a ns1:LearningResult ;
    ns1:learningResultCode "RA5" ;
    ns1:learningResultDescription "Asumir responsabilidades en lo que respecta al desarrollo de conocimientos y/o prácticas profesionales relacionadas con los sistemas eléctricos de potencia."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000550/2025-26/didactic_resource/1> a ns1:DidacticResource ;
    ns1:bibliographyDescription """Libro de texto básico.
Existe una versión en español: J.J. Grainger, W.D. Stevenson Jr., Análisis de Sistemas de Potencia, McGraw-Hill, 1996."""@es ;
    ns1:bibliographyTitle "J.J. Grainger, W.D. Stevenson Jr., Power System Analysis, McGraw-Hill, 1994."@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000550/2025-26/didactic_resource/2> a ns1:DidacticResource ;
    ns1:bibliographyTitle "A.J. Wood, B.F. Wollenberg, G.B. Sheble, Power Generation, Operation and Control, 3rd Ed., Wiley, 2013."@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000550/2025-26/didactic_resource/3> a ns1:DidacticResource ;
    ns1:bibliographyTitle "D. Glover, M. Sarma, T. Overbye, Power System Analysis and Design, Thomson, Fifth Ed., 2011."@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000550/2025-26/didactic_resource/4> a ns1:DidacticResource ;
    ns1:bibliographyTitle "A. Gómez Expósito, Análisis y operación de sistemas de energía eléctrica, McGraw-Hill, 2002."@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000550/2025-26/didactic_resource/5> a ns1:DidacticResource ;
    ns1:bibliographyDescription "Repositorio con diversos documentos: guiones de prácticas, ejercicios, exámenes de cursos anteriores, etc."@es ;
    ns1:bibliographyTitle "AulaWeb"@es ;
    ns1:bibliographyType "Recursos web"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000550/2025-26/evaluation> a ns1:EvaluationSystem ;
    ns1:evaluationDescription """1. Prácticas de laboratorio (30%)
Es obligatoria la realización de las prácticas en el laboratorio durante el periodo docente, la posterior presentación de los correspondientes informes y la obtención de una calificación superior a 5 sobre 10 en todos ellos. El cumplimiento de todo lo anterior supone la superación de la actividad de prácticas de laboratorio. Dicha superación será válida para la convocatoria ordinaria. En caso de no haber asistido a alguna de las sesiones de laboratorio y no haber alcanzado la nota mínima de 5 en la calificación de los informes, la calificación total de la asignatura quedará truncada a 4,5 si fuera superior.

2. Pruebas de evaluación (70%)
Prueba de evaluación global (presencial y escrita): en periodo de exámenes (ver fecha en POD). Sobre la totalidad de la asignatura. Su peso sobre la calificación final de la asignatura es del 70%.

3. Prueba de evaluación extraordinaria (100%)
Prueba de evaluación global (presencial y escrita): en periodo de exámenes (ver fecha en POD). Sobre la totalidad de la asignatura. Su peso sobre la calificación final de la asignatura es del 100%."""@es ;
    ns1:hasEvaluationTrial <https://guia-kg.skai.etsisi.upm.es/resource/53000550/2025-26/evaluation/trial1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53000550/2025-26/evaluation/trial2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53000550/2025-26/evaluation/trial3>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53000550/2025-26/evaluation/trial4>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53000550/2025-26/evaluation/trial5> .

