<https://guia-kg.skai.etsisi.upm.es/resource/133000207> a ns1:Course ;
    ns1:courseType "Optativa"@es ;
    ns1:courseYear 2 ;
    ns1:semester "Tercer semestre"@es ;
    schema:courseCode 133000207 ;
    schema:hasCourseInstance <https://guia-kg.skai.etsisi.upm.es/resource/133000207/2025-26> ;
    schema:name "Technological Innovation And Sustainable Entrepren"@en,
        "Innovacion Tecnologica y Emprendimiento Sostenible"@es ;
    schema:numberOfCredits 2.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/133000207/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/133000207/2025-26/CB06>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000207/2025-26/CB09>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000207/2025-26/CG01>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000207/2025-26/CT02> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/133000207/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000207/2025-26/didactic_resource/2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000207/2025-26/didactic_resource/3>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000207/2025-26/didactic_resource/4>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000207/2025-26/didactic_resource/5> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/133000207/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/133000207/2025-26/RA20>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000207/2025-26/RA22>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000207/2025-26/RA23>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000207/2025-26/RA24> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/133000207/2025-26/syllabus> ;
    ns1:inpersonHours "27 horas (50%)"@es ;
    ns1:numberOfCredits 2.0 ;
    ns1:otherInformation """In this course, subjects are taught that contribute to training students to achieve the following Sustainable Development Goals (SDGs):
GOAL 1: NO POVERTY

GOAL 8: DECENT WORK AND ECONOMIC GROWTH

GOAL 9: INDUSTRY, INNOVATION, AND INFRASTRUCTURE"""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "27 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/133000207/2025-26/eventSchedule> ;
    schema:description "This course considers two aspects, the organization, development and launching of new innovative products in technology companies and the formation of new companies to commercialize innovative ideas, how to make the business plan, get financing and protect the ideas legally."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/francisco.ayuga%40upm.es> ;
    schema:inLanguage "Inglés/Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/francisco.ayuga%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/jesus.lopez.santiago%40upm.es> ;
    schema:name "Innovacion Tecnologica y Emprendimiento Sostenible"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000207/2025-26/CB06> a ns1:Competency ;
    ns1:competencyCode "CB06" ;
    ns1:competencyDescription "Poseer y comprender conocimientos que aporten una base u oportunidad de ser originales en el desarrollo y/o aplicación de ideas, a menudo en un contexto de investigación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000207/2025-26/CB09> a ns1:Competency ;
    ns1:competencyCode "CB09" ;
    ns1:competencyDescription "Que los estudiantes sepan comunicar sus conclusiones y los conocimientos y razones últimas que las sustentan a públicos especializados y no especializados de un modo claro y sin ambigüedades"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000207/2025-26/CG01> a ns1:Competency ;
    ns1:competencyCode "CG01" ;
    ns1:competencyDescription "El alumno tendrá capacidad para analizar y evaluar las implicaciones de implantar un modelo de economía circular desde el punto de vista normativo, económico, industrial y tecnológico."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000207/2025-26/CT02> a ns1:Competency ;
    ns1:competencyCode "CT02" ;
    ns1:competencyDescription "El alumno tendrá capacidad para utilizar herramientas de gestión administrativa y económica de los recursos humanos, materiales y financieros en la propuesta y ejecución de proyectos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000207/2025-26/RA20> a ns1:LearningResult ;
    ns1:learningResultCode "RA20" ;
    ns1:learningResultDescription "Analizar modelos de negocio innovadores basados en una idea emprendedora del emprendimiento"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000207/2025-26/RA22> a ns1:LearningResult ;
    ns1:learningResultCode "RA22" ;
    ns1:learningResultDescription "Desarrollar un modelo de negocio en una economía circular"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000207/2025-26/RA23> a ns1:LearningResult ;
    ns1:learningResultCode "RA23" ;
    ns1:learningResultDescription "Que los estudiantes conozcan los fundamentos financieros"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000207/2025-26/RA24> a ns1:LearningResult ;
    ns1:learningResultCode "RA24" ;
    ns1:learningResultDescription "Diseñar un plan de negocio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000207/2025-26/didactic_resource/1> a ns1:DidacticResource ;
    ns1:bibliographyTitle "Drucker, P. (2014). Innovation and entrepreneurship. Routledge."@es ;
    ns1:bibliographyType "Bibliografía"@es .

