<https://guia-kg.skai.etsisi.upm.es/resource/145032006/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. CLASIFICACIÓN DE LOS VEHÍCULOS AEROESPACIALES"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145032006/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Definiciones y clasificaciones. Aviones. Aeronaves de alas giratorias. Lanzadores y misiles. Vehículos espaciales. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145032006/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "6. INTRODUCCIÓN A LOS SISTEMAS DE PROPULSIÓN."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145032006/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "6.1. Sistema motopropulsor: motivación y fundamentos. Creación de empuje. Clasificación de los sistemas de propulsión. Envolvente operacional de los distintos sistemas. Aspectos medioambientales. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145032006/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "7. INTRODUCCIÓN A LAS ACTUACIONES DEL AVIÓN."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145032006/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "7.1. Modelo físico-matemático del avión para el estudio de actuaciones. Sistemas de referencia. Vuelo horizontal rectilíneo y uniforme. Vuelo de ascenso/descenso rectilíneo y uniforme .Vuelo de planeo. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145032006/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "8. ACTUACIONES INTEGRALES."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145032006/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "8.1. Alcance. Autonomía. Envolvente operacional de la aeronave. Nomenclatura de pesos del avión. Limitaciones de pesos del avión. Diagramas carga de pago-alcance Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145032006/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "9. CLASIFICACIÓN Y ARQUITECTURA DE AAG."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145032006/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "9.1. Tipos de aeronaves de alas giratorias. Configuración general de los helicópteros. Rotor y mandos de vuelo. Arquitectura de helicópteros. Problemas aerodinámicos. Resonancia en tierra. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145032006/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "10. MECÁNICA ORBITAL."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145032006/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "10.1. Leyes de Kepler. Ley de la Gravitación Universal de Newton. Problema de los dos cuerpos. Órbitas circulares. Caso general de órbitas. Constantes de los movimientos orbitales. Maniobras básicas. Incremento de velocidad Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145032006/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "2. PARTES DEL AVIÓN"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145032006/2025-26/syllabus/20> a ns1:SyllabusItem ;
    ns1:itemIndex 20 ;
    ns1:syllabusDescription "11. VEHÍCULOS ESPACIALES Y LANZADORES"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145032006/2025-26/syllabus/21> a ns1:SyllabusItem ;
    ns1:itemIndex 21 ;
    ns1:syllabusDescription "11.1. Programas espaciales. Entorno espacial. Clasificación de las misiones y los vehículos espaciales. Bases de lanzamiento. Estaciones de seguimiento y control. Arquitectura de los vehículos espaciales. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145032006/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "2.1. Introducción. Fuselaje. Ala. Grupo motopropulsor. Superficies estabilizadores. Tren de aterrizaje. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145032006/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "3. ATMÓSFERA ESTÁNDAR INTERNACIONAL"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145032006/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "3.1. Definición de altitud absoluta y geométrica. Hipótesis de la ISA. Estructura térmica de la atmósfera. Ecuación de la fluido-estática. Solución de la ISA para la troposfera y estratosfera. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145032006/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "4. INTRODUCCIÓN A LA MECÁNICA DE FLUIDOS."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145032006/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "4.1. Estados de la materia. Ecuación de conservación de la masa. Ecuación de Bernouilli Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145032006/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "5. AERODINÁMICA"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145032006/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "5.1. Geometría y nomenclatura de perfiles. Fuerzas aerodinámicas. Curvas características. Coeficientes adimensionales. Entrada en pérdida. Dispositivos hipersustentadores. Efectos de compresibilidad. Sin subniveles"@es .

