        <https://guia-kg.skai.etsisi.upm.es/resource/rafael.daza%40upm.es> ;
    schema:name "Laboratorio de Materiales Biológicos y Biomateriales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20505087/2025-26/CE01> a ns1:Competency ;
    ns1:competencyCode "CE01" ;
    ns1:competencyDescription "Capacidad para conocer las propiedades de la materia, los principios termodinámicos y sus aplicaciones prácticas, así como las características comunes de los procesos físicoquímicos de interés biotecnológico a escala de laboratorio e industrial."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20505087/2025-26/CE07> a ns1:Competency ;
    ns1:competencyCode "CE07" ;
    ns1:competencyDescription "Capacidad de conocer y saber aplicar los métodos matemáticos, estadísticos y bioinformáticos básicos para el estudio, análisis y control de experimentos o procesos biotecnológicos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20505087/2025-26/CE08> a ns1:Competency ;
    ns1:competencyCode "CE08" ;
    ns1:competencyDescription "Comprender y aplicar las principales técnicas de muestreo y utilizar las pruebas estadísticas elementales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20505087/2025-26/CE23> a ns1:Competency ;
    ns1:competencyCode "CE23" ;
    ns1:competencyDescription "Capacidad para comprender los principios básicos del análisis instrumental así como el funcionamiento de la instrumentación analítica básica."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20505087/2025-26/CG01> a ns1:Competency ;
    ns1:competencyCode "CG01" ;
    ns1:competencyDescription "Ser capaz de evaluar y discernir los diferentes mecanismos moleculares y celulares responsables de las transformaciones que llevan a cabo los seres vivos, así como poder desarrollar soluciones alternativas y novedosas frente a problemas biológicos conocidos y/o emergentes."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20505087/2025-26/CG02> a ns1:Competency ;
    ns1:competencyCode "CG02" ;
    ns1:competencyDescription "Familiarizarse con el trabajo en el laboratorio, la instrumentación y los métodos experimentales. Además, ser capaz de realizar experimentos y/o diseñar aplicaciones de forma independiente y describir, cuantificar, analizar y evaluar críticamente los resultados obtenidos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20505087/2025-26/CG04> a ns1:Competency ;
    ns1:competencyCode "CG04" ;
    ns1:competencyDescription "Adquirir la formación y habilidades para el desarrollo de la investigación biotecnológica (tecnologías y estrategias frontera), de cara a su posterior aplicación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20505087/2025-26/CG07> a ns1:Competency ;
    ns1:competencyCode "CG07" ;
    ns1:competencyDescription "Adquirir la formación profesional para cubrir la demanda de las empresas biotecnológicas y para el acceso a estudios de postgrado del área."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20505087/2025-26/CG10> a ns1:Competency ;
    ns1:competencyCode "CG10" ;
    ns1:competencyDescription "Fomentar la implicación en el trabajo de laboratorio seguro y propiciar el conocimiento de los aspectos éticos y bioéticos del área."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20505087/2025-26/CT02> a ns1:Competency ;
    ns1:competencyCode "CT02" ;
    ns1:competencyDescription "Aplicar el método científico para la resolución de problemas de forma efectiva y creativa."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20505087/2025-26/CT04> a ns1:Competency ;
    ns1:competencyCode "CT04" ;
    ns1:competencyDescription "Capacidad para comunicar en lengua castellana e inglesa de forma oral y escrita."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20505087/2025-26/CT09> a ns1:Competency ;
    ns1:competencyCode "CT09" ;
    ns1:competencyDescription "Tener capacidad de análisis y síntesis para interpretar datos relevantes y abordar los problemas desde diferentes perspectivas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20505087/2025-26/RA148> a ns1:LearningResult ;
    ns1:learningResultCode "RA148" ;
    ns1:learningResultDescription "Conocer los diferentes tipos de biomateriales, su estructura y procesos biológicos asociados"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20505087/2025-26/RA31> a ns1:LearningResult ;
    ns1:learningResultCode "RA31" ;
    ns1:learningResultDescription "Aplicación de las técnicas básicas en un laboratorio de biotecnología a la resolución de problemas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20505087/2025-26/RA82> a ns1:LearningResult ;
    ns1:learningResultCode "RA82" ;
    ns1:learningResultDescription "Adquirir experiencia de laboratorio para el manejo de las técnicas bioquímicas básicas"@es .

