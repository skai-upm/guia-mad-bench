    ns1:inpersonHours "65 horas (41.7%)"@es ;
    ns1:numberOfCredits 6.0 ;
    ns1:otherInformation """Esta asignatura se alinea con los objetivos de desarrollo sostenible 2030: educación de calidad e igualdad de género.
La comunicación con los alumnos se realizará vía Moodle y correo oficial UPM."""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "65 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/115100006/2025-26/eventSchedule> ;
    schema:description "La asignatura está orientada a la identificación, comprensión y manejo de los conceptos básicos de la estadística, dentro del marco de procesos de investigación científica así como en el marco de la interpretación y valoración de las puntuaciones obtenidas en diferentes pruebas utilizadas en el campo aplicado de las Ciencias de la Actividad Física y el Deporte. Por otro lado las TICs aceleran el proceso de aprendizaje, aumentando su productividad y mejorando su eficiencia."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/misabel.barriopedro%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/misabel.barriopedro%40upm.es> ;
    schema:name "Estadística y Tecnologías de la Información y la Comunicación (Tic) en Afyd"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100006/2025-26/CE01> a ns1:Competency ;
    ns1:competencyCode "CE01" ;
    ns1:competencyDescription "Diseñar, desarrollar y evaluar los procesos de enseñanza¿aprendizaje relativos a la actividad física y el deporte con atención a las características individuales y contextuales de las personas. Nivel 3."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100006/2025-26/CE24> a ns1:Competency ;
    ns1:competencyCode "CE24" ;
    ns1:competencyDescription "Elaborar y comunicar, de manera crítica y fundamentada, argumentos y juicios sobre el valor de la actividad física y el deporte, y sobre sus posibilidades de contribuir al desarrollo y bienestar de las personas y de la sociedad, y al desarrollo sostenible, así como sobre su especial relación con la salud y la calidad de vida. Nivel 3."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100006/2025-26/CE25> a ns1:Competency ;
    ns1:competencyCode "CE25" ;
    ns1:competencyDescription "Analizar e interpretar los diferentes estudios referidos a las prácticas de actividad físico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100006/2025-26/CG14> a ns1:Competency ;
    ns1:competencyCode "CG14" ;
    ns1:competencyDescription "Utilizar y aplicar las tecnologías de la información y comunicación (TIC) al ámbito de las Ciencias de la Actividad Física y del Deporte, usando las principales fuentes de información científica disponibles."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100006/2025-26/CG16> a ns1:Competency ;
    ns1:competencyCode "CG16" ;
    ns1:competencyDescription "Desarrollar la conciencia de respeto e igualdad entre géneros, igualdad democrática y atención a la diversidad, como principios éticos necesarios para el correcto ejercicio profesional en las Ciencias de la Actividad Física y del Deporte."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100006/2025-26/RA72> a ns1:LearningResult ;
    ns1:learningResultCode "RA72" ;
    ns1:learningResultDescription "Comprender el significado de la función del análisis de datos en las Ciencias de la Actividad Física y el Deporte."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100006/2025-26/RA73> a ns1:LearningResult ;
    ns1:learningResultCode "RA73" ;
    ns1:learningResultDescription "Conocer los estadísticos básicos para valorar e interpretar las puntuaciones obtenidas a partir de diferentes instrumentos de medida"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100006/2025-26/RA74> a ns1:LearningResult ;
    ns1:learningResultCode "RA74" ;
    ns1:learningResultDescription "Tratamiento y análisis estadístico de datos relacionados con el deporte"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100006/2025-26/RA75> a ns1:LearningResult ;
    ns1:learningResultCode "RA75" ;
    ns1:learningResultDescription "Conocer las características técnicas de los distintos dispositivos de medición"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100006/2025-26/RA76> a ns1:LearningResult ;
    ns1:learningResultCode "RA76" ;
    ns1:learningResultDescription "Dominar las técnicas de organización y descripción de datos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100006/2025-26/RA77> a ns1:LearningResult ;
    ns1:learningResultCode "RA77" ;
    ns1:learningResultDescription "Gestión de recursos TIC básicos implicados en la actividad física y el deporte"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100006/2025-26/RA78> a ns1:LearningResult ;
    ns1:learningResultCode "RA78" ;
    ns1:learningResultDescription "Conocer y saber aplicar las técnicas básicas de la inferencia estadística"@es .

