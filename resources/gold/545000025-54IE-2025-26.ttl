    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/545000025/2025-26/eventSchedule> ;
    schema:description "La asignatura de Instalaciones II está referida al estudio de los contenidos relativos a las instalaciones de climatización y aprovechamiento energético en el ámbito de la edificación. Relacionando los conceptos básicos con la realidad y actualidad del sector comercial necesario para el desarrollo de las actuaciones profesionales de un Graduado en Edificación con atribuciones para ejercer la profesión de Arquitecto Técnico."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/patricia.aguilera%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/isabel.bach%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/juan.lopezasiain%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/patricia.aguilera%40upm.es> ;
    schema:name "Instalaciones II"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000025/2025-26/CE22> a ns1:Competency ;
    ns1:competencyCode "CE22" ;
    ns1:competencyDescription "Aptitud para aplicar la normativa específica sobre instalaciones al proceso de la edificación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000025/2025-26/CE24> a ns1:Competency ;
    ns1:competencyCode "CE24" ;
    ns1:competencyDescription "Capacidad para desarrollar constructivamente las instalaciones del edificio, controlar y planificar su ejecución y verificar las pruebas de servicio y de recepción, así como su mantenimiento"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000025/2025-26/CG01> a ns1:Competency ;
    ns1:competencyCode "CG01" ;
    ns1:competencyDescription "Dirigir la ejecución material de las obras de edificación, de sus instalaciones y elementos, llevando a cabo el control cualitativo y cuantitativo de lo construido mediante el establecimiento y gestión de los planes de control de materiales, sistemas y ejecución de obra, elaborando los correspondientes registros para su incorporación al Libro del Edificio."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000025/2025-26/CG05> a ns1:Competency ;
    ns1:competencyCode "CG05" ;
    ns1:competencyDescription "Elaborar los proyectos técnicos y desempeñar la dirección de obras de edificación en el ámbito de su habilitación legal."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000025/2025-26/CG06> a ns1:Competency ;
    ns1:competencyCode "CG06" ;
    ns1:competencyDescription "Gestionar las nuevas tecnologías edificatorias y participar en los procesos de gestión de la calidad en la edificación; realizar análisis, evaluaciones y certificaciones de eficiencia energética así como estudios de sostenibilidad en los edificios."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000025/2025-26/CG08> a ns1:Competency ;
    ns1:competencyCode "CG08" ;
    ns1:competencyDescription "Elaborar estudios del ciclo de vida útil de los materiales, sistemas constructivos y edificios."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000025/2025-26/CT05> a ns1:Competency ;
    ns1:competencyCode "CT05" ;
    ns1:competencyDescription "Respeto medioambiental"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000025/2025-26/CT07> a ns1:Competency ;
    ns1:competencyCode "CT07" ;
    ns1:competencyDescription "Capacidad de búsqueda, análisis y selección de información"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000025/2025-26/CT10> a ns1:Competency ;
    ns1:competencyCode "CT10" ;
    ns1:competencyDescription "Normas y Reglamentos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000025/2025-26/RA323> a ns1:LearningResult ;
    ns1:learningResultCode "RA323" ;
    ns1:learningResultDescription "RA01. Ser competente en el conocimiento de los principios científicos de las instalaciones térmicas y aprovechamiento energético."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000025/2025-26/RA324> a ns1:LearningResult ;
    ns1:learningResultCode "RA324" ;
    ns1:learningResultDescription "RA02. Identificar materiales relevantes, equipamientos, herramientas, procesos o productos que forman parte de las instalaciones térmicas y aprovechamiento energético."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000025/2025-26/RA325> a ns1:LearningResult ;
    ns1:learningResultCode "RA325" ;
    ns1:learningResultDescription "RA03. Diseñar y redactar la ejecución material de las diversas instalaciones térmicas y aprovechamiento energético que se dan en la edificación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000025/2025-26/RA326> a ns1:LearningResult ;
    ns1:learningResultCode "RA326" ;
    ns1:learningResultDescription "RA04. Identificar y cuantificar los recursos necesarios para definir protocolos de actuación en inspecciones, tareas de mantenimiento, pruebas de puesta en servicio, en el ámbito de las instalaciones térmicas y de aprovechamiento energético."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000025/2025-26/RA327> a ns1:LearningResult ;
    ns1:learningResultCode "RA327" ;
    ns1:learningResultDescription "RA05. Habilidad para encontrar, utilizar y aplicar documentación científica, técnica y comercial en el ámbito de las instalaciones térmicas y de aprovechamiento energético."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000025/2025-26/RA479> a ns1:LearningResult ;
    ns1:learningResultCode "RA479" ;
    ns1:learningResultDescription "Conciencia de los impactos de las instalaciones en edificación en los Objetivos de Desarrollo Sostenible (ODS)"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000025/2025-26/RA480> a ns1:LearningResult ;
    ns1:learningResultCode "RA480" ;
    ns1:learningResultDescription "Compromiso con la preservación del medio ambiente y la sostenibilidad"@es .

