    ns1:numberOfCredits 6.0 ;
    ns1:otherInformation """CARGA LECTIVA
Durante cada una de las semanas del periodo lectivo en el que se imparte esta asignatura el estudiante tendrá cuatro horas de trabajo presencial y otras cuatro estimadas de trabajo no presencial basado en los recursos didácticos que se suministran a tal efecto. Por su parte, las tutorías podrán ser telemáticas o presenciales.
Las semanas del periodo lectivo se complementan con otras adicionales con una carga estimada de 8 horas no presenciales. El trabajo no presencial se realizará individualmente o en grupo, dependiendo de la actividad, y en modalidades como estudio y ejercicios libres; ejercicios y prácticas dirigidos; cuestionarios de autoevaluación; preparación de prácticas de laboratorio; preparación de ejercicios evaluables."""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "63 horas y 30 minutos"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/595000029/2025-26/eventSchedule> ;
    schema:description """Sistemas de Control es una asignatura de tercer curso situada en el quinto semestre, específica para la titulación de Grado en Ingeniería Electrónica de Comunicaciones impartida en la ETSIST.
El estudiante toma contacto con los sistemas electrónicos de control, como aplicación práctica de la teoría de sistemas, ejemplificando en sistemas de control o circuitos electrónicos realimentados relacionados con las telecomunicaciones."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/agustin.rodriguez%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/agustin.rodriguez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/angelmanuel.groba%40upm.es> ;
    schema:name "Sistemas de Control"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000029/2025-26/CE%20EC03> a ns1:Competency ;
    ns1:competencyCode "CE EC03" ;
    ns1:competencyDescription "Capacidad de realizar la especificación, implementación, documentación y puesta a punto de equipos y sistemas, electrónicos, de instrumentación y de control, considerando tanto los aspectos técnicos como las normativas reguladoras correspondientes."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000029/2025-26/CE%20EC04> a ns1:Competency ;
    ns1:competencyCode "CE EC04" ;
    ns1:competencyDescription "Capacidad para aplicar la electrónica como tecnología de soporte en otros campos y actividades, y no sólo en el ámbito de las Tecnologías de la Información y las Comunicaciones."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000029/2025-26/CE%20EC06> a ns1:Competency ;
    ns1:competencyCode "CE EC06" ;
    ns1:competencyDescription "Capacidad para comprender y utilizar la teoría de la realimentación y los sistemas electrónicos de control."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000029/2025-26/CG%2003> a ns1:Competency ;
    ns1:competencyCode "CG 03" ;
    ns1:competencyDescription "Capacidad para expresarse correctamente de forma oral y escrita y transmitir información mediante documentos y exposiciones en público."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000029/2025-26/CG%2004> a ns1:Competency ;
    ns1:competencyCode "CG 04" ;
    ns1:competencyDescription "Capacidad de abstracción, de análisis y de síntesis y de resolución de problemas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000029/2025-26/CG%2005> a ns1:Competency ;
    ns1:competencyCode "CG 05" ;
    ns1:competencyDescription "Capacidad de trabajo en equipo y en entornos multidisciplinares."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000029/2025-26/RA1115> a ns1:LearningResult ;
    ns1:learningResultCode "RA1115" ;
    ns1:learningResultDescription "Exponer y transmitir los resultados del desarrollo de un proyecto de diseño de un sistema de control"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000029/2025-26/RA1116> a ns1:LearningResult ;
    ns1:learningResultCode "RA1116" ;
    ns1:learningResultDescription "Colaborar con otros miembros de un equipo en la preparación y defensa de la resolución de un supuesto práctico de análisis y/o diseño de un sistema de control"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000029/2025-26/RA223> a ns1:LearningResult ;
    ns1:learningResultCode "RA223" ;
    ns1:learningResultDescription "Manejar los diagramas de bloques/funciones de transferencia como medio de representación gráfica/analítica de sistemas de control continuos y discretos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000029/2025-26/RA224> a ns1:LearningResult ;
    ns1:learningResultCode "RA224" ;
    ns1:learningResultDescription "Obtener, mediante métodos analíticos y experimentales, modelos matemáticos de los procesos físicos a controlar"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000029/2025-26/RA225> a ns1:LearningResult ;
    ns1:learningResultCode "RA225" ;
    ns1:learningResultDescription "Manejar la función de transferencia en el dominio de Laplace y en el dominio Z como medio para modelar sistemas de control continuos y discretos, respectivamente"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000029/2025-26/RA226> a ns1:LearningResult ;
    ns1:learningResultCode "RA226" ;
    ns1:learningResultDescription "Calcular la precisión de un sistema de control realimentado a partir del concepto de error en régimen permanente"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000029/2025-26/RA227> a ns1:LearningResult ;
    ns1:learningResultCode "RA227" ;
    ns1:learningResultDescription "Caracterizar cualitativa y cuantitativamente el comportamiento temporal de un sistema de control a partir de su función de transferencia"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000029/2025-26/RA228> a ns1:LearningResult ;
    ns1:learningResultCode "RA228" ;
    ns1:learningResultDescription "Utilizar (trazar e interpretar) el lugar de raíces de un sistema de control realimentado como medio de relacionar la ganancia de realimentación con su comportamiento temporal"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000029/2025-26/RA229> a ns1:LearningResult ;
    ns1:learningResultCode "RA229" ;
    ns1:learningResultDescription "Calcular la función de transferencia del controlador que sería necesario aplicar en un sistema de control para alcanzar unas determinadas especificaciones de comportamiento temporal"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000029/2025-26/RA230> a ns1:LearningResult ;
    ns1:learningResultCode "RA230" ;
    ns1:learningResultDescription "Entender las propiedades fundamentales de las acciones de control PID, incluyendo sus limitaciones prácticas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000029/2025-26/RA231> a ns1:LearningResult ;
    ns1:learningResultCode "RA231" ;
    ns1:learningResultDescription "Ajustar los parámetros de un controlador PID para alcanzar unas determinadas especificaciones de comportamiento temporal en un sistema de control"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000029/2025-26/RA232> a ns1:LearningResult ;
    ns1:learningResultCode "RA232" ;
    ns1:learningResultDescription "Utilizar sistemas electrónicos para la realización de sistemas de control"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000029/2025-26/RA233> a ns1:LearningResult ;
    ns1:learningResultCode "RA233" ;
    ns1:learningResultDescription "Utilizar herramientas CASE como apoyo al análisis y diseño de sistemas de control"@es .

