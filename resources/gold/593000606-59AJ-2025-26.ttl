    schema:name "Scientific Research Methodology"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/593000606/2025-26/CEM13> a ns1:Competency ;
    ns1:competencyCode "CEM13" ;
    ns1:competencyDescription "Adquirir un conocimiento instrumental mínimo que permita plantear formalmente un proyecto de investigación. / Acquire a minimun instrumental knowledge that allows to formally propose a research project."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/593000606/2025-26/CGI02> a ns1:Competency ;
    ns1:competencyCode "CGI02" ;
    ns1:competencyDescription "Comprender el procedimiento, valor y límites del método científico, siendo capaz de identificar, localizar y obtenerdatos requeridos en un trabajo de investigación, de diseñar y guiar investigaciones analíticas, de modelado y experimentales, así como de evaluar datos de una manera crítica y extraer conclusiones. / Understand the procedure, value, and limits of the scientific method, being able to identify, locate and obtain data required in a research work, to design and guide analytical, modeling, and experimental investigations, as well as to critically evaluate data and extract conclusions."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/593000606/2025-26/CGI03> a ns1:Competency ;
    ns1:competencyCode "CGI03" ;
    ns1:competencyDescription "Valorar la importancia de las fuentes documentales, manejarlas y buscar la información para el desarrollo de cualquier trabajo de investigación. / Assess the importance of documentary sources, manage them and search for information for the development of any research work."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/593000606/2025-26/CGI05> a ns1:Competency ;
    ns1:competencyCode "CGI05" ;
    ns1:competencyDescription "Adquirir el conocimiento necesario sobre los mecanismos de financiación de la investigación y transferencia de la tecnología, y sobre la legislación vigente sobre protección de resultados. /Acquire the necessary knowledge about the mechanisms for financing research and technology transfer, and about current legislation on the protection of results."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/593000606/2025-26/RA19> a ns1:LearningResult ;
    ns1:learningResultCode "RA19" ;
    ns1:learningResultDescription "Entender el proceso y las características de la actividad investigadora/ Understand the process and characteristics of the research activity"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/593000606/2025-26/RA20> a ns1:LearningResult ;
    ns1:learningResultCode "RA20" ;
    ns1:learningResultDescription "Utilizar adecuadamente los recursos bibliográficos y bibliométricos disponibles/ Properly use of the available bibliographic and bibliometric resources"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/593000606/2025-26/RA21> a ns1:LearningResult ;
    ns1:learningResultCode "RA21" ;
    ns1:learningResultDescription "Adquirir una actitud crítica y pragmática de las teorías sobre el conocimiento científico/ Acquire a critical and pragmatic attitude in relation to the theories about scientific knowledge"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/593000606/2025-26/RA22> a ns1:LearningResult ;
    ns1:learningResultCode "RA22" ;
    ns1:learningResultDescription "Presentar y defender con rigor un trabajo de forma escrita y oral en inglés/ Present and rigorously defend a work in written and oral form in English"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/593000606/2025-26/RA23> a ns1:LearningResult ;
    ns1:learningResultCode "RA23" ;
    ns1:learningResultDescription "Localizar convocatorias de ayudas para investigación y redactar adecuadamente las propuestas/ Find out calls for research grants and properly draft proposals"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/593000606/2025-26/RA8> a ns1:LearningResult ;
    ns1:learningResultCode "RA8" ;
    ns1:learningResultDescription "Identificar el impacto social y económico de las comunicaciones móviles en un contexto global/ Identify the social and economic impact of mobile communications in a global context."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/593000606/2025-26/UPM1> a ns1:Competency ;
    ns1:competencyCode "UPM1" ;
    ns1:competencyDescription "Uso de la lengua inglesa / Use of the English language"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/593000606/2025-26/UPM2> a ns1:Competency ;
    ns1:competencyCode "UPM2" ;
    ns1:competencyDescription "Liderazgo de equipos / Team leadership"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/593000606/2025-26/didactic_resource/1> a ns1:DidacticResource ;
    ns1:bibliographyTitle "Carl J. Sindermann, \"Winning the games scientists play: strategies for enhancing your career in science\", Perseus Publishing, 2001"@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/593000606/2025-26/didactic_resource/2> a ns1:DidacticResource ;
    ns1:bibliographyTitle "Leslie A. Olsen and Thomas N. Hucklin, \"Technical writing and professional communication\", McGraw-Hill, 1991 (2nd Ed)."@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/593000606/2025-26/didactic_resource/3> a ns1:DidacticResource ;
    ns1:bibliographyTitle "C. George Thomas, \"Research Methodology and Scientific Writing\", Springer, 2021 (2nd Ed)."@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/593000606/2025-26/didactic_resource/4> a ns1:DidacticResource ;
    ns1:bibliographyTitle "E. B. Wilson, \"An Introduction to Scientific Research\", Dover Publications, 2012."@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/593000606/2025-26/didactic_resource/5> a ns1:DidacticResource ;
    ns1:bibliographyTitle "Uwem Essia, \"Lecture Notes on Research Methodology (Books 1-5)\", 2022"@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/593000606/2025-26/didactic_resource/6> a ns1:DidacticResource ;
    ns1:bibliographyDescription "Journal and conference papers, scientific reports, on-line bibliographic resources, websites of different calls for projects, etc."@es ;
    ns1:bibliographyTitle "On-Line Resources"@es ;
    ns1:bibliographyType "Recursos web"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/593000606/2025-26/evaluation> a ns1:EvaluationSystem ;
    ns1:evaluationDescription """The progressive evaluation will consist of two parts:
1) Classroom assessment of each of the 5 units of the course (6 weeks, 5% per week).
2) A work to be delivered and presented at the end of the course (70%). Depending on the number of students enrolled in the course this work will be either individual or in groups of 2-3 students.
The first part can be recovered in the final and/or extraordinary exam by students failing to pass the course through a global written exam (30%) that will include questions from the 5 units of the course. The second part is not recoverable and MUST be done during the course."""@es ;
