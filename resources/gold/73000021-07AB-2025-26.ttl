    schema:name "Sistemas de Informacion Geografica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/73000021/2025-26/CE%202.7> a ns1:Competency ;
    ns1:competencyCode "CE 2.7" ;
    ns1:competencyDescription "Capacidad para utilizar sistemas de información geográfica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/73000021/2025-26/CG%207> a ns1:Competency ;
    ns1:competencyCode "CG 7" ;
    ns1:competencyDescription "Utilización de las TICs para el trabajo cooperativo y el trabajo en equipo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/73000021/2025-26/RA79> a ns1:LearningResult ;
    ns1:learningResultCode "RA79" ;
    ns1:learningResultDescription "Conocer la definición y principales características de un Sistema de Información Geográfica (en adelante, SIG). Aplicaciones y sistemas afines. Componentes. Modelos de datos. Entrada de datos. Fuentes de información geográfica y cartográfica. Infraestructuras de Datos Espaciales y descarga de datos desde Internet."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/73000021/2025-26/RA80> a ns1:LearningResult ;
    ns1:learningResultCode "RA80" ;
    ns1:learningResultDescription "Conocer los sistemas de coordenadas: sistemas geodésicos de referencia y sistemas de proyección cartográficos. Definición del sistema de coordenadas. Transformación virtual y definitiva del sistema de coordenadas. Geo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/73000021/2025-26/RA81> a ns1:LearningResult ;
    ns1:learningResultCode "RA81" ;
    ns1:learningResultDescription "Creación y edición de capas vectoriales de polígonos, líneas y puntos. Manejo de información tabular: edición y gestión de tablas, consultas de datos, relaciones entre tablas, operaciones con campos, estadísticos y sumarios estadísticos. Leyendas y etiquetas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/73000021/2025-26/RA82> a ns1:LearningResult ;
    ns1:learningResultCode "RA82" ;
    ns1:learningResultDescription "Conocer las herramientas de consulta y geo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/73000021/2025-26/RA83> a ns1:LearningResult ;
    ns1:learningResultCode "RA83" ;
    ns1:learningResultDescription "Conocer el modelo de datos ráster. Formatos de capas ráster y conversiones entre formatos y desde el modelo de datos vectorial. Propiedades de las capas ráster y estadísticas básicas y zonales. Operaciones básicas de capas ráster: recortar, unir dos o má capas, reclasificar. La calculadora ráster."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/73000021/2025-26/RA84> a ns1:LearningResult ;
    ns1:learningResultCode "RA84" ;
    ns1:learningResultDescription "Conocer los principios del análisis del terreno. Modelos digitales del terreno de red triangular y malla regular. Datos de partida para la elaboración de modelos digitales del terreno. Métodos para la elaboración de un modelo digital del terreno. Análisis morfométricos: mapas de pendientes y orientaciones."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/73000021/2025-26/RA85> a ns1:LearningResult ;
    ns1:learningResultCode "RA85" ;
    ns1:learningResultDescription "Creación de salidas gráficas."@es .

