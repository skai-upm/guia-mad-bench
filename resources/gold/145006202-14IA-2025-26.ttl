        <https://guia-kg.skai.etsisi.upm.es/resource/145006202/2025-26/didactic_resource/7> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/145006202/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/145006202/2025-26/RA196>,
        <https://guia-kg.skai.etsisi.upm.es/resource/145006202/2025-26/RA197> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/145006202/2025-26/syllabus> ;
    ns1:inpersonHours "55 horas y 10 minutos (47.2%)"@es ;
    ns1:numberOfCredits 4.5 ;
    ns1:otherInformation """A principio de curso el alumno optará por evaluación contínua o sólo exámen final. En el segundo caso, el alumno no realizará (obviamente) la prueba de evaluación intermedia ni los trabajos de la asignatura. Para ello, deberá informar al profesor responsable de la asignatura en el plazo comprendido por las dos primeras semanas del curso.

La parte de trabajos se examinará mediante un examen oral."""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "55 horas y 10 minutos"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/145006202/2025-26/eventSchedule> ;
    schema:description """En esta asignatura se estudian los diferentes procesos que dan lugar al ciclo de trabajo de un motor alternativo, sea Otto o Diesel. La integración de los procesos da lugar al ciclo termodinámico.

Se realiza también un extenso análisis de la cinemática y dinámica del motor, calculando las fuerzas y momentos generados.

Finalmente se estudian temas más tecnológicos sobre el uso y aplicación de los motores alternativos."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/angel.velazquez%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/angel.velazquez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/juanramon.arias%40upm.es> ;
    schema:name "Motores Alternativos Aeronauticos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145006202/2025-26/CE34> a ns1:Competency ;
    ns1:competencyCode "CE34" ;
    ns1:competencyDescription "Conocimiento adecuado y aplicado a la Ingeniería de: los métodos de cálculo y de desarrollo de instalaciones de los sistemas propulsivos; la regulación y control de instalaciones de los sistemas propulsivos; el manejo de las técnicas experimentales, equipamiento e instrumentos de medida propios de la disciplina; los combustibles y lubricantes empleados en los motores de aviación y automoción; la simulación numérica de los procesos físico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145006202/2025-26/CE35> a ns1:Competency ;
    ns1:competencyCode "CE35" ;
    ns1:competencyDescription "Conocimiento aplicado de: aerodinámica interna; teoría de la propulsión; actuaciones de aviones y de aerorreactores; ingeniería de sistemas de propulsión; mecánica y termodinámica."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145006202/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Capacidad para identificar y resolver problemas aplicando, con creatividad, los conocimientos adquiridos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145006202/2025-26/CG9> a ns1:Competency ;
    ns1:competencyCode "CG9" ;
    ns1:competencyDescription "Razonamiento crítico y capacidad de asociación que posibiliten el aprendizaje continuo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145006202/2025-26/RA196> a ns1:LearningResult ;
    ns1:learningResultCode "RA196" ;
    ns1:learningResultDescription "Conocimiento, comprensión, aplicación, análisis y síntesis de la influencia de parámetros de operación y diseño sobre las actuaciones de los motores alternativos aeronáuticos y sus sistemas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145006202/2025-26/RA197> a ns1:LearningResult ;
    ns1:learningResultCode "RA197" ;
    ns1:learningResultDescription "Conocimiento de los aspectos más destacados de los ensayos de los motores alternativos."@es .

