<https://guia-kg.skai.etsisi.upm.es/resource/145006202/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/145006202/2025-26/CE34>,
        <https://guia-kg.skai.etsisi.upm.es/resource/145006202/2025-26/CE35>,
