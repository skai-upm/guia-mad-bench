<https://guia-kg.skai.etsisi.upm.es/resource/545000166/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/545000166/2025-26/CG13>,
        <https://guia-kg.skai.etsisi.upm.es/resource/545000166/2025-26/CG17>,
