    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/545000166/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/545000166/2025-26/RA160>,
        <https://guia-kg.skai.etsisi.upm.es/resource/545000166/2025-26/RA161>,
        <https://guia-kg.skai.etsisi.upm.es/resource/545000166/2025-26/RA162>,
        <https://guia-kg.skai.etsisi.upm.es/resource/545000166/2025-26/RA163> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/545000166/2025-26/syllabus> ;
    ns1:inpersonHours "68 horas (43.6%)"@es ;
    ns1:numberOfCredits 6.0 ;
    ns1:otherInformation "Para poder matricularse en esta asignatura, el estudiante deberá acreditar previamente el nivel B1 del Common European Framework of Reference for Languages establecido por el Consejo de Europa o similar en lengua inglesa. Para poder superar la asignatura, el o la estudiante deberá acreditar el nivel B2 con una antelación de, al menos, cinco días hábiles previos al examen de la convocatoria ordinaria o extraordinaria, según corresponda. En caso de no hacerlo, el estudiante podrá alcanzar una calificación máxima de 4.0 en la convocatoria ordinaria, y será calificado como No Presentado en la convocatoria extraordinaria."@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "68 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/545000166/2025-26/eventSchedule> ;
    schema:description "Estudio teórico-práctico de los rasgos léxicos, sintácticos, discursivos y estilísticos característicos del inglés empresarial. Introducción a esta lengua, haciendo hincapié en el aprendizaje de las destrezas comunicativas necesarias para poder desenvolverse con soltura en un futuro profesional."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/m.fernandez%40upm.es> ;
    schema:inLanguage "Inglés"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/joaquin.santiago%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/m.fernandez%40upm.es> ;
    schema:name "English For Professional And Academic Communications"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000166/2025-26/CG13> a ns1:Competency ;
    ns1:competencyCode "CG13" ;
    ns1:competencyDescription "Uso de la lengua inglesa en el ámbito de la edificación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000166/2025-26/CG17> a ns1:Competency ;
    ns1:competencyCode "CG17" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de trabajar en un entorno bilingüe (inglés"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000166/2025-26/CG20> a ns1:Competency ;
    ns1:competencyCode "CG20" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de trabajar en entornos diversos, comprendiendo y adaptándose a situaciones nuevas en el ámbito de la administración y dirección de empresas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000166/2025-26/RA160> a ns1:LearningResult ;
    ns1:learningResultCode "RA160" ;
    ns1:learningResultDescription "Conocer y saber utilizar la terminología especializada de la Administración y Dirección de Empresas en lengua inglesa."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000166/2025-26/RA161> a ns1:LearningResult ;
    ns1:learningResultCode "RA161" ;
    ns1:learningResultDescription "Comprender el discurso oral y escrito en inglés específico de la Administración y Dirección de Empresas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000166/2025-26/RA162> a ns1:LearningResult ;
    ns1:learningResultCode "RA162" ;
    ns1:learningResultDescription "Expresión oral y escrita en inglés en el contexto de la Administración y Dirección de Empresas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/545000166/2025-26/RA163> a ns1:LearningResult ;
    ns1:learningResultCode "RA163" ;
    ns1:learningResultDescription "Utilizar adecuadamente la lengua inglesa en el contexto profesional de la Administración y Dirección de Empresas."@es .

