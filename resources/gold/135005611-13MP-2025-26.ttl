    schema:name "Tecnologia para la Gestion de Residuos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005611/2025-26/CE%201.01> a ns1:Competency ;
    ns1:competencyCode "CE 1.01" ;
    ns1:competencyDescription "Conocer los campos de aplicación de la Ingeniería del Medio Natural, y tener una apreciación de la necesidad de poseer unos conocimientos técnicos profundos en ciertas áreas de aplicación; apreciación del grado de esta necesidad en, por lo menos, una situación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005611/2025-26/CE%201.14> a ns1:Competency ;
    ns1:competencyCode "CE 1.14" ;
    ns1:competencyDescription "Conocer y comprender la estructura, funcionamiento y evolución de los ecosistemas naturales y su utilidad de cara a la Ingeniería Ecológica."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005611/2025-26/CG01> a ns1:Competency ;
    ns1:competencyCode "CG01" ;
    ns1:competencyDescription "Aplicar de manera autónoma nuevos conocimientos y técnicas adecuados para la concepción, el desarrollo o la explotación de tecnología para la gestión, conservación y protección del Medio Natural"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005611/2025-26/CG13> a ns1:Competency ;
    ns1:competencyCode "CG13" ;
    ns1:competencyDescription "Controlar y gestionar los contaminantes y residuos generados en el ámbito del Medio Natural"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005611/2025-26/CT06> a ns1:Competency ;
    ns1:competencyCode "CT06" ;
    ns1:competencyDescription "Desarrollar la capacidad para trabajar en equipo, integrándose y colaborando de forma activa en la consecución de objetivos comunes."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005611/2025-26/RA151> a ns1:LearningResult ;
    ns1:learningResultCode "RA151" ;
    ns1:learningResultDescription "Adquirir capacidades para analizar la mejor opción en materia de gestión de residuos urbanos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135005611/2025-26/RA72> a ns1:LearningResult ;
    ns1:learningResultCode "RA72" ;
    ns1:learningResultDescription "RA 37 Reconocer y analizar problemas ambientales y planificar estrategias para la mejora de la calidad ambiental"@es .

