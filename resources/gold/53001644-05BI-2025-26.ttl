        <https://guia-kg.skai.etsisi.upm.es/resource/53001644/2025-26/MUII.%20%28g%29>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001644/2025-26/MUII.%20%28k%29>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001644/2025-26/MUII.%20%28l%29>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001644/2025-26/MUII.CB06>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001644/2025-26/MUII.CB09>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001644/2025-26/MUII.CG10> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/53001644/2025-26/didactic_resource/1>,
