    schema:name "Restoration Of Polluted Soils"@en,
        "Restauración de Suelos Contaminados"@es ;
    schema:numberOfCredits 4.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/133000308/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/133000308/2025-26/CB10>,
