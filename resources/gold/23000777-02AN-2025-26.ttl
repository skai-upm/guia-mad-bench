    ns1:semester "Tercer semestre"@es ;
    schema:courseCode 23000777 ;
    schema:hasCourseInstance <https://guia-kg.skai.etsisi.upm.es/resource/23000777/2025-26> ;
    schema:name "Recovery Of Degraded Areas"@en,
        "Recuperación de Espacios Degradados"@es ;
    schema:numberOfCredits 2.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/23000777/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/23000777/2025-26/C8>,
        <https://guia-kg.skai.etsisi.upm.es/resource/23000777/2025-26/K3>,
        <https://guia-kg.skai.etsisi.upm.es/resource/23000777/2025-26/S5> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/23000777/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/23000777/2025-26/didactic_resource/2> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/23000777/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/23000777/2025-26/RA103>,
        <https://guia-kg.skai.etsisi.upm.es/resource/23000777/2025-26/RA96> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/23000777/2025-26/syllabus> ;
    ns1:inpersonHours "26 horas (50%)"@es ;
    ns1:numberOfCredits 2.0 ;
    ns1:otherInformation ""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "26 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/23000777/2025-26/eventSchedule> ;
    schema:description "Esta asigantura se refiere al tercer pilar de la gestión ambiental: el curativo, que se orienta a recuperar lo ya degradado. Entiende la recuperación en un sentido amplio: lejos de la idea de devolver un terreno a su estado original, adopta un enfoque más realista: sustituir una situación insatisfactoria por otra que no lo sea, con independencia de lo que originariamente fue. Combina de forma equilibrada los contenidos conceptual, metodológico y técnico de la recuperación con carácter instrumental, lo que significa que la docencia se orienta a la acción; por ello la columna vertebral del curso es la elaboración de un trabajo práctico que pretende simular el ejercicio profesional en la materia."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/teresa.gomez.villarino%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/teresa.gomez.villarino%40upm.es> ;
    schema:name "Recuperación de Espacios Degradados"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000777/2025-26/C8> a ns1:Competency ;
    ns1:competencyCode "C8" ;
    ns1:competencyDescription "Capacidad de realizar un diagnóstico integral de un espacio degradado y su problemática, así como de elaborar un plan de recuperación de dicho espacio en las circunstancias económicas, ambientales y sociales en las que se inscribe. TIPO: Competencias."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000777/2025-26/K3> a ns1:Competency ;
    ns1:competencyCode "K3" ;
    ns1:competencyDescription "Conocer los conceptos fundamentales de la ecología y cómo afectan a la jardinería y el paisajismo. TIPO: Conocimientos o contenidos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000777/2025-26/RA103> a ns1:LearningResult ;
    ns1:learningResultCode "RA103" ;
    ns1:learningResultDescription "S5"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000777/2025-26/RA96> a ns1:LearningResult ;
    ns1:learningResultCode "RA96" ;
    ns1:learningResultDescription "K3"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/23000777/2025-26/S5> a ns1:Competency ;
    ns1:competencyCode "S5" ;
    ns1:competencyDescription "Habilidad para ofrecer soluciones compatibles con la conservación del entorno de forma responsable y sostenible, y potenciar los beneficios que pueda generar la actividad profesional en el ámbito de la jardinería y el paisajismo. TIPO: Habilidades o destrezas."@es .

