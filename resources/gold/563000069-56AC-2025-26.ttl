<https://guia-kg.skai.etsisi.upm.es/resource/563000069/2025-26/RA98> a ns1:LearningResult ;
    ns1:learningResultCode "RA98" ;
    ns1:learningResultDescription "Potenciar el autoaprendizaje para aplicar las tecnologías a la práctica industrial."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000069/2025-26/RA99> a ns1:LearningResult ;
