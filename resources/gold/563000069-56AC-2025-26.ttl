<https://guia-kg.skai.etsisi.upm.es/resource/563000069/2025-26/CB10> a ns1:Competency ;
    ns1:competencyCode "CB10" ;
    ns1:competencyDescription "Que los estudiantes posean las habilidades de aprendizaje que les permitan continuar estudiando de un modo que habrá de ser en gran medida autodirigido o autónomo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000069/2025-26/CB6> a ns1:Competency ;
    ns1:competencyCode "CB6" ;
    ns1:competencyDescription "Poseer y comprender conocimientos que aporten una base u oportunidad de ser originales en el desarrollo y/o aplicación de ideas, a menudo en un contexto de investigación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000069/2025-26/CB7> a ns1:Competency ;
    ns1:competencyCode "CB7" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en entornos nuevos o poco conocidos dentro de contextos más amplios (o multidisciplinares) relacionados con su área de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000069/2025-26/CB8> a ns1:Competency ;
    ns1:competencyCode "CB8" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de integrar conocimientos y enfrentarse a la complejidad de formular juicios a partir de una información que, siendo incompleta o limitada, incluya reflexiones sobre las responsabilidades sociales y éticas vinculadas a la aplicación de sus conocimientos y juicios"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000069/2025-26/CB9> a ns1:Competency ;
    ns1:competencyCode "CB9" ;
    ns1:competencyDescription "Que los estudiantes sepan comunicar sus conclusiones y los conocimientos y razones últimas que las sustentan a públicos especializados y no especializados de un modo claro y sin ambigüedades"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000069/2025-26/CE1> a ns1:Competency ;
    ns1:competencyCode "CE1" ;
    ns1:competencyDescription "Capacidad de diseñar, innovar y gestionar nuevos productos teniendo en cuenta criterios de calidad y medioambientales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000069/2025-26/CE2> a ns1:Competency ;
    ns1:competencyCode "CE2" ;
    ns1:competencyDescription "Capacidad de gestionar el ciclo de vida del producto"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000069/2025-26/CG10> a ns1:Competency ;
    ns1:competencyCode "CG10" ;
    ns1:competencyDescription "Capacidad de integrarse en el ámbito empresarial a través del diseño y la innovación o a través de proyectos de diseño operativo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000069/2025-26/CG4> a ns1:Competency ;
    ns1:competencyCode "CG4" ;
    ns1:competencyDescription "Conocimiento de los procesos industriales para ser capaz de decidir sobre los criterios adecuados en la fabricación de productos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000069/2025-26/CG9> a ns1:Competency ;
    ns1:competencyCode "CG9" ;
    ns1:competencyDescription "Capacidad para aplicar los principios de la economía y de la gestión de recursos humanos y proyectos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000069/2025-26/CT1> a ns1:Competency ;
    ns1:competencyCode "CT1" ;
    ns1:competencyDescription "Capacidad para comunicarse con profesionales de su ámbito, con la comunidad académica en su conjunto y con la sociedad en general acerca de sus áreas de conocimiento"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000069/2025-26/CT2> a ns1:Competency ;
    ns1:competencyCode "CT2" ;
    ns1:competencyDescription "Ser capaz de negociar y trabajar en equipo así como de manera autónoma en un contexto internacional, multidisciplinar y multicultura"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000069/2025-26/CT3> a ns1:Competency ;
    ns1:competencyCode "CT3" ;
    ns1:competencyDescription "Ser capaz de organizar y planificar el tiempo de trabajo propio o de un equipo de trabajo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000069/2025-26/CT5> a ns1:Competency ;
    ns1:competencyCode "CT5" ;
    ns1:competencyDescription "Capacidad para desarrollar y ejercitar la creatividad"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000069/2025-26/CT7> a ns1:Competency ;
    ns1:competencyCode "CT7" ;
    ns1:competencyDescription "Capacidad para comunicarse en lengua inglesa en un entorno profesional"@es .

