    schema:inLanguage "Inglés"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/antoniojose.madrid%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/carlos.martindelaconcha%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/carlos.zanuy%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/g.ulzurrun%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/ivan.munoz%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/jm.soria%40upm.es> ;
    schema:name "Experimental Structural Analysis"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000554/2025-26/MICCPCE38> a ns1:Competency ;
    ns1:competencyCode "MICCPCE38" ;
    ns1:competencyDescription "Capacidad para integrar y aplicar los conocimientos técnicos en asesoría, análisis, diseño y modelización físico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000554/2025-26/MICCPCGP11> a ns1:Competency ;
    ns1:competencyCode "MICCPCGP11" ;
    ns1:competencyDescription "Capacidad para el proyecto, ejecución e inspección de estructuras (puentes, edificaciones, etc.), de obras de cimentación y de obras subterráneas de uso civil (túneles, aparcamientos), y el diagnóstico sobre su integridad. Incorpora las competencias CB6, CB7 y CB8."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000554/2025-26/MICCPCT01> a ns1:Competency ;
    ns1:competencyCode "MICCPCT01" ;
    ns1:competencyDescription "Capacidad de preparar y presentar comunicaciones orales, escritas y gráficas, estructurada y argumentadamente. Desarrolla la competencia CB9."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000554/2025-26/MICCPCT03> a ns1:Competency ;
    ns1:competencyCode "MICCPCT03" ;
    ns1:competencyDescription "Capacidad de comunicación técnica oral y escrita en lengua inglesa. Desarrolla la competencia transversal 1ª de la normativa UPM."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000554/2025-26/MICCPCT08> a ns1:Competency ;
    ns1:competencyCode "MICCPCT08" ;
    ns1:competencyDescription "Capacidad de diseñar, analizar e interpretar experimentos relevantes en ingeniería civil."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000554/2025-26/RA121> a ns1:LearningResult ;
    ns1:learningResultCode "RA121" ;
    ns1:learningResultDescription "SO1 The student knows the fundamentals and applications of the most relevant transducers for instrumentation of structures."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000554/2025-26/RA122> a ns1:LearningResult ;
    ns1:learningResultCode "RA122" ;
    ns1:learningResultDescription "The student acquires the fundamentals of static and dynamic experimental techniques in structural engineering, and understands the structural implications of taken measurements."@es .

