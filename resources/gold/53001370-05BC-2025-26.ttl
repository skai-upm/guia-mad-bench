    ns1:learningResultCode "RA19" ;
    ns1:learningResultDescription "Conocimiento de las operaciones de separación sólido"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001370/2025-26/RA20> a ns1:LearningResult ;
    ns1:learningResultCode "RA20" ;
    ns1:learningResultDescription "Conocimiento de las operaciones de aumento y reducción de tamaño de sólidos granulares"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001370/2025-26/RA21> a ns1:LearningResult ;
    ns1:learningResultCode "RA21" ;
    ns1:learningResultDescription "Conocimiento de las operaciones de transporte y almacenamiento de sólidos granulares"@es .

