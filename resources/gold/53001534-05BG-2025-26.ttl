<https://guia-kg.skai.etsisi.upm.es/resource/53001534/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/53001534/2025-26/CB06>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001534/2025-26/CB10>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001534/2025-26/CE03>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001534/2025-26/CE04>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001534/2025-26/CT01> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/53001534/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001534/2025-26/didactic_resource/2> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/53001534/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/53001534/2025-26/RA1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001534/2025-26/RA68>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001534/2025-26/RA69>,
        <https://guia-kg.skai.etsisi.upm.es/resource/53001534/2025-26/RA70> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/53001534/2025-26/syllabus> ;
    ns1:inpersonHours "34 horas (43.6%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation ""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "34 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/53001534/2025-26/eventSchedule> ;
    schema:description "Power consumption and energy management are some of the most important issues in current electronic systems, particularly in areas such as consumer electronics, transport, communications, new devices for intelligent environments, etc. The power consumption is, however, one of the most complex to estimate and optimize since it is closely linked to the implementation technology, the use of the system as well as other aspects of the architecture that are not always obvious. A second aspect that must be taken into account in the design of ultra-low-power systems is the design of the power systems that provide power to them. Thus, this subject is structured in three parts. In the first one, the basic aspects of power consumption of electronic systems in CMOS technology are studied. In the second part techniques for reducing power are analyzed from the point of view of the circuit structure, their application and some techniques for estimating the power and energy consumption in digital electronic systems. In the third part of the subject the power supply strategies for low-power systems will be studied."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/jose.miranda%40upm.es> ;
    schema:inLanguage "Inglés/Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/jose.miranda%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/miroslav.vasic%40upm.es> ;
    schema:name "Energy Management In Electronic Systems"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001534/2025-26/CB06> a ns1:Competency ;
    ns1:competencyCode "CB06" ;
    ns1:competencyDescription "Poseer y comprender conocimientos que aporten una base u oportunidad de ser originales en el desarrollo y/o aplicación de ideas, a menudo en un contexto de investigación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001534/2025-26/CB10> a ns1:Competency ;
    ns1:competencyCode "CB10" ;
    ns1:competencyDescription "Que los estudiantes posean las habilidades de aprendizaje que les permitan continuar estudiando de un modo que habrá de ser en gran medida autodirigido o autónomo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001534/2025-26/CE03> a ns1:Competency ;
    ns1:competencyCode "CE03" ;
    ns1:competencyDescription "Optimizar la gestión energética de los sistemas electrónicos mediante la aplicación de técnicas avanzadas de diseño de circuitos y de métodos de control."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001534/2025-26/CE04> a ns1:Competency ;
    ns1:competencyCode "CE04" ;
    ns1:competencyDescription "Utilización de herramientas CAD para la simulación, modelado y diseño de circuitos electrónicos industriales con altas prestaciones y/o restricciones"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001534/2025-26/CT01> a ns1:Competency ;
    ns1:competencyCode "CT01" ;
