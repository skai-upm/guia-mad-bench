<https://guia-kg.skai.etsisi.upm.es/resource/53001203/2025-26/RA126> a ns1:LearningResult ;
    ns1:learningResultCode "RA126" ;
    ns1:learningResultDescription "El alumno es capaz de valorar los efectos positivos y negativos de la solución a un problema de ingeniería que afectan a la sociedad, la economía y el medio ambiente."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001203/2025-26/RA133> a ns1:LearningResult ;
