    schema:hasCourseInstance <https://guia-kg.skai.etsisi.upm.es/resource/105001024/2025-26> ;
    schema:name "Architectures For Massive Data Processing"@en,
        "Arquitecturas para el Procesamiento Masivo de Datos"@es ;
    schema:numberOfCredits 6.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/105001024/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/105001024/2025-26/CB01>,
        <https://guia-kg.skai.etsisi.upm.es/resource/105001024/2025-26/CB02>,
        <https://guia-kg.skai.etsisi.upm.es/resource/105001024/2025-26/CB03>,
        <https://guia-kg.skai.etsisi.upm.es/resource/105001024/2025-26/CB05>,
        <https://guia-kg.skai.etsisi.upm.es/resource/105001024/2025-26/CE07>,
        <https://guia-kg.skai.etsisi.upm.es/resource/105001024/2025-26/CE08>,
        <https://guia-kg.skai.etsisi.upm.es/resource/105001024/2025-26/CG02>,
        <https://guia-kg.skai.etsisi.upm.es/resource/105001024/2025-26/CG04>,
        <https://guia-kg.skai.etsisi.upm.es/resource/105001024/2025-26/CG06> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/105001024/2025-26/didactic_resource/1> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/105001024/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/105001024/2025-26/RA106>,
        <https://guia-kg.skai.etsisi.upm.es/resource/105001024/2025-26/RA107>,
        <https://guia-kg.skai.etsisi.upm.es/resource/105001024/2025-26/RA108>,
        <https://guia-kg.skai.etsisi.upm.es/resource/105001024/2025-26/RA109>,
        <https://guia-kg.skai.etsisi.upm.es/resource/105001024/2025-26/RA110> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/105001024/2025-26/syllabus> ;
    ns1:inpersonHours "72 horas (46.2%)"@es ;
    ns1:numberOfCredits 6.0 ;
    ns1:otherInformation """En cuanto a la metodología docente que vamos a emplear, esta se centra en dar un enfoque muy práctico a la asignatura. Con el fin de motivar y reforzar el aprendizaje por parte del estudiantado, se emplearán varias metodologías docentes innovadoras (https://innovacioneducativa.upm.es/guias-pdi) [innovacioneducativa.upm.es ]:
Learning by doing: todos los temas se refuerzan con prácticas de programación, donde se fomenta la adquisición de competencias prácticas en la resolución de problemas relacionados con la teoría (paralelización, MPI, GPUs, vectorización,... todo ello en Python).
Aprendizaje basado en proyectos: Al final de la asignatura hay un proyecto en el que aplican buena parte de los visto en teoría. Mediante el desarrollo del mismo, se busca que los alumnos exploren la autonomía en el aprendizaje.
Aprendizaje basado en problemas: Se plantean en el aula numerosos problemas prácticos que se resuelven colectivamente entre todos en clase
Aprendizaje basado en retos: se estructura el aprendizaje en módulos concretos, progresivos, proponiendo a los estudiantes de forma gradual desafíos específicos en las distintas prácticas.
Design Thinking: En el proyecto, a partir del enunciado, deben abordar la resolución de problemas más complejos que los que han visto en las prácticas, tutelándoles y validando su trabajo y diseño en cada paso.
Aprendizaje cooperativo: Tanto las prácticas como el proyecto se realizan en grupos para fomentar el trabajo en equipo."""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "72 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/105001024/2025-26/eventSchedule> ;
    schema:description """En esta asignatura se describirá la infraestructura Hardware y Software que se utiliza para poder procesar el enorme volumen de datos que suele manejarse en la Ciencia de Datos y en la Inteligencia Artificial. Para ello se abordará los siguientes temas:
- Computación de alto rendimiento
- Sistemas Distribuidos
- Procesamiento batch de datos"""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/antonio.garcia.dopico%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/antonio.garcia.dopico%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/fernando.perez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/joseluis.pedraza%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/julian.arenas.guerrero%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/mariaisabel.garciac%40upm.es> ;
    schema:name "Arquitecturas para el Procesamiento Masivo de Datos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105001024/2025-26/CB01> a ns1:Competency ;
    ns1:competencyCode "CB01" ;
    ns1:competencyDescription "Que los estudiantes hayan demostrado poseer y comprender conocimientos en un área de estudio que parte de la base de la educación secundaria general, y se suele encontrar a un nivel que, si bien se apoya en libros de texto avanzados, incluye también algunos aspectos que implican conocimientos procedentes de la vanguardia de su campo de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105001024/2025-26/CB02> a ns1:Competency ;
    ns1:competencyCode "CB02" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar sus conocimientos a su trabajo o vocación de una forma profesional y posean las competencias que suelen demostrarse por medio de la elaboración y defensa de argumentos y la resolución de problemas dentro de su área de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105001024/2025-26/CB03> a ns1:Competency ;
    ns1:competencyCode "CB03" ;
    ns1:competencyDescription "Que los estudiantes tengan la capacidad de reunir e interpretar datos relevantes (normalmente dentro de su área de estudio) para emitir juicios que incluyan una reflexión sobre temas relevantes de índole social, científica o ética"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105001024/2025-26/CB05> a ns1:Competency ;
    ns1:competencyCode "CB05" ;
    ns1:competencyDescription "Que los estudiantes hayan desarrollado aquellas habilidades de aprendizaje necesarias para emprender estudios posteriores con un alto grado de autonomía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105001024/2025-26/CE07> a ns1:Competency ;
    ns1:competencyCode "CE07" ;
    ns1:competencyDescription "Capacidad de diseñar e implementar sistemas de información (incluyendo modelos de datos y estrategias de gestión de datos) dimensionados para gestionar el volumen, velocidad y variedad de los datos, de forma adecuada para su almacenamiento, procesamiento y acceso para tratamientos posteriores."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105001024/2025-26/CE08> a ns1:Competency ;
    ns1:competencyCode "CE08" ;
    ns1:competencyDescription "Poseer las destrezas para aplicar las tecnologías actuales de computación de altas prestaciones para diseñar e implementar nuevas aplicaciones de ciencia de datos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105001024/2025-26/CG02> a ns1:Competency ;
    ns1:competencyCode "CG02" ;
    ns1:competencyDescription "Capacidad para organizar y planificar tareas y proyectos, identificando objetivos, prioridades, plazos, recursos y riesgos, y controlando los procesos establecidos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105001024/2025-26/CG04> a ns1:Competency ;
    ns1:competencyCode "CG04" ;
    ns1:competencyDescription "Capacidad para innovar y encontrar soluciones creativas en situaciones complejas o de incertidumbre en el ámbito de la ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105001024/2025-26/CG06> a ns1:Competency ;
    ns1:competencyCode "CG06" ;
    ns1:competencyDescription "Identificar y utilizar las tecnologías de la información y las comunicaciones más adecuadas en el ámbito de la ingeniería."@es .

