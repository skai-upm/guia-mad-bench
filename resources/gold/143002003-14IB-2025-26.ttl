<https://guia-kg.skai.etsisi.upm.es/resource/143002003/2025-26/syllabus> a ns1:Syllabus ;
    ns1:hasItem <https://guia-kg.skai.etsisi.upm.es/resource/143002003/2025-26/syllabus/0>,
        <https://guia-kg.skai.etsisi.upm.es/resource/143002003/2025-26/syllabus/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/143002003/2025-26/syllabus/2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/143002003/2025-26/syllabus/3>,
        <https://guia-kg.skai.etsisi.upm.es/resource/143002003/2025-26/syllabus/4>,
        <https://guia-kg.skai.etsisi.upm.es/resource/143002003/2025-26/syllabus/5>,
        <https://guia-kg.skai.etsisi.upm.es/resource/143002003/2025-26/syllabus/6>,
        <https://guia-kg.skai.etsisi.upm.es/resource/143002003/2025-26/syllabus/7>,
        <https://guia-kg.skai.etsisi.upm.es/resource/143002003/2025-26/syllabus/8>,
        <https://guia-kg.skai.etsisi.upm.es/resource/143002003/2025-26/syllabus/9> .

<https://guia-kg.skai.etsisi.upm.es/resource/143002003/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. INTRODUCCIÓN."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143002003/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Introducción a la mecánica computacional en medios continuos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143002003/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "2. MEF NO LINEAL."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143002003/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "2.1. Introducción al cálculo no lineal de estructuras. Concepto de no linealidad geométrica, del material, de fuerzas y de contacto. Método de Newton-Raphson. Cálculo de la matriz de rigidez tangente. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143002003/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "3. TEORÍA DE LA ESTABILIDAD ESTRUCTURAL."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143002003/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "3.1. 2.1. Repaso al concepto de Pandeo y carga crítica. Pandeo elástico e inelástico. Modos de Pandeo. Matriz de Rigidez geométrica. Cálculo computacional de autovalores y autovectores en pandeo. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143002003/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "4. NO-LINEALIDAD GEOMÉTRICA: GRANDES DEFORMACIONES."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143002003/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "4.1. Tensor gradiente de deformaciones. Tensores métricos. Descomposición polar. Tensores de deformación. Tensores de tensión. Tensores conjugados de trabajo. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143002003/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "5. HIPERELASTICIDAD"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143002003/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "5.1. Comportamiento de polímeros y materiales biológicos. Modelos hiperelásticos. Materiales hiperelásticos compresiblles e incompresibles. Introducción a la hiperelasticidad WYPiWYG. Sin subniveles"@es .

