    ns1:numberOfCredits 6.0 ;
    ns1:otherInformation """La asignatura se relaciona con los Objetivos de Desarrollo Sostenible (ODS) siguientes:
ODS3. Salud y bienestar.
ODS4. Educación de calidad.
ODS8. Trabajo decente y crecimiento económico.
ODS9. Industria, innovación e infraestructura.
ODS11. Ciudades y comunidades sostenibles."""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "74 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/113000035/2025-26/eventSchedule> ;
    schema:description """El objetivo que se intenta conseguir con esta asignatura es que los alumnos sean capaces de:
Configurar y optimizar su entorno digital de trabajo para que puedan análizar los datos obtenidos en el campo de las Ciencias de la Actividad Física y el Deporte.
Conocer las técnicas de muestreo de datos más utilizadas en las publicaciones de referencia en el campo de las Ciencias de la Actividad Física y el Deporte.
Dominar el procedimiento a seguir en las diferentes pruebas estadísticas más utilizadas en las publicaciones de referencia en el campo de las Ciencias de la Actividad Física y el Deporte.
Analizar los resultados de las diferentes pruebas estadísticas más utilizadas en las publicaciones de referencia en el campo de las Ciencias de la Actividad Física y el Deporte.
Comprender el proceso de redacción del apartado resultados en las publicaciones de referencia en el campo de las Ciencias de la Actividad Física y el Deporte."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/jorge.garcia%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/jorge.garcia%40upm.es> ;
    schema:name "Analisis de Datos Aplicados a la Actividad Fisica y el Deporte"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000035/2025-26/CB10> a ns1:Competency ;
    ns1:competencyCode "CB10" ;
    ns1:competencyDescription "Que los estudiantes posean las habilidades de aprendizaje que les permitan continuar estudiando de un modo que habrá de ser en gran medida autodirigido o autónomo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000035/2025-26/CB6> a ns1:Competency ;
    ns1:competencyCode "CB6" ;
    ns1:competencyDescription "Poseer y comprender conocimientos que aporten una base u oportunidad de ser originales en el desarrollo y/o aplicación de ideas, a menudo en un contexto de investigación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000035/2025-26/CB9> a ns1:Competency ;
    ns1:competencyCode "CB9" ;
    ns1:competencyDescription "Que los estudiantes sepan comunicar sus conclusiones y los conocimientos y razones últimas que las sustentan a públicos especializados y no especializados de un modo claro y sin ambigüedades"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000035/2025-26/CE1> a ns1:Competency ;
    ns1:competencyCode "CE1" ;
    ns1:competencyDescription "Conocimiento de los aspectos más relevantes del conocimiento científico y su relación con las CC de la Actividad Física y del Deporte."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000035/2025-26/CE4> a ns1:Competency ;
    ns1:competencyCode "CE4" ;
    ns1:competencyDescription "Conocimiento de los fundamentos estadísticos para el análisis de datos propios del mundo del Deporte."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000035/2025-26/CE8> a ns1:Competency ;
    ns1:competencyCode "CE8" ;
    ns1:competencyDescription "Ser capaz realizar proyectos de investigación desde el punto de vista metodológico y procedimental."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000035/2025-26/CG2> a ns1:Competency ;
    ns1:competencyCode "CG2" ;
    ns1:competencyDescription "Desarrollo de las habilidades instrumentales básicas para la comunicación oral y escrita en un marco científico, siendo capaces de exponer reflexiones, ideas y conclusiones de manera sintética y ante diversos públicos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000035/2025-26/RA10> a ns1:LearningResult ;
    ns1:learningResultCode "RA10" ;
    ns1:learningResultDescription "Conocimiento de los fundamentos estadísticos para el análisis de datos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000035/2025-26/RA12> a ns1:LearningResult ;
    ns1:learningResultCode "RA12" ;
    ns1:learningResultDescription "Utilización de los modelos estadísticos básicos con ayuda de un programa informático (SPSS o Statgraphics). Interpretación y crítica de resultados estadísticos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000035/2025-26/RA47> a ns1:LearningResult ;
    ns1:learningResultCode "RA47" ;
    ns1:learningResultDescription "Dominar las técnicas de análisis univariado para la organización y descripción de datos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000035/2025-26/RA48> a ns1:LearningResult ;
    ns1:learningResultCode "RA48" ;
    ns1:learningResultDescription "Dominar las técnicas de análisis bivariado para la organización y descripción de datos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000035/2025-26/RA49> a ns1:LearningResult ;
    ns1:learningResultCode "RA49" ;
    ns1:learningResultDescription "Dominar las técnicas inferenciales parámetricas y no paramétricas más utilizadas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000035/2025-26/RA50> a ns1:LearningResult ;
    ns1:learningResultCode "RA50" ;
    ns1:learningResultDescription "Dominar el uso del paquete estadístico SPSS"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000035/2025-26/RA51> a ns1:LearningResult ;
    ns1:learningResultCode "RA51" ;
    ns1:learningResultDescription "Dominar la redacción del apartado de resultados en una publicación periódica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000035/2025-26/T1> a ns1:Competency ;
    ns1:competencyCode "T1" ;
    ns1:competencyDescription "Capacidad de resolución de problemas aplicando conocimientos de Ciencias de la Actividad Física y del Deporte."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000035/2025-26/T2> a ns1:Competency ;
