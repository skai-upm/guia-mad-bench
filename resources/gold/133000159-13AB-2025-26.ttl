<https://guia-kg.skai.etsisi.upm.es/resource/133000159> a ns1:Course ;
    ns1:courseType "Optativa"@es ;
    ns1:courseYear 1 ;
    ns1:semester "Segundo semestre"@es ;
    schema:courseCode 133000159 ;
    schema:hasCourseInstance <https://guia-kg.skai.etsisi.upm.es/resource/133000159/2025-26> ;
    schema:name "Management Skills For Rural And Local Tourism Projects"@en,
        "Competencias para la Dirección de Proyectos de Turismo Rural y Local"@es ;
    schema:numberOfCredits 3.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/133000159/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/133000159/2025-26/CB08>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000159/2025-26/CB09>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000159/2025-26/CE02>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000159/2025-26/CE09>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000159/2025-26/CG02> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/133000159/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000159/2025-26/didactic_resource/2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000159/2025-26/didactic_resource/3> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/133000159/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/133000159/2025-26/RA18>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000159/2025-26/RA19>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000159/2025-26/RA57> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/133000159/2025-26/syllabus> ;
    ns1:inpersonHours "30 horas y 30 minutos (39.1%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation "En esta asignatura no se tratan específicamente los ODS relacionados con el Turismo porque ya se han tratado en otra anterior sobre Planificación. Sin embargo se refuerza en el apartado de Competencias contextuales como el director de proyectos debe tener conocimiento y experiencia sobre la conexión de su proyecto con los marcos de referencia, y por consiguiente con su contribución, siquiera indirecta a los ODS."@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "54 horas y 30 minutos"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/133000159/2025-26/eventSchedule> ;
    schema:description "En el curso se abordan casos prácticos para tratar los aspectos relacionados con los procesos y los posibles pasos a emprender para identificar y mejorar los elementos de competencia. Se relacionan un conjunto de acciones y actividades interrelacionadas que se pueden llevar a cabo para alcanzar una serie de resultados concretos en relación una investigación aplicada en torno a los proyectos."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/ignacio.delosrios%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/ignacio.delosrios%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/joseluis.yague%40upm.es> ;
    schema:name "Competencias para la Dirección de Proyectos de Turismo Rural y Local"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000159/2025-26/CB08> a ns1:Competency ;
    ns1:competencyCode "CB08" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de integrar conocimientos y enfrentarse a la complejidad de formular juicios a partir de una información que, siendo incompleta o limitada, incluya reflexiones sobre las responsabilidades sociales y éticas vinculadas a la aplicación de sus conocimientos y juicios"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000159/2025-26/CB09> a ns1:Competency ;
    ns1:competencyCode "CB09" ;
    ns1:competencyDescription "Que los estudiantes sepan comunicar sus conclusiones y los conocimientos y razones últimas que las sustentan a públicos especializados y no especializados de un modo claro y sin ambigüedades"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000159/2025-26/CE02> a ns1:Competency ;
    ns1:competencyCode "CE02" ;
    ns1:competencyDescription "Capacidad para identificar, formular y resolver problemas sobre turismo ecológico y sostenible."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000159/2025-26/CE09> a ns1:Competency ;
    ns1:competencyCode "CE09" ;
    ns1:competencyDescription "Capacidad para coordinar al personal involucrado en proyectos y empresas de ecoturismo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000159/2025-26/CG02> a ns1:Competency ;
    ns1:competencyCode "CG02" ;
    ns1:competencyDescription "Capacidad para el liderazgo, organización y planificación de equipos humanos multidisciplinares y en contextos internacionales relacionados con el ecoturismo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000159/2025-26/RA18> a ns1:LearningResult ;
    ns1:learningResultCode "RA18" ;
    ns1:learningResultDescription "Identificar, valorar y tener en cuenta factores humanos, sociales y ambientales que afectan a la dirección de Proyecto de turismo Rural y Local"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000159/2025-26/RA19> a ns1:LearningResult ;
    ns1:learningResultCode "RA19" ;
    ns1:learningResultDescription "Conocer las competencias para la dirección de proyectos según esquemas internacionales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000159/2025-26/RA57> a ns1:LearningResult ;
    ns1:learningResultCode "RA57" ;
    ns1:learningResultDescription "Dominio de los contenidos de la asignatura"@es .

