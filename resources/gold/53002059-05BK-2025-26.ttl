        <https://guia-kg.skai.etsisi.upm.es/resource/53002059/2025-26/RA45> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/53002059/2025-26/syllabus> ;
    ns1:inpersonHours "30 horas (38.5%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation ""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "32 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/53002059/2025-26/eventSchedule> ;
    schema:description "La asignatura repasará conceptos estadísticos básicos y dará al alumno una visión de la estructura más habitual de las fuentes de datos, entrando luego en la aplicación práctica de las herramientas más comunes al análisis de datos en lenguaje de programación PYTHON, de uso común en la ciencia de datos. El curso se impartirá sobre cuadernos de JUPYTER. Además se dará de una introducción práctica sobre el control de versiones mediante GIT y la utilización de algoritmos de inteligencia artificial (AI) y de aprendizaje automático (Machine Learning) sobre bases de datos mediante el uso de SCIKIT-LEARN."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/joseluis.sanchezr%40upm.es> ;
    schema:inLanguage "Inglés/Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/joseluis.sanchezr%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/vazquez.martinez%40upm.es> ;
    schema:name "Data Analysis"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002059/2025-26/CB7> a ns1:Competency ;
    ns1:competencyCode "CB7" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en entornos nuevos o poco conocidos dentro de contextos más amplios (o multidisciplinares) relacionados con su área de estudio/ Students are capable of applying their knowledge, understanding, and problem"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002059/2025-26/CB8> a ns1:Competency ;
    ns1:competencyCode "CB8" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de integrar conocimientos y enfrentarse a la complejidad de formular juicios a partir de una información que, siendo incompleta o limitada, incluya reflexiones sobre las responsabilidades sociales y éticas vinculadas a la aplicación de sus conocimientos y juicios/ Students are capable of integrating knowledge and making complex decisions, which, although based on incomplete or limited information, require reflection on social and ethical responsibilities linked to the application of their knowledge and opinions."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002059/2025-26/CE13> a ns1:Competency ;
    ns1:competencyCode "CE13" ;
    ns1:competencyDescription "Entender la evolución y el funcionamiento de los mercados de petróleo, gas y electricidad. Conocer los principales tipos de diseño de los mercados de electricidad y gas que existen en la experiencia internacional y los criterios bajo los que se han diseñado, y ser capaz de analizar cuál es la regulación más adecuada para cada situación./ Understand the evolution and operation of the oil, gas and electricity markets. Know the main types of design of electricity and gas markets that exist in international experience and the criteria under which they have been designed, and be able to analyze which is the most appropriate regulation for each situation."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002059/2025-26/CE19> a ns1:Competency ;
    ns1:competencyCode "CE19" ;
    ns1:competencyDescription "Entender el funcionamiento de redes eléctricas en un contexto de decarbonización de la sociedad/ Understand the operation of electrical networks in a context of decarbonization of society"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002059/2025-26/CE8> a ns1:Competency ;
    ns1:competencyCode "CE8" ;
    ns1:competencyDescription "Disponer de habilidades, criterios y conocimientos para investigar, desarrollar e innovar en el campo de la energía: tecnologías renovables y no renovables, almacenamiento, vectores energéticos, en un contexto de decarbonización del sistema./ Skills, criteria and knowledge to research, develop and innovate in the field of energy: renewable and non"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002059/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Aplicar conocimientos de ciencias y tecnologías avanzadas a la práctica profesional o investigadora de la Ingeniería Energética./ Apply knowledge of advanced science and technology to the professional or research practice of Energy Engineering."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002059/2025-26/CG2> a ns1:Competency ;
    ns1:competencyCode "CG2" ;
    ns1:competencyDescription "Poseer capacidad para diseñar, desarrollar, implementar, gestionar y mejorar productos, sistemas y procesos en los distintos ámbitos energéticos, usando técnicas analíticas, computacionales o experimentales avanzadas./ Ability to design, develop, implement, manage and improve products, systems and processes in the different energy fields, using advanced analytical, computational or experimental techniques."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002059/2025-26/CT1> a ns1:Competency ;
    ns1:competencyCode "CT1" ;
    ns1:competencyDescription "Aplica. Habilidad para aplicar conocimientos científicos, matemáticos y tecnológicos en sistemas relacionados con la práctica de la ingeniería./ Apply. Ability to apply scientific, mathematical and technological knowledge in systems related to the practice of engineering."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002059/2025-26/CT11> a ns1:Competency ;
    ns1:competencyCode "CT11" ;
    ns1:competencyDescription "Usa herramientas. Habilidad para usar las técnicas, destrezas y herramientas ingenieriles modernas necesarias para la práctica de la ingeniería./ Use tools. Ability to use modern engineering techniques, skills, and tools necessary for engineering practice."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002059/2025-26/CT2> a ns1:Competency ;
    ns1:competencyCode "CT2" ;
    ns1:competencyDescription "Experimenta. Habilidad para diseñar y realizar experimentos, así como analizar e interpretar datos./ Experiment. Ability to design and perform experiments, as well as analyze and interpret data."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002059/2025-26/CT5> a ns1:Competency ;
    ns1:competencyCode "CT5" ;
    ns1:competencyDescription "Resuelve. Habilidad para identificar, formular y resolver problemas de ingeniería./ Solve. Ability to identify, formulate and solve engineering problems."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002059/2025-26/CT9> a ns1:Competency ;
    ns1:competencyCode "CT9" ;
    ns1:competencyDescription "Se actualiza. Reconocimiento de la necesidad y la habilidad para comprometerse al aprendizaje continuo./ Updating. Recognition of the need and ability to commit to continuous learning."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002059/2025-26/RA18> a ns1:LearningResult ;
    ns1:learningResultCode "RA18" ;
    ns1:learningResultDescription "Analizar los efectos socioeconómicos y ambientales de la implantación de escenarios energéticos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002059/2025-26/RA35> a ns1:LearningResult ;
    ns1:learningResultCode "RA35" ;
    ns1:learningResultDescription "Comprender e identificar las conexiones entre los parámetros de diseño y operación de los sistemas energéticos con sus dimensiones energética, exergética, medio ambiental y económica."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002059/2025-26/RA36> a ns1:LearningResult ;
    ns1:learningResultCode "RA36" ;
    ns1:learningResultDescription "Proponer opciones de mejora global de un sistema energético"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002059/2025-26/RA45> a ns1:LearningResult ;
    ns1:learningResultCode "RA45" ;
    ns1:learningResultDescription "RA 90"@es .

