<https://guia-kg.skai.etsisi.upm.es/resource/103000626/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Introducción de la Asignatura. Simulaciones usando Lógica Borrosa."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000626/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Introducción de la Asignatura. Simulación de procesos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000626/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Simulación usando Lógica Borrosa: Ampliación a la Computación con Palabras y Percepciones: construcción del modelo granular lingüístico de un fenómeno (GLMP) y su simulación. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000626/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "2. Simulación de Procesos Discretos. Simulación basada en agentes. Aplicación práctica de la modelización a problemas científicos. Uso de herramientas de software para la modelización y el estudio de sistemas y procesos reales. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000626/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "3. Simulación de Procesos Continuos. Técnicas probabilísticas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000626/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "3.1. Simulación mediante técnicas probabilísticas: Métodos de Montecarlo. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000626/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "3.2. Simulación de procesos continuos mediante ecuaciones diferenciales: problemas de valor inicial y problemas de valor en la frontera. Sin subniveles"@es .

