    ns1:inpersonHours "47 horas (40.2%)"@es ;
    ns1:numberOfCredits 4.5 ;
    ns1:otherInformation """La asignatura se relaciona con el ODS9 y el ODS12
En caso de tener que impartir docencia no presencial se utilizará la plataforma TEAMS para la impartición de las clases y tutorías. Las tutorías pueden ser acordadas con el profesor mediante correo electrónico.
El profesor solo puede atender a un máximo de 10 alumnos en las prácticas de laboratorio."""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "51 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/65001041/2025-26/eventSchedule> ;
    schema:description "La asignatura pretende recoger los principios elementales de la Ingeniería de Materiales, basada en la utilización de los tratamientos térmicos, técnicas de procesado y comportamiento en servicio de los materiales y su selección."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/josemanuel.ruizr%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/josemanuel.ruizr%40upm.es> ;
    schema:name "Ingenieria de Materiales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001041/2025-26/CG%201> a ns1:Competency ;
    ns1:competencyCode "CG 1" ;
    ns1:competencyDescription "Conocer y aplicar conocimientos de ciencias y tecnologías básicas a la práctica de la Tecnología Minera."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001041/2025-26/CG%202> a ns1:Competency ;
    ns1:competencyCode "CG 2" ;
    ns1:competencyDescription "Poseer capacidad para diseñar, analizar, calcular, proyectar, construir, mantener, conservar, explotar, desarrollar, implementar, gestionar y mejorar productos, sistemas y procesos en los distintos ámbitos de las Tecnologías Mineras, usando técnicas analíticas, computacionales o experimentales apropiadas, incluyendo la función de asesoría en estos campos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001041/2025-26/CG%203> a ns1:Competency ;
    ns1:competencyCode "CG 3" ;
    ns1:competencyDescription "Aplicar los conocimientos adquiridos para identificar, formular y resolver problemas dentro de contextos amplios y multidisciplinarios, siendo capaces de integrar conocimientos, trabajando en equipos multidisciplinares."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001041/2025-26/CG%205> a ns1:Competency ;
    ns1:competencyCode "CG 5" ;
    ns1:competencyDescription "Saber comunicar los conocimientos y conclusiones, tanto de forma oral, escrita y gráfica, a públicos especializados y no especializados de un modo claro y sin ambigüedades."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001041/2025-26/CG%206> a ns1:Competency ;
    ns1:competencyCode "CG 6" ;
    ns1:competencyDescription "Poseer habilidades de aprendizaje que permitan continuar estudiando a lo largo de la vida para su adecuado desarrollo profesional"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001041/2025-26/CG%207> a ns1:Competency ;
    ns1:competencyCode "CG 7" ;
    ns1:competencyDescription "Incorporar nuevas tecnologías y herramientas de la ingeniería en tecnología minera en sus actividades profesionales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001041/2025-26/F36> a ns1:Competency ;
    ns1:competencyCode "F36" ;
    ns1:competencyDescription "Ingeniería de los materiales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001041/2025-26/F37> a ns1:Competency ;
    ns1:competencyCode "F37" ;
    ns1:competencyDescription "Metalurgia y tratamiento de concentrados minerales, metales y aleaciones: Industria metalurgia férrea y no férrea, aleaciones especiales, ensayos metalotécnicos, etc"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001041/2025-26/F39> a ns1:Competency ;
    ns1:competencyCode "F39" ;
    ns1:competencyDescription "Tratamiento de superficies y soldaduras."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001041/2025-26/F40> a ns1:Competency ;
    ns1:competencyCode "F40" ;
    ns1:competencyDescription "Ensayos y control de calidad de materiales metálicos y no metálicos, materiales cerámicos y plásticos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001041/2025-26/RA201> a ns1:LearningResult ;
    ns1:learningResultCode "RA201" ;
    ns1:learningResultDescription "Comprender los principios básicos de las distintas técnicas de procesado de los materiales de ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001041/2025-26/RA202> a ns1:LearningResult ;
    ns1:learningResultCode "RA202" ;
    ns1:learningResultDescription "Comprender los problemas que presenta el comportamiento en servicio de los materiales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65001041/2025-26/RA203> a ns1:LearningResult ;
    ns1:learningResultCode "RA203" ;
    ns1:learningResultDescription "Comprender los criterios de selección de los materiales de ingeniería."@es .

