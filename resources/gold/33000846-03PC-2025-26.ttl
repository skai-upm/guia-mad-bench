<https://guia-kg.skai.etsisi.upm.es/resource/33000846/2025-26/RA132> a ns1:LearningResult ;
    ns1:learningResultCode "RA132" ;
    ns1:learningResultDescription "Conocimiento de los criterios específicos de intervención en patrimonio del siglo XX."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000846/2025-26/RA86> a ns1:LearningResult ;
    ns1:learningResultCode "RA86" ;
    ns1:learningResultDescription "Reconocer de la normativa y sistemas de la planificación territorial para detectar en ella contextos apropiados para la protección de los bienes patrimoniales inmuebles."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000846/2025-26/RA87> a ns1:LearningResult ;
    ns1:learningResultCode "RA87" ;
    ns1:learningResultDescription "Discriminar entre las políticas preventivas en la conservación del Patrimonio Inmueble: inventario, jerarquización y selección"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000846/2025-26/RA88> a ns1:LearningResult ;
