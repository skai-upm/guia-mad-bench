    ns1:otherInformation "La modalidad de docencia a impartir se corresponderá en cada momento con lo que establezca la normativa/legislación vigente."@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
