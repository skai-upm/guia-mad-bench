    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/53002094/2025-26/eventSchedule> ;
    schema:description """La asignatura se ocupa de la aplicación de métodos numéricos avanzados para resolver problemas de ingeniería industrial que previamente se han formulado en términos de ecuaciones diferenciales. Los objetivos de la asignatura son los siguientes:
- Construir y analizar algunos algoritmos numéricos para resolver problemas matemáticos formulados mediante ecuaciones en derivadas parciales.
- Análisis e implementación de algoritmos numéricos avanzados para resolver problemas complejos, tales como problemas de trasmisión de calor, problemas estructurales o dinámica de fluidos computacional.
- Utilización del ordenador como herramienta de cálculo en la resolución de problemas.
La herramienta principal que se estudiará en la asignatura es el Método de Elementos Finitos (MEF). Se prestará especial atención a la implementación del método utilizando como entorno de trabajo GNU Octave o Matlab."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/pedro.galan%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/jm.chaquet%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/pedro.galan%40upm.es> ;
    schema:name "Técnicas Numéricas Avanzadas en la Ingeniería"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002094/2025-26/%28a%29> a ns1:Competency ;
    ns1:competencyCode "(a)" ;
    ns1:competencyDescription "APLICA. Habilidad para aplicar conocimientos científicos, matemáticos y tecnológicos en sistemas relacionados con la práctica de la ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002094/2025-26/%28e%29> a ns1:Competency ;
    ns1:competencyCode "(e)" ;
    ns1:competencyDescription "RESUELVE. Habilidad para identificar, formular y resolver problemas de ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002094/2025-26/%28k%29> a ns1:Competency ;
    ns1:competencyCode "(k)" ;
    ns1:competencyDescription "USA HERRAMIENTAS. Habilidad para usar las técnicas, destrezas y herramientas ingenieriles modernas necesarias para la práctica de la ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002094/2025-26/CG01> a ns1:Competency ;
    ns1:competencyCode "CG01" ;
    ns1:competencyDescription "Tener conocimientos adecuados de los aspectos científicos y tecnológicos de: métodos matemáticos, analíticos y numéricos en la ingeniería, ingeniería eléctrica, ingeniería energética, ingeniería química, ingeniería mecánica, mecánica de medios continuos, electrónica industrial, automática, fabricación, materiales, métodos cuantitativos de gestión, informática industrial, urbanismo, infraestructuras, etc."@es .

