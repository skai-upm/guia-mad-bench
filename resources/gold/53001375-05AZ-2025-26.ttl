<https://guia-kg.skai.etsisi.upm.es/resource/53001375/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Introducción a la Nanotecnología"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001375/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Nanomateriales en la naturaleza y su historia. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001375/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "3.2. Formas alotrópicas del carbono (fullerenos, nanotubos de carbono y grafeno) y redes orgánicas covalentes: síntesis, propiedades y aplicaciones industriales. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001375/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "3.3. Filosilicatos y arcillas: síntesis, propiedades y aplicaciones industriales. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001375/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "3.4. Cerámicos nanoestructurados: síntesis, propiedades y aplicaciones industriales. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001375/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "3.5. Nanopartículas en base a polisacáridos, lípidos y proteínas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001375/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "3.6. Nanocomposites poliméricos: polímeros termoplásticos y termoestables reforzados. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001375/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Estado actual de la nanotecnología, investigación, mercado, tendencias y oportunidades. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001375/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "1.3. Definición de tamaño, relación superficie-volumen, estructuras y propiedades. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001375/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "1.4. Aspectos relacionas con la seguridad y la legislación de los nanomateriales. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001375/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "2. Síntesis y procesado de nanomateriales (Aproximación top-down/bottom-up)"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001375/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "2.1. Síntesis y procesado de nanomateriales: métodos físicos (Deposición en fase vapor, métodos de aerosol, técnicas electrodinámicas (electrospraying y electrospinning), precipitación, sol-gel, etc.) Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001375/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "2.2. Síntesis y procesado de nanomateriales: métodos químicos (Mediante tecnología de fluidos supercríticos, reducción química, polimerización, emulsificación/difusión de disolvente, nanoprecipitación, diálisis, etc.) Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001375/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "3. Nanomateriales: propiedades, caracterización y aplicaciones"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53001375/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "3.1. Nanopartículas metálicas, semiconductoras y magnéticas: síntesis, propiedades y aplicaciones industriales. Sin subniveles"@es .

