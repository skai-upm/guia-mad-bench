    schema:courseCode 33000836 ;
    schema:hasCourseInstance <https://guia-kg.skai.etsisi.upm.es/resource/33000836/2025-26> ;
    schema:name "Challenges In Cultural Heritage Management"@en,
        "Desafíos en la Gestión del Patrimonio Cultural"@es ;
    schema:numberOfCredits 6.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/33000836/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/33000836/2025-26/CE02>,
        <https://guia-kg.skai.etsisi.upm.es/resource/33000836/2025-26/CE16>,
