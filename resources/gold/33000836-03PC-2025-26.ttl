        <https://guia-kg.skai.etsisi.upm.es/resource/33000836/2025-26/CG17>,
        <https://guia-kg.skai.etsisi.upm.es/resource/33000836/2025-26/CT01>,
        <https://guia-kg.skai.etsisi.upm.es/resource/33000836/2025-26/CT02>,
        <https://guia-kg.skai.etsisi.upm.es/resource/33000836/2025-26/CT04>,
