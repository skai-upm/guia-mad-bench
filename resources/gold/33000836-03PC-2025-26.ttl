        <https://guia-kg.skai.etsisi.upm.es/resource/33000836/2025-26/CT10> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/33000836/2025-26/didactic_resource/1> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/33000836/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/33000836/2025-26/RA4>,
        <https://guia-kg.skai.etsisi.upm.es/resource/33000836/2025-26/RA6>,
        <https://guia-kg.skai.etsisi.upm.es/resource/33000836/2025-26/RA7>,
        <https://guia-kg.skai.etsisi.upm.es/resource/33000836/2025-26/RA8> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/33000836/2025-26/syllabus> ;
    ns1:inpersonHours "50 horas (32.1%)"@es ;
    ns1:numberOfCredits 6.0 ;
    ns1:otherInformation """Enlace a la ficha de la asignatura en la web del Máster: https://www.ucm.es/patrimonio-cultural-siglo21/plan-de-estudios.
Las asignatura se relaciona con el ODS 11, Ciudades y comunidades sostenibles, en su meta de redoblar los esfuerzos para proteger y salvaguardar el patrimonio cultural y natural."""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "50 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/33000836/2025-26/eventSchedule> ;
    schema:description "En esta segunda asignatura de la materia introductoria se afrontan se4is nuevos desafíos en la gestión del patrimonio cultural: la transversalidad académica, la ampliación de los contextos espaciales, los nuevos tipos de patrimonios, el impacto social, los discursos postcoloniales y la conservación experimental."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/rodrigo.delao%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/fernando.vela%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/m.palma%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/rodrigo.delao%40upm.es> ;
    schema:name "Desafíos en la Gestión del Patrimonio Cultural"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000836/2025-26/CE02> a ns1:Competency ;
    ns1:competencyCode "CE02" ;
    ns1:competencyDescription "Analizar los problemas sociales derivados de los conflictos entre la conservación y el desarrollo del Patrimonio Cultural"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000836/2025-26/CE16> a ns1:Competency ;
    ns1:competencyCode "CE16" ;
    ns1:competencyDescription "Contrastar los distintos riesgos que aquejan el Patrimonio Cultural Inmaterial y la repercusión económica que dichos peligros puede acarrear para su salvaguarda e iniciarse en la investigación sobre ello"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000836/2025-26/CG01> a ns1:Competency ;
    ns1:competencyCode "CG01" ;
    ns1:competencyDescription "Identificar los principios básicos del Patrimonio Cultural, de su gestión y de su investigación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000836/2025-26/CG04> a ns1:Competency ;
    ns1:competencyCode "CG04" ;
    ns1:competencyDescription "Contrastar la situación actual de la gestión del Patrimonio Cultural y abordar la propuesta de nuevos modelos de tutela, investigación y actividad profesional"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000836/2025-26/CG17> a ns1:Competency ;
    ns1:competencyCode "CG17" ;
    ns1:competencyDescription "Desarrollar instrumentos de protección y salvaguarda del Patrimonio Cultural"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000836/2025-26/CT01> a ns1:Competency ;
    ns1:competencyCode "CT01" ;
    ns1:competencyDescription "Analizar y sintetizar la información disponible y/o los resultados obtenidos, en un trabajo de investigación, en el ámbito que aquí compete"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000836/2025-26/CT02> a ns1:Competency ;
    ns1:competencyCode "CT02" ;
    ns1:competencyDescription "Desarrollar el proceso marcado por el método científico en el planteamiento y en la realización de trabajos de investigación y/o profesionales diversos, fomentando el espíritu crítico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000836/2025-26/CT04> a ns1:Competency ;
    ns1:competencyCode "CT04" ;
    ns1:competencyDescription "Organizar y planificar sistemas de gestión adecuados para el Patrimonio Cultural en cada una de sus especialidades"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000836/2025-26/CT06> a ns1:Competency ;
    ns1:competencyCode "CT06" ;
    ns1:competencyDescription "Analizar adecuadamente la bibliografía y recopilar referencias en el área de la gestión e investigación del Patrimonio Cultura"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000836/2025-26/CT10> a ns1:Competency ;
    ns1:competencyCode "CT10" ;
    ns1:competencyDescription "Desarrollar una capacidad permanente de compromiso ético y de respeto, en lo que se refiere al bienestar de la ciudadanía y al medio ambiente"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000836/2025-26/RA4> a ns1:LearningResult ;
    ns1:learningResultCode "RA4" ;
    ns1:learningResultDescription ""@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000836/2025-26/RA6> a ns1:LearningResult ;
    ns1:learningResultCode "RA6" ;
    ns1:learningResultDescription "Determinar con conocimientos los problemas sociales derivados de los conflictos entre la conservación y el desarrollo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000836/2025-26/RA7> a ns1:LearningResult ;
    ns1:learningResultCode "RA7" ;
    ns1:learningResultDescription ""@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000836/2025-26/RA8> a ns1:LearningResult ;
    ns1:learningResultCode "RA8" ;
    ns1:learningResultDescription "Identificar y analizar los ámbitos y los contextos en los que se sitúan o deben situarse las iniciativas sociales a favor del Patrimonio Cultural."@es .

