<https://guia-kg.skai.etsisi.upm.es/resource/45000130/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Materiales Metálicos Utilizados en la Construcción Civil"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000130/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Materias primas, obtención de metales y aleaciones, reciclabilidad. Aceros de Construcción, Aceros CORTEN. Características y procesado. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000130/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "3.2. Aceros Tratados Térmicamente, Aceros de Cementación y Nitruración. Hornos de Tratamiento Térmico. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000130/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "3.3. Aceros de Herramientas, Aceros Rápidos HSS. Características y Procesado. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000130/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "3.4. Plantas de Procesado P/M de componentes metálicos. Aceros Sinterizados. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000130/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "3.5. Fundiciones Férreas, características y procesado. Plantas de Fundición y tratamientos de acabado. Otros materiales metálicos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000130/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "4. Materiales para Automoción"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000130/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "4.1. Materiales Metálicos: Aceros HSLA y DPLA, Aceros de Ultra alta resistencia. Características y Procesado. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000130/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "4.2. Materiales Metálicos: Materias primas, obtención de metales y aleaciones, reciclabilidad. Aleaciones de Aluminio, Magnesio y Titanio. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000130/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "4.3. Materiales Poliméricos: Materias primas, obtención y reciclabilidad. Plantas de procesado. Inyección. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000130/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "5. Selección de Materiales Estructurales para Aplicaciones Especiales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000130/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "5.1. Industria del Ferrocarril y Naval Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000130/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Aceros Inoxidables, características y Procesado. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000130/2025-26/syllabus/20> a ns1:SyllabusItem ;
    ns1:itemIndex 20 ;
    ns1:syllabusDescription "5.2. Industria Aeroespacial, Superaleaciones Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000130/2025-26/syllabus/21> a ns1:SyllabusItem ;
    ns1:itemIndex 21 ;
    ns1:syllabusDescription "5.3. Aleaciones antifricción Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000130/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "1.3. Plantas de Procesado de aceros. Fundición, Forja y Laminación. Otros materiales metálicos. Extrusión. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000130/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "2. Materiales No Metálicos para la Construcción Civil"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000130/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "2.1. Materias Primas, Obtención y Reciclado. Plantas de tratamiento de Materiales Cerámicos. Molinos y Mezcladores. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000130/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "2.2. Cemento, Hormigón, áridos, Yeso y Piedra Natural. Características y Procesado. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000130/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "2.3. Otros Materiales: Madera y Materiales Poliméricos Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000130/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "3. Materiales Metálicos para la Fabricación de Componentes en la Industria Mecánica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000130/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "3.1. Materias Primas, Obtención de de materiales y aleaciones. Reciclabilidad. Aceros para engranajes, muelles, tornillería, etc. Características y Procesado. Sin subniveles"@es .

