    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/45000130/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/45000130/2025-26/didactic_resource/2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/45000130/2025-26/didactic_resource/3>,
        <https://guia-kg.skai.etsisi.upm.es/resource/45000130/2025-26/didactic_resource/4> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/45000130/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/45000130/2025-26/RA34>,
        <https://guia-kg.skai.etsisi.upm.es/resource/45000130/2025-26/RA35>,
        <https://guia-kg.skai.etsisi.upm.es/resource/45000130/2025-26/RA36>,
        <https://guia-kg.skai.etsisi.upm.es/resource/45000130/2025-26/RA37>,
        <https://guia-kg.skai.etsisi.upm.es/resource/45000130/2025-26/RA39> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/45000130/2025-26/syllabus> ;
    ns1:inpersonHours "50 horas (38.5%)"@es ;
    ns1:numberOfCredits 5.0 ;
    ns1:otherInformation """Si hubiese que desarrollar telemáticamente la asignatura, la plataforma empleada además de MOODLE, tanto para la docencia como para las tutorías sería TEAMS.
La asignatura se relaciona con el ODS11 y el ODS12."""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "52 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/45000130/2025-26/eventSchedule> ;
    schema:description "El objetivo de esta asignatura es proporcionar a los alumnos una base de conocimientos sólida sobre la microestructura, procesado y propiedades de los materiales utilizados en aplicaciones estructurales. También se estudiarán procedimientos de selección de materiales para aplicaciones estructurales, determinando previamente las condiciones de servicio presentes."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/josemanuel.ruizr%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/alfonsoj.morano%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/josemanuel.ruizr%40upm.es> ;
    schema:name "Materiales Estructurales I"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000130/2025-26/CE%2010.> a ns1:Competency ;
    ns1:competencyCode "CE 10." ;
    ns1:competencyDescription "Saber evaluar la seguridad, durabilidad e integridad estructural de los materiales y componentes fabricados con ellos/ Know how to evaluate the safety, durability and structural integrity of the materials and components manufactured with them"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000130/2025-26/CE%207.> a ns1:Competency ;
    ns1:competencyCode "CE 7." ;
    ns1:competencyDescription "Saber diseñar, desarrollar y controlar los procesos de producción y transformación de materiales / Know how to design, develop and control the processes of production and transformation of materials"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000130/2025-26/CG%2011> a ns1:Competency ;
    ns1:competencyCode "CG 11" ;
    ns1:competencyDescription "Responsabilidad y ética profesional/ Responsibility and professional ethics"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000130/2025-26/CG%202> a ns1:Competency ;
    ns1:competencyCode "CG 2" ;
    ns1:competencyDescription "Capacidad de trabajo en equipo/ Ability to work in a team"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000130/2025-26/CG%203> a ns1:Competency ;
    ns1:competencyCode "CG 3" ;
    ns1:competencyDescription "Comunicación oral y escrita"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000130/2025-26/CG%209> a ns1:Competency ;
    ns1:competencyCode "CG 9" ;
    ns1:competencyDescription "Capacidad de trabajo interdisciplinar/ Capacity for interdisciplinary work"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000130/2025-26/RA34> a ns1:LearningResult ;
    ns1:learningResultCode "RA34" ;
    ns1:learningResultDescription "Utilizar con soltura la comunicación oral y escrita"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000130/2025-26/RA35> a ns1:LearningResult ;
    ns1:learningResultCode "RA35" ;
    ns1:learningResultDescription "Saber trabajar en equipo en entornos interdisciplinares. Ejecutar el trabajo con responsabilidad y respeto a los demás."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000130/2025-26/RA36> a ns1:LearningResult ;
    ns1:learningResultCode "RA36" ;
    ns1:learningResultDescription "Conocer y comprender los procesos de obtención de las distintas familias de materiales, sabiendo entender de forma integradora los aspectos comunes de las tecnologías utilizadas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000130/2025-26/RA37> a ns1:LearningResult ;
    ns1:learningResultCode "RA37" ;
    ns1:learningResultDescription "Conocer y comprender las distintas técnicas de procesado, poniendo de relieve los aspectos comunes a cada familia de materiales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000130/2025-26/RA39> a ns1:LearningResult ;
    ns1:learningResultCode "RA39" ;
    ns1:learningResultDescription "Conocer y valorar los aspectos medioambientales y de seguridad en relación con la obtención y transformación de materiales."@es .

