<https://guia-kg.skai.etsisi.upm.es/resource/565000447/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. BLOQUE I (Análisis Cualitativo)"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000447/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. P1: Volumetrías de Neutralización. Determinación de carbonatos y bicarbonatos, y de carbonatos e hidróxido sódico en disolución. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000447/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "2.4. P4: Identificación de fases cristalinas mediante difracción de Rx. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000447/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "2.5. P5: Determinación de temperaturas de transición y sus entalpías asociadas mediante Análisis Térmico Diferencial. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000447/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "2.6. P6: Determinación del contenido en fósforo por colorimetría. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000447/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "2.7. P7: Determinación del contenido en sales con resinas de intercambio iónico. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000447/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "2.8. P8: Determinación de nitritos mediante espectroscopía UV-Visible. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000447/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "2.9. P9: Espectroscopia IR por transformada de Fourier. Medida de espesores. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000447/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "2.10. P10: Técnicas de medida de color. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000447/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "2.11. P11: Absorción y emisión atómica. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000447/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. P2: Determinación permanganimétrica del hierro de un mineral. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000447/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "1.3. P3: Determinación de calcio por complexometría. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000447/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "1.4. P4: Determinación de cloruros en una muestra por el método de Mohr. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000447/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "1.5. P5: Determinación gravimétrica del calcio. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000447/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "2. BLOQUE II y III (Análisis Instrumental)"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000447/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "2.1. P1: Determinación de residuo seco, pH y conductividad. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000447/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "2.2. P2: Determinación de cloruros (Potenciometría con electrodo selectivo). Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/565000447/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
