        <https://guia-kg.skai.etsisi.upm.es/resource/elena.villalba%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/oscar.dieste%40upm.es> ;
    schema:name "Evaluation Of Interactive Systems"@es .

