    ns1:otherInformation "Esta asignatura contribuye a los objetivos ODS 6, 8, 9, 10 y 11 de desarrollo sostenible de la ONU a través del resultado de aprendizaje RA69, así como a las metas 9A y 9B de la Agenda 2030."@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
