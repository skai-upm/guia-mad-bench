<https://guia-kg.skai.etsisi.upm.es/resource/25001401/2025-26/CG16> a ns1:Competency ;
    ns1:competencyCode "CG16" ;
    ns1:competencyDescription "Aplicar conocimientos adquiridos a la práctica de la ingeniería agraria"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001401/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Que los estudiantes tengan la capacidad de reunir e interpretar datos relevantes (normalmente dentro de su área de estudio) para emitir juicios que incluyan una reflexión sobre temas relevantes de índole social, científica o ética"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001401/2025-26/CG5> a ns1:Competency ;
    ns1:competencyCode "CG5" ;
    ns1:competencyDescription "Que los estudiantes hayan desarrollado aquellas habilidades de aprendizaje necesarias para emprender estudios posteriores con un alto grado de autonomía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001401/2025-26/CG7> a ns1:Competency ;
    ns1:competencyCode "CG7" ;
    ns1:competencyDescription "Compromiso ético y profesional y respeto por el medio ambiente y la diversidad"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001401/2025-26/RA180> a ns1:LearningResult ;
    ns1:learningResultCode "RA180" ;
    ns1:learningResultDescription "El resultado genérico del aprendizaje de la Agroenergética es el conocimiento de las distintas fuentes de obtención de biomasa del medio agrario, los principios de procesos de transformación en biocombustibles y aplicaciones de éstos con fines energéticos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001401/2025-26/RA392> a ns1:LearningResult ;
    ns1:learningResultCode "RA392" ;
    ns1:learningResultDescription "Caracterizar las biomasas de origen agrario para fines energéticos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001401/2025-26/RA393> a ns1:LearningResult ;
    ns1:learningResultCode "RA393" ;
    ns1:learningResultDescription "Comprender los procesos de obtención de biocombustibles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001401/2025-26/RA394> a ns1:LearningResult ;
