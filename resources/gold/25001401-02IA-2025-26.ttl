    ns1:learningResultDescription "Entender los principios de conversión energética de biocombustibles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/25001401/2025-26/RA395> a ns1:LearningResult ;
    ns1:learningResultCode "RA395" ;
    ns1:learningResultDescription "Interpretar las bases de la sostenibilidad agroenergética"@es .

