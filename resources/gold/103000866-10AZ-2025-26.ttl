    ns1:bibliographyDescription "Zaharia, Matei, et al. \"Resilient distributed datasets: A fault-tolerant abstraction for in-memory cluster computing.\" Proceedings of the 9th USENIX conference on Networked Systems Design and Implementation. USENIX Association, 2012."@es ;
    ns1:bibliographyTitle "Resilient Distributed Datasets"@es ;
    ns1:bibliographyType "Bibliografía"@es .

