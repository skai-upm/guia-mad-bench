    schema:hasCourseInstance <https://guia-kg.skai.etsisi.upm.es/resource/83000088/2025-26> ;
    schema:name "Energía Nuclear en Buques de Superficie, Submarinos, y Artefactos Flotante"@en,
        "Nuclear Energy In Surface Ships, Submarines, And Floating Artifacts"@es ;
