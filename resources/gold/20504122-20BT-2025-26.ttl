<https://guia-kg.skai.etsisi.upm.es/resource/20504122/2025-26/RA48> a ns1:LearningResult ;
    ns1:learningResultCode "RA48" ;
    ns1:learningResultDescription "Saber elegir las técnicas estadísticas pertinentes en cada momento y ponerlas en práctica mediante el uso de herramientas informáticas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/20504122/2025-26/RA49> a ns1:LearningResult ;
    ns1:learningResultCode "RA49" ;
    ns1:learningResultDescription "Habilidades técnicas para la producción y el análisis de datos cualitativos y cuantitativos"@es .

