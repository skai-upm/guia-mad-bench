    ns1:bibliographyTitle "HANS-HEINRICH ALTFELD. \"Commercial aircraft projects\". Ashgate, 2010, Aldershot."@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005018/2025-26/didactic_resource/10> a ns1:DidacticResource ;
