    ns1:inpersonHours "45 horas (34.6%)"@es ;
    ns1:numberOfCredits 5.0 ;
    ns1:otherInformation ""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "45 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/143005018/2025-26/eventSchedule> ;
    schema:description "Esta asignatura trata de proporcionar a los alumnos un conocimiento adecuado de la función de planificación de flotas en una compañía aérea, así como de la situación del mercado actual de aviones comerciales y de las principales empresas fabricantes, de los principales métodos de modelización empleados por las grandes compañías aéreas, de la secuencia de evaluación de aviones comerciales y finalmente del proceso de negociación de contratos para la compra de aeronaves comerciales y las principales opciones de financiación y gestión financiera existentes en el mercado de capitales."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/sergio.jimenez%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/gustavo.alonso%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/sergio.jimenez%40upm.es> ;
    schema:name "Planificacion de Flotas de Compañias Aereas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005018/2025-26/CE8> a ns1:Competency ;
    ns1:competencyCode "CE8" ;
    ns1:competencyDescription "Comprender los procesos operativos propios de las empresas de Transporte Aéreo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005018/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Poseer y comprender conocimientos que aporten una base u oportunidad de ser originales en el desarrollo de nuevos conceptos y técnicas aplicados al Sistema del Transporte Aéreo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005018/2025-26/CG6> a ns1:Competency ;
    ns1:competencyCode "CG6" ;
    ns1:competencyDescription "Que los estudiantes posean las habilidades de aprendizaje que les permitan continuar estudiando de un modo que habrá de ser en gran medida autodirigido o autónomo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005018/2025-26/CT4> a ns1:Competency ;
    ns1:competencyCode "CT4" ;
    ns1:competencyDescription "Analizar implicaciones económicas, administrativas, sociales o medioambientales ligadas a la aplicación de nuevos conceptos y técnicas en el Sistema del Transporte Aéreo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005018/2025-26/RA14> a ns1:LearningResult ;
    ns1:learningResultCode "RA14" ;
    ns1:learningResultDescription "Conocimiento adecuado de la función de planificación de flotas en una compañía aérea."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005018/2025-26/RA15> a ns1:LearningResult ;
    ns1:learningResultCode "RA15" ;
    ns1:learningResultDescription "Conocimiento adecuado de la situación del mercado actual de aviones comerciales y de las principales empresas fabricantes"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005018/2025-26/RA16> a ns1:LearningResult ;
    ns1:learningResultCode "RA16" ;
    ns1:learningResultDescription "Comprensión y dominio de los principales métodos de modelización empleados por las grandes compañías aéreas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005018/2025-26/RA17> a ns1:LearningResult ;
    ns1:learningResultCode "RA17" ;
    ns1:learningResultDescription "Conocimiento de la secuencia de evaluación de aviones comerciales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005018/2025-26/RA18> a ns1:LearningResult ;
    ns1:learningResultCode "RA18" ;
    ns1:learningResultDescription "Conocimiento adecuado de la secuencia de negociación de contratos y las principales opciones de financiación y gestión financiera existentes"@es .

