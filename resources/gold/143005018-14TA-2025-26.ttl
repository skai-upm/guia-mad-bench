    ns1:bibliographyTitle "Aulas Informáticas"@es ;
    ns1:bibliographyType "Equipamiento"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005018/2025-26/didactic_resource/2> a ns1:DidacticResource ;
    ns1:bibliographyTitle "JOHN D. ANDERSON. \"Aircraft performance and design\". WCB/McGraw-Hill, 1999, Boston"@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005018/2025-26/didactic_resource/3> a ns1:DidacticResource ;
    ns1:bibliographyTitle "ARTURO BENITO. \"Descubrir las compañías aéreas\". AENA 2ª ed. 2008, Madrid."@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005018/2025-26/didactic_resource/4> a ns1:DidacticResource ;
    ns1:bibliographyTitle "ARTURO BENITO y GUSTAVO ALONSO. \"Apuntes de explotación del transporte aéreo\". ETSIAE, 2013, Madrid."@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005018/2025-26/didactic_resource/5> a ns1:DidacticResource ;
    ns1:bibliographyTitle "PAUL CLARK. \"Buying the big jets\". Ashgate 2ª ed. 2008, Aldershot."@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005018/2025-26/didactic_resource/6> a ns1:DidacticResource ;
    ns1:bibliographyTitle "RIGAS DOGANIS. \"El negocio de las compañías aéreas en el siglo XXI\" INECO 2002, Madrid"@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005018/2025-26/didactic_resource/7> a ns1:DidacticResource ;
    ns1:bibliographyTitle "ALEJANDRO GÓMEZ ARTIME. \"Costes del transporte aéreo comercial\". Iberia JAE, 1988, Madrid."@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005018/2025-26/didactic_resource/8> a ns1:DidacticResource ;
    ns1:bibliographyTitle "STEPHEN HOLLOWAY. \"Straight and level: practical airline economics\". Ashgate 2ª ed. 2003, Aldershot"@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005018/2025-26/didactic_resource/9> a ns1:DidacticResource ;
    ns1:bibliographyTitle "PETER S. MORRELL. \"Airline Finance\". Ashgate, 4ª ed. 2013, Aldershot."@es ;
    ns1:bibliographyType "Bibliografía"@es .

