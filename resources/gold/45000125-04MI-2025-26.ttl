        <https://guia-kg.skai.etsisi.upm.es/resource/josemiguel.atienza%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/mihaela.iordachescu%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/rafael.sancho%40upm.es> ;
    schema:name "Mechanical Behaviour Of Materials Iv"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45000125/2025-26/CE%202.> a ns1:Competency ;
    ns1:competencyCode "CE 2." ;
    ns1:competencyDescription "Saber modelizar el comportamiento (mecánico, electrónico, químico o biológico) de los materiales y su integración en componentes y dispositivos./ Know how to model the behavior (mechanical, electronic, chemical or biological) of materials and their integration into components and devices."@es .

