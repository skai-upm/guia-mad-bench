    ns1:competencyCode "CE24" ;
    ns1:competencyDescription "Comprender, utilizar y diseñar sistemas de ayuda a la gestión de la información biomédica y a la toma de decisiones médicas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000342/2025-26/CE25> a ns1:Competency ;
    ns1:competencyCode "CE25" ;
    ns1:competencyDescription "Conocer los principales sistemas de comunicaciones por cable e inalámbricos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000342/2025-26/CE26> a ns1:Competency ;
    ns1:competencyCode "CE26" ;
    ns1:competencyDescription "Conocer las redes de comunicaciones y su uso en los sistemas de gestión intra e interhospitalaria"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000342/2025-26/CE27> a ns1:Competency ;
    ns1:competencyCode "CE27" ;
    ns1:competencyDescription "Conocer los sistemas actuales y saber diseñar sistemas de consulta médica a través de redes de comunicaciones"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000342/2025-26/CG01> a ns1:Competency ;
    ns1:competencyCode "CG01" ;
    ns1:competencyDescription "Desarrollar las habilidades de aprendizaje necesarias para emprender actividades o estudios posteriores de forma autónoma y con confianza."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000342/2025-26/CG02> a ns1:Competency ;
    ns1:competencyCode "CG02" ;
    ns1:competencyDescription "Aplicar de forma profesional a su trabajo los conocimientos adquiridos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000342/2025-26/CG03> a ns1:Competency ;
    ns1:competencyCode "CG03" ;
    ns1:competencyDescription "Ser capaz de manejar todas las tecnologías de la información y las comunicaciones."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000342/2025-26/CG05> a ns1:Competency ;
    ns1:competencyCode "CG05" ;
    ns1:competencyDescription "Tener capacidad de análisis y síntesis, pensar de forma integrada, abordar los problemas desde diferentes perspectivas y estar siempre preparado para ¿to think out of the box¿"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000342/2025-26/CG06> a ns1:Competency ;
    ns1:competencyCode "CG06" ;
    ns1:competencyDescription "Adoptar una actitud ante los problemas de su competencia que considere que su papel no es exclusivamente aportar soluciones sino, siempre que sea posible, participar además en la propia identificación u definición de dichos problemas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000342/2025-26/CG10> a ns1:Competency ;
    ns1:competencyCode "CG10" ;
    ns1:competencyDescription "Formular, diseñar y elaborar proyectos siendo capaz de liderar grupos de trabajo y buscar en distintas fuentes de información e integrar nuevos conocimientos en su investigación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000342/2025-26/CG11> a ns1:Competency ;
    ns1:competencyCode "CG11" ;
    ns1:competencyDescription "Elaborar y defender argumentos y resolver los problemas de forma efectiva y creativa."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000342/2025-26/CG12> a ns1:Competency ;
    ns1:competencyCode "CG12" ;
    ns1:competencyDescription "Tener capacidad de iniciativa, integración, colaboración y potenciación de la discusión crítica en el ámbito del trabajo en equipo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000342/2025-26/CG15> a ns1:Competency ;
    ns1:competencyCode "CG15" ;
    ns1:competencyDescription "Transmitir la información adquirida, las ideas, los problemas y las soluciones de forma oral y escrita en castellano e inglés."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000342/2025-26/RA76> a ns1:LearningResult ;
    ns1:learningResultCode "RA76" ;
    ns1:learningResultDescription "Conocimientos teóricos y habilidades prácticas en las tecnologías necesarias para el desarrollo e integración de servicios de telemedicina."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000342/2025-26/RA78> a ns1:LearningResult ;
    ns1:learningResultCode "RA78" ;
    ns1:learningResultDescription "Conocimiento del entorno en el que se han de instalar y operar los servicios de telemedicina."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000342/2025-26/RA79> a ns1:LearningResult ;
    ns1:learningResultCode "RA79" ;
    ns1:learningResultDescription "Sabe aplicar las tecnologías de la información y las comunicaciones en todas las etapas del ciclo de vida"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000342/2025-26/RA80> a ns1:LearningResult ;
    ns1:learningResultCode "RA80" ;
    ns1:learningResultDescription "Mediante la comparación de tecnologías aplicables sabe diseñar e implementar diversos sistemas de telecuidado, telemonitorización, telediagnóstico, diagnóstico cooperativo, etc, con especial atención a los puntos críticos para su implantación en entornos clínicos reales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000342/2025-26/RA81> a ns1:LearningResult ;
    ns1:learningResultCode "RA81" ;
    ns1:learningResultDescription "Conoce un conjunto de métodos, tecnologías y recursos para el diseño, desarrollo y evaluación de aplicaciones de telemedicina"@es .

