    ns1:inpersonHours "31 horas y 31 minutos (40.4%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation """Language
The course is delivered in English.
You are advice to bring a laptop or tablet to the lessons"""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "31 horas y 31 minutos"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/103000900/2025-26/eventSchedule> ;
    schema:description """Data scientists and AI professionals will face legal and ethical issues during their careers. Designing, deploying, or using AI systems and data-intensive applications requires knowing and abiding by the law (legal compliance) and being aware of the technology's impact and acting accordingly (ethical responsibility).
In this course, students will learn about European Union policies and regulations related to AI and data. Specifically, they will cover the basics of the EU AI Regulation and the AI Liability Directive, the General Data Protection Regulation (GDPR), the Data Governance Act, the Data Act, and some aspects of copyright law, including the Database Directive. The course will also cover open data policies in Europe."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/victor.rodriguez%40upm.es> ;
    schema:inLanguage "Inglés"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/asunciondemaria.gomez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/victor.rodriguez%40upm.es> ;
    schema:name "Ethics And Law For Data Science"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000900/2025-26/CB08> a ns1:Competency ;
    ns1:competencyCode "CB08" ;
    ns1:competencyDescription "Que los estudiantes tengan la capacidad de reunir e interpretar datos relevantes (normalmente dentro de su área de estudio) para emitir juicios que incluyan una reflexión sobre temas relevantes de índole social, científica o ética/ Students should be capable of gathering and interpreting applicable data (usually within their field of study) for decision making requiring reflection on major social, scientific or ethical issues."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000900/2025-26/CECD09> a ns1:Competency ;
    ns1:competencyCode "CECD09" ;
    ns1:competencyDescription "Capacidad para actuar con los principios éticos y legales relacionados con la manipulación de datos según el ámbito de aplicación/ To demonstrate the ability to apply ethical and legal frameworks in the data profession."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000900/2025-26/CG10> a ns1:Competency ;
    ns1:competencyCode "CG10" ;
    ns1:competencyDescription "Apreciación de los límites del conocimiento actual y de la aplicación práctica de la última tecnología/ To describe and explain applicable techniques and methods for their particular area of study and identify their limitations."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000900/2025-26/RA37> a ns1:LearningResult ;
    ns1:learningResultCode "RA37" ;
    ns1:learningResultDescription "Knowledge of the European and national legal framework of AI and data processing"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000900/2025-26/RA38> a ns1:LearningResult ;
    ns1:learningResultCode "RA38" ;
    ns1:learningResultDescription "Ability to assess the societal, legal and ethical impact of Artificial Intelligence and data processing projects"@es .

