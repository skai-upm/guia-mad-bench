<https://guia-kg.skai.etsisi.upm.es/resource/105000013/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/105000013/2025-26/CG>,
        <https://guia-kg.skai.etsisi.upm.es/resource/105000013/2025-26/Ce%202>,
        <https://guia-kg.skai.etsisi.upm.es/resource/105000013/2025-26/Ce%203/4>,
