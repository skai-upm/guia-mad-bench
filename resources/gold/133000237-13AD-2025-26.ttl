        <https://guia-kg.skai.etsisi.upm.es/resource/133000237/2025-26/CT02>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000237/2025-26/CT08> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/133000237/2025-26/didactic_resource/1> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/133000237/2025-26/evaluation> ;
