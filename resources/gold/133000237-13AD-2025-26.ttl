<https://guia-kg.skai.etsisi.upm.es/resource/133000237/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/133000237/2025-26/CB06>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000237/2025-26/CE%202.3>,
