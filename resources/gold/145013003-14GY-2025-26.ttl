<https://guia-kg.skai.etsisi.upm.es/resource/145013003/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Tema 1. NAVEGACIÓN AÉREA."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145013003/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. El problema de la navegación. Concepto de navegación aérea. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145013003/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "3. Tema 3. LA ALTIMETRÍA EN LA NAVEGACIÓN Y CIRCULACIÓN AÉREAS."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145013003/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "3.1. La atmósfera. Presión, densidad y temperatura. La atmósfera Standard. La presión como variable para la determinación de la coordenada vertical. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145013003/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "3.2. Altitud, Altura y Elevación Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145013003/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "3.3. El altímetro barométrico. Reglajes de Altímetro. QNH, QFE y Standard. Utilización del altímetro barométrico. Altitud de Transición, Capa de Transición y Nivel de transición. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145013003/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "4. Tema 4. LOS SERVICIOS DE NAVEGACIÓN AÉREA"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145013003/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "4.1. Servicio ATS (ATC, FIS, ALT) Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145013003/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "4.2. Servicio AIS Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145013003/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "4.3. Servicio MET Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145013003/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "4.4. Servicio CNS Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145013003/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "4.5. Servicio de diseño de espacio aéreo Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145013003/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Terminología utilizada en la navegación aérea. Rumbo (verdadero y magnético), ruta, milla náutica y nudo. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145013003/2025-26/syllabus/20> a ns1:SyllabusItem ;
    ns1:itemIndex 20 ;
    ns1:syllabusDescription "5. Tema 5. EL SOPORTE TÉCNICO DE LA NAVEGACIÓN AÉREA (NAVEGACIÓN)."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145013003/2025-26/syllabus/21> a ns1:SyllabusItem ;
    ns1:itemIndex 21 ;
    ns1:syllabusDescription "5.1. Concepto de ayuda a la navegación aérea. Prestaciones operacionales: Exactitud, Disponibilidad, Continuidad del servicio e Integridad Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145013003/2025-26/syllabus/22> a ns1:SyllabusItem ;
    ns1:itemIndex 22 ;
    ns1:syllabusDescription "5.2. Clasificación de los sistemas de ayuda a la navegación según distintos criterios Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145013003/2025-26/syllabus/23> a ns1:SyllabusItem ;
    ns1:itemIndex 23 ;
    ns1:syllabusDescription "5.3. Funcionamiento general de los sistemas de ayuda a la naveación aérea. Uso operacional: VDF, NDB, DME, TACAN, ILS, MLS, GNSS (Constelaciones básicas, aumentaciones ABAS, SBAS y GBAS) Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145013003/2025-26/syllabus/24> a ns1:SyllabusItem ;
    ns1:itemIndex 24 ;
    ns1:syllabusDescription "5.4. Servidumbres aeronáuticas Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145013003/2025-26/syllabus/25> a ns1:SyllabusItem ;
    ns1:itemIndex 25 ;
    ns1:syllabusDescription "6. Tema 6. RUTAS AÉREAS"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145013003/2025-26/syllabus/26> a ns1:SyllabusItem ;
    ns1:itemIndex 26 ;
    ns1:syllabusDescription "6.1. Ruta Ortodrómica. Círculo máximo. Características. Parámetros que definen la ruta. Cálculo de distancias y rumbos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145013003/2025-26/syllabus/27> a ns1:SyllabusItem ;
    ns1:itemIndex 27 ;
    ns1:syllabusDescription "6.2. Ruta Loxodrómica. Características. Parámetros que definen la ruta. Cálculo de distancias y rumbos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145013003/2025-26/syllabus/28> a ns1:SyllabusItem ;
    ns1:itemIndex 28 ;
    ns1:syllabusDescription "7. Tema 7. GEODESIA y CARTOGRAFÍA"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145013003/2025-26/syllabus/29> a ns1:SyllabusItem ;
    ns1:itemIndex 29 ;
    ns1:syllabusDescription "7.1. La Tierra. Movimientos de rotación y traslación. Eje de rotación. Eclíptica. Trópicos Cáncer y Capricornio. Solsticios Verano e Invierno. Equinocios Primavera y Otoño. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145013003/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "1.3. El efecto del viento en la navegación aérea: El triángulo de velocidades. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145013003/2025-26/syllabus/30> a ns1:SyllabusItem ;
    ns1:itemIndex 30 ;
    ns1:syllabusDescription "7.2. Geodesia. El Geoide. Sistemas de referencia locales y globales, Datum, Coordenadas. Puntos cardinales. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145013003/2025-26/syllabus/31> a ns1:SyllabusItem ;
    ns1:itemIndex 31 ;
    ns1:syllabusDescription "7.3. Sistemas de referencia ED50, WGS84, PZ90, ITRS, ETRS Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145013003/2025-26/syllabus/32> a ns1:SyllabusItem ;
    ns1:itemIndex 32 ;
    ns1:syllabusDescription "7.4. Concepto de Cartografías. Escala. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145013003/2025-26/syllabus/33> a ns1:SyllabusItem ;
    ns1:itemIndex 33 ;
    ns1:syllabusDescription "7.5. Proyecciones cartográficas, Automecoismo, Conformidad y Equivalencia, Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145013003/2025-26/syllabus/34> a ns1:SyllabusItem ;
    ns1:itemIndex 34 ;
    ns1:syllabusDescription "7.6. Proyecciones Centrales (Gnomónica, Estereográfica y Ortográfica), Proyecciones Cónicas. Proyección Cónica conforme de Lambert, Proyecciones Cilíndricas. Proyección UTM. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145013003/2025-26/syllabus/35> a ns1:SyllabusItem ;
    ns1:itemIndex 35 ;
    ns1:syllabusDescription "8. Tema 8. CARTAS AERONÁUTICAS."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145013003/2025-26/syllabus/36> a ns1:SyllabusItem ;
    ns1:itemIndex 36 ;
    ns1:syllabusDescription "8.1. Objetivo general de las cartas aeronáuticas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145013003/2025-26/syllabus/37> a ns1:SyllabusItem ;
    ns1:itemIndex 37 ;
    ns1:syllabusDescription "8.2. Tipos de cartas aeronáuticas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145013003/2025-26/syllabus/38> a ns1:SyllabusItem ;
    ns1:itemIndex 38 ;
    ns1:syllabusDescription "8.3. Objetivo particular de cada una de ellas. Información que contienen. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145013003/2025-26/syllabus/39> a ns1:SyllabusItem ;
    ns1:itemIndex 39 ;
    ns1:syllabusDescription "8.4. Simbología utilizada. Escalas. Interpretación de las cartas aeronáuticas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145013003/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "1.4. Campo magnético terrestre. Declinación magnética. Inclinación magnética. Norte magnético, norte verdadero y norte del compas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145013003/2025-26/syllabus/40> a ns1:SyllabusItem ;
