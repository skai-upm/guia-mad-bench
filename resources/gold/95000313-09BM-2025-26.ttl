<https://guia-kg.skai.etsisi.upm.es/resource/95000313/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Cinemática. Aplicación al movimiento del sistema músculo-esquelético"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000313/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Cinemática tridimensional de la partícula. Elementos de geometría diferencial. Expresiones de velocidad y aceleración en diversos sistemas de coordenadas Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000313/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "3.2. Dinámica general de sistemas. Principios de Newton-Euler, teorema de la energía. Cinética y dinámica 2D. Aplicaciones a modelos planos Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000313/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "4. Dinámica tridimensional del sólido rígido y sistemas formados por sólidos rígidos. Aplicaciones al sistema músculo-esquelético"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000313/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "4.1. Geometría de masas. Tensor de inercia, momentos y direcciones principales Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000313/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "4.2. Cinética tridimensional del sólido rígido Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000313/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "4.3. Dinámica tridimensional del sólido rígido con punto fijo (ecuaciones de Euler), eje fijo y libre. Cálculo de reacciones; aplicación al cálculo de fuerzas en articulaciones. Efecto giroscópico. Sistemas de sólidos rígidos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000313/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Movimientos tridimensionales finitos del sólido rígido. Sólido con punto fijo. Teorema de Euler. Parametrizaciones de la rotación (ángulos de Euler). Sólido libre Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000313/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "1.3. Movimientos tridimensionales infinitesimales del sólido rígido. Campo de velocida y aceleración. Composición de movimientos. Derivación empleando sistemas móviles. Sólidos en contacto. Movimiento plano Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000313/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "2. Estática. Aplicación al equilibrio y la estabilidad del sistema músculo-esquelético"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000313/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "2.1. Conceptos generales sobre sistemas. Equilibrio, estabilidad, momento de una fuerza, sistemas de fuerzas equivalentes Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000313/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "2.2. Equilibrio de sistemas (I). Ecuaciones cardinales, cálculo de reacciones, problemas isostáticos/hiperestáticos, fricción. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000313/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "2.3. Equilibrio de sistemas (II). Principio de los trabajos virtuales, condiciones analíticas de estabilidad. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000313/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "3. Dinámica de la partícula y de los sistemas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000313/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "3.1. Dinámica tridimensional de la partícula. Principio y teoremas de Newton-Euler. Movimientos libre y restringido Sin subniveles"@es .

