<https://guia-kg.skai.etsisi.upm.es/resource/103000611/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/103000611/2025-26/CE19>,
        <https://guia-kg.skai.etsisi.upm.es/resource/103000611/2025-26/CE8>,
        <https://guia-kg.skai.etsisi.upm.es/resource/103000611/2025-26/CG16> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/103000611/2025-26/didactic_resource/1> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/103000611/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/103000611/2025-26/RA204>,
        <https://guia-kg.skai.etsisi.upm.es/resource/103000611/2025-26/RA205>,
        <https://guia-kg.skai.etsisi.upm.es/resource/103000611/2025-26/RA206> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/103000611/2025-26/syllabus> ;
    ns1:inpersonHours "31 horas y 30 minutos (40.4%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation ""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "57 horas y 30 minutos"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/103000611/2025-26/eventSchedule> ;
    schema:description "Este curso tiene como objetivo proporcionar a los alumnos conocimientos acerca de las técnicas de desarrollo de software utilizadas en disciplinas ágiles, tales como el desarrollo dirigido por tests, test automatizados y coordinación mediante repositorios. Se hará especial énfasis en los aspectos de calidad, incluyendo el diseño de casos de prueba, verificación estática y dinámica (con contratos)."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/oscar.dieste%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/francydiomar.rodriguez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/natalia.juristo%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/oscar.dieste%40upm.es> ;
    schema:name "Profundizacion en Ingenieria del Software"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000611/2025-26/CE19> a ns1:Competency ;
    ns1:competencyCode "CE19" ;
    ns1:competencyDescription "Capacidad para desarrollar e implantar una solución informática en un entorno empresarial"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000611/2025-26/CE8> a ns1:Competency ;
    ns1:competencyCode "CE8" ;
    ns1:competencyDescription "Capacidad para analizar las necesidades de información que se plantean en un entorno y llevar a cabo en todas sus etapas el proceso de construcción de un sistema de información."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000611/2025-26/CG16> a ns1:Competency ;
    ns1:competencyCode "CG16" ;
    ns1:competencyDescription "Capacidad para proyectar, calcular y diseñar productos, procesos e instalaciones en todos los ámbitos de la ingeniería informática"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000611/2025-26/RA204> a ns1:LearningResult ;
    ns1:learningResultCode "RA204" ;
    ns1:learningResultDescription "Aplicar técnicas de mejora de calidad del software dentro del proceso de desarrollo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000611/2025-26/RA205> a ns1:LearningResult ;
