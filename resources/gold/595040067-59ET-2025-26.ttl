<https://guia-kg.skai.etsisi.upm.es/resource/595040067/2025-26/CG%2002> a ns1:Competency ;
    ns1:competencyCode "CG 02" ;
    ns1:competencyDescription "Capacidad de búsqueda y selección de información, de razonamiento crítico y de elaboración y defensa de argumentos dentro del área."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595040067/2025-26/CG%2003> a ns1:Competency ;
    ns1:competencyCode "CG 03" ;
    ns1:competencyDescription "Capacidad para expresarse correctamente de forma oral y escrita y transmitir información mediante documentos y exposiciones en público."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595040067/2025-26/CG%2004> a ns1:Competency ;
    ns1:competencyCode "CG 04" ;
    ns1:competencyDescription "Capacidad de abstracción, de análisis y de síntesis y de resolución de problemas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595040067/2025-26/CG%2005> a ns1:Competency ;
    ns1:competencyCode "CG 05" ;
    ns1:competencyDescription "Capacidad de trabajo en equipo y en entornos multidisciplinares."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595040067/2025-26/CG%2006> a ns1:Competency ;
    ns1:competencyCode "CG 06" ;
    ns1:competencyDescription "Capacidad de adaptación, negociación, resolución de conflictos y de liderazgo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595040067/2025-26/CG%2008> a ns1:Competency ;
    ns1:competencyCode "CG 08" ;
    ns1:competencyDescription "Capacidad de organización, planificación y de toma de decisiones."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595040067/2025-26/CG%2012> a ns1:Competency ;
    ns1:competencyCode "CG 12" ;
    ns1:competencyDescription "Habilidad para las relaciones interpersonales y el trabajo en un contexto nacional e internacional, con capacidad para expresarse de forma oral y escrita en lengua inglesa."@es .

