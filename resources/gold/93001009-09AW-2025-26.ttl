    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/93001009/2025-26/eventSchedule> ;
    schema:description """Presentación de las vulnerabilidades más relevantes asociadas al desarrollo software en diferentes lenguajes y plataformas: C, C++, Java, aplicaciones web, aplicaciones móviles.
Explotación de las vulnerabilidades.
Análisis de los motivos por los que se producen dichas vulnerabilidades.
Medidas para mitigar los riesgos asociados a estas vulnerabilidades.
Modelos de desarrollo seguro."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/juanalberto.defrutos%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/juanalberto.defrutos%40upm.es> ;
    schema:name "Seguridad en el Desarrollo Software"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93001009/2025-26/CE06> a ns1:Competency ;
    ns1:competencyCode "CE06" ;
    ns1:competencyDescription "Capacidad de aplicar las principales metodologías y técnicas de seguridad en el desarrollo del software y sistemas informáticos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93001009/2025-26/CG02> a ns1:Competency ;
    ns1:competencyCode "CG02" ;
    ns1:competencyDescription "Dotar al alumno del conocimiento de los distintos tipos de amenazas que pueden afectar a una organización y sus consecuencias en diferentes escenarios sociales, económicos e industriales y dotarle de la capacidad de aplicar las técnicas de análisis y gestión de todo tipo de riesgos para definir e implantar las salvaguardas necesarias para mitigar o eliminar sus impactos hacer resiliente a la organización"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93001009/2025-26/CT12> a ns1:Competency ;
    ns1:competencyCode "CT12" ;
    ns1:competencyDescription "Aprendizaje autónomo, adaptación a nuevas situaciones y motivación por el desarrollo profesional permanente"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93001009/2025-26/CT14> a ns1:Competency ;
    ns1:competencyCode "CT14" ;
    ns1:competencyDescription "Motivación por la calidad"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93001009/2025-26/RA13> a ns1:LearningResult ;
    ns1:learningResultCode "RA13" ;
    ns1:learningResultDescription "Analizar las vulnerabilidades que puedan existir en una aplicación software. Así como saber programar para evitar dichas vulnerabilidades"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/93001009/2025-26/RA14> a ns1:LearningResult ;
    ns1:learningResultCode "RA14" ;
    ns1:learningResultDescription "Conocer las técnicas de ciberataques para explotar las vulnerabilidades en el software"@es .

