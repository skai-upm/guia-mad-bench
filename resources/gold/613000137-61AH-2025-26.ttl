    ns1:learningResultDescription "Conocer casos reales de investigación en las áreas del título"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000137/2025-26/RA57> a ns1:LearningResult ;
    ns1:learningResultCode "RA57" ;
    ns1:learningResultDescription "Conocer de manera práctica cómo se desarrolla una investigación real"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000137/2025-26/RA58> a ns1:LearningResult ;
    ns1:learningResultCode "RA58" ;
    ns1:learningResultDescription "Conocer de manera práctica cómo se realiza una presentación de una investigación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000137/2025-26/RA59> a ns1:LearningResult ;
    ns1:learningResultCode "RA59" ;
    ns1:learningResultDescription "Conocer trabajos punteros e innovadores en las áreas del aprendizaje automático y los datos masivos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/613000137/2025-26/S01> a ns1:Competency ;
    ns1:competencyCode "S01" ;
    ns1:competencyDescription "El alumno elabora artículos e informes científicos que demuestran una o varias hipótesis mediante los resultados obtenidos a partir de experimentos"@es .

