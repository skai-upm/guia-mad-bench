<https://guia-kg.skai.etsisi.upm.es/resource/115100033/2025-26/CE03> a ns1:Competency ;
    ns1:competencyCode "CE03" ;
    ns1:competencyDescription "Identificar y prevenir los riesgos que se derivan para la salud de los escolares en la práctica de actividades físicas inadecuadas o realizadas de forma incorrecta. Nivel 3."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100033/2025-26/CE12> a ns1:Competency ;
    ns1:competencyCode "CE12" ;
    ns1:competencyDescription "Planificar, desarrollar y evaluar la realización de programas de actividades físico deportivas orientadas a la prevención y mejora de la salud. Nivel 3."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100033/2025-26/CE13> a ns1:Competency ;
    ns1:competencyCode "CE13" ;
    ns1:competencyDescription "Aplicar, de manera fundamentada y argumentada, los principios fisiológicos, biomecánicos, comportamentales y sociales al campo de la actividad física y salud. Nivel 3."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100033/2025-26/CE14> a ns1:Competency ;
    ns1:competencyCode "CE14" ;
    ns1:competencyDescription "Evaluar la condición física y prescribir ejercicios físicos orientados hacia la salud. Nivel 2."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100033/2025-26/CE15> a ns1:Competency ;
    ns1:competencyCode "CE15" ;
    ns1:competencyDescription "Identificar y prevenir los riesgos que se derivan para la salud, de la práctica de actividades físicas inadecuadas, entre la población que realiza práctica física orientada a la salud. Nivel 3."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100033/2025-26/CE17> a ns1:Competency ;
    ns1:competencyCode "CE17" ;
    ns1:competencyDescription "Promover y evaluar la formación de hábitos perdurables y autónomos de práctica de actividad físico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100033/2025-26/CE24> a ns1:Competency ;
    ns1:competencyCode "CE24" ;
    ns1:competencyDescription "Elaborar y comunicar, de manera crítica y fundamentada, argumentos y juicios sobre el valor de la actividad física y el deporte, y sobre sus posibilidades de contribuir al desarrollo y bienestar de las personas y de la sociedad, y al desarrollo sostenible, así como sobre su especial relación con la salud y la calidad de vida. Nivel 3."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100033/2025-26/CG03> a ns1:Competency ;
    ns1:competencyCode "CG03" ;
    ns1:competencyDescription "Organizar y planificar propuestas de acción, programas y actividades propias de su campo profesional en sus diferentes ámbitos de aplicación y desarrollo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100033/2025-26/CG05> a ns1:Competency ;
    ns1:competencyCode "CG05" ;
    ns1:competencyDescription "Gestionar con eficacia y eficiencia la información procedente de diferentes fuentes integrando sus aspectos relevantes para el cumplimiento de los objetivos propuestos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100033/2025-26/CG08> a ns1:Competency ;
    ns1:competencyCode "CG08" ;
    ns1:competencyDescription "Aplicar los conocimientos adquiridos en los procesos de formación en la práctica profesional, en diferentes contextos y situaciones."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100033/2025-26/CG10> a ns1:Competency ;
    ns1:competencyCode "CG10" ;
    ns1:competencyDescription "Mostrar capacidad de aprender nuevos conocimientos y habilidades a lo largo de su vida profesional y personal."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100033/2025-26/CG12> a ns1:Competency ;
    ns1:competencyCode "CG12" ;
    ns1:competencyDescription "Comprender y manejar la literatura científica del ámbito de la actividad física y el deporte en lengua inglesa y en otras lenguas de presencia significativa en el ámbito científico y específico de conocimiento."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/115100033/2025-26/CG13> a ns1:Competency ;
    ns1:competencyCode "CG13" ;
    ns1:competencyDescription "Desarrollar habilidades adecuadas de comunicación oral y escrita en lengua inglesa y en otras lenguas de presencia significativa en el ámbito científico y específico de conocimiento, que permitan la adecuada comunicación y transferencia de conocimientos."@es .

