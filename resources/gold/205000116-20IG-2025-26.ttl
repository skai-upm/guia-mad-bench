    ns1:learningResultCode "RA343" ;
    ns1:learningResultDescription "Discriminar la naturaleza de la enfermedad e identificar los principios necesarios para un correcto diagnóstico y control"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000116/2025-26/RA344> a ns1:LearningResult ;
