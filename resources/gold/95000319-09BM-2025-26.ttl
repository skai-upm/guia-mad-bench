    ns1:learningResultCode "RA262" ;
    ns1:learningResultDescription "Comprender el funcionamiento de los sistemas digitales basados en microprocesador"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000319/2025-26/RA263> a ns1:LearningResult ;
