    ns1:inpersonHours "64 horas (41%)"@es ;
    ns1:numberOfCredits 6.0 ;
    ns1:otherInformation "Esta asignatura está relacionada con los ODS3 (Salud y bienestar), ODS4 (Educación de calidad) y ODS9 (Industria, información e infraestructuras)"@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "64 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/95000319/2025-26/eventSchedule> ;
    schema:description "Esta asignatura pretende enseñar al alumno a analizar y diseñar un sistema digital para resolver aplicaciones concretas (preferiblemente de tipo biomédico). El sistema interactuará con su entorno, mediante unidades de entradas/salidas principalmente digitales, pero también analógicas con los correspondientes conversores. Se estudiarán las soluciones con puertas lógicas (circuitos combinacionales y secuenciales) así como su realización con circuitos programables. Asimismo, se estudiarán los sistemas basados en microprocesadores o microcontroladores, incluyendo sus posibilidades de tratamiento de información en tiempo real."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/andres.santos%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/andres.santos%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/juanantonio.lopez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/juanjo.gomez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/lucilio.cordero%40upm.es> ;
    schema:name "Sistemas Electrónicos"@es .

