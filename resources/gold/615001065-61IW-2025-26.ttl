    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/615001065/2025-26/eventSchedule> ;
    schema:description """El objetivo principal de esta asignatura consiste en formar a los alumnos para que conozcan los fundamentos básicos del desarrollo de aplicaciones que les permita desarrollar soluciones web completas. Los objetivos específicos son adquirir los conocimientos técnicos y buenas prácticas sobre los siguientes aspectos:
Conocimiento del lenguaje de marcado HTML, lenguajes de scripting en cliente, hojas de estilo CSS, AJAX
El protocolo HTTP, lenguajes de desarrollo en backend, acceso a sistemas de gestión de bases de datos, implementación de servicios web"""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/franciscojavier.gil%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/franciscojavier.gil%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/javier.alegre.landaburu%40upm.es> ;
    schema:name "Tecnologías de Desarrollo para la Web"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615001065/2025-26/CB4> a ns1:Competency ;
    ns1:competencyCode "CB4" ;
    ns1:competencyDescription "Conocimiento de los fundamentos del uso y programación de los computadores, los sistemas operativos, las bases de datos y, en general, los programas informáticos con aplicación en ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615001065/2025-26/CC13> a ns1:Competency ;
    ns1:competencyCode "CC13" ;
    ns1:competencyDescription "Conocimiento y aplicación de las herramientas necesarias para el almacenamiento, procesamiento y acceso a los Sistemas de información, incluidos los basados en web."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615001065/2025-26/CT12> a ns1:Competency ;
    ns1:competencyCode "CT12" ;
    ns1:competencyDescription "Uso de tecnologías de la información y las comunicaciones : Usar las tecnologías de la información y las comunicaciones en el ámbito de la ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615001065/2025-26/RA309> a ns1:LearningResult ;
    ns1:learningResultCode "RA309" ;
    ns1:learningResultDescription "Construye soluciones basadas en aplicaciones Web sobre diversas plataformas relevantes presentes en el mercado"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615001065/2025-26/RA310> a ns1:LearningResult ;
    ns1:learningResultCode "RA310" ;
    ns1:learningResultDescription "Desarrolla soluciones basadas en aplicaciones web con entornos de desarrollo actuales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615001065/2025-26/RA311> a ns1:LearningResult ;
    ns1:learningResultCode "RA311" ;
    ns1:learningResultDescription "Identifica, comprende y aplica la sintaxis y semántica de lenguajes para el desarrollo de aplicaciones web actuales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615001065/2025-26/RA312> a ns1:LearningResult ;
    ns1:learningResultCode "RA312" ;
    ns1:learningResultDescription "Aplica con éxito técnicas para encontrar nuevas alternativas e ideas, fraccionando el problema, relacionando conceptos y estableciendo analogías"@es .

