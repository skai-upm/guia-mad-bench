    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/133000181/2025-26/eventSchedule> ;
    schema:description """La asignatura tiene como contenido analizar todo el marco político y normativo nacional, europeo e internacional necesario para comprender el ámbito donde se desarrolla la economía circular. Se analizará de forma práctica con casos reales el denominado Derecho económico e industrial y todas las repercusiones necesarias de la protección ambiental en el contexto del cambio climático.
En el caso que no se pudieran impartir las clases por indicación de la autoridad sanitaria, las clases serán impartidas on line mediante medios telemáticos"""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/lc.fernandez-espinar%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/juan.teson%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/lc.fernandez-espinar%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/roberto.rodriguezsolano%40upm.es> ;
    schema:name "Marco Politico y Normativo Derecho Economico e Industrial"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000181/2025-26/CE01> a ns1:Competency ;
    ns1:competencyCode "CE01" ;
    ns1:competencyDescription "El alumno conocerá la legislación ambiental y tendrá la capacidad de planificar un modelo de economía circular."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000181/2025-26/CG01> a ns1:Competency ;
    ns1:competencyCode "CG01" ;
    ns1:competencyDescription "El alumno tendrá capacidad para analizar y evaluar las implicaciones de implantar un modelo de economía circular desde el punto de vista normativo, económico, industrial y tecnológico."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000181/2025-26/CT01> a ns1:Competency ;
    ns1:competencyCode "CT01" ;
    ns1:competencyDescription "El alumno desarrollará habilidades para trabajar en contextos internacionales, respetando y considerando entornos socioculturales y científico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000181/2025-26/CT07> a ns1:Competency ;
    ns1:competencyCode "CT07" ;
    ns1:competencyDescription "El alumno tendrá capacidad para utilizar la lengua inglesa para la comunicación oral y escrita a nivel avanzado en entornos académicos y profesionales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000181/2025-26/RA18> a ns1:LearningResult ;
    ns1:learningResultCode "RA18" ;
    ns1:learningResultDescription "Capacidad para situar y comprender las bases de los acuerdos supranacionales sobre cambio climático y su incidencia en la normativa español"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000181/2025-26/RA30> a ns1:LearningResult ;
    ns1:learningResultCode "RA30" ;
    ns1:learningResultDescription "Evaluar el entorno personal de aprendizaje propio para fines académicos y profesionales./ Evaluate the own current personal learning environment for professional and training purposes."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000181/2025-26/RA32> a ns1:LearningResult ;
    ns1:learningResultCode "RA32" ;
    ns1:learningResultDescription "Aplicar buenas prácticas para presentaciones orales./ Apply good practices for oral presentations."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000181/2025-26/RA8> a ns1:LearningResult ;
    ns1:learningResultCode "RA8" ;
    ns1:learningResultDescription "Capacidad de detereminar el mejor modelo circular en insitituciones y empresas"@es .

