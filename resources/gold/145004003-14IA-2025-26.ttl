<https://guia-kg.skai.etsisi.upm.es/resource/145004003/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/145004003/2025-26/CE17>,
        <https://guia-kg.skai.etsisi.upm.es/resource/145004003/2025-26/CE18>,
