    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/305000101/2025-26/eventSchedule> ;
    schema:description """El objetivo principal de esta asignatura es asentar los fundamentos del cálculo diferencial e integral y al mismo tiempo desarrollar las destrezas que los alumnos han de tener para afrontar otras asignaturas del grado, en especial aquellas relacionadas con el análisis matemático.
Por eso se hará especial énfasis en el rigor a la hora de presentar los contenidos habituales de una asignatura de cálculo en una variable. Los conceptos y resultados se expondrán siempre de una manera rigurosa, acompañados de ejemplos sencillos que los motiven y que faciliten su comprensión, y de problemas más complejos que fomenten el pensamiento analítico y riguroso de los estudiantes."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/maricruz.vilela%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/maricruz.vilela%40upm.es> ;
    schema:name "Cálculo en una Variable"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000101/2025-26/CB1> a ns1:Competency ;
    ns1:competencyCode "CB1" ;
    ns1:competencyDescription "Que los estudiantes hayan demostrado poseer y comprender conocimientos en un área de estudio que parte de la base de la educación secundaria general, y se suele encontrar a un nivel que, si bien se apoya en libros de texto avanzados, incluye también algunos aspectos que implican conocimientos procedentes de la vanguardia de su campo de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000101/2025-26/CB2> a ns1:Competency ;
    ns1:competencyCode "CB2" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar sus conocimientos a su trabajo o vocación de una forma profesional y posean las competencias que suelen demostrarse por medio de la elaboración y defensa de argumentos y la resolución de problemas dentro de su área de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000101/2025-26/CB3> a ns1:Competency ;
    ns1:competencyCode "CB3" ;
    ns1:competencyDescription "Que los estudiantes tengan la capacidad de reunir e interpretar datos relevantes (normalmente dentro de su área de estudio) para emitir juicios que incluyan una reflexión sobre temas relevantes de índole social, científica o ética"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000101/2025-26/CB4> a ns1:Competency ;
    ns1:competencyCode "CB4" ;
    ns1:competencyDescription "Que los estudiantes puedan transmitir información, ideas, problemas y soluciones a un público tanto especializado como no especializado"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000101/2025-26/CE1> a ns1:Competency ;
    ns1:competencyCode "CE1" ;
    ns1:competencyDescription "Comprender y utilizar el lenguaje matemático. Adquirir la capacidad para enunciar propiedades en distintos campos de la Matemática, para construir argumentaciones, elaborar cálculos y para transmitir los conocimientos matemáticos adquiridos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000101/2025-26/CE2> a ns1:Competency ;
    ns1:competencyCode "CE2" ;
    ns1:competencyDescription "Conocer y comprender demostraciones rigurosas de los principales teoremas de cada área de la Matemática y extraer de ellos corolarios mediante la particularización a casos concretos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000101/2025-26/CE3> a ns1:Competency ;
    ns1:competencyCode "CE3" ;
    ns1:competencyDescription "Asimilar la definición de un nuevo objeto matemático, en términos de otros ya conocidos, y ser capaz de utilizar este objeto en diferentes contextos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000101/2025-26/CE4> a ns1:Competency ;
    ns1:competencyCode "CE4" ;
    ns1:competencyDescription "Abstraer las propiedades estructurales de objetos matemáticos, de la realidad observada o de otros ámbitos distinguiéndolas de aquellas puramente ocasionales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000101/2025-26/CE5> a ns1:Competency ;
    ns1:competencyCode "CE5" ;
    ns1:competencyDescription "Comprobar con demostraciones hipótesis sobre un objeto matemático o refutarlas con contraejemplos, así como identificar errores en razonamientos incorrectos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000101/2025-26/CE7> a ns1:Competency ;
    ns1:competencyCode "CE7" ;
    ns1:competencyDescription "Resolver problemas de Matemáticas, mediante habilidades de cálculo básico y tecnologías de computación, planificando su resolución en función de las herramientas de que se disponga y de las restricciones de tiempo y recursos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000101/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Identificar la naturaleza, métodos y fines de los distintos campos de la Matemática y asociarlos con cierta perspectiva histórica de su desarrollo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000101/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Utilizar las capacidades analíticas y de abstracción, la intuición y el pensamiento lógico y riguroso desarrolladas a través del estudio de la Matemática en contextos tanto matemáticos como no matemáticos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000101/2025-26/CG4> a ns1:Competency ;
    ns1:competencyCode "CG4" ;
    ns1:competencyDescription "Utilizar los conocimientos teóricos y prácticos adquiridos en la definición y planteamiento de problemas y en la búsqueda de sus soluciones tanto en contextos académicos como profesionales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000101/2025-26/CG5> a ns1:Competency ;
    ns1:competencyCode "CG5" ;
    ns1:competencyDescription "Sintetizar conocimientos y habilidades adquiridas en el campo de la matemática en diferentes materias del plan de estudios para enfocarlas en posteriores estudios especializados, tanto en una disciplina matemática como en cualquiera de las ciencias que requieran buenos fundamentos matemáticos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000101/2025-26/RA19> a ns1:LearningResult ;
    ns1:learningResultCode "RA19" ;
    ns1:learningResultDescription "Identificar las propiedades del conjunto de los números reales y su topología."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000101/2025-26/RA20> a ns1:LearningResult ;
    ns1:learningResultCode "RA20" ;
    ns1:learningResultDescription "Analizar las propiedades de una función continua en un dominio."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000101/2025-26/RA21> a ns1:LearningResult ;
    ns1:learningResultCode "RA21" ;
    ns1:learningResultDescription "Determinar la convergencia de sucesiones, de series numéricas, de series de potencias y de integrales impropias."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000101/2025-26/RA23> a ns1:LearningResult ;
    ns1:learningResultCode "RA23" ;
    ns1:learningResultDescription "Relacionar las características gráficas de una función con sus propiedades y expresión analítica."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000101/2025-26/RA24> a ns1:LearningResult ;
    ns1:learningResultCode "RA24" ;
    ns1:learningResultDescription "Aproximar localmente funciones mediante el polinomio de Taylor y estimar el error cometido."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000101/2025-26/RA25> a ns1:LearningResult ;
    ns1:learningResultCode "RA25" ;
    ns1:learningResultDescription "Resolver problemas de optimización."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000101/2025-26/RA26> a ns1:LearningResult ;
    ns1:learningResultCode "RA26" ;
    ns1:learningResultDescription "Identificar, formular y probar resultados relativos al concepto de derivada e integral."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000101/2025-26/RA27> a ns1:LearningResult ;
    ns1:learningResultCode "RA27" ;
    ns1:learningResultDescription "Calcular derivadas e integrales y utilizarlas en problemas aplicados."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000101/2025-26/RA62> a ns1:LearningResult ;
    ns1:learningResultCode "RA62" ;
    ns1:learningResultDescription "Reconocer y manejar el concepto de límite. En particular, reconocer la derivada como tasa de variación y la integral de Riemann como límite de sumas."@es .

