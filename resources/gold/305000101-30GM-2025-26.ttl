<https://guia-kg.skai.etsisi.upm.es/resource/305000101/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Números reales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000101/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Los números naturales, enteros, racionales, irracionales y reales. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000101/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "4.1. Definición de derivada. Interpretación geométrica. Derivadas sucesivas. Reglas de derivación. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000101/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "4.2. Derivabilidad y continuidad. Extremos locales. Teorema de Rolle. Teorema del valor medio. Representación gráfica de funciones. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000101/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "5. Polinomio de Taylor. Estudio local de funciones."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000101/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "5.1. Definición de polinomio de Taylor. Resto de Taylor. Teorema de Taylor. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000101/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "6. Integral de Riemann."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000101/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "6.1. Definición de integral de Riemann. Funciones integrables. Propiedades. Teorema fundamental del cálculo. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000101/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "6.2. Primitivas. Técnicas de integración. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000101/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "6.3. Integrales impropias. Convergencia. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000101/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "6.4. Aplicaciones de la integral. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000101/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "7. Series."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000101/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Desigualdades y valor absoluto. Máximo y mínimo. Supremo e ínfimo. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000101/2025-26/syllabus/20> a ns1:SyllabusItem ;
    ns1:itemIndex 20 ;
    ns1:syllabusDescription "7.1. Series numéricas. Convergencia. Series armónicas y geométricas. Criterios de convergencia. Convergencia absoluta. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000101/2025-26/syllabus/21> a ns1:SyllabusItem ;
    ns1:itemIndex 21 ;
    ns1:syllabusDescription "7.2. Series de funciones. Convergencia uniforme. Series de potencias. Series de Taylor. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000101/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "2. Sucesiones."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000101/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "2.1. Sucesiones de números. Límites de sucesiones. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000101/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "2.2. Convergencia. Subsucesiones. Teorema de Bolzano-Weierstrass. Sucesiones de Cauchy. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000101/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "3. Funciones de variable real. Límites y continuidad de funciones."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000101/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "3.1. Noción de función. Límite de una función en un punto. Límites en el infinito. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000101/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "3.2. Funciones continuas. Teorema del valor intermedio. Teorema de Weierstrass. Continuidad uniforme. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000101/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "4. Derivabilidad de funciones."@es .

