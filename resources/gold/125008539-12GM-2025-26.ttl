    schema:name "Aplicaciones Geomáticas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125008539/2025-26/CG01> a ns1:Competency ;
    ns1:competencyCode "CG01" ;
    ns1:competencyDescription "Diseñar y desarrollar proyectos geomáticos y topográficos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125008539/2025-26/CG05> a ns1:Competency ;
    ns1:competencyCode "CG05" ;
    ns1:competencyDescription "Determinar, medir, evaluar y representar el terreno, objetos tridimensionales, puntos y trayectorias"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125008539/2025-26/CG08> a ns1:Competency ;
    ns1:competencyCode "CG08" ;
    ns1:competencyDescription "Planificación, proyecto, dirección, ejecución, y gestión de procesos de medida, sistemas de información, explotación de imágenes, posicionamiento y navegación; modelización, representación y visualización de la información territorial en, bajo y sobre la superficie terrestre"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125008539/2025-26/CG09> a ns1:Competency ;
    ns1:competencyCode "CG09" ;
    ns1:competencyDescription "Planificación, proyecto, dirección, ejecución y gestión de procesos y productos de aplicación a la obra civil y la edificación, en el ámbito geomático"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125008539/2025-26/CT01> a ns1:Competency ;
    ns1:competencyCode "CT01" ;
    ns1:competencyDescription "COMUNICACIÓN ORAL Y ESCRITA Capacidad para transmitir conocimientos y expresar ideas y argumentos de manera clara, rigurosa y convincente, tanto de forma oral como escrita, utilizando los recursos gráficos y los medios necesarios adecuadamente y adaptándose a las características de la situación y de la audiencia."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125008539/2025-26/CT02> a ns1:Competency ;
    ns1:competencyCode "CT02" ;
    ns1:competencyDescription "USO DE LAS TIC Capacidad sobre conocimientos tecnológicos que permitan desenvolverse cómodamente y así afrontar los retos que la sociedad le va a imponer en su quehacer profesional en permanente autoformación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125008539/2025-26/CT03> a ns1:Competency ;
