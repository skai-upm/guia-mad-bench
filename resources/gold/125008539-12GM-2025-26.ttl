<https://guia-kg.skai.etsisi.upm.es/resource/125008539/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. PARTE 1: Diseño, observación, cálculo y ajuste de una red básica, una red secundaria y una red de detalle; y levantamiento topográfico a escala 1/500."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125008539/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Diseño e implantación de una Red básica, compatible con la observación por metodología GNSS y Topografía clásica Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125008539/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "1.10. Cálculo y ajuste de la red secundaria Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125008539/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "1.11. Levantamiento de la red de detalle de una zona urbana con metodologías conjuntas y complementarias (GNSS y Taquimetría) para observación y registro de todos los puntos necesarios para la obtención de la cartografía final. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125008539/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "1.12. Cálculos necesarios para la obtención de todos los puntos, que constituyen el levantamiento topográfico efectuado, en sistema de coordenadas ETRS89. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125008539/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "2. PARTE 2: Proyecto de ejecución de Cartografía urbana a escala 1:500 del Campus Sur de la UPM."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125008539/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "2.1. Importación de datos y preparación de la base de datos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125008539/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "2.2. Digitalización de líneas de ruptura, elaboración de un TIN y curvado para representación del relieve. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125008539/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "2.3. Diseño y colocación de la simbología puntual, lineal, superficial y textos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125008539/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "2.4. Diseño de hoja, cartela y leyenda Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125008539/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "2.5. Impresión del plano a escala 1:500 Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125008539/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "3. Talleres Complementarios"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125008539/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Observación de una red mediante técnicas de GNSS y de Topografía convencional Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125008539/2025-26/syllabus/20> a ns1:SyllabusItem ;
    ns1:itemIndex 20 ;
    ns1:syllabusDescription "3.1. Taller 1: Redacción de informes Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125008539/2025-26/syllabus/21> a ns1:SyllabusItem ;
    ns1:itemIndex 21 ;
    ns1:syllabusDescription "3.2. Taller 2: Maquetación de informes Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125008539/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "1.3. Observación de la altimetría por Nivelación geométrica Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125008539/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "1.4. Depuración de observaciones de campo: GNSS, de Topografía convencional y Nivelación geométrica Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125008539/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "1.5. Cálculos y ajustes, mediante las dos metodologías, GNSS, de Topografía convencional, de las coordenadas planimétricas y altimétricas de la Red básica observada. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125008539/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "1.6. Cálculo y ajuste de la Nivelación geométrica de la Red básica Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125008539/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "1.7. Análisis y comparación de las precisiones planimétricas alcanzadas en los parámetros de los dos cálculos realizados (de las dos metodologías utilizadas) Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125008539/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "1.8. Análisis y comparación de las precisiones de la altimetría de la red observada, de los tres cálculos realizados (de las tres metodologías utilizadas) Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/125008539/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "1.9. Diseño y observación de la red secundaria mediante Itinerarios Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/12GM%20-%20Grado%20en%20Ingenieria%20Geomatica> a ns1:BachelorDegree ;
    ns1:degreeCode "12GM"@es ;
