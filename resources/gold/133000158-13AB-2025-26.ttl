<https://guia-kg.skai.etsisi.upm.es/resource/133000158> a ns1:Course ;
    ns1:courseType "Optativa"@es ;
    ns1:courseYear 1 ;
    ns1:semester "Segundo semestre"@es ;
    schema:courseCode 133000158 ;
    schema:hasCourseInstance <https://guia-kg.skai.etsisi.upm.es/resource/133000158/2025-26> ;
    schema:name "Planning And Project Management In Farm - Rural Tourism"@en,
        "Planificación y Gestión de Proyectos de Agroturismo ¿ Turismo Rural"@es ;
    schema:numberOfCredits 3.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/133000158/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/133000158/2025-26/CB09>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000158/2025-26/CE02>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000158/2025-26/CE05>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000158/2025-26/CE07>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000158/2025-26/CG03> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/133000158/2025-26/didactic_resource/1> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/133000158/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/133000158/2025-26/RA16>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000158/2025-26/RA17>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000158/2025-26/RA57> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/133000158/2025-26/syllabus> ;
    ns1:inpersonHours "37 horas y 30 minutos (48.1%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation "La asignatura se relaciona con los ODS 8, 12 y 14. Durante la misma se ofrecen contenidos específicos que abordan la contribución del turismo a los ODS para ser considerados como parte de la planificación integral."@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "70 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/133000158/2025-26/eventSchedule> ;
    schema:description """La asignatura aborda las bases de la planificación desde un punto de establecer el marco de referencia que establece reglas del juego y ordenamiento a la actividad turística en una zona, ofreciendo tanto limitaciones al desarrollo de las actividades como incentivos u oportunidades, e incluso financiamiento, y que por lo tanto es importante considerar.
Para ello se repasan en primer lugar conceptos clave sobre planificación y planificación turística, para posteriormente mostrar cómo ha sido la evolución a lo largo del tiempo de los trabajos orientados a realizarla y cómo esta evolución influye en los contenidos y el enfoque que se recoge en la planificación actual.
Posteriormente se repasan algunas consideraciones complementarias que en la actualidad es importante tener en cuenta al abordar la planificación integral, desde enfoque de sostenibilidad, el trabajo en red, etc.
Finalmente se trabajará con planes turísticos reales, para comparar el alcance según el nivel territorial al que aplican, su estructura de contenidos y cómo evolucionan en el tiempo."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/joseluis.yague%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/joseluis.yague%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/manuel.aparicio%40upm.es> ;
    schema:name "Planificación y Gestión de Proyectos de Agroturismo ¿ Turismo Rural"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000158/2025-26/CB09> a ns1:Competency ;
    ns1:competencyCode "CB09" ;
    ns1:competencyDescription "Que los estudiantes sepan comunicar sus conclusiones y los conocimientos y razones últimas que las sustentan a públicos especializados y no especializados de un modo claro y sin ambigüedades"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000158/2025-26/CE02> a ns1:Competency ;
    ns1:competencyCode "CE02" ;
    ns1:competencyDescription "Capacidad para identificar, formular y resolver problemas sobre turismo ecológico y sostenible."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000158/2025-26/CE05> a ns1:Competency ;
    ns1:competencyCode "CE05" ;
    ns1:competencyDescription "Capacidad para identificar y valorar las ventajas y los inconvenientes del turismo responsable en el entorno natural para las comunidades y empresas locales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000158/2025-26/CE07> a ns1:Competency ;
    ns1:competencyCode "CE07" ;
    ns1:competencyDescription "Capacidad para diseñar, redactar y gestionar proyectos de ecoturismo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000158/2025-26/CG03> a ns1:Competency ;
    ns1:competencyCode "CG03" ;
    ns1:competencyDescription "Capacidad crítica para el análisis, la síntesis y el aprendizaje mediante el intercambio de opiniones en el área del turismo ecológico y sostenible, presentando argumentos sólidos y estructurados"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000158/2025-26/RA16> a ns1:LearningResult ;
    ns1:learningResultCode "RA16" ;
    ns1:learningResultDescription "Comprender y diseñar instrumentos de planificación de los espacios y actividades agroturísticas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000158/2025-26/RA17> a ns1:LearningResult ;
    ns1:learningResultCode "RA17" ;
    ns1:learningResultDescription "Conocer las metodologías y herramientas necesarias para la redacción y elaboración de los planes y proyectos agroturísticos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000158/2025-26/RA57> a ns1:LearningResult ;
    ns1:learningResultCode "RA57" ;
    ns1:learningResultDescription "Dominio de los contenidos de la asignatura"@es .

