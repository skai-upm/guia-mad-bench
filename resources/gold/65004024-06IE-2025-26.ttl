        <https://guia-kg.skai.etsisi.upm.es/resource/65004024/2025-26/didactic_resource/5> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/65004024/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/65004024/2025-26/RA123>,
        <https://guia-kg.skai.etsisi.upm.es/resource/65004024/2025-26/RA124>,
        <https://guia-kg.skai.etsisi.upm.es/resource/65004024/2025-26/RA125>,
        <https://guia-kg.skai.etsisi.upm.es/resource/65004024/2025-26/RA126>,
        <https://guia-kg.skai.etsisi.upm.es/resource/65004024/2025-26/RA127>,
        <https://guia-kg.skai.etsisi.upm.es/resource/65004024/2025-26/RA128> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/65004024/2025-26/syllabus> ;
    ns1:inpersonHours "61 horas (39.1%)"@es ;
    ns1:numberOfCredits 6.0 ;
    ns1:otherInformation """La asignatura permite relacionar los Objetivos de Desarrollo Sostenible con las distintas fuentes de generación de energía eléctrica siguiendo los informes del IPCC. En concreto los ODS 7 "Energía Asequible y No contaminante".
Se utilizara la plataforma Microsoft Teams para la comunicación telemática con el alumno en caso de ser necesaria.
Los alumnos se podrán comunicar por email o por Teams con el profesorado de la asignatura."""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "61 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/65004024/2025-26/eventSchedule> ;
    schema:description """Con esta asignatura el alumno adquirirá unos conocimientos básicos sobre la generación de electricidad a través del uso civil de la Energía Nuclear, englobando tanto aspectos ingenieriles como aspectos de física nuclear.
El alumno adquirirá conocimientos prácticos sobre detectores de radiación durante las prácticas de laboratorio."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/kevin.fcosials%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/cesar.queral%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/kevin.fcosials%40upm.es> ;
    schema:name "Energia Nuclear y Ciclo del Combustible"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004024/2025-26/CE42> a ns1:Competency ;
    ns1:competencyCode "CE42" ;
    ns1:competencyDescription "Conocer y comprender la física y tecnología de la desintegración radiactiva, la fisión y la fusión nuclear."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004024/2025-26/CE43> a ns1:Competency ;
    ns1:competencyCode "CE43" ;
    ns1:competencyDescription "Aplicar los principios de la ingeniería nuclear y de la protección radiológica."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004024/2025-26/CE48> a ns1:Competency ;
    ns1:competencyCode "CE48" ;
    ns1:competencyDescription "Comprender el aprovechamiento, transformación y gestión de los recursos energéticos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004024/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Conocer y aplicar conocimientos de ciencias y tecnologías básicas a la práctica de la Ingeniería de la Energía."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004024/2025-26/CG2> a ns1:Competency ;
    ns1:competencyCode "CG2" ;
    ns1:competencyDescription "Poseer capacidad para diseñar, desarrollar, implementar, gestionar y mejorar productos, sistemas y procesos en los distintos ámbitos energéticos, usando técnicas analíticas, computacionales o experimentales apropiadas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004024/2025-26/CG4> a ns1:Competency ;
    ns1:competencyCode "CG4" ;
    ns1:competencyDescription "Comprender el impacto de la ingeniería energética en el medio ambiente, el desarrollo sostenible de la sociedad y la importancia de trabajar en un entorno profesional y responsable."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004024/2025-26/CG5> a ns1:Competency ;
    ns1:competencyCode "CG5" ;
    ns1:competencyDescription "Saber comunicar los conocimientos y conclusiones, tanto de forma oral, escrita y gráfica, a públicos especializados y no especializados de un modo claro y sin ambigüedades."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004024/2025-26/CG8> a ns1:Competency ;
    ns1:competencyCode "CG8" ;
    ns1:competencyDescription "Capacidad de trabajar en un entorno bilingüe (inglés"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004024/2025-26/RA123> a ns1:LearningResult ;
    ns1:learningResultCode "RA123" ;
    ns1:learningResultDescription "Utilizar los principios de la ingeniería nuclear y la protección radiológica."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004024/2025-26/RA124> a ns1:LearningResult ;
    ns1:learningResultCode "RA124" ;
    ns1:learningResultDescription "Analizar el comportamiento de la población neutrónica en un reactor nuclear."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004024/2025-26/RA125> a ns1:LearningResult ;
    ns1:learningResultCode "RA125" ;
    ns1:learningResultDescription "Diferenciar las diferentes tecnologías de generación térmica nuclear en función del combustible, el moderador y el refrigerante."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004024/2025-26/RA126> a ns1:LearningResult ;
    ns1:learningResultCode "RA126" ;
    ns1:learningResultDescription "Analizar el impacto de la gestión del combustible nuclear en los parámetros de seguridad de la planta."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004024/2025-26/RA127> a ns1:LearningResult ;
    ns1:learningResultCode "RA127" ;
    ns1:learningResultDescription "Comprender las actividades relacionadas con la primera y segunda parte del ciclo del combustible nuclear."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004024/2025-26/RA128> a ns1:LearningResult ;
    ns1:learningResultCode "RA128" ;
    ns1:learningResultDescription "Analizar las posibilidades de tratamiento y gestión de los residuos radiactivos de baja, media y alta actividad."@es .

