<https://guia-kg.skai.etsisi.upm.es/resource/65004024/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/65004024/2025-26/CE42>,
        <https://guia-kg.skai.etsisi.upm.es/resource/65004024/2025-26/CE43>,
