<https://guia-kg.skai.etsisi.upm.es/resource/65004050/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/65004050/2025-26/CE19>,
        <https://guia-kg.skai.etsisi.upm.es/resource/65004050/2025-26/CE40>,
        <https://guia-kg.skai.etsisi.upm.es/resource/65004050/2025-26/CE41>,
        <https://guia-kg.skai.etsisi.upm.es/resource/65004050/2025-26/CE45>,
        <https://guia-kg.skai.etsisi.upm.es/resource/65004050/2025-26/CE48>,
        <https://guia-kg.skai.etsisi.upm.es/resource/65004050/2025-26/CG1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/65004050/2025-26/CG5>,
        <https://guia-kg.skai.etsisi.upm.es/resource/65004050/2025-26/CG6>,
