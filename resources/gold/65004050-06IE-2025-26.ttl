    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/65004050/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/65004050/2025-26/RA150>,
        <https://guia-kg.skai.etsisi.upm.es/resource/65004050/2025-26/RA71>,
        <https://guia-kg.skai.etsisi.upm.es/resource/65004050/2025-26/RA72>,
        <https://guia-kg.skai.etsisi.upm.es/resource/65004050/2025-26/RA73> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/65004050/2025-26/syllabus> ;
    ns1:inpersonHours "49 horas (41.9%)"@es ;
    ns1:numberOfCredits 4.5 ;
    ns1:otherInformation """En relación con los Objetivos de Desarrollo Sostenible ODS y la consecución de la Agenda 2030, son varios los objetivos en los que un buen aprendizaje de la asignatura puede contribuir.
En primer lugar con esta asignatura pretendemos contribuir al ODS 4 "Educación de Calidad". Como servicio público, el profesor de la asignatura está comprometido con la educación, como primera misión de la universidad. Por ese motivo se tienen actualizado los materiales y se transmite pasión por la asignatura. Así mismo, se tiene un trato cercano con el alumno para solventar cualquier duda que le surja en su aprendizaje.
En el aspecto más técnico, esta asignatura puede ser utilizada por los ingenieros del futuro en sectores industriales donde nos encontramos con los siguientes ODS:
ODS 7: Energía asequible y no contaminante. Conocer los principios físicos de la energía hidráulica, y centrales de bombeo.
ODS9: Industria, innovación y estructuras. En gran parte de las industrias, el uso de fluidos es básico. Industria donde las bombas juegan un papel esencial en el movimiento de un fluido por el interior de tuberías."""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "49 horas y 20 minutos"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/65004050/2025-26/eventSchedule> ;
    schema:description """MÓDULO 1: Fundamentos de las máquinas hidráulicas
Tema 1. Clasificación y descripción de las máquinas hidráulicas.
Tema 2. Análisis dimensional aplicado a máquinas hidráulicas
Tema 3. Conceptos esenciales
MÓDULO 2: Bombas hidráulicas
Tema 4. Teorema de Euler: Teoría ideal de turbomáquinas
Tema 5. Correcciones a la teoría ideal
Tema 6. Curvas características y semejanza
MÓDULO 3: Instalaciones hidráulicas con bomba acoplada
Tema 7. Instalaciones hidráulicas
Tema 8. Selección e instalación de bombas. Regulación
Tema 9. Alteraciones en el funcionamiento de máquinas hidráulicas: Cavitación
MÓDULO 4: Centrales hidroeléctricas
Tema 10: Elementos fundamentales de una central hidroeléctrica.
Tema 11. Seguridad: Golpe de ariete.
Tema 12. Análisis de la Turbina Pelton."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/jaime.carpio%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/jaime.carpio%40upm.es> ;
    schema:name "Maquinas e Instalaciones Hidraulicas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004050/2025-26/CE19> a ns1:Competency ;
    ns1:competencyCode "CE19" ;
    ns1:competencyDescription "Comprender los principios de mecánica de fluidos e hidráulica y aplicarlos en la Ingeniería de la Energía."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004050/2025-26/CE40> a ns1:Competency ;
    ns1:competencyCode "CE40" ;
    ns1:competencyDescription "Comprender el funcionamiento y la operación de las centrales eléctricas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004050/2025-26/CE41> a ns1:Competency ;
    ns1:competencyCode "CE41" ;
    ns1:competencyDescription "Planificar y gestionar los recursos hidráulicos para la producción de energía."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004050/2025-26/CE45> a ns1:Competency ;
    ns1:competencyCode "CE45" ;
    ns1:competencyDescription "Aplicación de conocimientos de ingeniería al diseño, implantación y puesta en operación de plantas energéticas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004050/2025-26/CE48> a ns1:Competency ;
    ns1:competencyCode "CE48" ;
    ns1:competencyDescription "Comprender el aprovechamiento, transformación y gestión de los recursos energéticos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004050/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Conocer y aplicar conocimientos de ciencias y tecnologías básicas a la práctica de la Ingeniería de la Energía."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004050/2025-26/CG5> a ns1:Competency ;
    ns1:competencyCode "CG5" ;
    ns1:competencyDescription "Saber comunicar los conocimientos y conclusiones, tanto de forma oral, escrita y gráfica, a públicos especializados y no especializados de un modo claro y sin ambigüedades."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004050/2025-26/CG6> a ns1:Competency ;
    ns1:competencyCode "CG6" ;
    ns1:competencyDescription "Poseer habilidades de aprendizaje que permitan continuar estudiando a lo largo de la vida para su adecuado desarrollo profesional."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004050/2025-26/CG7> a ns1:Competency ;
    ns1:competencyCode "CG7" ;
    ns1:competencyDescription "Incorporar nuevas tecnologías y herramientas de la Ingeniería Energética en sus actividades profesionales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004050/2025-26/RA150> a ns1:LearningResult ;
    ns1:learningResultCode "RA150" ;
    ns1:learningResultDescription "Capacidad para caracterizar y comprender el comportamiento de los fluidos en distintas situaciones de interés para el ingeniero industrial de la especialidad de Técnicas Energéticas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004050/2025-26/RA71> a ns1:LearningResult ;
    ns1:learningResultCode "RA71" ;
    ns1:learningResultDescription "Conocimiento de los principios de mecánica de fluidos e hidráulica."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004050/2025-26/RA72> a ns1:LearningResult ;
    ns1:learningResultCode "RA72" ;
    ns1:learningResultDescription "Conocer las teorías de estática, cinemática y dinámica de fluidos perfectos y reales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65004050/2025-26/RA73> a ns1:LearningResult ;
    ns1:learningResultCode "RA73" ;
    ns1:learningResultDescription "Aplicar estos conocimientos a problemas de tuberías, canales, bombas, turbinas y regímenes transitorios sencillos."@es .

