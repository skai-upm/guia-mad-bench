        <https://guia-kg.skai.etsisi.upm.es/resource/lm.pozo%40upm.es> ;
    schema:name "Cálculo II"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615001007/2025-26/CB04> a ns1:Competency ;
    ns1:competencyCode "CB04" ;
    ns1:competencyDescription "Que los estudiantes puedan transmitir información, ideas, problemas y soluciones a un público tanto especializado como no especializado"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615001007/2025-26/CE01> a ns1:Competency ;
    ns1:competencyCode "CE01" ;
    ns1:competencyDescription "Capacidad para utilizar con destreza los conceptos y métodos matemáticos que subyacen a los problemas de la ciencia de datos y la inteligencia artificial para su modelización y resolución."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615001007/2025-26/CG02> a ns1:Competency ;
    ns1:competencyCode "CG02" ;
    ns1:competencyDescription "Capacidad para organizar y planificar tareas y proyectos, identificando objetivos, prioridades, plazos, recursos y riesgos, y controlando los procesos establecidos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615001007/2025-26/RA10> a ns1:LearningResult ;
    ns1:learningResultCode "RA10" ;
    ns1:learningResultDescription "8. Modelizar matemáticamente problemas reales y conocer técnicas para resolverlos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615001007/2025-26/RA37> a ns1:LearningResult ;
    ns1:learningResultCode "RA37" ;
    ns1:learningResultDescription "Estudiar funciones de varias variables, calcular límites y estudiar su continuidad"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615001007/2025-26/RA38> a ns1:LearningResult ;
    ns1:learningResultCode "RA38" ;
    ns1:learningResultDescription "Calcular derivadas e integrales de funciones de varias variables, y usarlas para el estudio de propiedades locales de funciones y problemas aplicados"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615001007/2025-26/RA39> a ns1:LearningResult ;
    ns1:learningResultCode "RA39" ;
    ns1:learningResultDescription "Conocer los conceptos de sucesión y serie de funciones, así como sus convergencias"@es .

