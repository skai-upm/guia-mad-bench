<https://guia-kg.skai.etsisi.upm.es/resource/33000471/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/33000471/2025-26/CE%201.7>,
        <https://guia-kg.skai.etsisi.upm.es/resource/33000471/2025-26/CE%201.8>,
