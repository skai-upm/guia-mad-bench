    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/115100030/2025-26/eventSchedule> ;
    schema:description "La Fisiología del Ejercicio continúa con la labor de formación en las ciencias biomédicas aplicadas al ejercicio. Permite comprender y aplicar correctamente los estímulos de entrenamiento que se producen en la mayoría de las actividades físicas. Es el complemento consustancial a la teoría del entrenamiento y el resto de las ciencias fisiológicas, aportando herramientas prácticas para el egresado en su práctica profesional más habitual."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/pedroj.benito%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/domingojesus.ramos%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/ismael.mguardado%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/pedroj.benito%40upm.es> ;
    schema:name "Fisiología del Ejercicio"@es .

