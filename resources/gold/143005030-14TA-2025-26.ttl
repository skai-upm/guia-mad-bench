    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/143005030/2025-26/eventSchedule> ;
    schema:description """La asignatura está enfocada a la descripción de los diferentes elementos y sistemas de un sistema completo de aviónica.
Se pretende enfocar la actividad al aprendizaje por parte del alumno de nuevas tendencias en sistemas electrónicos embarcados.
En la asignatura se prestará especial atención a las técnicas de certificación de sistemas embarcados."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/javier.crespo%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/javier.crespo%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/tomas.martin%40upm.es> ;
    schema:name "Arquitectura de Sistemas de Avionica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005030/2025-26/CE10> a ns1:Competency ;
    ns1:competencyCode "CE10" ;
    ns1:competencyDescription "Comprender la problemática propia de los sistemas electrónicos terrestres y embarcados en los diferentes elementos del Sistema del Transporte Aéreo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005030/2025-26/CG2> a ns1:Competency ;
    ns1:competencyCode "CG2" ;
    ns1:competencyDescription "Aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en los entornos de evolución previstos en los Sistemas de Transporte Aéreo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005030/2025-26/CG4> a ns1:Competency ;
    ns1:competencyCode "CG4" ;
    ns1:competencyDescription "Comunicar sus conclusiones y los conocimientos y razones últimas que las sustentan a públicos especializados, y no especializados de un modo claro y sin ambigüedades"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005030/2025-26/CG6> a ns1:Competency ;
    ns1:competencyCode "CG6" ;
    ns1:competencyDescription "Que los estudiantes posean las habilidades de aprendizaje que les permitan continuar estudiando de un modo que habrá de ser en gran medida autodirigido o autónomo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005030/2025-26/RA26> a ns1:LearningResult ;
    ns1:learningResultCode "RA26" ;
    ns1:learningResultDescription "El alumno conoce y comprende los sistemas fundamentales de los equipos embarcados de aviónica, sus instalaciones eléctricas y electrónicas asociadas y los principios del control automático de vuelo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005030/2025-26/RA27> a ns1:LearningResult ;
    ns1:learningResultCode "RA27" ;
    ns1:learningResultDescription "Conocimiento de los sistemas y subsistemas que dan soporte al sistema de Navegación, de los transmisores y receptores integrados en cualquier aeronave o vehículo espacial y de su instalación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005030/2025-26/RA29> a ns1:LearningResult ;
    ns1:learningResultCode "RA29" ;
    ns1:learningResultDescription "Conocimiento y comprensión de la normativa aplicable en materia de seguridad y protección de la aviación civil"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/143005030/2025-26/RA39> a ns1:LearningResult ;
    ns1:learningResultCode "RA39" ;
    ns1:learningResultDescription "Comprensión de la necesidad de la evolución del Sistema de Navegación Aérea"@es .

