<https://guia-kg.skai.etsisi.upm.es/resource/43000682/2025-26/eventSchedule> a ns1:Schedule ;
    schema:eventSchedule <https://guia-kg.skai.etsisi.upm.es/resource/43000682/2025-26/eventSchedule/1>,
