    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/53000984/2025-26/eventSchedule> ;
    schema:description """Esta asignatura persigue proporcionar una formación en sistemas de medida, sensores y sistemas de adquisición de datos en el entorno de la ingeniería mecánica, particularmente en el contexto de la fabricación industrial.
Para ello se ha estructurado en tres grandes temas: sistemas de medida, sensores y sistemas de adquisición de datos, en los que se combinan actividades teóricas y prácticas.
El cronograma representa una orientación del plan docente de la asignatura que podrá sufrir variaciones dependiendo del desarrollo y evolución del curso académico."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/juandejuanes.marquez%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/juandejuanes.marquez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/monica.villaverde%40upm.es> ;
    schema:name "Instrumentacion en Ingenieria Mecanica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000984/2025-26/CG%202> a ns1:Competency ;
    ns1:competencyCode "CG 2" ;
    ns1:competencyDescription "Diseñar, desarrollar, implementar, gestionar y mejorar productos, sistemas y procesos en los distintos ámbitos de la ingeniería mecánica, usando técnicas analíticas, computacionales o experimentales apropiadas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000984/2025-26/CG%205> a ns1:Competency ;
    ns1:competencyCode "CG 5" ;
    ns1:competencyDescription "Comunicar los conocimientos y conclusiones, tanto de forma oral, escrita y gráfica, a públicos especializados y no especializados de un modo claro y sin ambigüedades."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000984/2025-26/CG%207> a ns1:Competency ;
    ns1:competencyCode "CG 7" ;
    ns1:competencyDescription "Aplicar nuevas tecnologías y herramientas de la Ingeniería Mecánica en sus actividades profesionales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53000984/2025-26/RA37> a ns1:LearningResult ;
    ns1:learningResultCode "RA37" ;
    ns1:learningResultDescription "Asignatura que introduce a las técnicas de medida en proceso o en prototipos de uso industrial, sensorización, acondicionamiento de señal, procesado digital de señal, desarrollo de interfaces Hombre"@es .

