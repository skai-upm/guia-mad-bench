<https://guia-kg.skai.etsisi.upm.es/resource/595040341/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/595040341/2025-26/CE%20B2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/595040341/2025-26/CE%20EC03>,
