<https://guia-kg.skai.etsisi.upm.es/resource/33000713/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Aproximación multiescalar Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000713/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "2. Gran escala/ paisaje Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000713/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "11. Capacidad para poner en práctica algunas variables de proyecto relacionadas con el estudio de referencias arquitectónicas contemporáneas; modos de habitar; relación interior-exterior; proyectar desde el exterior y desde el interior Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000713/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "12. Capacidad para aplicar los conocimientos técnico-estructurales en el proyecto y definir una respuesta precisa y ajustada a las definiciones proyectuales previas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000713/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "13. Capacidad para aplicar los conocimientos técnico-constructivos en el proyecto y definir una respuesta precisa y ajustada a las definiciones proyectuales previas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000713/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "14. Capacidad para aplicar los conocimientos sobre instalaciones y técnico aplicadas en el proyecto y definir una respuesta precisa y ajustada a las definiciones proyectuales previas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000713/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "15. Aptitud para reflexionar y analizar sobre los procesos de ideación arquitectónica con apoyo de la geometría Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000713/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "16. Ampliación de conocimientos sobre las herramientas básicas de la representación arquitectónica Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000713/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "17. Aptitud para la generación de sistemas arquitectónicos básicos Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000713/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "18. Conocimiento y práctica sobre accesibilidad universal de las personas con discapacidad. Sin subniveles"@es .

