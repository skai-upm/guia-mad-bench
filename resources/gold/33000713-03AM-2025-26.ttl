        <https://guia-kg.skai.etsisi.upm.es/resource/joseignacio.abalos%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/mariadelasnieves.mestre%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/mauro.gil.fournieresquerra%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/mi.collado%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/oscar.rueda%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/renata.sentkiewicz%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/sergio.demiguel%40upm.es> ;
    schema:name "Taller de Proyectos II"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000713/2025-26/CG1> a ns1:Competency ;
    ns1:competencyCode "CG1" ;
    ns1:competencyDescription "Conocimiento de los métodos de investigación y preparación de proyectos de construcción"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000713/2025-26/CG2> a ns1:Competency ;
    ns1:competencyCode "CG2" ;
    ns1:competencyDescription "Aptitud para crear proyectos arquitectónicos que satisfagan a su vez las exigencias estéticas y las técnicas, y los requisitos de los usuarios del edificio respetando los límites impuestos por los factores presupuestarios y la normativa sobre construcción."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000713/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Capacidad de comprender la profesión de arquitecto y su función en la sociedad, en particular elaborando proyectos que tengan en cuenta los factores sociales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000713/2025-26/CT1> a ns1:Competency ;
    ns1:competencyCode "CT1" ;
    ns1:competencyDescription "Capacidad para comprender los contenidos de clases magistrales, conferencias y seminarios en lengua inglesa."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000713/2025-26/CT2> a ns1:Competency ;
    ns1:competencyCode "CT2" ;
    ns1:competencyDescription "Capacidad para dinamizar y liderar equipos de trabajo multidisciplinares"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000713/2025-26/CT3> a ns1:Competency ;
    ns1:competencyCode "CT3" ;
    ns1:competencyDescription "Capacidad para adoptar soluciones creativas que satisfagan adecuadamente las diferentes necesidades planteadas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000713/2025-26/CT4> a ns1:Competency ;
    ns1:competencyCode "CT4" ;
    ns1:competencyDescription "Capacidad para trabajar de forma efectiva como individuo, organizando y planificando su propio trabajo, de forma independiente o como miembro de un equipo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000713/2025-26/CT5> a ns1:Competency ;
    ns1:competencyCode "CT5" ;
    ns1:competencyDescription "Capacidad para gestionar la información, identificando las fuentes necesarias, los principales tipos de documentos técnicos y científicos, de una manera adecuada y eficiente"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000713/2025-26/CT6> a ns1:Competency ;
