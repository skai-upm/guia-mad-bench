    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/53002088/2025-26/eventSchedule> ;
    schema:description "Esta asignatura se centra en algunos aspectos concreto de la bioingeniería de gran relevancia tanto actual como futura. La parte de ingeniería en las disciplinas que se imparten en la asignatura están relacionadas con tecnologías industriales aplicadas a tecnologías de la salud y la bioingeniería en su conjunto. Así la asignatura está organizada en cuatro módulos. El primer módulo es de introducción a la Bioingeniería, el segundo ya se centra en las técnicas de fabricación en ingeniería de tejido, el tercero en las técnicas de fabricación y diseño de chips microfluídicos para órganos y tejidos en chips, para terminar con un último módulo centrado en sistemas de detección Biológica y biosensores. La asignatura se cursará en 14 semanas con tres prácticas para cada uno de los módulos especializados. A continuación, se detalla el programa de la asignatura."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/m.holgado%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/carlos.molpeceres%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/m.holgado%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/mariafe.laguna%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/sara.lauzurica%40upm.es> ;
    schema:name "Bioingeniería"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002088/2025-26/%28a%29> a ns1:Competency ;
    ns1:competencyCode "(a)" ;
    ns1:competencyDescription "APLICA. Habilidad para aplicar conocimientos científicos, matemáticos y tecnológicos en sistemas relacionados con la práctica de la ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002088/2025-26/%28b%29> a ns1:Competency ;
    ns1:competencyCode "(b)" ;
    ns1:competencyDescription "EXPERIMENTA. Habilidad para diseñar y realizar experimentos así como analizar e interpretar datos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002088/2025-26/CB07> a ns1:Competency ;
    ns1:competencyCode "CB07" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en entornos nuevos o poco conocidos dentro de contextos más amplios"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002088/2025-26/CG01> a ns1:Competency ;
    ns1:competencyCode "CG01" ;
    ns1:competencyDescription "Tener conocimientos adecuados de los aspectos científicos y tecnológicos de: métodos matemáticos, analíticos y numéricos en la ingeniería, ingeniería eléctrica, ingeniería energética, ingeniería química, ingeniería mecánica, mecánica de medios continuos, electrónica industrial, automática, fabricación, materiales, métodos cuantitativos de gestión, informática industrial, urbanismo, infraestructuras, etc."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002088/2025-26/CG04> a ns1:Competency ;
    ns1:competencyCode "CG04" ;
    ns1:competencyDescription "Realizar investigación, desarrollo e innovación en productos, procesos y métodos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002088/2025-26/RA423> a ns1:LearningResult ;
    ns1:learningResultCode "RA423" ;
    ns1:learningResultDescription "Conocer el ámbito y los fundamentos de bioingeniería, biotecnología y biomedicina"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002088/2025-26/RA424> a ns1:LearningResult ;
    ns1:learningResultCode "RA424" ;
    ns1:learningResultDescription "Fundamentos de tecnologías ómicas, biología molecular, bioquímica e inmunología, materiales biocompatibles y aspectos básicos de micro"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002088/2025-26/RA425> a ns1:LearningResult ;
    ns1:learningResultCode "RA425" ;
    ns1:learningResultDescription "Técncias de fabricación en ingeniería de tejido, especialmente las orientadas a fabricación tridimensional (3D)"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/53002088/2025-26/RA426> a ns1:LearningResult ;
    ns1:learningResultCode "RA426" ;
    ns1:learningResultDescription "Conocer las principales rutas tecnológicas hacia la futura fabricación de organoides y organos en bioreactores y chips microfluídicos"@es .

