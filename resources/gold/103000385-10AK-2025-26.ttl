<https://guia-kg.skai.etsisi.upm.es/resource/103000385/2025-26/CEM1> a ns1:Competency ;
    ns1:competencyCode "CEM1" ;
    ns1:competencyDescription "Identificar, a partir del estado de la cuestión, la presencia de problemas de investigación relacionados con la concepción, la construcción, el uso y la evaluación de sistemas sociotécnicos complejos que hagan un uso intensivo de software"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000385/2025-26/CEM4> a ns1:Competency ;
    ns1:competencyCode "CEM4" ;
    ns1:competencyDescription "Analizar y evaluar los diferentes paradigmas y enfoques de ingeniería de construcción y gestión de sistemas basados en software."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000385/2025-26/CEM5> a ns1:Competency ;
    ns1:competencyCode "CEM5" ;
    ns1:competencyDescription "Aportar soluciones a aquellos problemas abiertos relacionados con el ámbito de aplicación y los métodos, técnicas y herramientas de Verificación y Validación de Software"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000385/2025-26/CG12> a ns1:Competency ;
    ns1:competencyCode "CG12" ;
    ns1:competencyDescription "Comprensión amplia de las técnicas y métodos aplicables en una especialización concreta, así como de sus límites"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000385/2025-26/CG13> a ns1:Competency ;
    ns1:competencyCode "CG13" ;
    ns1:competencyDescription "Apreciación de los límites del conocimiento actual y de la aplicación práctica de la tecnología más reciente."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000385/2025-26/CG14> a ns1:Competency ;
    ns1:competencyCode "CG14" ;
    ns1:competencyDescription "Conocimiento y comprensión de la informática necesaria para la creación de modelos de información, y de los sistemas y procesos complejos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000385/2025-26/CG4> a ns1:Competency ;
    ns1:competencyCode "CG4" ;
    ns1:competencyDescription "Que los estudiantes posean las habilidades de aprendizaje que les permitan continuar estudiando de un modo que habrá de ser en gran medida autodirigido o autónomo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000385/2025-26/CG7> a ns1:Competency ;
    ns1:competencyCode "CG7" ;
    ns1:competencyDescription "Especificación y realización de tareas informáticas complejas, poco definidas o no familiares"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000385/2025-26/CG8> a ns1:Competency ;
    ns1:competencyCode "CG8" ;
    ns1:competencyDescription "Planteamiento y resolución de problemas también en áreas nuevas y emergentes de su disciplina"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000385/2025-26/CG9> a ns1:Competency ;
    ns1:competencyCode "CG9" ;
    ns1:competencyDescription "Aplicación de los métodos de resolución de problemas más recientes o innovadores y que puedan implicar el uso de otras disciplinas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000385/2025-26/CGI20> a ns1:Competency ;
    ns1:competencyCode "CGI20" ;
    ns1:competencyDescription "Adquirir conocimientos científicos avanzados del campo de la informática que le permitan generar nuevas ideas dentro de una línea de investigación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000385/2025-26/CGI23> a ns1:Competency ;
    ns1:competencyCode "CGI23" ;
    ns1:competencyDescription "Capacidad de leer y comprender publicaciones dentro de su ámbito de estudio/investigación, así como su catalogación y valor científico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000385/2025-26/RA41> a ns1:LearningResult ;
    ns1:learningResultCode "RA41" ;
    ns1:learningResultDescription "Aplicar efectivamente las técnicas de verificación y validación de software"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/103000385/2025-26/RA42> a ns1:LearningResult ;
    ns1:learningResultCode "RA42" ;
    ns1:learningResultDescription "Seleccionar la técnica de verificación/validación de software más adecuada para un proyecto determinado"@es .

