<https://guia-kg.skai.etsisi.upm.es/resource/205000021/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. UT1.- Sistemas agrarios"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000021/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. UT1-Tema 1.- Sistemas agrarios e intensificación sostenible de los sistemas de producción."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000021/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "2.2.1. Desarrollo vs. Crecimiento. Fenología, fases y estadios. Motores del desarrollo: temperatura y fotoperiodo. Necesidades de frío y vernalización. Cuantificación del desarrollo: Tasas de desarrollo; Integral térmica y Fototérmica. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000021/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "2.2.2. Crecimiento y tasas de producción de biomasa. Fuentes y Sumideros. Eficiencia en el uso de la radiación PAR: concepto y factores que influyen. Índices de crecimiento Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000021/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "2.2.3. Reparto de los productos fotosintetizados. Índice de cosecha. Rendimiento y sus componentes. Brecha de Rendimiento. Reparto de fotoasimilados en frutales: poda y sistemas de conducción. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000021/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "3. UT3.- La interacción cultivo-ambiente"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000021/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "3.1. UT3-Tema 4.- Balances de energía y su aplicación a las técnicas de cultivo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000021/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "3.1.1. Componentes del balance de energía en los cultivos Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000021/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "3.1.2. Densidad de flujo de calor al suelo. Perfiles de Tsuelo. Técnicas de modificación de la Tsuelo. Acolchados Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000021/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "3.1.3. Densidad de flujo de calor sensible y calor latente en el aire. Perfiles de Taire y de humedad sobre los cultivos. Perfil del viento y efectos sobre los cultivos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000021/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "3.1.4. Protección contra temperaturas desfavorables. Temperaturas elevadas y heladas. Métodos directos e indirectos. Casos prácticos Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000021/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "3.2. UT3-Tema 5.- Relaciones hídricas y continuo suelo-cultivo-atmósfera; la evapotranspiración de los cultivos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000021/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.1.1. Sistemas agrarios: Definición, estructura, y propiedades. Diferencias entre sistemas agrarios y ecosistemas. Clasificación y atributos. Sistemas agrarios más representativos de la agricultura mediterránea. Brechas de rendimiento. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000021/2025-26/syllabus/20> a ns1:SyllabusItem ;
    ns1:itemIndex 20 ;
    ns1:syllabusDescription "3.2.1. Movimiento del agua en el continuo suelo-cultivo-atmósfera. Evapotranspiración de los cultivos. Factores que influyen en la evapotranspiración. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000021/2025-26/syllabus/21> a ns1:SyllabusItem ;
    ns1:itemIndex 21 ;
    ns1:syllabusDescription "3.2.2. Relaciones entre la evapotranspiración y la producción de los cultivos. Funciones de producción. Uso de agua en la producción de biomasa. Eficiencia en el uso del agua. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000021/2025-26/syllabus/22> a ns1:SyllabusItem ;
    ns1:itemIndex 22 ;
    ns1:syllabusDescription "3.2.3. Métodos de medida y de estimación de la evapotranspiración de referencia (ET0) y de los cultivos (ETc, ETmax). Casos prácticos, estimación de las necesidades de agua de cultivos herbáceos y leñosos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000021/2025-26/syllabus/23> a ns1:SyllabusItem ;
    ns1:itemIndex 23 ;
    ns1:syllabusDescription "3.3. UT3-Tema 6-. Cultivo en condiciones de déficit hídrico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000021/2025-26/syllabus/24> a ns1:SyllabusItem ;
    ns1:itemIndex 24 ;
    ns1:syllabusDescription "3.3.1. Definiciones: sequía, déficit hídrico y estrés hídrico. Tipos de déficit hídrico y respuesta de los cultivos al déficit hídrico según la fase de desarrollo. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000021/2025-26/syllabus/25> a ns1:SyllabusItem ;
    ns1:itemIndex 25 ;
    ns1:syllabusDescription "3.3.2. Mecanismos de adaptación. Relaciones entre evapotranspiración y producción de los cultivos. Funciones de producción. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000021/2025-26/syllabus/26> a ns1:SyllabusItem ;
    ns1:itemIndex 26 ;
    ns1:syllabusDescription "3.3.3. Técnicas para optimizar la eficiencia en el uso del agua por los cultivos. Estrategias de manejo en zonas áridas y semiáridas: rotaciones, barbecho, elección de especies y variedades, fechas de siembra, densidades. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000021/2025-26/syllabus/27> a ns1:SyllabusItem ;
    ns1:itemIndex 27 ;
    ns1:syllabusDescription "4. UT4- Manejo de cultivos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000021/2025-26/syllabus/28> a ns1:SyllabusItem ;
    ns1:itemIndex 28 ;
    ns1:syllabusDescription "4.1. UT4-Tema 7.- Siembra y plantación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000021/2025-26/syllabus/29> a ns1:SyllabusItem ;
    ns1:itemIndex 29 ;
    ns1:syllabusDescription "4.1.1. Decisiones relacionadas con la siembra. Fecha, densidad, profundidad de siembra Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000021/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "1.1.2. Secuencias de cultivos. Rotaciones de cultivo. Cultivos asociados e intercalares. Diversidad de los sistemas de cultivo resultantes. Itinerarios técnicos de los cultivos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000021/2025-26/syllabus/30> a ns1:SyllabusItem ;
    ns1:itemIndex 30 ;
    ns1:syllabusDescription "4.1.2. Transplante de plantas anuales. Establecimiento de plantaciones Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000021/2025-26/syllabus/31> a ns1:SyllabusItem ;
    ns1:itemIndex 31 ;
    ns1:syllabusDescription "4.2. UT4-Tema 8.- Manejo del suelo. Técnicas de conservación y mejora de los suelos agrícolas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000021/2025-26/syllabus/32> a ns1:SyllabusItem ;
    ns1:itemIndex 32 ;
    ns1:syllabusDescription "4.2.1. Laboreo del suelo. Preparación del suelo para la siembra. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000021/2025-26/syllabus/33> a ns1:SyllabusItem ;
    ns1:itemIndex 33 ;
    ns1:syllabusDescription "4.2.2. Laboreo de conservación. Sistemas de conservación del suelo en plantaciones Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000021/2025-26/syllabus/34> a ns1:SyllabusItem ;
    ns1:itemIndex 34 ;
    ns1:syllabusDescription "4.3. UT4-Tema 9.- Control de la materia orgánica del suelo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000021/2025-26/syllabus/35> a ns1:SyllabusItem ;
    ns1:itemIndex 35 ;
    ns1:syllabusDescription "4.3.1. Programas de fertilización orgánica. Balances Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000021/2025-26/syllabus/36> a ns1:SyllabusItem ;
    ns1:itemIndex 36 ;
    ns1:syllabusDescription "4.3.2. Incorporación de los fertizantes orgánicos. Estiércoles y purines Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000021/2025-26/syllabus/37> a ns1:SyllabusItem ;
    ns1:itemIndex 37 ;
    ns1:syllabusDescription "4.4. UT4-Tema 10.- Gestión de la fertilidad del suelo y suministro de nutrientes"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000021/2025-26/syllabus/38> a ns1:SyllabusItem ;
    ns1:itemIndex 38 ;
    ns1:syllabusDescription "4.4.1. Gestión de la fertilidad del suelo y suministro de nutrientes. Necesidades de nutrientes de los cultivos herbáceos y leñosos Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000021/2025-26/syllabus/39> a ns1:SyllabusItem ;
    ns1:itemIndex 39 ;
    ns1:syllabusDescription "4.4.2. Planificación de la fertilización nitrogenada en el ciclo del cultivo: balances y elección del fertilizante. Métodos de incorporación de los fertilizantes Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000021/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "1.1.3. Prácticas: Capacidad de carga. Relación de área equivalente. Relación de rendimiento equivalente. Brechas de rendimiento Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000021/2025-26/syllabus/40> a ns1:SyllabusItem ;
    ns1:itemIndex 40 ;
    ns1:syllabusDescription "4.4.3. Planificación de la fertilización con fósforo, potasio y otros nutrientes. Criterios de planificación de la fertilización. Métodos de incorporación Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000021/2025-26/syllabus/41> a ns1:SyllabusItem ;
    ns1:itemIndex 41 ;
    ns1:syllabusDescription "4.4.4. Casos prácticos de programación de la fertilización en cultivos y en rotaciones. Aprendizaje con Fertilicalc Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000021/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "2. UT2.- Bases de la productividad de los cultivos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000021/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "2.1. UT2-Tema 2.- Intercepción de radiación en cubiertas vegetales y diseño de cubiertas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000021/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "2.1.1. Intercepción y balance de radiación PAR en cultivos herbáceos y leñosos. Influencia de la arquitectura de la cubierta vegetal en la intercepción de radiación PAR en cultivos herbáceos y leñosos Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000021/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "2.1.2. Factores y prácticas agronómicas que influyen en el balance de radiación PAR. Densidad y marcos de siembra y plantación, poda y sistemas de conducción Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000021/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "2.2. UT2-Tema 3.- Crecimiento y desarrollo: Formación del rendimiento"@es .

