    ns1:courseType "Obligatoria"@es ;
    ns1:courseYear 1 ;
    ns1:semester "Primer semestre"@es ;
    schema:courseCode 563000145 ;
    schema:hasCourseInstance <https://guia-kg.skai.etsisi.upm.es/resource/563000145/2025-26> ;
    schema:name "Mathematics Applied To Production Engineering"@en,
        "Matemáticas Aplicadas a la Ingeniería de Producción"@es ;
    schema:numberOfCredits 4.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/563000145/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/563000145/2025-26/CEC03>,
        <https://guia-kg.skai.etsisi.upm.es/resource/563000145/2025-26/CEI16>,
        <https://guia-kg.skai.etsisi.upm.es/resource/563000145/2025-26/CG06> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/563000145/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/563000145/2025-26/didactic_resource/2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/563000145/2025-26/didactic_resource/3>,
        <https://guia-kg.skai.etsisi.upm.es/resource/563000145/2025-26/didactic_resource/4>,
        <https://guia-kg.skai.etsisi.upm.es/resource/563000145/2025-26/didactic_resource/5>,
        <https://guia-kg.skai.etsisi.upm.es/resource/563000145/2025-26/didactic_resource/6> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/563000145/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/563000145/2025-26/RA18> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/563000145/2025-26/syllabus> ;
    ns1:inpersonHours "27 horas (26%)"@es ;
    ns1:numberOfCredits 4.0 ;
    ns1:otherInformation "Las clases se impartirán presencialmente. En caso de necesitar impartir las clases telemáticamente se usará la platraforma Teams Office y Moodle, de acuerdo a la planificación indicada para la enseñanza presencial."@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "27 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/563000145/2025-26/eventSchedule> ;
    schema:description """La asignatura tiene dos bloques, uno dedicado a la inferencia estadística y otro a los sistemas dinámicos tal como se muestra a continuación.
1.- INFERENCIA ESTADÍSTICA
1.1 Introducción a la inferencia estadística
1.1 Estimación puntual paramétrica
1.2 Estimación por regiones o intervalos de confianza
1.3 Contraste de hipótesis
1.4 Teoría de la decisión
1.5 Inferencia no paramétrica
1.6 Regresión lineal
1.6 Análisis de la varianza
2.- SISTEMAS DINÁMICOS
2.1 Dinámica discreta
2.2 Introducción a la teoría del caos
En la parte estadística se les enseñará a aplicar los criterios estadísticos para la toma de decisiones. En la dinámica de sistemas se les enseñará a modelar sistemas y estudiar los efectos no lineales."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/dl.rodriguez.vidanes%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/dl.rodriguez.vidanes%40upm.es> ;
    schema:name "Matemáticas Aplicadas a la Ingeniería de Producción"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000145/2025-26/CEC03> a ns1:Competency ;
    ns1:competencyCode "CEC03" ;
    ns1:competencyDescription "Capacidad para el modelado matemático, cálculo y simulación de productos, sistemas y procesos en centros tecnológicos y de ingeniería"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000145/2025-26/CEI16> a ns1:Competency ;
    ns1:competencyCode "CEI16" ;
    ns1:competencyDescription "Capacidad de comunicar con sus colegas, con la comunidad académica en su conjunto y con la sociedad en general acerca de sus áreas de conocimiento"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000145/2025-26/CG06> a ns1:Competency ;
    ns1:competencyCode "CG06" ;
    ns1:competencyDescription "Capacidad para la aplicación de los conocimientos adquiridos y resolver problemas en entornos nuevos o poco conocidos dentro de contextos más amplios y multidisciplinares, siendo capaces de integrar conocimientos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/563000145/2025-26/RA18> a ns1:LearningResult ;
    ns1:learningResultCode "RA18" ;
    ns1:learningResultDescription "Capacidad para crear un modelo matemático a partir de un problema físico"@es .

