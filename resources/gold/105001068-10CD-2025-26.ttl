    ns1:inpersonHours "34 horas (43.6%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation """Metodologías docentes innovadoras aplicadas en la asignatura
El enfoque Design Thinking para la resolución de las prácticas de laboratorio, éstas se abordarán y resolverán con curiosidad, observación,
empatía, razonamiento sistémico, imaginación, experimentación, optimismo, y de manera colaborativa."""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "42 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/105001068/2025-26/eventSchedule> ;
    schema:description """ADQUISICIÓN DE SEÑALES DIGITALES
- Introducción a la plataforma Arduino
- Sensores y Actuadores
- Adquisición de Señales Digitales
APLICACIONES DEL PROCESADO DIGITAL DE SEÑALES
- Procesado de señales de audio
- Procesado de imágenes
- Procesado de señales biomédicas"""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/n.felix%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/angelmario.garcia%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/francisco.naveros%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/marco.rivera%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/n.felix%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/rafael.martinezo%40upm.es> ;
    schema:name "Aplicaciones del Procesado Digital de Señales"@es .

