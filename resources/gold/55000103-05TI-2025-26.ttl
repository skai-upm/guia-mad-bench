<https://guia-kg.skai.etsisi.upm.es/resource/55000103/2025-26/evaluation> a ns1:EvaluationSystem ;
    ns1:evaluationDescription "Para superar tanto por evaluación progresiva como por evaluación global es necesario obtener una nota igual o superior a 5. El proyecto es obligatorio y pesa un 30% de la nota final y el examen escrito pesa un 70% en los dos tipos de evaluación. Por evaluación progresiva, se puede liberar la mitad del temario en la PEG de la semana 14."@es ;
    ns1:hasEvaluationTrial <https://guia-kg.skai.etsisi.upm.es/resource/55000103/2025-26/evaluation/trial1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55000103/2025-26/evaluation/trial2>,
