    ns1:hasItem <https://guia-kg.skai.etsisi.upm.es/resource/55000103/2025-26/syllabus/0>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55000103/2025-26/syllabus/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55000103/2025-26/syllabus/10>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55000103/2025-26/syllabus/2>,
