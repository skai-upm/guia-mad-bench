        <https://guia-kg.skai.etsisi.upm.es/resource/55000103/2025-26/syllabus/6>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55000103/2025-26/syllabus/7>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55000103/2025-26/syllabus/8>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55000103/2025-26/syllabus/9> .

<https://guia-kg.skai.etsisi.upm.es/resource/55000103/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Presentación de la asignatura Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000103/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "2. Introducción a la Física de Estado Solido. Conducción eléctrica en semiconductores Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000103/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "11. Circuitos lineales con AOs. Análisis en bucle abierto y en bucle cerrado. Estabilidad. Error máximo en continua Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000103/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "3. La Unión PN Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000103/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "4. El diodo. Ecuación y curva característica. El dodo como elemento de circuito. Diferentes tipos de diodos Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000103/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "5. Transistores. El transistor bipolar. Modelos de pequeña y gran señal. El transistor como elemento de circuito Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000103/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "6. Transistores de efecto de campo. Transistores JFET y MOSFET. Modelos de pequeña y gran señal. El transistor de efecto de campo como elemento de circuito Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000103/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "7. Amplificación discreta con componentes discretos. Análisis en el dominio de la frecuencia. Análisis en continua y alterna Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000103/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "8. Amplificadores de varias etapas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000103/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "9. Amplificadores realimentados. Análisis de estabilidad. Criterio de Nyquist Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000103/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "10. Amplificación integrada. El amplificador operacional. Análisis en continua y alterna. Estabilidad Sin subniveles"@es .

