    ns1:competencyCode "C1" ;
    ns1:competencyDescription "Elaborar y redactar conclusiones deducidas de los análisis y estudios realizados sobre obras o textos de proyectos arquitectónicos TIPO: Competencias."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000858/2025-26/C7> a ns1:Competency ;
    ns1:competencyCode "C7" ;
    ns1:competencyDescription "Comisariar investigaciones/exposiciones y gestionar publicaciones sobre proyectos arquitectónicos con enfoques contemporáneos TIPO: Competencias."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000858/2025-26/C9> a ns1:Competency ;
    ns1:competencyCode "C9" ;
    ns1:competencyDescription "Crear áreas de oportunidad proyectual TIPO: Competencias."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000858/2025-26/K11> a ns1:Competency ;
    ns1:competencyCode "K11" ;
    ns1:competencyDescription "Explicar proyectos de investigación o tesis en proyectos arquitectónicos TIPO: Conocimientos o contenidos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000858/2025-26/K3> a ns1:Competency ;
    ns1:competencyCode "K3" ;
    ns1:competencyDescription "Relacionar diferentes proyectos arquitectónicos, así como las estrategias y tácticas aplicadas en ellos TIPO: Conocimientos o Contenidos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000858/2025-26/K5> a ns1:Competency ;
    ns1:competencyCode "K5" ;
    ns1:competencyDescription "Gestionar presupuestos y tiempos TIPO: Conocimientos o contenidos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000858/2025-26/RA31> a ns1:LearningResult ;
    ns1:learningResultCode "RA31" ;
    ns1:learningResultDescription "Los resultados del aprendizaje correspondientes a esta asignatura han quedado definidos en el apartado de competencias de este documento, señalando los que corresponden a conocimientos, habilidades y competencias propiamente dichas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000858/2025-26/SK12> a ns1:Competency ;
    ns1:competencyCode "SK12" ;
    ns1:competencyDescription "Elaborar nuevas metodologías en el ámbito de la investigación en proyectos arquitectónicos TIPO: Habilidades o destrezas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000858/2025-26/SK9> a ns1:Competency ;
    ns1:competencyCode "SK9" ;
    ns1:competencyDescription "Formular hipótesis y verificarlas a través de un proceso proyectual, desde la comprensión sistemática y la conciencia crítica del conocimiento arquitectónico TIPO: Habilidades o destrezas."@es .

