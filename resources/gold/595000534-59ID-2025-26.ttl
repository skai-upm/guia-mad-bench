    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/595000534/2025-26/eventSchedule> ;
    schema:description """Los objetivos de esta asignatura son:
Conocer la necesidad de la Ciberseguridad y los componentes y elementos que forman parte de sus competencias.
Conocer los fundamentos organizativos y legislativos en los que se basan las tecnologías de ciberseguridad y protección de datos.
Conocer las principales amenazas y vulnerabilidades de los distintos elementos involucrados en la ingeniería de datos, así como sus causas.
Conocer y ser capaz de diseñar y aplicar las tecnologías y sistemas que conforman una Arquitectura de Seguridad de las TIC, en sus distintas perspectivas, así como los fundamentos de criptografía en los que se basan.
Conocer y ser capaz de diseñar sistemas de Ingeniería de Privacidad"""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/marialuisa.martinr%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/marialuisa.martinr%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/mario.vega%40upm.es> ;
    schema:name "Ciberseguridad y Protección de Datos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000534/2025-26/CB01> a ns1:Competency ;
    ns1:competencyCode "CB01" ;
    ns1:competencyDescription "Que los estudiantes hayan demostrado poseer y comprender conocimientos en un área de estudio que parte de la base de la educación secundaria general, y se suele encontrar a un nivel que, si bien se apoya en libros de texto avanzados, incluye también algunos aspectos que implican conocimientos procedentes de la vanguardia de su campo de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000534/2025-26/CB02> a ns1:Competency ;
    ns1:competencyCode "CB02" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar sus conocimientos a su trabajo o vocación de una forma profesional y posean las competencias que suelen demostrarse por medio de la elaboración y defensa de argumentos y la resolución de problemas dentro de su área de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000534/2025-26/CB03> a ns1:Competency ;
    ns1:competencyCode "CB03" ;
    ns1:competencyDescription "Que los estudiantes tengan la capacidad de reunir e interpretar datos relevantes (normalmente dentro de su área de estudio) para emitir juicios que incluyan una reflexión sobre temas relevantes de índole social, científica o ética"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000534/2025-26/CB04> a ns1:Competency ;
    ns1:competencyCode "CB04" ;
    ns1:competencyDescription "Que los estudiantes puedan transmitir información, ideas, problemas y soluciones a un público tanto especializado como no especializado"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000534/2025-26/CB05> a ns1:Competency ;
    ns1:competencyCode "CB05" ;
    ns1:competencyDescription "Que los estudiantes hayan desarrollado aquellas habilidades de aprendizaje necesarias para emprender estudios posteriores con un alto grado de autonomía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000534/2025-26/CE04> a ns1:Competency ;
    ns1:competencyCode "CE04" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de aplicar los conceptos y tecnologías del ámbito de la ingeniería de la telecomunicación en cualquier sector (eHealth, business intelligence, smart cities, etc.) incorporando aspectos técnicos, de negocio y de gestión."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000534/2025-26/CE05> a ns1:Competency ;
    ns1:competencyCode "CE05" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de analizar los requisitos e identificar los riesgos de un proyecto de ingeniería de datos y sistemas en el ámbito de la ingeniería de telecomunicación a partir de la comprensión del ciclo de vida completo del dato."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000534/2025-26/CE11> a ns1:Competency ;
    ns1:competencyCode "CE11" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de diseñar y operar sistemas de almacenamiento y transmisión de datos teniendo en cuenta estrategias y requisitos de seguridad y privacidad, políticas de acceso a los datos, con capacidad de prever ataques y subsanar vulnerabilidades."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000534/2025-26/CE21> a ns1:Competency ;
    ns1:competencyCode "CE21" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de aplicar de manera adecuada la normativa, legislación y regulaciones relativas a los sistemas y servicios específicos de la titulación, así como las especificaciones, estándares y directivas técnicas en función de las características, los requisitos y la funcionalidad que deban implementarse."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000534/2025-26/CG01> a ns1:Competency ;
    ns1:competencyCode "CG01" ;
    ns1:competencyDescription "Tener capacidad de trabajar en entornos internacionales y multidisciplinares, haciendo uso de la lengua inglesa en forma oral y escrita."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000534/2025-26/CG03> a ns1:Competency ;
    ns1:competencyCode "CG03" ;
    ns1:competencyDescription "Ser capaz de explicar de forma oral o escrita las soluciones planteadas para la resolución de un problema."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000534/2025-26/CG04> a ns1:Competency ;
    ns1:competencyCode "CG04" ;
    ns1:competencyDescription "Saber identificar y utilizar las herramientas de las Tecnologías de la Información y de las Comunicaciones más adecuadas para plantear y construir soluciones a problemas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000534/2025-26/CG05> a ns1:Competency ;
    ns1:competencyCode "CG05" ;
    ns1:competencyDescription "Tener la capacidad de concebir y proponer soluciones creativas aplicando los métodos científico y de ingeniería para la definición y resolución de problemas formalizando los objetivos buscados y considerando los recursos disponibles."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000534/2025-26/RA104> a ns1:LearningResult ;
    ns1:learningResultCode "RA104" ;
    ns1:learningResultDescription "Comprender las amenazas a la seguridad de las infraestructuras de datos y las metodologías de análisis de riesgos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000534/2025-26/RA105> a ns1:LearningResult ;
    ns1:learningResultCode "RA105" ;
    ns1:learningResultDescription "Diseñar y aplicar las técnicas de protección de las infraestructuras de datos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000534/2025-26/RA106> a ns1:LearningResult ;
    ns1:learningResultCode "RA106" ;
    ns1:learningResultDescription "Conocer la legislación en materia de protección de datos."@es .

