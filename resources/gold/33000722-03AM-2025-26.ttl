<https://guia-kg.skai.etsisi.upm.es/resource/33000722> a ns1:Course ;
    ns1:courseType "Optativa"@es ;
    ns1:courseYear 1 ;
    ns1:semester "Primer semestre"@es ;
    schema:courseCode 33000722 ;
    schema:hasCourseInstance <https://guia-kg.skai.etsisi.upm.es/resource/33000722/2025-26> ;
    schema:name "Architecture Now"@en,
        "La Arquitectura Ahora"@es ;
    schema:numberOfCredits 4.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/33000722/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/33000722/2025-26/CE71>,
        <https://guia-kg.skai.etsisi.upm.es/resource/33000722/2025-26/CE73>,
        <https://guia-kg.skai.etsisi.upm.es/resource/33000722/2025-26/CG2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/33000722/2025-26/CG3>,
        <https://guia-kg.skai.etsisi.upm.es/resource/33000722/2025-26/CT4>,
        <https://guia-kg.skai.etsisi.upm.es/resource/33000722/2025-26/CT5> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/33000722/2025-26/didactic_resource/1> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/33000722/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/33000722/2025-26/RA84>,
        <https://guia-kg.skai.etsisi.upm.es/resource/33000722/2025-26/RA85>,
        <https://guia-kg.skai.etsisi.upm.es/resource/33000722/2025-26/RA86>,
        <https://guia-kg.skai.etsisi.upm.es/resource/33000722/2025-26/RA87>,
        <https://guia-kg.skai.etsisi.upm.es/resource/33000722/2025-26/RA88> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/33000722/2025-26/syllabus> ;
    ns1:inpersonHours "46 horas y 30 minutos (44.7%)"@es ;
    ns1:numberOfCredits 4.0 ;
    ns1:otherInformation ""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "46 horas y 30 minutos"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/33000722/2025-26/eventSchedule> ;
    schema:description """La obra de todo arquitecto se nutre e impregna del contexto arquitectónico en el que se produce y, en él, las preferencias de cada uno son referentes habituales de esa obra.
Actualmente, ese contexto está constituido por una gran variedad de tendencias que se han ido fraguando y desarrollando en el periodo que abarca el cambio del siglo XX al XXI.
La asignatura plantea una exposición ordenada de las principales tendencias del panorama arquitectónico actual. Aborda el estudio de sus orígenes y desarrollos a través de las obras arquitectónicas más significativas.
De este modo pretende ampliar y rellenar el hueco existente en las enseñanzas de grado y proporcionar un conocimiento que todo arquitecto en ejercicio debería tener."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/laura.sanchezca%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/enrique.encabo%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/laura.sanchezca%40upm.es> ;
    schema:name "La Arquitectura Ahora"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000722/2025-26/CE71> a ns1:Competency ;
    ns1:competencyCode "CE71" ;
    ns1:competencyDescription "Aptitud para elaborar programas funcionales de edificios y espacios urbanos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000722/2025-26/CE73> a ns1:Competency ;
    ns1:competencyCode "CE73" ;
    ns1:competencyDescription "Aptitud para ejercer la crítica arquitectónica."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000722/2025-26/CG2> a ns1:Competency ;
    ns1:competencyCode "CG2" ;
    ns1:competencyDescription "Aptitud para crear proyectos arquitectónicos que satisfagan a su vez las exigencias estéticas y las técnicas, y los requisitos de los usuarios del edificio respetando los límites impuestos por los factores presupuestarios y la normativa sobre construcción."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000722/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Capacidad de comprender la profesión de arquitecto y su función en la sociedad, en particular elaborando proyectos que tengan en cuenta los factores sociales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000722/2025-26/CT4> a ns1:Competency ;
    ns1:competencyCode "CT4" ;
    ns1:competencyDescription "Capacidad para trabajar de forma efectiva como individuo, organizando y planificando su propio trabajo, de forma independiente o como miembro de un equipo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000722/2025-26/CT5> a ns1:Competency ;
    ns1:competencyCode "CT5" ;
    ns1:competencyDescription "Capacidad para gestionar la información, identificando las fuentes necesarias, los principales tipos de documentos técnicos y científicos, de una manera adecuada y eficiente"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000722/2025-26/RA84> a ns1:LearningResult ;
    ns1:learningResultCode "RA84" ;
    ns1:learningResultDescription "Comprensión general sistematizada según criterios historiográficos y críticos de los sectores más relevantes del panorama actual de la arquitectura internacional"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000722/2025-26/RA85> a ns1:LearningResult ;
    ns1:learningResultCode "RA85" ;
    ns1:learningResultDescription "Conocimiento detallado de obras, autores, textos y corrientes integrantes del panorama arquitectónico de los años recientes, así como de las bibliografías pertinentes para su estudio."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000722/2025-26/RA86> a ns1:LearningResult ;
    ns1:learningResultCode "RA86" ;
    ns1:learningResultDescription "Capacidad para el entendimiento de los diferentes desarrollos teóricos y de las elaboraciones prácticas en arquitectura que han conducido al panorama actual, y que constituyen su genealogía."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000722/2025-26/RA87> a ns1:LearningResult ;
    ns1:learningResultCode "RA87" ;
    ns1:learningResultDescription "Adquisición de conocimientos y capacidades para el entendimiento profundo de problemas y soluciones presentes en las propuestas más recientes de la arquitectura."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000722/2025-26/RA88> a ns1:LearningResult ;
    ns1:learningResultCode "RA88" ;
    ns1:learningResultDescription "Capacidad para realizar estudios y análisis en profundidad de las diferentes aportaciones aparecidas en el panorama global de la arquitectura."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000722/2025-26/didactic_resource/1> a ns1:DidacticResource ;
