<https://guia-kg.skai.etsisi.upm.es/resource/133000052> a ns1:Course ;
    ns1:courseType "Optativa"@es ;
    ns1:courseYear 1 ;
    ns1:semester "Segundo semestre"@es ;
    schema:courseCode 133000052 ;
    schema:hasCourseInstance <https://guia-kg.skai.etsisi.upm.es/resource/133000052/2025-26> ;
    schema:name "Applied Gis For Aquatic Ecosystems Management"@en,
        "Sig Aplicado a la Gestion de Ecosistemas Acuaticos"@es ;
    schema:numberOfCredits 3.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/133000052/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/133000052/2025-26/CB10>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000052/2025-26/CB6>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000052/2025-26/CE14>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000052/2025-26/CT7> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/133000052/2025-26/didactic_resource/1> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/133000052/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/133000052/2025-26/RA50>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000052/2025-26/RA61>,
        <https://guia-kg.skai.etsisi.upm.es/resource/133000052/2025-26/RA78> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/133000052/2025-26/syllabus> ;
    ns1:inpersonHours "36 horas (46.2%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation """Los contenidos de esta guía están sujetos a una posible modificación durante la realización del curso por causas ajenas a la planificación docente, bien sea por causas establecidas por las autoridades competentes o situaciones que impidan el desarrollo de la docencia tal como esta fijada en esta guía.
En esta asignatura se trabajan parcialmente siempre a través de los contenidos y prácticas los siguientes ODS:
ODS8.Promover el crecimiento económico sostenido, inclusivo y sostenible, el empleo pleno y productivo y el trabajo decente para todos.
ODS13.Adoptar medidas urgentes para combatir el cambio climático y sus efectos.
ODS15.Proteger, restablecer y promover el uso sostenible de los ecosistemas terrestres, gestionar los bosques de forma sostenible, luchar contra la desertificación, detener e invertir la degradación de las tierras y poner freno a la pérdida de la diversidad biológica.

LAS COMPETENCIAS Y LOS RESULTADOS DE APRENDIZAJE DE ESTA ASIGNATURA SON CONFORMES CON LA MEMORIA VERIFICA DEL TÍTULO"""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "40 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/133000052/2025-26/eventSchedule> ;
    schema:description """Adquisición, análisis y gestión de datos espaciales utilizando técnicas emergentes de captura de información.
Modelización de datos SIG, tanto vectorial como ráster.
Técnicas de interpolación y presentación cartográfica de los resultados.
Aplicación al análisis espacial de fenómenos relacionados con la gestión del medio natural.."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/mariajesus.garcia.garcia%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/carolina.echavarria%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/concepcion.gonzalez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/esperanza.ayuga%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/luis.iglesias%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/mariajesus.garcia.garcia%40upm.es> ;
    schema:name "Sig Aplicado a la Gestion de Ecosistemas Acuaticos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000052/2025-26/CB10> a ns1:Competency ;
    ns1:competencyCode "CB10" ;
    ns1:competencyDescription "Que los estudiantes posean las habilidades de aprendizaje que les permitan continuar estudiando de un modo que habrá de ser en gran medida autodirigido o autónomo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000052/2025-26/CB6> a ns1:Competency ;
    ns1:competencyCode "CB6" ;
    ns1:competencyDescription "Poseer y comprender conocimientos que aporten una base u oportunidad de ser originales en el desarrollo y/o aplicación de ideas, a menudo en un contexto de investigación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000052/2025-26/CE14> a ns1:Competency ;
    ns1:competencyCode "CE14" ;
    ns1:competencyDescription "Aplicar e integrar conocimientos innovadores de ingeniería y gestión aplicados al uso sostenible de masas de agua y a la planificación de recursos hídricos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000052/2025-26/CT7> a ns1:Competency ;
    ns1:competencyCode "CT7" ;
    ns1:competencyDescription "Utilizar la lengua inglesa para la comunicación oral y escrita a nivel avanzado en entornos académicos y profesionales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000052/2025-26/RA50> a ns1:LearningResult ;
    ns1:learningResultCode "RA50" ;
    ns1:learningResultDescription "Complementar los conocimientos, destrezas y habilidades en ámbitos eminentemente prácticos vinculados con el uso y gestión de los ecosistemas acuáticos y los biomas a ellos vinculados"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000052/2025-26/RA61> a ns1:LearningResult ;
    ns1:learningResultCode "RA61" ;
    ns1:learningResultDescription "Exponer y defender públicamente el trabajo realizado, apoyándose en las nuevas tecnologías disponibles para la presentación de ideas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000052/2025-26/RA78> a ns1:LearningResult ;
    ns1:learningResultCode "RA78" ;
    ns1:learningResultDescription "Ser capaz de realizar análisis geográficos aplicados a la problemática de las aguas en el medio natural"@es .

