    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/615001002/2025-26/eventSchedule> ;
    schema:description """En esta asignatura se estudia, fundamentalmente, el cálculo diferencial e integral de funciones de una variable real, así como las sucesiones y series de números reales.
Se hace especial énfasis en la formalización y lenguaje matemático, por su componente formativo, así como en las estrategias para aplicar los conceptos adquiridos y resolver problemas."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/rafael.minano%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/rafael.minano%40upm.es> ;
    schema:name "Cálculo I"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615001002/2025-26/CE01> a ns1:Competency ;
    ns1:competencyCode "CE01" ;
    ns1:competencyDescription "Capacidad para utilizar con destreza los conceptos y métodos matemáticos que subyacen a los problemas de la ciencia de datos y la inteligencia artificial para su modelización y resolución."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615001002/2025-26/RA10> a ns1:LearningResult ;
    ns1:learningResultCode "RA10" ;
    ns1:learningResultDescription "8. Modelizar matemáticamente problemas reales y conocer técnicas para resolverlos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615001002/2025-26/RA30> a ns1:LearningResult ;
    ns1:learningResultCode "RA30" ;
    ns1:learningResultDescription "Conocer y manejar con soltura los números reales y complejos, hallar límites de sucesiones y estudiar series numéricas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615001002/2025-26/RA31> a ns1:LearningResult ;
    ns1:learningResultCode "RA31" ;
    ns1:learningResultDescription "Conocer las funciones elementales y sus propiedades, calcular límites de funciones y estudiar su continuidad"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615001002/2025-26/RA32> a ns1:LearningResult ;
    ns1:learningResultCode "RA32" ;
    ns1:learningResultDescription "Calcular derivadas e integrales, y usarlas para el estudio de propiedades locales de funciones y problemas aplicados"@es .

