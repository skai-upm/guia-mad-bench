<https://guia-kg.skai.etsisi.upm.es/resource/23000146/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/23000146/2025-26/CE31>,
        <https://guia-kg.skai.etsisi.upm.es/resource/23000146/2025-26/CE32> ;
