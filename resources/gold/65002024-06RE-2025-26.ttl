    ns1:learningResultCode "RA147" ;
    ns1:learningResultDescription "Utilizar los principios de la ingeniería nuclear y la protección radiológica."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65002024/2025-26/RA148> a ns1:LearningResult ;
    ns1:learningResultCode "RA148" ;
    ns1:learningResultDescription "Analizar el comportamiento de la población neutrónica en un reactor nuclear."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65002024/2025-26/RA149> a ns1:LearningResult ;
    ns1:learningResultCode "RA149" ;
    ns1:learningResultDescription "Diferenciar las diferentes tecnologías de generación térmica nuclear."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65002024/2025-26/RA150> a ns1:LearningResult ;
    ns1:learningResultCode "RA150" ;
    ns1:learningResultDescription "Analizar el impacto de la gestión del combustible nuclear en los parámetros de seguridad de la planta."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65002024/2025-26/RA151> a ns1:LearningResult ;
    ns1:learningResultCode "RA151" ;
    ns1:learningResultDescription "Comprender las actividades relacionadas con la primera y segunda parte del ciclo del combustible nuclear."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/65002024/2025-26/RA152> a ns1:LearningResult ;
    ns1:learningResultCode "RA152" ;
    ns1:learningResultDescription "Analizar las posibilidades de tratamiento y gestión de los residuos radiactivos de baja, media y alta actividad."@es .

