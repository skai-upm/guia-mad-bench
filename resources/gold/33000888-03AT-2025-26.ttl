    schema:name "Materials For a Sustainable Construction"@en,
        "Materiales para una Construcción Sotenible"@es ;
    schema:numberOfCredits 3.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/33000888/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/33000888/2025-26/CB08>,
        <https://guia-kg.skai.etsisi.upm.es/resource/33000888/2025-26/CB10>,
        <https://guia-kg.skai.etsisi.upm.es/resource/33000888/2025-26/CE04> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/33000888/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/33000888/2025-26/didactic_resource/2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/33000888/2025-26/didactic_resource/3> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/33000888/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/33000888/2025-26/RA1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/33000888/2025-26/RA8> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/33000888/2025-26/syllabus> ;
    ns1:inpersonHours "44 horas (54.3%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation "La asignatura se relaciona con el Objetivo de Desarrollo Sostenible (ODS) 11. Ciudades y comunidades sostenibles y con el Objetivo Estratégico de la Agenda Urbana (OE) 3. Prevenir y reducir los efectos del cambio climático. Resiliencia."@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "44 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/33000888/2025-26/eventSchedule> ;
    schema:description """La asignatura tiene como objetivo que el alumno entienda la construcción como soporte material del proyecto. Que integre los materiales al proyecto arquitectónico a lo largo de todas sus fases, durante la concepción como elemento íntimamente ligado a la idea, forma y textura, y en el detalle constructivo como elemento capaz de materializar las intenciones y resolver los problemas técnicos. Se estudian tanto nuevos materiales como formas novedosas de utilizar materiales más tradicionales, es decir las diferentes vías de cómo el material puede aportar novedad constructiva al proyecto arquitectónico.
Durante la asignatura se tratan las propiedades de los materiales de construcción y la comprensión de los principios básicos utilizados en la selección adecuada para cumplir los requerimiento del proyecto en función de su rendimiento inherente, incluido el impacto ambiental y la reutilización.
Esta asignatura estudia los materiales de construcción como el medio con el que se construye de forma novedosa, de cada categoría se estudia el material (obtención y procesado, propiedades), su tecnología constructiva asociada (métodos de construcción del material) y el modo en la que puede introducir formas o usos novedosos en los edificios (ejemplos de edificios singulares con ese material)."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/javier.pinilla%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/aj.gonzalez.cruz%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/esther.moreno%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/javier.pinilla%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/joseramon.aira%40upm.es> ;
    schema:name "Materiales para una Construcción Sotenible"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000888/2025-26/CB08> a ns1:Competency ;
    ns1:competencyCode "CB08" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de integrar conocimientos y enfrentarse a la complejidad de formular juicios a partir de una información que, siendo incompleta o limitada, incluya reflexiones sobre las responsabilidades sociales y éticas vinculadas a la aplicación de sus conocimientos y juicios"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000888/2025-26/CB10> a ns1:Competency ;
    ns1:competencyCode "CB10" ;
    ns1:competencyDescription "Que los estudiantes posean las habilidades de aprendizaje que les permitan continuar estudiando de un modo que habrá de ser en gran medida autodirigido o autónomo."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000888/2025-26/CE04> a ns1:Competency ;
    ns1:competencyCode "CE04" ;
    ns1:competencyDescription "Dominio de conocimiento sobre técnicas innovadoras y sostenibles en edificación. Análisis de riesgos en sistemas innovadores de construcción. Arquitectura de fábrica, diseñar con nuevas técnicas. Investigaciones en la optimización e industrialización de viviendas de los sistemas constructivos. Influencia de la aplicación de nuevos materiales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000888/2025-26/RA1> a ns1:LearningResult ;
    ns1:learningResultCode "RA1" ;
    ns1:learningResultDescription "Los alumnos aprenderán a realizar la captura, almacenamiento, tratamiento y análisis de información requerida para los proyectos de la investigación en materiales de construcción, sistemas constructivos,"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000888/2025-26/RA8> a ns1:LearningResult ;
    ns1:learningResultCode "RA8" ;
    ns1:learningResultDescription "Análisis comparativo"@es .

