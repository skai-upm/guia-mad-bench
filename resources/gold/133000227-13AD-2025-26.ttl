    ns1:competencyCode "CE 2.5" ;
    ns1:competencyDescription "Capacidad para el control de la contaminación del Medio Natural debido a la actividad industrial y la gestión de residuos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/133000227/2025-26/CE%206.2> a ns1:Competency ;
