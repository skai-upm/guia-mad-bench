        <https://guia-kg.skai.etsisi.upm.es/resource/615001034/2025-26/didactic_resource/3>,
        <https://guia-kg.skai.etsisi.upm.es/resource/615001034/2025-26/didactic_resource/4>,
        <https://guia-kg.skai.etsisi.upm.es/resource/615001034/2025-26/didactic_resource/5>,
        <https://guia-kg.skai.etsisi.upm.es/resource/615001034/2025-26/didactic_resource/6>,
        <https://guia-kg.skai.etsisi.upm.es/resource/615001034/2025-26/didactic_resource/7> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/615001034/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/615001034/2025-26/RA168> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/615001034/2025-26/syllabus> ;
    ns1:inpersonHours "30 horas (38.5%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation """La asignatura se relaciona con el ODS9 y el ODS11.
La asignatura se relaciona con el ODS9 (Industria, Innovación e Infraestructuras). Los sistemas robóticos han estado siempre presentes en gran parte de la industria moderna y en la actualidad son fundamentales en muchas de las áreas donde la innovación es un elemento primordial y se establecen como básicos en muchas de las infraestructuras de futuro."""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "32 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/615001034/2025-26/eventSchedule> ;
    schema:description "Se estudian los fundamentos de la Robótica, así como su relación con la Inteligencia Artificial. Se estudian los fundamentos teóricos de los manipuladores y su aplicación al diseño y modelado de robots industriales. Se revisan diferentes arquitecturas de diseño de software para desarrollar sistemas de control de robots móviles. Finalmente, se analizan los sistemas de percepción del entorno de navegación del robot."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/joseeugenio.naranjo%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/alfredo.valle%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/joseeugenio.naranjo%40upm.es> ;
    schema:name "Robótica"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615001034/2025-26/CE16> a ns1:Competency ;
    ns1:competencyCode "CE16" ;
    ns1:competencyDescription "Capacidad para describir las técnicas de percepción y robótica cognitiva y utilizarlas para desarrollar sistemas que puedan percibir su entorno y desempeñar tareas de manipulación, navegación y planificación de su comportamiento, con cierto grado de autonomía."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615001034/2025-26/CG01> a ns1:Competency ;
    ns1:competencyCode "CG01" ;
    ns1:competencyDescription "Capacidad de trabajo en equipo, en entornos interdisciplinares y complejos, negociando y resolviendo conflictos, diseñando soluciones eficientes, fiables, robustas y responsables."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/615001034/2025-26/RA168> a ns1:LearningResult ;
    ns1:learningResultCode "RA168" ;
    ns1:learningResultDescription "Ser capaces de construir un sistema de navegación para un robot móvil"@es .

