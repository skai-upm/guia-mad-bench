<https://guia-kg.skai.etsisi.upm.es/resource/615001034/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/615001034/2025-26/CE16>,
        <https://guia-kg.skai.etsisi.upm.es/resource/615001034/2025-26/CG01> ;
