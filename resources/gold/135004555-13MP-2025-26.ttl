    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Introducción a la genética de la conservación."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004555/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Importancia y objetivos de la disciplina. Sin subniveles"@es .

