    ns1:itemIndex 10 ;
    ns1:syllabusDescription "3.1. Análisis de ADN y marcadores moleculares. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004555/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "3.2. Organización jerárquica de la diversidad. Estudios de estructura poblacional. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004555/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "4. Uso de información genética para la toma de decisiones."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004555/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "4.1. Manejo genético de poblaciones en peligro. Diseño de reservas y corredores ecológicos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004555/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "4.2. Programas de cría y ensayos genéticos. Huertos semilleros. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004555/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "4.3. Bancos de germoplasma y criopreservación. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004555/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "5. Ética y política en conservación genética. Tendencias y avances."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004555/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "5.1. Consideraciones éticas e impacto ecológico de la manipulación genética. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004555/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "5.2. Legislación y políticas internacionales. Participación comunitaria y educación ambiental. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004555/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "5.3. Conservación genética en la era del cambio climático. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004555/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. Impacto de la pérdida de diversidad genética en la adaptabilidad y supervivencia de las poblaciones. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004555/2025-26/syllabus/20> a ns1:SyllabusItem ;
    ns1:itemIndex 20 ;
    ns1:syllabusDescription "6. Casos de estudio y aplicaciones prácticas."@es .

