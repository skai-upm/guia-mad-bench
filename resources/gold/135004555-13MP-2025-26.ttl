    ns1:itemIndex 21 ;
    ns1:syllabusDescription "6.1. Evaluación crítica de programas de conservación de especies de interés. Éxitos y desafíos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004555/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "2. Fundamentos de genética. Diversidad genética de las poblaciones."@es .

