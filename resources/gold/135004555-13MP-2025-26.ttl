    ns1:itemIndex 6 ;
    ns1:syllabusDescription "2.3. Variación genética y su medición. Mutaciones. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/135004555/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "2.4. Estructura poblacional. Flujo genético y deriva genética. Sin subniveles"@es .

