    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/595000021/2025-26/eventSchedule> ;
    schema:description "La asignatura esta basada en un microprocesador de 32 Bits (ARM Cortex-M). Está enfocada al diseño de aplicaciones con microprocesador y con un carácter eminentemente práctico, donde el alumno desarrolla durante el curso el diseño de un sistema basado en microprocesador. Se utiliza este diseño para ir introduciendo los diferentes conceptos teóricos necesarios para el desarrollo de este tipo de aplicaciones."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/miguel.chavarrias%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/fernando.pescador%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/g.azuara%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/mcesar.rlacruz%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/miguel.chavarrias%40upm.es> ;
    schema:name "Microprocesadores"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000021/2025-26/CE%20B2> a ns1:Competency ;
    ns1:competencyCode "CE B2" ;
    ns1:competencyDescription "Conocimientos básicos sobre el uso y programación de los ordenadores, sistemas operativos, bases de datos y programas informáticos con aplicación en ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000021/2025-26/CE%20TEL10> a ns1:Competency ;
    ns1:competencyCode "CE TEL10" ;
    ns1:competencyDescription "Capacidad de análisis y diseño de circuitos combinacionales y secuenciales, síncronos y asíncronos, y de utilización de microprocesadores y circuitos integrados."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000021/2025-26/CG%2002> a ns1:Competency ;
    ns1:competencyCode "CG 02" ;
    ns1:competencyDescription "Capacidad de búsqueda y selección de información, de razonamiento crítico y de elaboración y defensa de argumentos dentro del área."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000021/2025-26/CG%2003> a ns1:Competency ;
    ns1:competencyCode "CG 03" ;
    ns1:competencyDescription "Capacidad para expresarse correctamente de forma oral y escrita y transmitir información mediante documentos y exposiciones en público."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000021/2025-26/CG%2004> a ns1:Competency ;
    ns1:competencyCode "CG 04" ;
    ns1:competencyDescription "Capacidad de abstracción, de análisis y de síntesis y de resolución de problemas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000021/2025-26/CG%2011> a ns1:Competency ;
    ns1:competencyCode "CG 11" ;
    ns1:competencyDescription "Habilidades para la utilización de las Tecnologías de la Información y las Comunicaciones."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000021/2025-26/RA73> a ns1:LearningResult ;
    ns1:learningResultCode "RA73" ;
    ns1:learningResultDescription "Comprender la funcionalidad e interfaz de los subsistemas combinacionales, secuenciales y memorias"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000021/2025-26/RA78> a ns1:LearningResult ;
    ns1:learningResultCode "RA78" ;
    ns1:learningResultDescription "Comprender los principios de funcionamiento de un microprocesador, los elementos básicos que conforman su arquitectura, y los circuitos digitales que integran un sistema basado en microprocesador."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000021/2025-26/RA79> a ns1:LearningResult ;
    ns1:learningResultCode "RA79" ;
    ns1:learningResultDescription "Conocer la arquitectura, características y funcionamiento de un microprocesador comercial"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000021/2025-26/RA80> a ns1:LearningResult ;
    ns1:learningResultCode "RA80" ;
    ns1:learningResultDescription "Realizar programas sencillos en lenguaje ensamblador y en lenguaje de alto nivel para un microprocesador comercial."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000021/2025-26/RA81> a ns1:LearningResult ;
    ns1:learningResultCode "RA81" ;
    ns1:learningResultDescription "Diseñar la lógica necesaria para conectar la memoria y los periféricos de entrada/salida en un sistema digital basado en microprocesador, respetando la temporización establecida en sus ciclos de máquina."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000021/2025-26/RA82> a ns1:LearningResult ;
    ns1:learningResultCode "RA82" ;
    ns1:learningResultDescription "Comprender las distintas técnicas de entrada/salida para el intercambio de datos entre un sistema basado en microprocesador y otros sistemas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000021/2025-26/RA83> a ns1:LearningResult ;
    ns1:learningResultCode "RA83" ;
    ns1:learningResultDescription "Conocer los principios de funcionamiento de algunos periféricos básicos. Puerto serie, puerto paralelo, temporizadores, etc."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000021/2025-26/RA84> a ns1:LearningResult ;
    ns1:learningResultCode "RA84" ;
    ns1:learningResultDescription "Emplear los periféricos de un microprocesador para desarrollar aplicaciones que den solución a problemas de mediana complejidad."@es .

