        <https://guia-kg.skai.etsisi.upm.es/resource/93000841/2025-26/didactic_resource/7> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/93000841/2025-26/evaluation> ;
