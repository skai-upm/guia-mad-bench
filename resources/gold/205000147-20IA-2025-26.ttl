    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/205000147/2025-26/eventSchedule> ;
    schema:description "Esta asignatura reúne los conocimientos y aplicaciones fundamentales de las áreas de Geología, Edafología y Climatología, relacionados con la producción de alimentos."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/ab.mgonzalez%40upm.es> ;
