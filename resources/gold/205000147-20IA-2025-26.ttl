<https://guia-kg.skai.etsisi.upm.es/resource/205000147/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "2.1. Morfología y descripción de suelos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000147/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "2.1.1. Introducción: Concepto de edafología e importancia del suelo en el ecosistema y en la producción agraria"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000147/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "2.1.1.1. El perfil del suelo Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000147/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "2.1.2. Horizontes genéticos y de diagnóstico. Nomenclatura. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000147/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "2.1.3. Descripción de perfiles de suelos en campo. Muestreo de suelos. Estudio de suelos en laboratorio. Propiedades observadas e inferidas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000147/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "2.1.4. Práctica de Campo: descripción morfológica y muestreo de suelos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000147/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.1.1. Concepto e mineralogia. Clasificaciónde los minerales. Estructura de los silicatos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000147/2025-26/syllabus/20> a ns1:SyllabusItem ;
    ns1:itemIndex 20 ;
    ns1:syllabusDescription "2.2. Componentes del suelo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000147/2025-26/syllabus/21> a ns1:SyllabusItem ;
    ns1:itemIndex 21 ;
    ns1:syllabusDescription "2.2.1. Fracciones del suelo: sólida, líquida y gaseosa Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000147/2025-26/syllabus/22> a ns1:SyllabusItem ;
    ns1:itemIndex 22 ;
    ns1:syllabusDescription "2.2.2. Componente mineral y orgánico. Complejos órgano-minerales. Balance de materia orgánica. Relación C/N Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000147/2025-26/syllabus/23> a ns1:SyllabusItem ;
    ns1:itemIndex 23 ;
    ns1:syllabusDescription "2.2.3. Componente biológico. Clasificación y funciones de los organismos del suelo Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000147/2025-26/syllabus/24> a ns1:SyllabusItem ;
    ns1:itemIndex 24 ;
    ns1:syllabusDescription "2.3. Propiedades físicas del suelo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000147/2025-26/syllabus/25> a ns1:SyllabusItem ;
    ns1:itemIndex 25 ;
    ns1:syllabusDescription "2.3.1. Textura del suelo: fracciones granulométricas, clases texturales y su relación con otras propiedades del suelo Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000147/2025-26/syllabus/26> a ns1:SyllabusItem ;
    ns1:itemIndex 26 ;
    ns1:syllabusDescription "2.3.2. Estructura del suelo: concepto y formación de agregados. Clasificación morfológica de la estructura. Estabilidad estructural Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000147/2025-26/syllabus/27> a ns1:SyllabusItem ;
    ns1:itemIndex 27 ;
    ns1:syllabusDescription "2.3.3. Porosidad del suelo, densidad real y aparente. Determinación de la densidad. Compactación Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000147/2025-26/syllabus/28> a ns1:SyllabusItem ;
    ns1:itemIndex 28 ;
    ns1:syllabusDescription "2.3.4. El agua del suelo. Contenido: humedad gravimétrica y volumétrica. Potencial del agua en el suelo. Capacidad de campo y punto de marchitez permanente. Capacidad de retención de agua disponible (CRAD) y agua disponible (AD). Infiltración y permeabilidad. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000147/2025-26/syllabus/29> a ns1:SyllabusItem ;
    ns1:itemIndex 29 ;
    ns1:syllabusDescription "2.3.5. Color y temperatura del suelo. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000147/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "1.1.2. Nesosilicatos, sorosilicatos, ciclosilicatos e inosilicatos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000147/2025-26/syllabus/30> a ns1:SyllabusItem ;
    ns1:itemIndex 30 ;
    ns1:syllabusDescription "2.3.6. Práctica 1.- Edafología (Laboratorio): Determinación de elementos gruesos. Determinación de la Humedad de la. muestra seca al aire. Color del suelo. Textura del suelo al tacto. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000147/2025-26/syllabus/31> a ns1:SyllabusItem ;
    ns1:itemIndex 31 ;
    ns1:syllabusDescription "2.3.7. Práctica 2.- Edafología (Laboratorio): Propiedades físicas I.- Granulometría del suelo. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000147/2025-26/syllabus/32> a ns1:SyllabusItem ;
    ns1:itemIndex 32 ;
    ns1:syllabusDescription "2.3.8. Práctica 3.- Edafología (Laboratorio): Propiedades físicas II.- Densidad aparente en muestra disturbada (tierra fina). Porosidad. Capacidad de campo. Cálculo del CRAD. Propiedades químicas I.- (1) pH y CE en agua (2) pH en KCl. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000147/2025-26/syllabus/33> a ns1:SyllabusItem ;
    ns1:itemIndex 33 ;
    ns1:syllabusDescription "2.4. Propiedades químicas del suelo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000147/2025-26/syllabus/34> a ns1:SyllabusItem ;
    ns1:itemIndex 34 ;
    ns1:syllabusDescription "2.4.1. La fracción coloidal del suelo. Capacidad de intercambio catiónico. Carga permanente y carga variable. Reacciones de superficie: doble capa difusa. Floculación y dispersión de arcillas. Saturación por bases. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000147/2025-26/syllabus/35> a ns1:SyllabusItem ;
    ns1:itemIndex 35 ;
    ns1:syllabusDescription "2.4.2. Reacción del suelo: pH. Influencia sobre la disponibilidad de nutrientes. Poder tampón del suelo. Tolerancia de los cultivos al pH. Encalado de suelos Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000147/2025-26/syllabus/36> a ns1:SyllabusItem ;
    ns1:itemIndex 36 ;
    ns1:syllabusDescription "2.4.3. El aire en el suelo. Química de los procesos redox en el suelo. Suelos hidromorfos Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000147/2025-26/syllabus/37> a ns1:SyllabusItem ;
    ns1:itemIndex 37 ;
    ns1:syllabusDescription "2.4.4. Concentración de sales y conductividad eléctrica. Salinidad y sodicidad. Suelos salinos y sódicos. Recuperación de suelos salinos y sódicos. Tolerancia de los cultivos a la salinidad. Calidad del agua del riego. Balance de sales Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000147/2025-26/syllabus/38> a ns1:SyllabusItem ;
    ns1:itemIndex 38 ;
    ns1:syllabusDescription "2.4.5. Práctica 4.- Edafología (Laboratorio): Propiedades químicas II.- (1) Materia orgánica (%) (2) Carbonato cálcico (CaCO3 %). Propiedades físico-químicas: (1) Pasta saturada: humedad de saturación (2) Extracto de saturación. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000147/2025-26/syllabus/39> a ns1:SyllabusItem ;
    ns1:itemIndex 39 ;
    ns1:syllabusDescription "2.4.6. Práctica 5.- Edafología (Laboratorio): (1) Repetición y/o verificación de análisis. (2) Consultas sobre la elaboración del trabajo de Edafología. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000147/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "1.1.3. Filosilicatos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000147/2025-26/syllabus/40> a ns1:SyllabusItem ;
    ns1:itemIndex 40 ;
    ns1:syllabusDescription "2.5. Genesis y Clasificación de suelos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000147/2025-26/syllabus/41> a ns1:SyllabusItem ;
    ns1:itemIndex 41 ;
    ns1:syllabusDescription "2.5.1. Bases para la clasificación de suelos: Soil Taxonomy y WRB. Órdenes y subórdenes de la Soil Taxonomy más frecuentes en España Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000147/2025-26/syllabus/42> a ns1:SyllabusItem ;
    ns1:itemIndex 42 ;
    ns1:syllabusDescription "3. UT.- CLIMATOLOGÍA"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000147/2025-26/syllabus/43> a ns1:SyllabusItem ;
    ns1:itemIndex 43 ;
    ns1:syllabusDescription "3.1. Nociones básicas de Meteorología y Climatología Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000147/2025-26/syllabus/44> a ns1:SyllabusItem ;
    ns1:itemIndex 44 ;
    ns1:syllabusDescription "3.2. Elementos climáticos térmicos. Radiación. Calor y temperatura"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000147/2025-26/syllabus/45> a ns1:SyllabusItem ;
    ns1:itemIndex 45 ;
    ns1:syllabusDescription "3.2.1. Radiación: estimación de la radiación a nivel de la superficie del suelo Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000147/2025-26/syllabus/46> a ns1:SyllabusItem ;
    ns1:itemIndex 46 ;
    ns1:syllabusDescription "3.2.2. Calor (específico y latente) y Temperatura. Datos de temperatura (medias, máximas, mínimas y su nomenclatura.). Oscilación diaria y anual de temperatura. Factores reguladores de temperatura. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000147/2025-26/syllabus/47> a ns1:SyllabusItem ;
    ns1:itemIndex 47 ;
    ns1:syllabusDescription "3.2.3. Efecto de continentalidad: aplicación del índice de Gorczynski y Kerner. Otros elementos térmicos (frío invernal) horas de frío. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000147/2025-26/syllabus/48> a ns1:SyllabusItem ;
    ns1:itemIndex 48 ;
    ns1:syllabusDescription "3.2.4. Origen y tipos de heladas. Métodos de estimación: Papadakis y Emberger Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000147/2025-26/syllabus/49> a ns1:SyllabusItem ;
    ns1:itemIndex 49 ;
    ns1:syllabusDescription "3.3. Elementos climáticos hídricos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000147/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "1.1.4. Tectosilicatos. Minerales carbonatados y minerales evaporíticos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000147/2025-26/syllabus/50> a ns1:SyllabusItem ;
    ns1:itemIndex 50 ;
    ns1:syllabusDescription "3.3.1. Indices de humedad. Aire húmedo y seco. Humedad relativa. Punto (temperatura) de rocío Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000147/2025-26/syllabus/51> a ns1:SyllabusItem ;
    ns1:itemIndex 51 ;
    ns1:syllabusDescription "3.3.2. Precipitaciones: Cantidad. Intensidad. Variabilidad Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/205000147/2025-26/syllabus/52> a ns1:SyllabusItem ;
    ns1:itemIndex 52 ;
    ns1:syllabusDescription "3.4. Evaporación y Evapotranspiración"@es .

