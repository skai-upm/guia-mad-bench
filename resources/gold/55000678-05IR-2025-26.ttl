    schema:name "Information Systems"@en,
        "Sistemas de Información"@es ;
    schema:numberOfCredits 3.0 .

<https://guia-kg.skai.etsisi.upm.es/resource/55000678/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/55000678/2025-26/CE34> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/55000678/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55000678/2025-26/didactic_resource/2> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/55000678/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/55000678/2025-26/RA188>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55000678/2025-26/RA291> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/55000678/2025-26/syllabus> ;
    ns1:inpersonHours "30 horas (38.5%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation "La asignatura se relaciona con el ODS8 \"Promover el crecimiento económico inclusivo y sostenible, el empleo y el trabajo decente para todos\" y ODS9 \"Construir infraestructuras resilientes, promover la industrialización sostenible y fomentar la innovación\"."@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "32 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/55000678/2025-26/eventSchedule> ;
    schema:description "Esta asignatura es una introducción a los sistemas de información y al papel cada vez más relevante que éstos tienen en los procesos de negocio de las empresas."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/teresa.sanchez%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/javier.romero%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/teresa.sanchez%40upm.es> ;
    schema:name "Sistemas de Información"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000678/2025-26/CE34> a ns1:Competency ;
    ns1:competencyCode "CE34" ;
    ns1:competencyDescription "Conocimiento de los sistemas de información de las empresas y la integración de los mismos en los procesos de gestión y toma de decisiones"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000678/2025-26/RA188> a ns1:LearningResult ;
    ns1:learningResultCode "RA188" ;
    ns1:learningResultDescription "Comprender cómo los sistemas de información soportan en la actualidad los procesos de las empresas y organizaciones, ayudando en la toma de decisiones y permitiendo nuevos modelos de negocio a través de Internet. Entender la relación entre los sistemas de información y la agilidad y competitividad empresarial. Conocer las tecnologías en base a las cuales se construyen los sistemas de información."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000678/2025-26/RA291> a ns1:LearningResult ;
    ns1:learningResultCode "RA291" ;
    ns1:learningResultDescription "Entender cómo los sistemas de información aydan a las empresas a llevar a cabo sus procesos de negocio más eficientemente"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000678/2025-26/didactic_resource/1> a ns1:DidacticResource ;
    ns1:bibliographyDescription "https://www.pearson.com/us/higher-education/program/Laudon-Management-Information-Systems-Managing-the-Digital-Firm-15th-Edition/PGM2432008.html"@es ;
    ns1:bibliographyTitle "Libro: Management Information Systems de K. Laudon. 15th edition (English)"@es ;
    ns1:bibliographyType "Bibliografía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000678/2025-26/didactic_resource/2> a ns1:DidacticResource ;
    ns1:bibliographyDescription "Se utiliza para poner a disposición del alumnos el material que se va a utilizar clase, blogs de cada una de las partes de la asignatura y la área de entrega de los ejercicios y casos prácticos."@es ;
    ns1:bibliographyTitle "PLATAFORMA MOODLE - Sistemas de información (GIO)"@es ;
    ns1:bibliographyType "Recursos web"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000678/2025-26/evaluation> a ns1:EvaluationSystem ;
    ns1:evaluationDescription """Tipos de evaluación:
A. Evaluación progresiva. El alumno que no supere la evaluación continua pasará al examen final de enero
B. Evaluación por prueba de evaluación global. Presentándose al examen final de enero. El alumno que no superen esta evaluación pasará al examen extraordinario
C. Evaluación de examen extraordinario.
Elección del tipo de evaluación:
Esta asignatura se impartirá por evaluación progresiva de la UPM y excepcionalmente y, por causas muy justificadas, los alumnos podrían optar a presentarse directamente la prueba de evaluación global de enero y en su caso a la extraordinaria.
Se deberá notificar por escrito al coordinador de la asignatura (javier.romero@upm.es).
Evaluación progresiva (EP) (nota mínima 5)
- Participación en clase y presentaciones 60%
- Examen escrito: 40%

Evaluación por prueba de evaluación global:
La calificación será la del examen final de enero (nota mínima 5)

Evaluación por prueba de evaluación global:
La calificación será la del examen final extraordinario (nota mínima 5)

Examen Extraordinario:
- Examen escrito: 100% (nota mínima 5)"""@es ;
    ns1:hasEvaluationTrial <https://guia-kg.skai.etsisi.upm.es/resource/55000678/2025-26/evaluation/trial1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55000678/2025-26/evaluation/trial2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55000678/2025-26/evaluation/trial3>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55000678/2025-26/evaluation/trial4> .

