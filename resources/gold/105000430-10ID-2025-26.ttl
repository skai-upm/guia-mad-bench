<https://guia-kg.skai.etsisi.upm.es/resource/105000430/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "2. Conceptos y el marco analítico en la gestión de riesgo: Identificación de riesgos y planificación con escenarios. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000430/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "3. Los mercados, productos y riesgos financieros (riesgos de tipo de cambio, de tipo de interés y de crédito) y estrategias de cobertura de riesgos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000430/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "4. Los productos derivados y estrategias de cobertura del riesgo. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/105000430/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "5. Aplicación de la gestión de riesgos a casos prácticos en sectores específicos. Marco de planificación y gestión del riesgo. Sin subniveles"@es .

