    schema:name "Redes de Ordenadores"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000129/2025-26/CE%20TEL06> a ns1:Competency ;
    ns1:competencyCode "CE TEL06" ;
    ns1:competencyDescription "Capacidad de concebir, desplegar, organizar y gestionar redes, sistemas, servicios e infraestructuras de telecomunicación en contextos residenciales (hogar, ciudad y comunidades digitales), empresariales o institucionales responsabilizándose de su puesta en marcha y mejora continua, así como conocer su impacto económico y social."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000129/2025-26/CE%20TEL13> a ns1:Competency ;
    ns1:competencyCode "CE TEL13" ;
    ns1:competencyDescription "Conocimiento y utilización de los conceptos de arquitectura de red, protocolos e interfaces de comunicaciones."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000129/2025-26/CE%20TEL14> a ns1:Competency ;
    ns1:competencyCode "CE TEL14" ;
    ns1:competencyDescription "Capacidad de diferenciar los conceptos de redes de acceso y transporte, redes de conmutación de circuitos y de paquetes, redes fijas y móviles, así como los sistemas y aplicaciones de red distribuidos, servicios de voz, datos, audio, video y servicios interactivos y multimedia."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/595000129/2025-26/CE%20TEL15> a ns1:Competency ;
    ns1:competencyCode "CE TEL15" ;
    ns1:competencyDescription "Conocimiento de los métodos de interconexión de redes y encaminamiento, así como los fundamentos de la planificación, dimensionado de redes en función de parámetros de tráfico."@es .

