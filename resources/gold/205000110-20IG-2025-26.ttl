        <https://guia-kg.skai.etsisi.upm.es/resource/205000110/2025-26/CG09>,
        <https://guia-kg.skai.etsisi.upm.es/resource/205000110/2025-26/CG11>,
        <https://guia-kg.skai.etsisi.upm.es/resource/205000110/2025-26/CT04>,
        <https://guia-kg.skai.etsisi.upm.es/resource/205000110/2025-26/CT05> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/205000110/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/205000110/2025-26/didactic_resource/2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/205000110/2025-26/didactic_resource/3>,
