<https://guia-kg.skai.etsisi.upm.es/resource/103000486/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/103000486/2025-26/CE10>,
        <https://guia-kg.skai.etsisi.upm.es/resource/103000486/2025-26/CE9>,
