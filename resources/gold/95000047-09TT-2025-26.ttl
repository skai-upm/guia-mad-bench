    ns1:itemIndex 6 ;
    ns1:syllabusDescription "2.1. Resonadores de microondas. Líneas de transmisión como elementos resonantes; parámetro de pendiente, factor de calidad. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000047/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "2.2. Introducción a los filtros de microondas. Pérdidas de inserción. Respuesta maximalmente plana y equirrizada. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000047/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "2.3. Transformaciones circuitales, paso alto, paso banda, banda eliminada. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000047/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "2.4. Transformación de Richards, síntesis con elementos distribuidos. Identidades de Kuroda. Sin subniveles"@es .

