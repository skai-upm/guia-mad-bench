    ns1:itemIndex 16 ;
    ns1:syllabusDescription "3.3. Diseño de amplificadores de una etapa para máxima ganancia. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000047/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "3.4. Círculos de ganancia constante. Sin subniveles"@es .

