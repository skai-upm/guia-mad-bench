    ns1:itemIndex 3 ;
    ns1:syllabusDescription "1.3. Teoría de grafos de flujo de señal aplicada a circuitos de radiofrecuencia. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000047/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "1.4. Escalado de funciones de red en frecuencia e impedancia. Sin subniveles"@es .

