    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/565000462/2025-26/eventSchedule> ;
    schema:description """En esta asignatura se imparte una visión general del proceso productivo automatizado. Se incluyen los siguientes grandes temas:
Introducción al proceso productivo e instrumentación.
Modelado del control de eventos discretos. Diagrama Grafcet.
El autómata: fundamentos de funcionamiento
El autómata: fundamentos de programación (se toma como referencia la familia de autómatas SIEMENS-S7300)"""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/pablo.sansegundo%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/alberto.brunete%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/carlos.platero%40upm.es>,
