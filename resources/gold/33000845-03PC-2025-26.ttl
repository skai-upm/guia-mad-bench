    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/33000845/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/33000845/2025-26/RA74>,
        <https://guia-kg.skai.etsisi.upm.es/resource/33000845/2025-26/RA75>,
        <https://guia-kg.skai.etsisi.upm.es/resource/33000845/2025-26/RA76>,
        <https://guia-kg.skai.etsisi.upm.es/resource/33000845/2025-26/RA77>,
