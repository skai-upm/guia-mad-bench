        <https://guia-kg.skai.etsisi.upm.es/resource/33000845/2025-26/RA83>,
        <https://guia-kg.skai.etsisi.upm.es/resource/33000845/2025-26/RA84>,
        <https://guia-kg.skai.etsisi.upm.es/resource/33000845/2025-26/RA85> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/33000845/2025-26/syllabus> ;
    ns1:inpersonHours "48 horas (30.8%)"@es ;
    ns1:numberOfCredits 6.0 ;
    ns1:otherInformation "La asignatura se relaciona con el 11º Objetivo de Desarrollo Sostenible de la Agenda 2030 de Naciones Unidas: «redoblar los esfuerzos para proteger y salvaguardar el patrimonio cultural y natural»."@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "51 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/33000845/2025-26/eventSchedule> ;
    schema:description """La asignatura supone una específica mirada al Patrimonio mueble e inmaterial considerando las dimensiones patrimoniales que le son propias (el lugar, el valor de uso, la determinante construcción, la integración de artes y oficios?).
OBJETIVOS
Capacitar al alumnado para la para la comprensión de los distintos valores patrimoniales que pueden incidir en un bien mueble, ya sea artístico, documental o bibliográfico.
Capacidad para aplicar las herramientas de investigación propias de la historia, la arquitectura y la ingeniería, la arqueología, etc. a los bienes muebles.
Comprender la naturaleza especial del Patrimonio inmaterial, así como los problemas de su gestión y de su salvaguarda.
Introducirse en la complejidad del Patrimonio documental y bibliográfico con el fin de poder calibrar lo específico de sus sistemas de gestión."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/nicolas.marine%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/nicolas.marine%40upm.es> ;
    schema:name "Patrimonio Mueble e Inmaterial"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000845/2025-26/CB07> a ns1:Competency ;
    ns1:competencyCode "CB07" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar los conocimientos adquiridos y su capacidad de resolución de problemas en entornos nuevos o poco conocidos dentro de contextos más amplios (o multidisciplinares) relacionados con su área de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000845/2025-26/CB08> a ns1:Competency ;
    ns1:competencyCode "CB08" ;
    ns1:competencyDescription "Que los estudiantes sean capaces de integrar conocimientos y enfrentarse a la complejidad de formular juicios a partir de una información que, siendo incompleta o limitada, incluya reflexiones sobre las responsabilidades sociales y éticas vinculadas a la aplicación de sus conocimientos y juicios"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000845/2025-26/CE02> a ns1:Competency ;
    ns1:competencyCode "CE02" ;
    ns1:competencyDescription "Analizar los problemas sociales derivados de los conflictos entre la conservación y el desarrollo del Patrimonio Cultural"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000845/2025-26/CE17> a ns1:Competency ;
    ns1:competencyCode "CE17" ;
    ns1:competencyDescription "Interpretar la legislación internacional, nacional y autonómica que regula la promoción, salvaguarda y difusión de cada uno de los tipos de Patrimonio Cultural"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000845/2025-26/CG01> a ns1:Competency ;
    ns1:competencyCode "CG01" ;
    ns1:competencyDescription "Identificar los principios básicos del Patrimonio Cultural, de su gestión y de su investigación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000845/2025-26/CT10> a ns1:Competency ;
    ns1:competencyCode "CT10" ;
    ns1:competencyDescription "Desarrollar una capacidad permanente de compromiso ético y de respeto, en lo que se refiere al bienestar de la ciudadanía y al medio ambiente"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000845/2025-26/RA74> a ns1:LearningResult ;
    ns1:learningResultCode "RA74" ;
    ns1:learningResultDescription "Definir y describir los distintos tipos de Patrimonio Cultural."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000845/2025-26/RA75> a ns1:LearningResult ;
    ns1:learningResultCode "RA75" ;
    ns1:learningResultDescription "Experimentar la capacidad para resolver problemas interconectados con las diferentes disciplinas con las que se relacionan los distintos tipos de Patrimonio Cultural (Inmueble, Mueble, Inmaterial, Artístico, Arqueológico, etc.)."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000845/2025-26/RA76> a ns1:LearningResult ;
    ns1:learningResultCode "RA76" ;
    ns1:learningResultDescription "Analizar, de forma autónoma, los conceptos usados en la investigación de la gestión de los distintos tipos de Patrimonio Cultural por las diferentes disciplinas implicadas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000845/2025-26/RA77> a ns1:LearningResult ;
    ns1:learningResultCode "RA77" ;
    ns1:learningResultDescription ""@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000845/2025-26/RA78> a ns1:LearningResult ;
    ns1:learningResultCode "RA78" ;
    ns1:learningResultDescription "Discriminar entre los trabajos científicos más innovadores en los métodos y las técnicas de gestión del Patrimonio Cultural."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000845/2025-26/RA79> a ns1:LearningResult ;
    ns1:learningResultCode "RA79" ;
    ns1:learningResultDescription "Clasificar y comparar las fuentes de información a través de métodos cualitativos que establezcan los problemas del Patrimonio Cultural."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000845/2025-26/RA80> a ns1:LearningResult ;
    ns1:learningResultCode "RA80" ;
    ns1:learningResultDescription "Capacidad para utilizar la información contenida en archivos sobre la historia del Patrimonio Cultural."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000845/2025-26/RA81> a ns1:LearningResult ;
    ns1:learningResultCode "RA81" ;
    ns1:learningResultDescription "Discriminar entre los resultados relacionados con la investigación de los distintos tipos de Patrimonio Cultural"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000845/2025-26/RA82> a ns1:LearningResult ;
    ns1:learningResultCode "RA82" ;
    ns1:learningResultDescription ""@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000845/2025-26/RA83> a ns1:LearningResult ;
    ns1:learningResultCode "RA83" ;
    ns1:learningResultDescription "Identificar el significado de los distintos riesgos que aquejan al Patrimonio Cultural y la repercusión económica que dichos peligros puede acarrear para su salvaguarda."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000845/2025-26/RA84> a ns1:LearningResult ;
    ns1:learningResultCode "RA84" ;
    ns1:learningResultDescription "Apreciar los procesos de deterioro de las dimensiones materiales e inmateriales de los distintos tipos de Patrimonio Cultural."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000845/2025-26/RA85> a ns1:LearningResult ;
    ns1:learningResultCode "RA85" ;
    ns1:learningResultDescription "Aplicar la legislación internacional, nacional y autonómica que regula la promoción, salvaguarda y difusión del Patrimonio Cultural."@es .

