        <https://guia-kg.skai.etsisi.upm.es/resource/33000845/2025-26/syllabus/5> .

<https://guia-kg.skai.etsisi.upm.es/resource/33000845/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. El Patrimonio artístico. Catálogos e inventarios desde el siglo XIX. Una revisión crítica Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000845/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "2. Sistemas de inventariado actuales del Patrimonio artístico. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000845/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "3. El Patrimonio bibliográfico y documental. Control, acceso y modelos de descripción. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000845/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "4. Retos del Patrimonio bibliográfico y documental. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000845/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "5. El concepto de Patrimonio Cultural Inmaterial. Su historia y situación actual. El papel de la Antropología en su definición. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/33000845/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "6. Los mecanismos especiales de Gestión del Patrimonio Cultural Inmaterial. La Convención UNESCO y el Plan Nacional de Salvaguarda. Los retos del futuro en la gestión y protección del P. Cultural Inmaterial. Sin subniveles"@es .

