<https://guia-kg.skai.etsisi.upm.es/resource/113000065/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. La Actividad Física y el Deporte Adaptado (AFDA) como ámbito de conocimiento en las ciencias del deporte"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000065/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Principales líneas de investigación en AFDA Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000065/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "3.2. Deporte inclusivo e investigación: transferencia de los resultados de la investigación Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000065/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "3.3. Desarrollo y preparación de proyectos de investigación aplicada en AFDA y deporte inclusivo Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000065/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "4. Aplicaciones de la AFDA: proyecto de la asignatura"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000065/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "4.1. Concepción y desarrollo de un trabajo de investigación en AFDA Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000065/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "4.2. Presentación y difusión (prospectiva) de un trabajo de investigación en AFDA Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000065/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. El funcionamiento, la discapacidad y la salud: Las clasificaciones OMS como herramienta de investigación en AFDA Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000065/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "1.3. Las fuentes de información cientifica en AFDA. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000065/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "2. El papel de la actividad físico deportiva sobre la salud de personas con discapacidad"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000065/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "2.1. Consecuencias perceptivo motrices según tipo de discapacidad y relación con la investigación en el ámbito Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000065/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "2.2. Aspectos sociodemográficos, saludables, educativos, recreativos y deportivos de la investigación aplicada en AFA Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000065/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "2.3. Necesidades y consideraciones específicas en los diseños de investigación aplicados Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000065/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "3. La Catedra \"Fundación Sanitas\" de Estudios sobre Deporte Inclusivo (CEDI): vivero de proyectos de investigación en AFDA"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/113000065/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "3.1. Deporte inclusivo e investigación: generación de contextos de práctica y su análisis Sin subniveles"@es .

