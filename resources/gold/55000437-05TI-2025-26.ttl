<https://guia-kg.skai.etsisi.upm.es/resource/55000437/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/55000437/2025-26/CG10>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55000437/2025-26/CG3>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55000437/2025-26/CG5>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55000437/2025-26/CG6> ;
    ns1:hasDidacticResource <https://guia-kg.skai.etsisi.upm.es/resource/55000437/2025-26/didactic_resource/1>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55000437/2025-26/didactic_resource/2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55000437/2025-26/didactic_resource/3>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55000437/2025-26/didactic_resource/4> ;
    ns1:hasEvaluation <https://guia-kg.skai.etsisi.upm.es/resource/55000437/2025-26/evaluation> ;
    ns1:hasLearningResult <https://guia-kg.skai.etsisi.upm.es/resource/55000437/2025-26/RA208>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55000437/2025-26/RA209>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55000437/2025-26/RA210>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55000437/2025-26/RA211>,
        <https://guia-kg.skai.etsisi.upm.es/resource/55000437/2025-26/RA212> ;
    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/55000437/2025-26/syllabus> ;
    ns1:inpersonHours "30 horas (38.5%)"@es ;
    ns1:numberOfCredits 3.0 ;
    ns1:otherInformation """La asignatura se relaciona con los siguientes Objetivos de Desarrollo Sostenible (ODS) establecidos por Naciones Unidas: ODS4, ODS5, ODS8, ODS10 y ODS16.
Debido a la incertidumbre generada por la emergencia sanitaria internacional, la Universidad Politécnica de Madrid ha establecido que, si las autoridades decretasen un nuevo encierro durante este semestre, todas las actividades del curso deberían transferirse en las siguientes 72 horas a un formato en línea. Esto incluiría sesiones de tutoría y también podría incluir actividades de evaluación. La plataforma que se utilizaría es Microsoft TEAMS. El temario permanecería igual."""@es ;
    ns1:periodEndingMonth "Enero"@es ;
    ns1:periodStartingMonth "Septiembre"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Septiembre-Enero"@es ;
    ns1:totalHours "32 horas"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/55000437/2025-26/eventSchedule> ;
    schema:description """La asignatura de Español para Extranjeros III tiene como finalidad capacitar al alumnado para usar el idioma de manera suficiente, receptiva y productivamente, tanto en forma hablada como escrita, así como para mediar entre hablantes de distintas lenguas, en situaciones cotidianas y de inmediata necesidad que requieran comprender y producir textos breves, en diversos registros y en lengua estándar, que versen sobre aspectos concretos de temas generales y que contengan expresiones, léxico y estructuras de uso frecuente.
La asignatura de Español para Extranjeros III presenta las características de los niveles de competencia B1, según se define en el Marco Común Europeo de Referencia para las Lenguas."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/isabel.lopez%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/isabel.lopez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/josemaria.gonzalezd%40upm.es> ;
    schema:name "Español para Extranjeros III"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000437/2025-26/CG10> a ns1:Competency ;
    ns1:competencyCode "CG10" ;
    ns1:competencyDescription "Capacidad para generar nuevas ideas (Creatividad)."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000437/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Aplicar los conocimientos adquiridos para identificar, formular y resolver problemas dentro de contextos amplios y multidisciplinarios, siendo capaces de integrar conocimientos, trabajando en equipos multidisciplinares."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000437/2025-26/CG5> a ns1:Competency ;
    ns1:competencyCode "CG5" ;
    ns1:competencyDescription "Saber comunicar los conocimientos y conclusiones, de forma oral, escrita y gráfica, a públicos especializados y no especializados de un modo claro y sin ambigüedades."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/55000437/2025-26/CG6> a ns1:Competency ;
    ns1:competencyCode "CG6" ;
    ns1:competencyDescription "Poseer habilidades de aprendizaje que permitan continuar estudiando a lo largo de la vida para su adecuado desarrollo profesional."@es .

