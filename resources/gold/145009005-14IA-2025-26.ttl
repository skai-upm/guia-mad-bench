    ns1:inpersonHours "30 horas y 10 minutos (29%)"@es ;
    ns1:numberOfCredits 4.0 ;
    ns1:otherInformation """La asignatura se relaciona con los siguientes Objetivos de Desarrollo Sostenible:
ODS13: Acción por el clima.
ODS7: Energía asequible y no contaminante."""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "30 horas y 10 minutos"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/145009005/2025-26/eventSchedule> ;
    schema:description """La asignatura "Diseño Conceptual de Aerogeneradores" es una asignatura optativa de 4 ECTS que se imparte en el segundo semestre del cuarto curso de grado de la Escuela Técnica Superior de Ingeniería Aeronáutica y del Espacio. Se trata de una asignatura que pretende que el alumnado adquiera:
El conocimiento adecuado y aplicado a la ingeniería de los sistemas de aprovechamiento de energía eólica.
El conocimiento adecuado y aplicado a la ingeniería de los métodos de cálculo de diseño y proyecto de aerogeneradores; el uso de los parámetros más significativos en la aplicación teórica.
El conocimiento aplicado de aerodinámica, mecánica, ingeniería de aerogeneradores aplicada al problema eólico.
El conocimiento básico de la problemática climática y ambiental, y el papel de la energía eólica en la lucha contra el cambio climático.
La capacidad para identificar y resolver problemas aplicando, con creatividad, los conocimientos adquiridos.
El razonamiento crítico y la capacidad de asociación que posibiliten el aprendizaje continuo."""@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/cristobaljose.gallego%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/alvaro.cuerva%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/cristobaljose.gallego%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/oscar.lopez.garcia%40upm.es> ;
    schema:name "Diseño Conceptual de Aerogeneradores"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145009005/2025-26/CE03> a ns1:Competency ;
    ns1:competencyCode "CE03" ;
    ns1:competencyDescription "Conocimientos básicos sobre el uso y programación de los ordenadores, sistemas operativos, bases de datos y programas informáticos con aplicación en ingeniería."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145009005/2025-26/CE51> a ns1:Competency ;
    ns1:competencyCode "CE51" ;
    ns1:competencyDescription "Capacidad para relacionar fenómenos físicos distintos a través de un modelo matemático, aplicar las técnicas apropiadas para obtener información del mismo e interpretar los resultados"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145009005/2025-26/CE55> a ns1:Competency ;
    ns1:competencyCode "CE55" ;
    ns1:competencyDescription "Conocimiento adecuado y aplicado a la Ingeniería de los métodos de diseño y proyecto aeronáutico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145009005/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Capacidad para identificar y resolver problemas aplicando, con creatividad, los conocimientos adquiridos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145009005/2025-26/CG4> a ns1:Competency ;
    ns1:competencyCode "CG4" ;
    ns1:competencyDescription "Capacidad para integrarse y formar parte activa de equipos de trabajo. Trabajo en equipo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145009005/2025-26/CG9> a ns1:Competency ;
    ns1:competencyCode "CG9" ;
    ns1:competencyDescription "Razonamiento crítico y capacidad de asociación que posibiliten el aprendizaje continuo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145009005/2025-26/RA214> a ns1:LearningResult ;
    ns1:learningResultCode "RA214" ;
    ns1:learningResultDescription "Redactar informes técnicos y hacer exposiciones orales técnicas relacionadas con lo anterior."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145009005/2025-26/RA582> a ns1:LearningResult ;
    ns1:learningResultCode "RA582" ;
    ns1:learningResultDescription "RA01 Conocimiento, comprensión y aplicación de la aerodinámica de los rotores, las actuaciones y la controlabilidad de aerogeneradores."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145009005/2025-26/RA583> a ns1:LearningResult ;
    ns1:learningResultCode "RA583" ;
    ns1:learningResultDescription "RA02 Conocimiento, comprensión, aplicación y análisis del diseño preliminar de aerogeneradores y sus costes operacionales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145009005/2025-26/RA584> a ns1:LearningResult ;
    ns1:learningResultCode "RA584" ;
    ns1:learningResultDescription "RA03 Conocimiento de la simulación computacional del problema de diseño del aerogenerador."@es .

