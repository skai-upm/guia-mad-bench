<https://guia-kg.skai.etsisi.upm.es/resource/85003412/2025-26/CB3> a ns1:Competency ;
    ns1:competencyCode "CB3" ;
    ns1:competencyDescription "Que los estudiantes tengan la capacidad de reunir e interpretar datos relevantes (normalmente dentro de su área de estudio) para emitir juicios que incluyan una reflexión sobre temas relevantes de índole social, científica o ética"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003412/2025-26/CB4> a ns1:Competency ;
    ns1:competencyCode "CB4" ;
    ns1:competencyDescription "Que los estudiantes puedan transmitir información, ideas, problemas y soluciones a un público tanto especializado como no especializado"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003412/2025-26/CB5> a ns1:Competency ;
    ns1:competencyCode "CB5" ;
    ns1:competencyDescription "Que los estudiantes hayan desarrollado aquellas habilidades de aprendizaje necesarias para emprender estudios posteriores con un alto grado de autonomía"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003412/2025-26/CE%2015> a ns1:Competency ;
    ns1:competencyCode "CE 15" ;
    ns1:competencyDescription "Conocimiento de las características de los sistemas de propulsión naval"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003412/2025-26/CE%2024> a ns1:Competency ;
    ns1:competencyCode "CE 24" ;
    ns1:competencyDescription "Capacidad para la integración a bordo de los sistemas propulsores, teniendo en cuenta su empacho, peso, cargas dinámicas, impacto en la estanqueidad, el espacio necesario para su mantenimiento, etc."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003412/2025-26/CE%207> a ns1:Competency ;
    ns1:competencyCode "CE 7" ;
    ns1:competencyDescription "Conocimiento de los conceptos fundamentales de la mecánica de fluidos y de su aplicación a las carenas de buques y artefactos, y a las máquinas, equipos y sistemas navales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003412/2025-26/CG5> a ns1:Competency ;
    ns1:competencyCode "CG5" ;
    ns1:competencyDescription "Capacidad para la realización de mediciones, cálculos, valoraciones, tasaciones, peritaciones, estudios, informes, planos de labores y otros trabajos análogos en el ámbito de la Arquitectura Naval."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003412/2025-26/RA170> a ns1:LearningResult ;
    ns1:learningResultCode "RA170" ;
    ns1:learningResultDescription "Conocer la combinación de todos los tipos de generadores entre sí para gestionar la potencia generada"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003412/2025-26/RA171> a ns1:LearningResult ;
    ns1:learningResultCode "RA171" ;
    ns1:learningResultDescription "Conocer las características y diseño de la propulsión del buque"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003412/2025-26/RA172> a ns1:LearningResult ;
    ns1:learningResultCode "RA172" ;
    ns1:learningResultDescription "Conocer las aplicaciones de los sistemas térmicos para su aplicación auxiliar a bordo resultando en un aumento de la eficiencia energética del buque o artefacto"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003412/2025-26/RA173> a ns1:LearningResult ;
    ns1:learningResultCode "RA173" ;
    ns1:learningResultDescription "Conocer y comprender los sistemas de generación de energía a bordo y su aplicación a la producción eléctrica y a la propulsión del buque o artefacto marino"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/85003412/2025-26/RA174> a ns1:LearningResult ;
    ns1:learningResultCode "RA174" ;
    ns1:learningResultDescription "Analizar y aplicar el funcionamiento y diseño del motor Diésel, la turbina de gas y la planta de vapor"@es .

