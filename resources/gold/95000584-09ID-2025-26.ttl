        <https://guia-kg.skai.etsisi.upm.es/resource/s.iglesias%40upm.es> ;
    schema:name "Ingeniería en Cooperación para el Desarrollo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000584/2025-26/CB02> a ns1:Competency ;
    ns1:competencyCode "CB02" ;
    ns1:competencyDescription "Que los estudiantes sepan aplicar sus conocimientos a su trabajo o vocación de una forma profesional y posean las competencias que suelen demostrarse por medio de la elaboración y defensa de argumentos y la resolución de problemas dentro de su área de estudio"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000584/2025-26/CB03> a ns1:Competency ;
    ns1:competencyCode "CB03" ;
    ns1:competencyDescription "Que los estudiantes tengan la capacidad de reunir e interpretar datos relevantes (normalmente dentro de su área de estudio) para emitir juicios que incluyan una reflexión sobre temas relevantes de índole social, científica o ética"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000584/2025-26/CG02> a ns1:Competency ;
    ns1:competencyCode "CG02" ;
    ns1:competencyDescription "Desarrollar la capacidad de trabajar en equipo empleando metodologías ágiles para diseñar soluciones eficientes, fiables y robustas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000584/2025-26/CG10> a ns1:Competency ;
    ns1:competencyCode "CG10" ;
    ns1:competencyDescription "Desarrollar la capacidad de proponer e implementar soluciones y proyectos orientados a retos sociales basados en la responsabilidad social corporativa (RSC) y en los objetivos de desarrollo sostenible (ODS)."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000584/2025-26/RA167> a ns1:LearningResult ;
    ns1:learningResultCode "RA167" ;
    ns1:learningResultDescription "Adquisición de una visión objetiva y amplia de los actuales desequilibrios sociales y medioambientales; de sus causas, alcance y perspectivas de evolución."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000584/2025-26/RA168> a ns1:LearningResult ;
    ns1:learningResultCode "RA168" ;
    ns1:learningResultDescription "Conocimiento de la estructura y los instrumentos de la cooperación internacional para el desarrollo y que sean conscientes de su potencial contribución, como ingenieros, a la lucha contra la pobreza y la exclusión social."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/95000584/2025-26/RA169> a ns1:LearningResult ;
    ns1:learningResultCode "RA169" ;
    ns1:learningResultDescription "Conocimiento y aplicación de metodologías de planificación e intervención en proyectos de desarrollo con componente tecnológica."@es .

