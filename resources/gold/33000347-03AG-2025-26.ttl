<https://guia-kg.skai.etsisi.upm.es/resource/33000347/2025-26> a ns1:CourseGuide ;
    ns1:hasCompetency <https://guia-kg.skai.etsisi.upm.es/resource/33000347/2025-26/CE%206.12>,
        <https://guia-kg.skai.etsisi.upm.es/resource/33000347/2025-26/CE%206.7>,
