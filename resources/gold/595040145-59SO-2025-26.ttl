    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/enrique.rendon%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/martina.eckert%40upm.es> ;
    schema:name "Síntesis y Animación de Imágenes"@es .

