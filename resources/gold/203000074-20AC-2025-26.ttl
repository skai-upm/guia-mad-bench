    ns1:hasSyllabus <https://guia-kg.skai.etsisi.upm.es/resource/203000074/2025-26/syllabus> ;
    ns1:inpersonHours "87 horas (41.8%)"@es ;
    ns1:numberOfCredits 8.0 ;
    ns1:otherInformation """El Máster en Producción y Sanidad Animal en un Máster Interuniversitario en el que participan la UPM y la UCM. El profesor coordinador de esta asignatura es Roberto Sánchez Sánchez, adscrito al departamento de Sanidad Animal de la Facultad de Veterinaria de la Universidad Complutense de Madrid. La asignatura se relaciona con el ODS15.
La docencia de esta asignatura será presencial. No obstante, y en función de la disponibilidad de los profesores participantes, algunas sesiones podrían ser impartidas en formato no presencial."""@es ;
    ns1:periodEndingMonth "Junio"@es ;
    ns1:periodStartingMonth "Febrero"@es ;
    ns1:teachingPeriod "2025-26" ;
    ns1:teachingPeriodMonths "Febrero-Junio"@es ;
    ns1:totalHours "89 horas y 30 minutos"@es ;
    schema:activitiesWorkload "100%"@es ;
    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/203000074/2025-26/eventSchedule> ;
    schema:description "En la asignatura se estudiarán las principales enfermedades transmisibles que afectan a la sanidad de la producción avícola y cunícola, haciendo hincapié en sus agentes causales, los factores y mecanismos que afectan a su desarrollo, y sus lesiones más características. Por otro lado, se revisarán la situación epidemiológica actual de cada enfermedad, su impacto económico, y las medidas de prevención y control específicos. Todo ello con un enfoque eminentemente práctico mediante la resolución de casos clínicos."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/nora.formosorafferty%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/nora.formosorafferty%40upm.es> ;
    schema:name "Sanidad Animal en Aves y Conejos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000074/2025-26/CE01> a ns1:Competency ;
    ns1:competencyCode "CE01" ;
    ns1:competencyDescription "Adquirir unos conocimientos y unas destrezas adecuadas en producción y sanidad animal para poder plantear soluciones y resolver las problemáticas inherentes a las explotaciones ganaderas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000074/2025-26/CE02> a ns1:Competency ;
    ns1:competencyCode "CE02" ;
    ns1:competencyDescription "Aplicar conocimientos avanzados acerca de la gestión técnico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000074/2025-26/CE04> a ns1:Competency ;
    ns1:competencyCode "CE04" ;
    ns1:competencyDescription "Diseñar nuevas estrategias para mejorar la productividad de los modelos ganaderos, optimizando la utilización de los factores de producción, afrontando adecuadamente la temática del bienestar animal y minimizando el impacto ambiental de los mencionados modelos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000074/2025-26/CE05> a ns1:Competency ;
    ns1:competencyCode "CE05" ;
    ns1:competencyDescription "Dominar los aspectos éticos, legales, medioambientales y los protocolos de bioseguridad, que deben cumplir las empresas pecuarias y los trabajos experimentales realizados en producción animal y en sanidad animal."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000074/2025-26/CE08> a ns1:Competency ;
    ns1:competencyCode "CE08" ;
    ns1:competencyDescription "Conocer las metodologías de investigación disponibles en la producción animal y en la sanidad animal."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/203000074/2025-26/CE09> a ns1:Competency ;
    ns1:competencyCode "CE09" ;
    ns1:competencyDescription "Saber utilizar las herramientas y técnicas bioinformáticas más actuales a la investigación en producción animal y en sanidad animal."@es .

