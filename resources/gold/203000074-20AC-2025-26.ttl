        <https://guia-kg.skai.etsisi.upm.es/resource/203000074/2025-26/RA2>,
        <https://guia-kg.skai.etsisi.upm.es/resource/203000074/2025-26/RA3>,
        <https://guia-kg.skai.etsisi.upm.es/resource/203000074/2025-26/RA5>,
