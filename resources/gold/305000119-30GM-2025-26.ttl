<https://guia-kg.skai.etsisi.upm.es/resource/305000119/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Ecuaciones diferenciales ordinarias en una dimensión Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000119/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "2. Problemas de valor inicial. Existencia y unicidad de soluciones. Teoremas de Picard y Cauchy. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000119/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "3. Dependencia continua de parámetros y datos iniciales. Desigualdades de Gronwall. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000119/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "4. Introducción a la teoría cualitativa y los sistemas dinámicos. Flujo, órbitas, diagrama de fases. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000119/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "5. Estabilidad de los puntos de equilibrio. Conjuntos límite. Funciones de Lyapunov. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/305000119/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "6. Existencia de órbitas periódicas y ciclos límite. Teorema de Poincaré-Bendixon. Sin subniveles"@es .

