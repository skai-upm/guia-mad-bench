<https://guia-kg.skai.etsisi.upm.es/resource/43000154/2025-26/RA10> a ns1:LearningResult ;
    ns1:learningResultCode "RA10" ;
    ns1:learningResultDescription "Argumenta la resolucion de los problemas de gestion mediante logica cientifica y aplicando una metodologia razonada."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000154/2025-26/RA103> a ns1:LearningResult ;
    ns1:learningResultCode "RA103" ;
    ns1:learningResultDescription "Aplica técnicas de optimización a la resolución de problemas de sistemas de ingeniería civil"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000154/2025-26/RA109> a ns1:LearningResult ;
    ns1:learningResultCode "RA109" ;
    ns1:learningResultDescription "Hacer una presentación oral de sus conocimientos aplicados, mediante la resolución de casos prácticos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000154/2025-26/RA113> a ns1:LearningResult ;
    ns1:learningResultCode "RA113" ;
    ns1:learningResultDescription "Aplica y evalúa modelos avanzados para el proyecto y la explotación de infraestructuras de transporte"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000154/2025-26/RA12> a ns1:LearningResult ;
    ns1:learningResultCode "RA12" ;
    ns1:learningResultDescription "Ser capaz de identificar los problemas a resolver en dicha área de Ingeniería Civil, plantear y diseñar soluciones para resolverlos, dimensionar y calcular los parámetros de diseño en cada uno de los casos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000154/2025-26/RA124> a ns1:LearningResult ;
    ns1:learningResultCode "RA124" ;
    ns1:learningResultDescription "Analizar y describir las características de la demanda y oferta de de los puertos en el entorno del transporte para todo tipo de mercancías y pasajeros e identificar las variables explicativas así como su contexto histórico y evolución"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000154/2025-26/RA125> a ns1:LearningResult ;
    ns1:learningResultCode "RA125" ;
    ns1:learningResultDescription "Analizar y comprender cómo las características de las infraestructuras influyen en su comportamiento frente a la explotación de los servicios de transporte en función de las mercancías y los equipos empleados así como aplicar metodologías de estudios y evaluaciones de impacto ambiental"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000154/2025-26/RA126> a ns1:LearningResult ;
    ns1:learningResultCode "RA126" ;
    ns1:learningResultDescription "Describir y analizar la relación existente entre los actores del sector transporte y la relevancia del marco jurídico, organización, funciones y modelo de gestión"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000154/2025-26/RA127> a ns1:LearningResult ;
    ns1:learningResultCode "RA127" ;
    ns1:learningResultDescription "Comprender la relación entre construcción y conservación de obras de intercambio modal y su explotación posterior la interrelación de los condicionantes que impone infraestructuras y comprensión del funcionamiento de los ecosistemas y de los factores ambientales, capacidad de aplicación de metodologías de restauración ambiental"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000154/2025-26/RA128> a ns1:LearningResult ;
    ns1:learningResultCode "RA128" ;
    ns1:learningResultDescription "Describir y analizar procesos de planificación y gestión del transporte y de los aspectos medioambientales relacionados con las infraestructuras logísticas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000154/2025-26/RA63> a ns1:LearningResult ;
    ns1:learningResultCode "RA63" ;
    ns1:learningResultDescription "Estructurar, desde el punto de vista científico, una investigación en el área, consultando, sintetizando y estudiando las fuentes bibliográficas y las bases de datos básicas."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000154/2025-26/RA70> a ns1:LearningResult ;
    ns1:learningResultCode "RA70" ;
    ns1:learningResultDescription "Analizar con carácter crítico la parte metodológica de un proyecto de investigación, contemplando los recursos y los datos disponibles para la investigación. Proponer metodologías alternativas a un proyecto de investigación en concreto del área de Transporte y Territorio."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000154/2025-26/RA73> a ns1:LearningResult ;
    ns1:learningResultCode "RA73" ;
    ns1:learningResultDescription "Estructurar, desde el punto de vista científico, una investigación del área, consultando, sintetizando y estudiando las fuentes bibliográficas y las bases de datos básicas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000154/2025-26/RA74> a ns1:LearningResult ;
    ns1:learningResultCode "RA74" ;
    ns1:learningResultDescription "Conocer y familiarizarse con los medios de difusión científica más utilizados en el área del Transporte y Territorio (Congresos Nacionales, Congresos Internacionales, Revistas indexadas, etc.)"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000154/2025-26/RA76> a ns1:LearningResult ;
    ns1:learningResultCode "RA76" ;
    ns1:learningResultDescription "Conocer en detalle un conjunto mínimo de líneas de investigación vigentes en la UPM del área de Transporte y Territorio, así como sus limitaciones y los ámbitos de aplicación nacionales e internacionales."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000154/2025-26/RA92> a ns1:LearningResult ;
    ns1:learningResultCode "RA92" ;
    ns1:learningResultDescription "Capacidad para analizar y sintetizar los diversos contenidos de información de fuentes diversas"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000154/2025-26/RA93> a ns1:LearningResult ;
    ns1:learningResultCode "RA93" ;
    ns1:learningResultDescription "Capacidad para aplicar e integrar sus conocimientos técnicos hacia la consecución de un fin"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000154/2025-26/RA94> a ns1:LearningResult ;
    ns1:learningResultCode "RA94" ;
    ns1:learningResultDescription "Capacidad para organizar su propio trabajo de forma independiente, desarrollando habilidades profesionales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000154/2025-26/RA95> a ns1:LearningResult ;
    ns1:learningResultCode "RA95" ;
    ns1:learningResultDescription "Capacidad para desarrollar un trabajo profesional con responsabilidad"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000154/2025-26/RA96> a ns1:LearningResult ;
    ns1:learningResultCode "RA96" ;
    ns1:learningResultDescription "Capacidad para comunicarse de forma escrita y oral"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000154/2025-26/RA97> a ns1:LearningResult ;
    ns1:learningResultCode "RA97" ;
    ns1:learningResultDescription "Capacidad de plantear una metodología de investigación basada en el estado del arte. Desarrollar una aplicación en una de las líneas de investigación que valide la metodología"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000154/2025-26/RA98> a ns1:LearningResult ;
    ns1:learningResultCode "RA98" ;
    ns1:learningResultDescription "Capacidad de analizar los resultados y plantear futuros desarrollos de investigación"@es .

