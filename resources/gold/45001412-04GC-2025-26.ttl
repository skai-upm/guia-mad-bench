<https://guia-kg.skai.etsisi.upm.es/resource/45001412/2025-26/syllabus/0> a ns1:SyllabusItem ;
    ns1:itemIndex 0 ;
    ns1:syllabusDescription "1. Hidrometría aplicada al diseño de obras civiles."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001412/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. Variables hidrológicas. Redes de medida. Instrumentación. Pluviómetros y pluviógrafos. Hidráulica de las estaciones de aforo. Curva de gasto. Tratamiento de datos hidrométricos. Análisis de calidad de datos. Aplicación al estudio hidrológico profesional. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001412/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "4.1. Tipos de modelos: modelos conceptuales y físicamente basados, agregados y distribuidos, de eventos y continuos. El modelo HEC-HMS: precipitación, generación y transporte de escorrentía Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001412/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "4.2. Usos en la ingeniería civil. Ejemplos y aplicación al estudio hidrológico profesional. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001412/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "5. La planificación hidrológica y la gestión de los recursos hidráulicos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001412/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "5.1. Conceptos. La directiva marco del agua. Normativa aplicada y comparada. Contenido de los planes hidrológicos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001412/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "6. Estudios de recursos hidráulicos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001412/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "6.1. Fuentes de información, análisis crítico de datos. Métodos basados en datos. Modelos de regresión. Fórmulas climatológicas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001412/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "6.2. Modelos de precipitación-aportación. El modelo de Témez. El modelo SIMPA. Restitución al régimen natural. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001412/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "6.3. Análisis de incertidumbre. Aplicación al estudio hidrológico profesional. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001412/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "7. Regulación de sistemas hidráulicos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001412/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "7.1. Usos del agua. Demandas. Proyecciones futuras. Evaluación de infraestructura existente en el sistema, interconexiones, reglas de operación. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001412/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "2. Estadística aplicada a la hidrología de diseño"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001412/2025-26/syllabus/20> a ns1:SyllabusItem ;
    ns1:itemIndex 20 ;
    ns1:syllabusDescription "7.2. Regulación. Métodos de cálculo de regulación. Garantías de suministro. Métodos probabilísticos. Aplicación al estudio hidrológico profesional. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001412/2025-26/syllabus/21> a ns1:SyllabusItem ;
    ns1:itemIndex 21 ;
    ns1:syllabusDescription "8. Modelos de gestión de recursos hídricos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001412/2025-26/syllabus/22> a ns1:SyllabusItem ;
    ns1:itemIndex 22 ;
    ns1:syllabusDescription "8.1. Modelos de gestión de recursos. Modelos en embalses. El modelo AQUATOOL y WEAP. Análisis de incertidumbre. Análisis probabilístico. Aplicación al estudio hidrológico profesional. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001412/2025-26/syllabus/23> a ns1:SyllabusItem ;
    ns1:itemIndex 23 ;
    ns1:syllabusDescription "9. Efecto del cambio climático en sistemas hidráulicos. Diseño de medidas de adaptación"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001412/2025-26/syllabus/24> a ns1:SyllabusItem ;
    ns1:itemIndex 24 ;
    ns1:syllabusDescription "9.1. Definición de escenarios climáticos. Fuentes de información. Análisis de incertidumbre. Cuantificación del impacto del cambio climático en sistemas hidráulicos y efecto de posibles medidas de adaptación Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001412/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "2.1. Período de retorno. Función de probabilidad y de distribución. Cálculo de Funciones de distribución y métodos de estimación de parámetros. Test estadísticos. Cálculo de cuantiles. Regresión y correlación. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001412/2025-26/syllabus/4> a ns1:SyllabusItem ;
    ns1:itemIndex 4 ;
    ns1:syllabusDescription "2.2. Análisis de valores extremos. Análisis de calidad de datos. Diseño hidrológico de obras civiles. Aplicación al estudio hidrológico profesional. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001412/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "3. Cálculo hidrometeorológico de avenidas de proyecto"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001412/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "3.1. Normativa aplicable. Determinación de la lluvia de proyecto. Curvas IDF. Coeficiente de simultaneidad. Cuantificación de abstracciones. Métodos de transformación lluvia-escorrentía. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001412/2025-26/syllabus/7> a ns1:SyllabusItem ;
    ns1:itemIndex 7 ;
    ns1:syllabusDescription "3.2. Estimación de caudales de diseño e hidrogramas de proyecto. Propagación de ondas de avenidas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001412/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "3.3. Cálculo estocástico de avenidas. Aplicaciones en la ingeniería civil. Aplicación al estudio hidrológico profesional. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/45001412/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
    ns1:syllabusDescription "4. Modelos hidrometeorológicos aplicados al diseño de infraestructuras"@es .

