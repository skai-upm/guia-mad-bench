    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/145006404/2025-26/eventSchedule> ;
    schema:description "Introducción al diseño de estructuras de hormigón armado, principalmente de Edificación. Se exponen temas relacionados con la tecnología del hormigón en aspectos históricos, propiedades de los materiales, bases de cálculo, análisis estructural, normativa y tipología"@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/antonia.pacios%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/antonia.pacios%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/jesusmaria.rodriguez%40upm.es> ;
    schema:name "Estructuras de Hormigon"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145006404/2025-26/CE60> a ns1:Competency ;
    ns1:competencyCode "CE60" ;
    ns1:competencyDescription "Conocimiento aplicado de: edificación; electricidad; electrotecnia; electrónica; mecánica del vuelo; hidráulica; instalaciones aeroportuarias; ciencia y tecnología de los materiales; teoría de estructuras; mantenimiento y explotación de aeropuertos; transporte aéreo, cartografía, topografía, geotecnia y meteorología."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145006404/2025-26/CE61> a ns1:Competency ;
    ns1:competencyCode "CE61" ;
    ns1:competencyDescription "Conocimiento adecuado y aplicado a la Ingeniería de: La mecánica de fractura del medio continuo y los planteamientos dinámicos, de fatiga y de inestabilidad estructural."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145006404/2025-26/CG3> a ns1:Competency ;
    ns1:competencyCode "CG3" ;
    ns1:competencyDescription "Capacidad para identificar y resolver problemas aplicando, con creatividad, los conocimientos adquiridos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145006404/2025-26/CG9> a ns1:Competency ;
    ns1:competencyCode "CG9" ;
    ns1:competencyDescription "Razonamiento crítico y capacidad de asociación que posibiliten el aprendizaje continuo"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145006404/2025-26/RA246> a ns1:LearningResult ;
    ns1:learningResultCode "RA246" ;
    ns1:learningResultDescription "Conocimiento, comprensión y capacidad de aplicación de lo aprendido para establecer las combinaciones de acciones a tener en cuenta en el proyecto de una estructura aeroportuaria de hormigón."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145006404/2025-26/RA247> a ns1:LearningResult ;
    ns1:learningResultCode "RA247" ;
    ns1:learningResultDescription "Conocimiento, comprensión y capacidad de aplicación de lo aprendido para predimensionar estructuras aeroportuarias de hormigón armado."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145006404/2025-26/RA248> a ns1:LearningResult ;
    ns1:learningResultCode "RA248" ;
    ns1:learningResultDescription "Conocimiento, comprensión y capacidad de análisis y síntesis de la teoría de cálculo del hormigón armado como para poder proyectar las armaduras necesarias de los diferentes componentes de los tipos estructurales aeroportuarios o efectuar la comprobación de su diseño, en su caso."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145006404/2025-26/RA249> a ns1:LearningResult ;
    ns1:learningResultCode "RA249" ;
    ns1:learningResultDescription "Conocimiento, comprensión y capacidad de análisis y síntesis de la teoría de cálculo del hormigón armado como para poder diseñar y evaluar detalles constructivos en los que intervenga la ferralla, observando la durabilidad y constructividad del diseño."@es .

