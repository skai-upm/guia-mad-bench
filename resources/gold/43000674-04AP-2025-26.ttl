    schema:courseSchedule <https://guia-kg.skai.etsisi.upm.es/resource/43000674/2025-26/eventSchedule> ;
    schema:description "La asignatura contempla los aspectos técnicos, científicos y normativos de las tipologías de hormigones no convencionales. Se tratan además, temas relacionados con la investigación, proyecto, diseño de mezclas, puesta en obra, curado y durabilidad de estos hormigones. Incluye conceptos experimentales, aspectos prácticos y ejemplos de aplicaciones."@es ;
    schema:director <https://guia-kg.skai.etsisi.upm.es/resource/jaime.galvez%40upm.es> ;
    schema:inLanguage "Castellano"@es ;
    schema:instructor <https://guia-kg.skai.etsisi.upm.es/resource/alejandro.enfedaque%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/encarnacion.reyes%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/jaime.galvez%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/jesus.diaz%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/ma.sanjuan%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/marcos.garcia%40upm.es>,
        <https://guia-kg.skai.etsisi.upm.es/resource/mariadelpilar.alaejos%40upm.es> ;
    schema:name "Materiales de Refuerzo y Hormigones Especiales"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000674/2025-26/C4> a ns1:Competency ;
    ns1:competencyCode "C4" ;
    ns1:competencyDescription "[Proviene de las competencias CE1 y CE4]: Capacidad para el análisis del comportamiento mecánico y la durabilidad de estructuras de ingeniería civil y edificación, sus materiales y sus cimentaciones TIPO: Competencias"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000674/2025-26/K2> a ns1:Competency ;
    ns1:competencyCode "K2" ;
    ns1:competencyDescription "[Proviene de la competencia CG2]: Identifica los componentes determinantes para ejercer las funciones de diseño, construcción, conservación y evaluación técnica de estructuras, cimentaciones y materiales, mediante el uso de normativa y documentación científica nacional e internacional. TIPO: Conocimientos o contenidos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000674/2025-26/K3> a ns1:Competency ;
    ns1:competencyCode "K3" ;
    ns1:competencyDescription "[Proviene de la competencia CG3]: Identifica y explica los aspectos determinantes para diseñar, analizar e interpretar experimentos relevantes, así como usar varios lenguajes de computación, programas de análisis y simulación, y modelos avanzados en ingeniería estructural, geotécnica y de materiales estructurales. TIPO: Conocimientos o contenidos"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000674/2025-26/RA48> a ns1:LearningResult ;
    ns1:learningResultCode "RA48" ;
    ns1:learningResultDescription "Identifica las propiedades de los materiales de construcción en función del uso y condiciones ambientales y selecciona los apropiados."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000674/2025-26/RA49> a ns1:LearningResult ;
    ns1:learningResultCode "RA49" ;
    ns1:learningResultDescription "Aplica la normativa de control y calidad de los materiales de construcción a partir de sus fundamentos."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000674/2025-26/RA50> a ns1:LearningResult ;
    ns1:learningResultCode "RA50" ;
    ns1:learningResultDescription "Establece las necesidades de materiales de construcción y de sistemas estructurales en distintas condiciones ambientales. Identifica las características microestructurales que determinan las propiedades mecánicas y de durabilidad de los materiales de construcción."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000674/2025-26/RA51> a ns1:LearningResult ;
    ns1:learningResultCode "RA51" ;
    ns1:learningResultDescription "Explica los mecanismos físico"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/43000674/2025-26/RA52> a ns1:LearningResult ;
    ns1:learningResultCode "RA52" ;
    ns1:learningResultDescription "Aplica técnicas de elaboración y caracterización de materiales de construcción."@es .

