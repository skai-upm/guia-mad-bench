<https://guia-kg.skai.etsisi.upm.es/resource/145005305/2025-26/syllabus/1> a ns1:SyllabusItem ;
    ns1:itemIndex 1 ;
    ns1:syllabusDescription "1.1. 1.1. Modelo de un sistema de telecomunicación. Definición de información. Fuentes de información. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005305/2025-26/syllabus/10> a ns1:SyllabusItem ;
    ns1:itemIndex 10 ;
    ns1:syllabusDescription "4.1. 4.1. Muestreo. Teorema del muestreo. Reconstrucción de señales a partir de sus muestras, interpolación. Efectos del submuestreo. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005305/2025-26/syllabus/11> a ns1:SyllabusItem ;
    ns1:itemIndex 11 ;
    ns1:syllabusDescription "4.2. 4.2. Modulación por amplitud, posición y anchura de impulsos. Modulación PCM, ancho de banda. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005305/2025-26/syllabus/12> a ns1:SyllabusItem ;
    ns1:itemIndex 12 ;
    ns1:syllabusDescription "4.3. 4.3. Interferencia entre símbolos, criterios de Nyquist. Modulación por codificación de pulso diferencial. Multiplexación de señales por división en el tiempo. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005305/2025-26/syllabus/13> a ns1:SyllabusItem ;
    ns1:itemIndex 13 ;
    ns1:syllabusDescription "5. Tema 5. MODULACIONES DIGITALES, ANÁLISIS SEÑAL-ESPACIO."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005305/2025-26/syllabus/14> a ns1:SyllabusItem ;
    ns1:itemIndex 14 ;
    ns1:syllabusDescription "5.1. 5.1. Transmisión digital modulada. Análisis de las modulaciones en el plano I-Q, espacio de la señal, regiones de decisión. Propiedades de los tipos de modulaciones digitales. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005305/2025-26/syllabus/15> a ns1:SyllabusItem ;
    ns1:itemIndex 15 ;
    ns1:syllabusDescription "5.2. 5.2. Modulaciones digitales ASK, FSK, PSK. Modulaciones digitales multiniveles QAM. Eficiencia espectral. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005305/2025-26/syllabus/16> a ns1:SyllabusItem ;
    ns1:itemIndex 16 ;
    ns1:syllabusDescription "6. Tema 6. MODULACIÓN EN ESPECTRO EXPANDIDO."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005305/2025-26/syllabus/17> a ns1:SyllabusItem ;
    ns1:itemIndex 17 ;
    ns1:syllabusDescription "6.1. 6.1. Secuencias seudoaleatorias, secuencias de máxima longitud, propiedades. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005305/2025-26/syllabus/18> a ns1:SyllabusItem ;
    ns1:itemIndex 18 ;
    ns1:syllabusDescription "6.2. 6.2. Tipos de sistemas de espectro expandido. Margen sobre la interferencia. Comportamientos de sistemas de espectro expandido frente al ruido y la interferencia. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005305/2025-26/syllabus/19> a ns1:SyllabusItem ;
    ns1:itemIndex 19 ;
    ns1:syllabusDescription "7. Tema 7. ELECTRÓNICA DE COMUNICACIONES."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005305/2025-26/syllabus/2> a ns1:SyllabusItem ;
    ns1:itemIndex 2 ;
    ns1:syllabusDescription "1.2. 1.2. Redundancia y velocidad media de información. Capacidad de un sistema, fórmula de Shannon. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005305/2025-26/syllabus/20> a ns1:SyllabusItem ;
    ns1:itemIndex 20 ;
    ns1:syllabusDescription "7.1. 7.1. Bucles de seguimiento de fase (PLL), sintetizadores de frecuencia, aplicaciones. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005305/2025-26/syllabus/21> a ns1:SyllabusItem ;
    ns1:itemIndex 21 ;
    ns1:syllabusDescription "7.2. 7.2. Sensibilidad y ruido en receptores. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005305/2025-26/syllabus/22> a ns1:SyllabusItem ;
    ns1:itemIndex 22 ;
    ns1:syllabusDescription "8. Tema 8. CODIFICACIÓN PARA EL CONTROL DE ERROR."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005305/2025-26/syllabus/23> a ns1:SyllabusItem ;
    ns1:itemIndex 23 ;
    ns1:syllabusDescription "8.1. 8.1. Codificación, códigos bloque, códigos convolucionales, códigos FEC, Hamming y CRC. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005305/2025-26/syllabus/24> a ns1:SyllabusItem ;
    ns1:itemIndex 24 ;
    ns1:syllabusDescription "9. Tema 9. REDES, EL MODELO OSI Y PROTOCOLOS DE RED."@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005305/2025-26/syllabus/25> a ns1:SyllabusItem ;
    ns1:itemIndex 25 ;
    ns1:syllabusDescription "9.1. 9.1. Estructura del Modelo OSI, arquitectura de red. Capas del modelo OSI. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005305/2025-26/syllabus/26> a ns1:SyllabusItem ;
    ns1:itemIndex 26 ;
    ns1:syllabusDescription "9.2. 9.2. Capas de transporte, protocolos. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005305/2025-26/syllabus/27> a ns1:SyllabusItem ;
    ns1:itemIndex 27 ;
    ns1:syllabusDescription "9.3. 9.3. Estándar IEEE 802.x. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005305/2025-26/syllabus/3> a ns1:SyllabusItem ;
    ns1:itemIndex 3 ;
    ns1:syllabusDescription "2. Tema 2. SEÑALES CONTINUAS Y DISCRETAS."@es .

