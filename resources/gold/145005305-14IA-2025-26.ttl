    ns1:itemIndex 7 ;
    ns1:syllabusDescription "3.1. 3.1. Modulaciones lineales en AM, DBL y BLU. Moduladores, demoduladores asíncronos y síncronos, SNR. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005305/2025-26/syllabus/8> a ns1:SyllabusItem ;
    ns1:itemIndex 8 ;
    ns1:syllabusDescription "3.2. 3.2. Modulaciones en frecuencia y fase. Modulación angular en banda estrecha y ancha. Moduladores y demoduladores. Relación señal ruido en la modulación angular, efecto umbral. Multiplexación por división en frecuencia. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005305/2025-26/syllabus/9> a ns1:SyllabusItem ;
    ns1:itemIndex 9 ;
