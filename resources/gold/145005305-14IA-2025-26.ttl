    ns1:itemIndex 4 ;
    ns1:syllabusDescription "2.1. 2.1. Representación en series de Fourier de señales periódicas continuas y discretas, propiedades. Filtrado. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005305/2025-26/syllabus/5> a ns1:SyllabusItem ;
    ns1:itemIndex 5 ;
    ns1:syllabusDescription "2.2. 2.2. Transformada continua de Fourier para señales aperiódicas continuas. Transformada continua de Fourier para señales aperiódicas discretas. Sin subniveles"@es .

<https://guia-kg.skai.etsisi.upm.es/resource/145005305/2025-26/syllabus/6> a ns1:SyllabusItem ;
    ns1:itemIndex 6 ;
    ns1:syllabusDescription "3. Tema 3. MODULACIÓN DE ONDA CONTINUA."@es .

